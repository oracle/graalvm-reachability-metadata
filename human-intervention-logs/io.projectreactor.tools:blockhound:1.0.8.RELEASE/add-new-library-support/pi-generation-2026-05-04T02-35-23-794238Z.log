       throw error;\n    61\t            }\n    62\t        } catch (RuntimeException exception) {\n    63\t            if (!isCausedByUnsupportedFeatureError(exception)) {\n    64\t                throw exception;\n    65\t            }\n    66\t        } finally {\n    67\t            if (securityManagerInstalled) {\n    68\t                System.setSecurityManager(previousSecurityManager);\n    69\t            }\n    70\t            restoreSafeProperty(previousSafeProperty);\n    71\t        }\n    72\t    }\n    73\t\n    74\t    private static void injectClassThroughReflectionDispatcher() {\n    75\t        boolean unsafeInjectionAvailable = ClassInjector.UsingUnsafe.isAvailable();\n    76\t        boolean reflectionInjectionAvailable = ClassInjector.UsingReflection.isAvailable();\n    77\t\n    78\t        String packageName = PACKAGE_PREFIX + Long.toUnsignedString(System.nanoTime());\n    79\t        String className = packageName + \".Injected\";\n    80\t        byte[] classFile = new ByteBuddy()\n    81\t                .subclass(Object.class)\n    82\t                .name(className)\n    83\t                .make()\n    84\t                .getBytes();\n    85\t\n    86\t        PackagePredefiningClassLoader classLoader = new PackagePredefiningClassLoader(\n    87\t                ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeInjectionTest.class.getClassLoader());\n    88\t        PackageDefinitionStrategy packageDefinitionStrategy = new PredefiningPackageDefinitionStrategy(classLoader);\n    89\t        ClassInjector classInjector = new ClassInjector.UsingReflection(\n    90\t                classLoader,\n    91\t                null,\n    92\t                packageDefinitionStrategy,\n    93\t                false);\n    94\t\n    95\t        try {\n    96\t            Map<String, Class<?>> injectedTypes = classInjector.injectRaw(\n    97\t                    Collections.singletonMap(className, classFile));\n    98\t\n    99\t            Class<?> injectedType = injectedTypes.get(className);\n   100\t            assertThat(reflectionInjectionAvailable).isTrue();\n   101\t            assertThat(injectedTypes).containsOnlyKeys(className);\n   102\t            assertThat(injectedType.getName()).isEqualTo(className);\n   103\t            assertThat(injectedType.getClassLoader()).isSameAs(classLoader);\n   104\t            assertThat(classLoader.getDefinedPackageForTest(packageName)).isNotNull();\n   105\t        } catch (UnsupportedOperationException exception) {\n   106\t            assertThat(unsafeInjectionAvailable).isFalse();\n   107\t            assertThat(exception).hasMessageContaining(\"using reflection\");\n   108\t        }\n   109\t    }\n   110\t\n   111\t    private static boolean installSecurityManagerIfSupported(SecurityManager securityManager) {\n   112\t        try {\n   113\t            System.setSecurityManager(securityManager);\n   114\t            return System.getSecurityManager() == securityManager;\n   115\t        } catch (UnsupportedOperationException | SecurityException exception) {\n   116\t            return false;\n   117\t        }\n   118\t    }\n   119\t\n   120\t    private static boolean isCausedByUnsupportedFeatureError(Throwable throwable) {\n   121\t        Throwable current = throwable.getCause();\n   122\t        while (current != null) {\n   123\t            if (current instanceof Error error && NativeImageSupport.isUnsupportedFeatureError(error)) {\n   124\t                return true;\n   125\t            }\n   126\t            current = current.getCause();\n   127\t        }\n   128\t        return false;\n   129\t    }\n   130\t\n   131\t    private static void restoreSafeProperty(String previousSafeProperty) {\n   132\t        if (previousSafeProperty == null) {\n   133\t            System.clearProperty(BYTE_BUDDY_SAFE_PROPERTY);\n   134\t        } else {\n   135\t            System.setProperty(BYTE_BUDDY_SAFE_PROPERTY, previousSafeProperty);\n   136\t