ap;\n\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\n\nimport reactor.blockhound.shaded.net.bytebuddy.ByteBuddy;\nimport reactor.blockhound.shaded.net.bytebuddy.dynamic.loading.ClassInjector;\nimport reactor.blockhound.shaded.net.bytebuddy.dynamic.loading.PackageDefinitionStrategy;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeInjectionTest {\n    private static final String BYTE_BUDDY_SAFE_PROPERTY = \"reactor.blockhound.shaded.net.bytebuddy.safe\";\n    private static final String PACKAGE_NAME = \"io_projectreactor_tools.blockhound.generated.unsafeinjection\";\n\n    @Test\n    void reflectionInjectorUsesUnsafeAccessorForClassAndPackageOperations() {\n        String previousSafeProperty = System.getProperty(BYTE_BUDDY_SAFE_PROPERTY);\n        SecurityManager previousSecurityManager = System.getSecurityManager();\n        boolean securityManagerInstalled = false;\n\n        try {\n            System.setProperty(BYTE_BUDDY_SAFE_PROPERTY, \"false\");\n            securityManagerInstalled = installSecurityManagerIfSupported(new PermissiveSecurityManager());\n\n            injectClassThroughReflectionDispatcher();\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        } catch (IllegalStateException exception) {\n            if (!(exception.getCause() instanceof Error error\n                    && NativeImageSupport.isUnsupportedFeatureError(error))) {\n                throw exception;\n            }\n        } catch (UnsupportedOperationException exception) {\n            assertThat(exception)\n                    .hasMessageContaining(\"Cannot\")\n                    .hasMessageContaining(\"using reflection\");\n        } finally {\n            if (securityManagerInstalled) {\n                System.setSecurityManager(previousSecurityManager);\n            }\n            restoreSafeProperty(previousSafeProperty);\n        }\n    }\n\n    private static void injectClassThroughReflectionDispatcher() {\n        String className = PACKAGE_NAME + \".Injected\" + Long.toUnsignedString(System.nanoTime());\n        byte[] classFile = new ByteBuddy()\n                .subclass(Object.class)\n                .name(className)\n                .make()\n                .getBytes();\n\n        PackagePredefiningClassLoader classLoader = new PackagePredefiningClassLoader(\n                ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeInjectionTest.class.getClassLoader());\n        PackageDefinitionStrategy packageDefinitionStrategy = new PredefiningPackageDefinitionStrategy(classLoader);\n        ClassInjector classInjector = new ClassInjector.UsingReflection(\n                classLoader,\n                null,\n                packageDefinitionStrategy,\n                false);\n\n        Map<String, Class<?>> injectedTypes = classInjector.injectRaw(Collections.singletonMap(className, classFile));\n\n        assertThat(injectedTypes).containsOnlyKeys(className);\n        assertThat(injectedTypes.get(className).getName()).isEqualTo(className);\n        assertThat(injectedTypes.get(className).getClassLoader()).isSameAs(classLoader);\n        assertThat(classLoader.getDefinedPackageForTest(PACKAGE_NAME)).isNotNull();\n    }\n\n    private static boolean installSecurityManagerIfSupported(SecurityManager securityManager) {\n        try {\n            System.setSecurityManager(securityManager);\n            return System.getSecurityManager() == securityManager;\n        } catch (UnsupportedOperationException | SecurityException exception) {\n            return false;\n        }\n    }\n\n    private static void restoreSafeProperty(String previousSafeProperty) {\n        if (previousSafeProperty == null) {\n            System.clearProperty(BYTE_BUDDY_SAFE_PROPERTY);\n        } else {\n            System.setProperty(BYTE_BUDDY_SAFE_PROPERTY, previousSafeProperty);\n        }\n    }\n\n    private static final class PackagePredefiningClassLoader extends ClassLoader {\n        private PackagePredefiningClassLoader(ClassLoader parent) {\n            super(parent);\n        }\n\n        private void definePackageIfAbsent(String packageName) {\n            if (getDefinedPackage(packageName) == null) {\n                definePackage(packageName, null, null, null, null, null, null, null);\n            }\n        }\n\n        private Package getDefinedPackageForTest(String packageName) {\n            return getDefinedPackage(packageName);\n        }\n    }\n\n    private static final class PredefiningPackageDefinitionStrategy implements PackageDefinitionStrategy {\n        private final PackagePredefiningClassLoader classLoader;\n\n        private PredefiningPackageDefinitionStrategy(PackagePredefiningClassLoader classLoader) {\n            this.classLoader = classLoader;\n        }\n\n        @Override\n        public Definition define(ClassLoader classLoader, String packageName, String typeName) {\n            assertThat(classLoader).isSameAs(this.classLoader);\n            assertThat(typeName).startsWith(packageName + \".\");\n            return new PredefiningDefinition(this.classLoader, packageName);\n        }\n    }\n\n    private static final class PredefiningDefinition implements PackageDefinitionStrategy.Definition {\n        private final PackagePredefiningClassLoader classLoader;\n        private final String packageName;\n\n        private PredefiningDefinition(PackagePredefiningClassLoader classLoader, String packageName) {\n            this.classLoader = classLoader;\n            this.packageName = packageName;\n        }\n\n        @Override\n        public boolean isDefined() {\n            return true;\n        }\n\n        @Override\n        public String getSpecificationTitle() {\n            classLoader.definePackageIfAbsent(packageName);\n            return null;\n        }\n\n        @Override\n        public String getSpecificationVersion() {\n            return null;\n        }\n\n        @Override\n        public String getSpecificationVendor() {\n            return null;\n        }\n\n        @Override\n        public String getImplementationTitle() {\n            return null;\n        }\n\n        @Override\n        public String getImplementationVersion() {\n            return null;\n        }\n\n        @Override\n        public String getImplementationVendor() {\n            return null;\n        }\n\n        @Override\n        public URL getSealBase() {\n            return null;\n        }\n\n        @Override\n        public boolean isCompatibleTo(Package definedPackage) {\n            return definedPackage != null && packageName.equals(definedPackage.getName());\n        }\n    }\n\n    private static final class PermissiveSecurityManager extends SecurityManager {\n        @Override\n        public void checkPermission(Permission permission) {\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777862095215}]}
