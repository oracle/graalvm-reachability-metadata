ate static void restoreSafeProperty(String previousSafeProperty) {\n        if (previousSafeProperty == null) {\n            System.clearProperty(BYTE_BUDDY_SAFE_PROPERTY);\n        } else {\n            System.setProperty(BYTE_BUDDY_SAFE_PROPERTY, previousSafeProperty);\n        }\n    }\n\n    private static final class PackagePredefiningClassLoader extends ClassLoader {\n        private PackagePredefiningClassLoader(ClassLoader parent) {\n            super(parent);\n        }\n\n        private void definePackageIfAbsent(String packageName) {\n            if (getDefinedPackage(packageName) == null) {\n                definePackage(packageName, null, null, null, null, null, null, null);\n            }\n        }\n\n        private Package getDefinedPackageForTest(String packageName) {\n            return getDefinedPackage(packageName);\n        }\n    }\n\n    private static final class PredefiningPackageDefinitionStrategy implements PackageDefinitionStrategy {\n        private final PackagePredefiningClassLoader classLoader;\n\n        private PredefiningPackageDefinitionStrategy(PackagePredefiningClassLoader classLoader) {\n            this.classLoader = classLoader;\n        }\n\n        @Override\n        public Definition define(ClassLoader classLoader, String packageName, String typeName) {\n            assertThat(classLoader).isSameAs(this.classLoader);\n            assertThat(typeName).startsWith(packageName + \".\");\n            return new PredefiningDefinition(this.classLoader, packageName);\n        }\n    }\n\n    private static final class PredefiningDefinition implements PackageDefinitionStrategy.Definition {\n        private final PackagePredefiningClassLoader classLoader;\n        private final String packageName;\n\n        private PredefiningDefinition(PackagePredefiningClassLoader classLoader, String packageName) {\n            this.classLoader = classLoader;\n            this.packageName = packageName;\n        }\n\n        @Override\n        public boolean isDefined() {\n            return true;\n        }\n\n        @Override\n        public String getSpecificationTitle() {\n            classLoader.definePackageIfAbsent(packageName);\n            return null;\n        }\n\n        @Override\n        public String getSpecificationVersion() {\n            return null;\n        }\n\n        @Override\n        public String getSpecificationVendor() {\n            return null;\n        }\n\n        @Override\n        public String getImplementationTitle() {\n            return null;\n        }\n\n        @Override\n        public String getImplementationVersion() {\n            return null;\n        }\n\n        @Override\n        public String getImplementationVendor() {\n            return null;\n        }\n\n        @Override\n        public URL getSealBase() {\n            return null;\n        }\n\n        @Override\n        public boolean isCompatibleTo(Package definedPackage) {\n            return definedPackage != null && packageName.equals(definedPackage.getName());\n        }\n    }\n\n    private static final class PermissiveSecurityManager extends SecurityManager {\n        @Override\n        public void checkPermission(java.security.Permission permission) {\n        }\n    }\n}\n"}
