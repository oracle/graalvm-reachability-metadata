[tool-call] delta {"path":"tests/src/io.projectreactor.tools/blockhound/1.0.8.RELEASE/src/test/java/io_projectreactor_tools/blockhound/ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeInjectionTest.java","edits":[{"oldText":"            injectClassThroughReflectionDispatcher();\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        } finally {\n","newText":"            injectClassThroughReflectionDispatcher();\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        } catch (IllegalStateException exception) {\n            if (!(exception.getCause() instanceof Error error\n                    && NativeImageSupport.isUnsupportedFeatureError(error))) {\n                throw exception;\n            }\n        } catch (UnsupportedOperationException exception) {\n            assertThat(exception)\n                    .hasMessageContaining(\"Cannot\")\n                    .hasMessageContaining(\"using reflection\");\n        } finally {\n"}]}
