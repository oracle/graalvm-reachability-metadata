lCall", "id": "call_ZnHt1REmS7rgGEtfIWJ10v53|fc_016c67c62a44ff910169f806c0a730819183084ce9b8ad0f5a", "name": "write", "arguments": {"path": "tests/src/io.projectreactor.tools/blockhound/1.0.8.RELEASE/src/test/java/io_projectreactor_tools/blockhound/ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeInjectionTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_projectreactor_tools.blockhound;\n\nimport java.security.Permission;\n\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\n\nimport reactor.blockhound.shaded.net.bytebuddy.ByteBuddy;\nimport reactor.blockhound.shaded.net.bytebuddy.dynamic.loading.ClassInjector;\nimport reactor.blockhound.shaded.net.bytebuddy.dynamic.loading.ClassInjector.UsingReflection.Dispatcher;\nimport reactor.blockhound.shaded.net.bytebuddy.dynamic.loading.ClassInjector.UsingReflection.Dispatcher.CreationAction;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\n@SuppressWarnings(\"removal\")\npublic class ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeInjectionTest {\n    private static final String BYTE_BUDDY_SAFE_PROPERTY = \"reactor.blockhound.shaded.net.bytebuddy.safe\";\n    private static final String PACKAGE_PREFIX = \"io_projectreactor_tools.blockhound.generated.unsafeinjection\";\n\n    @Test\n    void unsafeInjectionDispatcherDefinesPackagesAndClassesThroughGeneratedAccessor() {\n        String previousSafeProperty = System.getProperty(BYTE_BUDDY_SAFE_PROPERTY);\n        SecurityManager previousSecurityManager = System.getSecurityManager();\n        boolean securityManagerInstalled = false;\n\n        try {\n            System.setProperty(BYTE_BUDDY_SAFE_PROPERTY, \"false\");\n            securityManagerInstalled = installSecurityManagerIfSupported(new PermissiveSecurityManager());\n\n            exerciseUnsafeInjectionDispatcher();\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        } finally {\n            if (securityManagerInstalled) {\n                System.setSecurityManager(previousSecurityManager);\n            }\n            restoreSafeProperty(previousSafeProperty);\n        }\n    }\n\n    private static void exerciseUnsafeInjectionDispatcher() {\n        assertThat(ClassInjector.UsingUnsafe.isAvailable()).isTrue();\n\n        Dispatcher.Initializable initializable = CreationAction.INSTANCE.run();\n        assertThat(initializable.isAvailable()).isTrue();\n        Dispatcher dispatcher = initializable.initialize();\n\n        InjectingClassLoader classLoader = new InjectingClassLoader(\n                ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeInjectionTest.class.getClassLoader());\n        String packageName = PACKAGE_PREFIX + Long.toUnsignedString(System.nanoTime());\n        String className = packageName + \".Injected\";\n        byte[] classFile = new ByteBuddy()\n                .subclass(Object.class)\n                .name(className)\n                .make()\n                .getBytes();\n\n        assertThat(dispatcher.getClassLoadingLock(classLoader, className)).isNotNull();\n        assertThat(dispatcher.findClass(classLoader, className)).isNull();\n        assertThat(dispatcher.getDefinedPackage(classLoader, packageName)).isNull();\n\n        Package definedPackage = dispatcher.definePackage(\n                classLoader,\n                packageName,\n                null,\n                null,\n                null,\n                null,\n                null,\n                null,\n                null);\n        assertThat(definedPackage.getName()).isEqualTo(packageName);\n        assertThat(dispatcher.getDefinedPackage(classLoader, packageName)).isSameAs(definedPackage);\n        assertThat(dispatcher.getPackage(classLoader, packageName)).isSameAs(definedPackage);\n\n        Class<?> definedClass = dispatcher.defineClass(classLoader, className, classFile, null);\n        assertThat(definedClass.getName()).isEqualTo(className);\n        assertThat(definedClass.getClassLoader()).isSameAs(classLoader);\n        assertThat(dispatcher.findClass(classLoader, className)).isSameAs(definedClass);\n    }\n\n    private static boolean installSecurityManagerIfSupported(SecurityManager securityManager) {\n        try {\n            System.setSecurityManager(securityManager);\n            return System.getSecurityManager() == securityManager;\n        } catch (UnsupportedOperationException | SecurityException exception) {\n            return false;\n        }\n    }\n\n    private static void restoreSafeProperty(String previousSafeProperty) {\n        if (previousSafeProperty == null) {\n            System.clearProperty(BYTE_BUDDY_SAFE_PROPERTY);\n        } else {\n            System.setProperty(BYTE_BUDDY_SAFE_PROPERTY, previousSafeProperty);\n        }\n    }\n\n    private static final class InjectingClassLoader extends ClassLoader {\n        private InjectingClassLoader(ClassLoader parent) {\n            super(parent);\n        }\n    }\n\n    private static final class PermissiveSecurityManager extends SecurityManager {\n        @Override\n        public void checkPermission(Permission permission) {\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 723, "output": 2310, "cacheRead": 77824, "cacheWrite": 0, "totalTokens": 80857, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777862318596, "responseId": "resp_016c67c62a44ff910169f806af7e2c819185f3ed0ad9c8d1c8"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_ZnHt1REmS7rgGEtfIWJ10v53|fc_016c67c62a44ff910169f806c0a730819183084ce9b8ad0f5a", "to