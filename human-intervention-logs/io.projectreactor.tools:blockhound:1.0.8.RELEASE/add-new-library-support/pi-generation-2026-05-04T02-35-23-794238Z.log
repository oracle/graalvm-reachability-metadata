     240	    static void exerciseDispatcherMethods() throws Exception {
     241	        Accessor accessor = new Accessor();
     242	        Dispatcher dispatcher = new HarnessDispatcher(
     243	                accessor,
     244	                accessorMethod("findLoadedClass", ClassLoader.class, String.class),
     245	                accessorMethod("defineClass", ClassLoader.class, String.class, byte[].class,
     246	                        int.class, int.class, ProtectionDomain.class),
     247	                accessorMethod("getDefinedPackage", ClassLoader.class, String.class),
     248	                accessorMethod("getPackage", ClassLoader.class, String.class),
     249	                accessorMethod("definePackage", ClassLoader.class, String.class, String.class,
     250	                        String.class, String.class, String.class, String.class, String.class, URL.class),
     251	                accessorMethod("getClassLoadingLock", ClassLoader.class, String.class)
     252	        ).initialize();
     253	
     254	        DispatcherClassLoader classLoader = new DispatcherClassLoader(
     255	                ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeInjectionTest.class
     256	                        .getClassLoader());
     257	        String packageName = PACKAGE_PREFIX + "dispatcher" + Long.toUnsignedString(java.lang.System.nanoTime());
     258	        String className = packageName + ".Injected";
     259	        byte[] classFile = new ByteBuddy()
     260	                .subclass(Object.class)
     261	                .name(className)
     262	                .make()
     263	                .getBytes();
     264	
     265	        assertThat(dispatcher.getClassLoadingLock(classLoader, className)).isSameAs(classLoader);
     266	        assertThat(dispatcher.findClass(classLoader, className)).isNull();
     267	        assertThat(dispatcher.getDefinedPackage(classLoader, packageName)).isNull();
     268	
     269	        Package definedPackage = dispatcher.definePackage(
     270	                classLoader, packageName, null, null, null, null, null, null, null);
     271	        assertThat(definedPackage.getName()).isEqualTo(packageName);
     272	        assertThat(dispatcher.getDefinedPackage(classLoader, packageName)).isSameAs(definedPackage);
     273	        assertThat(dispatcher.getPackage(classLoader, packageName)).isSameAs(definedPackage);
     274	
     275	        Class<?> definedClass = dispatcher.defineClass(classLoader, className, classFile, null);
     276	        assertThat(definedClass.getName()).isEqualTo(className);
     277	        assertThat(definedClass.getClassLoader()).isSameAs(classLoader);
     278	        assertThat(dispatcher.findClass(classLoader, className)).isSameAs(definedClass);
     279	    }
