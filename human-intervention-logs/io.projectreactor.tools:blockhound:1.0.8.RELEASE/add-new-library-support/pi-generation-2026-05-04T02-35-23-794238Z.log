  package io_projectreactor_tools.blockhound;
  
  import java.lang.reflect.Method;
  import java.net.URL;
  import java.security.Permission;
  import java.security.ProtectionDomain;
  import java.util.Collections;
  import java.util.Map;
  
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  
  import reactor.blockhound.shaded.net.bytebuddy.ByteBuddy;
  import reactor.blockhound.shaded.net.bytebuddy.dynamic.loading.ClassInjector;
  import reactor.blockhound.shaded.net.bytebuddy.dynamic.loading.PackageDefinitionStrategy;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  @SuppressWarnings("removal")
  public class ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeInjectionTest {
      private static final String BYTE_BUDDY_SAFE_PROPERTY = "reactor.blockhound.shaded.net.bytebuddy.safe";
      private static final String PACKAGE_PREFIX = "io_projectreactor_tools.blockhound.generated.unsafeinjection";
  
      @Test
      void unsafeInjectionDispatcherInvokesAccessorMethods() {
          try {
              UnsafeInjectionHarness.exerciseDispatcherMethods();
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          } catch (RuntimeException exception) {
              if (!isCausedByUnsupportedFeatureError(exception)) {
                  throw exception;
              }
          } catch (Exception exception) {
              throw new IllegalStateException(exception);
          }
      }
  
      @Test
      void reflectionInjectorUsesUnsafeAccessorForClassAndPackageOperations() {
          String previousSafeProperty = System.getProperty(BYTE_BUDDY_SAFE_PROPERTY);
          SecurityManager previousSecurityManager = System.getSecurityManager();
          boolean securityManagerInstalled = false;
  
          try {
              System.setProperty(BYTE_BUDDY_SAFE_PROPERTY, "false");
              securityManagerInstalled = installSecurityManagerIfSupported(new PermissiveSecurityManager());
  
              injectClassThroughReflectionDispatcher();
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          } catch (RuntimeException exception) {
              if (!isCausedByUnsupportedFeatureError(exception)) {
                  throw exception;
              }
          } finally {
              if (securityManagerInstalled) {
                  System.setSecurityManager(previousSecurityManager);
              }
              restoreSafeProperty(previousSafeProperty);
          }
      }
  
      private static void injectClassThroughReflectionDispatcher() {
          boolean unsafeInjectionAvailable = ClassInjector.UsingUnsafe.isAvailable();
          boolean reflectionInjectionAvailable = ClassInjector.UsingReflection.isAvailable();
  
          String packageName = PACKAGE_PREFIX + Long.toUnsignedString(System.nanoTime());
          String className = packageName + ".Injected";
          byte[] classFile = new ByteBuddy()
                  .subclass(Object.class)
                  .name(className)
                  .make()
                  .getBytes();
  
          PackagePredefiningClassLoader classLoader = new PackagePredefiningClassLoader(
                  ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeInjectionTest.class.getClassLoader());
          PackageDefinitionStrategy packageDefinitionStrategy = new PredefiningPackageDefinitionStrategy(classLoader);
          ClassInjector classInjector = new ClassInjector.UsingReflection(
                  classLoader,
                  null,
                  packageDefinitionStrategy,
                  false);
  
          try {
              Map<String, Class<?>> injectedTypes = classInjector.injectRaw(
                      Collections.singletonMap(className, classFile));
  
              Class<?> injectedType = injectedTypes.get(className);
              assertThat(reflectionInjectionAvailable).isTrue();
              assertThat(injectedTypes).containsOnlyKeys(className);
              assertThat(injectedType.getName()).isEqualTo(className);
              assertThat(injectedType.getClassLoader()).isSameAs(classLoader);
              assertThat(classLoader.getDefinedPackageForTest(packageName)).isNotNull();
          } catch (UnsupportedOperationException exception) {
              assertThat(unsafeInjectionAvailable).isFalse();
              assertThat(exception).hasMessageContaining("using reflection");
          }
      }
  
      private static boolean installSecurityManagerIfSupported(SecurityManager securityManager) {
          try {
              System.setSecurityManager(securityManager);
              return System.getSecurityManager() == securityManager;
          } catch (UnsupportedOperationException | SecurityException exception) {
              return false;
          }
      }
  
      private static boolean isCausedByUnsupportedFeatureError(Throwable throwable) {
          Throwable current = throwable.getCause();
          while (current != null) {
              if (current instanceof Error error && NativeImageSupport.isUnsupportedFeatureError(error)) {
                  return true;
              }
              current = current.getCause();
          }
          return false;
      }
  
      private static void restoreSafeProperty(String previousSafeProperty) {
          if (previousSafeProperty == null) {
              System.clearProperty(BYTE_BUDDY_SAFE_PROPERTY);
          } else {
              System.setProperty(BYTE_BUDDY_SAFE_PROPERTY, previousSafeProperty);
          }
      }
  
      private static final class PackagePredefiningClassLoader extends ClassLoader {
          private PackagePredefiningClassLoader(ClassLoader parent) {
              super(parent);
          }
  
          private void definePackageIfAbsent(String packageName) {
              if (getDefinedPackage(packageName) == null) {
                  definePackage(packageName, null, null, null, null, null, null, null);
              }
          }
  
          private Package getDefinedPackageForTest(String packageName) {
              return getDefinedPackage(packageName);
          }
      }
  
      private static final class PredefiningPackageDefinitionStrategy implements PackageDefinitionStrategy {
          private final PackagePredefiningClassLoader classLoader;
  
          private PredefiningPackageDefinitionStrategy(PackagePredefiningClassLoader classLoader) {
              this.classLoader = classLoader;
          }
  
          @Override
          public Definition define(ClassLoader classLoader, String packageName, String typeName) {
              assertThat(classLoader).isSameAs(this.classLoader);
              assertThat(typeName).startsWith(packageName + ".");
              return new PredefiningDefinition(this.classLoader, packageName);
          }
      }
  
      private static final class PredefiningDefinition implements PackageDefinitionStrategy.Definition {
          private final PackagePredefiningClassLoader classLoader;
          private final String packageName;
  
          private PredefiningDefinition(PackagePredefiningClassLoader classLoader, String packageName) {
              this.classLoader = classLoader;
              this.packageName = packageName;
          }
  
          @Override
          public boolean isDefined() {
              return true;
          }
  
          @Override
          public String getSpecificationTitle() {
              classLoader.definePackageIfAbsent(packageName);
              return null;
          }
  
          @Override
          public String getSpecificationVersion() {
              return null;
          }
  
          @Override
          public String getSpecificationVendor() {
              return null;
          }
  
          @Override
          public String getImplementationTitle() {
              return null;
          }
  
          @Override
          public String getImplementationVersion() {
              return null;
          }
  
          @Override
          public String getImplementationVendor() {
              return null;
          }
  
          @Override
          public URL getSealBase() {
              return null;
          }
  
          @Override
          public boolean isCompatibleTo(Package definedPackage) {
              return definedPackage != null && packageName.equals(definedPackage.getName());
          }
      }
  
      private static final class PermissiveSecurityManager extends SecurityManager {
          @Override
          public void checkPermission(Permission permission) {
          }
      }
  }
  
  final class UnsafeInjectionHarness extends ClassInjector.UsingReflection {
      private static final String PACKAGE_PREFIX = "io_projectreactor_tools.blockhound.generated.unsafeinjection";
  
      private UnsafeInjectionHarness(ClassLoader classLoader) {
          super(classLoader);
      }
  
      static void exerciseDispatcherMethods() throws Exception {
          Accessor accessor = new Accessor();
          Dispatcher dispatcher = new HarnessDispatcher(
                  accessor,
                  accessorMethod("findLoadedClass", ClassLoader.class, String.class),
                  accessorMethod("defineClass", ClassLoader.class, String.class, byte[].class,
                          int.class, int.class, ProtectionDomain.class),
                  accessorMethod("getDefinedPackage", ClassLoader.class, String.class),
                  accessorMethod("getPackage", ClassLoader.class, String.class),
                  accessorMethod("definePackage", ClassLoader.class, String.class, String.class,
                          String.class, String.class, String.class, String.class, String.class, URL.class),
                  accessorMethod("getClassLoadingLock", ClassLoader.class, String.class)
          ).initialize();
  
          DispatcherClassLoader classLoader = new DispatcherClassLoader(
                  ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeInjectionTest.class
                          .getClassLoader());
          String packageName = PACKAGE_PREFIX + "dispatcher" + Long.toUnsignedString(java.lang.System.nanoTime());
          String className = packageName + ".Injected";
          byte[] classFile = new ByteBuddy()
                  .subclass(Object.class)
                  .name(className)
                  .make()
                  .getBytes();
  
          assertThat(dispatcher.getClassLoadingLock(classLoader, className)).isSameAs(classLoader);
          assertThat(dispatcher.findClass(classLoader, className)).isNull();
          assertThat(dispatcher.getDefinedPackage(classLoader, packageName)).isNull();
  
          Package definedPackage = dispatcher.definePackage(
                  classLoader, packageName, null, null, null, null, null, null, null);
          assertThat(definedPackage.getName()).isEqualTo(packageName);
          assertThat(dispatcher.getDefinedPackage(classLoader, packageName)).isSameAs(definedPackage);
          assertThat(dispatcher.getPackage(classLoader, packageName)).isSameAs(definedPackage);
  
          Class<?> definedClass = dispatcher.defineClass(classLoader, className, classFile, null);
          assertThat(definedClass.getName()).isEqualTo(className);
          assertThat(definedClass.getClassLoader()).isSameAs(classLoader);
          assertThat(dispatcher.findClass(classLoader, className)).isSameAs(definedClass);
      }
  
      private static Method accessorMethod(String name, Class<?>... parameterTypes) throws NoSuchMethodException {
          return Accessor.class.getMethod(name, parameterTypes);
      }
  
      private static final class HarnessDispatcher extends Dispatcher.UsingUnsafeInjection {
          private HarnessDispatcher(Object accessor, Method findLoadedClass, Method defineClass,
                  Method getDefinedPackage, Method getPackage, Method definePackage,
                  Method getClassLoadingLock) {
              super(accessor, findLoadedClass, defineClass, getDefinedPackage, getPackage,
                      definePackage, getClassLoadingLock);
          }
      }
  }
  
  final class Accessor {
      public Object getClassLoadingLock(ClassLoader classLoader, String name) {
          return classLoader;
      }
  
      public Class<?> findLoadedClass(ClassLoader classLoader, String name) {
          try {
              return Class.forName(name, false, classLoader);
          } catch (ClassNotFoundException exception) {
              return null;
          }
      }
  
      public Class<?> defineClass(ClassLoader classLoader, String name, byte[] binaryRepresentation,
              int offset, int length, ProtectionDomain protectionDomain) {
          return ((DispatcherClassLoader) classLoader)
                  .defineClassForTest(name, binaryRepresentation, offset, length, protectionDomain);
      }
  
      public Package getDefinedPackage(ClassLoader classLoader, String name) {
          return ((DispatcherClassLoader) classLoader).getDefinedPackageForTest(name);
      }
  
      public Package getPackage(ClassLoader classLoader, String name) {
          return ((DispatcherClassLoader) classLoader).getPackageForTest(name);
      }
  
      public Package definePackage(ClassLoader classLoader, String name, String specificationTitle,
              String specificationVersion, String specificationVendor, String implementationTitle,
              String implementationVersion, String implementationVendor, URL sealBase) {
          return ((DispatcherClassLoader) classLoader).definePackageForTest(
                  name,
                  specificationTitle,
                  specificationVersion,
                  specificationVendor,
                  implementationTitle,
                  implementationVersion,
                  implementationVendor,
                  sealBase);
      }
  }
  
  final class DispatcherClassLoader extends ClassLoader {
      DispatcherClassLoader(ClassLoader parent) {
          super(parent);
      }
  
      Class<?> defineClassForTest(String name, byte[] binaryRepresentation, int offset,
              int length, ProtectionDomain protectionDomain) {
          return defineClass(name, binaryRepresentation, offset, length, protectionDomain);
      }
  
      Package definePackageForTest(String name, String specificationTitle,
              String specificationVersion, String specificationVendor, String implementationTitle,
              String implementationVersion, String implementationVendor, URL sealBase) {
          return definePackage(name, specificationTitle, specificationVersion, specificationVendor,
                  implementationTitle, implementationVersion, implementationVendor, sealBase);
      }
  
      Package getDefinedPackageForTest(String name) {
          return getDefinedPackage(name);
      }
  
      Package getPackageForTest(String name) {
          return getPackage(name);
      }
  }
