Name;\n   177\t        }\n   178\t\n   179\t        @Override\n   180\t        public boolean isDefined() {\n   181\t            return true;\n   182\t        }\n   183\t\n   184\t        @Override\n   185\t        public String getSpecificationTitle() {\n   186\t            classLoader.definePackageIfAbsent(packageName);\n   187\t            return null;\n   188\t        }\n   189\t\n   190\t        @Override\n   191\t        public String getSpecificationVersion() {\n   192\t            return null;\n   193\t        }\n   194\t\n   195\t        @Override\n   196\t        public String getSpecificationVendor() {\n   197\t            return null;\n   198\t        }\n   199\t\n   200\t        @Override\n   201\t        public String getImplementationTitle() {\n   202\t            return null;\n   203\t        }\n   204\t\n   205\t        @Override\n   206\t        public String getImplementationVersion() {\n   207\t            return null;\n   208\t        }\n   209\t\n   210\t        @Override\n   211\t        public String getImplementationVendor() {\n   212\t            return null;\n   213\t        }\n   214\t\n   215\t        @Override\n   216\t        public URL getSealBase() {\n   217\t            return null;\n   218\t        }\n   219\t\n   220\t        @Override\n   221\t        public boolean isCompatibleTo(Package definedPackage) {\n   222\t            return definedPackage != null && packageName.equals(definedPackage.getName());\n   223\t        }\n   224\t    }\n   225\t\n   226\t    private static final class UnsafeInjectionHarness extends ClassInjector.UsingReflection {\n   227\t        private UnsafeInjectionHarness(ClassLoader classLoader) {\n   228\t            super(classLoader);\n   229\t        }\n   230\t\n   231\t        private static void exerciseDispatcherMethods() throws Exception {\n   232\t            Accessor accessor = new Accessor();\n   233\t            Dispatcher dispatcher = new HarnessDispatcher(\n   234\t                    accessor,\n   235\t                    accessorMethod(\"findLoadedClass\", ClassLoader.class, String.class),\n   236\t                    accessorMethod(\"defineClass\", ClassLoader.class, String.class, byte[].class,\n   237\t                            int.class, int.class, ProtectionDomain.class),\n   238\t                    accessorMethod(\"getDefinedPackage\", ClassLoader.class, String.class),\n   239\t                    accessorMethod(\"getPackage\", ClassLoader.class, String.class),\n   240\t                    accessorMethod(\"definePackage\", ClassLoader.class, String.class, String.class,\n   241\t                            String.class, String.class, String.class, String.class, String.class, URL.class),\n   242\t                    accessorMethod(\"getClassLoadingLock\", ClassLoader.class, String.class)\n   243\t            ).initialize();\n   244\t\n   245\t            DispatcherClassLoader classLoader = new DispatcherClassLoader(\n   246\t                    ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeInjectionTest.class\n   247\t                            .getClassLoader());\n   248\t            String packageName = PACKAGE_PREFIX + \"dispatcher\" + Long.toUnsignedString(System.nanoTime());\n   249\t            String className = packageName + \".Injected\";\n   250\t            byte[] classFile = new ByteBuddy()\n   251\t                    .subclass(Object.class)\n   252\t                    .name(className)\n   253\t                    .make()\n   254\t                    .getBytes();\n   255\t\n   256\t            assertThat(dispatcher.getClassLoadingLock(classLoader, className)).isSameAs(classLoader);\n   257\t            assertThat(dispatcher.findClass(classLoader, className)).isNull();\n   258\t            assertThat(dispatcher.getDefinedPackage(classLoader, packageName)).isNull();\n   259\t\n   260\t            Package definedPackage = dispatcher.definePackage(\n   261\t                    classLoader, packageName, null, null, 