on.annotation.AnnotationDescription;\n\nimport java.lang.annotation.Retention;\nimport java.lang.annotation.RetentionPolicy;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class AnnotationDescriptionInnerAnnotationInvocationHandlerTest {\n    @Test\n    void loadsAnnotationDescriptionAsAnnotationProxyAndComparesItWithRuntimeAnnotation() {\n        AnnotationDescription annotationDescription = AnnotationDescription.Builder.ofType(SampleAnnotation.class)\n                .define(\"value\", \"alpha\")\n                .define(\"count\", 42)\n                .define(\"type\", String.class)\n                .build();\n\n        SampleAnnotation generated = annotationDescription.prepare(SampleAnnotation.class).load();\n        SampleAnnotation runtimeAnnotation = AnnotatedSample.class.getAnnotation(SampleAnnotation.class);\n\n        assertThat(generated.annotationType()).isEqualTo(SampleAnnotation.class);\n        assertThat(generated.value()).isEqualTo(\"alpha\");\n        assertThat(generated.count()).isEqualTo(42);\n        assertThat(generated.type()).isEqualTo(String.class);\n        assertThat(generated).isEqualTo(runtimeAnnotation);\n        assertThat(generated.hashCode()).isEqualTo(runtimeAnnotation.hashCode());\n        assertThat(generated.toString()).contains(\"alpha\");\n    }\n\n    @Retention(RetentionPolicy.RUNTIME)\n    public @interface SampleAnnotation {\n        String value();\n\n        int count() default 7;\n\n        Class<?> type() default Void.class;\n    }\n\n    @SampleAnnotation(value = \"alpha\", count = 42, type = String.class)\n    static class AnnotatedSample {\n    }\n}\n"}], "isError": false, "timestamp": 1781092839312}, {"role": "toolResult", "toolCallId": "call_7EK8jDRGl9Q67SJVneJ4AEpX|fc_04641a8cc84ecb1a016a2951e721008190911da397a3433b75", "toolName": "read", "content": [{"type": "text", "text": "ENOENT: no such file or directory, access '/home/vjovanov/c/forge/forge2/graalvm-reachability-metadata/forge/local