\t                null,\n    80\t                null,\n    81\t                null,\n    82\t                null);\n    83\t\n    84\t        Package definedPackage = dispatcher.getDefinedPackage(targetClassLoader, packageName);\n    85\t\n    86\t        return definedPackage.getName();\n    87\t    }\n    88\t\n    89\t    private static final class DirectAccessor extends Dispatcher.Direct {\n    90\t        private DirectAccessor(\n    91\t                Method findLoadedClass,\n    92\t                Method defineClass,\n    93\t                Method getDefinedPackage,\n    94\t                Method getPackage,\n    95\t                Method definePackage) {\n    96\t            super(findLoadedClass, defineClass, getDefinedPackage, getPackage, definePackage);\n    97\t        }\n    98\t\n    99\t        private static Dispatcher.Initializable create() throws Exception {\n   100\t            return new DirectAccessor(\n   101\t                    PackageDefiningClassLoaderForDirect.class.getMethod(\"findLoadedClassForDirect\", String.class),\n   102\t                    PackageDefiningClassLoaderForDirect.class.getMethod(\n   103\t                            \"defineClassForDirect\",\n   104\t                            String.class,\n   105\t                            byte[].class,\n   106\t                            int.class,\n   107\t                            int.class,\n   108\t                            ProtectionDomain.class),\n   109\t                    getDefinedPackage(),\n   110\t                    PackageDefiningClassLoaderForDirect.class.getMethod(\"getPackageForDirect\", String.class),\n   111\t                    PackageDefiningClassLoaderForDirect.class.getMethod(\n   112\t                            \"definePackageForDirect\",\n   113\t                            String.class,\n   114\t                            String.class,\n   115\t                            String.class,\n   116\t                            String.class,\n   117\t                            String.class,\n   118\t                            String.class,\n   119\t                            String.class,\n   120\t                            URL.class));\n   121\t        }\n   122\t\n   123\t        private static Method getDefinedPackage() throws Exception {\n   124\t            try {\n   125\t                return ClassLoader.class.getMethod(\"getDefinedPackage\", String.class);\n   126\t            } catch (NoSuchMethodException ignored) {\n   127\t                return null;\n   128\t            }\n   129\t        }\n   130\t\n   131\t        @Override\n   132\t        public Object getClassLoadingLock(ClassLoader classLoader, String name) {\n   133\t            return classLoader;\n   134\t        }\n   135\t    }\n   136\t}\n   137\t\n   138\tfinal class PackageDefiningClassLoaderForDirect extends URLClassLoader {\n   139\t    PackageDefiningClassLoaderForDirect(ClassLoader parent) {\n   140\t        super(new URL[0], parent);\n   141\t    }\n   142\t\n   143\t    public Class<?> findLoadedClassForDirect(String name) {\n   144\t        return findLoadedClass(name);\n   145\t    }\n   146\t\n   147\t    public Class<?> defineClassForDirect(\n   148\t            String name,\n   149\t            byte[] binaryRepresentation,\n   150\t            int offset,\n   151\t            int length,\n   152\t            ProtectionDomain protectionDomain) {\n   153\t        return defineClass(name, binaryRepresentation, offset, length, protectionDomain);\n   154\t    }\n   155\t\n   156\t    public Package getPackageForDirect(String name) {\n   157\t        return super.getPackage(name);\n   158\t    }\n   159\t\n   160\t    public Package definePackageForDirect(\n   161\t            String name,\n   162\t            String specificationTitle,\n   163\t            String specificationVersion,\n   164\t            String specificationVendor,\n   165\t            String implementationTitle,\n   166\t            String implemen