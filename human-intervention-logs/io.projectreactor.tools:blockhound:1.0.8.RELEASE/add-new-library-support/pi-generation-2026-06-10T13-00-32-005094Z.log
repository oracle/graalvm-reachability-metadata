 java.lang.System.nanoTime();\n    73\t        dispatcher.definePackage(\n    74\t                targetClassLoader,\n    75\t                packageName,\n    76\t                null,\n    77\t                null,\n    78\t                null,\n    79\t                null,\n    80\t                null,\n    81\t                null,\n    82\t                null);\n    83\t\n    84\t        Package definedPackage = dispatcher.getDefinedPackage(targetClassLoader, packageName);\n    85\t\n    86\t        return definedPackage.getName();\n    87\t    }\n    88\t\n    89\t    private static final class DirectAccessor extends Dispatcher.Direct {\n    90\t        private DirectAccessor(\n    91\t                Method findLoadedClass,\n    92\t                Method defineClass,\n    93\t                Method getDefinedPackage,\n    94\t                Method getPackage,\n    95\t                Method definePackage) {\n    96\t            super(findLoadedClass, defineClass, getDefinedPackage, getPackage, definePackage);\n    97\t        }\n    98\t\n    99\t        private static Dispatcher.Initializable create() throws Exception {\n   100\t            return new DirectAccessor(\n   101\t                    accessible(ClassLoader.class.getDeclaredMethod(\"findLoadedClass\", String.class)),\n   102\t                    accessible(ClassLoader.class.getDeclaredMethod(\n   103\t                            \"defineClass\",\n   104\t                            String.class,\n   105\t                            byte[].class,\n   106\t                            int.class,\n   107\t                            int.class,\n   108\t                            ProtectionDomain.class)),\n   109\t                    ClassLoader.class.getMethod(\"getDefinedPackage\", String.class),\n   110\t                    accessible(ClassLoader.class.getDeclaredMethod(\"getPackage\", String.class)),\n   111\t                    accessible(ClassLoader.class.getDeclaredMethod(\n   112\t                            \"definePackage\",\n   113\t                            String.class,\n   114\t                            String.class,\n   115\t                            String.class,\n   116\t                            String.class,\n   117\t                            String.class,\n   118\t                            String.class,\n   119\t                            String.class,\n   120\t                            URL.class)));\n   121\t        }\n   122\t\n   123\t        private static Method accessible(Method method) {\n   124\t            method.setAccessible(true);\n   125\t            return method;\n   126\t        }\n   127\t\n   128\t        @Override\n   129\t        public Object getClassLoadingLock(ClassLoader classLoader, String name) {\n   130\t            return classLoader;\n   131\t        }\n   132\t    }\n   133\t}\n"}], "isError": false, "timestamp": 1781097088596}]}
