      69	
      70	    String defineAndReadPackage() throws Exception {
      71	        Dispatcher dispatcher = DirectAccessor.create().initialize();
      72	        String packageName = PACKAGE_PREFIX + java.lang.System.nanoTime();
      73	        dispatcher.definePackage(
      74	                targetClassLoader,
      75	                packageName,
      76	                null,
