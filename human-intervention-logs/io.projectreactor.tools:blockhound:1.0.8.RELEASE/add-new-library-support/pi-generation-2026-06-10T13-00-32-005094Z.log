tion ignored) {\n            return false;\n        }\n    }\n\n    public static final class PermissiveSecurityManager extends SecurityManager {\n        @Override\n        public void checkPermission(Permission permission) {\n            // Permit all operations while the direct dispatcher permission check is exercised.\n        }\n\n        @Override\n        public void checkPermission(Permission permission, Object context) {\n            // Permit all operations while the direct dispatcher permission check is exercised.\n        }\n    }\n\n    private static final class DirectDispatcherAccessor extends ClassInjector.UsingReflection {\n        private static final String PACKAGE_PREFIX = \"io_projectreactor_tools.blockhound.generated.direct\";\n\n        private final ClassLoader targetClassLoader;\n\n        private DirectDispatcherAccessor(ClassLoader targetClassLoader) {\n            super(targetClassLoader);\n            this.targetClassLoader = targetClassLoader;\n        }\n\n        private String defineAndReadPackage() throws Exception {\n            Dispatcher dispatcher = DirectAccessor.makeDirect().initialize();\n            String packageName = PACKAGE_PREFIX + System.nanoTime();\n            dispatcher.definePackage(\n                    targetClassLoader,\n                    packageName,\n                    null,\n                    null,\n                    null,\n                    null,\n                    null,\n                    null,\n                    null);\n\n            Package definedPackage = dispatcher.getDefinedPackage(targetClassLoader, packageName);\n\n            return definedPackage.getName();\n        }\n\n        private abstract static class DirectAccessor extends Dispatcher.Direct {\n            private DirectAccessor(\n                    Method findLoadedClass,\n                    Method defineClass,\n                    Method getDefinedPackage,\n                    Method getPackage,\n                    Metho