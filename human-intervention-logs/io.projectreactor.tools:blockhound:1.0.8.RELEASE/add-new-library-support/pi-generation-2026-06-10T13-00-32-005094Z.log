nimport java.net.URLClassLoader;\nimport java.security.Permission;\nimport java.security.ProtectionDomain;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\n@SuppressWarnings({\"deprecation\", \"removal\"})\npublic class ClassInjectorInnerUsingReflectionInnerDispatcherInnerDirectTest {\n    @Test\n    void directDispatcherChecksSecurityManagerAndReadsDefinedPackage() throws Exception {\n        SecurityManager previousSecurityManager = System.getSecurityManager();\n        boolean securityManagerChanged = installPermissiveSecurityManager();\n        try (PackageDefiningClassLoaderForDirect classLoader = new PackageDefiningClassLoaderForDirect(\n                getClass().getClassLoader())) {\n            DirectDispatcherAccessorForDirect accessor = new DirectDispatcherAccessorForDirect(classLoader);\n\n            assertThat(accessor.defineAndReadPackage())\n                    .startsWith(DirectDispatcherAccessorForDirect.PACKAGE_PREFIX);\n        } finally {\n            if (securityManagerChanged) {\n                System.setSecurityManager(previousSecurityManager);\n            }\n        }\n    }\n\n    private static boolean installPermissiveSecurityManager() {\n        try {\n            System.setSecurityManager(new PermissiveSecurityManagerForDirect());\n            return System.getSecurityManager() != null;\n        } catch (UnsupportedOperationException ignored) {\n            return false;\n        }\n    }\n}\n\nfinal class PermissiveSecurityManagerForDirect extends SecurityManager {\n    @Override\n    public void checkPermission(Permission permission) {\n        // Permit all operations while the direct dispatcher permission check is exercised.\n    }\n\n    @Override\n    public void checkPermission(Permission permission, Object context) {\n        // Permit all operations while the direct dispatcher permission check is exercised.\n    }\n}\n\nfinal class DirectDispatcherAccessorForDirect extends ClassInjector.UsingReflection {\n    static final String PACKAGE_PREFIX = \"io_projectreactor_tools.blockhound.generated.direct\";\n\n    private final PackageDefiningClassLoaderForDirect targetClassLoader;\n\n    DirectDispatcherAccessorForDirect(PackageDefiningClassLoaderForDirect targetClassLoader) {\n        super(targetClassLoader);\n        this.targetClassLoader = targetClassLoader;\n    }\n\n    String defineAndReadPackage() throws Exception {\n        Dispatcher dispatcher = DirectAccessor.create().initialize();\n        String packageName = PACKAGE_PREFIX + java.lang.System.nanoTime();\n        targetClassLoader.definePackageForDirect(\n                packageName,\n                null,\n                null,\n                null,\n                null,\n                null,\n                null,\n                null);\n\n        Package definedPackage = dispatcher.getDefinedPackage(targetClassLoader, packageName);\n\n        return definedPackage.getName();\n    }\n\n    private static final class DirectAccessor extends Dispatcher.Direct {\n        private DirectAccessor(\n                Method findLoadedClass,\n                Method defineClass,\n                Method getDefinedPackage,\n                Method getPackage,\n                Method definePackage) {\n            super(findLoadedClass, defineClass, getDefinedPackage, getPackage, definePackage);\n        }\n\n        private static Dispatcher.Initializable create() throws Exception {\n            return new DirectAccessor(\n                    PackageDefiningClassLoaderForDirect.class.getMethod(\"findLoadedClassForDirect\", String.class),\n                    PackageDefiningClassLoaderForDirect.class.getMethod(\n                            \"defineClassForDirect\",\n                            String.class,\n                            byte[].class,\n                            int.class,\n                            int.class,\n                            ProtectionDomain.class),\n                    getDefinedPackage(),\n                    PackageDefiningClassLoaderForDirect.class.getMethod(\"getPackageForDirect\", String.class),\n                    PackageDefiningClassLoaderForDirect.class.getMethod(\n                            \"definePackageForDirect\",\n                            String.class,\n                            String.class,\n                            String.class,\n                            String.class,\n                            String.class,\n                            String.class,\n                            String.class,\n                            URL.class));\n        }\n\n        private static Method getDefinedPackage() throws Exception {\n            try {\n                return ClassLoader.class.getMethod(\"getDefinedPackage\", String.class);\n            } catch (NoSuchMethodException ignored) {\n                return null;\n            }\n        }\n\n        @Override\n        public Object getClassLoadingLock(ClassLoader classLoader, String name) {\n            return classLoader;\n        }\n    }\n}\n\nfinal class PackageDefiningClassLoaderForDirect extends URLClassLoader {\n    PackageDefiningClassLoaderForDirect(ClassLoader parent) {\n        super(new URL[0], parent);\n    }\n\n    public Class<?> findLoadedClassForDirect(String name) {\n        return findLoadedClass(name);\n    }\n\n    public Class<?> defineClassForDirect(\n            String name,\n            byte[] binaryRepresentation,\n            int offset,\n            int length,\n            ProtectionDomain protectionDomain) {\n        return defineClass(name, binaryRepresentation, offset, length, protectionDomain);\n    }\n\n    public Package getPackageForDirect(String name) {\n        return super.getPackage(name);\n    }\n\n    public Package definePackageForDirect(\n            String name,\n            String specificationTitle,\n            String specificationVersion,\n            String specificationVendor,\n            String implementationTitle,\n            String implementationVersion,\n            String implementationVendor,\n            URL sealBase) {\n        return definePackage(\n                name,\n                specificationTitle,\n                specificationVersion,\n                specificationVendor,\n                implementationTitle,\n                implementationVersion,\n                implementationVendor,\n                sealBase);\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 1727, "output": 3620, "cacheRead": 80896, "cacheWrite": 0, "totalTokens": 86243, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1781097119868, "responseId": "resp_0b316ca6b490cce3016a2962a08e248190ae2160fcd4ea60c9"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_3KlnuQjWxdcGIHL3bBp4Cxte|fc_0b316ca6b490cce3016a2962e2308c8190be7347e6564a0690", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 6661 bytes to tests/src/io.projectreactor.tools/blockhound/1.0.8.RELEASE/src/test/java/io_projectreactor_tools/blockhound/ClassInjectorInnerUsingReflectionInnerDispatcherInnerDirectTest.java"}], "isError": false, "timestamp": 1781097200532}]}
