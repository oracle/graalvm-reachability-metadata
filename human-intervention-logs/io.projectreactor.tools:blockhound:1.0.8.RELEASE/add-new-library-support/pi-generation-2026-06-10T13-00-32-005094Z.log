      20	@SuppressWarnings({"deprecation", "removal"})
      21	public class ClassInjectorInnerUsingReflectionInnerDispatcherInnerDirectTest {
      22	    @Test
      23	    void directDispatcherChecksSecurityManagerAndReadsDefinedPackage() throws Exception {
      24	        SecurityManager previousSecurityManager = System.getSecurityManager();
      25	        boolean securityManagerChanged = installPermissiveSecurityManager();
      26	        try (URLClassLoader classLoader = new URLClassLoader(new URL[0], getClass().getClassLoader())) {
      27	            DirectDispatcherAccessorForDirect accessor = new DirectDispatcherAccessorForDirect(classLoader);
      28	
      29	            assertThat(accessor.defineAndReadPackage())
      30	                    .startsWith(DirectDispatcherAccessorForDirect.PACKAGE_PREFIX);
      31	        } finally {
      32	            if (securityManagerChanged) {
      33	                System.setSecurityManager(previousSecurityManager);
      34	            }
      35	        }
      36	    }
      37	
      38	    private static boolean installPermissiveSecurityManager() {
      39	        try {
      40	            System.setSecurityManager(new PermissiveSecurityManagerForDirect());
      41	            return System.getSecurityManager() != null;
      42	        } catch (UnsupportedOperationException ignored) {
      43	            return false;
      44	        }
      45	    }
      46	}
      47	
      48	final class PermissiveSecurityManagerForDirect extends SecurityManager {
      49	    @Override
      50	    public void checkPermission(Permission permission) {
      51	        // Permit all operations while the direct dispatcher permission check is exercised.
      52	    }
      53	
      54	    @Override
      55	    public void checkPermission(Permission permission, Object context) {
