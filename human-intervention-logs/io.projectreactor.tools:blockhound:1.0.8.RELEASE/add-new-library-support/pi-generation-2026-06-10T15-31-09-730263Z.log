  package io_projectreactor_tools.blockhound;
  
  import org.junit.jupiter.api.Test;
  import reactor.blockhound.shaded.net.bytebuddy.agent.builder.AgentBuilder;
  import reactor.blockhound.shaded.net.bytebuddy.description.type.TypeDescription;
  import reactor.blockhound.shaded.net.bytebuddy.pool.TypePool;
  import reactor.blockhound.shaded.net.bytebuddy.utility.JavaModule;
  
  import java.lang.reflect.Modifier;
  import java.util.concurrent.ExecutorService;
  import java.util.concurrent.Executors;
  import java.util.concurrent.TimeUnit;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class AgentBuilderInnerDescriptionStrategyInnerSuperTypeLoadingInnerAsynchronousInnerThreadSwitchingClassLoadingDelegateInnerSimpleClassLoadingActionTest {
      @Test
      void loadsSuperTypeAsynchronouslyWhenCallerDoesNotOwnClassLoaderMonitor() throws InterruptedException {
          ExecutorService executorService = Executors.newSingleThreadExecutor();
          try {
              ClassLoader classLoader = Child.class.getClassLoader();
              assertThat(classLoader).isNotNull();
  
              AgentBuilder.DescriptionStrategy descriptionStrategy =
                      new AgentBuilder.DescriptionStrategy.SuperTypeLoading.Asynchronous(
                              new LatentChildDescriptionStrategy(), executorService);
              TypeDescription childDescription = descriptionStrategy.apply(
                      Child.class.getName(),
                      null,
                      TypePool.Empty.INSTANCE,
                      new AgentBuilder.CircularityLock.Default(),
                      classLoader,
                      JavaModule.ofType(Child.class));
  
              TypeDescription superClass = childDescription.getSuperClass().asErasure();
  
              assertThat(superClass.represents(Parent.class)).isTrue();
          } finally {
              executorService.shutdownNow();
              assertThat(executorService.awaitTermination(5, TimeUnit.SECONDS)).isTrue();
          }
      }
  
      private static final class LatentChildDescriptionStrategy implements AgentBuilder.DescriptionStrategy {
          @Override
          public boolean isLoadedFirst() {
              return false;
          }
  
          @Override
          public TypeDescription apply(
                  String typeName,
                  Class<?> type,
                  TypePool typePool,
                  AgentBuilder.CircularityLock circularityLock,
                  ClassLoader classLoader,
                  JavaModule module) {
              return new TypeDescription.Latent(
                      typeName,
                      Modifier.PUBLIC,
                      TypeDescription.Generic.OfNonGenericType.ForLoadedType.of(Parent.class));
          }
      }
  
      private static class Parent {
      }
  
      private static final class Child extends Parent {
      }
  }
