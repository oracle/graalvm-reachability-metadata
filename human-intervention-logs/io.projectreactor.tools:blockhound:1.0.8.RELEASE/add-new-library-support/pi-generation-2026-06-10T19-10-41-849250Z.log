  package io_projectreactor_tools.blockhound;
  
  import org.junit.jupiter.api.Test;
  import reactor.blockhound.shaded.net.bytebuddy.dynamic.loading.ClassInjector;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ClassInjectorInnerUsingReflectionInnerDispatcherInnerInitializableInnerUnavailableTest {
      @Test
      void unavailableDispatcherFindsClassesVisibleToTheTargetClassLoader() {
          try {
              UnavailableDispatcherAccessor accessor = new UnavailableDispatcherAccessor(getClass().getClassLoader());
  
              Class<?> loadedClass = accessor.findVisibleClass(String.class.getName());
  
              assertThat(loadedClass).isSameAs(String.class);
          } catch (Throwable throwable) {
              BlockHoundNativeImageSupport.rethrowIfNotExpectedNativeImageFailure(throwable);
          }
      }
  }
  
  final class UnavailableDispatcherAccessor extends ClassInjector.UsingReflection {
      private final ClassLoader targetClassLoader;
  
      UnavailableDispatcherAccessor(ClassLoader targetClassLoader) {
          super(targetClassLoader);
          this.targetClassLoader = targetClassLoader;
      }
  
      Class<?> findVisibleClass(String className) {
          Dispatcher dispatcher = new InitializableUnavailableDispatcher("reflection injection unavailable").initialize();
          return dispatcher.findClass(targetClassLoader, className);
      }
  
      private static final class InitializableUnavailableDispatcher extends Dispatcher.Initializable.Unavailable {
          private InitializableUnavailableDispatcher(String message) {
              super(message);
          }
      }
  }
