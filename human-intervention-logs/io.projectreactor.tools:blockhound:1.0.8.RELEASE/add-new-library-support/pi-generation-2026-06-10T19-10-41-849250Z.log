  package io_projectreactor_tools.blockhound;
  
  import org.junit.jupiter.api.Test;
  import reactor.blockhound.shaded.net.bytebuddy.dynamic.loading.ClassInjector;
  
  import java.lang.reflect.Method;
  import java.net.URL;
  import java.net.URLClassLoader;
  import java.security.Permission;
  import java.security.ProtectionDomain;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  @SuppressWarnings({"deprecation", "removal"})
  public class ClassInjectorInnerUsingReflectionInnerDispatcherInnerDirectTest {
      @Test
      void directDispatcherChecksSecurityManagerAndReadsDefinedPackage() throws Exception {
          SecurityManager previousSecurityManager = System.getSecurityManager();
          boolean securityManagerChanged = installPermissiveSecurityManager();
          try (PackageDefiningClassLoaderForDirect classLoader = new PackageDefiningClassLoaderForDirect(
                  getClass().getClassLoader())) {
              try {
                  DirectDispatcherAccessorForDirect accessor = new DirectDispatcherAccessorForDirect(classLoader);
  
                  assertThat(accessor.defineAndReadPackage())
                          .startsWith(DirectDispatcherAccessorForDirect.PACKAGE_PREFIX);
              } catch (Throwable throwable) {
                  BlockHoundNativeImageSupport.rethrowIfNotExpectedNativeImageFailure(throwable);
              }
          } finally {
              if (securityManagerChanged) {
                  System.setSecurityManager(previousSecurityManager);
              }
          }
      }
  
      private static boolean installPermissiveSecurityManager() {
          try {
              System.setSecurityManager(new PermissiveSecurityManagerForDirect());
              return System.getSecurityManager() != null;
          } catch (UnsupportedOperationException ignored) {
              return false;
          }
      }
  }
  
  final class PermissiveSecurityManagerForDirect extends SecurityManager {
      @Override
      public void checkPermission(Permission permission) {
          // Permit all operations while the direct dispatcher permission check is exercised.
      }
  
      @Override
      public void checkPermission(Permission permission, Object context) {
          // Permit all operations while the direct dispatcher permission check is exercised.
      }
  }
  
  final class DirectDispatcherAccessorForDirect extends ClassInjector.UsingReflection {
      static final String PACKAGE_PREFIX = "io_projectreactor_tools.blockhound.generated.direct";
  
      private final PackageDefiningClassLoaderForDirect targetClassLoader;
  
      DirectDispatcherAccessorForDirect(PackageDefiningClassLoaderForDirect targetClassLoader) {
          super(targetClassLoader);
          this.targetClassLoader = targetClassLoader;
      }
  
      String defineAndReadPackage() throws Exception {
          Dispatcher dispatcher = DirectAccessor.create().initialize();
          String packageName = PACKAGE_PREFIX + java.lang.System.nanoTime();
          targetClassLoader.definePackageForDirect(
                  packageName,
                  null,
                  null,
                  null,
                  null,
                  null,
                  null,
                  null);
  
          Package definedPackage = dispatcher.getDefinedPackage(targetClassLoader, packageName);
  
          return definedPackage.getName();
      }
  
      private static final class DirectAccessor extends Dispatcher.Direct {
          private DirectAccessor(
                  Method findLoadedClass,
                  Method defineClass,
                  Method getDefinedPackage,
                  Method getPackage,
                  Method definePackage) {
              super(findLoadedClass, defineClass, getDefinedPackage, getPackage, definePackage);
          }
  
          private static Dispatcher.Initializable create() throws Exception {
              return new DirectAccessor(
                      PackageDefiningClassLoaderForDirect.class.getMethod("findLoadedClassForDirect", String.class),
                      PackageDefiningClassLoaderForDirect.class.getMethod(
                              "defineClassForDirect",
                              String.class,
                              byte[].class,
                              int.class,
                              int.class,
                              ProtectionDomain.class),
                      getDefinedPackage(),
                      PackageDefiningClassLoaderForDirect.class.getMethod("getPackageForDirect", String.class),
                      PackageDefiningClassLoaderForDirect.class.getMethod(
                              "definePackageForDirect",
                              String.class,
                              String.class,
                              String.class,
                              String.class,
                              String.class,
                              String.class,
                              String.class,
                              URL.class));
          }
  
          private static Method getDefinedPackage() throws Exception {
              try {
                  return ClassLoader.class.getMethod("getDefinedPackage", String.class);
              } catch (NoSuchMethodException ignored) {
                  return null;
              }
          }
  
          @Override
          public Object getClassLoadingLock(ClassLoader classLoader, String name) {
              return classLoader;
          }
      }
  }
  
  final class PackageDefiningClassLoaderForDirect extends URLClassLoader {
      PackageDefiningClassLoaderForDirect(ClassLoader parent) {
          super(new URL[0], parent);
      }
  
      public Class<?> findLoadedClassForDirect(String name) {
          return findLoadedClass(name);
      }
  
      public Class<?> defineClassForDirect(
              String name,
              byte[] binaryRepresentation,
              int offset,
              int length,
              ProtectionDomain protectionDomain) {
          return defineClass(name, binaryRepresentation, offset, length, protectionDomain);
      }
  
      public Package getPackageForDirect(String name) {
          return super.getPackage(name);
      }
  
      public Package definePackageForDirect(
              String name,
              String specificationTitle,
              String specificationVersion,
              String specificationVendor,
              String implementationTitle,
              String implementationVersion,
              String implementationVendor,
              URL sealBase) {
          return definePackage(
                  name,
                  specificationTitle,
                  specificationVersion,
                  specificationVendor,
                  implementationTitle,
                  implementationVersion,
                  implementationVendor,
                  sealBase);
      }
  }
