rInnerUsingReflectionInnerDispatcherInnerUnavailableTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_projectreactor_tools.blockhound;\n\nimport org.junit.jupiter.api.Test;\nimport reactor.blockhound.shaded.net.bytebuddy.dynamic.loading.ClassInjector;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ClassInjectorInnerUsingReflectionInnerDispatcherInnerUnavailableTest {\n    @Test\n    void unavailableDispatcherFindsClassesVisibleToTheTargetClassLoader() {\n        try {\n            UnavailableReflectionDispatcherAccessor accessor = new UnavailableReflectionDispatcherAccessor(\n                    getClass().getClassLoader());\n\n            Class<?> loadedClass = accessor.findVisibleClass(StringBuilder.class.getName());\n\n            assertThat(loadedClass).isSameAs(StringBuilder.class);\n        } catch (Throwable throwable) {\n            BlockHoundNativeImageSupport.rethrowIfNotExpectedNativeImageFailure(throwable);\n        }\n    }\n}\n\nfinal class UnavailableReflectionDispatcherAccessor extends ClassInjector.UsingReflection {\n    private final ClassLoader targetClassLoader;\n\n    UnavailableReflectionDispatcherAccessor(ClassLoader targetClassLoader) {\n        super(targetClassLoader);\n        this.targetClassLoader = targetClassLoader;\n    }\n\n    Class<?> findVisibleClass(String className) {\n        Dispatcher dispatcher = new UnavailableDispatcher(new IllegalStateException(\"reflection injection unavailable\"));\n        return dispatcher.findClass(targetClassLoader, className);\n    }\n\n    private static final class UnavailableDispatcher extends Dispatcher.Unavailable {\n        private UnavailableDispatcher(Exception exception) {\n            super(exception);\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": 