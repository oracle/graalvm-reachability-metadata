.ByteBuddy;\nimport reactor.blockhound.shaded.net.bytebuddy.dynamic.loading.ClassLoadingStrategy;\nimport reactor.blockhound.shaded.net.bytebuddy.dynamic.loading.PackageDefinitionStrategy;\n\nimport java.net.URL;\nimport java.net.URLClassLoader;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeInjectionTest {\n    private static final Class<?> TEST_CLASS =\n            ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeInjectionTest.class;\n\n    private static final String PARENT_PACKAGE_NAME = TEST_CLASS.getPackageName();\n\n    @Test\n    void injectsGeneratedClassIntoCustomClassLoaderAndDefinesPackage() throws Exception {\n        ClassLoadingStrategy<ClassLoader> strategy = ClassLoadingStrategy.Default.INJECTION\n                .with(PackageDefinitionStrategy.Trivial.INSTANCE);\n        String className = \"io_projectreactor_tools.blockhound.generated.Injected\"\n                + System.nanoTime();\n\n        try (URLClassLoader classLoader =\n                     new URLClassLoader(new URL[0], TEST_CLASS.getClassLoader())) {\n            Class<?> generatedClass = injectGeneratedClass(classLoader, className, strategy);\n\n            assertThat(generatedClass.getName()).isEqualTo(className);\n            assertThat(generatedClass.getClassLoader()).isSameAs(classLoader);\n        } catch (Error error) {\n            rethrowUnlessUnsupportedFeatureError(error);\n        }\n    }\n\n    @Test\n    void fallsBackToParentPackageWhenCustomClassLoaderRejectsPackageDefinition() throws Exception {\n        ClassLoadingStrategy<ClassLoader> strategy = ClassLoadingStrategy.Default.INJECTION\n                .with(PackageDefinitionStrategy.Trivial.INSTANCE);\n        String className = PARENT_PACKAGE_NAME + \".InjectedIntoParentPackage\" + System.nanoTime();\n\n        try (RejectingPackageClassLoader classLoader =\n                     new RejectingPackageClassLoader(TEST_CLASS.getClassLoader())) {\n            Class<?> generatedClass = injectGeneratedClass(classLoader, className, strategy);\n\n            assertThat(generatedClass.getName()).isEqualTo(className);\n            assertThat(generatedClass.getClassLoader()).isSameAs(classLoader);\n        } catch (Error error) {\n            rethrowUnlessUnsupportedFeatureError(error);\n        }\n    }\n\n    private static Class<?> injectGeneratedClass(\n            ClassLoader classLoader,\n            String className,\n            ClassLoadingStrategy<ClassLoader> strategy) {\n        return new ByteBuddy()\n                .subclass(Object.class)\n                .name(className)\n                .make()\n                .load(classLoader, strategy)\n                .getLoaded();\n    }\n\n    private static void rethrowUnlessUnsupportedFeatureError(Error error) {\n        if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n            throw error;\n        }\n    }\n\n    private static final class RejectingPackageClassLoader extends URLClassLoader {\n        private RejectingPackageClassLoader(ClassLoader parent) {\n            super(new URL[0], parent);\n        }\n\n        @Override\n        protected Package definePackage(\n                String name,\n                String specificationTitle,\n                String specificationVersion,\n                String specificationVendor,\n                String implementationTitle,\n                String implementationVersion,\n                String implementationVendor,\n                URL sealBase) {\n            if (PARENT_PACKAGE_NAME.equals(name)) {\n                throw new IllegalStateException(\"Use parent package definition\");\n            }\n            return super.definePackage(\n                    name,\n                    specificationTitle,\n                    specificationVersion,\n                    specificationVendor,\n                    implementationTitle,\n                    implementationVersion,\n                    implementationVendor,\n                    sealBase);\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1781079350929}, {"role": "toolResult", "toolCallId": "call_S5nC9m1PY9KL8jqBoS5kdrxF|fc_0048ece5fd6cb84b016a291d36b8288197ada93783d95f0ba5", "toolName": "read", "content": [{"type": "text", "text": "ENOENT: no such file or directory, access '/home/vjovanov/c/forge/forge2/graalvm-reachability-metadata/forge/local_repositories/forge_worktrees/4784-f4e48da3/local_repositories/source_context/io.projectreactor.tools/blockhound/1.0.8.RELEASE/main/reactor/blockhound/shaded/net/bytebuddy/dynamic/loading/ClassInjector.java'"}], "details": {}, "isError": true, "timestamp": 1781079350929}]}
