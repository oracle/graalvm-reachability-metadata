      private static final String EXERCISE_CLASS_NAME = NESTED_EXERCISE_PREFIX + "UsingUnsafeOverrideExercise";
  
      @Test
      void injectsClassesThroughUnsafeOverrideDispatcher() throws Exception {
          try {
              assertThat(new UsingUnsafeOverrideExercise().call()).isEqualTo("ok");
          } catch (Error error) {
              rethrowUnlessUnsupportedFeatureError(error);
