eflectionInnerDispatcherInnerUsingUnsafeOverrideTest.class.getName() + \"$\";\n\n    private static final String EXERCISE_CLASS_NAME = NESTED_EXERCISE_PREFIX + \"UsingUnsafeOverrideExercise\";\n\n    @Test\n    void injectsClassesThroughUnsafeOverrideDispatcher() throws Exception {\n        try {\n            assertThat(new UsingUnsafeOverrideExercise().call()).isEqualTo(\"ok\");\n        } catch (Error error) {\n            rethrowUnlessUnsupportedFeatureError(error);\n        }\n    }\n\n    @Test\n    void injectsClassesThroughUnsafeOverrideDispatcherFromIsolatedLoader() throws Exception {\n        try (ChildFirstByteBuddyClassLoader classLoader = new ChildFirstByteBuddyClassLoader(classPathUrls())) {\n            Class<?> exerciseClass = classLoader.loadClass(EXERCISE_CLASS_NAME);\n            Callable<?> exercise = (Callable<?>) exerciseClass.getDeclaredConstructor().newInstance();\n\n            assertThat(exercise.call()).isEqualTo(\"ok\");\n        } catch (Error error) {\n            rethrowUnlessUnsupportedFeatureError(error);\n        }\n    }\n\n    private static URL[] classPathUrls() throws Exception {\n        String classPath = System.getProperty(\"java.class.path\", \"\");\n        if (classPath.isEmpty()) {\n            return new URL[0];\n        }\n        String[] entries = classPath.split(File.pathSeparator);\n        URL[] urls = new URL[entries.length];\n        for (int i = 0; i < entries.length; i++) {\n            urls[i] = new File(entries[i]).toURI().toURL();\n        }\n        return urls;\n    }", "newText": "@SuppressWarnings({\"deprecation\", \"removal\"})\npublic class ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeOverrideTest {\n    @Test\n    void injectsClassesThroughUnsafeOverrideDispatcher() {\n        try {\n            assertThat(new UsingUnsafeOverrideExercise().call()).isEqualTo(\"ok\");\n        } catch (Error error) {\n            rethrowUnlessUnsupportedFeatureError(error);\n        }\n    }"}, {"oldTe