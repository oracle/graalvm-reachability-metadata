  package io_projectreactor_tools.blockhound;
  
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  import reactor.blockhound.shaded.net.bytebuddy.ByteBuddy;
  import reactor.blockhound.shaded.net.bytebuddy.dynamic.loading.ClassInjector;
  import reactor.blockhound.shaded.net.bytebuddy.dynamic.loading.ClassLoadingStrategy;
  import reactor.blockhound.shaded.net.bytebuddy.dynamic.loading.PackageDefinitionStrategy;
  
  import java.io.File;
  import java.net.URL;
  import java.net.URLClassLoader;
  import java.security.Permission;
  import java.util.concurrent.Callable;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeOverrideTest {
      private static final String EXERCISE_CLASS_NAME =
              ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeOverrideTest.class.getName()
                      + "$UsingUnsafeOverrideExercise";
  
      @Test
      void injectsClassesThroughUnsafeOverrideDispatcher() throws Exception {
          try (ChildFirstByteBuddyClassLoader classLoader = new ChildFirstByteBuddyClassLoader(classPathUrls())) {
              Class<?> exerciseClass = classLoader.loadClass(EXERCISE_CLASS_NAME);
              Callable<?> exercise = (Callable<?>) exerciseClass.getDeclaredConstructor().newInstance();
  
              assertThat(exercise.call()).isEqualTo("ok");
          } catch (Error error) {
              rethrowUnlessUnsupportedFeatureError(error);
          }
      }
  
      private static URL[] classPathUrls() throws Exception {
          String[] entries = System.getProperty("java.class.path").split(File.pathSeparator);
          URL[] urls = new URL[entries.length];
          for (int i = 0; i < entries.length; i++) {
              urls[i] = new File(entries[i]).toURI().toURL();
          }
          return urls;
      }
  
      private static void rethrowUnlessUnsupportedFeatureError(Error error) {
          if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
              throw error;
          }
      }
  
      private static final class ChildFirstByteBuddyClassLoader extends URLClassLoader {
          private ChildFirstByteBuddyClassLoader(URL[] urls) {
              super(urls, ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeOverrideTest.class.getClassLoader());
          }
  
          @Override
          protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {
              synchronized (getClassLoadingLock(name)) {
                  Class<?> loadedClass = findLoadedClass(name);
                  if (loadedClass == null && shouldLoadChildFirst(name)) {
                      try {
                          loadedClass = findClass(name);
                      } catch (ClassNotFoundException ignored) {
                          loadedClass = null;
                      }
                  }
                  if (loadedClass == null) {
                      loadedClass = super.loadClass(name, false);
                  }
                  if (resolve) {
                      resolveClass(loadedClass);
                  }
                  return loadedClass;
              }
          }
  
          private static boolean shouldLoadChildFirst(String name) {
              return name.startsWith("reactor.blockhound.shaded.net.bytebuddy.")
                      || name.startsWith(
                      ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeOverrideTest.class.getName() + "$");
          }
      }
  
      public static final class UsingUnsafeOverrideExercise implements Callable<String> {
          private static final String SAFE_PROPERTY = "net.bytebuddy.safe";
  
          @Override
          public String call() {
              String previousSafeProperty = System.getProperty(SAFE_PROPERTY);
              SecurityManager previousSecurityManager = System.getSecurityManager();
              boolean securityManagerChanged = false;
              try {
                  System.setProperty(SAFE_PROPERTY, Boolean.TRUE.toString());
                  if (ClassInjector.UsingUnsafe.isAvailable()) {
                      throw new IllegalStateException("Unsafe injection should be disabled for the isolated loader");
                  }
                  restoreSafeProperty(previousSafeProperty);
  
                  securityManagerChanged = installPermissiveSecurityManager();
  
                  ClassLoadingStrategy<ClassLoader> strategy = ClassLoadingStrategy.Default.INJECTION
                          .with(PackageDefinitionStrategy.Trivial.INSTANCE);
                  injectIntoNewPackage(strategy);
                  injectWithPackageFallback(strategy);
                  return "ok";
              } finally {
                  if (securityManagerChanged) {
                      System.setSecurityManager(previousSecurityManager);
                  }
                  restoreSafeProperty(previousSafeProperty);
              }
          }
  
          private static void injectIntoNewPackage(ClassLoadingStrategy<ClassLoader> strategy) {
              String className = "io_projectreactor_tools.blockhound.generated.unsafeoverride.Injected"
                      + System.nanoTime();
              try (URLClassLoader classLoader = new URLClassLoader(new URL[0],
                      UsingUnsafeOverrideExercise.class.getClassLoader())) {
                  Class<?> generatedClass = injectGeneratedClass(classLoader, className, strategy);
                  if (!generatedClass.getName().equals(className) || generatedClass.getClassLoader() != classLoader) {
                      throw new IllegalStateException("Generated class was not injected into the requested loader");
                  }
              } catch (Exception exception) {
                  throw new IllegalStateException(exception);
              }
          }
  
          private static void injectWithPackageFallback(ClassLoadingStrategy<ClassLoader> strategy) {
              String packageName = "io_projectreactor_tools.blockhound.generated.unsafeoverridefallback";
              String className = packageName + ".Injected" + System.nanoTime();
              try (RejectingPackageClassLoader classLoader = new RejectingPackageClassLoader(
                      UsingUnsafeOverrideExercise.class.getClassLoader(),
                      packageName,
                      UsingUnsafeOverrideExercise.class.getPackage())) {
                  Class<?> generatedClass = injectGeneratedClass(classLoader, className, strategy);
                  if (!generatedClass.getName().equals(className) || generatedClass.getClassLoader() != classLoader) {
                      throw new IllegalStateException("Generated class was not injected after package fallback");
                  }
              } catch (Exception exception) {
                  throw new IllegalStateException(exception);
              }
          }
  
          private static Class<?> injectGeneratedClass(
                  ClassLoader classLoader,
                  String className,
                  ClassLoadingStrategy<ClassLoader> strategy) {
              return new ByteBuddy()
                      .subclass(Object.class)
                      .name(className)
                      .make()
                      .load(classLoader, strategy)
                      .getLoaded();
          }
  
          private static boolean installPermissiveSecurityManager() {
              try {
                  System.setSecurityManager(new PermissiveSecurityManager());
                  return System.getSecurityManager() != null;
              } catch (UnsupportedOperationException ignored) {
                  return false;
              }
          }
  
          private static void restoreSafeProperty(String previousValue) {
              if (previousValue == null) {
                  System.clearProperty(SAFE_PROPERTY);
              } else {
                  System.setProperty(SAFE_PROPERTY, previousValue);
              }
          }
      }
  
      @SuppressWarnings("removal")
      private static final class PermissiveSecurityManager extends SecurityManager {
          @Override
          public void checkPermission(Permission permission) {
          }
  
          @Override
          public void checkPermission(Permission permission, Object context) {
          }
      }
  
      private static final class RejectingPackageClassLoader extends URLClassLoader {
          private final String rejectedPackageName;
          private final Package fallbackPackage;
  
          private RejectingPackageClassLoader(ClassLoader parent, String rejectedPackageName, Package fallbackPackage) {
              super(new URL[0], parent);
              this.rejectedPackageName = rejectedPackageName;
              this.fallbackPackage = fallbackPackage;
          }
  
          @Override
          protected Package definePackage(
                  String name,
                  String specificationTitle,
                  String specificationVersion,
                  String specificationVendor,
                  String implementationTitle,
                  String implementationVersion,
                  String implementationVendor,
                  URL sealBase) {
              if (rejectedPackageName.equals(name)) {
                  throw new IllegalStateException("Use package fallback");
              }
              return super.definePackage(
                      name,
                      specificationTitle,
                      specificationVersion,
                      specificationVendor,
                      implementationTitle,
                      implementationVersion,
                      implementationVendor,
                      sealBase);
          }
  
          @Override
          protected Package getPackage(String name) {
              if (rejectedPackageName.equals(name)) {
                  return fallbackPackage;
              }
              return super.getPackage(name);
          }
      }
  }
