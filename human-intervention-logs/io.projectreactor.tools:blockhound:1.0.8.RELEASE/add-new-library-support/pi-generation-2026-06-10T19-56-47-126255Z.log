[tool-call] delta {"path":"tests/src/io.projectreactor.tools/blockhound/1.0.8.RELEASE/src/test/java/io_projectreactor_tools/blockhound/JavaDispatcherInnerDispatcherInnerForContainerCreationTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_projectreactor_tools.blockhound;\n\nimport org.junit.jupiter.api.Test;\nimport reactor.blockhound.shaded.net.bytebuddy.utility.dispatcher.JavaDispatcher;\n\nimport java.util.Arrays;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class JavaDispatcherInnerDispatcherInnerForContainerCreationTest {\n\n    @Test\n    void reflectiveDispatcherCreatesContainersForTheProxiedType() {\n        try {\n            StringContainerDispatcher dispatcher = dispatcher().run();\n            String[] values = dispatcher.newContainer(3);\n\n            Arrays.fill(values, \"blockhound\");\n\n            assertThat(values).hasSize(3).containsOnly(\"blockhound\");\n            assertThat(values.getClass().getComponentType()).isEqualTo(String.class);\n        } catch (Throwable throwable) {\n            BlockHoundNativeImageSupport.rethrowIfNotExpectedNativeImageFailure(throwable);\n        }\n    }\n\n    private static ExposedJavaDispatcher<StringContainerDispatcher> dispatcher() {\n        return new ExposedJavaDispatcher<>(\n                StringContainerDispatcher.class,\n                JavaDispatcherInnerDispatcherInnerForContainerCreationTest.class.getClassLoader(),\n                false);\n    }\n\n    private static final class ExposedJavaDispatcher<T> extends JavaDispatcher<T> {\n        private ExposedJavaDispatcher(Class<T> proxy, ClassLoader classLoader, boolean generate) {\n            super(proxy, classLoader, generate);\n        }\n    }\n\n    @JavaDispatcher.Proxied(\"java.lang.String\")\n    public interface StringContainerDispatcher {\n        @JavaDispatcher.Container\n        String[] newContainer(int length);\n    }\n}\n"}
