  package io_projectreactor_tools.blockhound;
  
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  import reactor.blockhound.shaded.net.bytebuddy.agent.builder.LambdaFactory;
  
  import java.lang.instrument.ClassFileTransformer;
  import java.security.ProtectionDomain;
  import java.util.Collection;
  import java.util.List;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class LambdaFactoryTest {
      @Test
      void registersFactoryInvokesItAndReleasesTransformer() {
          ClassFileTransformer transformer = new NoOpClassFileTransformer();
          RecordingClassFileFactory factory = new RecordingClassFileFactory();
          boolean registered = false;
  
          try {
              boolean firstRegistration = LambdaFactory.register(transformer, factory);
              registered = true;
  
              byte[] generatedBytes = LambdaFactory.make(
                      new Object(),
                      "run",
                      new Object(),
                      new Object(),
                      new Object(),
                      new Object(),
                      false,
                      List.of(Runnable.class),
                      List.of());
  
              assertThat(firstRegistration).isTrue();
              assertThat(generatedBytes).containsExactly(1, 2, 3);
              assertThat(factory.invocations).isEqualTo(1);
              assertThat(factory.lastInvokedName).isEqualTo("run");
              assertThat(factory.lastClassFileTransformers).containsExactly(transformer);
  
              assertThat(LambdaFactory.release(transformer)).isTrue();
              registered = false;
          } catch (Error error) {
              rethrowUnlessUnsupportedFeatureError(error);
          } finally {
              if (registered) {
                  LambdaFactory.release(transformer);
              }
          }
      }
  
      private static void rethrowUnlessUnsupportedFeatureError(Error error) {
          if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
              throw error;
          }
      }
  
      private static final class NoOpClassFileTransformer implements ClassFileTransformer {
          @Override
          public byte[] transform(
                  Module module,
                  ClassLoader loader,
                  String className,
                  Class<?> classBeingRedefined,
                  ProtectionDomain protectionDomain,
                  byte[] classfileBuffer) {
              return null;
          }
      }
  
      public static final class RecordingClassFileFactory {
          private int invocations;
          private String lastInvokedName;
          private Collection<ClassFileTransformer> lastClassFileTransformers;
  
          public byte[] make(
                  Object caller,
                  String invokedName,
                  Object invokedType,
                  Object samMethodType,
                  Object implMethod,
                  Object instantiatedMethodType,
                  boolean serializable,
                  List<Class<?>> markerInterfaces,
                  List<?> additionalBridges,
                  Collection<ClassFileTransformer> classFileTransformers) {
              invocations++;
              lastInvokedName = invokedName;
              lastClassFileTransformers = classFileTransformers;
              return new byte[] {1, 2, 3};
          }
      }
  }
