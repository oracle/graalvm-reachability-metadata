nd related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_projectreactor_tools.blockhound;\n\nimport org.junit.jupiter.api.Test;\nimport reactor.blockhound.shaded.net.bytebuddy.agent.Attacher;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class AttacherTest {\n    @Test\n    void mainAttachesLoadsAgentAndDetaches() {\n        RecordingVirtualMachine.reset();\n\n        Attacher.main(new String[] {\n                RecordingVirtualMachine.class.getName(),\n                \"12345\",\n                \"/tmp/example-agent.jar\",\n                Boolean.FALSE.toString(),\n                \"=alpha\",\n                \"beta\"\n        });\n\n        assertThat(RecordingVirtualMachine.attachedProcessId).isEqualTo(\"12345\");\n        assertThat(RecordingVirtualMachine.loadedAgent).isEqualTo(\"/tmp/example-agent.jar\");\n        assertThat(RecordingVirtualMachine.loadedAgentArgument).isEqualTo(\"alpha beta\");\n        assertThat(RecordingVirtualMachine.loadedAgentPath).isNull();\n        assertThat(RecordingVirtualMachine.detached).isTrue();\n    }\n\n    @Test\n    void mainLoadsNativeAgentPathWhenRequested() {\n        RecordingVirtualMachine.reset();\n\n        Attacher.main(new String[] {\n                RecordingVirtualMachine.class.getName(),\n                \"67890\",\n                \"/tmp/example-agent.so\",\n                Boolean.TRUE.toString(),\n                \"\"\n        });\n\n        assertThat(RecordingVirtualMachine.attachedProcessId).isEqualTo(\"67890\");\n        assertThat(RecordingVirtualMachine.loadedAgentPath).isEqualTo(\"/tmp/example-agent.so\");\n        assertThat(RecordingVirtualMachine.loadedAgentArgument).isNull();\n        assertThat(RecordingVirtualMachine.loadedAgent).isNull();\n        assertThat(RecordingVirtualMachine.detached).isTrue();\n    }\n\n    public static final class RecordingVirtualMachine {\n        private static String attachedProcessId;\n        private static String loadedAgent;\n        private static String loadedAgentPath;\n        private static String loadedAgentArgument;\n        private static boolean detached;\n\n        public static RecordingVirtualMachine attach(String processId) {\n            attachedProcessId = processId;\n            return new RecordingVirtualMachine();\n        }\n\n        public void loadAgent(String agent, String argument) {\n            loadedAgent = agent;\n            loadedAgentArgument = argument;\n        }\n\n        public void loadAgentPath(String agent, String argument) {\n            loadedAgentPath = agent;\n            loadedAgentArgument = argument;\n        }\n\n        public void detach() {\n            detached = true;\n        }\n\n        private static void reset() {\n            attachedProcessId = null;\n            loadedAgent = null;\n            loadedAgentPath = null;\n            loadedAgentArgument = null;\n            detached = false;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 549, "output": 2072, "cacheRead": 44032, "cacheWrite": 0, "totalTokens": 46653, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1781081196220, "responseId": "resp_04bc3f2b7aead828016a29246cc52481978b2ecdc323eac0e7"}}
