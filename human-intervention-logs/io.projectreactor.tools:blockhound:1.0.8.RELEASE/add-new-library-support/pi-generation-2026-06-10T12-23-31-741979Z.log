InnerForCurrentVmInnerForLegacyVmTest {\n    @Test\n    void resolvesCurrentProcessIdThroughLegacyManagementBeanProvider() {\n        String processId = ForLegacyVm.INSTANCE.resolve();\n\n        assertThat(processId)\n                .containsOnlyDigits()\n                .isEqualTo(Long.toString(ProcessHandle.current().pid()));\n    }\n}\n", "newText": "import org.junit.jupiter.api.Test;\nimport reactor.blockhound.shaded.net.bytebuddy.agent.ByteBuddyAgent.ProcessProvider;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ByteBuddyAgentInnerProcessProviderInnerForCurrentVmInnerForLegacyVmTest {\n    private static final String LEGACY_VM_PROVIDER = \"reactor.blockhound.shaded.net.bytebuddy.agent\"\n            + \".ByteBuddyAgent$ProcessProvider$ForCurrentVm$ForLegacyVm\";\n\n    @Test\n    void resolvesCurrentProcessIdThroughLegacyManagementBeanProvider() throws ClassNotFoundException {\n        ProcessProvider processProvider = (ProcessProvider) enumConstant(LEGACY_VM_PROVIDER, \"INSTANCE\");\n\n        String processId = processProvider.resolve();\n\n        assertThat(processId)\n                .containsOnlyDigits()\n                .isEqualTo(Long.toString(ProcessHandle.current().pid()));\n    }\n\n    @SuppressWarnings({\"rawtypes\", \"unchecked\"})\n    private static Enum<?> enumConstant(String className, String constantName) throws ClassNotFoundException {\n        Class<? extends Enum> enumType = Class.forName(className).asSubclass(Enum.class);\n        return Enum.valueOf(enumType, constantName);\n    }\n}\n"}]}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 1036, "output": 1323, "cacheRead": 36864, "cacheWrite": 0, "totalTokens": 39223, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1781094319150, "responseId": "resp_0b781881a343fea6016a2957af9f6081969cd36e086c8832e1"}}
