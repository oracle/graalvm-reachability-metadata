finition;\nimport java.lang.instrument.ClassFileTransformer;\nimport java.lang.instrument.Instrumentation;\nimport java.lang.instrument.UnmodifiableClassException;\nimport java.lang.invoke.MethodHandle;\nimport java.lang.invoke.MethodHandles;\nimport java.lang.invoke.MethodType;\nimport java.lang.module.Configuration;\nimport java.lang.module.ModuleFinder;\nimport java.nio.file.Files;\nimport java.nio.file.Path;\nimport java.util.Base64;\nimport java.util.Collections;\nimport java.util.List;\nimport java.util.Map;\nimport java.util.Set;\nimport java.util.jar.JarEntry;\nimport java.util.jar.JarFile;\nimport java.util.jar.JarOutputStream;\n\nimport static org.assertj.core.api.Assertions.assertThat;\nimport static org.assertj.core.api.Assertions.assertThatThrownBy;\n\npublic class ByteBuddyAgentTest {\n    private static final String ALLOW_SELF_ATTACH_PROPERTY = \"jdk.attach.allowAttachSelf\";\n    private static final String BYTE_BUDDY_AGENT_COPY_MODULE = \"blockhound.bytebuddy.agent.copy\";\n    private static final String BYTE_BUDDY_AGENT_PACKAGE = \"reactor.blockhound.shaded.net.bytebuddy.agent\";\n    private static final String BYTE_BUDDY_AGENT_RESOURCE_PATH = \"reactor/blockhound/shaded/net/bytebuddy/agent/\";\n    private static final byte[] BYTE_BUDDY_AGENT_COPY_MODULE_INFO = Base64.getDecoder().decode(\n            \"yv66vgAAADUADwcAAgEAC21vZHVsZS1pbmZvAQAKU291cmNlRmlsZQEAEG1vZHVsZS1pbmZvLmphdmEB\"\n                    + \"AAZNb2R1bGUTAAcBAB9ibG9ja2hvdW5kLmJ5dGVidWRkeS5hZ2VudC5jb3B5EwAJAQAJamF2YS5iYXNl\"\n                    + \"AQABORMADAEAD2phdmEuaW5zdHJ1bWVudBQADgEALXJlYWN0b3IvYmxvY2tob3VuZC9zaGFkZWQvbmV0\"\n                    + \"L2J5dGVidWRkeS9hZ2VudIAAAAEAAAAAAAAAAAACAAMAAAACAAQABQAAACIABgAAAAAAAgAIgAAACgAL\"\n                    + \"AAAACgABAA0AAAAAAAAAAAAA\");\n    private static final List<String> MODULAR_AGENT_CLASS_RESOURCES = List.of(\n            \"ByteBuddyAgent.class\",\n            \"ByteBuddyAgent$AgentProvider.class\",\n            \"ByteBuddyAgent$AgentProvider$ForByteBuddyAgent.class\",\n            \"ByteBuddyAgent$AgentProvider$ForExistingAgent.class\",\n            \"ByteBuddyAgent$AttachmentProvider.class\",\n            \"ByteBuddyAgent$AttachmentProvider$Accessor.class\",\n            \"ByteBuddyAgent$AttachmentProvider$Accessor$ExternalAttachment.class\",\n            \"ByteBuddyAgent$AttachmentProvider$Accessor$Simple.class\",\n            \"ByteBuddyAgent$AttachmentProvider$Accessor$Simple$WithDirectAttachment.class\",\n            \"ByteBuddyAgent$AttachmentProvider$Accessor$Simple$WithExternalAttachment.class\",\n            \"ByteBuddyAgent$AttachmentProvider$Accessor$Unavailable.class\",\n            \"ByteBuddyAgent$AttachmentProvider$Compound.class\",\n            \"ByteBuddyAgent$AttachmentProvider$ForEmulatedAttachment.class\",\n            \"ByteBuddyAgent$AttachmentProvider$ForJ9Vm.class\",\n            \"ByteBuddyAgent$AttachmentProvider$ForModularizedVm.class\",\n            \"ByteBuddyAgent$AttachmentProvider$ForStandardToolsJarVm.class\",\n            \"ByteBuddyAgent$AttachmentProvider$ForUserDefinedToolsJar.class\",\n            \"ByteBuddyAgent$AttachmentTypeEvaluator.class\",\n            \"ByteBuddyAgent$AttachmentTypeEvaluator$Disabled.class\",\n            \"ByteBuddyAgent$AttachmentTypeEvaluator$ForJava9CapableVm.class\",\n            \"ByteBuddyAgent$AttachmentTypeEvaluator$InstallationAction.class\",\n            \"ByteBuddyAgent$ProcessProvider.class\",\n            \"ByteBuddyAgent$ProcessProvider$ForCurrentVm.class\",\n            \"ByteBuddyAgent$ProcessProvider$ForCurrentVm$ForJava9CapableVm.class\",\n            \"ByteBuddyAgent$ProcessProvider$ForCurrentVm$ForLegacyVm.class\",\n            \"Installer.class\");\n\n    @Test\n    void getInstrumentationAndExternalAttachmentUseByteBuddyAgentInstallerPaths() throws Throwable {\n        try {\n            exerciseByteBuddyAgentInstallerPaths();\n            getInstrumentationFromNamedModuleAddsReadEdgeToSystemInstaller();\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    private static void exerciseByteBuddyAgentInstallerPaths() throws Exception {\n        String originalAllowSelfAttach = System.getProperty(ALLOW_SELF_ATTACH_PROPERTY);\n        String originalLatentResolve = System.getProperty(ByteBuddyAgent.LATENT_RESOLVE);\n        Path marker = Files.createTempFile(\"blockhound-byte-buddy-agent\", \".marker\");\n        Files.deleteIfExists(marker);\n        Path virtualMachineJar = writeVirtualMachineJar();\n        Path agentJar = Files.createTempFile(\"blockhound-byte-buddy-agent\", \".jar\");\n        try {\n            System.setProperty(ALLOW_SELF_ATTACH_PROPERTY, Boolean.FALSE.toString());\n            System.setProperty(ByteBuddyAgent.LATENT_RESOLVE, Boolean.TRUE.toString());\n\n            assertThatThrownBy(ByteBuddyAgent::getInstrumentation)\n                    .isInstanceOf(IllegalStateException.class)\n                    .hasMessageContaining(\"Byte Buddy agent\");\n\n            Instrumentation instrumentation = new RecordingInstrumentation();\n            Installer.premain(null, instrumentation);\n            assertThat(ByteBuddyAgent.getInstrumentation()).isSameAs(instrumentation);\n            Installer.premain(null, null);\n\n            ByteBuddyAgent.attach(agentJar.toFile(),\n                    () -> Long.toString(ProcessHandle.current().pid()),\n                    marker.toString(),\n                    new ExternalAttachmentProvider(virtualMachineJar.toFile()));\n\n            assertThat(marker).exists();\n            assertThat(Files.readString(marker)).contains(agentJar.toString());\n        } finally {\n            Installer.premain(null, null);\n            restoreProperty(ALLOW_SELF_ATTACH_PROPERTY, originalAllowSelfAttach);\n            restoreProperty(ByteBuddyAgent.LATENT_RESOLVE, originalLatentResolve);\n        