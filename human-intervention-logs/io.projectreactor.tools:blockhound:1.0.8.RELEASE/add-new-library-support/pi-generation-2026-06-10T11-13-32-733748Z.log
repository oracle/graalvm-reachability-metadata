ertions.assertThatThrownBy;\n\npublic class ByteBuddyAgentTest {\n    private static final String ALLOW_SELF_ATTACH_PROPERTY = \"jdk.attach.allowAttachSelf\";\n    private static final String BYTE_BUDDY_AGENT_COPY_MODULE = \"blockhound.bytebuddy.agent.copy\";\n    private static final String BYTE_BUDDY_AGENT_PACKAGE = \"reactor.blockhound.shaded.net.bytebuddy.agent\";\n    private static final String BYTE_BUDDY_AGENT_RESOURCE_PATH = \"reactor/blockhound/shaded/net/bytebuddy/agent/\";\n    private static final byte[] BYTE_BUDDY_AGENT_COPY_MODULE_INFO = Base64.getDecoder().decode(\n            \"yv66vgAAADUADwcAAgEAC21vZHVsZS1pbmZvAQAKU291cmNlRmlsZQEAEG1vZHVsZS1pbmZvLmphdmEB\"\n                    + \"AAZNb2R1bGUTAAcBAB9ibG9ja2hvdW5kLmJ5dGVidWRkeS5hZ2VudC5jb3B5EwAJAQAJamF2YS5iYXNl\"\n                    + \"AQABORMADAEAD2phdmEuaW5zdHJ1bWVudBQADgEALXJlYWN0b3IvYmxvY2tob3VuZC9zaGFkZWQvbmV0\"\n                    + \"L2J5dGVidWRkeS9hZ2VudIAAAAEAAAAAAAAAAAACAAMAAAACAAQABQAAACIABgAAAAAAAgAIgAAACgAL\"\n                    + \"AAAACgABAA0AAAAAAAAAAAAA\");\n    private static final List<String> MODULAR_AGENT_CLASS_RESOURCES = List.of(\n            \"ByteBuddyAgent.class\",\n            \"ByteBuddyAgent$AgentProvider.class\",\n            \"ByteBuddyAgent$AgentProvider$ForByteBuddyAgent.class\",\n            \"ByteBuddyAgent$AgentProvider$ForExistingAgent.class\",\n            \"ByteBuddyAgent$AttachmentProvider.class\",\n            \"ByteBuddyAgent$AttachmentProvider$Accessor.class\",\n            \"ByteBuddyAgent$AttachmentProvider$Accessor$ExternalAttachment.class\",\n            \"ByteBuddyAgent$AttachmentProvider$Accessor$Simple.class\",\n            \"ByteBuddyAgent$AttachmentProvider$Accessor$Simple$WithDirectAttachment.class\",\n            \"ByteBuddyAgent$AttachmentProvider$Accessor$Simple$WithExternalAttachment.class\",\n            \"ByteBuddyAgent$AttachmentProvider$Accessor$Unavailable.class\",\n            \"ByteBuddyAgent$AttachmentProvider$Compound.class\",\n            \"ByteBuddyAgent$AttachmentProvider$ForEmulatedAttachment.class\",\n            \"ByteBuddyAgent$AttachmentProvider$ForJ9Vm.class\",\n            \"ByteBuddyAgent$AttachmentProvider$ForModularizedVm.class\",\n            \"ByteBuddyAgent$AttachmentProvider$ForStandardToolsJarVm.class\",\n            \"ByteBuddyAgent$AttachmentProvider$ForUserDefinedToolsJar.class\",\n            \"ByteBuddyAgent$AttachmentTypeEvaluator.class\",\n            \"ByteBuddyAgent$AttachmentTypeEvaluator$Disabled.class\",\n            \"ByteBuddyAgent$AttachmentTypeEvaluator$ForJava9CapableVm.class\",\n            \"ByteBuddyAgent$AttachmentTypeEvaluator$InstallationAction.class\",\n            \"ByteBuddyAgent$ProcessProvider.class\",\n            \"ByteBuddyAgent$ProcessProvider$ForCurrentVm.class\",\n            \"ByteBuddyAgent$ProcessProvider$ForCurrentVm$ForJava9CapableVm.class\",\n            \"ByteBuddyAgent$ProcessProvider$ForCurrentVm$ForLegacyVm.class\",\n            \"Installer.class\");\n\n    @Test\n    void getInstrumentationAndExternalAttachmentUseByteBuddyAgentInstallerPaths() throws Throwable {\n        try {\n            exerciseByteBuddyAgentInstallerPaths();\n            getInstrumentationFromNamedModuleAddsReadEdgeToSystemInstaller();\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    private static void exerciseByteBuddyAgentInstallerPaths() throws Exception {\n        String originalAllowSelfAttach = System.getProperty(ALLOW_SELF_ATTACH_PROPERTY);\n        String originalLatentResolve = System.getProperty(ByteBuddyAgent.LATENT_RESOLVE);\n        Path marker = Files.createTempFile(\"blockhound-byte-buddy-agent\", \".marker\");\n        Files.deleteIfExists(marker);\n        Path virtualMachineJar = writeVirtualMachineJar();\n        Path agentJar = Files.createTempFile(\"blockhound-byte-buddy-agent\", \".jar\");\n        try {\n            System.setProperty(ALLOW_SELF_ATTACH_PROPERTY, Boolean.FALSE.toString());\n            System.setProperty(ByteBuddyAgent.LATENT_RESOLVE, Boolean.TRUE.toString());\n\n            assertThatThrownBy(ByteBuddyAgent::getInstrumentation)\n                    .isInstanceOf(IllegalStateException.class)\n                    .hasMessageContaining(\"Byte Buddy agent\");\n\n            Instrumentation instrumentation = new RecordingInstrumentation();\n            Installer.premain(null, instrumentation);\n            assertThat(ByteBuddyAgent.getInstrumentation()).isSameAs(instrumentation);\n            Installer.premain(null, null);\n\n            ByteBuddyAgent.attach(agentJar.toFile(),\n                    () -> Long.toString(ProcessHandle.current().pid()),\n                    marker.toString(),\n                    new ExternalAttachmentProvider(virtualMachineJar.toFile()));\n\n            assertThat(marker).exists();\n            assertThat(Files.readString(marker)).contains(agentJar.toString());\n        } finally {\n            Installer.premain(null, null);\n            restoreProperty(ALLOW_SELF_ATTACH_PROPERTY, originalAllowSelfAttach);\n            restoreProperty(ByteBuddyAgent.LATENT_RESOLVE, originalLatentResolve);\n            Files.deleteIfExists(agentJar);\n            Files.deleteIfExists(marker);\n            Files.deleteIfExists(virtualMachineJar);\n        }\n    }\n\n    private static void getInstrumentationFromNamedModuleAddsReadEdgeToSystemInstaller() throws Throwable {\n        Path modularJar = writeModularByteBuddyAgentJar();\n        Instrumentation instrumentation = new RecordingInstrumentation();\n        try {\n            Installer.premain(null, instrumentation);\n\n            ModuleFinder finder = ModuleFinder.of(modularJar);\n            Configuration configuration = ModuleLayer.boot().configuration()\n                    .resolve(finder, ModuleFinder.of(), Set.of(BYTE_BUDDY_AGENT_COPY_MODULE));\n            ModuleLayer layer = ModuleLayer.boot()\n                    .defineModulesWithOneLoader(configuration, ClassLoader.getPlatformClassLoader());\n            Class<?> agentClass = layer.findLoader(BYTE_BUDDY_AGENT_COPY_MODULE)\n                    .loadClass(BYTE_BUDDY_AGENT_PACKAGE + \".ByteBuddyAgent\");\n            MethodHandle getInstrumentation = MethodHandles.publicLookup()\n                    .findStatic(agentClass, \"getInstrumentation\", MethodType.methodType(Instrumentation.class));\n\n            assertThat(getInstrumentation.invoke()).isSameAs(instrumentation);\n        } finally {\n            Installer.premain(null, null);\n            Files.deleteIfExists(modularJar);\n        }\n    }\n\n    private static Path writeModularByteBuddyAgentJar() throws IOException {\n        Path jar = Files.createTempFile(\"blockhound-byte-buddy-agent-module\", \".jar\");\n        try (JarOutputStream jarOutputStream = new JarOutputStream(Files.newOutputStream(jar))) {\n            jarOutputStream.putNextEntry(new JarEntry(\"module-info.class\"));\n            jarOutputStream.write(BYTE_BUDDY_AGENT_COPY_MODULE_INFO);\n            jarOutputStream.closeEntry();\n            for (String classResource : MODULAR_AGENT_CLASS_RESOURCES) {\n                String resourceName = BYTE_BUDDY_AGENT_RESOURCE_PATH + classResource;\n                try (InputStream inputStream = ByteBuddyAgent.class.getClassLoader()\n                        .getResourceAsStream(resourceName)) {\n                    assertThat(inputStream).isNotNull();\n                    jarOutputStream.putNextEntry(new JarEntry(resourceName));\n                    copy(inputStream, jarOutputStream);\n                    jarOutputStream.closeEntry();\n                }\n            }\n        }\n        return jar;\n    }\n\n    private static Path writeVirtualMachineJar() throws IOException {\n        Path jar = Files.createTempFile(\"blockhound-byte-buddy-virtual-machine\", \".jar\");\n        String resourceName = RecordingVirtualMachine.class.getName().replace('.', '/') + \".class\";\n        try (InputStream inputStream = ByteBuddyAgentTest.class.getClassLoader().getResourceAsStream(resourceName)) {\n            assertThat(inputStream).isNotNull();\n            try (JarOutputStream jarOutputStream = new JarOutputStream(Files.newOutputStream(jar))) {\n                jarOutputStream.putNextEntry(new JarEntry(resourceName));\n                copy(inputStream, jarOutputStream);\n                jarOutputStream.closeEntry();\n            }\n        }\n        return jar;\n    }\n\n    private static void copy(InputStream inputStream, OutputStream outputStream) throws IOException {\n        byte[] buffer = new byte[8192];\n        int length;\n        while ((length = inputStream.read(buffer)) != -1) {\n            outputStream.write(buffer, 0, length);\n        }\n    }\n\n    private static void restoreProperty(String name, String originalValue) {\n        if (originalValue == null) {\n            System.clearProperty(name);\n        } else {\n            System.setProperty(name, originalValue);\n        }\n    }\n\n    private static final class ExternalAttachmentProvider implements AttachmentProvider {\n        private final File virtualMachineJar;\n\n        private ExternalAttachmentProvider(File virtualMachineJar) {\n            this.virtualMachineJar = virtualMachineJar;\n        }\n\n        @Override\n        public Accessor attempt() {\n            return new ExternalAttachmentAccessor(virtualMachineJar);\n        }\n    }\n\n    private static final class ExternalAttachmentAccessor implements Accessor {\n        private final File virtualMachineJar;\n\n        private ExternalAttachmentAccessor(File virtualMachineJar) {\n            this.virtualMachineJar = virtualMachineJar;\n        }\n\n        @Override\n        public boolean isAvailable() {\n            return true;\n        }\n\n        @Override\n        public boolean isExternalAttachmentRequired() {\n            return true;\n        }\n\n        @Override\n        public Class<?> getVirtualMachineType() {\n            return RecordingVirtualMachine.class;\n        }\n\n        @Override\n        public ExternalAttachment getExternalAttachment() {\n            return new ExternalAttachment(\n                    RecordingVirtualMachine.class.getName(),\n                    Collections.singletonList(virtualMachineJar));\n        }\n    }\n\n    private static final class RecordingInstrumentation implements Instrumentation {\n        @Override\n        public void addTransformer(ClassFileTransformer transformer, boolean canRetransform) {\n        }\n\n        @Override\n        public void addTransformer(ClassFileTransformer transformer) {\n        }\n\n        @Override\n        public boolean removeTransformer(ClassFileTransformer transformer) {\n            return false;\n        }\n\n        @Override\n        public boolean isRetransformClassesSupported() {\n            return false;\n        }\n\n        @Override\n        public void retransformClasses(Class<?>... classes) throws UnmodifiableClassException {\n            throw new UnmodifiableClassException();\n        }\n\n        @Override\n        public boolean isRedefineClassesSupported() {\n            return false;\n        }\n\n        @Override\n        public void redefineClasses(ClassDefinition... definitions)\n                throws ClassNotFoundException, UnmodifiableClassException {\n            throw new UnmodifiableClassException();\n        }\n\n        @Override\n        public boolean isModifiableClass(Class<?> theClass) {\n            return false;\n        }\n\n        @Override\n        public Class[] getAllLoadedClasses() {\n            return new Class[0];\n        }\n\n        @Override\n        public Class[] getInitiatedClasses(ClassLoader loader) {\n            return new Class[0];\n        }\n\n        @Override\n        public long getObjectSize(Object objectToSize) {\n            return 0L;\n        }\n\n        @Override\n        public void appendToBootstrapClassLoaderSearch(JarFile jarfile) {\n        }\n\n        @Override\n        public void appendToSystemClassLoaderSearch(JarFile jarfile) {\n        }\n\n        @Override\n        public boolean isNativeMethodPrefixSupported() {\n            return false;\n        }\n\n        @Override\n        public void setNativeMethodPrefix(ClassFileTransformer transformer, String prefix) {\n        }\n\n        @Override\n        public void redefineModule(\n                Module module,\n                Set<Module> extraReads,\n                Map<String, Set<Module>> extraExports,\n                Map<String, Set<Module>> extraOpens,\n                Set<Class<?>> extraUses,\n                Map<Class<?>, List<Class<?>>> extraProvides) {\n        }\n\n        @Override\n        public boolean isModifiableModule(Module module) {\n            return false;\n        }\n    }\n\n    public static final class RecordingVirtualMachine {\n        private final String processId;\n\n        private RecordingVirtualMachine(String processId) {\n            this.processId = processId;\n        }\n\n        public static RecordingVirtualMachine attach(String processId) {\n            return new RecordingVirtualMachine(processId);\n        }\n\n        public void loadAgent(String agent, String argument) throws IOException {\n            Files.writeString(Path.of(argument), processId + System.lineSeparator() + agent);\n        }\n\n        public void loadAgentPath(String agent, String argument) throws IOException {\n            Files.writeString(Path.of(argument), processId + System.lineSeparator() + agent);\n        }\n\n        public void detach() {\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1781089797103}]}
