      @Test
      void fromInstalledAgentResolvesInstrumentationFromSystemInstaller() throws Throwable {
          try {
              Instrumentation instrumentation = new RetransformCapableInstrumentation();
              assertThat(fromNamedModule(instrumentation)).isNotNull();
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
      }
  
      private static Object fromNamedModule(Instrumentation instrumentation) throws Throwable {
          Path installerJar = writeModularInstallerJar();
          Path modularJar = writeModularByteBuddyJar();
          Class<?> installerClass = null;
          try {
              installerClass = defineSystemInstallerModule(installerJar);
              invokeInstallerPremain(installerClass, instrumentation);
  
              ModuleFinder finder = ModuleFinder.of(modularJar);
              Configuration configuration = ModuleLayer.boot().configuration()
                      .resolve(finder, ModuleFinder.of(), Set.of(BYTE_BUDDY_COPY_MODULE));
              ModuleLayer layer = ModuleLayer.boot()
                      .defineModulesWithOneLoader(configuration, ClassLoader.getPlatformClassLoader());
              Class<?> classReloadingStrategy = layer.findLoader(BYTE_BUDDY_COPY_MODULE)
                      .loadClass(CLASS_RELOADING_STRATEGY_NAME);
              MethodType methodType = MethodType.methodType(classReloadingStrategy);
              MethodHandle fromInstalledAgent = MethodHandles.publicLookup()
                      .findStatic(classReloadingStrategy, "fromInstalledAgent", methodType);
              return fromInstalledAgent.invoke();
          } finally {
              if (installerClass != null) {
                  invokeInstallerPremain(installerClass, null);
              }
              Files.deleteIfExists(modularJar);
              Files.deleteIfExists(installerJar);
          }
      }
  
      private static Class<?> defineSystemInstallerModule(Path installerJar) throws ClassNotFoundException {
          ModuleFinder finder = ModuleFinder.of(installerJar);
          Configuration configuration = ModuleLayer.boot().configuration()
                  .resolve(finder, ModuleFinder.of(), Set.of(BYTE_BUDDY_AGENT_COPY_MODULE));
          ModuleLayer layer = ModuleLayer.boot()
                  .defineModulesWithOneLoader(configuration, ClassLoader.getSystemClassLoader());
          Class<?> installerClass = layer.findLoader(BYTE_BUDDY_AGENT_COPY_MODULE).loadClass(INSTALLER_NAME);
          assertThat(installerClass.getModule().getName()).isEqualTo(BYTE_BUDDY_AGENT_COPY_MODULE);
          assertThat(ClassLoader.getSystemClassLoader().loadClass(INSTALLER_NAME)).isSameAs(installerClass);
          return installerClass;
      }
  
      private static void invokeInstallerPremain(
              Class<?> installerClass,
              Instrumentation instrumentation) throws Throwable {
          MethodType methodType = MethodType.methodType(void.class, String.class, Instrumentation.class);
          MethodHandle premain = MethodHandles.publicLookup().findStatic(installerClass, "premain", methodType);
          premain.invoke(null, instrumentation);
      }
  
      private static Path writeModularInstallerJar() throws IOException {
          Path jar = Files.createTempFile("blockhound-byte-buddy-agent-module", ".jar");
          Set<String> addedEntries = new HashSet<>();
          try (JarOutputStream jarOutputStream = new JarOutputStream(Files.newOutputStream(jar))) {
              writeEntry(jarOutputStream, addedEntries, "module-info.class", BYTE_BUDDY_AGENT_COPY_MODULE_INFO);
              try (InputStream inputStream = ClassReloadingStrategy.class.getClassLoader()
                      .getResourceAsStream(INSTALLER_RESOURCE)) {
                  assertThat(inputStream).isNotNull();
                  writeEntry(jarOutputStream, addedEntries, INSTALLER_RESOURCE, inputStream.readAllBytes());
              }
          }
          return jar;
      }
  
      private static Path writeModularByteBuddyJar() throws IOException, URISyntaxException {
          Path jar = Files.createTempFile("blockhound-byte-buddy-loading-module", ".jar");
          Set<String> addedEntries = new HashSet<>();
          try (JarOutputStream jarOutputStream = new JarOutputStream(Files.newOutputStream(jar))) {
              writeEntry(jarOutputStream, addedEntries, "module-info.class", BYTE_BUDDY_COPY_MODULE_INFO);
              Path codeSource = Path.of(ClassReloadingStrategy.class.getProtectionDomain()
                      .getCodeSource()
                      .getLocation()
                      .toURI());
              if (Files.isDirectory(codeSource)) {
                  copyByteBuddyClassesFromDirectory(codeSource, jarOutputStream, addedEntries);
              } else {
                  copyByteBuddyClassesFromJar(codeSource, jarOutputStream, addedEntries);
              }
          }
          return jar;
  
