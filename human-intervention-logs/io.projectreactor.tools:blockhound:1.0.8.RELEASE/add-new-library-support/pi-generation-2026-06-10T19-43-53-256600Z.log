  package io_projectreactor_tools.blockhound;
  
  import org.junit.jupiter.api.Test;
  import reactor.blockhound.shaded.net.bytebuddy.jar.asm.ClassReader;
  import reactor.blockhound.shaded.net.bytebuddy.jar.asm.ClassWriter;
  import reactor.blockhound.shaded.net.bytebuddy.jar.asm.Label;
  import reactor.blockhound.shaded.net.bytebuddy.jar.asm.MethodVisitor;
  import reactor.blockhound.shaded.net.bytebuddy.jar.asm.Opcodes;
  import reactor.blockhound.shaded.net.bytebuddy.jar.asm.Type;
  
  import java.util.ArrayList;
  import java.util.LinkedList;
  import java.util.List;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ClassWriterTest {
      private static final String ARRAY_LIST_TYPE = Type.getInternalName(ArrayList.class);
      private static final String LINKED_LIST_TYPE = Type.getInternalName(LinkedList.class);
      private static final String LIST_DESCRIPTOR = Type.getDescriptor(List.class);
      private static final String OBJECT_TYPE = Type.getInternalName(Object.class);
  
      @Test
      void computesCommonSuperclassForMergedFrameTypes() {
          ClassWriter classWriter = new ClassWriter(ClassWriter.COMPUTE_FRAMES);
          classWriter.visit(Opcodes.V1_8, Opcodes.ACC_PUBLIC, "example/GeneratedListFactory", null,
                  OBJECT_TYPE, null);
          writeDefaultConstructor(classWriter);
          writeMergedListFactoryMethod(classWriter);
          classWriter.visitEnd();
  
          byte[] classFile = classWriter.toByteArray();
  
          assertThat(new ClassReader(classFile).getClassName()).isEqualTo("example/GeneratedListFactory");
          assertThat(classFile).isNotEmpty();
      }
  
      private static void writeDefaultConstructor(ClassWriter classWriter) {
          MethodVisitor constructor = classWriter.visitMethod(Opcodes.ACC_PUBLIC, "<init>", "()V", null, null);
          constructor.visitCode();
          constructor.visitVarInsn(Opcodes.ALOAD, 0);
          constructor.visitMethodInsn(Opcodes.INVOKESPECIAL, OBJECT_TYPE, "<init>", "()V", false);
          constructor.visitInsn(Opcodes.RETURN);
          constructor.visitMaxs(0, 0);
          constructor.visitEnd();
      }
  
      private static void writeMergedListFactoryMethod(ClassWriter classWriter) {
          MethodVisitor method = classWriter.visitMethod(Opcodes.ACC_PUBLIC | Opcodes.ACC_STATIC, "newList",
                  "(Z)" + LIST_DESCRIPTOR, null, null);
          Label createLinkedList = new Label();
          Label returnList = new Label();
  
          method.visitCode();
          method.visitVarInsn(Opcodes.ILOAD, 0);
          method.visitJumpInsn(Opcodes.IFEQ, createLinkedList);
          method.visitTypeInsn(Opcodes.NEW, ARRAY_LIST_TYPE);
          method.visitInsn(Opcodes.DUP);
          method.visitMethodInsn(Opcodes.INVOKESPECIAL, ARRAY_LIST_TYPE, "<init>", "()V", false);
          method.visitJumpInsn(Opcodes.GOTO, returnList);
          method.visitLabel(createLinkedList);
          method.visitTypeInsn(Opcodes.NEW, LINKED_LIST_TYPE);
          method.visitInsn(Opcodes.DUP);
          method.visitMethodInsn(Opcodes.INVOKESPECIAL, LINKED_LIST_TYPE, "<init>", "()V", false);
          method.visitLabel(returnList);
          method.visitInsn(Opcodes.ARETURN);
          method.visitMaxs(0, 0);
          method.visitEnd();
      }
  }
