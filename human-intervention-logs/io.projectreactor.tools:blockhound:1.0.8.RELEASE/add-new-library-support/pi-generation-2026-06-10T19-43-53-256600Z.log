  import reactor.blockhound.shaded.net.bytebuddy.asm.ClassVisitorFactory;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ClassVisitorFactoryInnerCreateClassVisitorFactoryTest {
      @Test
      void createsFactoryForExternalAsmClassVisitorAndTranslatesVisitors() {
          try {
              ClassVisitorFactory<ClassVisitor> factory = ClassVisitorFactory.of(ClassVisitor.class);
  
              assertThat(factory.getType()).isEqualTo(ClassVisitor.class);
          } catch (Throwable throwable) {
              BlockHoundNativeImageSupport.rethrowIfNotExpectedNativeImageFailure(throwable);
          }
      }
  }
