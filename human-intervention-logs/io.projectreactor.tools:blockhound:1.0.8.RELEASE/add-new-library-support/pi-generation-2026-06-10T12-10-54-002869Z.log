  public class ClassFileLocatorInnerForInstrumentationTest {
      private static final String EXPLICIT_BYTE_BUDDY_MODULE = "blockhound.bytebuddy.classfilelocator.explicit";
      private static final String CLASS_FILE_LOCATOR =
              "reactor.blockhound.shaded.net.bytebuddy.dynamic.ClassFileLocator";
      private static final String CLASS_FILE_LOCATOR_FOR_INSTRUMENTATION =
