nimport java.util.Set;\nimport java.util.jar.JarEntry;\nimport java.util.jar.JarFile;\nimport java.util.stream.Collectors;\nimport java.util.stream.Stream;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ClassFileLocatorInnerForInstrumentationTest {\n    private static final String EXPLICIT_BYTE_BUDDY_MODULE = \"blockhound.bytebuddy.classfilelocator.explicit\";\n    private static final String CLASS_FILE_LOCATOR =\n            \"reactor.blockhound.shaded.net.bytebuddy.dynamic.ClassFileLocator\";\n    private static final String CLASS_FILE_LOCATOR_FOR_INSTRUMENTATION =\n            \"reactor.blockhound.shaded.net.bytebuddy.dynamic.ClassFileLocator$ForInstrumentation\";\n\n    @Test\n    void fromInstalledAgentResolvesInstrumentationThroughSystemInstaller() throws Throwable {\n        Instrumentation instrumentation = new RetransformCapableInstrumentation();\n        try {\n            Installer.premain(null, instrumentation);\n            try {\n                ClassFileLocator classFileLocator = ClassFileLocator.ForInstrumentation.fromInstalledAgent(\n                        ClassLoader.getSystemClassLoader());\n                classFileLocator.close();\n\n                invokeClassFileLocatorFromExplicitModule();\n            } catch (Error error) {\n                if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                    throw error;\n                }\n            }\n        } finally {\n            Installer.premain(null, null);\n        }\n    }\n\n    private static void invokeClassFileLocatorFromExplicitModule() throws Throwable {\n        Path blockHoundJar = Path.of(ClassFileLocator.class.getProtectionDomain()\n                .getCodeSource()\n                .getLocation()\n                .toURI());\n        ModuleFinder finder = new ExplicitBlockHoundModuleFinder(blockHoundJar);\n        Configuration configuration = ModuleLayer.boot().configuration()\n                .resolve(finder, ModuleFinder.of