      @Test
      void fromInstalledAgentResolvesInstrumentationThroughSystemInstaller() throws Throwable {
          Instrumentation instrumentation = new RetransformCapableInstrumentation();
          try {
              Installer.premain(null, instrumentation);
              try {
                  ClassFileLocator classFileLocator = ClassFileLocator.ForInstrumentation.fromInstalledAgent(
                          ClassLoader.getSystemClassLoader());
                  classFileLocator.close();
  
                  invokeClassFileLocatorFromExplicitModule();
              } catch (Error error) {
                  if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                      throw error;
                  }
              }
          } finally {
              Installer.premain(null, null);
          }
      }
  
      private static void invokeClassFileLocatorFromExplicitModule() throws Throwable {
          Path blockHoundJar = Path.of(ClassFileLocator.class.getProtectionDomain()
                  .getCodeSource()
