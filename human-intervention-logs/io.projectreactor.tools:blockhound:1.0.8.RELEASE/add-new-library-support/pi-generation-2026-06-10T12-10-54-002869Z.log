                  .toURI());
          ModuleFinder finder = new ExplicitBlockHoundModuleFinder(blockHoundJar);
          Configuration configuration = ModuleLayer.boot().configuration()
                  .resolve(finder, ModuleFinder.of(), Set.of(EXPLICIT_BYTE_BUDDY_MODULE));
          ModuleLayer layer = ModuleLayer.boot()
                  .defineModulesWithOneLoader(configuration, ClassLoader.getPlatformClassLoader());
          ClassLoader moduleClassLoader = layer.findLoader(EXPLICIT_BYTE_BUDDY_MODULE);
          Class<?> locatorType = moduleClassLoader.loadClass(CLASS_FILE_LOCATOR);
          Class<?> locatorFactory = moduleClassLoader.loadClass(CLASS_FILE_LOCATOR_FOR_INSTRUMENTATION);
          MethodHandle fromInstalledAgent = MethodHandles.publicLookup().findStatic(locatorFactory,
                  "fromInstalledAgent", MethodType.methodType(locatorType, ClassLoader.class));
          MethodHandle close = MethodHandles.publicLookup()
                  .findVirtual(locatorType, "close", MethodType.methodType(void.class));
  
          Object classFileLocator = fromInstalledAgent.invoke(ClassLoader.getSystemClassLoader());
          assertThat(classFileLocator).isNotNull();
          close.invoke(classFileLocator);
