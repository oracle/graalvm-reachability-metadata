AME = \"io_projectreactor_tools.blockhound.unsafeoverride.generated\";\n\n    static {\n        System.setProperty(BYTE_BUDDY_SAFE_PROPERTY, \"false\");\n    }\n\n    @Test\n    void unsafeOverrideDispatcherDefinesAndFindsClassesAndPackages() throws Exception {\n        try {\n            ClassInjector.UsingReflection.Dispatcher dispatcher = unsafeOverrideDispatcher();\n            PackageAwareClassLoader classLoader = new PackageAwareClassLoader();\n            String className = PACKAGE_NAME + \".InjectedType\";\n\n            assertThat(dispatcher.findClass(classLoader, className)).isNull();\n\n            Package definedPackage = dispatcher.definePackage(classLoader, PACKAGE_NAME,\n                    \"specification-title\", \"1\", \"specification-vendor\",\n                    \"implementation-title\", \"1\", \"implementation-vendor\", null);\n            assertThat(definedPackage).isNotNull();\n            assertThat(definedPackage.getName()).isEqualTo(PACKAGE_NAME);\n            assertThat(dispatcher.getDefinedPackage(classLoader, PACKAGE_NAME)).isSameAs(definedPackage);\n            assertThat(dispatcher.getPackage(classLoader, PACKAGE_NAME)).isSameAs(definedPackage);\n\n            Class<?> loaded = dispatcher.defineClass(classLoader, className, generatedTypeBytes(className),\n                    getClass().getProtectionDomain());\n\n            assertThat(loaded.getName()).isEqualTo(className);\n            assertThat(loaded.getClassLoader()).isSameAs(classLoader);\n            assertThat(dispatcher.findClass(classLoader, className)).isSameAs(loaded);\n        } catch (Error error) {\n            verifyNativeImageUnsupportedFeature(error);\n        }\n    }\n\n    @Test\n    @SuppressWarnings(\"removal\")\n    void unsafeOverrideDispatcherInitializesWithSecurityManager() throws Exception {\n        SecurityManager previousSecurityManager = null;\n        boolean securityManagerChanged = false;\n        try {\n            previousSecurityManager = System.getSecurityManager();\n            System.setSecurityManager(new PermissiveSecurityManager());\n            securityManagerChanged = true;\n\n            ClassInjector.UsingReflection.Dispatcher dispatcher = unsafeOverrideDispatcher();\n\n            assertThat(dispatcher).isNotNull();\n        } catch (UnsupportedOperationException exception) {\n            assertThat(exception).isNotNull();\n        } catch (Error error) {\n            verifyNativeImageUnsupportedFeature(error);\n        } finally {\n            if (securityManagerChanged) {\n                System.setSecurityManager(previousSecurityManager);\n            }\n        }\n    }\n\n    private static ClassInjector.UsingReflection.Dispatcher unsafeOverrideDispatcher() throws Exception {\n        ClassInjector.UsingReflection.Dispatcher.Initializable initializable = ExposedUsingUnsafeOverride.makeDispatcher();\n        assertThat(initializable.isAvailable()).isTrue();\n        return initializable.initialize();\n    }\n\n    private static byte[] generatedTypeBytes(String className) {\n        DynamicType.Unloaded<Object> generatedType = new ByteBuddy()\n                .subclass(Object.class)\n                .name(className)\n                .defineField(\"marker\", String.class, Visibility.PUBLIC)\n                .make();\n        return generatedType.getBytes();\n    }\n\n    private static void verifyNativeImageUnsupportedFeature(Error error) {\n        if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n            throw error;\n        }\n    }\n\n    private static class PackageAwareClassLoader extends ClassLoader {\n        PackageAwareClassLoader() {\n            super(ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeOverrideTest.class.getClassLoader());\n        }\n    }\n\n    @SuppressWarnings(\"removal\")\n    private static final class PermissiveSecurityManager extends SecurityManager {\n        @Override\n        public void checkPermission(Permission permission) {\n            permission.getClass();\n        }\n    }\n\n    private abstract static class ExposedUsingUnsafeOverride\n            extends ClassInjector.UsingReflection.Dispatcher.UsingUnsafeOverride {\n        ExposedUsingUnsafeOverride(Method findLoadedClass, Method defineClass, Method getDefinedPackage,\n                Method getPackage, Method definePackage) {\n            super(findLoadedClass, defineClass, getDefinedPackage, getPackage, definePackage);\n        }\n\n        static ClassInjector.UsingReflection.Dispatcher.Initializable makeDispatcher() throws Exception {\n            return make();\n        }\n    }\n}\n"}, "partialJson": "{\"path\":\"tests/src/io.projectreactor.tools/blockhound/1.0.8.RELEASE/src/test/java/io_projectreactor_tools/blockhound/ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeOverrideTest.java\",\"content\":\"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage io_projectreactor_tools.blockhound;\\n\\nimport java.lang.reflect.Method;\\nimport java.security.Permission;\\n\\nimport org.graalvm.internal.tck.NativeImageSupport;\\nimport org.junit.jupiter.api.Test;\\n\\nimport reactor.blockhound.shaded.net.bytebuddy.ByteBuddy;\\nimport reactor.blockhound.shaded.net.bytebuddy.description.modifier.Visibility;\\nimport reactor.blockhound.shaded.net.bytebuddy.dynamic.DynamicType;\\nimport reactor.blockhound.shaded.net.bytebuddy.dynamic.loading.ClassInjector;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\n\\npublic class ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeOverrideTest {\\n    private static final String BYTE_BUDDY_SAFE_PROPERTY = \\\"reactor.blockhound.shaded.net.bytebuddy.safe\\\";\\n    private static final String PACKAGE_NAME = \\\"io_projectreactor_tools.blockhound.unsafeoverride.generated\\\";\\n\\n    sta