  package io_projectreactor_tools.blockhound;
  
  import java.lang.reflect.Method;
  import java.net.URL;
  import java.security.Permission;
  
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  
  import reactor.blockhound.shaded.net.bytebuddy.ByteBuddy;
  import reactor.blockhound.shaded.net.bytebuddy.description.modifier.Visibility;
  import reactor.blockhound.shaded.net.bytebuddy.dynamic.DynamicType;
  import reactor.blockhound.shaded.net.bytebuddy.dynamic.loading.ClassInjector;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeOverrideTest {
      private static final String BYTE_BUDDY_SAFE_PROPERTY = "reactor.blockhound.shaded.net.bytebuddy.safe";
      private static final String BYTE_BUDDY_EXPERIMENTAL_PROPERTY =
              "reactor.blockhound.shaded.net.bytebuddy.experimental";
      private static final String PACKAGE_NAME = "io_projectreactor_tools.blockhound.unsafeoverride.generated";
  
      static {
          System.setProperty(BYTE_BUDDY_SAFE_PROPERTY, "false");
          System.setProperty(BYTE_BUDDY_EXPERIMENTAL_PROPERTY, "true");
      }
  
      @Test
      void unsafeOverrideDispatcherDefinesAndFindsClassesAndPackages() throws Exception {
          try {
              UnsafeOverrideHarness.DispatcherHarness dispatcher = UnsafeOverrideHarness.createDispatcher();
              PackageAwareClassLoader classLoader = new PackageAwareClassLoader();
              String className = PACKAGE_NAME + ".InjectedType";
  
              assertThat(dispatcher.findClass(classLoader, className)).isNull();
  
              Package definedPackage = dispatcher.definePackage(classLoader, PACKAGE_NAME,
                      "specification-title", "1", "specification-vendor",
                      "implementation-title", "1", "implementation-vendor", null);
              assertThat(definedPackage).isNotNull();
              assertThat(definedPackage.getName()).isEqualTo(PACKAGE_NAME);
              assertThat(dispatcher.getDefinedPackage(classLoader, PACKAGE_NAME)).isSameAs(definedPackage);
              assertThat(dispatcher.getPackage(classLoader, PACKAGE_NAME)).isSameAs(definedPackage);
  
              Class<?> loaded = dispatcher.defineClass(classLoader, className, generatedTypeBytes(className));
  
              assertThat(loaded.getName()).isEqualTo(className);
              assertThat(loaded.getClassLoader()).isSameAs(classLoader);
              assertThat(dispatcher.findClass(classLoader, className)).isSameAs(loaded);
          } catch (Error error) {
              verifyNativeImageUnsupportedFeature(error);
          }
      }
  
      @Test
      @SuppressWarnings("removal")
      void unsafeOverrideDispatcherInitializesWithSecurityManager() throws Exception {
          SecurityManager previousSecurityManager = null;
          boolean securityManagerChanged = false;
          try {
              previousSecurityManager = System.getSecurityManager();
              System.setSecurityManager(new PermissiveSecurityManager());
              securityManagerChanged = true;
  
              UnsafeOverrideHarness.DispatcherHarness dispatcher = UnsafeOverrideHarness.createDispatcher();
  
              assertThat(dispatcher).isNotNull();
          } catch (UnsupportedOperationException exception) {
              assertThat(exception).isNotNull();
          } catch (Error error) {
              verifyNativeImageUnsupportedFeature(error);
          } finally {
              if (securityManagerChanged) {
                  System.setSecurityManager(previousSecurityManager);
              }
          }
      }
  
      private static byte[] generatedTypeBytes(String className) {
          DynamicType.Unloaded<Object> generatedType = new ByteBuddy()
                  .subclass(Object.class)
                  .name(className)
                  .defineField("marker", String.class, Visibility.PUBLIC)
                  .make();
          return generatedType.getBytes();
      }
  
      private static void verifyNativeImageUnsupportedFeature(Error error) {
          if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
              throw error;
          }
      }
  
      private static class PackageAwareClassLoader extends ClassLoader {
          PackageAwareClassLoader() {
              super(ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeOverrideTest.class.getClassLoader());
          }
      }
  
      @SuppressWarnings("removal")
      private static final class PermissiveSecurityManager extends SecurityManager {
          @Override
          public void checkPermission(Permission permission) {
              permission.getClass();
          }
      }
  }
  
  final class UnsafeOverrideHarness extends ClassInjector.UsingReflection {
      UnsafeOverrideHarness(ClassLoader classLoader) {
          super(classLoader);
      }
  
      static DispatcherHarness createDispatcher() throws Exception {
          Dispatcher.Initializable initializable = ExposedUsingUnsafeOverride.makeDispatcher();
          assertThat(initializable.isAvailable()).isTrue();
          return new DispatcherHarness(initializable.initialize());
      }
  
      static final class DispatcherHarness {
          private final Dispatcher dispatcher;
  
          private DispatcherHarness(Dispatcher dispatcher) {
              this.dispatcher = dispatcher;
          }
  
          Class<?> findClass(ClassLoader classLoader, String className) {
              return dispatcher.findClass(classLoader, className);
          }
  
          Class<?> defineClass(ClassLoader classLoader, String className, byte[] binaryRepresentation) {
              return dispatcher.defineClass(classLoader, className, binaryRepresentation,
                      getClass().getProtectionDomain());
          }
  
          Package getDefinedPackage(ClassLoader classLoader, String packageName) {
              return dispatcher.getDefinedPackage(classLoader, packageName);
          }
  
          Package getPackage(ClassLoader classLoader, String packageName) {
              return dispatcher.getPackage(classLoader, packageName);
          }
  
          Package definePackage(ClassLoader classLoader, String packageName, String specificationTitle,
                  String specificationVersion, String specificationVendor, String implementationTitle,
                  String implementationVersion, String implementationVendor, URL sealBase) {
              return dispatcher.definePackage(classLoader, packageName, specificationTitle, specificationVersion,
                      specificationVendor, implementationTitle, implementationVersion, implementationVendor, sealBase);
          }
      }
  
      private abstract static class ExposedUsingUnsafeOverride extends Dispatcher.UsingUnsafeOverride {
          ExposedUsingUnsafeOverride(Method findLoadedClass, Method defineClass, Method getDefinedPackage,
                  Method getPackage, Method definePackage) {
              super(findLoadedClass, defineClass, getDefinedPackage, getPackage, definePackage);
          }
  
          static Dispatcher.Initializable makeDispatcher() throws Exception {
              return make();
          }
      }
  }
