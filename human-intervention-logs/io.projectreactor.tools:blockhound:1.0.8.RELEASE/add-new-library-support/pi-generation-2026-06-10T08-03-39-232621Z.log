     180	         * <p>
     181	         * A class loading strategy which applies a class loader injection while applying a given {@link java.security.ProtectionDomain} on class injection.
     182	         * </p>
     183	         * <p>
     184	         * <b>Important</b>: Class injection requires access to JVM internal methods that are sealed by security managers and the
     185	         * Java Platform module system. Since Java 11, access to these methods is no longer feasible unless those packages
     186	         * are explicitly opened.
     187	         * </p>
     188	         */
     189	        @HashCodeAndEqualsPlugin.Enhance
     190	        protected static class InjectionDispatcher implements ClassLoadingStrategy.Configurable<ClassLoader> {
     191	
     192	            /**
     193	             * The protection domain to apply or {@code null} if no protection domain is set.
     194	             */
     195	            @MaybeNull
     196	            @HashCodeAndEqualsPlugin.ValueHandling(HashCodeAndEqualsPlugin.ValueHandling.Sort.REVERSE_NULLABILITY)
     197	            private final ProtectionDomain protectionDomain;
     198	
     199	            /**
     200	             * The package definer to be used for querying information on package information.
     201	             */
     202	            private final PackageDefinitionStrategy packageDefinitionStrategy;
     203	
     204	            /**
     205	             * Determines if an exception should be thrown when attempting to load a type that already exists.
     206	             */
     207	            private final boolean forbidExisting;
     208	
     209	            /**
     210	             * Creates a new injection dispatcher.
     211	             */
     212	            protected InjectionDispatcher() {
     213	                this(NO_PROTECTION_DOMAIN, PackageDefinitionStrategy.NoOp.INSTANCE, DEFAULT_FORBID_EXISTING);
     214	            }
     215	
     216	            /**
     217	             * Creates a new injection dispatcher.
     218	             *
     219	             * @param protectionDomain          The protection domain to apply or {@code null} if no protection domain is set.
     220	             * @param packageDefinitionStrategy The package definer to be used for querying information on package information.
     221	             * @param forbidExisting            Determines if an exception should be thrown when attempting to load a type that already exists.
     222	             */
     223	            private InjectionDispatcher(@MaybeNull ProtectionDomain protectionDomain,
     224	                                        PackageDefinitionStrategy packageDefinitionStrategy,
     225	                                        boolean forbidExisting) {
     226	                this.protectionDomain = protectionDomain;
     227	                this.packageDefinitionStrategy = packageDefinitionStrategy;
     228	                this.forbidExisting = forbidExisting;
     229	            }
     230	
     231	            /**
     232	             * {@inheritDoc}
     233	             */
     234	            public Map<TypeDescription, Class<?>> load(@MaybeNull ClassLoader classLoader, Map<TypeDescription, byte[]> types) {
     235	                if (classLoader == null) {
     236	                    throw new IllegalArgumentException("Cannot inject classes into the bootstrap class loader");
     237	                }
     238	                return new ClassInjector.UsingReflection(classLoader,
     239	                        protectionDomain,
     240	                        packageDefinitionStrategy,
     241	                        forbidExisting).inject(types);
     242	            }
