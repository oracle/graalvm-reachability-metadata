 Package definedPackage = dispatcher.getDefinedPackage(classLoader, packageName);\n   252\t                                if (definedPackage == null) {\n   253\t                                    try {\n   254\t                                        dispatcher.definePackage(classLoader,\n   255\t                                                packageName,\n   256\t                                                definition.getSpecificationTitle(),\n   257\t                                                definition.getSpecificationVersion(),\n   258\t                                                definition.getSpecificationVendor(),\n   259\t                                                definition.getImplementationTitle(),\n   260\t                                                definition.getImplementationVersion(),\n   261\t                                                definition.getImplementationVendor(),\n   262\t                                                definition.getSealBase());\n   263\t                                    } catch (IllegalStateException exception) {\n   264\t                                        // Custom classloaders may call getPackage (instead of getDefinedPackage) from\n   265\t                                        // within definePackage, which can cause the package to be defined in an\n   266\t                                        // ancestor classloader or find a previously defined one from an ancestor. In\n   267\t                                        // this case definePackage will also throw since it considers that package\n   268\t                                        // already loaded and will not allow to define it directly in this classloader.\n   269\t                                        // To make sure this is the case, call getPackage instead of getDefinedPackage\n   270\t                                        // here and verify that we actually have a compatible package defined in an\n   271\t       