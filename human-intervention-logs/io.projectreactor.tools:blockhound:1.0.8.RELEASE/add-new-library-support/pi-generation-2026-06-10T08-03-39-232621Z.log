fore, calls to\n   119\t         * {@link Class#getPackage()} might return {@code null}. Packages are only defined manually by a class loader prior to\n   120\t         * Java 9.\n   121\t         * </p>\n   122\t         */\n   123\t        INJECTION(new InjectionDispatcher());\n   124\t\n   125\t        /**\n   126\t         * The default behavior when attempting to load a type that was already loaded.\n   127\t         */\n   128\t        private static final boolean DEFAULT_FORBID_EXISTING = true;\n   129\t\n   130\t        /**\n   131\t         * The dispatcher to be used when loading a class.\n   132\t         */\n   133\t        private final Configurable<ClassLoader> dispatcher;\n   134\t\n   135\t        /**\n   136\t         * Creates a new default class loading strategy.\n   137\t         *\n   138\t         * @param dispatcher The dispatcher to be used when loading a class.\n   139\t         */\n   140\t        Default(Configurable<ClassLoader> dispatcher) {\n   141\t            this.dispatcher = dispatcher;\n   142\t        }\n   143\t\n   144\t        /**\n   145\t         * {@inheritDoc}\n   146\t         */\n   147\t        public Map<TypeDescription, Class<?>> load(@MaybeNull ClassLoader classLoader, Map<TypeDescription, byte[]> types) {\n   148\t            return dispatcher.load(classLoader, types);\n   149\t        }\n   150\t\n   151\t        /**\n   152\t         * {@inheritDoc}\n   153\t         */\n   154\t        public Configurable<ClassLoader> with(ProtectionDomain protectionDomain) {\n   155\t            return dispatcher.with(protectionDomain);\n   156\t        }\n   157\t\n   158\t        /**\n   159\t         * {@inheritDoc}\n   160\t         */\n   161\t        public Configurable<ClassLoader> with(PackageDefinitionStrategy packageDefinitionStrategy) {\n   162\t            return dispatcher.with(packageDefinitionStrategy);\n   163\t        }\n   164\t\n   165\t        /**\n   166\t         * {@inheritDoc}\n   167\t         */\n   168\t        public Configurable<ClassLoader> allowExistingTypes() {\n   169\t            return dispatcher.allowExistingTypes();\n   170\t        }\n   171\t\n   172\t        /**\n   173\t         * {@inheritDoc}\n   174\t         */\n   175\t        public Configurable<ClassLoader> opened() {\n   176\t            return dispatcher.opened();\n   177\t        }\n   178\t\n   179\t        /**\n   180\t         * <p>\n"}], "isError": false, "timestamp": 1781078406192}]}
