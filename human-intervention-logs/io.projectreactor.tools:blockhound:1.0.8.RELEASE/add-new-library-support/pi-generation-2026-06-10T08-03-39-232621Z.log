[tool-call] delta {"path":"tests/src/io.projectreactor.tools/blockhound/1.0.8.RELEASE/src/test/java/io_projectreactor_tools/blockhound/ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeInjectionTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_projectreactor_tools.blockhound;\n\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\nimport reactor.blockhound.shaded.net.bytebuddy.ByteBuddy;\nimport reactor.blockhound.shaded.net.bytebuddy.dynamic.loading.ClassLoadingStrategy;\nimport reactor.blockhound.shaded.net.bytebuddy.dynamic.loading.PackageDefinitionStrategy;\n\nimport java.net.URL;\nimport java.net.URLClassLoader;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeInjectionTest {\n    private static final String PARENT_PACKAGE_NAME =\n            ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeInjectionTest.class.getPackageName();\n\n    @Test\n    void injectsGeneratedClassIntoCustomClassLoaderAndDefinesPackage() throws Exception {\n        ClassLoadingStrategy<ClassLoader> strategy = ClassLoadingStrategy.Default.INJECTION\n                .with(PackageDefinitionStrategy.Trivial.INSTANCE);\n        String className = \"io_projectreactor_tools.blockhound.generated.Injected\" + System.nanoTime();\n\n        try (URLClassLoader classLoader = new URLClassLoader(new URL[0], getClass().getClassLoader())) {\n            Class<?> generatedClass = injectGeneratedClass(classLoader, className, strategy);\n\n            assertThat(generatedClass.getName()).isEqualTo(className);\n            assertThat(generatedClass.getClassLoader()).isSameAs(classLoader);\n        } catch (Error error) {\n            rethrowUnlessUnsupportedFeatureError(error);\n        }\n    }\n\n    @Test\n    void fallsBackToParentPackageWhenCustomClassLoaderRejectsPackageDefinition() throws Exception {\n        ClassLoadingStrategy<ClassLoader> strategy = ClassLoadingStrategy.Default.INJECTION\n                .with(PackageDefinitionStrategy.Trivial.INSTANCE);\n        String className = PARENT_PACKAGE_NAME + \".InjectedIntoParentPackage\" + System.nanoTime();\n\n        try (RejectingPackageClassLoader classLoader = new RejectingPackageClassLoader(getClass().getClassLoader())) {\n            Class<?> generatedClass = injectGeneratedClass(classLoader, className, strategy);\n\n            assertThat(generatedClass.getName()).isEqualTo(className);\n            assertThat(generatedClass.getClassLoader()).isSameAs(classLoader);\n        } catch (Error error) {\n            rethrowUnlessUnsupportedFeatureError(error);\n        }\n    }\n\n    private static Class<?> injectGeneratedClass(\n            ClassLoader classLoader,\n            String className,\n            ClassLoadingStrategy<ClassLoader> strategy) {\n        return new ByteBuddy()\n                .subclass(Object.class)\n                .name(className)\n                .make()\n                .load(classLoader, strategy)\n                .getLoaded();\n    }\n\n    private static void rethrowUnlessUnsupportedFeatureError(Error error) {\n        if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n            throw error;\n        }\n    }\n\n    private static final class RejectingPackageClassLoader extends URLClassLoader {\n        private RejectingPackageClassLoader(ClassLoader parent) {\n            super(new URL[0], parent);\n        }\n\n        @Override\n        protected Package definePackage(\n                String name,\n                String specificationTitle,\n                String specificationVersion,\n                String specificationVendor,\n                String implementationTitle,\n                String implementationVersion,\n                String implementationVendor,\n                URL sealBase) {\n            if (PARENT_PACKAGE_NAME.equals(name)) {\n                throw new IllegalStateException(\"Use parent package definition\");\n            }\n            return super.definePackage(\n                    name,\n                    specificationTitle,\n                    specificationVersion,\n                    specificationVendor,\n                    implementationTitle,\n                    implementationVersion,\n                    implementationVendor,\n                    sealBase);\n        }\n    }\n}\n"}
