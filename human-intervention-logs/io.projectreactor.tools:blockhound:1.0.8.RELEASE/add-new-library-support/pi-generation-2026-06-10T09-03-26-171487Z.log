[tool-call] delta {"path":"tests/src/io.projectreactor.tools/blockhound/1.0.8.RELEASE/src/test/java/io_projectreactor_tools/blockhound/ByteArrayClassLoaderInnerChildFirstTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_projectreactor_tools.blockhound;\n\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\nimport reactor.blockhound.shaded.net.bytebuddy.ByteBuddy;\nimport reactor.blockhound.shaded.net.bytebuddy.dynamic.loading.ClassLoadingStrategy;\n\nimport java.io.IOException;\nimport java.net.URL;\nimport java.util.Enumeration;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ByteArrayClassLoaderInnerChildFirstTest {\n    private static final Class<?> TEST_CLASS = ByteArrayClassLoaderInnerChildFirstTest.class;\n\n    @Test\n    void childFirstLoaderLoadsGeneratedTypesAndDelegatesResources() throws IOException {\n        try {\n            Class<?> generatedClass = loadGeneratedClass(\"Latent\", ClassLoadingStrategy.Default.CHILD_FIRST);\n            ClassLoader classLoader = generatedClass.getClassLoader();\n            String generatedResourceName = generatedClass.getName().replace('.', '/') + \".class\";\n\n            assertThat(classLoader.loadClass(generatedClass.getName())).isSameAs(generatedClass);\n            assertThat(classLoader.getResource(generatedResourceName)).isNull();\n\n            String parentResourceName = \"org/junit/jupiter/api/Test.class\";\n            URL parentResource = classLoader.getResource(parentResourceName);\n            Enumeration<URL> parentResources = classLoader.getResources(parentResourceName);\n\n            assertThat(parentResource).isNotNull();\n            assertThat(parentResources.hasMoreElements()).isTrue();\n        } catch (Error error) {\n            rethrowUnlessUnsupportedFeatureError(error);\n        }\n    }\n\n    @Test\n    void persistentChildFirstLoaderExposesGeneratedClassResources() throws IOException {\n        try {\n            Class<?> generatedClass = loadGeneratedClass(\"Persistent\", ClassLoadingStrategy.Default.CHILD_FIRST_PERSISTENT);\n            ClassLoader classLoader = generatedClass.getClassLoader();\n            String generatedResourceName = generatedClass.getName().replace('.', '/') + \".class\";\n\n            URL generatedResource = classLoader.getResource(generatedResourceName);\n            Enumeration<URL> generatedResources = classLoader.getResources(generatedResourceName);\n\n            assertThat(generatedResource).isNotNull();\n            assertThat(generatedResources).isNotNull();\n        } catch (Error error) {\n            rethrowUnlessUnsupportedFeatureError(error);\n        }\n    }\n\n    private static Class<?> loadGeneratedClass(\n            String nameSuffix,\n            ClassLoadingStrategy<ClassLoader> classLoadingStrategy) {\n        String className = \"io_projectreactor_tools.blockhound.generated.childfirst.Generated\"\n                + nameSuffix\n                + System.nanoTime();\n        return new ByteBuddy()\n                .subclass(Object.class)\n                .name(className)\n                .make()\n                .load(TEST_CLASS.getClassLoader(), classLoadingStrategy)\n                .getLoaded();\n    }\n\n    private static void rethrowUnlessUnsupportedFeatureError(Error error) {\n        if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n            throw error;\n        }\n    }\n}\n"}
[tool-call] end id=call_pmfc4pr0Os1sxbxBRsh75MWp|fc_028505847d8167b2016a29283906448193949c77c8157364fb name=write args={"path": "tests/src/io.projectreactor.tools/blockhound/1.0.8.RELEASE/src/test/java/io_projectreactor_tools/blockhound/ByteArrayClassLoaderInnerChildFirstTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_projectreactor_tools.blockhound;\n\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\nimport reactor.blockhound.shaded.net.bytebuddy.ByteBuddy;\nimport reactor.blockhound.shaded.net.bytebuddy.dynamic.loading.ClassLoadingStrategy;\n\nimport java.io.IOException;\nimport java.net.URL;\nimport java.util.Enumeration;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ByteArrayClassLoaderInnerChildFirstTest {\n    private static final Class<?> TEST_CLASS = ByteArrayClassLoaderInnerChildFirstTest.class;\n\n    @Test\n    void childFirstLoaderLoadsGeneratedTypesAndDelegatesResources() throws IOException {\n        try {\n            Class<?> generatedClass = loadGeneratedClass(\"Latent\", ClassLoadingStrategy.Default.CHILD_FIRST);\n            ClassLoader classLoader = generatedClass.getClassLoader();\n            String generatedResourceName = generatedClass.getName().replace('.', '/') + \".class\";\n\n            assertThat(classLoader.loadClass(generatedClass.getName())).isSameAs(generatedClass);\n            assertThat(classLoader.getResource(generatedResourceName)).isNull();\n\n            String parentResourceName = \"org/junit/jupiter/api/Test.class\";\n            URL parentResource = classLoader.getResource(parentResourceName);\n            Enumeration<URL> parentResources = classLoader.getResources(parentResourceName);\n\n            assertThat(parentResource).isNotNull();\n            assertThat(parentResources.hasMoreElements()).isTrue();\n        } catch (Error error) {\n            rethrowUnlessUnsupportedFeatureError(error);\n        }\n    }\n\n    @Test\n    void persistentChildFirstLoaderExposesGeneratedClassResources() throws IOException {\n        try {\n            Class<?> generatedClass = loadGeneratedClass(\"Persistent\", ClassLoadingStrategy.Default.CHILD_FIRST_PERSISTENT);\n            ClassLoader classLoader = generatedClass.getClassLoader();\n            String generatedResourceName = generatedClass.getName().replace('.', '/') + \".class\";\n\n            URL generatedResource = classLoader.getResource(generatedResourceName);\n            Enumeration<URL> generatedResources = classLoader.getResources(generatedResourceName);\n\n            assertThat(generatedResource).isNotNull();\n            assertThat(generatedResources).isNotNull();\n        } catch (Error error) {\n            rethrowUnlessUnsupportedFeatureError(error);\n        }\n    }\n\n    private static Class<?> loadGeneratedClass(\n            String nameSuffix,\n            ClassLoadingStrategy<ClassLoader> classLoadingStrategy) {\n        String className = \"io_projectreactor_tools.blockhound.generated.childfirst.Generated\"\n                + nameSuffix\n                + System.nanoTime();\n        return new ByteBuddy()\n                .subclass(Object.class)\n                .name(className)\n                .make()\n                .load(TEST_CLASS.getClassLoader(), classLoadingStrategy)\n                .getLoaded();\n    }\n\n    private static void rethrowUnlessUnsupportedFeatureError(Error error) {\n        if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n            throw error;\n        }\n    }\n}\n"}
