\n            URL generatedResource = classLoader.getResource(generatedResourceName);\n            Enumeration<URL> generatedResources = classLoader.getResources(generatedResourceName);\n\n            assertThat(generatedResource).isNotNull();\n            assertThat(generatedResources).isNotNull();\n        } catch (Error error) {\n            rethrowUnlessUnsupportedFeatureError(error);\n        }\n    }\n\n    private static Class<?> loadGeneratedClass(\n            String nameSuffix,\n            ClassLoadingStrategy<ClassLoader> classLoadingStrategy) {\n        String className = \"io_projectreactor_tools.blockhound.generated.childfirst.Generated\"\n                + nameSuffix\n                + System.nanoTime();\n        return new ByteBuddy()\n                .subclass(Object.class)\n                .name(className)\n                .make()\n                .load(TEST_CLASS.getClassLoader(), classLoadingStrategy)\n                .getLoaded();\n    }\n\n    private static void rethrowUnlessUnsupportedFeatureError(Error error) {\n        if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n            throw error;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 3875, "output": 1666, "cacheRead": 42496, "cacheWrite": 0, "totalTokens": 48037, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1781082143155, "responseId": "resp_028505847d8167b2016a29281fc3c08193ad1dfba65d46579c"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_pmfc4pr0Os1sxbxBRsh75MWp|fc_028505847d8167b2016a29283906448193949c77c8157364fb", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 3359 bytes to tests/src/io.projectreactor.tools/blockhound/1.0.8.RELEASE/src/test/java/io_projectreactor_tools/blockhound/ByteArrayClassLoaderInnerChildFirstTest.java"}], "isError": false, "timestamp": 1781082178360}]}
