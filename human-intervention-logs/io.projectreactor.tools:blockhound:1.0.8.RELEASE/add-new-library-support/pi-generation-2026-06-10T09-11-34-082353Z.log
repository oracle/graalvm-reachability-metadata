aram processId          The target process id.\n277:      * @param attachmentProvider The attachment provider to use.\n278:      */\n279:     public static void attach(File agentJar, String processId, AttachmentProvider attachmentProvider) {\n280:         attach(agentJar, processId, WITHOUT_ARGUMENT, attachmentProvider);\n281:     }\n282: \n283:     /**\n284:      * <p>\n285:      * Attaches the given agent Jar on the target process which must be a virtual machine process. This operation blocks until the\n286:      * attachment is complete.\n287:      * </p>\n288:      * <p>\n289:      * <b>Important</b>: It is only possible to attach to processes that are executed by the same operating system user.\n290:      * </p>\n291:      *\n292:      * @param agentJar           The agent jar file.\n293:      * @param processId          The target process id.\n294:      * @param argument           The argument to provide to the agent.\n295:      * @param attachmentProvider The attachment provider to use.\n296:      */\n297:     public static void attach(File agentJar, String processId, @MaybeNull String argument, AttachmentProvider attachmentProvider) {\n298:         install(attachmentProvider, processId, argument, new AgentProvider.ForExistingAgent(agentJar), false);\n299:     }\n300: \n301:     /**\n302:      * <p>\n303:      * Attaches the given agent Jar on the target process which must be a virtual machine process. The default attachment provider\n304:      * is used for applying the attachment. This operation blocks until the attachment is complete. If the current VM does not supply\n305:      * any known form of attachment to a remote VM, an {@link IllegalStateException} is thrown. The agent is not provided an argument.\n306:      * </p>\n307:      * <p>\n308:      * <b>Important</b>: It is only possible to attach to processes that are executed by the same operating system user.\n309:      * </p>\n310:      *\n311:      * @param agentJar        The agent jar file.\n312:      * @param processProvider A provider of the target process id.\n313:      */\n314:     public static void attach(File agentJar, ProcessProvider processProvider) {\n315:         attach(agentJar, processProvider, WITHOUT_ARGUMENT);\n316:     }\n317: \n318:     /**\n319:      * <p>\n--- 360\n360:      * </p>\n361:      *\n362:      * @param agentJar           The agent jar file.\n363:      * @param processProvider    A provider of the target process id.\n364:      * @param argument           The argument to provide to the agent.\n365:      * @param attachmentProvider The attachment provider to use.\n366:      */\n367:     public static void attach(File agentJar, ProcessProvider processProvider, @MaybeNull String argument, AttachmentProvider attachmentProvider) {\n368:         install(attachmentProvider, processProvider.resolve(), argument, new AgentProvider.ForExistingAgent(agentJar), false);\n369:     }\n370: \n371:     /**\n372:      * <p>\n373:      * Attaches the given agent library on the target process which must be a virtual machine process. The default attachment provider\n374:      * is used for applying the attachment. This operation blocks until the attachment is complete. If the current VM does not supply\n375:      * any known form of attachment to a remote VM, an {@link IllegalStateException} is thrown. The agent is not provided an argument.\n376:      * </p>\n377:      * <p>\n378:      * <b>Important</b>: It is only possible to attach to processes that are executed by the same operating system user.\n379:      * </p>\n380:      *\n381:      * @param agentLibrary The agent jar file.\n382:      * @param processId    The target process id.\n383:      */\n384:     public static void attachNative(File agentLibrary, String processId) {\n385:         attachNative(agentLibrary, processId, WITHOUT_ARGUMENT);\n386:     }\n387: \n388:     /**\n389:      * <p>\n390:      * Attaches the given agent library on the target process which must be a virtual machine process. The default attachment provider\n391:      * is used for applying the attachment. This operation blocks until the attachment is complete. If the current VM does not supply\n392:      * any known form of attachment to a remote VM, an {@link IllegalStateException} is thrown.\n393:      * </p>\n394:      * <p>\n395:      * <b>Important</b>: It is only possible to attach to processes that are executed by the same operating system user.\n396:      * </p>\n397:      *\n398:      * @param agentLibrary The agent library.\n399:      * @param processId    The target process id.\n400:      * @param argument     The argument to provide to the agent.\n401:      */\n402:     public static void attachNative(File agentLibrary, String processId, @MaybeNull String argument) {\n403:         attachNative(agentLibrary, processId, argument, AttachmentProvider.DEFAULT);\n404:     }\n405: \n406:     /**\n407:      * <p>\n408:      * Attaches the given agent library on the target process which must be a virtual machine process. This operation blocks until the\n409:      * attachment is complete. The agent is not provided an argument.\n--- 500\n500:      * </p>\n501:      *\n502:      * @param agentLibrary       The agent library.\n503:      * @param processProvider    A provider of the target process id.\n504:      * @param argument           The argument to provide to the agent.\n505:      * @param attachmentProvider The attachment provider to use.\n506:      */\n507:     public static void attachNative(File agentLibrary, ProcessProvider processProvider, @MaybeNull String argument, AttachmentProvider attachmentProvider) {\n508:         install(attachmentProvider, processProvider.resolve(), argument, new AgentProvider.ForExistingAgent(agentLibrary), true);\n509:     }\n510: \n511:     /**\n512:      * <p>\n513:      * Installs an agent on the currently running Java virtual machine. Unfortunately, this does\n514:      * not always work. The runtime installation of a Java agent is supp