atic void exerciseByteBuddyAgentInstallerPaths() throws Exception {\n        String originalAllowSelfAttach = System.getProperty(ALLOW_SELF_ATTACH_PROPERTY);\n        String originalLatentResolve = System.getProperty(ByteBuddyAgent.LATENT_RESOLVE);\n        Path marker = Files.createTempFile(\"blockhound-byte-buddy-agent\", \".marker\");\n        Files.deleteIfExists(marker);\n        Path virtualMachineJar = writeVirtualMachineJar();\n        Path agentJar = Files.createTempFile(\"blockhound-byte-buddy-agent\", \".jar\");\n        try {\n            System.setProperty(ALLOW_SELF_ATTACH_PROPERTY, Boolean.FALSE.toString());\n            System.setProperty(ByteBuddyAgent.LATENT_RESOLVE, Boolean.TRUE.toString());\n\n            assertThatThrownBy(ByteBuddyAgent::getInstrumentation)\n                    .isInstanceOf(IllegalStateException.class)\n                    .hasMessageContaining(\"Byte Buddy agent\");\n\n            ByteBuddyAgent.attach(agentJar.toFile(),\n                    () -> Long.toString(ProcessHandle.current().pid()),\n                    marker.toString(),\n                    new ExternalAttachmentProvider(virtualMachineJar.toFile()));\n\n            assertThat(marker).exists();\n            assertThat(Files.readString(marker)).contains(agentJar.toString());\n        } finally {\n            restoreProperty(ALLOW_SELF_ATTACH_PROPERTY, originalAllowSelfAttach);\n            restoreProperty(ByteBuddyAgent.LATENT_RESOLVE, originalLatentResolve);\n            Files.deleteIfExists(agentJar);\n            Files.deleteIfExists(marker);\n            Files.deleteIfExists(virtualMachineJar);\n        }\n    }\n\n    private static Path writeVirtualMachineJar() throws IOException {\n        Path jar = Files.createTempFile(\"blockhound-byte-buddy-virtual-machine\", \".jar\");\n        String resourceName = RecordingVirtualMachine.class.getName().replace('.', '/') + \".class\";\n        try (InputStream inputStream = ByteBuddyAgentTest.class.getClassLoader().get