[tool-call] delta {"path":"tests/src/org.apache.ant/ant-launcher/1.8.1/src/test/java/org_apache_ant/ant_launcher/LocatorTest.java","edits":[{"oldText":"import java.io.File;\nimport java.io.UnsupportedEncodingException;\nimport java.net.MalformedURLException;\nimport java.net.URL;\n","newText":"import java.io.File;\nimport java.io.IOException;\nimport java.io.UnsupportedEncodingException;\nimport java.net.MalformedURLException;\nimport java.net.URL;\nimport java.nio.file.Path;\n"},{"oldText":"import org.junit.jupiter.api.Test;\n","newText":"import org.junit.jupiter.api.Test;\nimport org.junit.jupiter.api.io.TempDir;\n"},{"oldText":"    void fileLocationUrlsUseJarFilterWhenDirectoryIsScanned() throws MalformedURLException {\n        File location = new File(\"build/locator-test-libs\");\n        assertThat(location.mkdirs() || location.isDirectory()).isTrue();\n        File jarFile = new File(location, \"ant-launcher-test.jar\");\n        File ignoredFile = new File(location, \"ant-launcher-test.txt\");\n\n        URL[] urls = Locator.getLocationURLs(location, new String[] {\".jar\"});\n\n        assertThat(jarFile).doesNotExist();\n        assertThat(ignoredFile).doesNotExist();\n        assertThat(urls).isEmpty();\n    }\n","newText":"    void fileLocationUrlsUseJarFilterWhenDirectoryIsScanned(@TempDir Path temporaryDirectory)\n            throws IOException {\n        File location = temporaryDirectory.toFile();\n        File jarFile = new File(location, \"ant-launcher-test.jar\");\n        File ignoredFile = new File(location, \"ant-launcher-test.txt\");\n        assertThat(jarFile.createNewFile()).isTrue();\n        assertThat(ignoredFile.createNewFile()).isTrue();\n\n        URL[] urls = Locator.getLocationURLs(location, new String[] {\".jar\"});\n\n        assertThat(urls).containsExactly(jarFile.toURI().toURL());\n    }\n"}]}
