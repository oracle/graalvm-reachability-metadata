e,\n                StandardCharsets.UTF_8));\n        StandardErrorListener listener = new StandardErrorListener();\n        listener.setLogger(logger);\n        listener.setMaximumNumberOfWarnings(1);\n        listener.setStackTraceDetail(0);\n        listener.setMaxOrdinaryCharacter(127);\n\n        StandardErrorListener copy = listener.makeAnother(HostLanguage.XSLT);\n\n        assertThat(copy).isNotSameAs(listener);\n        assertThat(copy).isInstanceOf(StandardErrorListener.class);\n        assertThat(copy.getLogger()).isSameAs(logger);\n        assertThat(copy.getMaximumNumberOfWarnings()).isEqualTo(25);\n        assertThat(copy.getStackTraceDetail()).isEqualTo(2);\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 515, "output": 925, "cacheRead": 17920, "cacheWrite": 0, "totalTokens": 19360, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1781109288950, "responseId": "resp_07a45dc3bc3f9b85016a299229483081908ddccada768ddecd"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_xrnKE1RdgBVdgKq93iE7alRI|fc_07a45dc3bc3f9b85016a299237caf4819084a3df2a6b371d22", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1488 bytes to tests/src/net.sf.saxon/Saxon-HE/10.0/src/test/java/net_sf_saxon/Saxon_HE/StandardErrorListenerTest.java"}], "isError": false, "timestamp": 1781109306168}]}
