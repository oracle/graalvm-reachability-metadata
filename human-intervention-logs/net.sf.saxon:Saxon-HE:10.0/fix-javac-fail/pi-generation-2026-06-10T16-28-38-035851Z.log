e(new StringReader(\"<child>fragment</child>\"));\n            }\n            return null;\n        });\n\n        reader.parse(new InputSource(new StringReader(\"\"\"\n                <!DOCTYPE root [<!ENTITY fragment SYSTEM \"urn:saxon-test-fragment\">]>\n                <root>&fragment;</root>\n                \"\"\")));\n\n        assertThat(elementNames).containsExactly(\"root\", \"child\");\n    }\n}\n", "newText": "public class JavaPlatformTest {\n    private static final String TRY_JDK9_FIELD = \"tryJdk9\";\n\n    @Test\n    void loadsParserForXmlFragmentsThatUsesSuppliedEntityResolver() throws Exception {\n        XMLReader reader = new JavaPlatform().loadParserForXmlFragments();\n\n        assertThat(parseWithExternalEntity(reader)).containsExactly(\"root\", \"child\");\n    }\n\n    @Test\n    void loadsParserForXmlFragmentsWhenJdk9DefaultParserLookupIsUnavailable() throws Exception {\n        boolean originalTryJdk9 = setTryJdk9(false);\n        try {\n            XMLReader reader = new JavaPlatform().loadParserForXmlFragments();\n\n            assertThat(parseWithExternalEntity(reader)).containsExactly(\"root\", \"child\");\n        } finally {\n            setTryJdk9(originalTryJdk9);\n        }\n    }\n\n    private static List<String> parseWithExternalEntity(XMLReader reader) throws Exception {\n        List<String> elementNames = new ArrayList<>();\n        reader.setContentHandler(new DefaultHandler() {\n            @Override\n            public void startElement(String uri, String localName, String qName, Attributes attributes) {\n                elementNames.add(qName);\n            }\n        });\n        reader.setEntityResolver((publicId, systemId) -> {\n            if (\"urn:saxon-test-fragment\".equals(systemId)) {\n                return new InputSource(new StringReader(\"<child>fragment</child>\"));\n            }\n            return null;\n        });\n\n        reader.parse(new InputSource(new StringReader(\"\"\"\n                <!DOCTYPE root [<!ENTITY fragment SYSTEM \"urn:saxon-test-fragment\">]>\n                <root>&fragment;</root>\n                \"\"\")));\n        return elementNames;\n    }\n\n    private static boolean setTryJdk9(boolean value) throws Exception {\n        Field tryJdk9 = JavaPlatform.class.getDeclaredField(TRY_JDK9_FIELD);\n        tryJdk9.setAccessible(true);\n        boolean previous = tryJdk9.getBoolean(null);\n        tryJdk9.setBoolean(null, value);\n        return previous;\n    }\n}\n"}]}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 21828, "output": 1441, "cacheRead": 0, "cacheWrite": 0, "totalTokens": 23269, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1781109063468, "responseId": "resp_0021ba2060b05e56016a2991480874819584d58d1ecc02d400"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_0nDw1YuIxN9iH20C6oyaU3hn|fc_0021ba2060b05e56016a29915d4e0c81958d4741ac83839139", "toolName": "edit", "content": [{"type": "text", "text": "Successfully replaced 2 block(s) in tests/src/net.sf.saxon/Saxon-HE/10.0/src/test/java/net_sf_saxon/Saxon_HE/JavaPlatformTest.java."}], "details": {"diff": "    ...\n 14 import org.xml.sax.XMLReader;\n 15 import org.xml.sax.helpers.DefaultHandler;\n 16 \n 17 import java.io.StringReader;\n+18 import java.lang.reflect.Field;\n 18 import java.util.ArrayList;\n 19 import java.util.List;\n 20 \n 21 import static org.assertj.core.api.Assertions.assertThat;\n 22 \n 23 public class JavaPlatformTest {\n+25     private static final String TRY_JDK9_FIELD = \"tryJdk9\";\n+26 \n 24     @Test\n 25     void loadsParserForXmlFragmentsThatUsesSuppliedEntityResolver() throws Exception {\n 26         XMLReader reader = new JavaPlatform().loadParserForXmlFragments();\n+30 \n+31         assertThat(parseWithExternalEntity(reader)).containsExactly(\"root\", \"child\");\n+32     }\n+33 \n+34     @Test\n+35     void loadsParserForXmlFr