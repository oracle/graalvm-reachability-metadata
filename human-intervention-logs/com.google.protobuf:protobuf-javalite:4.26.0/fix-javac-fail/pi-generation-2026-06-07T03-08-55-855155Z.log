          GeneratedLiteMapMessage message = GeneratedLiteMapMessage.newBuilder()
                  .putMetadata("library", "protobuf-javalite")
                  .build();
  
          GeneratedLiteMapMessage parsed = GeneratedLiteMapMessage.parseFrom(message.toByteArray());
  
          assertThat(parsed.getMetadataOrThrow("library"))
                  .isEqualTo("protobuf-javalite");
          assertThat(parsed.getDefaultInstanceForType())
                  .isSameAs(GeneratedLiteMapMessage.getDefaultInstance());
      }
  
