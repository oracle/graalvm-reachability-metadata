();\\n        channel.pipeline().addLast(publisher);\\n\\n        publisher.subscribe(first);\\n        publisher.subscribe(second);\\n        channel.runPendingTasks();\\n\\n        assertThat(first.subscription).isNotNull();\\n        assertThat(first.errors).isEmpty();\\n        assertThat(second.subscription).isNotNull();\\n        assertThat(second.errors).hasSize(1);\\n        assertThat(second.errors.get(0))\\n                .isInstanceOf(IllegalStateException.class)\\n                .hasMessage(\\\"This publisher only supports one subscriber\\\");\\n    }\\n\\n    @Test\\n    void handlerSubscriberRequestsInitialDemandAndWritesReceivedElements() {\", \"newText\": \"    @Test\\n    void handlerPublisherAllowsOnlyOneSubscriber() {\\n        EmbeddedChannel channel = new EmbeddedChannel();\\n        HandlerPublisher<String> publisher = new HandlerPublisher<>(channel.eventLoop(), String.class);\\n        TestSubscriber<String> first = new TestSubscriber<>();\\n        TestSubscriber<String> second = new TestSubscriber<>();\\n        channel.pipeline().addLast(publisher);\\n\\n        publisher.subscribe(first);\\n        publisher.subscribe(second);\\n        channel.runPendingTasks();\\n\\n        assertThat(first.subscription).isNotNull();\\n        assertThat(first.errors).isEmpty();\\n        assertThat(second.subscription).isNotNull();\\n        assertThat(second.errors).hasSize(1);\\n        assertThat(second.errors.get(0))\\n                .isInstanceOf(IllegalStateException.class)\\n                .hasMessage(\\\"This publisher only supports one subscriber\\\");\\n    }\\n\\n    @Test\\n    void handlerPublisherReleasesBufferedMessagesWhenSubscriptionIsCancelled() {\\n        EmbeddedChannel channel = new EmbeddedChannel();\\n        HandlerPublisher<ByteBuf> publisher = new HandlerPublisher<>(channel.eventLoop(), ByteBuf.class);\\n        TestSubscriber<ByteBuf> subscriber = new TestSubscriber<>();\\n        ByteBuf bufferedMessage = Unpooled.buffer().writeByte(1);\\n        channel.pipeline().addLast(publisher);\\n        publisher.subscribe(subscriber);\\n        channel.runPendingTasks();\\n\\n        channel.writeInbound(bufferedMessage);\\n        assertThat(bufferedMessage.refCnt()).isEqualTo(1);\\n        assertThat(subscriber.values).isEmpty();\\n\\n        subscriber.subscription.cancel();\\n        channel.runPendingTasks();\\n\\n        assertThat(bufferedMessage.refCnt()).isZero();\\n        assertThat(subscriber.values).isEmpty();\\n        assertThat(subscriber.errors).isEmpty();\\n        assertThat(subscriber.completed).isFalse();\\n    }\\n\\n    @Test\\n    void handlerSubscriberRequestsInitialDemandAndWritesReceivedElements() {\"}]}, \"partialJson\": \"{\\\"path\\\":\\\"tests/src/com.typesafe.netty/netty-reactive-streams/2.0.4/src/test/java/com_typesafe_netty/netty_reactive_streams/Netty_reactive_streamsTest.java\\\",\\\"edits\\\":[{\\\"oldText\\\":\\\"import com.typesafe.netty.HandlerPublisher;\\\\nimport com.typesafe.netty.HandlerSubscriber;\\\\nimport io.netty.channel.embedded.EmbeddedChannel;\\\",\\\"newText\\\":\\\"import com.typesafe.netty.HandlerPublisher;\\\\nimport com.typesafe.netty.HandlerSubscriber;\\\\nimport io.netty.buffer.ByteBuf;\\\\nimport io.netty.buffer.Unpooled;\\\\nimport io.netty.channel.embedded.EmbeddedChannel;\\\"},{\\\"oldText\\\":\\\"    @Test\\\\n    void handlerPublisherAllowsOnlyOneSubscriber() {\\\\n        EmbeddedChannel channel = new EmbeddedChannel();\\\\n        HandlerPublisher<String> publisher = new HandlerPublisher<>(channel.eventLoop(), String.class);\\\\n        TestSubscriber<String> first = new TestSubscriber<>();\\\\n        TestSubscriber<String> second = new TestSubscriber<>();\\\\n        channel.pipeline().addLast(publisher);\\\\n\\\\n        publisher.subscribe(first);\\\\n        publisher.subscribe(second);\\\\n        channel.runPendingTasks();\\\\n\\\\n        assertThat(first.subscription).isNotNull();\\\\n        assertThat(first.errors).isEmpty();\\\\n        assertThat(second.subscription).isNotNull();\\\\n        assertThat(second.errors).hasSize(1);\\\\n        assertThat(second.errors.get(0))\\\\n                .isInstanceOf(IllegalStateException.class)\\\\n                .hasMessage(\\\\\\\"This publisher only supports one subscriber\\\\\\\");\\\\n    }\\\\n\\\\n    @Test\\\\n    void handlerSubscriberRequestsInitialDemandAndWritesReceivedElements() {\\\",\\\"newText\\\":\\\"    @Test\\\\n    void handlerPublisherAllowsOnlyOneSubscriber() {\\\\n        EmbeddedChannel channel = new EmbeddedChannel();\\\\n        HandlerPublisher<String> publisher = new HandlerPublisher<>(channel.eventLoop(), String.class);\\\\n        TestSubscriber<String> first = new TestSubscriber<>();\\\\n        TestSubscriber<String> second = new TestSubscriber<>();\\\\n        channel.pipeline().addLast(publisher);\\\\n\\\\n        publisher.subscribe(first);\\\\n        publisher.subscribe(second);\\\\n        channel.runPendingTasks();\\\\n\\\\n        assertThat(first.subscription).isNotNull();\\\\n        assertThat(first.errors).isEmpty();\\\\n        assertThat(second.subscription).isNotNull();\\\\n        assertThat(second.errors).hasSize(1);\\\\n        assertThat(second.errors.get(0))\\\\n                .isInstanceOf(IllegalStateException.class)\\\\n                .hasMessage(\\\\\\\"This publisher only supports one subscriber\\\\\\\");\\\\n    }\\\\n\\\\n    @Test\\\\n    void handlerPublisherReleasesBufferedMessagesWhenSubscriptionIsCancelled() {\\\\n        EmbeddedChannel channel = new EmbeddedChannel();\\\\n        HandlerPublisher<ByteBuf> publisher = new HandlerPublisher<>(channel.eventLoop(), ByteBuf.class);\\\\n        TestSubscriber<ByteBuf> subscriber = new TestSubscriber<>();\\\\n        ByteBuf bufferedMessage = Unpooled.buffer().writeByte(1);\\\\n        channel.pipeline().addLast(publisher);\\\\n        publisher.subscribe(subscriber);\\\\n        channel.runPendingTasks();\\\\n\\\\n      