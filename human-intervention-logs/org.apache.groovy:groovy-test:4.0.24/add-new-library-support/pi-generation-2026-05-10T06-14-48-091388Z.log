  package org_apache_groovy.groovy_test
  
  import groovy.test.GroovyAssert
  import org.junit.jupiter.api.Test
  
  public class GroovyAssertTest {
      @Test
      public void testNotYetImplementedRerunsCurrentTestMethod() {
          if (GroovyAssert.notYetImplemented(this)) {
              return
          }
  
          throw new AssertionError('The rerun performed by notYetImplemented should still fail')
      }
  }
