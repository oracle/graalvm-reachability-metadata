  package org_apache_groovy.groovy_test
  
  import groovy.test.GroovyAssert
  import org.junit.jupiter.api.Test
  
  public class GroovyAssertTest {
      private boolean rerunShouldPass
  
      @Test
      public void testNotYetImplementedInvokesCurrentTestMethod() {
          if (rerunShouldPass) {
              return
          }
  
          rerunShouldPass = true
          Throwable thrown = GroovyAssert.shouldFail(AssertionError) {
              GroovyAssert.notYetImplemented(this)
          }
  
          assert thrown.message.contains('marked as not yet implemented but passes unexpectedly')
      }
  }
