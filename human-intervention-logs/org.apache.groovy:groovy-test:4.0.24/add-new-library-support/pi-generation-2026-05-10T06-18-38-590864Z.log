  package org_apache_groovy.groovy_test
  
  import groovy.test.AllTestSuite
  import junit.framework.TestSuite
  import junit.framework.Test as JUnitTest
  import org.junit.jupiter.api.Test
  
  import java.nio.file.Files
  import java.nio.file.Path
  
  public class AllTestSuiteTest {
      @Test
      public void suiteScansAnEmptyDirectory() {
          Path testDirectory = Files.createTempDirectory('all-test-suite-empty')
          try {
              JUnitTest suite = AllTestSuite.suite(testDirectory.toString(), '**/*Test.groovy')
  
              assert suite instanceof TestSuite
              assert ((TestSuite) suite).countTestCases() == 0
          } finally {
              Files.deleteIfExists(testDirectory)
          }
      }
  }
