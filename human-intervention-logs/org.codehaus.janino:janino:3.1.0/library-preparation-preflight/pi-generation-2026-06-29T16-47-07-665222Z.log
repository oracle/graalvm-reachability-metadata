s. It supplies interfaces and shared utilities used by Janino and alternate compiler implementations without bundling a full compiler implementation itself.\",\nmetadata/org.codehaus.janino/commons-compiler/index.json:19:      \"org.codehaus.janino\"\nmetadata/ch.qos.logback/logback-core/1.5.33/reachability-metadata.json:170:      \"type\" : \"org.codehaus.janino.ScriptEvaluator\"\nmetadata/ch.qos.logback/logback-core/1.5.32/reachability-metadata.json:170:      \"type\" : \"org.codehaus.janino.ScriptEvaluator\"\nmetadata/ch.qos.logback/logback-core/1.5.26/reachability-metadata.json:120:      \"type\" : \"org.codehaus.janino.ScriptEvaluator\"\n"}], "isError": false, "timestamp": 1782751592789}, {"role": "toolResult", "toolCallId": "call_morK9pLQ8IHPEXSRxaCSuSgx|fc_0dc59e3b6f8d5adb016a42a16873c481959d7e3fe8da60aa77", "toolName": "bash", "content": [{"type": "text", "text": "URL https://repo1.maven.org/maven2/org/codehaus/janino/janino/3.1.0/janino-3.1.0.pom\n<?xml version=\"1.0\"?>\n\n<project xmlns=\"http://maven.apache.org/POM/4.0.0\" xmlns:xsi=\"http://www.w3.org/2001/XMLSchema-instance\"\n         xsi:schemaLocation=\"http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd\">\n  <modelVersion>4.0.0</modelVersion>\n\n  <parent>\n    <groupId>org.codehaus.janino</groupId>\n    <artifactId>janino-parent</artifactId>\n    <version>3.1.0</version>\n    <relativePath>../janino-parent</relativePath>\n  </parent>\n\n  <artifactId>janino</artifactId>\n\n  <name>janino</name>\n\n  <dependencies>\n    <dependency>\n      <groupId>junit</groupId>\n      <artifactId>junit</artifactId>\n      <scope>test</scope>\n    </dependency>\n\n    <dependency>\n      <groupId>org.codehaus.janino</groupId>\n      <artifactId>commons-compiler</artifactId>\n      <version>${project.parent.version}</version>\n    </dependency>\n    <dependency>\n    \t<groupId>org.apache.ant</groupId>\n    \t<artifactId>ant</artifactId>\n    \t<version>1.7.1</version>\n    \t<scope>provided</scope>\n    \t<optional>true</optional>\n    </dependency>\n  </dependencies>\n\n  <build>\n    <plugins>\n      <plugin>\n        <groupId>org.apache.maven.plugins</groupId>\n        <artifactId>maven-surefire-plugin</artifactId>\n        <configuration>\n          <argLine>-Xss2m</argLine>\n        </configuration>\n      </plugin>\n\n      <plugin>\n        <groupId>org.apache.felix</groupId>\n        <artifactId>maven-bundle-plugin</artifactId>\n        <configuration>\n          <instructions>\n\t\t\t<Export-Package>org.codehaus.janino, org.codehaus.janino.samples, org.codehaus.janino.tools, org.codehaus.janino.util, org.codehaus.janino.util.resource</Export-Package>\n            <Require-Bundle>org.codehaus.janino.commons-compiler</Require-Bundle>\n          </instructions>\n        </configuration>\n      </plugin>\n    </plugins>\n  </build>\n  <description>The &quot;JANINO&quot; implementation of the &quot;commons-compiler&quot; API: Super-small, super-fast, independent from the JDK's &quot;tools.jar&quot;.</description>\n</project>\n\nURL https://janino-compiler.github.io/janino/\n<!doctype html>\n<html>\n  <head>\n    <meta charset=\"utf-8\">\n    <meta http-equiv=\"X-UA-Compatible\" content=\"chrome=1\">\n    <title>Janino by janino-compiler</title>\n\n    <link rel=\"stylesheet\" href=\"stylesheets/styles.css\">\n    <link rel=\"stylesheet\" href=\"stylesheets/github-dark.css\">\n    <script src=\"javascripts/scale.fix.js\"></script>\n\n    <script src=\"syntaxhighlighter_3.0.83/scripts/shCore.js\"></script>\n    <script src=\"syntaxhighlighter_3.0.83/scripts/shBrushBash.js\"></script>\n    <script src=\"syntaxhighlighter_3.0.83/scripts/shBrushJava.js\"></script>\n    <script src=\"syntaxhighlighter_3.0.83/scripts/shBrushXml.js\"></script>\n    <link href=\"syntaxhighlighter_3.0.83/styles/shCore.css\" rel=\"stylesheet\" type=\"text/css\">\n    <link href=\"syntaxhighlighter_3.0.83/styles/shThemeRDark.css\" rel=\"stylesheet\" type=\"text/css\">\n\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1, user-scalable=no\">\n\n    <!--[if lt IE 9]>\n    <script src=\"//html5shiv.googlecode.com/svn/trunk/html5.js\"></script>\n    <![endif]-->\n    \n    <style>\n.syntaxHighlighter.xml {\n  padding: 6px 12px 6px 12px;\n  line-height: 1em;\n}\n.syntaxHighlighter.xml .plain {\n  color: #b9bdb6;\n}\n.syntaxHighlighter.xml .spaces {\n}\n.syntaxHighlighter.xml .keyword {\n  color: #5ba1cf;\n}\n    </style>\n  </head>\n  <body>\n    <div class=\"wrapper\">\n      <header>\n        <h1>Janino</h1>\n        <p>A super-small, super-fast Java compiler</p>\n        <p class=\"view\"><a href=\"https://github.com/janino-compiler/janino\">\n          View the Project on GitHub <small>janino-compiler/janino</small></a>\n        </p>\n        <ul>\n          <li><a href=\"#download\">Download <strong>ZIP File</strong></a></li>\n          <li><a href=\"apidocs/\">Browse <strong>JAVADOC</strong></a></li>\n          <li><a href=\"https://github.com/janino-compiler/janino\">View On <strong>GitHub</strong></a></li>\n        </ul>\n      </header>\n      <section>\n        <div style=\"border:solid 1px; padding:12px;margin-bottom:12px;font-weight:bold\">\n          <div style=\"font-size:24px\">Breaking news!</div>\n          <div style=\"margin-bottom:8px\">\n            Janino is now \"Tee-ware\", which means that the applicable license is still BSD,\n            but you are free to\n            <a href=\"https://teespring.com/janino\" target=\"blank\">buy a fan t-shirt on Teespring</a>\n            (one per CPU, or as many as you want 😉).\n          </div>\n          <div>\n            Support the software development and show your appreciation by purchasing Janino merch!\n          </div>\n        </div>\n        <div style=\"float:right;clear:right;position:relative;margin:0.5em 0 0.8em 1.4em\">\n          <img src=\"logo/logo_167x134.gif\" alt=\"Janino Swoosh\" />\n        </div>\n        <p>\n          Janino is a super-small, super-fast Java compiler.\n        </p>\n        <p>\n          Janino can not only <a href=\"#janino-as-a-command-line-java-compiler\">compile a set of source files to a set\n          of class files</a> like JAVAC, but also compile\n          <a href=\"#janino-as-an-expression-evaluator\">a Java expression</a>,\n          <a href=\"#janino-as-a-script-evaluator\">a block</a>,\n          <a href=\"#janino-as-a-class-body-evaluator\">a class body</a>,\n          <a href=\"#janino-as-a-simple-compiler\">one .java file</a> or\n          <a href=\"#janino-as-a compiler\">a set of .java files</a>\n          in memory, load the bytecode and execute it directly in the running JVM.\n        </p>\n\n        <p>JANINO is integrated with Apache Commons JCI (\"Java Compiler Interface\") and JBoss Rules / Drools.</p>\n\n        <p>\n          JANINO can also be used for\n          <a href=\"#janino-as-a-code-analyser\">static code analysis</a>\n          or\n          <a href=\"#janino-as-a-code-manipulator\">code manipulation</a>.\n        </p>\n\n        <h2>Table of Contents</h2>\n        <ul>\n          <li><a href=\"#getting_started\">Getting Started</a></li>\n          <li><a href=\"#properties\">Properties</a></li>\n          <li><a href=\"#requirements\">Requirements<\n"}], "isError": false, "timestamp": 1782751593065}]}
