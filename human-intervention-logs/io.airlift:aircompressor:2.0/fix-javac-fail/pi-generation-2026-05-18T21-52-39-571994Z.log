[tool-call] delta {"path":"tests/src/io.airlift/aircompressor/2.0/build.gradle","edits":[{"oldText":"dependencies {\n    testImplementation \"io.airlift:aircompressor:$libraryVersion\"\n    testImplementation 'org.assertj:assertj-core:3.22.0'\n}\n\ngraalvmNative {","newText":"dependencies {\n    testImplementation \"io.airlift:aircompressor:$libraryVersion\"\n    testImplementation 'org.assertj:assertj-core:3.22.0'\n}\n\ntasks.named(\"processTestResources\") {\n    doLast {\n        String osName = System.getProperty(\"os.name\")\n        String platformName = switch (osName) {\n            case \"Linux\" -> \"linux\"\n            case \"Mac OS X\" -> \"macos\"\n            default -> throw new GradleException(\"Unsupported OS platform: $osName\")\n        }\n\n        String architecture = System.getProperty(\"os.arch\")\n        if (architecture == \"x86_64\") {\n            architecture = \"amd64\"\n        }\n\n        File jsigLibrary = file(\"${System.getProperty(\"java.home\")}/lib/${System.mapLibraryName(\"jsig\")}\")\n        if (!jsigLibrary.exists()) {\n            throw new GradleException(\"Unable to locate jsig library: $jsigLibrary\")\n        }\n\n        copy {\n            from jsigLibrary\n            into new File(destinationDirectory.get().asFile, \"aircompressor/${platformName}-${architecture}\")\n            rename { String ignored -> System.mapLibraryName(\"native_loader_test\") }\n        }\n    }\n}\n\ngraalvmNative {"}]}
