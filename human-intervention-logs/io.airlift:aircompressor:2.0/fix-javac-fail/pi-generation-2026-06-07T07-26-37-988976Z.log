actual = new byte[input.length];\n        int restoredSize = decompressor.decompress(compressed, 0, compressedSize, actual, 0, actual.length);\n\n        assertThat(restoredSize).isEqualTo(input.length);\n        assertThat(actual).isEqualTo(input);\n    }"}]}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 23650, "output": 1053, "cacheRead": 17408, "cacheWrite": 0, "totalTokens": 42111, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780817207688, "responseId": "resp_0325f33e9d973c06016a251d391528819596af4e2d6d520505"}}
