{"type":"item.completed","item":{"id":"item_126","type":"command_execution","command":"/usr/bin/bash -lc \"sed -n '1,260p' tests/src/org.scalatest/scalatest-core_2.13/3.2.19/src/test/scala/org_scalatest/scalatest_core_2_13/IconEmbellishedListCellRendererInnerIconsTest.scala\"","aggregated_output":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_scalatest.scalatest_core_2_13\n\nimport java.awt.Component\nimport java.lang.reflect.Constructor\n\nimport javax.swing.ImageIcon\nimport javax.swing.JLabel\nimport javax.swing.JList\nimport javax.swing.ListCellRenderer\n\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\nimport org.scalatest.ConfigMap\nimport org.scalatest.Suite\nimport org.scalatest.events.Event\nimport org.scalatest.events.IndentedText\nimport org.scalatest.events.Ordinal\nimport org.scalatest.events.RunStarting\n\nclass IconEmbellishedListCellRendererInnerIconsTest {\n  @Test\n  def renderingRunStartingEventLoadsAllRendererIcons(): Unit = {\n    val renderer: ListCellRenderer[AnyRef] = newRenderer()\n    val event: Event = RunStarting(\n      new Ordinal(1),\n      1,\n      ConfigMap.empty,\n      formatter = Some(IndentedText(\"run starting\", \"run starting\", 0))\n    )\n    val eventHolder: AnyRef = newEventHolder(event)\n    val list: JList[AnyRef] = new JList[AnyRef](Array(eventHolder))\n\n    val component: Component = renderer.getListCellRendererComponent(\n      list,\n      eventHolder,\n      0,\n      false,\n      false\n    )\n\n    assertThat(component).isInstanceOf(classOf[JLabel])\n    val label: JLabel = component.asInstanceOf[JLabel]\n    assertThat(label.getIcon).isInstanceOf(classOf[ImageIcon])\n    val icon: ImageIcon = label.getIcon.asInstanceOf[ImageIcon]\n    assertThat(icon.getIconWidth).isGreaterThan(0)\n    assertThat(icon.getIconHeight).isGreaterThan(0)\n  }\n\n  private def newRenderer(): ListCellRenderer[AnyRef] = {\n    val rendererClass: Class[_] = Class.forName(\n      \"org.scalatest.tools.IconEmbellishedListCellRenderer\",\n      true,\n      classOf[Suite].getClassLoader\n    )\n    val constructor: Constructor[_] = rendererClass.getDeclaredConstructor()\n    constructor.setAccessible(true)\n    constructor.newInstance().asInstanceOf[ListCellRenderer[AnyRef]]\n  }\n\n  private def newEventHolder(event: Event): AnyRef = {\n    val eventHolderClass: Class[_] = Class.forName(\n      \"org.scalatest.tools.EventHolder\",\n      true,\n      classOf[Suite].getClassLoader\n    )\n    val constructor: Constructor[_] = eventHolderClass.getDeclaredConstructor(\n      classOf[Event],\n      classOf[Option[_]],\n      classOf[Option[_]],\n      classOf[Option[_]]\n    )\n    constructor.setAccessible(true)\n    constructor.newInstance(event, None, None, None).asInstanceOf[AnyRef]\n  }\n}\n","exit_code":0,"status":"completed"}}
