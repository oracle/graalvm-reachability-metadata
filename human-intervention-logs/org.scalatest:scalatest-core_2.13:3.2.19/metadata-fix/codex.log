jectSuite[$configuredName]\"\n  }\n\n  override def run(testName: Option[String], args: Args): Status = {\n    assertThat(constructorConfig(\"answer\")).isEqualTo(42)\n    assertThat(args.configMap(\"answer\")).isEqualTo(42)\n    SucceededStatus\n  }\n}\n\nclass ReporterThatIgnoresEvents extends Reporter {\n  override def apply(event: Event): Unit = ()\n}\n","exit_code":0,"status":"completed"}}
