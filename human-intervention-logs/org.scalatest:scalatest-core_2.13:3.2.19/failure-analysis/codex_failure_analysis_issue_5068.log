JList\\nimport javax.swing.ListCellRenderer\\n\\nimport org.assertj.core.api.Assertions.assertThat\\nimport org.junit.jupiter.api.Test\\nimport org.scalatest.Suite\\nimport org.scalatest.tools.Runner\\n\\nclass IconEmbellishedListCellRendererInnerIconsTest {\\n  @Test\\n  def graphicalRunnerRendersEventListWithBundledIcons(): Unit = {\\n    val initialWindows: Set[Window] = Window.getWindows.toSet\\n    val runnerFailure: AtomicReference[Throwable] = new AtomicReference[Throwable]()\\n    val runnerThread: Thread = new Thread(\\n      new Runnable {\\n        override def run(): Unit = {\\n          try {\\n            val succeeded: Boolean = Runner.run(\\n              Array(\\n                \\\"-s\\\",\\n                \\\"org_scalatest.scalatest_core_2_13.IconEmbellishedListCellRendererInnerIconsSampleSuite\\\",\\n                \\\"-g\\\"\\n              )\\n            )\\n            if (!succeeded) {\\n              runnerFailure.compareAndSet(null, new AssertionError(\\\"ScalaTest graphical run did not succeed\\\"))\\n            }\\n          }\\n          catch {\\n            case throwable: Throwable => runnerFailure.compareAndSet(null, throwable)\\n          }\\n        }\\n      },\\n      \\\"scalatest-graphical-runner\\\"\\n    )\\n\\n    runnerThread.start()\\n\\n    try {\\n      val rendered: Boolean = waitForPopulatedEventList(initialWindows, runnerFailure)\\n      assertThat(rendered).isTrue()\\n    }\\n    finally {\\n      onEventDispatchThread(disposeNewWindows(initialWindows))\\n      runnerThread.join(10000L)\\n    }\\n\\n    assertThat(runnerThread.isAlive).isFalse()\\n    val failure: Throwable = runnerFailure.get()\\n    if (failure != null) {\\n      throw failure\\n    }\\n  }\\n\\n  private def waitForPopulatedEventList(\\n      initialWindows: Set[Window],\\n      runnerFailure: AtomicReference[Throwable]\\n  ): Boolean = {\\n    val deadlineNanos: Long = System.nanoTime() + 10000000000L\\n    var rendered: Boolean = false\\n    while (!rendered && runnerFailure.get() == null && System.nanoTime() < deadlineNanos) {\\n      rendered = onEventDispatchThread(renderFirstPopulatedList(initialWindows))\\n      if (!rendered) {\\n        Thread.sleep(50L)\\n      }\\n    }\\n    rendered\\n  }\\n\\n  private def renderFirstPopulatedList(initialWindows: Set[Window]): Boolean = {\\n    newWindows(initialWindows).exists { window =>\\n      findLists(window).exists { list =>\\n        val size: Int = list.getModel.getSize\\n        if (size > 0) {\\n          renderListCell(list)\\n          true\\n        }\\n        else {\\n          false\\n        }\\n      }\\n    }\\n  }\\n\\n  private def renderListCell(list: JList[_]): Unit = {\\n    val value: AnyRef = list.getModel.getElementAt(0).asInstanceOf[AnyRef]\\n    val renderer: ListCellRenderer[AnyRef] = list.getCellRenderer.asInstanceOf[ListCellRenderer[AnyRef]]\\n    renderer.getListCellRendererComponent(list.asInstanceOf[JList[AnyRef]], value, 0, false, false)\\n    renderer.getListCellRendererComponent(list.asInstanceOf[JList[AnyRef]], value, 0, true, false)\\n  }\\n\\n  private def findLists(component: Component): Seq[JList[_]] = {\\n    val current: Seq[JList[_]] = component match {\\n      case list: JList[_] => Seq(list)\\n      case _ => Seq.empty\\n    }\\n    val nested: Seq[JList[_]] = component match {\\n      case container: Container => container.getComponents.toSeq.flatMap(findLists)\\n      case _ => Seq.empty\\n    }\\n    current ++ nested\\n  }\\n\\n  private def disposeNewWindows(initialWindows: Set[Window]): Unit = {\\n    newWindows(initialWindows).foreach(_.dispose())\\n  }\\n\\n  private def newWindows(initialWindows: Set[Window]): Seq[Window] = {\\n    Window.getWindows.toSeq.filter(window => !initialWindows.contains(window) && window.isDisplayable)\\n  }\\n\\n  private def onEventDispatchThread[A](body: => A): A = {\\n    if (EventQueue.isDispatchThread) {\\n      body\\n    }\\n    else {\\n      val result: AtomicReference[Either[Throwable, A]] = new AtomicReference[Either[Throwable, A]]()\\n      EventQueue.invokeAndWait(\\n        new Runnable {\\n          override def run(): Unit = {\\n            try {\\n              result.set(Right(body))\\n            }\\n            catch {\\n              case throwable: Throwable => result.set(Left(throwable))\\n            }\\n          }\\n        }\\n      )\\n      result.get() match {\\n        case Right(value) => value\\n        case Left(throwable: InvocationTargetException) => throw throwable.getCause\\n        case Left(throwable) => throw throwable\\n      }\\n    }\\n  }\\n}\\n\\nclass IconEmbellishedListCellRendererInnerIconsSampleSuite extends Suite {\\n  def testPassingEvent(): Unit = {\\n    assert(1 + 1 == 2)\\n  }\\n}\\n\"}}], \"api\": \"openai-responses\", \"provider\": \"OCA\", \"model\": \"oca/gpt-5.5\", \"usage\": {\"input\": 286, \"output\": 3561, \"cacheRead\": 33280, \"cacheWrite\": 0, \"totalTokens\": 37127, \"cost\": {\"input\": 0, \"output\": 0, \"cacheRead\": 0, \"cacheWrite\": 0, \"total\": 0}}, \"stopReason\": \"toolUse\", \"timestamp\": 1781076423891, \"responseId\": \"resp_0b67f1c04402e2e7016a2911c8562081969d9b08baaa6bd4f5\"}}\nhuman-intervention-logs/org.scalatest:scalatest-core_2.13:3.2.19/add-new-library-support/pi-generation-2026-06-10T07-32-00-728601Z.log:2498:[tool-exec] start id=call_POZ3TNH33JUmURQwqZV94FED|fc_0b67f1c04402e2e7016a29120cb4188196a3c88c47b05756ff name=write args={\"path\": \"tests/src/org.scalatest/scalatest-core_2.13/3.2.19/src/test/scala/org_scalatest/scalatest_core_2_13/IconEmbellishedListCellRendererInnerIconsTest.scala\", \"content\": \"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage org_scalatest.scalatest_core_2_13\\n\\nimport java.awt.Component\\nimport java.awt.Container\\nimport java.awt.EventQueue