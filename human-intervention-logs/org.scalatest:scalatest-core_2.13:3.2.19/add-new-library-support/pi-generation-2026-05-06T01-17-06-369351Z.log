  package org_scalatest.scalatest_core_2_13
  
  import java.awt.Component
  import java.lang.reflect.Constructor
  
  import javax.swing.ImageIcon
  import javax.swing.JLabel
  import javax.swing.JList
  import javax.swing.ListCellRenderer
  
  import org.assertj.core.api.Assertions.assertThat
  import org.junit.jupiter.api.Test
  import org.scalatest.ConfigMap
  import org.scalatest.Suite
  import org.scalatest.events.Event
  import org.scalatest.events.IndentedText
  import org.scalatest.events.Ordinal
  import org.scalatest.events.RunStarting
  
  class IconEmbellishedListCellRendererInnerIconsTest {
    @Test
    def renderingRunStartingEventLoadsAllRendererIcons(): Unit = {
      val renderer: ListCellRenderer[AnyRef] = newRenderer()
      val event: Event = RunStarting(
        new Ordinal(1),
        1,
        ConfigMap.empty,
        formatter = Some(IndentedText("run starting", "run starting", 0))
      )
      val eventHolder: AnyRef = newEventHolder(event)
      val list: JList[AnyRef] = new JList[AnyRef](Array(eventHolder))
  
      val component: Component = renderer.getListCellRendererComponent(
        list,
        eventHolder,
        0,
        false,
        false
      )
  
      assertThat(component).isInstanceOf(classOf[JLabel])
      val label: JLabel = component.asInstanceOf[JLabel]
      assertThat(label.getIcon).isInstanceOf(classOf[ImageIcon])
      val icon: ImageIcon = label.getIcon.asInstanceOf[ImageIcon]
      assertThat(icon.getIconWidth).isGreaterThan(0)
      assertThat(icon.getIconHeight).isGreaterThan(0)
    }
  
    private def newRenderer(): ListCellRenderer[AnyRef] = {
      val rendererClass: Class[_] = Class.forName(
        "org.scalatest.tools.IconEmbellishedListCellRenderer",
        true,
        classOf[Suite].getClassLoader
      )
      val constructor: Constructor[_] = rendererClass.getDeclaredConstructor()
      constructor.setAccessible(true)
      constructor.newInstance().asInstanceOf[ListCellRenderer[AnyRef]]
    }
  
    private def newEventHolder(event: Event): AnyRef = {
      val eventHolderClass: Class[_] = Class.forName(
        "org.scalatest.tools.EventHolder",
        true,
        classOf[Suite].getClassLoader
      )
      val constructor: Constructor[_] = eventHolderClass.getDeclaredConstructor(
        classOf[Event],
        classOf[Option[_]],
        classOf[Option[_]],
        classOf[Option[_]]
      )
      constructor.setAccessible(true)
      constructor.newInstance(event, None, None, None).asInstanceOf[AnyRef]
    }
