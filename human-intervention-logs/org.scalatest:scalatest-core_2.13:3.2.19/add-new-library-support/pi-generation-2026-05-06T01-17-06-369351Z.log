  package org_scalatest.scalatest_core_2_13
  
  import org.assertj.core.api.Assertions.assertThat
  import org.junit.jupiter.api.Test
  import org.scalatest.Args
  import org.scalatest.ConfigMap
  import org.scalatest.ConfigMapWrapperSuite
  import org.scalatest.Reporter
  import org.scalatest.Status
  import org.scalatest.SucceededStatus
  import org.scalatest.Suite
  import org.scalatest.events.Event
  
  class ConfigMapWrapperSuiteTest {
    @Test
    def suiteNameInstantiatesWrappedSuiteWithEmptyConfigMap(): Unit = {
      val wrapper: ConfigMapWrapperSuite = new ConfigMapWrapperSuite(classOf[ConfigMapWrapperSubjectSuite])
  
      assertThat(wrapper.suiteName).isEqualTo("ConfigMapWrapperSubjectSuite[empty]")
    }
  
    @Test
    def runInstantiatesWrappedSuiteWithRunConfigMap(): Unit = {
      val wrapper: ConfigMapWrapperSuite = new ConfigMapWrapperSuite(classOf[ConfigMapWrapperSubjectSuite])
      val configMap: ConfigMap = ConfigMap("suite-name" -> "configured", "answer" -> 42)
      val args: Args = Args(ReporterThatIgnoresEvents, configMap = configMap)
  
      val status: Status = wrapper.run(None, args)
  
      assertThat(status.succeeds()).isTrue()
    }
  }
  
  class ConfigMapWrapperSubjectSuite(configMap: Map[_, _]) extends Suite {
    private val constructorConfig: Map[Any, Any] = configMap.asInstanceOf[Map[Any, Any]]
  
    override def suiteName: String = {
      val configuredName: String = constructorConfig.get("suite-name").map(_.toString).getOrElse("empty")
      s"ConfigMapWrapperSubjectSuite[$configuredName]"
    }
  
    override def run(testName: Option[String], args: Args): Status = {
      assert(constructorConfig("answer") == 42)
      assert(args.configMap("answer") == 42)
      SucceededStatus
    }
  }
  
  object ReporterThatIgnoresEvents extends Reporter {
    override def apply(event: Event): Unit = ()
  }
