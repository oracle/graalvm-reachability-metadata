  package org_scalatest.scalatest_core_2_13
  
  import java.nio.file.Files
  import java.nio.file.Path
  import java.nio.file.Paths
  
  import org.assertj.core.api.Assertions.assertThat
  import org.junit.jupiter.api.Test
  import org.scalatest.Suite
  import org.scalatest.WrapWith
  import org.scalatest.tools.Runner
  
  class DiscoverySuiteTest {
    @Test
    def runnerDiscoveryInstantiatesPlainAndWrapWithSuites(): Unit = {
      System.clearProperty(DiscoverySuiteTest.PlainSuiteProperty)
      System.clearProperty(DiscoverySuiteTest.WrappedSuiteProperty)
  
      try {
        val succeeded: Boolean = Runner.run(
          Array(
            "-R",
            discoveryRunpath,
            "-w",
            "org_scalatest.scalatest_core_2_13.discovery",
            "-o"
          )
        )
  
        assertThat(succeeded).isTrue()
        assertThat(System.getProperty(DiscoverySuiteTest.PlainSuiteProperty))
          .isEqualTo(classOf[discovery.DiscoveryRunnerPlainSuite].getName)
        assertThat(System.getProperty(DiscoverySuiteTest.WrappedSuiteProperty))
          .isEqualTo(classOf[discovery.DiscoveryRunnerWrappedClass].getName)
      }
      finally {
        System.clearProperty(DiscoverySuiteTest.PlainSuiteProperty)
        System.clearProperty(DiscoverySuiteTest.WrappedSuiteProperty)
      }
    }
  
    private def discoveryRunpath: String = {
      val candidates: Seq[Path] =
        classLocation.toSeq ++ Seq(
          Paths.get("build/classes/scala/test"),
          Paths.get("build/classes/java/test")
        ) ++ buildLibraryJars
  
      candidates
        .map(_.toAbsolutePath.normalize())
        .find(isScannableRunpath)
        .map(_.toString)
        .getOrElse(throw new IllegalStateException("Could not find compiled test classes for ScalaTest discovery"))
    }
  
    private def classLocation: Option[Path] = {
      try {
        Option(classOf[discovery.DiscoveryRunnerPlainSuite].getProtectionDomain)
          .flatMap(domain => Option(domain.getCodeSource))
          .flatMap(source => Option(source.getLocation))
          .map(location => Paths.get(location.toURI))
      }
      catch {
        case _: IllegalArgumentException => None
      }
    }
  
    private def buildLibraryJars: Seq[Path] = {
      val libraryDirectory: Path = Paths.get("build/libs")
      if (!Files.isDirectory(libraryDirectory)) {
        Seq.empty
      }
      else {
        val stream = Files.list(libraryDirectory)
        try {
          val iterator = stream.iterator()
          val paths = Vector.newBuilder[Path]
          while (iterator.hasNext) {
            val path: Path = iterator.next()
            if (path.getFileName.toString.endsWith(".jar")) {
              paths += path
            }
          }
          paths.result()
        }
        finally {
          stream.close()
        }
      }
    }
  
    private def isScannableRunpath(path: Path): Boolean =
      Files.isDirectory(path) || (Files.isRegularFile(path) && path.getFileName.toString.endsWith(".jar"))
  }
  
  object DiscoverySuiteTest {
    val PlainSuiteProperty: String = "org_scalatest.scalatest_core_2_13.discovery.plainSuite"
    val WrappedSuiteProperty: String = "org_scalatest.scalatest_core_2_13.discovery.wrappedSuite"
  }
  
  package discovery {
    class DiscoveryRunnerPlainSuite extends Suite {
      System.setProperty(
        DiscoverySuiteTest.PlainSuiteProperty,
        classOf[DiscoveryRunnerPlainSuite].getName
      )
    }
  
    @WrapWith(classOf[DiscoveryRunnerWrappedClassSuite])
    class DiscoveryRunnerWrappedClass
  
    class DiscoveryRunnerWrappedClassSuite(wrappedClass: Class[_]) extends Suite {
      System.setProperty(DiscoverySuiteTest.WrappedSuiteProperty, wrappedClass.getName)
    }
  }
