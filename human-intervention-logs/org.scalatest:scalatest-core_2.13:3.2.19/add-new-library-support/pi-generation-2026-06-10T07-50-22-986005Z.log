nd compiled test classes for ScalaTest discovery\"))\n  }\n\n  private def classLocation: Option[Path] = {\n    try {\n      Option(classOf[discovery.DiscoveryRunnerPlainSuite].getProtectionDomain)\n        .flatMap(domain => Option(domain.getCodeSource))\n        .flatMap(source => Option(source.getLocation))\n        .map(location => Paths.get(location.toURI))\n    }\n    catch {\n      case _: IllegalArgumentException => None\n    }\n  }\n\n  private def buildLibraryJars: Seq[Path] = {\n    val libraryDirectory: Path = Paths.get(\"build/libs\")\n    if (!Files.isDirectory(libraryDirectory)) {\n      Seq.empty\n    }\n    else {\n      val stream = Files.list(libraryDirectory)\n      try {\n        val iterator = stream.iterator()\n        val paths = Vector.newBuilder[Path]\n        while (iterator.hasNext) {\n          val path: Path = iterator.next()\n          if (path.getFileName.toString.endsWith(\".jar\")) {\n            paths += path\n          }\n        }\n        paths.result()\n      }\n      finally {\n        stream.close()\n      }\n    }\n  }\n\n  private def isScannableRunpath(path: Path): Boolean =\n    Files.isDirectory(path) || (Files.isRegularFile(path) && path.getFileName.toString.endsWith(\".jar\"))\n}\n\nobject DiscoverySuiteTest {\n  val PlainSuiteProperty: String = \"org_scalatest.scalatest_core_2_13.discovery.plainSuite\"\n  val WrappedSuiteProperty: String = \"org_scalatest.scalatest_core_2_13.discovery.wrappedSuite\"\n}\n\npackage discovery {\n  class DiscoveryRunnerPlainSuite extends Suite {\n    System.setProperty(\n      DiscoverySuiteTest.PlainSuiteProperty,\n      classOf[DiscoveryRunnerPlainSuite].getName\n    )\n  }\n\n  @WrapWith(classOf[DiscoveryRunnerWrappedClassSuite])\n  class DiscoveryRunnerWrappedClass\n\n  class DiscoveryRunnerWrappedClassSuite(wrappedClass: Class[_]) extends Suite {\n    System.setProperty(DiscoverySuiteTest.WrappedSuiteProperty, wrappedClass.getName)\n  }\n}\n"}
