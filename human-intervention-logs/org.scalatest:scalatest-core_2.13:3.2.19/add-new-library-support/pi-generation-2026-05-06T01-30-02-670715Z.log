  package org_scalatest.scalatest_core_2_13 {
  
    import org.assertj.core.api.Assertions.assertThat
    import org.junit.jupiter.api.Test
    import org.scalatest.Suite
    import org.scalatest.WrapWith
    import org.scalatest.tools.Runner
  
    class RunnerTest {
      @Test
      def namedSuiteRunInstantiatesNoArgSuite(): Unit = {
        assertRunSucceeds("-o", "-s", classOf[RunnerNoArgSuite].getName)
      }
  
      @Test
      def namedSuiteRunInstantiatesWrapWithSuite(): Unit = {
        assertRunSucceeds("-o", "-s", classOf[RunnerAnnotatedSubject].getName)
      }
  
      @Test
      def junitRunInstantiatesJUnitWrapperSuite(): Unit = {
        assertRunSucceeds("-o", "-j", "org_scalatest.scalatest_core_2_13.RunnerSyntheticJUnitTest")
      }
  
      @Test
      def testNGRunInstantiatesTestNGWrapperSuite(): Unit = {
        assertRunSucceeds("-o", "-b", "runner-synthetic-testng-suite.xml")
      }
  
      private def assertRunSucceeds(args: String*): Unit = {
        assertThat(Runner.run(args.toArray)).isTrue()
      }
    }
  
    class RunnerNoArgSuite extends Suite {
      def testRunnerCanInstantiateThisSuite(): Unit = {
        assert(true)
      }
    }
  
    @WrapWith(classOf[RunnerWrappedSuite])
    class RunnerAnnotatedSubject
  
    class RunnerWrappedSuite(wrappedClass: Class[_]) extends Suite {
      def testRunnerCanInstantiateWrapWithSuite(): Unit = {
        assert(wrappedClass == classOf[RunnerAnnotatedSubject])
      }
    }
  }
  
  package org.scalatestplus.junit {
  
    import org.scalatest.Suite
  
    class JUnitWrapperSuite(className: String, loader: ClassLoader) extends Suite {
      def testRunnerPassesJUnitWrapperArguments(): Unit = {
        assert(className == "org_scalatest.scalatest_core_2_13.RunnerSyntheticJUnitTest")
        assert(loader != null)
      }
    }
  }
  
  package org.scalatestplus.testng {
  
    import org.scalatest.Suite
  
    class TestNGWrapperSuite(suiteFiles: List[String]) extends Suite {
      def testRunnerPassesTestNGWrapperArguments(): Unit = {
        assert(suiteFiles == List("runner-synthetic-testng-suite.xml"))
      }
    }
  }
