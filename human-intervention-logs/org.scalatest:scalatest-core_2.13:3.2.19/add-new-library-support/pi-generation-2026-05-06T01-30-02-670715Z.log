  package org_scalatest.scalatest_core_2_13
  
  import java.lang.reflect.Method
  
  import scala.jdk.CollectionConverters._
  
  import org.assertj.core.api.Assertions.assertThat
  import org.junit.jupiter.api.Test
  import org.scalatest.Informer
  import org.scalatest.Suite
  
  class SuiteTest {
    @Test
    def checkForPublicNoArgConstructorRecognizesAccessibleSuites(): Unit = {
      assertThat(Suite.checkForPublicNoArgConstructor(classOf[SuitePublicNoArgSubject])).isTrue()
      assertThat(Suite.checkForPublicNoArgConstructor(classOf[SuiteConstructorArgSubject])).isFalse()
    }
  
    @Test
    def getMethodForTestNameFindsLegacyStyleTestMethods(): Unit = {
      val suite: SuiteMethodLookupSubject = new SuiteMethodLookupSubject
  
      val noArgMethod: Method = Suite.getMethodForTestName(suite, "legacyNoArgTest")
      val informerMethod: Method = Suite.getMethodForTestName(suite, "legacyInformerTest(Informer)")
  
      assertThat(noArgMethod.getName).isEqualTo("legacyNoArgTest")
      assertThat(noArgMethod.getParameterTypes).isEmpty()
      assertThat(informerMethod.getName).isEqualTo("legacyInformerTest")
      assertThat(informerMethod.getParameterTypes).containsExactly(classOf[Informer])
