[tool-call] delta {"path":"tests/src/org.scalatest/scalatest-core_2.13/3.2.19/src/test/scala/org_scalatest/scalatest_core_2_13/SuiteTest.scala","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_scalatest.scalatest_core_2_13\n\nimport java.lang.reflect.Method\n\nimport scala.jdk.CollectionConverters._\n\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\nimport org.scalatest.Informer\nimport org.scalatest.Suite\n\nclass SuiteTest {\n  @Test\n  def checkForPublicNoArgConstructorRecognizesAccessibleSuites(): Unit = {\n    assertThat(suiteModule.checkForPublicNoArgConstructor(classOf[SuitePublicNoArgSubject])).isTrue()\n    assertThat(suiteModule.checkForPublicNoArgConstructor(classOf[SuiteConstructorArgSubject])).isFalse()\n  }\n\n  @Test\n  def getMethodForTestNameFindsLegacyStyleTestMethods(): Unit = {\n    val suite: SuiteMethodLookupSubject = new SuiteMethodLookupSubject\n\n    val noArgMethod: Method = suiteModule.getMethodForTestName(suite, \"legacyNoArgTest\")\n    val informerMethod: Method = suiteModule.getMethodForTestName(suite, \"legacyInformerTest(Informer)\")\n\n    assertThat(noArgMethod.getName).isEqualTo(\"legacyNoArgTest\")\n    assertThat(noArgMethod.getParameterTypes).isEmpty()\n    assertThat(informerMethod.getName).isEqualTo(\"legacyInformerTest\")\n    assertThat(informerMethod.getParameterTypes).containsExactly(classOf[Informer])\n  }\n\n  @Test\n  def yeOldeTestNamesDiscoversLegacyTestMethods(): Unit = {\n    val names: Set[String] = suiteModule.yeOldeTestNames(new SuiteYeOldeNamesSubject)\n\n    assertThat(names.asJava).containsExactly(\"testAlpha\", \"testBeta(Informer)\")\n  }\n\n  private def suiteModule: _root_.org.scalatest.`Suite$` = _root_.org.scalatest.`Suite$`.`MODULE$`\n}\n\nclass SuitePublicNoArgSubject extends Suite\n\nclass SuiteConstructorArgSubject(name: String) extends Suite {\n  override def suiteName: String = name\n}\n\nclass SuiteMethodLookupSubject extends Suite {\n  def legacyNoArgTest(): Unit = ()\n\n  def legacyInformerTest(informer: Informer): Unit = {\n    informer(\"covered\")\n  }\n}\n\nclass SuiteYeOldeNamesSubject extends Suite {\n  def testAlpha(): Unit = ()\n\n  def testBeta(informer: Informer): Unit = {\n    informer(\"covered\")\n  }\n\n  def helperMethod(): Unit = ()\n}\n"}
