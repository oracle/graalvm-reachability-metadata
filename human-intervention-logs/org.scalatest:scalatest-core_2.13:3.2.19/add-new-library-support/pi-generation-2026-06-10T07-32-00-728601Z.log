              runpathList,
              loader,
              RunnerJFrame.this,
              nextRunStamp,
              concurrentConfig,
              suffixes,
              chosenStyleSet,
              testSortingReporterTimeout
            )
          }
          finally {
            stopper.reset()
            nextRunStamp += 1
          }
        }
      }
    }
  
