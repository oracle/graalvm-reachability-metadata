    // tests so they can be run again later.
    //
    private[tools] def readMemoryFiles(fileNames: List[String],
                                       reporter: Reporter,
                                       tracker: Tracker):
    List[SuiteParam] =
    {
      val mementos =
        for {
          fileName <- fileNames
          memento <- Memento.readFromFile(fileName)
