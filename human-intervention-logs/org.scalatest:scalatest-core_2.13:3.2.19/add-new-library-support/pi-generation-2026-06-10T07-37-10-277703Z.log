  package org_scalatest.scalatest_core_2_13
  
  import java.nio.charset.StandardCharsets
  import java.nio.file.Files
  import java.nio.file.Path
  import java.util.concurrent.atomic.AtomicReference
  
  import org.assertj.core.api.Assertions.assertThat
  import org.junit.{Test => JUnitFourTest}
  import org.junit.jupiter.api.Test
  import org.scalatest.Suite
  import org.scalatest.WrapWith
  import org.scalatest.tools.Runner
  import org.testng.annotations.{Test => TestNgTest}
  
  class RunnerTest {
    @Test
    def commandLineRunnerInstantiatesNamedSuitesAndWrapWithSuites(): Unit = {
      RunnerWrappedClassSuite.constructedWith.set(null)
  
      val succeeded: Boolean = Runner.run(
        Array(
          "-s",
          classOf[RunnerPlainSuite].getName,
          "-s",
          classOf[RunnerWrappedClass].getName,
          "-o"
        )
      )
  
      assertThat(succeeded).isTrue()
      assertThat(RunnerWrappedClassSuite.constructedWith.get()).isEqualTo(classOf[RunnerWrappedClass])
    }
  
    @Test
    def commandLineRunnerInstantiatesJUnitWrapperSuite(): Unit = {
      val succeeded: Boolean = Runner.run(
        Array(
          "-j",
          classOf[RunnerJUnitFourTestCase].getName,
          "-o"
        )
      )
  
      assertThat(succeeded).isTrue()
    }
  
    @Test
    def commandLineRunnerInstantiatesTestNgWrapperSuite(): Unit = {
      val suiteFile: Path = Files.createTempFile("scalatest-runner-testng", ".xml")
      try {
        val suiteXml: String =
          s"""<suite name="runner-suite">
             |  <test name="runner-test">
             |    <classes>
             |      <class name="${classOf[RunnerTestNgTestCase].getName}"/>
             |    </classes>
             |  </test>
             |</suite>
             |""".stripMargin
        Files.write(suiteFile, suiteXml.getBytes(StandardCharsets.UTF_8))
  
        val succeeded: Boolean = Runner.run(
          Array(
            "-b",
            suiteFile.toString,
            "-o"
          )
        )
  
        assertThat(succeeded).isTrue()
      }
      finally {
        Files.deleteIfExists(suiteFile)
      }
    }
  }
  
  class RunnerPlainSuite extends Suite
  
  @WrapWith(classOf[RunnerWrappedClassSuite])
  class RunnerWrappedClass
  
  class RunnerWrappedClassSuite(wrappedClass: Class[_]) extends Suite {
    RunnerWrappedClassSuite.constructedWith.set(wrappedClass)
  }
  
  object RunnerWrappedClassSuite {
