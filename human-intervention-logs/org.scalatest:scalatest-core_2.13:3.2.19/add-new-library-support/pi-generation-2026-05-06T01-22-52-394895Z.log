  package org_scalatest.scalatest_core_2_13 {
  
    import java.nio.file.Files
    import java.nio.file.Path
    import java.nio.file.Paths
  
    import org.assertj.core.api.Assertions.assertThat
    import org.junit.jupiter.api.Test
    import org.scalatest.tools.Runner
    import org_scalatest.scalatest_core_2_13.discovery.DiscoveryNoArgSuite
  
    class DiscoverySuiteTest {
      @Test
      def membersOnlyDiscoveryInstantiatesNoArgAndWrappedSuites(): Unit = {
        val discoveryPackage: String = "org_scalatest.scalatest_core_2_13.discovery"
        val args: Array[String] = Array("-o", "-R", testClassesRunpath, "-m", discoveryPackage)
  
        assertThat(Runner.run(args)).isTrue()
      }
  
      private def testClassesRunpath: String = {
        val fallbackPath: Path = Paths.get("build", "classes", "scala", "test").toAbsolutePath
        val codeSource = classOf[DiscoveryNoArgSuite].getProtectionDomain.getCodeSource
        if (codeSource == null)
          fallbackPath.toString
        else {
          val codeSourcePath: Path = Paths.get(codeSource.getLocation.toURI)
          if (Files.isDirectory(codeSourcePath)) codeSourcePath.toString else fallbackPath.toString
        }
      }
    }
  }
  
  package org_scalatest.scalatest_core_2_13.discovery {
  
    import org.scalatest.Suite
    import org.scalatest.WrapWith
  
    class DiscoveryNoArgSuite extends Suite {
      def testDiscoveryCanInstantiatePublicNoArgSuites(): Unit = {
        assert(true)
      }
    }
  
    @WrapWith(classOf[DiscoveryWrappedSuite])
    class DiscoveryWrappedSubject
  
    class DiscoveryWrappedSuite(wrappedClass: Class[_]) extends Suite {
      def testDiscoveryCanInstantiateWrapWithSuites(): Unit = {
        assert(wrappedClass == classOf[DiscoveryWrappedSubject])
      }
    }
  }
