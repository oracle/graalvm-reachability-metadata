 Wrapper Target Suite\")\n\n    val constructorConfigMap: Map[_, _] = ConfigMapWrapperTargetSuite.constructorConfigMaps.poll()\n    assertThat(constructorConfigMap).isEmpty()\n    assertThat(ConfigMapWrapperTargetSuite.constructorConfigMaps).isEmpty()\n  }\n\n  @Test\n  def runConstructsWrappedSuiteWithProvidedConfigMapAndDelegatesRun(): Unit = {\n    ConfigMapWrapperTargetSuite.reset()\n\n    val wrapperSuite: ConfigMapWrapperSuite =\n      new ConfigMapWrapperSuite(classOf[ConfigMapWrapperTargetSuite])\n    val configMap: Map[String, Any] = Map(\"answer\" -> 42)\n    val args: Args = Args(ConfigMapWrapperSuiteTest.noopReporter, configMap = configMap)\n\n    val status: Status = wrapperSuite.run(None, args)\n\n    assertThat(status).isSameAs(SucceededStatus)\n    assertThat(ConfigMapWrapperTargetSuite.constructorConfigMaps.poll()).isEqualTo(configMap)\n    assertThat(ConfigMapWrapperTargetSuite.runConfigMaps.poll()).isEqualTo(configMap)\n    assertThat(ConfigMapWrapperTargetSuite.constructorConfigMaps).isEmpty()\n    assertThat(ConfigMapWrapperTargetSuite.runConfigMaps).isEmpty()\n  }\n}\n\nobject ConfigMapWrapperSuiteTest {\n  val noopReporter: Reporter = new Reporter {\n    override def apply(event: Event): Unit = ()\n  }\n}\n\nclass ConfigMapWrapperTargetSuite(configMap: Map[_, _]) extends Suite {\n  ConfigMapWrapperTargetSuite.constructorConfigMaps.add(configMap)\n\n  override def run(testName: Option[String], args: Args): Status = {\n    ConfigMapWrapperTargetSuite.runConfigMaps.add(args.configMap)\n    SucceededStatus\n  }\n}\n\nobject ConfigMapWrapperTargetSuite {\n  val constructorConfigMaps: ConcurrentLinkedQueue[Map[_, _]] =\n    new ConcurrentLinkedQueue[Map[_, _]]()\n  val runConfigMaps: ConcurrentLinkedQueue[Map[_, _]] =\n    new ConcurrentLinkedQueue[Map[_, _]]()\n\n  def reset(): Unit = {\n    constructorConfigMaps.clear()\n    runConfigMaps.clear()\n  }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 1642, "output": 1366, "cacheRead": 25600, "cacheWrite": 0, "totalTokens": 28608, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1781077500694, "responseId": "resp_06c18b28fb9a8f48016a2915fd20d481969eb68bb2ad8bfefd"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_fzeHq4FmjYtCuIgteEFlL2SE|fc_06c18b28fb9a8f48016a29161113ec8196a78967e7d3a97cf3", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2798 bytes to tests/src/org.scalatest/scalatest-core_2.13/3.2.19/src/test/scala/org_scalatest/scalatest_core_2_13/ConfigMapWrapperSuiteTest.scala"}], "isError": false, "timestamp": 1781077529569}]}
