ssertRunSucceeds(\"-o\", \"-s\", classOf[RunnerNoArgSuite].getName)\n  }\n\n  @Test\n  def namedSuiteRunInstantiatesWrapWithSuite(): Unit = {\n    assertRunSucceeds(\"-o\", \"-s\", classOf[RunnerAnnotatedSubject].getName)\n  }\n\n  @Test\n  def junitRunInstantiatesJUnitWrapperSuite(): Unit = {\n    assertRunSucceeds(\"-o\", \"-j\", \"org_scalatest.scalatest_core_2_13.RunnerSyntheticJUnitTest\")\n  }\n\n  @Test\n  def testNGRunInstantiatesTestNGWrapperSuite(): Unit = {\n    assertRunSucceeds(\"-o\", \"-b\", \"runner-synthetic-testng-suite.xml\")\n  }\n\n  private def assertRunSucceeds(args: String*): Unit = {\n    assertThat(Runner.run(args.toArray)).isTrue()\n  }\n}\n\nclass RunnerNoArgSuite extends Suite {\n  def testRunnerCanInstantiateThisSuite(): Unit = {\n    assert(true)\n  }\n}\n\n@WrapWith(classOf[RunnerWrappedSuite])\nclass RunnerAnnotatedSubject\n\nclass RunnerWrappedSuite(wrappedClass: Class[_]) extends Suite {\n  def testRunnerCanInstantiateWrapWithSuite(): Unit = {\n    assert(wrappedClass == classOf[RunnerAnnotatedSubject])\n  }\n}\n}\n\npackage org.scalatestplus.junit {\n\nimport org.scalatest.Suite\n\nclass JUnitWrapperSuite(className: String, loader: ClassLoader) extends Suite {\n  def testRunnerPassesJUnitWrapperArguments(): Unit = {\n    assert(className == \"org_scalatest.scalatest_core_2_13.RunnerSyntheticJUnitTest\")\n    assert(loader != null)\n  }\n}\n}\n\npackage org.scalatestplus.testng {\n\nimport org.scalatest.Suite\n\nclass TestNGWrapperSuite(suiteFiles: List[String]) extends Suite {\n  def testRunnerPassesTestNGWrapperArguments(): Unit = {\n    assert(suiteFiles == List(\"runner-synthetic-testng-suite.xml\"))\n  }\n}\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 718, "output": 957, "cacheRead": 51200, "cacheWrite": 0, "totalTokens": 52875, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778029804121, "responseId": "re