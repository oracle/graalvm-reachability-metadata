istCoordinates\", DefaultTask) { task ->\n    task.setDescription(\"Lists all matching GAV coordinates (one per line) honoring -Pcoordinates filter; use -PstrictCoordinates=true for strict matching\")\n    task.setGroup(METADATA_GROUP)\n    task.doFirst {\n        boolean strictCoordinates = project.hasProperty(\"strictCoordinates\") &&\n                Objects.toString(project.findProperty(\"strictCoordinates\"), \"false\").toBoolean()\n        List<String> coords\n        if (strictCoordinates) {\n            if (CoordinateUtils.isFractionalBatch(coordinateFilter)) {\n                def frac = CoordinateUtils.parseFraction(coordinateFilter)\n                List<String> allStrict = tck.getMatchingCoordinatesStrict(\"all\")\n                coords = CoordinateUtils.computeBatchedCoordinates(allStrict, frac[0], frac[1])\n            } else {\n                coords = tck.getMatchingCoordinatesStrict(coordinateFilter)\n            }\n            coords = coords.findAll { !it.startsWith(\"samples:\") }\n        } else {\n            coords = new ArrayList<>(matchingCoordinates)\n        }\n        coords.sort()\n        if (coords.isEmpty()) {\n            println \"No matching coordinates found!\"\n        } else {\n            coords.each { println it }\n        }\n        writeGithubOutput(\"coordinates\", coords.join(' '))\n    }\n}\n\ntasks.register(\"populateArtifactURLs\", PopulateArtifactURLs.class) { task ->\n    task.setDescription(\"Uses a coding agent command to fill source-code-url, repository-url, test-code-url, documentation-url, description, and language in matching metadata index entries.\")\n    task.setGroup(METADATA_GROUP)\n}\n\ntasks.register(\"discoverArtifactMetadata\", DiscoverArtifactMetadata.class) { task ->\n    task.setDescription(\"Uses a coding agent command to discover artifact metadata for a single coordinate and stores it under build/.\")\n    task.setGroup(METADATA_GROUP)\n}\n\ntasks.register(\"listLibraryJars\", ListLibraryJarsInvocationTask.class) { task ->\n    task.setDescription(\"Lists resolved tested-library JARs for matching coordinates (one per line)\")\n    task.setGroup(METADATA_GROUP)\n}\n\ntasks.register(\"generateDynamicAccessReport\", GenerateDynamicAccessReportInvocationTask.class) { task ->\n    task.setDescription(\"Builds native tests and prints generated dynamic-access JSON report files for matching coordinates\")\n    task.setGroup(METADATA_GROUP)\n}\n\ntasks.register(\"generateDynamicAccessCoverageReport\", GenerateDynamicAccessCoverageReportTask.class) { task ->\n    task.setDescription(\"Generates a per-class dynamic-access coverage report for matching coordinates\")\n    task.setGroup(METADATA_GROUP)\n}\n\ntasks.register(\"generateLibraryStats\", GenerateLibraryStatsTask.class) { task ->\n    task.setDescription(\"Generates local library stats and updates stats/<group>/<artifact>/<metadata-version>/stats.json\")\n    task.setGroup(METADATA_GROUP)\n","exit_code":0,"status":"completed"}}
