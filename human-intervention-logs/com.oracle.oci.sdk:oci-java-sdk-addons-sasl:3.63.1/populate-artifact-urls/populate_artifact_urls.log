            <goal>jar</goal>
          </goals>
          <executions>
            <execution>
              <id>aggregate</id>
              <phase>package</phase>
              <goals>
                <goal>jar</goal>
              </goals>
            </execution>
          </executions>
          <configuration>
            <!-- Exclude classes that shouldn't be exposed to end users, ex, those in 'internal' packages -->
            <excludePackageNames>*.internal.*</excludePackageNames>
