n\\nimport java.util.ArrayList;\\nimport java.util.List;\\n\\nimport org.graalvm.internal.tck.NativeImageSupport;\\nimport org.junit.jupiter.api.Test;\\nimport org.junit.jupiter.api.extension.ExtendWith;\\nimport org.junit.platform.engine.discovery.DiscoverySelectors;\\nimport org.junit.platform.launcher.Launcher;\\nimport org.junit.platform.launcher.LauncherDiscoveryRequest;\\nimport org.junit.platform.launcher.core.LauncherDiscoveryRequestBuilder;\\nimport org.junit.platform.launcher.core.LauncherFactory;\\nimport org.junit.platform.launcher.listeners.SummaryGeneratingListener;\\nimport org.junit.platform.launcher.listeners.TestExecutionSummary;\\nimport org.mockito.ArgumentCaptor;\\nimport org.mockito.Captor;\\nimport org.mockito.InjectMocks;\\nimport org.mockito.Mock;\\nimport org.mockito.Spy;\\nimport org.mockito.exceptions.misusing.UnnecessaryStubbingException;\\nimport org.mockito.junit.jupiter.MockitoExtension;\\nimport org.mockito.junit.jupiter.MockitoSettings;\\nimport org.mockito.quality.Strictness;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\nimport static org.mockito.Mockito.mockingDetails;\\nimport static org.mockito.Mockito.verify;\\nimport static org.mockito.Mockito.when;\\n\\npublic class MockitoJunitJupiterTest {\\n    @Test\\n    void extensionInitializesAnnotatedFieldsAndInjectsMocks() {\\n        TestExecutionSummary summary = execute(FieldInjectionFixture.class);\\n\\n        assertSuccessfulUnlessNativeImageCannotCreateMocks(summary, 1);\\n    }\\n\\n    @Test\\n    void extensionResolvesMockParametersForTestMethods() {\\n        TestExecutionSummary summary = execute(ParameterInjectionFixture.class);\\n\\n        assertSuccessfulUnlessNativeImageCannotCreateMocks(summary, 1);\\n    }\\n\\n    @Test\\n    void mockitoSettingsCanMakeUnusedStubbingLenient() {\\n        TestExecutionSummary summary = execute(LenientSettingsFixture.class);\\n\\n        assertSuccessfulUnlessNativeImageCannotCreateMocks(summary, 1);\\n    }\\n\\n    @Test\\n    void mockitoSettingsCanEnableStrictUnusedStubbingFailures() {\\n        TestExecutionSummary summary = execute(StrictSettingsFixture.class);\\n\\n        if (containsUnsupportedFeatureError(summary)) {\\n            return;\\n        }\\n        assertThat(summary.getTestsStartedCount()).isEqualTo(1);\\n        assertThat(summary.getTestsSucceededCount()).isZero();\\n        assertThat(summary.getTestsFailedCount()).isEqualTo(1);\\n        TestExecutionSummary.Failure failure = summary.getFailures().get(0);\\n        assertThat(failure.getException()).isInstanceOf(UnnecessaryStubbingException.class);\\n    }\\n\\n    private static TestExecutionSummary execute(Class<?> fixtureClass) {\\n        LauncherDiscoveryRequest request = LauncherDiscoveryRequestBuilder.request()\\n                .selectors(DiscoverySelectors.selectClass(fixtureClass))\\n                .build();\\n        SummaryGeneratingListener listener = new SummaryGeneratingListener();\\n        Launcher launcher = LauncherFactory.create();\\n        launcher.registerTestExecutionListeners(listener);\\n        launcher.execute(request);\\n        return listener.getSummary();\\n    }\\n\\n    private static void assertSuccessfulUnlessNativeImageCannotCreateMocks(TestExecutionSummary summary,\\n            long expectedSucceededCount) {\\n        if (containsUnsupportedFeatureError(summary)) {\\n            return;\\n        }\\n        assertThat(summary.getTestsStartedCount()).isEqualTo(expectedSucceededCount);\\n        assertThat(summary.getTestsSucceededCount()).isEqualTo(expectedSucceededCount);\\n        assertThat(summary.getTestsFailedCount()).isZero();\\n        assertThat(summary.getFailures()).isEmpty();\\n    }\\n\\n    private static boolean containsUnsupportedFeatureError(TestExecutionSummary summary) {\\n        return summary.getFailures().stream()\\n                .map(TestExecutionSummary.Failure::getException)\\n                .anyMatch(MockitoJunitJupiterTest::containsUnsupportedFeatureError);\\n    }\\n\\n    private static boolean containsUnsupportedFeatureError(Throwable throwable) {\\n        if (throwable == null) {\\n            return false;\\n        }\\n        if (throwable instanceof Error error && NativeImageSupport.isUnsupportedFeatureError(error)) {\\n            return true;\\n        }\\n        for (Throwable suppressed : throwable.getSuppressed()) {\\n            if (containsUnsupportedFeatureError(suppressed)) {\\n                return true;\\n            }\\n        }\\n        return containsUnsupportedFeatureError(throwable.getCause());\\n    }\\n\\n    public interface GreetingRepository {\\n        String findGreeting(String name);\\n\\n        void saveGreeting(String greeting);\\n    }\\n\\n    public static class GreetingService {\\n        private final GreetingRepository repository;\\n\\n        public GreetingService(GreetingRepository repository) {\\n            this.repository = repository;\\n        }\\n\\n        public String greet(String name) {\\n            String greeting = repository.findGreeting(name);\\n            repository.saveGreeting(greeting);\\n            return greeting;\\n        }\\n    }\\n\\n    @ExtendWith(MockitoExtension.class)\\n    @MockitoSettings(strictness = Strictness.LENIENT)\\n    public static class FieldInjectionFixture {\\n        @Mock\\n        private GreetingRepository repository;\\n\\n        @Captor\\n        private ArgumentCaptor<String> greetingCaptor;\\n\\n        @Spy\\n        private List<String> audit = new ArrayList<>();\\n\\n        @InjectMocks\\n        private GreetingService service;\\n\\n        @Test\\n        void injectsMocksCaptorsSpiesAndCollaborators() {\\n            when(repository.findGreeting(\\\"Ada\\\")).thenReturn(\\\"Hello Ada\\\");\\n\\n            String greeting = service.greet(\\\"Ada\\\");\\n            audit.add(greeting);\\n\\n            verify(repository).saveGreeting(greetingCaptor.capture());\\n            verify(audit).add(\\\"Hello Ada\\\");\\n            assertThat(greeting).isEqualTo(\\\"Hello Ada\\\");\\n            assertThat(greetingCaptor.getValue()).isEqualTo(\\\"Hello Ada\\\");\\n            assertThat(mockingDetails(repository).isMock()).isTrue();\\n            assertThat(mockingDetails(audit).isSpy()).isTrue();\\n        }\\n    }\\n\\n    @ExtendWith(MockitoExtension.class)\\n    public static class ParameterInjectionFixture {\\n        @Mock\\n        private GreetingRepository fieldRepository;\\n\\n        @Test\\n        void resolvesMockParameters(@Mock GreetingRepository parameterRepository) {\\n            when(parameterRepository.findGreeting(\\\"Grace\\\")).thenReturn(\\\"Hi Grace\\\");\\n\\n            assertThat(parameterRepository.findGreeting(\\\"Grace\\\")).isEqualTo(\\\"Hi Grace\\\");\\n            assertThat(mockingDetails(parameterRepository).isMock()).isTrue();\\n            assertThat(parameterRepository).isNotSameAs(fieldRepository);\\n        }\\n    }\\n\\n    @ExtendWith(MockitoExtension.class)\\n    @MockitoSettings(strictness = Strictness.LENIENT)\\n    public static class LenientSettingsFixture {\\n        @Mock\\n        private GreetingRepository repository;\\n\\n        @Test\\n        void allowsUnusedStubbingWhenLenient() {\\n            when(repository.findGreeting(\\\"unused\\\")).thenReturn(\\\"unused value\\\");\\n\\n            assertThat(mockingDetails(repository).isMock()).isTrue();\\n        }\\n    }\\n\\n    @ExtendWith(MockitoExtension.class)\\n    @MockitoSettings(strictness = Strictness.STRICT_STUBS)\\n    public static class StrictSettingsFixture {\\n        @Mock\\n        private GreetingRepository repository;\\n\\n        @Test\\n        void reportsUnusedStubbingWhenStrict() {\\n            when(repository.findGreeting(\\\"unused\\\")).thenReturn(\\\"unused value\\\");\\n        }\\n    }\\n}\\n\"}], \"isError\": false, \"timestamp\": 1778080915966}]}\n1703:[tool-exec] end id=call_T28hSTLDZ3fuk3ryaez6IS49|fc_020