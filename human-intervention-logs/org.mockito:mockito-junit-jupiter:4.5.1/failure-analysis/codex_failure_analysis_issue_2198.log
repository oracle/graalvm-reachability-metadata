\nimport org.junit.platform.launcher.LauncherDiscoveryRequest;\\nimport org.junit.platform.launcher.core.LauncherDiscoveryRequestBuilder;\\nimport org.junit.platform.launcher.core.LauncherFactory;\\nimport org.junit.platform.launcher.listeners.SummaryGeneratingListener;\\nimport org.junit.platform.launcher.listeners.TestExecutionSummary;\\nimport org.mockito.ArgumentCaptor;\\nimport org.mockito.Captor;\\nimport org.mockito.InjectMocks;\\nimport org.mockito.Mock;\\nimport org.mockito.Spy;\\nimport org.mockito.exceptions.misusing.UnnecessaryStubbingException;\\nimport org.mockito.junit.jupiter.MockitoExtension;\\nimport org.mockito.junit.jupiter.MockitoSettings;\\nimport org.mockito.quality.Strictness;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\nimport static org.mockito.Mockito.mockingDetails;\\nimport static org.mockito.Mockito.verify;\\nimport static org.mockito.Mockito.when;\\n\\npublic class MockitoJunitJupiterTest {\\n    @Test\\n    void extensionInitializesAnnotatedFieldsAndInjectsMocks() {\\n        TestExecutionSummary summary = execute(FieldInjectionFixture.class);\\n\\n        assertSuccessfulUnlessNativeImageCannotCreateMocks(summary, 1);\\n    }\\n\\n    @Test\\n    void extensionResolvesMockParametersForTestMethods() {\\n        TestExecutionSummary summary = execute(ParameterInjectionFixture.class);\\n\\n        assertSuccessfulUnlessNativeImageCannotCreateMocks(summary, 1);\\n    }\\n\\n    @Test\\n    void mockitoSettingsCanMakeUnusedStubbingLenient() {\\n        TestExecutionSummary summary = execute(LenientSettingsFixture.class);\\n\\n        assertSuccessfulUnlessNativeImageCannotCreateMocks(summary, 1);\\n    }\\n\\n    @Test\\n    void mockitoSettingsCanEnableStrictUnusedStubbingFailures() {\\n        TestExecutionSummary summary = execute(StrictSettingsFixture.class);\\n\\n        if (containsUnsupportedFeatureError(summary)) {\\n            return;\\n        }\\n        assertThat(summary.getTestsStartedCount()).isEqualTo(1);\\n        assertThat(summary.getTestsSucceededCount()).isZero();\\n        assertThat(summary.getTestsFailedCount()).isEqualTo(1);\\n        assertThat(summary.getFailures())\\n                .singleElement()\\n                .extracting(TestExecutionSummary.Failure::getException)\\n                .isInstanceOf(UnnecessaryStubbingException.class);\\n    }\\n\\n    private static TestExecutionSummary execute(Class<?> fixtureClass) {\\n        LauncherDiscoveryRequest request = LauncherDiscoveryRequestBuilder.request()\\n                .selectors(DiscoverySelectors.selectClass(fixtureClass))\\n                .build();\\n        SummaryGeneratingListener listener = new SummaryGeneratingListener();\\n        Launcher launcher = LauncherFactory.create();\\n        launcher.registerTestExecutionListeners(listener);\\n        launcher.execute(request);\\n        return listener.getSummary();\\n    }\\n\\n    private static void assertSuccessfulUnlessNativeImageCannotCreateMocks(TestExecutionSummary summary,\\n            long expectedSucceededCount) {\\n        if (containsUnsupportedFeatureError(summary)) {\\n            return;\\n        }\\n        assertThat(summary.getTestsStartedCount()).isEqualTo(expectedSucceededCount);\\n        assertThat(summary.getTestsSucceededCount()).isEqualTo(expectedSucceededCount);\\n        assertThat(summary.getTestsFailedCount()).isZero();\\n        assertThat(summary.getFailures()).isEmpty();\\n    }\\n\\n    private static boolean containsUnsupportedFeatureError(TestExecutionSummary summary) {\\n        return summary.getFailures().stream()\\n                .map(TestExecutionSummary.Failure::getException)\\n                .anyMatch(MockitoJunitJupiterTest::containsUnsupportedFeatureError);\\n    }\\n\\n    private static boolean containsUnsupportedFeatureError(Throwable throwable) {\\n        if (throwable == null) {\\n            return false;\\n        }\\n        if (throwable instanceof Error error && NativeImageSuppor