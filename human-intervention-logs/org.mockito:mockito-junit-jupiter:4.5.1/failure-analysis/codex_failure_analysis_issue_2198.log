ssertThat(mockingDetails(audit).isSpy()).isTrue();\\n        }\\n    }\\n\\n    @ExtendWith(MockitoExtension.class)\\n    public static class ParameterInjectionFixture {\\n        @Mock\\n        private GreetingRepository fieldRepository;\\n\\n        @Test\\n        void resolvesMockParameters(@Mock GreetingRepository parameterRepository) {\\n            when(parameterRepository.findGreeting(\\\"Grace\\\")).thenReturn(\\\"Hi Grace\\\");\\n\\n            assertThat(parameterRepository.findGreeting(\\\"Grace\\\")).isEqualTo(\\\"Hi Grace\\\");\\n            assertThat(mockingDetails(parameterRepository).isMock()).isTrue();\\n            assertThat(parameterRepository).isNotSameAs(fieldRepository);\\n        }\\n    }\\n\\n    @ExtendWith(MockitoExtension.class)\\n    @MockitoSettings(strictness = Strictness.LENIENT)\\n    public static class LenientSettingsFixture {\\n        @Mock\\n        private GreetingRepository repository;\\n\\n        @Test\\n        void allowsUnusedStubbingWhenLenient() {\\n            when(repository.findGreeting(\\\"unused\\\")).thenReturn(\\\"unused value\\\");\\n\\n            assertThat(mockingDetails(repository).isMock()).isTrue();\\n        }\\n    }\\n\\n    @ExtendWith(MockitoExtension.class)\\n    @MockitoSettings(strictness = Strictness.STRICT_STUBS)\\n    public static class StrictSettingsFixture {\\n        @Mock\\n        private GreetingRepository repository;\\n\\n        @Test\\n        void reportsUnusedStubbingWhenStrict() {\\n            when(repository.findGreeting(\\\"unused\\\")).thenReturn(\\\"unused value\\\");\\n        }\\n    }\\n}\\n\"}\n1379:[tool-call] end id=call_cswQ6NUx5VCPWOWYbA0h3v4v|fc_0202e27dc767aecb0169fb5c64746c819eb2a65522ca656a3f name=write args={\"path\": \"tests/src/org.mockito/mockito-junit-jupiter/4.5.1/src/test/java/org_mockito/mockito_junit_jupiter/MockitoJunitJupiterTest.java\", \"content\": \"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the