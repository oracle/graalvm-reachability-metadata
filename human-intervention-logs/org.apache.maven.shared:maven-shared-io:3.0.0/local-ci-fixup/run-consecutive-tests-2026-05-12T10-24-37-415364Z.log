kerImagesTask.java:122:                    // Priority: 1. test-version (if present), 2. metadata-version\ntests/tck-build-logic/src/test/java/org/graalvm/internal/tck/harness/tasks/ValidateLibraryStatsTaskTests.java:271:                .hasMessageContaining(\"Missing metadata-version entry for com.example:demo:1.0.0\");\ntests/tck-build-logic/src/test/java/org/graalvm/internal/tck/harness/tasks/ValidateLibraryStatsTaskTests.java:282:                .hasMessageContaining(\"Missing metadata-version entry for com.example:demo:1.0.0\")\ntests/tck-build-logic/src/test/java/org/graalvm/internal/tck/harness/tasks/ValidateLibraryStatsTaskTests.java:283:                .hasMessageContaining(\"Missing metadata-version entry for com.example:demo:1.1.0\")\ntests/tck-build-logic/src/main/groovy/org/graalvm/internal/tck/harness/tasks/PopulateArtifactURLs.java:315:                - Entry test-version: %s\ntests/tck-build-logic/src/main/groovy/org/graalvm/internal/tck/harness/tasks/SingleCoordinateTask.java:28:            throw new GradleException(\"Multiple coordinates matched: \" + coords + \". This task requires a single concrete coordinate. \" +\ntests/tck-build-logic/src/main/groovy/org/graalvm/internal/tck/harness/tasks/SplitTestOnlyMetadataTask.java:33: * Splits test-only entries out of library reachability metadata into a separate\ntests/tck-build-logic/src/main/groovy/org/graalvm/internal/tck/harness/tasks/SplitTestOnlyMetadataTask.java:110:            getLogger().lifecycle(\"No test-only reachability metadata entries found for {}\", coordinate);\ntests/tck-build-logic/src/main/groovy/org/graalvm/internal/tck/harness/tasks/SplitTestOnlyMetadataTask.java:158:                    + \" in \" + indexFile + \" has no test-version or metadata-version\");\n","exit_code":2,"status":"failed"}}
