  	 * @return a new {@link Loader} instance
  	 */
  	public static Loader factoriesAndBeans(ListableBeanFactory beanFactory) {
  		ClassLoader classLoader = (beanFactory instanceof ConfigurableBeanFactory configurableBeanFactory ?
