        RegisteredBean registeredBean = RegisteredBean.of(beanFactory, \"compiledByAjc\");\n\n        List<BeanRegistrationAotContribution> contributions = AotServices\n                .factories(beanFactory.getBeanClassLoader())\n                .load(BeanRegistrationAotProcessor.class)\n                .stream()\n                .map(processor -> processor.processAheadOfTime(registeredBean))\n                .filter(Objects::nonNull)\n                .toList();\n\n        assertThat(contributions).hasSize(1);\n    }\n\n    public static class CompiledByAjc {\n        private static final Object ajc$perSingletonInstance = new Object();\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 2747, "output": 958, "cacheRead": 44544, "cacheWrite": 0, "totalTokens": 48249, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780747609610, "responseId": "resp_09888aa9de507c01016a240d5a417881949b9bdb271cc335bf"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_50DQ085hC2WW1NrZsfrZaaCj|fc_09888aa9de507c01016a240d65cfec81948e75998ad2e98bf4", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1778 bytes to tests/src/org.springframework/spring-aop/6.1.7/src/test/java/org_springframework/spring_aop/AspectJAdvisorBeanRegistrationAotProcessorTest.java"}], "isError": false, "timestamp": 1780747628876}]}
