  package org_apache_camel.camel_util;
  
  import java.lang.reflect.Field;
  import java.lang.reflect.Method;
  import java.util.LinkedHashMap;
  import java.util.LinkedHashSet;
  import java.util.Map;
  import java.util.Set;
  
  import org.apache.camel.util.ReflectionHelper;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ReflectionHelperTest {
      @Test
      void visitsDeclaredClassesFieldsAndMethods() {
          final Set<String> nestedClassNames = new LinkedHashSet<>();
          ReflectionHelper.doWithClasses(InspectableChild.class, clazz -> nestedClassNames.add(clazz.getSimpleName()));
          assertThat(nestedClassNames).containsExactly("NestedCommand");
  
          final Set<String> fieldNames = new LinkedHashSet<>();
          ReflectionHelper.doWithFields(InspectableChild.class, field -> fieldNames.add(field.getName()));
          assertThat(fieldNames).contains("childValue", "baseValue");
  
          final Set<String> methodNames = new LinkedHashSet<>();
          ReflectionHelper.doWithMethods(InspectableChild.class, method -> methodNames.add(method.getName()));
          assertThat(methodNames).contains("childOperation", "baseOperation");
      }
  
      @Test
      void findsDeclaredAndInterfaceMethods() {
          final Method declaredMethod = ReflectionHelper.findMethod(
                  InspectableChild.class,
                  "childOperation",
                  String.class
          );
          assertThat(declaredMethod).isNotNull();
          assertThat(declaredMethod.getDeclaringClass()).isEqualTo(InspectableChild.class);
  
          final Method publicInterfaceMethod = ReflectionHelper.findMethod(
                  OperationContract.class,
                  "contractOperation",
                  String.class
          );
          assertThat(publicInterfaceMethod).isNotNull();
          assertThat(publicInterfaceMethod.getDeclaringClass()).isEqualTo(OperationContract.class);
