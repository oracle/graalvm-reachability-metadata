      void setsPrimitiveAndObjectFieldsThenReadsObjectField() {
          final PrimitiveAndObjectFields target = new PrimitiveAndObjectFields();
          final Map<String, Field> fields = fieldsByName(PrimitiveAndObjectFields.class);
  
