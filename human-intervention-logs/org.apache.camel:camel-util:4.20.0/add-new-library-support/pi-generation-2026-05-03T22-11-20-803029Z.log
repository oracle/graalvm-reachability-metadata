  package org_apache_camel.camel_util;
  
  import java.io.IOException;
  import java.net.URL;
  import java.util.Collections;
  import java.util.Enumeration;
  import java.util.List;
  
  import org.apache.camel.util.AntPathMatcher;
  import org.apache.camel.util.ObjectHelper;
  import org.junit.jupiter.api.Test;
  
  import static org.junit.jupiter.api.Assertions.assertEquals;
  import static org.junit.jupiter.api.Assertions.assertFalse;
  import static org.junit.jupiter.api.Assertions.assertNotNull;
  import static org.junit.jupiter.api.Assertions.assertNull;
  import static org.junit.jupiter.api.Assertions.assertSame;
  import static org.junit.jupiter.api.Assertions.assertTrue;
  
  public class ObjectHelperTest {
      private static final String RESOURCE_NAME = "object-helper/resource.txt";
      private static final String DEFAULT_CAMEL_CONTEXT = "org.apache.camel.impl.DefaultCamelContext";
  
      @Test
      void loadsNonSimpleArrayClass() {
          Class<?> loadedClass = ObjectHelper.loadClass(AntPathMatcher.class.getName() + "[]", null, false);
  
          assertSame(AntPathMatcher[].class, loadedClass);
      }
  
      @Test
      void checksConstructorsOnCamelUtilityClass() {
          assertFalse(ObjectHelper.hasDefaultPublicNoArgConstructor(ObjectHelper.class));
          assertFalse(ObjectHelper.hasDefaultNoArgConstructor(ObjectHelper.class));
      }
  
      @Test
      void looksUpPublicConstantFieldValue() {
          assertEquals("/", ObjectHelper.lookupConstantFieldValue(AntPathMatcher.class, ".DEFAULT_PATH_SEPARATOR"));
      }
  
      @Test
      void loadsResourceUrlFromProvidedClassLoader() throws Exception {
          URL expectedUrl = new URL("file", "", "/provided-class-loader-resource");
          ClassLoader classLoader = new SingleResourceClassLoader(expectedUrl);
  
          URL loadedUrl = ObjectHelper.loadResourceAsURL(RESOURCE_NAME, classLoader);
  
          assertEquals(expectedUrl, loadedUrl);
      }
  
      @Test
      void loadsResourceUrlFromThreadContextClassLoader() throws Exception {
          URL expectedUrl = new URL("file", "", "/thread-context-resource");
          ClassLoader classLoader = new SingleResourceClassLoader(expectedUrl);
  
          withContextClassLoader(classLoader, () -> {
              URL loadedUrl = ObjectHelper.loadResourceAsURL(RESOURCE_NAME);
  
              assertEquals(expectedUrl, loadedUrl);
          });
      }
  
      @Test
      void consultsDefaultCamelContextClassLoaderWhenLoadingResourceUrl() throws Exception {
          ClassLoader classLoader = new DefaultCamelContextLookupClassLoader();
  
          withContextClassLoader(classLoader, () -> {
              URL loadedUrl = ObjectHelper.loadResourceAsURL("object-helper/missing-resource.txt");
  
              assertNull(loadedUrl);
          });
      }
  
      @Test
      void loadsResourceUrlFromObjectHelperClassLoader() throws Exception {
          withContextClassLoader(null, () -> {
              URL loadedUrl = ObjectHelper.loadResourceAsURL(RESOURCE_NAME);
  
              assertNotNull(loadedUrl);
          });
      }
  
      @Test
      void loadsAbsoluteResourceUrlFromObjectHelperClass() throws Exception {
          withContextClassLoader(null, () -> {
              URL loadedUrl = ObjectHelper.loadResourceAsURL("/" + RESOURCE_NAME);
  
              assertNotNull(loadedUrl);
          });
      }
  
      @Test
      void loadsResourceUrlsFromProvidedClassLoader() throws Exception {
          URL expectedUrl = new URL("file", "", "/provided-class-loader-resources");
          ClassLoader classLoader = new SingleResourceClassLoader(expectedUrl);
  
          Enumeration<URL> loadedUrls = ObjectHelper.loadResourcesAsURL(RESOURCE_NAME, classLoader);
  
          assertNotNull(loadedUrls);
          assertTrue(loadedUrls.hasMoreElements());
          assertEquals(expectedUrl, loadedUrls.nextElement());
      }
  
      @Test
      void loadsResourceUrlsFromThreadContextClassLoader() throws Exception {
          URL expectedUrl = new URL("file", "", "/thread-context-resources");
          ClassLoader classLoader = new SingleResourceClassLoader(expectedUrl);
  
          withContextClassLoader(classLoader, () -> {
              Enumeration<URL> loadedUrls = ObjectHelper.loadResourcesAsURL(RESOURCE_NAME);
  
              assertNotNull(loadedUrls);
              assertTrue(loadedUrls.hasMoreElements());
              assertEquals(expectedUrl, loadedUrls.nextElement());
          });
      }
  
      @Test
      void consultsDefaultCamelContextClassLoaderWhenLoadingResourceUrls() throws Exception {
          ClassLoader classLoader = new DefaultCamelContextLookupClassLoader();
  
          withContextClassLoader(classLoader, () -> {
              Enumeration<URL> loadedUrls = ObjectHelper.loadResourcesAsURL(RESOURCE_NAME);
  
              assertNotNull(loadedUrls);
          });
      }
  
      @Test
      void loadsResourceUrlsFromObjectHelperClassLoader() throws Exception {
          withContextClassLoader(null, () -> {
              Enumeration<URL> loadedUrls = ObjectHelper.loadResourcesAsURL(RESOURCE_NAME);
  
              assertNotNull(loadedUrls);
          });
      }
  
      private static void withContextClassLoader(ClassLoader classLoader, ThrowingRunnable runnable) throws Exception {
          Thread currentThread = Thread.currentThread();
          ClassLoader originalClassLoader = currentThread.getContextClassLoader();
          currentThread.setContextClassLoader(classLoader);
          try {
              runnable.run();
          } finally {
              currentThread.setContextClassLoader(originalClassLoader);
          }
      }
  
      private interface ThrowingRunnable {
          void run() throws Exception;
      }
  
      private static final class SingleResourceClassLoader extends ClassLoader {
          private final URL resourceUrl;
  
          private SingleResourceClassLoader(URL resourceUrl) {
              super(ObjectHelperTest.class.getClassLoader());
              this.resourceUrl = resourceUrl;
          }
  
          @Override
          public URL getResource(String name) {
              if (RESOURCE_NAME.equals(name)) {
                  return resourceUrl;
              }
              return null;
          }
  
          @Override
          public Enumeration<URL> getResources(String name) throws IOException {
              if (RESOURCE_NAME.equals(name)) {
                  return Collections.enumeration(List.of(resourceUrl));
              }
              return Collections.emptyEnumeration();
          }
      }
  
      private static final class DefaultCamelContextLookupClassLoader extends ClassLoader {
          private DefaultCamelContextLookupClassLoader() {
              super(ObjectHelperTest.class.getClassLoader());
          }
  
          @Override
          public URL getResource(String name) {
              return null;
          }
  
          @Override
          public Enumeration<URL> getResources(String name) throws IOException {
              return null;
          }
  
          @Override
          public Class<?> loadClass(String name) throws ClassNotFoundException {
              if (DEFAULT_CAMEL_CONTEXT.equals(name)) {
                  return ObjectHelper.class;
              }
              return super.loadClass(name);
          }
      }
  }
