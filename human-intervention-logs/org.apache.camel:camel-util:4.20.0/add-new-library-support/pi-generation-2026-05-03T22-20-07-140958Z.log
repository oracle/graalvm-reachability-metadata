l_util/AnnotationHelperTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_apache_camel.camel_util;\n\nimport java.lang.annotation.ElementType;\nimport java.lang.annotation.Retention;\nimport java.lang.annotation.RetentionPolicy;\nimport java.lang.annotation.Target;\nimport java.lang.reflect.Field;\nimport java.lang.reflect.Method;\nimport java.util.List;\n\nimport org.apache.camel.util.AnnotationHelper;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class AnnotationHelperTest {\n    @Test\n    void findsDeclaredAndInheritedMethodsWithDirectAndMetaAnnotations() {\n        List<Method> directMethods = AnnotationHelper.findMethodsWithAnnotation(\n                AnnotatedChild.class,\n                DirectMarker.class\n        );\n        assertThat(directMethods)\n                .extracting(Method::getName)\n                .contains(\"childDirectOperation\", \"baseDirectOperation\")\n                .doesNotContain(\"childMetaOperation\");\n\n        List<Method> metaMethods = AnnotationHelper.findMethodsWithAnnotation(\n                AnnotatedChild.class,\n                MetaMarker.class,\n                true\n        );\n        assertThat(metaMethods)\n                .extracting(Method::getName)\n                .containsExactly(\"childMetaOperation\");\n    }\n\n    @Test\n    void readsAnnotationValuesFromMethodAndFieldAnnotations() throws Exception {\n        Method method = AnnotationValueHolder.class.getDeclaredMethod(\"annotatedOperation\");\n        Field field = AnnotationValueHolder.class.getDeclaredField(\"annotatedField\");\n        String annotationName = ValueMarker.class.getName();\n\n        assertThat(AnnotationHelper.getAnnotationValue(method, annotationName)).isEqualTo(\"method-value\");\n        assertThat(AnnotationHelper.getAnnotationValue(method, annotationName, \"rank\")).isEqualTo(42);\n        assertThat(AnnotationHelper.getAnnotationValue(field, annotationName)).isEqualTo(\"field-value\");\n        assertThat(AnnotationHelper.getAnnotationValue(field, annotationName, \"rank\")).isEqualTo(7);\n        assertThat(AnnotationHelper.getAnnotationValue(method, annotationName, \"missingKey\")).isNull();\n    }\n\n    @Retention(RetentionPolicy.RUNTIME)\n    @Target(ElementType.METHOD)\n    private @interface DirectMarker {\n    }\n\n    @Retention(RetentionPolicy.RUNTIME)\n    @Target(ElementType.ANNOTATION_TYPE)\n    private @interface MetaMarker {\n    }\n\n    @MetaMarker\n    @Retention(RetentionPolicy.RUNTIME)\n    @Target(ElementType.METHOD)\n    private @interface ComposedMarker {\n    }\n\n    @Retention(RetentionPolicy.RUNTIME)\n    @Target({ ElementType.FIELD, ElementType.METHOD })\n    private @interface ValueMarker {\n        String value();\n\n        int rank();\n    }\n\n    private static class AnnotatedBase {\n        @DirectMarker\n        private void baseDirectOperation() {\n        }\n    }\n\n    private static final class AnnotatedChild extends AnnotatedBase {\n        @DirectMarker\n        private void childDirectOperation() {\n        }\n\n        @ComposedMarker\n        private void childMetaOperation() {\n        }\n    }\n\n    private static final class AnnotationValueHolder {\n        @ValueMarker(value = \"field-value\", rank = 7)\n        private String annotatedField;\n\n        @ValueMarker(value = \"method-value\", rank = 42)\n        private void annotatedOperation() {\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 2899, "output": 1387, "cacheRead": 11776, "cacheWrite": 0, "totalTokens": 16062, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777846778195, "responseId": "resp_02