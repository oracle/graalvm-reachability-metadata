commons.org/publicdomain/zero/1.0/>.\n */\npackage org_apache_camel.camel_util;\n\nimport java.io.IOException;\nimport java.net.URL;\nimport java.util.Collections;\nimport java.util.Enumeration;\nimport java.util.List;\n\nimport org.apache.camel.util.AntPathMatcher;\nimport org.apache.camel.util.ObjectHelper;\nimport org.junit.jupiter.api.Test;\n\nimport static org.junit.jupiter.api.Assertions.assertEquals;\nimport static org.junit.jupiter.api.Assertions.assertFalse;\nimport static org.junit.jupiter.api.Assertions.assertNotNull;\nimport static org.junit.jupiter.api.Assertions.assertNull;\nimport static org.junit.jupiter.api.Assertions.assertSame;\nimport static org.junit.jupiter.api.Assertions.assertTrue;\n\npublic class ObjectHelperTest {\n    private static final String RESOURCE_NAME = \"object-helper/resource.txt\";\n    private static final String DEFAULT_CAMEL_CONTEXT = \"org.apache.camel.impl.DefaultCamelContext\";\n\n    @Test\n    void loadsNonSimpleArrayClass() {\n        Class<?> loadedClass = ObjectHelper.loadClass(AntPathMatcher.class.getName() + \"[]\", null, false);\n\n        assertSame(AntPathMatcher[].class, loadedClass);\n    }\n\n    @Test\n    void checksConstructorsOnCamelUtilityClass() {\n        assertFalse(ObjectHelper.hasDefaultPublicNoArgConstructor(ObjectHelper.class));\n        assertFalse(ObjectHelper.hasDefaultNoArgConstructor(ObjectHelper.class));\n    }\n\n    @Test\n    void looksUpPublicConstantFieldValue() {\n        assertEquals(\"/\", ObjectHelper.lookupConstantFieldValue(AntPathMatcher.class, \".DEFAULT_PATH_SEPARATOR\"));\n    }\n\n    @Test\n    void loadsResourceUrlFromProvidedClassLoader() throws Exception {\n        URL expectedUrl = new URL(\"file\", \"\", \"/provided-class-loader-resource\");\n        ClassLoader classLoader = new SingleResourceClassLoader(expectedUrl);\n\n        URL loadedUrl = ObjectHelper.loadResourceAsURL(RESOURCE_NAME, classLoader);\n\n        assertEquals(expectedUrl, loadedUrl);\n    }\n\n    @Test\n    void loadsResourceUrlFromThreadContextClassLoader() throws Exception {\n        URL expectedUrl = new URL(\"file\", \"\", \"/thread-context-resource\");\n        ClassLoader classLoader = new SingleResourceClassLoader(expectedUrl);\n\n        withContextClassLoader(classLoader, () -> {\n            URL loadedUrl = ObjectHelper.loadResourceAsURL(RESOURCE_NAME);\n\n            assertEquals(expectedUrl, loadedUrl);\n        });\n    }\n\n    @Test\n    void consultsDefaultCamelContextClassLoaderWhenLoadingResourceUrl() throws Exception {\n        ClassLoader classLoader = new DefaultCamelContextLookupClassLoader();\n\n        withContextClassLoader(classLoader, () -> {\n            URL loadedUrl = ObjectHelper.loadResourceAsURL(\"object-helper/missing-resource.txt\");\n\n            assertNull(loadedUrl);\n        });\n    }\n\n    @Test\n    void loadsResourceUrlFromObjectHelperClassLoader() throws Exception {\n        withContextClassLoader(null, () -> {\n            URL loadedUrl = ObjectHelper.loadResourceAsURL(RESOURCE_NAME);\n\n            assertNotNull(loadedUrl);\n        });\n    }\n\n    @Test\n    void loadsAbsoluteResourceUrlFromObjectHelperClass() throws Exception {\n        withContextClassLoader(null, () -> {\n            URL loadedUrl = ObjectHelper.loadResourceAsURL(\"/\" + RESOURCE_NAME);\n\n            assertNotNull(loadedUrl);\n        });\n    }\n\n    @Test\n    void loadsResourceUrlsFromProvidedClassLoader() throws Exception {\n        URL expectedUrl = new URL(\"file\", \"\", \"/provided-class-loader-resources\");\n        ClassLoader classLoader = new SingleResourceClassLoader(expectedUrl);\n\n        Enumeration<URL> loadedUrls = ObjectHelper.loadResourcesAsURL(RESOURCE_NAME, classLoader);\n\n        assertNotNull(loadedUrls);\n        assertTrue(loadedUrls.hasMoreElements());\n        assertEquals(expectedUrl, loadedUrls.nextElement());\n    }\n\n    @Test\n    void loadsResourceUrlsFromThreadContextClassLoader() throws Exception {\n        URL expectedUrl = new URL(\"file\", \"\", \"/thread-context-resources\");\n        ClassLoader classLoader = new SingleResourceClassLoader(expectedUrl);\n\n        withContextClassLoader(classLoader, () -> {\n            Enumeration<URL> loadedUrls = ObjectHelper.loadResourcesAsURL(RESOURCE_NAME);\n\n            assertNotNull(loadedUrls);\n            assertTrue(loadedUrls.hasMoreElements());\n            assertEquals(expectedUrl, loadedUrls.nextElement());\n        });\n    }\n\n    @Test\n    void consultsDefaultCamelContextClassLoaderWhenLoadingResourceUrls() throws Exception {\n        ClassLoader classLoader = new DefaultCamelContextLookupClassLoader();\n\n        withContextClassLoader(classLoader, () -> {\n            Enumeration<URL> loadedUrls = ObjectHelper.loadResourcesAsURL(RESOURCE_NAME);\n\n            assertNotNull(loadedUrls);\n        });\n    }\n\n    @Test\n    void loadsResourceUrlsFromObjectHelperClassLoader() throws Exception {\n        withContextClassLoader(null, () -> {\n            Enumeration<URL> loadedUrls = ObjectHelper.loadResourcesAsURL(RESOURCE_NAME);\n\n            assertNotNull(loadedUrls);\n        });\n    }\n\n    private static void withContextClassLoader(ClassLoader classLoader, ThrowingRunnable runnable) throws Exception {\n        Thread currentThread = Thread.currentThread();\n        ClassLoader originalClassLoader = currentThread.getContextClassLoader();\n        currentThread.setContextClassLoader(classLoader);\n        try {\n            runnable.run();\n        } finally {\n            currentThread.setContextClassLoader(originalClassLoader);\n        }\n    }\n\n    private interface ThrowingRunnable {\n        void run() throws Exception;\n    }\n\n    private static final class SingleResourceClassLoader extends ClassLoader {\n        private final URL resourceUrl;\n\n        private SingleResourceClassLoader(URL resourceUrl) {\n            super(ObjectHelperTest.class.getClassLoader());\n            this.resourceUrl = resourceUrl;\n        }\n\n        @Override\n        public URL getResource(String name) {\n            if (RESOURCE_NAME.equals(name)) {\n                return resourceUrl;\n            }\n            return null;\n        }\n\n        @Override\n        public Enumeration<URL> getResources(String name) throws IOException {\n            if (RESOURCE_NAME.equals(name)) {\n                return Collections.enumeration(List.of(resourceUrl));\n            }\n            return Collections.emptyEnumeration();\n        }\n    }\n\n    private static final class DefaultCamelContextLookupClassLoader extends ClassLoader {\n        private DefaultCamelContextLookupClassLoader() {\n            super(ObjectHelperTest.class.getClassLoader());\n        }\n\n        @Override\n        public URL getResource(String name) {\n            return null;\n        }\n\n        @Override\n        public Enumeration<URL> getResources(String name) throws IOException {\n            return null;\n        }\n\n        @Override\n        public Class<?> loadClass(String name) throws ClassNotFoundException {\n            if (DEFAULT_CAMEL_CONTEXT.equals(name)) {\n                return ObjectHelper.class;\n            }\n            return super.loadClass(name);\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777846778191}, {"role": "toolResult", "toolCallId": "call_Pl3G4DvWsSyzhJ6oGqMXSTjk|fc_02ddd8e54a0fd0100169f7c9f9f6088197a301acb5bc483106", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_apache_camel.camel_util;\n\nimport java.lang.reflect.Field;\nimport java.lang.reflect.Method;\nimport java.util.LinkedHashMap;\nimport java.util.LinkedHashSet;\nimport java.util.Map;\nimport java.util.Set;\n\nimport org.apache.camel.util.ReflectionHelper;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ReflectionHelperTest {\n    @Test\n    void visitsDeclaredClassesFieldsAndMethods() {\n        final Set<String> nestedClassNames = new LinkedHashSet<>();\n        ReflectionHelper.doWithClasses(InspectableChild.class, clazz -> nestedClassNames.add(clazz.getSimpleName()));\n        assertThat(nestedClassNames).containsExactly(\"NestedCommand\");\n\n        final Set<String> fieldNames = new LinkedHashSet<>();\n        ReflectionHelper.doWithFields(InspectableChild.class, field -> fieldNames.add(field.getName()));\n        assertThat(fieldNames).contains(\"childValue\", \"baseValue\");\n\n        final Set<String> methodNames = new LinkedHashSet<>();\n        ReflectionHelper.doWithMethods(OperationContract.class, method -> methodNames.add(method.getName()));\n        assertThat(methodNames).contains(\"contractOperation\");\n    }\n\n    @Test\n    void findsDeclaredAndInterfaceMethods() {\n        final Method declaredMethod = ReflectionHelper.findMethod(\n                InspectableChild.class,\n                \"childOperation\",\n                String.class\n        );\n        assertThat(declaredMethod).isNotNull();\n        assertThat(declaredMethod.getDeclaringClass()).isEqualTo(InspectableChild.class);\n\n        final Method publicInterfaceMethod = ReflectionHelper.findMethod(\n                OperationContract.class,\n                \"contractOperation\",\n                String.class\n        );\n        assertThat(publicInterfaceMethod).isNotNull();\n        assertThat(publicInterfaceMethod.getDeclaringClass()).isEqualTo(OperationContract.class);\n    }\n\n    @Test\n    void setsPrimitiveAndObjectFieldsThenReadsObjectField() {\n        final PrimitiveAndObjectFields target = new PrimitiveAndObjectFields();\n        final Map<String, Field> fields = fieldsByName(PrimitiveAndObjectFields.class);\n\n        ReflectionHelper.setField(fields.get(\"enabled\"), target, \"true\");\n        ReflectionHelper.setField(fields.get(\"level\"), target, \"12\");\n        ReflectionHelper.setField(fields.get(\"count\"), target, \"34\");\n        ReflectionHelper.setField(fields.get(\"size\"), target, \"56\");\n        ReflectionHelper.setField(fields.get(\"ratio\"), target, \"7.5\");\n        ReflectionHelper.setField(fields.get(\"price\"), target, \"8.25\");\n        ReflectionHelper.setField(fields.get(\"label\"), target, \"camel\");\n\n        assertThat(target.isEnabled()).isTrue();\n        assertThat(target.getLevel()).isEqualTo((byte) 12);\n        assertThat(target.getCount()).isEqualTo(34);\n        assertThat(target.getSize()).isEqualTo(56L);\n        assertThat(target.getRatio()).isEqualTo(7.5F);\n        assertThat(target.getPrice()).isEqualTo(8.25D);\n        assertThat(ReflectionHelper.getField(fields.get(\"label\"), target)).isEqualTo(\"camel\");\n    }\n\n    private static Map<String, Field> fieldsByName(Class<?> type) {\n        final Map<String, Field> fields = new LinkedHashMap<>();\n        ReflectionHelper.doWithFields(type, field -> fields.put(field.getName(), field));\n        return fields;\n    }\n\n    private static class InspectableBase {\n        private String baseValue = \"base\";\n\n    }\n\n    private static final class InspectableChild extends InspectableBase {\n        private String childValue = \"child\";\n\n        private String childOperation(String suffix) {\n            return childValue + suffix;\n        }\n\n        private static final class NestedCommand {\n        }\n    }\n\n    private interface OperationContract {\n        String contractOperation(String value);\n    }\n\n    private static final class PrimitiveAndObjectFields {\n        private boolean enabled;\n        private byte level;\n        private int count;\n        private long size;\n        private float ratio;\n        private double price;\n        private String label;\n\n        private boolean isEnabled() {\n            return enabled;\n        }\n\n        private byte getLevel() {\n            return level;\n        }\n\n        private int getCount() {\n            return count;\n        }\n\n        private long getSize() {\n            return size;\n        }\n\n        private float getRatio() {\n            return ratio;\n        }\n\n        private double getPrice() {\n            return price;\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777846778191}, {"role": "toolResult", "toolCallId": "call_Uv8HQAWPYeCR4k1Ib62Y2AYS|fc_02ddd8e54a0fd0100169f7c9f9f6108197a4538d741a7f8d1d", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\nplugins {\n    id \"org.graalvm.internal.tck\"\n}\n\nString libraryVersion = tck.testedLibraryVersion.get()\n\ndependencies {\n    testImplementation \"org.apache.camel:camel-util:$libraryVersion\"\n    testImplementation 'org.assertj:assertj-core:3.22.0'\n}\n\ngraalvmNative {\n    agent {\n        defaultMode = \"conditional\"\n        modes {\n            conditional {\n                userCodeFilterPath = \"user-code-filter.json\"\n            }\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777846778192}, {"role": "toolResult", "toolCallId": "call_CCgmMNFMhvYIOWpYhMG1TYbz|fc_02ddd8e54a0fd0100169f7c9f9f6188197abeea77b4e4fd549", "toolName": "read", "content": [{"type": "text", "text": "{}\n"}], "isError": false, "timestamp": 1777846778192}]}
