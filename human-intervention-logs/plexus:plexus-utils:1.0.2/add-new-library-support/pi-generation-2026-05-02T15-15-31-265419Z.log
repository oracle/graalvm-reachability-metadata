[tool-call] delta {"path":"tests/src/plexus/plexus-utils/1.0.2/src/test/java/plexus/plexus_utils/ReflectorTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage plexus.plexus_utils;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport org.codehaus.plexus.util.reflection.Reflector;\nimport org.junit.jupiter.api.Test;\n\npublic class ReflectorTest {\n    @Test\n    void createsNewInstanceUsingPublicConstructor() throws Exception {\n        Reflector reflector = new Reflector();\n\n        Object created = reflector.newInstance(ConstructorTarget.class, new Object[] { \"created\" });\n\n        assertThat(created).isInstanceOf(ConstructorTarget.class);\n        assertThat(((ConstructorTarget) created).value).isEqualTo(\"created\");\n    }\n\n    @Test\n    void readsPublicInstanceAndStaticFields() throws Exception {\n        Reflector reflector = new Reflector();\n        FieldTarget target = new FieldTarget(\"visible\");\n\n        assertThat(reflector.getField(target, \"message\")).isEqualTo(\"visible\");\n        assertThat(reflector.getStaticField(FieldTarget.class, \"GLOBAL_MESSAGE\")).isEqualTo(\"shared\");\n    }\n\n    @Test\n    void invokesInstanceStaticAndSingletonFactoryMethods() throws Exception {\n        Reflector reflector = new Reflector();\n        InvocationTarget target = new InvocationTarget(\"prefix\");\n\n        assertThat(reflector.invoke(target, \"join\", new Object[] { \"value\" })).isEqualTo(\"prefix-value\");\n        assertThat(reflector.invokeStatic(InvocationTarget.class, \"staticJoin\", new Object[] { \"value\" }))\n                .isEqualTo(\"static-value\");\n\n        Object singleton = reflector.getSingleton(SingletonFactory.class, new Object[] { \"value\" });\n        assertThat(singleton).isInstanceOf(SingletonFactory.class);\n        assertThat(((SingletonFactory) singleton).value).isEqualTo(\"value-singleton\");\n    }\n\n    @Test\n    void retrievesObjectPropertyThroughBeanAccessor() throws Exception {\n        Reflector reflector = new Reflector();\n        PropertyTarget target = new PropertyTarget(\"field-value\", \"bean-value\");\n\n        assertThat(reflector.getObjectProperty(target, \"name\")).isEqualTo(\"bean-value\");\n    }\n\n    public static final class ConstructorTarget {\n        public final String value;\n\n        public ConstructorTarget(String value) {\n            this.value = value;\n        }\n    }\n\n    public static final class FieldTarget {\n        public static final String GLOBAL_MESSAGE = \"shared\";\n\n        public final String message;\n\n        public FieldTarget(String message) {\n            this.message = message;\n        }\n    }\n\n    public static final class InvocationTarget {\n        private final String prefix;\n\n        public InvocationTarget(String prefix) {\n            this.prefix = prefix;\n        }\n\n        public String join(String suffix) {\n            return prefix + \"-\" + suffix;\n        }\n\n        public static String staticJoin(String suffix) {\n            return \"static-\" + suffix;\n        }\n    }\n\n    public static final class SingletonFactory {\n        public final String value;\n\n        private SingletonFactory(String value) {\n            this.value = value;\n        }\n\n        public static SingletonFactory getInstance(String value) {\n            return new SingletonFactory(value + \"-singleton\");\n        }\n    }\n\n    public static final class PropertyTarget {\n        public final String name;\n        private final String beanName;\n\n        public PropertyTarget(String name, String beanName) {\n            this.name = name;\n            this.beanName = beanName;\n        }\n\n        public String getName() {\n            return beanName;\n        }\n    }\n}\n"}
