at(singleton).isInstanceOf(SingletonFactory.class);\\n        assertThat(((SingletonFactory) singleton).value).isEqualTo(\\\"value-singleton\\\");\\n    }\\n\\n    @Test\\n    void retrievesObjectPropertyThroughBeanAccessor() throws Exception {\\n        Reflector reflector = new Reflector();\\n        PropertyTarget target = new PropertyTarget(\\\"field-value\\\", \\\"bean-value\\\");\\n\\n        assertThat(reflector.getObjectProperty(target, \\\"name\\\")).isEqualTo(\\\"bean-value\\\");\\n    }\\n\\n    public static final class ConstructorTarget {\\n        public final String value;\\n\\n        public ConstructorTarget(String value) {\\n            this.value = value;\\n        }\\n    }\\n\\n    public static final class FieldTarget {\\n        public static final String GLOBAL_MESSAGE = \\\"shared\\\";\\n\\n        public final String message;\\n\\n        public FieldTarget(String message) {\\n            this.message = message;\\n        }\\n    }\\n\\n    public static final class InvocationTarget {\\n        private final String prefix;\\n\\n        public InvocationTarget(String prefix) {\\n            this.prefix = prefix;\\n        }\\n\\n        public String join(String suffix) {\\n            return prefix + \\\"-\\\" + suffix;\\n        }\\n\\n        public static String staticJoin(String suffix) {\\n            return \\\"static-\\\" + suffix;\\n        }\\n    }\\n\\n    public static final class SingletonFactory {\\n        public final String value;\\n\\n        private SingletonFactory(String value) {\\n            this.value = value;\\n        }\\n\\n        public static SingletonFactory getInstance(String value) {\\n            return new SingletonFactory(value + \\\"-singleton\\\");\\n        }\\n    }\\n\\n    public static final class PropertyTarget {\\n        public final String name;\\n        private final String beanName;\\n\\n        public PropertyTarget(String name, String beanName) {\\n            this.name = name;\\n         