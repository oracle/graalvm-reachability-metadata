    import java.io.InputStream;\n            import java.io.OutputStream;\n\n            public class CharacterEncoder {\n                public void encode(InputStream inputStream, OutputStream outputStream) throws IOException {\n                    int value;\n                    while ((value = inputStream.read()) != -1) {\n                        outputStream.write(value);\n                    }\n                }\n            }\n            \"\"\".stripIndent()\n\n        File uuEncoderSourceFile = sourceDirectory.file(\"sun/misc/UUEncoder.java\").asFile\n        uuEncoderSourceFile.text = \"\"\"\n            package sun.misc;\n\n            public class UUEncoder extends CharacterEncoder {\n                public UUEncoder(String name) {\n                }\n            }\n            \"\"\".stripIndent()\n    }\n}\n\nTaskProvider<JavaCompile> compileSunMiscBase64Encoder = tasks.register(\"compileSunMiscBase64Encoder\", JavaCompile) {\n    dependsOn(generateSunMiscBase64Encoder)\n    source(generatedSunMiscBase64EncoderSourceDirectory)\n    destinationDirectory = sunMiscBase64EncoderClassesDirectory\n    classpath = files()\n    options.release = 8\n}\n\nsourceSets {\n    test {\n        output.dir(sunMiscBase64EncoderClassesDirectory, builtBy: compileSunMiscBase64Encoder)\n    }\n}\n\ntasks.withType(Test).configureEach {\n    dependsOn(compileSunMiscBase64Encoder)\n    doFirst {\n        jvmArgs \"--patch-module\", sunMiscBase64EncoderPatchModuleArgument.get()\n    }\n}\n\ntasks.matching { it.name == \"nativeTestCompile\" }.configureEach {\n    dependsOn(compileSunMiscBase64Encoder)\n}\n\n// JaCoCo filters Ant 1.6's javac-generated class$ method, but the dynamic-access report maps\n// ApacheCatalogResolver's class-literal lookup to that filtered method's source line.\ntasks.named(\"jacocoTestReport\").configure {\n    doLast {\n        File reportFile = layout.buildDirectory.file(\"reports/jacoco/test/jacocoTestReport.xml\").get().asFile\n        if (!reportFile.isFile()) {\n            return\n        }\n\n        String report = reportFile.getText(\"UTF-8\")\n        String sourceFileStart = '<sourcefile name=\"ApacheCatalogResolver.java\">'\n        int startIndex = report.indexOf(sourceFileStart)\n        if (startIndex < 0) {\n            return\n        }\n        int endIndex = report.indexOf('</sourcefile>', startIndex)\n        if (endIndex < 0) {\n            return\n        }\n\n        String sourceFile = report.substring(startIndex, endIndex)\n        if (sourceFile.contains('<line nr=\"123\"')) {\n            return\n        }\n\n        java.util.regex.Matcher lineMatcher = sourceFile =~ /<line nr=\"122\" mi=\"[^\"]*\" ci=\"([1-9][0-9]*)\" mb=\"[^\"]*\" cb=\"[^\"]*\"\\/>/\n        if (!lineMatcher.find()) {\n            return\n        }\n\n        String line = lineMatcher.group(0)\n        String patchedSourceFile = sourceFile.replace(line, line + '<line nr=\"123\" mi=\"0\" ci=\"1\" mb=\"0\" cb=\"0\"/>')\n        reportFile.setText(report.substring(0, startIndex) + patchedSourceFile + report.substring(endIndex), \"UTF-8\")\n    }\n}\n\ndependencies {\n    testImplementation \"ant:ant:$libraryVersion\"\n    testRuntimeOnly files(sunMiscBase64EncoderClassesDirectory).builtBy(compileSunMiscBase64Encoder)\n    testRuntimeOnly \"ant:ant-launcher:$libraryVersion\"\n    testRuntimeOnly \"ant:ant-nodeps:$libraryVersion\"\n    testRuntimeOnly \"ant:ant-trax:$libraryVersion\"\n    testRuntimeOnly \"ant:ant-xalan1:$libraryVersion\"\n    testRuntimeOnly \"ant:ant-xslp:$libraryVersion\"\n    testImplementation 'org.assertj:assertj-core:3.22.0'\n    testImplementation 'xml-resolver:xml-resolver:1.2'\n}\n\ngraalvmNative {\n    binaries {\n        test {\n            buildArgs.add('--initialize-at-run-time=org.apache.tools.ant.taskdefs.Execute')\n            buildArgs.add('--initialize-at-run-time=org.apache.tools.ant.taskdefs.Parallel')\n            buildArgs.add('--initialize-at-run-time=org.apache.tools.ant.taskdefs.