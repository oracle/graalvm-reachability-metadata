           */
          public String getDefault() {
              return defaultValue;
          }
  
          /**
           * equality method
           *
           * @param obj an <code>Object</code> value
           * @return a <code>boolean</code> value
           */
          public boolean equals(Object obj) {
              if (obj == null) {
                  return false;
              }
              if (obj.getClass() != getClass()) {
                  return false;
              }
              Attribute other = (Attribute) obj;
              if (name == null) {
