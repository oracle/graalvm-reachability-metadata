          MyAntTypeDefinition def = new MyAntTypeDefinition(this);
          def.setName(name);
          def.setClass(MacroInstance.class);
  
          ComponentHelper helper = ComponentHelper.getComponentHelper(
              getProject());
  
          helper.addDataTypeDefinition(def);
      }
  
  
