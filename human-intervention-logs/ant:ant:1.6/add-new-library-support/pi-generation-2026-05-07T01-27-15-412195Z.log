  package ant.ant;
  
  import java.util.ArrayList;
  import java.util.List;
  
  import org.apache.tools.ant.AntTypeDefinition;
  import org.apache.tools.ant.Project;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class AntTypeDefinitionTest {
  
      @Test
      void createLoadsClassByNameAndInvokesNoArgumentConstructor() {
          Project project = new Project();
          AntTypeDefinition definition = new AntTypeDefinition();
          definition.setName("noarg-type");
          definition.setClassName(NoArgumentType.class.getName());
  
          Object created = definition.create(project);
  
          assertThat(created).isInstanceOf(NoArgumentType.class);
          NoArgumentType typed = (NoArgumentType) created;
          assertThat(typed.constructorUsed).isEqualTo("noarg");
          assertThat(typed.project).isSameAs(project);
          assertThat(definition.getTypeClass(project)).isSameAs(NoArgumentType.class);
      }
  
      @Test
      void createLoadsClassThroughConfiguredLoaderAndInvokesProjectConstructor() {
          Project project = new Project();
          TrackingClassLoader loader = new TrackingClassLoader(getClass().getClassLoader());
          AntTypeDefinition definition = new AntTypeDefinition();
          definition.setName("project-type");
          definition.setClassName(ProjectConstructorType.class.getName());
          definition.setClassLoader(loader);
  
          Object created = definition.create(project);
  
          assertThat(created).isInstanceOf(ProjectConstructorType.class);
          ProjectConstructorType typed = (ProjectConstructorType) created;
          assertThat(typed.constructorProject).isSameAs(project);
          assertThat(typed.referenceProject).isSameAs(project);
          assertThat(loader.loadedClassNames).contains(ProjectConstructorType.class.getName());
          assertThat(definition.getTypeClass(project)).isSameAs(ProjectConstructorType.class);
      }
  
      public static final class NoArgumentType {
          private final String constructorUsed;
          private Project project;
  
          public NoArgumentType() {
              constructorUsed = "noarg";
          }
  
          public void setProject(Project project) {
              this.project = project;
          }
      }
  
      public static final class ProjectConstructorType {
          private final Project constructorProject;
          private Project referenceProject;
  
          public ProjectConstructorType(Project project) {
              constructorProject = project;
          }
  
          public void setProject(Project project) {
              referenceProject = project;
          }
      }
  
      public static final class TrackingClassLoader extends ClassLoader {
          private final List<String> loadedClassNames = new ArrayList<>();
  
          TrackingClassLoader(ClassLoader parent) {
              super(parent);
          }
  
          @Override
          public Class<?> loadClass(String name) throws ClassNotFoundException {
              loadedClassNames.add(name);
              return super.loadClass(name);
          }
      }
  }
