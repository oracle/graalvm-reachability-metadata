  package ant.ant;
  
  import java.lang.invoke.MethodHandles;
  import java.lang.invoke.VarHandle;
  
  import org.apache.tools.ant.Project;
  import org.apache.tools.ant.TaskAdapter;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class TaskAdapterTest {
      private static final String PROJECT_CLASS_CACHE_FIELD = "class$org$apache$tools$ant$Project";
  
      @Test
      void validatesAndExecutesProxyTaskThroughTaskAdapter() {
          Project project = new Project();
          ProxyTask proxy = new ProxyTask();
  
          checkAdaptableTaskClass(project);
          resetCachedProjectClass();
  
          TaskAdapter adapter = new TaskAdapter();
          adapter.setProject(project);
          adapter.setProxy(proxy);
          adapter.execute();
  
          assertThat(proxy.project).isSameAs(project);
          assertThat(proxy.executed).isTrue();
          assertThat(adapter.getProxy()).isSameAs(proxy);
      }
  
      private static void checkAdaptableTaskClass(Project project) {
          try {
              TaskAdapter.checkTaskClass(ProxyTask.class, project);
          } catch (NullPointerException exception) {
              // Ant 1.6 passes a null parameter array to Class#getMethod from pre-varargs bytecode.
              assertThat(exception).isInstanceOf(NullPointerException.class);
          }
      }
  
      private static void resetCachedProjectClass() {
          try {
              MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(TaskAdapter.class, MethodHandles.lookup());
              VarHandle projectClassCache = lookup.findStaticVarHandle(
                      TaskAdapter.class,
                      PROJECT_CLASS_CACHE_FIELD,
                      Class.class
              );
              projectClassCache.set((Class<?>) null);
          } catch (IllegalAccessException | NoSuchFieldException exception) {
              throw new AssertionError("Unable to reset TaskAdapter's legacy Project class cache", exception);
          }
      }
  
      public static final class ProxyTask {
          private Project project;
          private boolean executed;
  
          public void setProject(Project project) {
              this.project = project;
          }
  
          public void execute() {
              executed = true;
          }
      }
  }
