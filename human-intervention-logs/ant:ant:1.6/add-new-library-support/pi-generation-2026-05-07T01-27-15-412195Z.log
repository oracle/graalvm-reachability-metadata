      private URL fileToURL() {
          if (!(file.exists())) {
              log("File " + file + " does not exist", Project.MSG_WARN);
              return null;
          }
          if (!(file.isFile())) {
              log("File " + file + " is not a file", Project.MSG_WARN);
              return null;
          }
          try {
