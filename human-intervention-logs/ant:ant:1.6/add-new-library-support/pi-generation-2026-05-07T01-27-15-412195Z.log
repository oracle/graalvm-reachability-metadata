       */
      public Hashtable getDataTypeDefinitions() {
          synchronized (typeClassDefinitions) {
              synchronized (antTypeTable) {
                  if (rebuildTypeClassDefinitions) {
                      typeClassDefinitions.clear();
                      for (Iterator i = antTypeTable.keySet().iterator();
