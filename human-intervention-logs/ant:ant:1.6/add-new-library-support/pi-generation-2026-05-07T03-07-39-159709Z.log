[tool-call] delta {"path":"tests/src/ant/ant/1.6/src/test/java/ant/ant/ParallelTest.java","edits":[{"oldText":"package ant.ant;\n\nimport java.util.concurrent.atomic.AtomicInteger;\n","newText":"package ant.ant;\n\nimport java.lang.invoke.MethodHandles;\nimport java.lang.invoke.VarHandle;\nimport java.util.concurrent.atomic.AtomicInteger;\n"},{"oldText":"    @Test\n    void executeUsesRuntimeProcessorCountWhenThreadsPerProcessorIsConfigured() {\n        Project project = new Project();\n        project.init();\n        AtomicInteger executions = new AtomicInteger();\n\n        Parallel parallel = new Parallel();\n        parallel.setProject(project);\n        parallel.setThreadsPerProcessor(1);\n        parallel.addTask(new CountingTask(project, executions));\n\n        parallel.execute();\n\n        assertThat(executions).hasValue(1);\n    }\n","newText":"    @Test\n    void executeUsesRuntimeProcessorCountWhenThreadsPerProcessorIsConfigured() throws Throwable {\n        Project project = new Project();\n        project.init();\n        AtomicInteger executions = new AtomicInteger();\n\n        Parallel parallel = new Parallel();\n        parallel.setProject(project);\n        parallel.setThreadsPerProcessor(1);\n        parallel.addTask(new CountingTask(project, executions));\n        MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(Parallel.class, MethodHandles.lookup());\n        VarHandle runtimeClass = lookup.findStaticVarHandle(\n            Parallel.class,\n            \"class$java$lang$Runtime\",\n            Class.class);\n        Object previousRuntimeClass = runtimeClass.get();\n        try {\n            runtimeClass.set(null);\n\n            parallel.execute();\n\n            assertThat(executions).hasValue(1);\n            assertThat(runtimeClass.get()).isSameAs(Runtime.class);\n        } finally {\n            runtimeClass.set(previousRuntimeClass);\n        }\n    }\n"}]}
