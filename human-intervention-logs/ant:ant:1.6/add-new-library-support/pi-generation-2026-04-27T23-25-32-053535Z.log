          this.bean = bean;
  
          Method[] methods = bean.getMethods();
          for (int i = 0; i < methods.length; i++) {
              final Method m = methods[i];
              final String name = m.getName();
              Class returnType = m.getReturnType();
              Class[] args = m.getParameterTypes();
  
