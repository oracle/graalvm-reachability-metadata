  package ant.ant;
  
  import java.io.File;
  import java.io.IOException;
  import java.io.InputStream;
  import java.nio.file.Path;
  
  import org.apache.tools.ant.loader.AntClassLoader2;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  import org.junit.jupiter.api.io.TempDir;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class AntClassLoader2Test {
      private static final String FIXTURE_CLASS_NAME = "ant.ant.AntClassLoader2Fixture";
  
      @TempDir
      Path temporaryDirectory;
  
      @Test
      void definesClassFromBytecodeUsingAntProtectionDomain() throws Exception {
          ExposedAntClassLoader2 loader = new ExposedAntClassLoader2();
          byte[] classData = readClassData(FIXTURE_CLASS_NAME);
  
          try {
              Class<?> definedClass = loader.defineClassFromBytes(
                      temporaryDirectory.toFile(), classData, FIXTURE_CLASS_NAME);
  
              assertThat(definedClass.getName()).isEqualTo(FIXTURE_CLASS_NAME);
              assertThat(definedClass.getClassLoader()).isSameAs(loader);
              assertThat(definedClass.getPackage().getName()).isEqualTo("ant.ant");
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
      }
  
      private static byte[] readClassData(String className) throws IOException {
          String resourceName = className.replace('.', '/') + ".class";
          try (InputStream inputStream = AntClassLoader2Test.class.getClassLoader()
                  .getResourceAsStream(resourceName)) {
              assertThat(inputStream).isNotNull();
              return inputStream.readAllBytes();
          }
      }
  }
  
  class ExposedAntClassLoader2 extends AntClassLoader2 {
      Class<?> defineClassFromBytes(File container, byte[] classData, String className)
              throws IOException {
          return defineClassFromData(container, classData, className);
      }
  }
  
  class AntClassLoader2Fixture {
