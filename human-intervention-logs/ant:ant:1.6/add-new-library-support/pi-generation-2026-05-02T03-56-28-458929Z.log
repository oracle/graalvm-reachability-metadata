el": "gpt-5.5", "usage": {"input": 2678, "output": 1354, "cacheRead": 43520, "cacheWrite": 0, "totalTokens": 47552, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777694607923, "responseId": "resp_0be572b0bcda8af70169f57790860c8193a69124c5ce9a1226"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_oSUXDNh8LhUa20tpVYiY28Uo|fc_0be572b0bcda8af70169f577a5bf9c81939fcb128a1e415842", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage ant.ant;\n\nimport java.io.File;\nimport java.io.IOException;\n\nimport org.apache.tools.ant.taskdefs.Execute;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ProcessDestroyerTest {\n    @Test\n    void executeRegistersAndUnregistersShutdownHookAroundProcess() throws IOException {\n        Execute execute = new Execute();\n        execute.setCommandline(new String[] {javaExecutable(), \"-version\"});\n\n        int exitCode = execute.execute();\n\n        assertThat(exitCode).isZero();\n        assertThat(execute.getExitValue()).isZero();\n        assertThat(Execute.isFailure(exitCode)).isFalse();\n    }\n\n    private static String javaExecutable() {\n        String executableName = isWindows() ? \"java.exe\" : \"java\";\n        String javaHome = System.getProperty(\"java.home\");\n        if (javaHome != null) {\n            File executable = new File(new File(javaHome, \"bin\"), executableName);\n            if (executable.isFile()) {\n                return executable.getAbsolutePath();\n            }\n        }\n        return executableName;\n    }\n\n    private static boolean isWindows() {\n        return System.getProperty(\"os.name\", \"\").toLowerCase().contains(\"win\");\n    }\n}\n"}], "isError": false, "timestamp": 1777694630060}]}
