      public static synchronized IntrospectionHelper getHelper(Class c) {
          IntrospectionHelper ih = (IntrospectionHelper) helpers.get(c);
          if (ih == null) {
              ih = new IntrospectionHelper(c);
              helpers.put(c, ih);
          }
          return ih;
