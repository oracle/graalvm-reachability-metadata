          private ModeAttribute mode;
  
          public void setMode(ModeAttribute value) {
              this.mode = value;
          }
      }
  
      public static final class ModeAttribute extends EnumeratedAttribute {
          public ModeAttribute() {
          }
  
          @Override
          public String[] getValues() {
              return new String[] {"lenient", "strict"};
          }
      }
  }
