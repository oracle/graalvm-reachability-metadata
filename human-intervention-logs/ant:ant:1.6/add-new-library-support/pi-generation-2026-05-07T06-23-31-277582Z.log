[tool-call] delta {"path":"tests/src/ant/ant/1.6/src/test/java/ant/ant/IntrospectionHelperAnonymous11Test.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage ant.ant;\n\nimport org.apache.tools.ant.IntrospectionHelper;\nimport org.apache.tools.ant.types.EnumeratedAttribute;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class IntrospectionHelperAnonymous11Test {\n\n    @Test\n    void setsEnumeratedAttribute() {\n        EnumeratedAttributeTarget target = new EnumeratedAttributeTarget();\n        IntrospectionHelper helper = IntrospectionHelper.getHelper(EnumeratedAttributeTarget.class);\n\n        helper.setAttribute(null, target, \"mode\", \"strict\");\n\n        assertThat(target.mode).isInstanceOf(ModeAttribute.class);\n        assertThat(target.mode.getValue()).isEqualTo(\"strict\");\n        assertThat(target.mode.getIndex()).isEqualTo(1);\n    }\n\n    public static final class EnumeratedAttributeTarget {\n        private ModeAttribute mode;\n\n        public void setMode(ModeAttribute value) {\n            this.mode = value;\n        }\n    }\n\n    public static final class ModeAttribute extends EnumeratedAttribute {\n        public ModeAttribute() {\n        }\n\n        @Override\n        public String[] getValues() {\n            return new String[] {\"lenient\", \"strict\"};\n        }\n    }\n}\n"}
