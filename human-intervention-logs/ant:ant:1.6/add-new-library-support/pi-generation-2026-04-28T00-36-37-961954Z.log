        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 709, "output": 1439, "cacheRead": 36864, "cacheWrite": 0, "totalTokens": 39012, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777336507701, "responseId": "resp_08a263fa8f9c1ac20169f000bc3164819c8627b2b21a5b0959"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_ELyIcU9i6t0F5WtzqBzPgHvO|fc_08a263fa8f9c1ac20169f000bdd634819cad5af79aa1520bdd", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 6284 bytes to tests/src/ant/ant/1.6/src/test/java/ant/ant/EmailTaskTest.java"}], "isError": false, "timestamp": 1777336517806}]}
