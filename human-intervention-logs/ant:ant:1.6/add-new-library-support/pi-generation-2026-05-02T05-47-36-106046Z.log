      @Test
      void forceLoadsClassFromConfiguredPath() throws Exception {
          Path classesDirectory = copyFixtureClassToTemporaryClasspath();
          AntClassLoader loader = new AntClassLoader(
                  AntClassLoaderTest.class.getClassLoader(),
