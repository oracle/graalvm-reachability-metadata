  package ant.ant;
  
  import org.apache.tools.ant.IntrospectionHelper;
  import org.apache.tools.ant.Project;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class IntrospectionHelperTest {
  
      @Test
      void introspectsAttributesTextAndNestedElements() {
          Project project = null;
          IntrospectionTarget target = new IntrospectionTarget();
  
          IntrospectionHelper helper = IntrospectionHelper.getHelper(IntrospectionTarget.class);
  
          assertThat(helper.supportsCharacters()).isTrue();
          helper.addText(project, target, "body text");
          assertThat(target.text).isEqualTo("body text");
  
          helper.setAttribute(project, target, "custom", "attribute value");
          assertThat(target.custom.value).isEqualTo("attribute value");
  
          Object noArgConfigured = helper.createElement(project, target, "noargconfigured");
          assertThat(noArgConfigured).isInstanceOf(NoArgNested.class);
          helper.storeElement(project, target, noArgConfigured, "noargconfigured");
          assertThat(target.noArgConfigured).isSameAs(noArgConfigured);
  
          Object projectConfigured = helper.createElement(project, target, "projectconfigured");
          assertThat(projectConfigured).isInstanceOf(ProjectNested.class);
          assertThat(((ProjectNested) projectConfigured).project).isNull();
          helper.storeElement(project, target, projectConfigured, "projectconfigured");
          assertThat(target.projectConfigured).isSameAs(projectConfigured);
  
          Object noArgAdded = helper.createElement(project, target, "noarg");
          assertThat(noArgAdded).isInstanceOf(NoArgNested.class);
          assertThat(target.noArgAdded).isSameAs(noArgAdded);
  
          Object projectAdded = helper.createElement(project, target, "project");
          assertThat(projectAdded).isInstanceOf(ProjectNested.class);
          assertThat(((ProjectNested) projectAdded).project).isNull();
          assertThat(target.projectAdded).isSameAs(projectAdded);
      }
  
      public static final class IntrospectionTarget {
          private String text;
          private CustomAttribute custom;
          private NoArgNested noArgConfigured;
          private ProjectNested projectConfigured;
          private NoArgNested noArgAdded;
          private ProjectNested projectAdded;
  
          public void addText(String value) {
              this.text = value;
          }
  
          public void setCustom(CustomAttribute value) {
              this.custom = value;
          }
  
          public void addConfiguredNoArgConfigured(NoArgNested value) {
              this.noArgConfigured = value;
          }
  
          public void addConfiguredProjectConfigured(ProjectNested value) {
              this.projectConfigured = value;
          }
  
          public void addNoArg(NoArgNested value) {
              this.noArgAdded = value;
          }
  
          public void addProject(ProjectNested value) {
              this.projectAdded = value;
          }
      }
  
      public static final class CustomAttribute {
          private final String value;
  
          public CustomAttribute(String value) {
              this.value = value;
          }
      }
  
      public static final class NoArgNested {
      }
  
      public static final class ProjectNested {
          private final Project project;
  
          public ProjectNested(Project project) {
              this.project = project;
          }
      }
  }
