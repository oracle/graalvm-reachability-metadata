dLogger.error).isNotNull();\n        assertThat(CustomBuildLogger.emacsMode).isTrue();\n        assertThat(CustomBuildListener.instances).hasValue(1);\n        assertThat(CustomBuildListener.project).isSameAs(project);\n        assertThat(project.getBuildListeners())\n            .hasAtLeastOneElementOfType(CustomBuildLogger.class)\n            .hasAtLeastOneElementOfType(CustomBuildListener.class);\n    }\n\n    @Test\n    void startAntLoadsConfiguredInputHandlerClassByNameBeforeRunningBuild() throws IOException, InterruptedException {\n        Path buildFile = createBuildFile();\n        CustomInputHandler.reset();\n        Thread antThread = new Thread(\n            () -> new Main().startAnt(new String[] {\n                \"-buildfile\", buildFile.toString(),\n                \"-inputhandler\", CustomInputHandler.class.getName()\n            }, null, null),\n            \"ant-main-input-handler\");\n        antThread.setDaemon(true);\n\n        antThread.start();\n\n        assertThat(CustomInputHandler.projectReferenceSet.await(10, TimeUnit.SECONDS)).isTrue();\n        assertThat(CustomInputHandler.instances).hasValue(1);\n        assertThat(CustomInputHandler.project).isNotNull();\n    }\n\n    @Test\n    void getAntVersionLoadsVersionResourceThroughMainClassLiteralCompatibilityPath() {\n        String antVersion = Main.getAntVersion();\n\n        assertThat(antVersion).startsWith(\"Apache Ant version \");\n        assertThat(antVersion).contains(\" compiled on \");\n    }\n\n    @Test\n    void getAntVersionInitializesLegacyClassLiteralCacheByName() throws Throwable {\n        MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(Main.class, MethodHandles.lookup());\n        VarHandle antVersion = lookup.findStaticVarHandle(Main.class, \"antVersion\", String.class);\n        VarHandle mainClass = lookup.findStaticVarHandle(\n            Main.class,\n            \"class$org$apache$tools$ant$Main\",\n            Class.class);\n        Object previousAntVersion = antVersion.get();\n        Object previousMainClass = mainClass.get();\n        try {\n            antVersion.set(null);\n            mainClass.set(null);\n\n            String version = Main.getAntVersion();\n\n            assertThat(version).startsWith(\"Apache Ant version \");\n            assertThat(mainClass.get()).isSameAs(Main.class);\n        } finally {\n            antVersion.set(previousAntVersion);\n            mainClass.set(previousMainClass);\n        }\n    }\n\n    private static Path createBuildFile() throws IOException {\n        Path directory = Files.createTempDirectory(\"ant-main\");\n        Path buildFile = directory.resolve(\"build.xml\");\n        Files.writeString(buildFile, \"\"\"\n            <project name=\"main-test\" default=\"ok\">\n                <target name=\"ok\"/>\n            </project>\n            \"\"\", StandardCharsets.UTF_8);\n        buildFile.toFile().deleteOnExit();\n        directory.toFile().deleteOnExit();\n        return buildFile;\n    }\n\n    private static final class ConfiguredMain extends Main {\n        ConfiguredMain(String... args) throws BuildException {\n            super(args);\n        }\n\n        void addListenersTo(Project project) {\n            addBuildListeners(project);\n        }\n    }\n\n    public static final class CustomBuildLogger implements BuildLogger {\n        private static final AtomicInteger instances = new AtomicInteger();\n        private static int messageOutputLevel;\n        private static PrintStream output;\n        private static PrintStream error;\n        private static boolean emacsMode;\n\n        public CustomBuildLogger() {\n            instances.incrementAndGet();\n        }\n\n        static void reset() {\n            instances.set(0);\n            messageOutputLevel = -1;\n            output = null;\n            error = null;\n            emacsMode = false;\n        }\n\n        @Override\n        public void setMessageOutputLevel(int level) {\n           