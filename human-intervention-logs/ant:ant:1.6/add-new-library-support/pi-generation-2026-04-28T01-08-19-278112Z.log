ache.tools.ant.Project;\nimport org.apache.tools.ant.types.XMLCatalog;\nimport org.apache.tools.ant.types.resolver.ApacheCatalogResolver;\nimport org.junit.jupiter.api.Test;\nimport org.junit.jupiter.api.io.TempDir;\nimport org.xml.sax.InputSource;\n\npublic class ApacheCatalogResolverTest {\n    private static final String PUBLIC_ID = \"-//Example//DTD Apache Resolver//EN\";\n    private static final String URI_ID = \"urn:example:apache-resolver-document\";\n\n    @Test\n    void parsesExternalCatalogEntriesIntoXmlCatalog(@TempDir Path temporaryDirectory) throws Exception {\n        Path dtdFile = temporaryDirectory.resolve(\"apache-resolver.dtd\");\n        Path xmlFile = temporaryDirectory.resolve(\"apache-resolver.xml\");\n        Path catalogFile = temporaryDirectory.resolve(\"catalog.cat\");\n        Files.write(dtdFile, \"<!ELEMENT example EMPTY>\".getBytes(StandardCharsets.UTF_8));\n        Files.write(xmlFile, \"<example/>\".getBytes(StandardCharsets.UTF_8));\n        Files.write(catalogFile, catalog(dtdFile, xmlFile).getBytes(StandardCharsets.UTF_8));\n\n        XMLCatalog catalog = newCatalog(temporaryDirectory);\n        ApacheCatalogResolver resolver = new ApacheCatalogResolver();\n        resolver.setXMLCatalog(catalog);\n\n        resolver.parseCatalog(catalogFile.toString());\n\n        InputSource entity = catalog.resolveEntity(PUBLIC_ID, \"urn:example:missing-dtd\");\n        Source source = catalog.resolve(URI_ID, null);\n\n        assertThat(entity).isNotNull();\n        assertThat(entity.getSystemId()).endsWith(\"apache-resolver.dtd\");\n        try (InputStream byteStream = entity.getByteStream()) {\n            assertThat(new String(byteStream.readAllBytes(), StandardCharsets.UTF_8)).contains(\"example\");\n        }\n        assertThat(source).isInstanceOf(SAXSource.class);\n        InputSource inputSource = ((SAXSource) source).getInputSource();\n        assertThat(inputSource.getSystemId()).endsWith(\"apache-resolver.xml\");\n    }\n\n    private static XMLCatalog newCatalog(Path baseDirectory) {\n        Project project = new Project();\n        project.setBaseDir(baseDirectory.toFile());\n\n        XMLCatalog catalog = new XMLCatalog();\n        catalog.setProject(project);\n        return catalog;\n    }\n\n    private static String catalog(Path dtdFile, Path xmlFile) {\n        return \"PUBLIC \\\"\" + PUBLIC_ID + \"\\\" \\\"\" + dtdFile.getFileName() + \"\\\"\\n\"\n                + \"URI \\\"\" + URI_ID + \"\\\" \\\"\" + xmlFile.getFileName() + \"\\\"\\n\";\n    }\n}\n"}], "isError": false, "timestamp": 1777338570118}, {"role": "toolResult", "toolCallId": "call_k0cgRdrv8GoiHD8ov4n3dMvY|fc_0db78ac3875b81430169f008c87acc819e9b213a9614ab2389", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\nplugins {\n    id \"org.graalvm.internal.tck\"\n}\n\nString libraryVersion = tck.testedLibraryVersion.get()\n// Ant 1.6 probes the removed JDK encoder before falling back to its internal Base64 implementation.\nProvider<Directory> generatedSunMiscBase64EncoderSourceDirectory = layout.buildDirectory\n    .dir(\"generated/sources/sunMiscBase64Encoder/java\")\nProvider<Directory> sunMiscBase64EncoderClassesDirectory = layout.buildDirectory\n    .dir(\"classes/java/sunMiscBase64Encoder\")\nProvider<String> sunMiscBase64EncoderPatchModuleArgument = sunMiscBase64EncoderClassesDirectory\n    .map { \"jdk.unsupported=${it.asFile.absolutePath}\" }\n\nTaskProvider<Task> generateSunMiscBase64Encoder = tasks.register(\"generateSunMiscBase64Encoder\") {\n    outputs.dir(generatedSunMiscBase64EncoderSourceDirectory)\n\n    doLast {\n        Directory sourceDirectory = generatedSunMiscBase64EncoderSourceDirectory.get()\n        File base64EncoderSourceFile = sourceDirectory.file(\"sun/misc/BASE64Encoder.java\").asFile\n        base64EncoderSourceFile.parentFile.mkdirs()\n        base64EncoderSourceFile.text = \"\"\"\n            package sun.misc;\n\n            public class BASE64Encoder {\n                public String encode(byte[] bytes) {\n                    return \"generated-encoder\";\n                }\n            }\n            \"\"\".stripIndent()\n\n        File characterEncoderSourceFile = sourceDirectory.file(\"sun/misc/CharacterEncoder.java\").asFile\n        characterEncoderSourceFile.text = \"\"\"\n            package sun.misc;\n\n            import java.io.IOException;\n            import java.io.InputStream;\n            import java.io.OutputStream;\n\n            public class CharacterEncoder {\n                public void encode(InputStream inputStream, OutputStream outputStream) throws IOException {\n                    int value;\n                    while ((value = inputStream.read()) != -1) {\n                        outputStream.write(value);\n                    }\n                }\n            }\n            \"\"\".stripIndent()\n\n        File uuEncoderSourceFile = sourceDirectory.file(\"sun/misc/UUEncoder.java\").asFile\n        uuEncoderSourceFile.text = \"\"\"\n            package sun.misc;\n\n            public class UUEncoder extends CharacterEncoder {\n                public UUEncoder(String name) {\n                }\n            }\n            \"\"\".stripIndent()\n    }\n}\n\nTaskProvider<JavaCompile> compileSunMiscBase64Encoder = tasks.register(\"compileSunMiscBase64Encoder\", JavaCompile) {\n    dependsOn(generateSunMiscBase64Encoder)\n    source(generatedSunMiscBase64EncoderSourceDirectory)\n    destinationDirectory = sunMiscBase64EncoderClassesDirectory\n    classpath = files()\n    options.release = 8\n}\n\nsourceSets {\n    test {\n        output.dir(sunMiscBase64EncoderClassesDirectory, builtBy: compileSunMiscBase64Encoder)\n    }\n}\n\ntasks.withType(Test).configureEach {\n    dependsOn(compileSunMiscBase64Encoder)\n    doFirst {\n        jvmArgs \"--patch-module\", sunMiscBase64EncoderPatchModuleArgument.get()\n    }\n}\n\ntasks.matching { it.name == \"nativeTestCompile\" }.configureEach {\n    dependsOn(compileSunMiscBase64Encoder)\n}\n\ndependencies {\n    testImplementation \"ant:ant:$libraryVersion\"\n    testRuntimeOnly files(sunMiscBase64EncoderClassesDirectory).builtBy(compileSunMiscBase64Encoder)\n    testRuntimeOnly \"ant:ant-launcher:$libraryVersion\"\n    testRuntimeOnly \"ant:ant-nodeps:$libraryVersion\"\n    testRuntimeOnly \"ant:ant-trax:$libraryVersion\"\n    testRuntimeOnly \"ant:ant-xalan1:$libraryVersion\"\n    testRuntimeOnly \"ant:ant-xslp:$libraryVersion\"\n    testImplementation 'org.assertj:assertj-core:3.22.0'\n    testImplementation 'xml-resolver:xml-resolver:1.2'\n}\n\ngraalvmNative {\n    binaries {\n        test {\n            buildArgs.add('--initialize-at-run-time=org.apache.tools.ant.taskdefs.Execute')\n            buildArgs.add('--initialize-at-run-time=org.apache.tools.ant.taskdefs.Parallel')\n            buildArgs.add('--initialize-at-run-time=org.apache.tools.ant.taskdefs.compilers.Kjc')\n            buildArgs.add('--initialize-at-run-time=org.apache.tools.ant.taskdefs.rmic.SunRmic')\n            buildArgs.add('--initialize-at-run-time=org.apache.tools.ant.taskdefs.rmic.WLRmic')\n            buildArgs.add(\"-J--patch-module=${sunMiscBase64EncoderPatchModuleArgument.get()}\")\n        }\n    }\n\n    agent {\n        defaultMode = \"conditional\"\n        modes {\n            conditional {\n                userCodeFilterPath = \"user-code-filter.json\"\n            }\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777338570118}, {"role": "toolResult", "toolCallId": "call_Nl3LRtWMpNixD68FsxJCu2Fb|fc_0db78ac3875b81430169f008c87ad4819e86ee80f49ff3b019", "toolName": "bash", "content": [{"type": "text", "text": "9e2eb3f4ba (HEAD -> ai/add-lib-support-ant-ant-1.6) Add ApacheCatalogResolver coverage test\nc5f6efd7a7 Add XMLCatalog reference coverage test\n5b50ba4f65 Add Ant FilterSet reference coverage test\n"}], "isError": false, "timestamp": 1777338570146}]}
