                                           + "\" does not exist!", getLocation());
              }
  
              DirectoryScanner ds = this.getDirectoryScanner(srcDir);
              String[] files = ds.getIncludedFiles();
  
              scanDir(srcDir, destDir != null ? destDir : srcDir, files);
          }
  
          compile();
      }
  
