              cmd.createArgument().setValue("-nowarn");
          }
  
          if (deprecation == true) {
              cmd.createArgument().setValue("-deprecation");
          }
  
          if (destDir != null) {
              cmd.createArgument().setValue("-d");
              cmd.createArgument().setFile(destDir);
