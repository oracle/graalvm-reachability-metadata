[tool-call] delta {"path":"tests/src/ant/ant/1.6/src/test/java/ant/ant/MainTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage ant.ant;\n\nimport static org.assertj.core.api.Assertions.assertThat;\nimport static org.assertj.core.api.Assertions.catchThrowable;\n\nimport java.nio.charset.StandardCharsets;\nimport java.nio.file.Files;\nimport java.nio.file.Path;\nimport java.security.Permission;\nimport org.apache.tools.ant.DefaultLogger;\nimport org.apache.tools.ant.Main;\nimport org.apache.tools.ant.input.DefaultInputHandler;\nimport org.junit.jupiter.api.Test;\nimport org.junit.jupiter.api.io.TempDir;\n\npublic class MainTest {\n    @Test\n    void startAntLoadsConfiguredLoggerListenerAndInputHandler(@TempDir Path temporaryDirectory) throws Exception {\n        Path buildFile = temporaryDirectory.resolve(\"build.xml\");\n        Files.write(buildFile, minimalProject().getBytes(StandardCharsets.UTF_8));\n\n        assertThat(Main.getAntVersion())\n                .startsWith(\"Apache Ant version \")\n                .contains(\" compiled on \");\n\n        ExitTrappingSecurityManager exitTrappingSecurityManager = new ExitTrappingSecurityManager();\n        SecurityManager previousSecurityManager = System.getSecurityManager();\n        System.setSecurityManager(exitTrappingSecurityManager);\n        try {\n            Throwable thrown = catchThrowable(() -> new Main().startAnt(new String[] {\n                    \"-logger\", DefaultLogger.class.getName(),\n                    \"-listener\", MainBuildListener.class.getName(),\n                    \"-inputhandler\", DefaultInputHandler.class.getName(),\n                    \"-projecthelp\",\n                    \"-buildfile\", buildFile.toString()\n            }, null, null));\n\n            assertThat(thrown).isInstanceOf(ExitException.class);\n            assertThat(((ExitException) thrown).getStatus()).isZero();\n        } finally {\n            System.setSecurityManager(previousSecurityManager);\n        }\n    }\n\n    private static String minimalProject() {\n        return String.join(System.lineSeparator(),\n                \"<project name=\\\"main-test\\\" default=\\\"verify\\\" description=\\\"Main startup test\\\">\",\n                \"    <target name=\\\"verify\\\" description=\\\"Verifies startup\\\"/>\",\n                \"</project>\");\n    }\n\n    private static final class ExitTrappingSecurityManager extends SecurityManager {\n        @Override\n        public void checkPermission(Permission permission) {\n        }\n\n        @Override\n        public void checkPermission(Permission permission, Object context) {\n        }\n\n        @Override\n        public void checkExit(int status) {\n            throw new ExitException(status);\n        }\n    }\n\n    private static final class ExitException extends SecurityException {\n        private final int status;\n\n        private ExitException(int status) {\n            this.status = status;\n        }\n\n        private int getStatus() {\n            return status;\n        }\n    }\n}\n"}
