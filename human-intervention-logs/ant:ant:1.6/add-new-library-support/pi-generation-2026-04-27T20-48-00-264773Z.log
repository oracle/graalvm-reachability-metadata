icsTest.java", "limit": 220}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 195, "output": 1327, "cacheRead": 20480, "cacheWrite": 0, "totalTokens": 22002, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777322756163, "responseId": "resp_0b6eeac6b52172910169efcb04a0788193a9bd72aff7ec0b54"}}
