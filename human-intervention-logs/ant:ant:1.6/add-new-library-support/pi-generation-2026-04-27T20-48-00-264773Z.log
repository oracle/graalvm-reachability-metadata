[tool-call] delta {"path":"tests/src/ant/ant/1.6/src/test/java/ant/ant/MainTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage ant.ant;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.nio.charset.StandardCharsets;\nimport java.nio.file.Files;\nimport java.nio.file.Path;\nimport org.apache.tools.ant.AntClassLoader;\nimport org.apache.tools.ant.DefaultLogger;\nimport org.apache.tools.ant.Main;\nimport org.apache.tools.ant.Project;\nimport org.junit.jupiter.api.Test;\nimport org.junit.jupiter.api.io.TempDir;\n\npublic class MainTest {\n    @Test\n    void commandLineConfigurationLoadsLoggerAndListener(@TempDir Path temporaryDirectory) throws Exception {\n        Path buildFile = temporaryDirectory.resolve(\"build.xml\");\n        Files.write(buildFile, minimalProject().getBytes(StandardCharsets.UTF_8));\n\n        assertThat(Main.getAntVersion())\n                .startsWith(\"Apache Ant version \")\n                .contains(\" compiled on \");\n\n        ExposedMain main = new ExposedMain(new String[] {\n                \"-logger\", DefaultLogger.class.getName(),\n                \"-listener\", AntClassLoader.class.getName(),\n                \"-projecthelp\",\n                \"-buildfile\", buildFile.toString()\n        });\n        Project project = new Project();\n\n        main.addConfiguredBuildListeners(project);\n\n        assertThat(project.getBuildListeners())\n                .hasSize(2)\n                .anySatisfy(listener -> assertThat(listener).isInstanceOf(DefaultLogger.class))\n                .anySatisfy(listener -> assertThat(listener).isInstanceOf(AntClassLoader.class));\n    }\n\n    private static String minimalProject() {\n        return String.join(System.lineSeparator(),\n                \"<project name=\\\"main-test\\\" default=\\\"verify\\\" description=\\\"Main startup test\\\">\",\n                \"    <target name=\\\"verify\\\" description=\\\"Verifies startup\\\"/>\",\n                \"</project>\");\n    }\n\n    private static final class ExposedMain extends Main {\n        private ExposedMain(String[] arguments) {\n            super(arguments);\n        }\n\n        private void addConfiguredBuildListeners(Project project) {\n            addBuildListeners(project);\n        }\n    }\n}\n"}
