[tool-call] delta {"path":"tests/src/ant/ant/1.6/src/test/java/ant/ant/ExecuteTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage ant.ant;\n\nimport java.io.File;\nimport java.net.MalformedURLException;\nimport java.net.URL;\nimport java.net.URLClassLoader;\nimport java.util.ArrayList;\nimport java.util.List;\nimport java.util.StringTokenizer;\n\nimport org.apache.tools.ant.taskdefs.Execute;\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ExecuteTest {\n    @Test\n    void initializesLauncherClassLiteralCacheInFreshClassLoader() throws Exception {\n        try (URLClassLoader isolatedClassLoader = new URLClassLoader(\n                runtimeClasspathUrls(), ClassLoader.getPlatformClassLoader())) {\n            Class<?> targetClass = Class.forName(\n                    FreshExecuteInitializer.class.getName(), true, isolatedClassLoader);\n            Runnable target = (Runnable) targetClass.getDeclaredConstructor().newInstance();\n\n            target.run();\n        } catch (Error error) {\n            rethrowUnlessUnsupportedDynamicClassLoading(error);\n        }\n    }\n\n    private static URL[] runtimeClasspathUrls() throws MalformedURLException {\n        List<URL> urls = new ArrayList<>();\n        StringTokenizer tokenizer = new StringTokenizer(\n                System.getProperty(\"java.class.path\", \"\"), File.pathSeparator);\n        while (tokenizer.hasMoreTokens()) {\n            urls.add(new File(tokenizer.nextToken()).toURI().toURL());\n        }\n        assertThat(urls).isNotEmpty();\n        return urls.toArray(new URL[0]);\n    }\n\n    private static void rethrowUnlessUnsupportedDynamicClassLoading(Error error) {\n        if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n            throw error;\n        }\n    }\n\n    public static class FreshExecuteInitializer implements Runnable {\n        @Override\n        public void run() {\n            Execute execute = new Execute();\n\n            if (execute.getExitValue() != Execute.INVALID) {\n                throw new AssertionError(\"new Execute should not have run a process\");\n            }\n        }\n    }\n}\n"}
