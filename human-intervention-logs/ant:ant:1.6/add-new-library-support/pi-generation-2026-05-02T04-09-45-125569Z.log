  package ant.ant;
  
  import java.io.ByteArrayOutputStream;
  import java.io.File;
  import java.io.IOException;
  
  import org.apache.tools.ant.taskdefs.Execute;
  import org.apache.tools.ant.taskdefs.PumpStreamHandler;
  import org.junit.jupiter.api.Test;
  import org.junit.jupiter.api.io.TempDir;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ExecuteTest {
      @TempDir
      File temporaryDirectory;
  
      @Test
      void launchesCommandWithVmLauncherAndWorkingDirectory() throws IOException {
          ByteArrayOutputStream standardOutput = new ByteArrayOutputStream();
          ByteArrayOutputStream errorOutput = new ByteArrayOutputStream();
          Execute execute = new Execute(new PumpStreamHandler(standardOutput, errorOutput));
          execute.setCommandline(new String[] {javaExecutable(), "-version"});
          execute.setWorkingDirectory(temporaryDirectory);
  
          int exitCode = execute.execute();
  
          assertThat(exitCode).isZero();
          assertThat(execute.getExitValue()).isZero();
          assertThat(errorOutput.toString()).containsIgnoringCase("version");
      }
  
      private static String javaExecutable() {
          String executableName = isWindows() ? "java.exe" : "java";
          String javaHome = System.getProperty("java.home");
          if (javaHome != null) {
              File executable = new File(new File(javaHome, "bin"), executableName);
              if (executable.isFile()) {
                  return executable.getAbsolutePath();
              }
          }
          return executableName;
      }
  
      private static boolean isWindows() {
          return System.getProperty("os.name", "").toLowerCase().contains("win");
      }
  }
