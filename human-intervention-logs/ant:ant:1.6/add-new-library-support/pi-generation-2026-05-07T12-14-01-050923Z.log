  package ant.ant;
  
  import java.io.ByteArrayOutputStream;
  import java.io.File;
  import java.io.IOException;
  import java.net.URISyntaxException;
  import java.security.CodeSource;
  import java.util.Locale;
  
  import org.apache.tools.ant.AntClassLoader;
  import org.apache.tools.ant.taskdefs.Execute;
  import org.apache.tools.ant.taskdefs.PumpStreamHandler;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  import org.junit.jupiter.api.io.TempDir;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ExecuteTest {
      @TempDir
      File temporaryDirectory;
  
      @Test
      void initializingFreshExecuteClassRunsLegacyClassLiteralPath() throws Exception {
          AntClassLoader loader = new AntClassLoader(getClass().getClassLoader(), false);
          try {
              loader.addPathElement(antJar().getAbsolutePath());
              try {
                  Class<?> loadedClass = loader.forceLoadClass(Execute.class.getName());
  
                  assertThat(loadedClass.getClassLoader()).isSameAs(loader);
                  AntClassLoader.initializeClass(loadedClass);
              } catch (Error error) {
                  if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                      throw error;
                  }
              }
          } finally {
              loader.cleanup();
          }
      }
  
      @Test
      void launchesCommandInConfiguredWorkingDirectoryThroughVmLauncher() throws IOException {
          ByteArrayOutputStream output = new ByteArrayOutputStream();
          Execute execute = new Execute(new PumpStreamHandler(output));
          execute.setWorkingDirectory(temporaryDirectory);
          execute.setCommandline(workingDirectoryCommand());
  
          int exitCode = execute.execute();
  
          assertThat(exitCode).isZero();
          assertThat(Execute.toString(output).trim()).isEqualTo(temporaryDirectory.getAbsolutePath());
      }
  
      private static File antJar() throws URISyntaxException {
          CodeSource codeSource = Execute.class.getProtectionDomain().getCodeSource();
          assertThat(codeSource).isNotNull();
          return new File(codeSource.getLocation().toURI());
      }
  
      private static String[] workingDirectoryCommand() {
          String osName = System.getProperty("os.name", "").toLowerCase(Locale.ROOT);
          if (osName.contains("win")) {
              return new String[] {"cmd", "/c", "cd"};
          }
          return new String[] {"/bin/sh", "-c", "pwd"};
      }
  }
