  --- /dev/null
  +++ 2/tests/src/ant/ant/1.6/src/test/java/ant/ant/ExecuteTest.java
  @@ -0,0 +1,56 @@
  +/*
  + * Copyright and related rights waived via CC0
  + *
  + * You should have received a copy of the CC0 legalcode along with this
  + * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.
  + */
  +package ant.ant;
  +
  +import java.io.ByteArrayOutputStream;
  +import java.io.File;
  +import java.io.IOException;
  +import java.lang.reflect.Method;
  +import java.util.Locale;
  +
  +import org.apache.tools.ant.taskdefs.Execute;
  +import org.apache.tools.ant.taskdefs.PumpStreamHandler;
  +import org.junit.jupiter.api.Test;
  +import org.junit.jupiter.api.io.TempDir;
  +
  +import static org.assertj.core.api.Assertions.assertThat;
  +
  +public class ExecuteTest {
  +    @TempDir
  +    File temporaryDirectory;
  +
  +    @Test
  +    void legacyClassLiteralHelperLoadsRuntimeClassByName() throws Exception {
  +        Method classLiteralHelper = Execute.class.getDeclaredMethod("class$", String.class);
  +        classLiteralHelper.setAccessible(true);
  +
  +        Object loadedClass = classLiteralHelper.invoke(null, "java.lang.Runtime");
  +
  +        assertThat(loadedClass).isSameAs(Runtime.class);
  +    }
  +
  +    @Test
  +    void launchesCommandInConfiguredWorkingDirectoryThroughVmLauncher() throws IOException {
  +        ByteArrayOutputStream output = new ByteArrayOutputStream();
  +        Execute execute = new Execute(new PumpStreamHandler(output));
  +        execute.setWorkingDirectory(temporaryDirectory);
  +        execute.setCommandline(workingDirectoryCommand());
  +
  +        int exitCode = execute.execute();
  +
  +        assertThat(exitCode).isZero();
  +        assertThat(Execute.toString(output).trim()).isEqualTo(temporaryDirectory.getAbsolutePath());
  +    }
  +
  +    private static String[] workingDirectoryCommand() {
  +        String osName = System.getProperty("os.name", "").toLowerCase(Locale.ROOT);
  +        if (osName.contains("win")) {
  +            return new String[] {"cmd", "/c", "cd"};
  +        }
  +        return new String[] {"/bin/sh", "-c", "pwd"};
  +    }
  +}
