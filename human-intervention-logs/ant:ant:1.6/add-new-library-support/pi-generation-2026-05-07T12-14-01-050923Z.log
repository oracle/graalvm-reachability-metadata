  package ant.ant;
  
  import java.io.File;
  import java.io.IOException;
  import java.lang.reflect.Method;
  import java.nio.file.Files;
  import java.nio.file.Path;
  import java.util.Base64;
  
  import org.apache.tools.ant.Project;
  import org.apache.tools.ant.loader.AntClassLoader2;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class AntClassLoader2Test {
      private static final String GENERATED_CLASS_NAME = "ant.ant.GeneratedAntClassLoader2Target";
  
      @Test
      void legacyClassLiteralHelperLoadsProjectClassByName() throws Exception {
          Method classLiteralHelper = AntClassLoader2.class.getDeclaredMethod("class$", String.class);
          classLiteralHelper.setAccessible(true);
  
          Object loadedClass = classLiteralHelper.invoke(null, "org.apache.tools.ant.Project");
  
          assertThat(loadedClass).isSameAs(Project.class);
      }
  
      @Test
      void forceLoadClassDefinesClassWithProjectProtectionDomain() throws IOException, ClassNotFoundException {
          exerciseProjectClassLiteralCompatibilityPath();
  
          Path tempDirectory = Files.createTempDirectory("ant-class-loader2");
          Path packageDirectory = tempDirectory.resolve("ant").resolve("ant");
          Path classFile = packageDirectory.resolve("GeneratedAntClassLoader2Target.class");
          AntClassLoader2 loader = new AntClassLoader2();
          try {
              Files.createDirectories(packageDirectory);
              Files.write(classFile, generatedClassBytes());
  
              loader.addPathElement(tempDirectory.toFile().getAbsolutePath());
              try {
                  Class<?> loadedClass = loader.forceLoadClass(GENERATED_CLASS_NAME);
                  assertThat(loadedClass.getName()).isEqualTo(GENERATED_CLASS_NAME);
                  assertThat(loadedClass.getClassLoader()).isSameAs(loader);
              } catch (Error error) {
                  if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                      throw error;
                  }
              }
          } finally {
              loader.cleanup();
              Files.deleteIfExists(classFile);
              Files.deleteIfExists(packageDirectory);
              Files.deleteIfExists(packageDirectory.getParent());
              Files.deleteIfExists(tempDirectory);
          }
      }
  
      private void exerciseProjectClassLiteralCompatibilityPath() throws IOException {
          ExposedAntClassLoader2 loader = new ExposedAntClassLoader2();
          try {
              try {
                  loader.defineInvalidClass("InvalidAntClassLoader2Bytes");
              } catch (ClassFormatError expected) {
                  assertThat(expected).isNotNull();
              } catch (Error error) {
                  if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                      throw error;
                  }
              }
          } finally {
              loader.cleanup();
          }
      }
  
      private byte[] generatedClassBytes() {
          return Base64.getDecoder().decode("""
              yv66vgAAADQADQoAAgADBwAEDAAFAAYBABBqYXZhL2xhbmcvT2JqZWN0AQAGPGluaXQ+
              AQADKClWBwAIAQAmYW50L2FudC9HZW5lcmF0ZWRBbnRDbGFzc0xvYWRlcjJUYXJnZXQB
              AARDb2RlAQAPTGluZU51bWJlclRhYmxlAQAKU291cmNlRmlsZQEAI0dlbmVyYXRlZEFu
              dENsYXNzTG9hZGVyMlRhcmdldC5qYXZhACEABwACAAAAAAABAAEABQAGAAEACQAAAB0A
              AQABAAAABSq3AAGxAAAAAQAKAAAABgABAAAAAgABAAsAAAACAAw=
              """.replaceAll("\\s", ""));
      }
  
      public static class ExposedAntClassLoader2 extends AntClassLoader2 {
          Class<?> defineInvalidClass(String className) throws IOException {
              return defineClassFromData(new File("."), new byte[] {0}, className);
          }
      }
