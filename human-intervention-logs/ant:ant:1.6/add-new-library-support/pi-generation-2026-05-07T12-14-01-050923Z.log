  package ant.ant;
  
  import java.util.UUID;
  
  import org.apache.tools.ant.AntClassLoader;
  import org.apache.tools.ant.Project;
  import org.apache.tools.ant.taskdefs.ExecuteJava;
  import org.apache.tools.ant.types.Commandline;
  import org.apache.tools.ant.types.Path;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ExecuteJavaTest {
      @Test
      void executesMainClassLoadedFromApplicationClasspath() {
          String propertyName = uniquePropertyName("application-classpath");
          try {
              ExecuteJava executeJava = new ExecuteJava();
              executeJava.setJavaCommand(commandFor(propertyName, "direct"));
  
              executeJava.execute(new Project());
  
              assertThat(System.getProperty(propertyName)).isEqualTo("direct");
          } finally {
              System.clearProperty(propertyName);
          }
      }
  
      @Test
      void executesMainClassLoadedThroughProjectClasspathLoader() {
          String propertyName = uniquePropertyName("project-classpath");
          ParentDelegatingProject project = new ParentDelegatingProject();
          try {
              ExecuteJava executeJava = new ExecuteJava();
              executeJava.setJavaCommand(commandFor(propertyName, "loader"));
              executeJava.setClasspath(new Path(project));
  
              executeJava.execute(project);
  
              assertThat(System.getProperty(propertyName)).isEqualTo("loader");
          } finally {
              System.clearProperty(propertyName);
          }
      }
  
      private static Commandline commandFor(String propertyName, String propertyValue) {
          Commandline commandline = new Commandline();
          commandline.setExecutable(RecordingMain.class.getName());
          commandline.createArgument().setValue(propertyName);
          commandline.createArgument().setValue(propertyValue);
          return commandline;
      }
  
      private static String uniquePropertyName(String suffix) {
          return ExecuteJavaTest.class.getName() + "." + suffix + "." + UUID.randomUUID();
      }
  
      public static final class RecordingMain {
          public static void main(String[] args) {
              System.setProperty(args[0], args[1]);
          }
      }
  
      public static final class ParentDelegatingProject extends Project {
          @Override
          public AntClassLoader createClassLoader(Path path) {
              return new ParentDelegatingAntClassLoader(ExecuteJavaTest.class.getClassLoader());
          }
      }
  
      public static final class ParentDelegatingAntClassLoader extends AntClassLoader {
          private final ClassLoader parent;
  
          ParentDelegatingAntClassLoader(ClassLoader parent) {
              super(parent, true);
              this.parent = parent;
          }
  
          @Override
          public Class forceLoadClass(String classname) throws ClassNotFoundException {
              return parent.loadClass(classname);
          }
  
          @Override
          protected synchronized Class loadClass(String classname, boolean resolve) throws ClassNotFoundException {
              return parent.loadClass(classname);
          }
      }
