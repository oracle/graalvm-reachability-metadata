  package ant.ant;
  
  import java.io.File;
  
  import org.apache.tools.ant.Project;
  import org.apache.tools.ant.taskdefs.Javac;
  import org.apache.tools.ant.taskdefs.compilers.Javac13;
  import org.apache.tools.ant.types.Path;
  import org.junit.jupiter.api.Test;
  import org.junit.jupiter.api.io.TempDir;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class Javac13Test {
  
      @TempDir
      File temporaryDirectory;
  
      @Test
      void executeInvokesModernCompilerReflectively() {
          File sourceDirectory = new File(temporaryDirectory, "src");
          File destinationDirectory = new File(temporaryDirectory, "classes");
          assertThat(sourceDirectory.mkdirs()).isTrue();
          assertThat(destinationDirectory.mkdirs()).isTrue();
  
          configureJavaHomeForModernCompiler();
  
          Project project = new Project();
          project.init();
          project.setBaseDir(temporaryDirectory);
  
          Javac javac = new Javac();
          javac.setProject(project);
          javac.setSrcdir(new Path(project, sourceDirectory.getAbsolutePath()));
          javac.setDestdir(destinationDirectory);
          javac.setCompiler("javac1.3");
          javac.setIncludeantruntime(false);
  
          Javac13 compiler = new Javac13();
          compiler.setJavac(javac);
  
          assertThat(compiler.execute()).isFalse();
      }
  
      private static void configureJavaHomeForModernCompiler() {
          String environmentJavaHome = System.getenv("JAVA_HOME");
          if (System.getProperty("java.home") == null && environmentJavaHome != null) {
              System.setProperty("java.home", environmentJavaHome);
          }
      }
  }
