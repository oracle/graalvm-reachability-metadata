  package ant.ant;
  
  import java.io.ByteArrayOutputStream;
  import java.io.File;
  import java.io.IOException;
  import java.io.InputStream;
  import java.nio.file.Files;
  import java.nio.file.Path;
  import java.nio.file.StandardCopyOption;
  import java.util.Locale;
  
  import org.apache.tools.ant.AntClassLoader;
  import org.apache.tools.ant.taskdefs.Execute;
  import org.apache.tools.ant.taskdefs.PumpStreamHandler;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  import org.junit.jupiter.api.io.TempDir;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ExecuteTest {
      @TempDir
      File temporaryDirectory;
  
      @Test
      void initializingFreshExecuteClassRunsLegacyClassLiteralPath() throws Exception {
          AntClassLoader loader = new AntClassLoader(getClass().getClassLoader(), false);
          try {
              loader.addPathElement(freshExecuteClassesRoot().getAbsolutePath());
              try {
                  Class<?> loadedClass = loader.forceLoadClass(Execute.class.getName());
  
                  assertThat(loadedClass.getClassLoader()).isSameAs(loader);
                  AntClassLoader.initializeClass(loadedClass);
              } catch (Error error) {
                  if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                      throw error;
                  }
              }
          } finally {
              loader.cleanup();
          }
      }
  
      @Test
      void launchesCommandInConfiguredWorkingDirectoryThroughVmLauncher() throws IOException {
          ByteArrayOutputStream output = new ByteArrayOutputStream();
          Execute execute = new Execute(new PumpStreamHandler(output));
          execute.setWorkingDirectory(temporaryDirectory);
          execute.setCommandline(workingDirectoryCommand());
  
          int exitCode = execute.execute();
  
          assertThat(exitCode).isZero();
          assertThat(Execute.toString(output).trim()).isEqualTo(temporaryDirectory.getAbsolutePath());
      }
  
      private File freshExecuteClassesRoot() throws IOException {
          Path packageDirectory = temporaryDirectory.toPath()
              .resolve("org")
              .resolve("apache")
              .resolve("tools")
              .resolve("ant")
              .resolve("taskdefs");
          Files.createDirectories(packageDirectory);
          for (String classFileName : executeClassFileNames()) {
              copyExecuteClassFile(classFileName, packageDirectory);
          }
          return temporaryDirectory;
      }
  
      private static void copyExecuteClassFile(String classFileName, Path packageDirectory) throws IOException {
          try (InputStream classBytes = Execute.class.getResourceAsStream(classFileName)) {
              assertThat(classBytes).isNotNull();
              Files.copy(classBytes, packageDirectory.resolve(classFileName), StandardCopyOption.REPLACE_EXISTING);
          }
      }
  
      private static String[] executeClassFileNames() {
          return new String[] {
              "Execute.class",
              "Execute$1.class",
              "Execute$CommandLauncher.class",
              "Execute$CommandLauncherProxy.class",
              "Execute$Java11CommandLauncher.class",
              "Execute$Java13CommandLauncher.class",
              "Execute$MacCommandLauncher.class",
              "Execute$OS2CommandLauncher.class",
              "Execute$PerlScriptCommandLauncher.class",
              "Execute$ScriptCommandLauncher.class",
              "Execute$VmsCommandLauncher.class",
              "Execute$WinNTCommandLauncher.class"
          };
      }
  
      private static String[] workingDirectoryCommand() {
          String osName = System.getProperty("os.name", "").toLowerCase(Locale.ROOT);
          if (osName.contains("win")) {
              return new String[] {"cmd", "/c", "cd"};
          }
          return new String[] {"/bin/sh", "-c", "pwd"};
      }
  }
