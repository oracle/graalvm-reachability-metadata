[tool-call] delta {"path":"tests/src/ant/ant/1.6/src/test/java/ant/ant/ExecuteTest.java","edits":[{"oldText":"import java.io.IOException;\nimport java.lang.reflect.Method;\nimport java.util.Locale;\n\nimport org.apache.tools.ant.taskdefs.Execute;","newText":"import java.io.IOException;\nimport java.net.URISyntaxException;\nimport java.security.CodeSource;\nimport java.util.Locale;\n\nimport org.apache.tools.ant.AntClassLoader;\nimport org.apache.tools.ant.taskdefs.Execute;"},{"oldText":"import org.junit.jupiter.api.Test;","newText":"import org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;"},{"oldText":"    @Test\n    void legacyClassLiteralHelperLoadsRuntimeClassByName() throws Exception {\n        Method classLiteralHelper = Execute.class.getDeclaredMethod(\"class$\", String.class);\n        classLiteralHelper.setAccessible(true);\n\n        Object loadedClass = classLiteralHelper.invoke(null, \"java.lang.Runtime\");\n\n        assertThat(loadedClass).isSameAs(Runtime.class);\n    }\n\n    @Test\n    void launchesCommandInConfiguredWorkingDirectoryThroughVmLauncher() throws IOException {","newText":"    @Test\n    void initializingFreshExecuteClassRunsLegacyClassLiteralPath() throws Exception {\n        AntClassLoader loader = new AntClassLoader(getClass().getClassLoader(), false);\n        try {\n            loader.addPathElement(antJar().getAbsolutePath());\n            try {\n                Class<?> loadedClass = loader.forceLoadClass(Execute.class.getName());\n\n                assertThat(loadedClass.getClassLoader()).isSameAs(loader);\n                AntClassLoader.initializeClass(loadedClass);\n            } catch (Error error) {\n                if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                    throw error;\n                }\n            }\n        } finally {\n            loader.cleanup();\n        }\n    }\n\n    @Test\n    void launchesCommandInConfiguredWorkingDirectoryThroughVmLauncher() throws IOException {"},{"oldText":"    private static String[] workingDirectoryCommand() {","newText":"    private static File antJar() throws URISyntaxException {\n        CodeSource codeSource = Execute.class.getProtectionDomain().getCodeSource();\n        assertThat(codeSource).isNotNull();\n        return new File(codeSource.getLocation().toURI());\n    }\n\n    private static String[] workingDirectoryCommand() {"}]}
