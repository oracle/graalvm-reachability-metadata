api.Assertions.assertThat;\n\npublic class MacroDefTest {\n\n    @Test\n    void executeRegistersMacroInstanceTypeDefinition() {\n        Project project = new Project();\n        project.init();\n        MacroDef macroDef = new MacroDef();\n        macroDef.setProject(project);\n        macroDef.setName(\"custom-macro\");\n        macroDef.createSequential();\n\n        macroDef.execute();\n\n        ComponentHelper componentHelper = ComponentHelper.getComponentHelper(project);\n        AntTypeDefinition definition = componentHelper.getDefinition(\"custom-macro\");\n        assertThat(definition).isNotNull();\n        assertThat(definition.getTypeClass(project)).isSameAs(MacroInstance.class);\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1714, "output": 345, "cacheRead": 23552, "cacheWrite": 0, "totalTokens": 25611, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778159534342, "responseId": "resp_0628035edf7293100169fc8faefd6481958a3e6dd23eccb393"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_2yN1vJ7D5ou8wGzYhj4iMfM2|fc_0628035edf7293100169fc8fb03e108195abfb955902ad4238", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1205 bytes to tests/src/ant/ant/1.6/src/test/java/ant/ant/MacroDefTest.java"}], "isError": false, "timestamp": 1778159537881}]}
