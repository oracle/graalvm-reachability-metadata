[tool-exec] end id=call_ReBKzsVjpA75iGGlSJjhfj40|fc_0628035edf7293100169fc8f9868a48195accf2db36c5f0bdd name=read status=success
  /*
   * Copyright and related rights waived via CC0
   *
   * You should have received a copy of the CC0 legalcode along with this
   * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.
   */
  plugins {
      id "org.graalvm.internal.tck"
  }
  
  String libraryVersion = tck.testedLibraryVersion.get()
  
  configurations {
      jacocoRuntimeAgent
  }
  
  def generatedLegacyClassesDir = layout.buildDirectory.dir('generated/legacyTestClasses')
  def generateLegacyBase64Encoder = tasks.register('generateLegacyBase64Encoder') {
      outputs.dir generatedLegacyClassesDir
  
      doLast {
          File encoderClass = generatedLegacyClassesDir.get().file('sun/misc/BASE64Encoder.class').asFile
          encoderClass.parentFile.mkdirs()
          String legacyBase64EncoderClass = '''
              yv66vgAAADQAEAoAAgADBwAEDAAFAAYBABBqYXZhL2xhbmcvT2JqZWN0AQAGPGluaXQ+
              AQADKClWBwAIAQAWc3VuL21pc2MvQkFTRTY0RW5jb2RlcgEABENvZGUBAAZlbmNvZGUB
              ABYoW0IpTGphdmEvbGFuZy9TdHJpbmc7CAANAQAET2c9PQEAClNvdXJjZUZpbGUBABJC
              QVNFNjRFbmNvZGVyLmphdmEAIQAHAAIAAAAAAAIAAQAFAAYAAQAJAAAAEQABAAEAAAAF
              KrcAAbEAAAAAAAEACgALAAEACQAAAA8AAQACAAAAAxIMsAAAAAAAAQAOAAAAAgAP
          '''.stripIndent().replaceAll('\\s', '')
          encoderClass.bytes = legacyBase64EncoderClass.decodeBase64()
      }
  }
  
  sourceSets.test.output.dir(generatedLegacyClassesDir, builtBy: generateLegacyBase64Encoder)
  
  dependencies {
      testImplementation "ant:ant:$libraryVersion"
      testImplementation "ant:ant-launcher:$libraryVersion"
      testImplementation "ant:ant-nodeps:$libraryVersion"
      testImplementation "ant:ant-trax:$libraryVersion"
      testImplementation "ant:ant-xalan1:$libraryVersion"
      testImplementation "ant:ant-xslp:$libraryVersion"
      testImplementation 'xml-resolver:xml-resolver:1.2'
      jacocoRuntimeAgent "org.jacoco:org.jacoco.agent:${jacoco.toolVersion}:runtime"
      testImplementation 'org.assertj:assertj-core:3.22.0'
  }
  
  jar {
      from sourceSets.test.output
  }
  
  tasks.withType(Test).configureEach {
      dependsOn generateLegacyBase64Encoder
      jvmArgs '--add-opens=java.base/java.lang=ALL-UNNAMED'
      doFirst {
          jvmArgs '--add-modules=jdk.unsupported',
                  "--patch-module=jdk.unsupported=${generatedLegacyClassesDir.get().asFile.absolutePath}"
      }
  }
  
  def availableBootstrapTest = tasks.register('availableBootstrapTest', Test) {
      description = 'Runs tests with ant appended to the bootstrap class path.'
      group = 'verification'
      testClassesDirs = sourceSets.test.output.classesDirs
      classpath = sourceSets.test.runtimeClasspath
      include 'ant/ant/AvailableTest.class', 'ant/ant/PropertyTest.class'
      shouldRunAfter tasks.named('test')
      useJUnitPlatform()
  
      if (extensions.findByName('jacoco') != null) {
          jacoco.enabled = false
      }
  
      doFirst {
          File antJar = configurations.testRuntimeClasspath.files.find { File file ->
              file.name == "ant-${libraryVersion}.jar"
          }
          if (antJar == null) {
              throw new GradleException("Could not find ant:${libraryVersion} on the test runtime classpath")
          }
          File jacocoAgent = configurations.jacocoRuntimeAgent.singleFile
          File jacocoDestination = layout.buildDirectory.file('jacoco/availableBootstrapTest.exec').get().asFile
          String bootstrapIncludes = [
              'org.apache.tools.ant.taskdefs.Available',
              'org.apache.tools.ant.taskdefs.Property'
          ].join(':')
          jvmArgs "-Xbootclasspath/a:${antJar.absolutePath}",
                  "-javaagent:${jacocoAgent.absolutePath}=destfile=${jacocoDestination.absolutePath},append=false,inclbootstrapclasses=true,includes=${bootstrapIncludes}"
      }
  }
  
  tasks.named('test') {
      finalizedBy availableBootstrapTest
  }
  
  tasks.named('jacocoTestReport') {
      dependsOn availableBootstrapTest
      executionData fileTree(dir: layout.buildDirectory.dir('jacoco').get().asFile, include: '*.exec')
  }
  
  graalvmNative {
      binaries {
          test {
              buildArgs("-H:+AllowJRTFileSystem")
              runtimeArgs("-Djava.home=${System.getenv('JAVA_HOME')}")
          }
      }
      agent {
          defaultMode = "conditional"
          modes {
              conditional {
                  userCodeFilterPath = "user-code-filter.json"
              }
          }
      }
  }
