[tool-call] delta {"path":"tests/src/ant/ant/1.6/src/test/java/ant/ant/MacroDefTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage ant.ant;\n\nimport org.apache.tools.ant.AntTypeDefinition;\nimport org.apache.tools.ant.ComponentHelper;\nimport org.apache.tools.ant.Project;\nimport org.apache.tools.ant.taskdefs.MacroDef;\nimport org.apache.tools.ant.taskdefs.MacroInstance;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class MacroDefTest {\n\n    @Test\n    void executeRegistersMacroInstanceTypeDefinition() {\n        Project project = new Project();\n        project.init();\n        MacroDef macroDef = new MacroDef();\n        macroDef.setProject(project);\n        macroDef.setName(\"custom-macro\");\n        macroDef.createSequential();\n\n        macroDef.execute();\n\n        ComponentHelper componentHelper = ComponentHelper.getComponentHelper(project);\n        AntTypeDefinition definition = componentHelper.getDefinition(\"custom-macro\");\n        assertThat(definition).isNotNull();\n        assertThat(definition.getTypeClass(project)).isSameAs(MacroInstance.class);\n    }\n}\n"}
