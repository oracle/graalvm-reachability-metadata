ddReference(\"shared.xmlcatalog\", source);\n\n        XMLCatalog referenced = new XMLCatalog();\n        referenced.setProject(project);\n        referenced.setRefid(new Reference(\"shared.xmlcatalog\"));\n\n        InputSource inputSource = referenced.resolveEntity(PUBLIC_ID, \"urn:example:referenced-catalog\");\n\n        assertThat(inputSource).isNotNull();\n        assertThat(inputSource.getSystemId()).endsWith(\"referenced-catalog.dtd\");\n    }\n\n    private static ResourceLocation resourceLocation(String publicId, String location) {\n        ResourceLocation resourceLocation = new ResourceLocation();\n        resourceLocation.setPublicId(publicId);\n        resourceLocation.setLocation(location);\n        return resourceLocation;\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 910, "output": 1002, "cacheRead": 35328, "cacheWrite": 0, "totalTokens": 37240, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777338254354, "responseId": "resp_0b7f7d7cf6618e610169f0078edb9c81a2ae24a3dac47228ec"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_6itHmaplJr4dPEQDByFvRqKy|fc_0b7f7d7cf6618e610169f00795e76c81a2953136191c65c898", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2104 bytes to tests/src/ant/ant/1.6/src/test/java/ant/ant/XMLCatalogTest.java"}], "isError": false, "timestamp": 1777338265982}]}
