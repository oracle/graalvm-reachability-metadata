              baseURL = matchingEntry.getBase();
          } else {
              try {
                  baseURL = fileUtils.getFileURL(getProject().getBaseDir());
              } catch (MalformedURLException ex) {
                  throw new BuildException("Project basedir cannot be converted to a URL");
