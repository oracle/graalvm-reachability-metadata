  package ant.ant;
  
  import org.apache.tools.ant.IntrospectionHelper;
  import org.apache.tools.ant.types.EnumeratedAttribute;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class IntrospectionHelperAnonymous11Test {
  
      @Test
      void setsEnumeratedAttribute() {
          EnumeratedAttributeTarget target = new EnumeratedAttributeTarget();
          IntrospectionHelper helper = IntrospectionHelper.getHelper(EnumeratedAttributeTarget.class);
  
          helper.setAttribute(null, target, "mode", "strict");
  
          assertThat(target.mode).isInstanceOf(ModeAttribute.class);
          assertThat(target.mode.getValue()).isEqualTo("strict");
          assertThat(target.mode.getIndex()).isEqualTo(1);
      }
  
      public static final class EnumeratedAttributeTarget {
          private ModeAttribute mode;
  
          public void setMode(ModeAttribute value) {
              this.mode = value;
          }
      }
  
      public static final class ModeAttribute extends EnumeratedAttribute {
          public ModeAttribute() {
          }
  
          @Override
          public String[] getValues() {
              return new String[] {"lenient", "strict"};
          }
      }
