[tool-call] delta {"path":"tests/src/ant/ant/1.6/src/test/java/ant/ant/IntrospectionHelperAnonymous13Test.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage ant.ant;\n\nimport org.apache.tools.ant.ComponentHelper;\nimport org.apache.tools.ant.IntrospectionHelper;\nimport org.apache.tools.ant.Project;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class IntrospectionHelperAnonymous13Test {\n    private static final String ADD_NESTED_TYPE = \"anonymous13-add-nested\";\n    private static final String ADD_CONFIGURED_NESTED_TYPE = \"anonymous13-add-configured-nested\";\n\n    @Test\n    void addTypeCreatorInvokesGenericAddDuringCreate() {\n        Project project = createProjectWithType(ADD_NESTED_TYPE, AddNested.class);\n        GenericAddParent parent = new GenericAddParent();\n        IntrospectionHelper helper = IntrospectionHelper.getHelper(GenericAddParent.class);\n\n        IntrospectionHelper.Creator creator = helper.getElementCreator(\n                project,\n                \"\",\n                parent,\n                ADD_NESTED_TYPE,\n                null\n        );\n        Object created = creator.create();\n        creator.store();\n\n        assertThat(created).isInstanceOf(AddNested.class);\n        assertThat(parent.added).isSameAs(created);\n    }\n\n    @Test\n    void addTypeCreatorInvokesGenericAddConfiguredDuringStore() {\n        Project project = createProjectWithType(ADD_CONFIGURED_NESTED_TYPE, AddConfiguredNested.class);\n        GenericAddConfiguredParent parent = new GenericAddConfiguredParent();\n        IntrospectionHelper helper = IntrospectionHelper.getHelper(GenericAddConfiguredParent.class);\n\n        IntrospectionHelper.Creator creator = helper.getElementCreator(\n                project,\n                \"\",\n                parent,\n                ADD_CONFIGURED_NESTED_TYPE,\n                null\n        );\n        Object created = creator.create();\n\n        assertThat(created).isInstanceOf(AddConfiguredNested.class);\n        assertThat(parent.configured).isNull();\n\n        creator.store();\n\n        assertThat(parent.configured).isSameAs(created);\n    }\n\n    private static Project createProjectWithType(String typeName, Class<?> typeClass) {\n        Project project = new Project();\n        project.init();\n        ComponentHelper.getComponentHelper(project).addDataTypeDefinition(typeName, typeClass);\n        return project;\n    }\n\n    public static final class GenericAddParent {\n        private AddNested added;\n\n        public void add(AddNested nested) {\n            this.added = nested;\n        }\n    }\n\n    public static final class GenericAddConfiguredParent {\n        private AddConfiguredNested configured;\n\n        public void addConfigured(AddConfiguredNested nested) {\n            this.configured = nested;\n        }\n    }\n\n    public static final class AddNested {\n        public AddNested() {\n        }\n    }\n\n    public static final class AddConfiguredNested {\n        public AddConfiguredNested() {\n        }\n    }\n}\n"}
