              if (adaptToClass.isAssignableFrom(o.getClass())) {
                  return o;
              }
          }
  
          TypeAdapter adapterObject = (TypeAdapter) createAndSet(
              project, adapterClass);
          if (adapterObject == null) {
              return null;
          }
  
          adapterObject.setProxy(o);
          return adapterObject;
      }
  
