path\n    useJUnitPlatform()\n    filter {\n        includeTestsMatching \"ant.ant.AvailableTest\"\n    }\n    shouldRunAfter tasks.named(\"test\")\n    systemProperty \"ant.available.bootstrap\", \"true\"\n\n    doFirst {\n        Set<File> antJars = configurations.testRuntimeClasspath.files.findAll {\n            it.name == \"ant-${libraryVersion}.jar\"\n                    || it.name.startsWith(\"ant-\")\n        }\n        if (antJars.isEmpty()) {\n            throw new GradleException(\n                    \"Could not locate Ant JARs on the test runtime classpath\")\n        }\n        jvmArgs \"-Xbootclasspath/a:${antJars*.absolutePath.join(File.pathSeparator)}\"\n    }\n}\n```\n\nThis should allow the scoped bootstrap test task to discover and run only `ant.ant.AvailableTest` without affecting the main test suite.", "textSignature": "{\"v\":1,\"id\":\"msg_0ec11b8f7823f2c60169f55655c090819db06cc154cad10658\",\"phase\":\"final_answer\"}"}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 787, "output": 334, "cacheRead": 62464, "cacheWrite": 0, "totalTokens": 63585, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "stop", "timestamp": 1777686099498, "responseId": "resp_0ec11b8f7823f2c60169f556543350819d85e39bcc4ab378ed"}, "toolResults": []}
