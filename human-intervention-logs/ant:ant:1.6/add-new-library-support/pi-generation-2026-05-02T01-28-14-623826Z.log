[tool-call] delta {"path":"tests/src/ant/ant/1.6/build.gradle","edits":[{"oldText":"tasks.withType(Test).configureEach {\n    doFirst {\n        Set<File> antJars = configurations.testRuntimeClasspath.files.findAll {\n            it.name == \"ant-${libraryVersion}.jar\"\n                    || it.name.startsWith(\"ant-\")\n        }\n        if (antJars.isEmpty()) {\n            throw new GradleException(\n                    \"Could not locate Ant JARs on the test runtime classpath\")\n        }\n        jvmArgs \"-Xbootclasspath/a:${antJars*.absolutePath.join(File.pathSeparator)}\"\n    }\n}\n\ndependencies {","newText":"tasks.register(\"availableBootstrapTest\", Test) {\n    description = \"Runs AvailableTest with Ant loaded from the bootstrap class path.\"\n    group = \"verification\"\n    testClassesDirs = sourceSets.test.output.classesDirs\n    classpath = sourceSets.test.runtimeClasspath\n    include \"ant/ant/AvailableTest.class\"\n    shouldRunAfter tasks.named(\"test\")\n    systemProperty \"ant.available.bootstrap\", \"true\"\n\n    doFirst {\n        Set<File> antJars = configurations.testRuntimeClasspath.files.findAll {\n            it.name == \"ant-${libraryVersion}.jar\"\n                    || it.name.startsWith(\"ant-\")\n        }\n        if (antJars.isEmpty()) {\n            throw new GradleException(\n                    \"Could not locate Ant JARs on the test runtime classpath\")\n        }\n        jvmArgs \"-Xbootclasspath/a:${antJars*.absolutePath.join(File.pathSeparator)}\"\n    }\n}\n\ntasks.named(\"test\") {\n    finalizedBy tasks.named(\"availableBootstrapTest\")\n}\n\ndependencies {"}]}
[tool-call] end id=call_QHNogTlkP9WnyPTfZmF9KzOn|fc_0ec11b8f7823f2c60169f55629f068819d9641053f21ec2666 name=edit args={"path": "tests/src/ant/ant/1.6/build.gradle", "edits": [{"oldText": "tasks.withType(Test).configureEach {\n    doFirst {\n        Set<File> antJars = configurations.testRuntimeClasspath.files.findAll {\n            it.name == \"ant-${libraryVersion}.jar\"\n                    || it.name.startsWith(\"ant-\")\n        }\n        if (antJars.isEmpty()) {\n            throw new GradleException(\n                    \"Could not locate Ant JARs on the test runtime classpath\")\n        }\n        jvmArgs \"-Xbootclasspath/a:${antJars*.absolutePath.join(File.pathSeparator)}\"\n    }\n}\n\ndependencies {", "newText": "tasks.register(\"availableBootstrapTest\", Test) {\n    description = \"Runs AvailableTest with Ant loaded from the bootstrap class path.\"\n    group = \"verification\"\n    testClassesDirs = sourceSets.test.output.classesDirs\n    classpath = sourceSets.test.runtimeClasspath\n    include \"ant/ant/AvailableTest.class\"\n    shouldRunAfter tasks.named(\"test\")\n    systemProperty \"ant.available.bootstrap\", \"true\"\n\n    doFirst {\n        Set<File> antJars = configurations.testRuntimeClasspath.files.findAll {\n            it.name == \"ant-${libraryVersion}.jar\"\n                    || it.name.startsWith(\"ant-\")\n        }\n        if (antJars.isEmpty()) {\n            throw new GradleException(\n                    \"Could not locate Ant JARs on the test runtime classpath\")\n        }\n        jvmArgs \"-Xbootclasspath/a:${antJars*.absolutePath.join(File.pathSeparator)}\"\n    }\n}\n\ntasks.named(\"test\") {\n    finalizedBy tasks.named(\"availableBootstrapTest\")\n}\n\ndependencies {"}]}
