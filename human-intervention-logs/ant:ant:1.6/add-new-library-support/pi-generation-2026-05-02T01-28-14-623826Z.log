[assistant] Fixed the `availableBootstrapTest` discovery issue.
[assistant] 
[assistant] Cause: the custom `Test` task did not explicitly enable JUnit Platform, and the class-file `include` pattern was not enough for Gradle’s test discovery/filtering behavior.
[assistant] 
[assistant] Updated `tests/src/ant/ant/1.6/build.gradle`:
[assistant] 
[assistant] ```groovy
[assistant] tasks.register("availableBootstrapTest", Test) {
[assistant]     description = "Runs AvailableTest with Ant loaded from the bootstrap class path."
[assistant]     group = "verification"
[assistant]     testClassesDirs = sourceSets.test.output.classesDirs
[assistant]     classpath = sourceSets.test.runtimeClasspath
[assistant]     useJUnitPlatform()
[assistant]     filter {
[assistant]         includeTestsMatching "ant.ant.AvailableTest"
[assistant]     }
[assistant]     shouldRunAfter tasks.named("test")
[assistant]     systemProperty "ant.available.bootstrap", "true"
[assistant] 
[assistant]     doFirst {
[assistant]         Set<File> antJars = configurations.testRuntimeClasspath.files.findAll {
[assistant]             it.name == "ant-${libraryVersion}.jar"
[assistant]                     || it.name.startsWith("ant-")
[assistant]         }
[assistant]         if (antJars.isEmpty()) {
[assistant]             throw new GradleException(
[assistant]                     "Could not locate Ant JARs on the test runtime classpath")
[assistant]         }
[assistant]         jvmArgs "-Xbootclasspath/a:${antJars*.absolutePath.join(File.pathSeparator)}"
[assistant]     }
[assistant] }
[assistant] ```
[assistant] 
[assistant] This should allow the scoped bootstrap test task to discover and run only `ant.ant.AvailableTest` without affecting the main test suite.
[assistant-event] text_end
