oid resolvesJdkClassAndResourceWithBootstrapLoadedAvailable() {\n        Available available = newAvailable();\n        available.setClassname(String.class.getName());\n        available.setResource(JDK_CLASS_RESOURCE);\n\n        assertThat(available.eval()).isTrue();\n    }\n\n    private Available newAvailable() {\n        return newAvailable(newProject());\n    }\n\n    private Available newAvailable(Project project) {\n        Available available = new Available();\n        available.setProject(project);\n        available.setTaskName(\"available\");\n        return available;\n    }\n\n    private Available newAppLoadedAvailable() {\n        Available available = new AppLoadedAvailable();\n        available.setProject(newProject());\n        available.setTaskName(\"available\");\n        return available;\n    }\n\n    private Project newProject() {\n        Project project = new Project();\n        project.init();\n        return project;\n    }\n}\n\nclass AppLoadedAvailable extends Available {\n    // Keeps this.getClass().getClassLoader() on Available's public path non-null.\n}\n"}
