ded from the bootstrap class path.\"\n    group = \"verification\"\n    testClassesDirs = sourceSets.test.output.classesDirs\n    classpath = sourceSets.test.runtimeClasspath\n    include \"ant/ant/AvailableTest.class\"\n    shouldRunAfter tasks.named(\"test\")\n    systemProperty \"ant.available.bootstrap\", \"true\"\n\n    doFirst {\n        Set<File> antJars = configurations.testRuntimeClasspath.files.findAll {\n            it.name == \"ant-${libraryVersion}.jar\"\n                    || it.name.startsWith(\"ant-\")\n        }\n        if (antJars.isEmpty()) {\n            throw new GradleException(\n                    \"Could not locate Ant JARs on the test runtime classpath\")\n        }\n        jvmArgs \"-Xbootclasspath/a:${antJars*.absolutePath.join(File.pathSeparator)}\"\n    }\n}\n\ntasks.named(\"test\") {\n    finalizedBy tasks.named(\"availableBootstrapTest\")\n}\n\ndependencies {"}]}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1910, "output": 2200, "cacheRead": 58368, "cacheWrite": 0, "totalTokens": 62478, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777686028039, "responseId": "resp_0ec11b8f7823f2c60169f5560cc254819d955d77f85794beff"}}
