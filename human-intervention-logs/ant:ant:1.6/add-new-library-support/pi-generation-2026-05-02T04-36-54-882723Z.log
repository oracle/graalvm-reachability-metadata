              && newLoader instanceof AntClassLoader
              && ((AntClassLoader) oldLoader).getClasspath()
              .equals(((AntClassLoader) newLoader).getClasspath())
              ) {
              return true;
          } else {
              return false;
          }
      }
  
      private String extractClassname(Class c) {
          if (c == null) {
