ewText": "    void setComprSizeUpdatesCompressedSizeInFreshClassLoader() throws Exception {\n        try (ChildFirstZipEntryClassLoader classLoader = new ChildFirstZipEntryClassLoader(classPathUrls())) {\n            Object entry = newIsolatedZipEntry(classLoader, \"archive/isolated-member.txt\");\n            Method setComprSize = entry.getClass().getMethod(\"setComprSize\", Long.TYPE);\n            Method getCompressedSize = entry.getClass().getMethod(\"getCompressedSize\");\n\n            setComprSize.invoke(entry, Long.valueOf(8192L));\n\n            assertThat(getCompressedSize.invoke(entry)).isEqualTo(Long.valueOf(8192L));\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    private static Object newIsolatedZipEntry(ClassLoader classLoader, String name) throws Exception {\n        Class<?> zipEntryClass = classLoader.loadClass(ZipEntry.class.getName());\n        Constructor<?> constructor = zipEntryClass.getConstructor(String.class);\n        return constructor.newInstance(name);\n    }\n\n    private static URL[] classPathUrls() throws Exception {\n        String[] classPathEntries = System.getProperty(\"java.class.path\").split(File.pathSeparator);\n        URL[] urls = new URL[classPathEntries.length];\n        for (int index = 0; index < classPathEntries.length; index++) {\n            urls[index] = new File(classPathEntries[index]).toURI().toURL();\n        }\n        return urls;\n    }\n\n    private static final class ChildFirstZipEntryClassLoader extends URLClassLoader {\n        private ChildFirstZipEntryClassLoader(URL[] urls) {\n            super(urls, ZipEntryTest.class.getClassLoader());\n        }\n\n        @Override\n        protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {\n            synchronized (getClassLoadingLock(name)) {\n                Class<?> loadedClass = findLoadedClass(name);\n                if (loadedClass == null) {\n                    loadedClass = findZipEntryClass(name);\n                }\n                if (loadedClass == null) {\n                    loadedClass = super.loadClass(name, false);\n                }\n                if (resolve) {\n                    resolveClass(loadedClass);\n                }\n                return loadedClass;\n            }\n        }\n\n        private Class<?> findZipEntryClass(String name) throws ClassNotFoundException {\n            if (!ZipEntry.class.getName().equals(name)) {\n                return null;\n            }\n            try {\n                return findClass(name);\n            } catch (ClassNotFoundException notFound) {\n                return null;\n            }\n        }\n    }\n}\n"}]}
