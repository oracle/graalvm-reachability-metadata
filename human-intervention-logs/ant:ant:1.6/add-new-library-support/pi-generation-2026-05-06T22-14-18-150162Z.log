[tool-call] delta {"path":"tests/src/ant/ant/1.6/src/test/java/ant/ant/TaskAdapterTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage ant.ant;\n\nimport java.lang.invoke.MethodHandles;\nimport java.lang.invoke.VarHandle;\n\nimport org.apache.tools.ant.Project;\nimport org.apache.tools.ant.TaskAdapter;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class TaskAdapterTest {\n    private static final String PROJECT_CLASS_CACHE_FIELD = \"class$org$apache$tools$ant$Project\";\n\n    @Test\n    void validatesAndExecutesProxyTaskThroughTaskAdapter() {\n        Project project = new Project();\n        ProxyTask proxy = new ProxyTask();\n\n        checkAdaptableTaskClass(project);\n        resetCachedProjectClass();\n\n        TaskAdapter adapter = new TaskAdapter();\n        adapter.setProject(project);\n        adapter.setProxy(proxy);\n        adapter.execute();\n\n        assertThat(proxy.project).isSameAs(project);\n        assertThat(proxy.executed).isTrue();\n        assertThat(adapter.getProxy()).isSameAs(proxy);\n    }\n\n    private static void checkAdaptableTaskClass(Project project) {\n        try {\n            TaskAdapter.checkTaskClass(ProxyTask.class, project);\n        } catch (NullPointerException exception) {\n            // Ant 1.6 passes a null parameter array to Class#getMethod from pre-varargs bytecode.\n            assertThat(exception).isInstanceOf(NullPointerException.class);\n        }\n    }\n\n    private static void resetCachedProjectClass() {\n        try {\n            MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(TaskAdapter.class, MethodHandles.lookup());\n            VarHandle projectClassCache = lookup.findStaticVarHandle(\n                    TaskAdapter.class,\n                    PROJECT_CLASS_CACHE_FIELD,\n                    Class.class\n            );\n            projectClassCache.set((Class<?>) null);\n        } catch (IllegalAccessException | NoSuchFieldException exception) {\n            throw new AssertionError(\"Unable to reset TaskAdapter's legacy Project class cache\", exception);\n        }\n    }\n\n    public static final class ProxyTask {\n        private Project project;\n        private boolean executed;\n\n        public void setProject(Project project) {\n            this.project = project;\n        }\n\n        public void execute() {\n            executed = true;\n        }\n    }\n}\n"}
