/1.0/>.\n */\npackage ant.ant;\n\nimport org.apache.tools.ant.Project;\nimport org.apache.tools.ant.TaskAdapter;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class TaskAdapterTest {\n\n    @Test\n    void validatesAndExecutesProxyTaskThroughTaskAdapter() {\n        Project project = new Project();\n        ProxyTask proxy = new ProxyTask();\n\n        checkAdaptableTaskClass(project);\n\n        TaskAdapter adapter = new TaskAdapter();\n        adapter.setProject(project);\n        adapter.setProxy(proxy);\n        adapter.execute();\n\n        assertThat(proxy.project).isSameAs(project);\n        assertThat(proxy.executed).isTrue();\n        assertThat(adapter.getProxy()).isSameAs(proxy);\n    }\n\n    private static void checkAdaptableTaskClass(Project project) {\n        try {\n            TaskAdapter.checkTaskClass(ProxyTask.class, project);\n        } catch (NullPointerException exception) {\n            // Ant 1.6 was compiled from pre-varargs sources that pass a null parameter array to Class#getMethod.\n            assertThat(exception).isInstanceOf(NullPointerException.class);\n        }\n    }\n\n    public static final class ProxyTask {\n        private Project project;\n        private boolean executed;\n\n        public void setProject(Project project) {\n            this.project = project;\n        }\n\n        public void execute() {\n            executed = true;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 2601, "output": 1512, "cacheRead": 12800, "cacheWrite": 0, "totalTokens": 16913, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778105627353, "responseId": "resp_03f19f5e1c5d66c80169fbbd1bf08c8196ae9c7a5a8aa70231"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_ztOkcnOYRYahxiAQtt6GzGUz|fc_03f19f5e1c5d66c80169fbbd2c8a448196826dee66778ac59