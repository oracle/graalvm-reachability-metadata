    @Test\n    void executesMainClassLoadedThroughProjectClasspathLoader() {\n        String propertyName = uniquePropertyName(\"project-classpath\");\n        ParentDelegatingProject project = new ParentDelegatingProject();\n        try {\n            ExecuteJava executeJava = new ExecuteJava();\n            executeJava.setJavaCommand(commandFor(propertyName, \"loader\"));\n            executeJava.setClasspath(new Path(project));\n\n            executeJava.execute(project);\n\n            assertThat(System.getProperty(propertyName)).isEqualTo(\"loader\");\n        } finally {\n            System.clearProperty(propertyName);\n        }\n    }\n\n    private static Commandline commandFor(String propertyName, String propertyValue) {\n        Commandline commandline = new Commandline();\n        commandline.setExecutable(RecordingMain.class.getName());\n        commandline.createArgument().setValue(propertyName);\n        commandline.createArgument().setValue(propertyValue);\n        return commandline;\n    }\n\n    private static String uniquePropertyName(String suffix) {\n        return ExecuteJavaTest.class.getName() + \".\" + suffix + \".\" + UUID.randomUUID();\n    }\n\n    public static final class RecordingMain {\n        public static void main(String[] args) {\n            System.setProperty(args[0], args[1]);\n        }\n    }\n\n    public static final class ParentDelegatingProject extends Project {\n        @Override\n        public AntClassLoader createClassLoader(Path path) {\n            return new ParentDelegatingAntClassLoader(ExecuteJavaTest.class.getClassLoader());\n        }\n    }\n\n    public static final class ParentDelegatingAntClassLoader extends AntClassLoader {\n        private final ClassLoader parent;\n\n        ParentDelegatingAntClassLoader(ClassLoader parent) {\n            super(parent, true);\n            this.parent = parent;\n        }\n\n        @Override\n        public Class forceLoadClass(String classname) throws ClassNotFoundException {\n            return Class.forName(classname, false, parent);\n        }\n\n        @Override\n        protected synchronized Class loadClass(String classname, boolean resolve) throws ClassNotFoundException {\n            Class loadedClass = Class.forName(classname, false, parent);\n            if (resolve) {\n                resolveClass(loadedClass);\n            }\n            return loadedClass;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1323, "output": 1343, "cacheRead": 23552, "cacheWrite": 0, "totalTokens": 26218, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778117906268, "responseId": "resp_0f0c6007a88711710169fbed13008481a2a4b42854b71c10ba"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_GjK0RWRsgTEYKWOsi28wFOai|fc_0f0c6007a88711710169fbed218ca881a2a98d0c9c705895b6", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 3455 bytes to tests/src/ant/ant/1.6/src/test/java/ant/ant/ExecuteJavaTest.java"}], "isError": false, "timestamp": 1778117944205}]}
