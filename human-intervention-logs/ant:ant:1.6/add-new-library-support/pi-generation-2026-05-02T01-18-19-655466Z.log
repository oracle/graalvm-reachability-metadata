       */
      protected final String readLine() throws IOException {
          int ch = in.read();
  
          if (ch == -1) {
              return null;
          }
  
          StringBuffer line = new StringBuffer();
  
          while (ch != -1) {
              line.append ((char) ch);
              if (ch == '\n') {
                  break;
              }
              ch = in.read();
          }
          return line.toString();
      }
  
