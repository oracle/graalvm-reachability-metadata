ring libraryVersion = tck.testedLibraryVersion.get()\n// Ant 1.6 probes the removed JDK encoder before falling back to its internal Base64 implementation.\nProvider<Directory> generatedSunMiscBase64EncoderSourceDirectory = layout.buildDirectory\n    .dir(\"generated/sources/sunMiscBase64Encoder/java\")\nProvider<Directory> sunMiscBase64EncoderClassesDirectory = layout.buildDirectory\n    .dir(\"classes/java/sunMiscBase64Encoder\")\nProvider<String> sunMiscBase64EncoderPatchModuleArgument = sunMiscBase64EncoderClassesDirectory\n    .map { \"jdk.unsupported=${it.asFile.absolutePath}\" }\n\nTaskProvider<Task> generateSunMiscBase64Encoder = tasks.register(\"generateSunMiscBase64Encoder\") {\n    outputs.dir(generatedSunMiscBase64EncoderSourceDirectory)\n\n    doLast {\n        Directory sourceDirectory = generatedSunMiscBase64EncoderSourceDirectory.get()\n        File base64EncoderSourceFile = sourceDirectory.file(\"sun/misc/BASE64Encoder.java\").asFile\n        base64EncoderSourceFile.parentFile.mkdirs()\n        base64EncoderSourceFile.text = \"\"\"\n            package sun.misc;\n\n            public class BASE64Encoder {\n                public String encode(byte[] bytes) {\n                    return \"generated-encoder\";\n                }\n            }\n            \"\"\".stripIndent()\n\n        File characterEncoderSourceFile = sourceDirectory.file(\"sun/misc/CharacterEncoder.java\").asFile\n        characterEncoderSourceFile.text = \"\"\"\n            package sun.misc;\n\n            import java.io.IOException;\n            import java.io.InputStream;\n            import java.io.OutputStream;\n\n            public class CharacterEncoder {\n                public void encode(InputStream inputStream, OutputStream outputStream) throws IOException {\n                    int value;\n                    while ((value = inputStream.read()) != -1) {\n                        outputStream.write(value);\n                    }\n                }\n            }\n            \"\"\".stripIndent()\n\n        File uuEncoderSourceFile = sourceDirectory.file(\"sun/misc/UUEncoder.java\").asFile\n        uuEncoderSourceFile.text = \"\"\"\n            package sun.misc;\n\n            public class UUEncoder extends CharacterEncoder {\n                public UUEncoder(String name) {\n                }\n            }\n            \"\"\".stripIndent()\n    }\n}\n\nTaskProvider<JavaCompile> compileSunMiscBase64Encoder = tasks.register(\"compileSunMiscBase64Encoder\", JavaCompile) {\n    dependsOn(generateSunMiscBase64Encoder)\n    source(generatedSunMiscBase64EncoderSourceDirectory)\n    destinationDirectory = sunMiscBase64EncoderClassesDirectory\n    classpath = files()\n    options.release = 8\n}\n\nsourceSets {\n    test {\n        output.dir(sunMiscBase64EncoderClassesDirectory, builtBy: compileSunMiscBase64Encoder)\n    }\n}\n\ntasks.withType(Test).configureEach {\n    dependsOn(compileSunMiscBase64Encoder)\n    doFirst {\n        jvmArgs \"--patch-module\", sunMiscBase64EncoderPatchModuleArgument.get()\n    }\n}\n\ntasks.matching { it.name == \"nativeTestCompile\" }.configureEach {\n    dependsOn(compileSunMiscBase64Encoder)\n}\n\ndependencies {\n    testImplementation \"ant:ant:$libraryVersion\"\n    testRuntimeOnly files(sunMiscBase64EncoderClassesDirectory).builtBy(compileSunMiscBase64Encoder)\n    testRuntimeOnly \"ant:ant-launcher:$libraryVersion\"\n    testRuntimeOnly \"ant:ant-nodeps:$libraryVersion\"\n    testRuntimeOnly \"ant:ant-trax:$libraryVersion\"\n    testRuntimeOnly \"ant:ant-xalan1:$libraryVersion\"\n    testRuntimeOnly \"ant:ant-xslp:$libraryVersion\"\n    testImplementation 'org.assertj:assertj-core:3.22.0'\n    testImplementation 'xml-resolver:xml-resolver:1.2'\n}\n\ngraalvmNative {\n    binaries {\n        test {\n            buildArgs.add('--initialize-at-run-time=org.apache.tools.ant.taskdefs.Execute')\n            buildArgs.add('--initialize-at-run-time=org.apache.tools.ant.taskdefs.Parallel')\n            buildArgs.add('--initialize-at-run-time=org.apache.tools.ant.taskdefs.compilers.Kjc')\n            buildArgs.add('--initialize-at-run-time=org.apache.tools.ant.taskdefs.rmic.SunRmic')\n            buildArgs.add('--initialize-at-run-time=org.apache.tools.ant.taskdefs.rmic.WLRmic')\n            buildArgs.add(\"-J--patch-module=${sunMiscBase64EncoderPatchModuleArgument.get()}\")\n        }\n    }\n\n    agent {\n        defaultMode = \"conditional\"\n        modes {\n            conditional {\n                userCodeFilterPath = \"user-code-filter.json\"\n            }\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777338060444}, {"role": "toolResult", "toolCallId": "call_jAUIB8TP67JNdXMgNuwKEwof|fc_0c214b5170417ca50169f006cc0da081a383bd7d51ca3c4d85", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage ant.ant;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.IOException;\nimport java.lang.reflect.Field;\nimport java.nio.charset.StandardCharsets;\nimport java.nio.file.Files;\nimport java.nio.file.Path;\nimport org.apache.tools.ant.Project;\nimport org.apache.tools.ant.taskdefs.Ant;\nimport org.junit.jupiter.api.BeforeEach;\nimport org.junit.jupiter.api.Test;\nimport org.junit.jupiter.api.io.TempDir;\n\npublic class AntTest {\n    @BeforeEach\n    void resetRecordingReference() throws ReflectiveOperationException {\n        RecordingReference.clonedFrom = null;\n        RecordingReference.assignedReference = null;\n        RecordingReference.assignedProject = null;\n        resetAntProjectClassCache();\n    }\n\n    @Test\n    void clonesAndConfiguresCopiedReferenceForSubproject(@TempDir Path temporaryDirectory) throws IOException {\n        Path buildFile = temporaryDirectory.resolve(\"child-build.xml\");\n        Files.writeString(buildFile, childBuildFile(), StandardCharsets.UTF_8);\n\n        Project parentProject = new Project();\n        parentProject.init();\n        parentProject.setBaseDir(temporaryDirectory.toFile());\n        RecordingReference originalReference = new RecordingReference(\"parent-reference\");\n        parentProject.addReference(\"recording-reference\", originalReference);\n\n        Ant antTask = new Ant();\n        antTask.setProject(parentProject);\n        antTask.setTaskName(\"ant\");\n        antTask.init();\n        antTask.setDir(temporaryDirectory.toFile());\n        antTask.setAntfile(buildFile.getFileName().toString());\n        antTask.setTarget(\"verify\");\n        antTask.addReference(copiedReference());\n\n        antTask.execute();\n\n        assertThat(RecordingReference.clonedFrom).isSameAs(originalReference);\n        assertThat(RecordingReference.assignedReference).isNotSameAs(originalReference);\n        assertThat(RecordingReference.assignedProject).isNotNull();\n        assertThat(RecordingReference.assignedProject).isNotSameAs(parentProject);\n        assertThat(originalReference.project).isNull();\n    }\n\n    private static void resetAntProjectClassCache() throws ReflectiveOperationException {\n        Field projectClassCache = Ant.class.getDeclaredField(\"class$org$apache$tools$ant$Project\");\n        projectClassCache.setAccessible(true);\n        projectClassCache.set(null, null);\n    }\n\n    private static Ant.Reference copiedReference() {\n        Ant.Reference reference = new Ant.Reference();\n        reference.setRefId(\"recording-reference\");\n        reference.setToRefid(\"copied-recording-reference\");\n        return reference;\n    }\n\n    private static String childBuildFile() {\n        return \"\"\"\n            <project name=\"child\" default=\"verify\">\n                <target name=\"verify\"/>\n            </project>\n            \"\"\";\n    }\n\n    public static final class RecordingReference implements Cloneable {\n        private static RecordingReference clonedFrom;\n        private static RecordingReference assignedReference;\n        private static Project assignedProject;\n\n        private final String name;\n        private Project project;\n\n        public RecordingReference(String name) {\n            this.name = name;\n        }\n\n        @Override\n        public RecordingReference clone() {\n            RecordingReference copy = new RecordingReference(name + \"-copy\");\n            clonedFrom = this;\n            return copy;\n        }\n\n        public void setProject(Project project) {\n            this.project = project;\n            assignedReference = this;\n            assignedProject = project;\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777338060444}, {"role": "toolResult", "toolCallId": "call_DhOTuyjJvRf1rxb3GRcAzrPK|fc_0c214b5170417ca50169f006cc0dac81a3bb10429127545112", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage ant.ant;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport org.apache.tools.ant.AntTypeDefinition;\nimport org.apache.tools.ant.Project;\nimport org.junit.jupiter.api.Test;\n\npublic class AntTypeDefinitionTest {\n    @Test\n    void createsNoArgumentTypeLoadedByName() {\n        Project project = new Project();\n        AntTypeDefinition definition = new AntTypeDefinition();\n        definition.setName(\"noArgumentComponent\");\n        definition.setClassName(NoArgumentComponent.class.getName());\n\n        Object component = definition.create(project);\n\n        assertThat(component).isInstanceOf(NoArgumentComponent.class);\n        assertThat(definition.getTypeClass(project)).isSameAs(NoArgumentComponent.class);\n    }\n\n    @Test\n    void createsProjectAwareTypeLoadedThroughConfiguredClassLoader() {\n        Project project = new Project();\n        RecordingClassLoader classLoader = new RecordingClassLoader(\n                AntTypeDefinitionTest.class.getClassLoader(), ProjectAwareComponent.class.getName());\n        AntTypeDefinition definition = new AntTypeDefinition();\n        definition.setName(\"projectAwareComponent\");\n        definition.setClassName(ProjectAwareComponent.class.getName());\n        definition.setClassLoader(classLoader);\n\n        Object component = definition.create(project);\n\n        assertThat(component).isInstanceOf(ProjectAwareComponent.class);\n        assertThat(((ProjectAwareComponent) component).project).isSameAs(project);\n        assertThat(classLoader.loadedClassName).isEqualTo(ProjectAwareComponent.class.getName());\n    }\n\n    public static final class NoArgumentComponent {\n        public NoArgumentComponent() {\n        }\n    }\n\n    public static final class ProjectAwareComponent {\n        private final Project project;\n\n        public ProjectAwareComponent(Project project) {\n            this.project = project;\n        }\n    }\n\n    private static final class RecordingClassLoader extends ClassLoader {\n        private final String expectedClassName;\n        private String loadedClassName;\n\n        private RecordingClassLoader(ClassLoader parent, String expectedClassName) {\n            super(parent);\n            this.expectedClassName = expectedClassName;\n        }\n\n        @Override\n        public Class<?> loadClass(String name) throws ClassNotFoundException {\n            if (expectedClassName.equals(name)) {\n                loadedClassName = name;\n            }\n            return super.loadClass(name);\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777338060444}, {"role": "toolResult", "toolCallId": "call_QcQIabjOAB4ObvyRX1AMk9jb|fc_0c214b5170417ca50169f006cc0db481a383f1c7c69c2d93d2", "toolName": "read", "content": [{"type": "text", "text": "{\n  \"rules\": [\n    {\n      \"excludeClasses\": \"**\"\n    },\n    {\n      \"includeClasses\": \"org.apache.tools.**\"\n    }\n  ]\n}\n"}], "isError": false, "timestamp": 1777338060444}]}
