  package ant.ant;
  
  import java.lang.invoke.MethodHandles;
  import java.lang.invoke.VarHandle;
  import java.util.Collections;
  import java.util.Comparator;
  import java.util.Iterator;
  import java.util.Vector;
  
  import org.apache.tools.ant.types.selectors.cacheselector.DigestAlgorithm;
  import org.apache.tools.ant.types.selectors.cacheselector.EqualComparator;
  import org.apache.tools.ant.types.selectors.cacheselector.PropertiesfileCache;
  import org.apache.tools.ant.types.selectors.modifiedselector.Algorithm;
  import org.apache.tools.ant.types.selectors.modifiedselector.Cache;
  import org.apache.tools.ant.types.selectors.modifiedselector.ModifiedSelector;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ModifiedSelectorTest {
  
      @Test
      void configureLoadsNamedComponentsFromLegacyCacheSelectorPackage() {
          ModifiedSelector selector = new ModifiedSelector();
          ModifiedSelector.AlgorithmName algorithmName = new ModifiedSelector.AlgorithmName();
          algorithmName.setValue("digest");
          ModifiedSelector.CacheName cacheName = new ModifiedSelector.CacheName();
          cacheName.setValue("propertyfile");
          ModifiedSelector.ComparatorName comparatorName = new ModifiedSelector.ComparatorName();
          comparatorName.setValue("equal");
          selector.setAlgorithm(algorithmName);
          selector.setCache(cacheName);
          selector.setComparator(comparatorName);
          ResetComponentsVector.install(selector);
  
          selector.configure();
  
          assertThat(selector.getAlgorithm()).isInstanceOf(DigestAlgorithm.class);
          assertThat(selector.getCache()).isInstanceOf(PropertiesfileCache.class);
          assertThat(selector.getComparator()).isInstanceOf(EqualComparator.class);
      }
  
      private static final class ResetComponentsVector extends Vector<Object> {
          private static final long serialVersionUID = 1L;
  
          private static final VarHandle ALGORITHM = privateField("algorithm", Algorithm.class);
          private static final VarHandle CACHE = privateField("cache", Cache.class);
          private static final VarHandle COMPARATOR = privateField("comparator", Comparator.class);
          private static final VarHandle CONFIG_PARAMETER = privateField(
                  "configParameter", Vector.class);
  
          private final ModifiedSelector selector;
  
          private ResetComponentsVector(ModifiedSelector selector) {
              this.selector = selector;
          }
  
          static void install(ModifiedSelector selector) {
              CONFIG_PARAMETER.set(selector, new ResetComponentsVector(selector));
          }
  
          @Override
          public Iterator<Object> iterator() {
              ALGORITHM.set(selector, null);
              CACHE.set(selector, null);
              COMPARATOR.set(selector, null);
              return Collections.emptyIterator();
          }
  
          private static VarHandle privateField(String name, Class<?> type) {
              try {
                  MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(
                          ModifiedSelector.class, MethodHandles.lookup());
                  return lookup.findVarHandle(ModifiedSelector.class, name, type);
              } catch (ReflectiveOperationException e) {
                  throw new AssertionError("Cannot access ModifiedSelector field " + name, e);
              }
          }
      }
