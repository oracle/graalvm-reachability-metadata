             <document><title>Ant XSLT</title></document>\n                \"\"\");\n        Path stylesheetFile = writeFile(\"style.xsl\", \"\"\"\n                <?xml version=\\\"1.0\\\" encoding=\\\"UTF-8\\\"?>\n                <xsl:stylesheet version=\\\"1.0\\\" xmlns:xsl=\\\"http://www.w3.org/1999/XSL/Transform\\\">\n                    <xsl:output method=\\\"text\\\"/>\n                    <xsl:template match=\\\"/document\\\">\n                        <xsl:value-of select=\\\"title\\\"/>\n                    </xsl:template>\n                </xsl:stylesheet>\n                \"\"\");\n        Path outputFile = temporaryDirectory.resolve(\"result.txt\");\n        ExposedXSLTProcess task = newTask(\"trax\");\n        task.setStyle(stylesheetFile.toString());\n        task.setIn(inputFile.toFile());\n        task.setOut(outputFile.toFile());\n\n        task.execute();\n\n        assertThat(Files.readString(outputFile, StandardCharsets.UTF_8)).contains(\"Ant XSLT\");\n    }\n\n    @Test\n    void resolvesDeprecatedXslpProcessorByName() {\n        assertOptionalProcessorResolution(\"xslp\", XSLP_LIAISON);\n    }\n\n    @Test\n    void resolvesDeprecatedXalanProcessorByName() {\n        assertOptionalProcessorResolution(\"xalan\", XALAN_LIAISON);\n    }\n\n    @Test\n    void resolvesCustomProcessorByClassName() {\n        ExposedXSLTProcess task = newTask(RecordingLiaison.class.getName());\n\n        XSLTLiaison liaison = task.exposeLiaison();\n\n        assertThat(liaison).isInstanceOf(RecordingLiaison.class);\n    }\n\n    @Test\n    void resolvesCustomProcessorThroughConfiguredAntClasspath() {\n        ExposedXSLTProcess task = newTask(RecordingLiaison.class.getName());\n        task.setClasspath(new Path(task.getProject()));\n\n        try {\n            XSLTLiaison liaison = task.exposeLiaison();\n\n            assertThat(liaison).isInstanceOf(RecordingLiaison.class);\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    private void assertOptionalProcessorResolution(String processor, String expectedClassName) {\n        ExposedXSLTProcess task = newTask(processor);\n\n        try {\n            XSLTLiaison liaison = task.exposeLiaison();\n\n            assertThat(liaison.getClass().getName()).isEqualTo(expectedClassName);\n        } catch (BuildException exception) {\n            assertOptionalDependencyFailure(exception.getException());\n        } catch (LinkageError error) {\n            assertOptionalDependencyFailure(error);\n        }\n    }\n\n    private void assertOptionalDependencyFailure(Throwable throwable) {\n        assertThat(throwable)\n                .isNotNull()\n                .isInstanceOfAny(ClassNotFoundException.class, NoClassDefFoundError.class);\n    }\n\n    private ExposedXSLTProcess newTask(String processor) {\n        Project project = new Project();\n        project.setBaseDir(temporaryDirectory.toFile());\n        ExposedXSLTProcess task = new ExposedXSLTProcess();\n        task.setProject(project);\n        task.setProcessor(processor);\n        return task;\n    }\n\n    private Path writeFile(String fileName, String content) throws IOException {\n        Path file = temporaryDirectory.resolve(fileName);\n        Files.writeString(file, content, StandardCharsets.UTF_8);\n        return file;\n    }\n\n    private static final class ExposedXSLTProcess extends XSLTProcess {\n        XSLTLiaison exposeLiaison() {\n            return getLiaison();\n        }\n    }\n\n    public static class RecordingLiaison implements XSLTLiaison {\n        private File stylesheet;\n\n        @Override\n        public void setStylesheet(File stylesheet) {\n            this.stylesheet = stylesheet;\n        }\n\n        @Override\n        public void addParam(String name, String expression) {\n            // Parameters are accepted so XSLTProcess can configure this liaison.\n        }\n\n        @Override\n        public void transform(File infile, File outfile) throws IOException {\n            assertThat(stylesheet).isNotNull();\n            Files.copy(infile.toPath(), outfile.toPath());\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 472, "output": 1491, "cacheRead": 29696, "cacheWrite": 0, "totalTokens": 31659, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777683454245, "responseId": "resp_07ec3050d334749e0169f54bfeb5748191a3b2811a06178db6"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_RWPZ16XW8jkooUuhYaAfQCf2|fc_07ec3050d334749e0169f54c011ca08191b8b69ec38ee5b165", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 5454 bytes to tests/src/ant/ant/1.6/src/test/java/ant/ant/XSLTProcessTest.java"}], "isError": false, "timestamp": 1777683465083}]}
