  package ant.ant;
  
  import java.io.IOException;
  import java.nio.file.Files;
  import java.nio.file.Path;
  
  import org.apache.tools.ant.Project;
  import org.apache.tools.ant.taskdefs.AntStructure;
  import org.apache.tools.ant.types.EnumeratedAttribute;
  import org.junit.jupiter.api.Test;
  import org.junit.jupiter.api.io.TempDir;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class AntStructureTest {
      @TempDir
      Path tempDirectory;
  
      @Test
      void executePrintsDeclaredValuesForEnumeratedAttribute() throws IOException {
          Project project = new Project();
          project.addDataTypeDefinition("sampletype", SampleType.class);
          Path output = tempDirectory.resolve("antstructure.dtd");
  
          AntStructure antStructure = new AntStructure();
          antStructure.setProject(project);
          antStructure.setOutput(output.toFile());
  
          antStructure.execute();
  
          String dtd = Files.readString(output);
          assertThat(dtd).contains("<!ELEMENT sampletype EMPTY>");
          assertThat(dtd).contains("flavor (sweet | sour) #IMPLIED");
      }
  
      public static final class SampleType {
          public SampleType() {
          }
  
          public void setFlavor(FlavorAttribute flavor) {
          }
      }
  
      public static final class FlavorAttribute extends EnumeratedAttribute {
          @Override
          public String[] getValues() {
              return new String[] {"sweet", "sour"};
          }
      }
  }
