te Mode mode;\n\n        public StructuredTask() {\n        }\n\n        public void setEnabled(boolean enabled) {\n            this.enabled = enabled;\n        }\n\n        public void setMode(Mode mode) {\n            this.mode = mode;\n        }\n\n        @Override\n        public void execute() {\n        }\n    }\n\n    public static class Mode extends EnumeratedAttribute {\n        public Mode() {\n        }\n\n        @Override\n        public String[] getValues() {\n            return new String[] {\"strict\", \"lenient\"};\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 461, "output": 997, "cacheRead": 23552, "cacheWrite": 0, "totalTokens": 25010, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777691584316, "responseId": "resp_0dbbb327044436ad0169f56bc0c39081a1b4c10312cb78b476"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_5PkmKIdVE5tpjKsS7bB4ipiD|fc_0dbbb327044436ad0169f56bc6863081a1895ebf1080cc6306", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2074 bytes to tests/src/ant/ant/1.6/src/test/java/ant/ant/AntStructureTest.java"}], "isError": false, "timestamp": 1777691593495}]}
