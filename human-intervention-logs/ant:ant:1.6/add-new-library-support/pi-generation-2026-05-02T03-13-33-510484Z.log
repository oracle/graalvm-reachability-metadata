tMode(Mode mode) {\n            this.mode = mode;\n        }\n\n        @Override\n        public void execute() {\n        }\n    }\n\n    public static class Mode extends EnumeratedAttribute {\n        public Mode() {\n        }\n\n        @Override\n        public String[] getValues() {\n            return new String[] {\"strict\", \"lenient\"};\n        }\n    }\n}\n"}
