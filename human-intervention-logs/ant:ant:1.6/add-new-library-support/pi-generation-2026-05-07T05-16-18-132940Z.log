  package ant.ant;
  
  import org.apache.tools.ant.AntClassLoader;
  import org.apache.tools.ant.Project;
  import org.apache.tools.ant.types.Mapper;
  import org.apache.tools.ant.types.Path;
  import org.apache.tools.ant.util.FileNameMapper;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class MapperTest {
  
      @Test
      void getImplementationLoadsMapperClassByNameAndConfiguresIt() {
          Project project = new Project();
          Mapper mapper = new Mapper(project);
          mapper.setClassname(RecordingFileNameMapper.class.getName());
          mapper.setFrom("*.java");
          mapper.setTo("*.class");
  
          FileNameMapper implementation = mapper.getImplementation();
  
          assertThat(implementation).isInstanceOf(RecordingFileNameMapper.class);
          RecordingFileNameMapper recordingMapper = (RecordingFileNameMapper) implementation;
          assertThat(recordingMapper.from).isEqualTo("*.java");
          assertThat(recordingMapper.to).isEqualTo("*.class");
          assertThat(recordingMapper.project).isSameAs(project);
          assertThat(recordingMapper.mapFileName("Example.java")).containsExactly("Example.java -> *.class");
      }
  
      @Test
      void getImplementationLoadsMapperClassThroughConfiguredClasspath() {
          TrackingProject project = new TrackingProject();
          Path classpath = new Path(project);
          Mapper mapper = new Mapper(project);
          mapper.setClassname(RecordingFileNameMapper.class.getName());
          mapper.setClasspath(classpath);
          mapper.setFrom("source.txt");
          mapper.setTo("target.txt");
  
          FileNameMapper implementation = mapper.getImplementation();
  
          try {
              assertThat(implementation).isInstanceOf(RecordingFileNameMapper.class);
              RecordingFileNameMapper recordingMapper = (RecordingFileNameMapper) implementation;
              assertThat(recordingMapper.from).isEqualTo("source.txt");
              assertThat(recordingMapper.to).isEqualTo("target.txt");
              assertThat(recordingMapper.project).isSameAs(project);
              assertThat(project.requestedClasspath).isSameAs(classpath);
              assertThat(project.createdClassLoader).isNotNull();
          } finally {
              project.cleanupCreatedClassLoader();
          }
      }
  
      public static final class RecordingFileNameMapper implements FileNameMapper {
          private String from;
          private String to;
          private Project project;
  
          public void setProject(Project project) {
              this.project = project;
          }
  
          @Override
          public void setFrom(String from) {
              this.from = from;
          }
  
          @Override
          public void setTo(String to) {
              this.to = to;
          }
  
          @Override
          public String[] mapFileName(String sourceFileName) {
              return new String[] {sourceFileName + " -> " + to};
          }
      }
  
      private static final class TrackingProject extends Project {
          private Path requestedClasspath;
          private AntClassLoader createdClassLoader;
  
          @Override
          public AntClassLoader createClassLoader(Path path) {
              requestedClasspath = path;
              createdClassLoader = new AntClassLoader(getClass().getClassLoader(), true);
              createdClassLoader.setProject(this);
              createdClassLoader.setClassPath(path);
              return createdClassLoader;
          }
  
          private void cleanupCreatedClassLoader() {
              if (createdClassLoader != null) {
                  createdClassLoader.cleanup();
              }
          }
      }
  }
