, "name": "write", "arguments": {"path": "tests/src/ant/ant/1.6/src/test/java/ant/ant/ExtraFieldUtilsTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage ant.ant;\n\nimport java.util.zip.ZipException;\n\nimport org.apache.tools.zip.ExtraFieldUtils;\nimport org.apache.tools.zip.ZipExtraField;\nimport org.apache.tools.zip.ZipShort;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ExtraFieldUtilsTest {\n\n    private static final ZipShort RECORDING_HEADER_ID = new ZipShort(0xCAFE);\n\n    @Test\n    void registerAndCreateExtraFieldInstantiateRegisteredImplementation() throws Exception {\n        RecordingExtraField.reset();\n\n        ExtraFieldUtils.register(RecordingExtraField.class);\n        ZipExtraField created = ExtraFieldUtils.createExtraField(RECORDING_HEADER_ID);\n\n        assertThat(created).isInstanceOf(RecordingExtraField.class);\n        assertThat(created.getHeaderId()).isEqualTo(RECORDING_HEADER_ID);\n        assertThat(RecordingExtraField.constructorCalls).isEqualTo(2);\n    }\n\n    public static final class RecordingExtraField implements ZipExtraField {\n        private static int constructorCalls;\n\n        public RecordingExtraField() {\n            constructorCalls++;\n        }\n\n        private static void reset() {\n            constructorCalls = 0;\n        }\n\n        @Override\n        public ZipShort getHeaderId() {\n            return RECORDING_HEADER_ID;\n        }\n\n        @Override\n        public ZipShort getLocalFileDataLength() {\n            return new ZipShort(0);\n        }\n\n        @Override\n        public ZipShort getCentralDirectoryLength() {\n            return getLocalFileDataLength();\n        }\n\n        @Override\n        public byte[] getLocalFileDataData() {\n            return new byte[0];\n        }\n\n        @Override\n        public byte[] getCentralDirectoryData() {\n            return getLocalFileDataData();\n        }\n\n        @Override\n        public void parseFromLocalFileData(byte[] data, int offset, int length) throws ZipException {\n            assertThat(length).isEqualTo(0);\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 933, "output": 1384, "cacheRead": 30208, "cacheWrite": 0, "totalTokens": 32525, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778130949139, "responseId": "resp_0d1d2245e6332b780169fc2005952c81978576fa9d77d38d13"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_Il2TA79PGSa6HHYdeunjwvmm|fc_0d1d2245e6332b780169fc2013556081979801512816904c5b", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2158 bytes to tests/src/ant/ant/1.6/src/test/java/ant/ant/ExtraFieldUtilsTest.java"}], "isError": false, "timestamp": 1778130966567}]}
