              while (urls.hasMoreElements()) {
                  URL url = (URL) urls.nextElement();
  
                  int format = this.format;
                  if (url.toString().toLowerCase(Locale.US).endsWith(".xml")) {
                      format = Format.XML;
                  }
  
                  if (format == Format.PROPERTIES) {
                      loadProperties(al, url);
                      break;
