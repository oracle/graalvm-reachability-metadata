          if (!definerSet) {
              throw new BuildException(
                  "name, file or resource attribute of "
                  + getTaskName() + " is undefined", getLocation());
          }
  
          if (name != null) {
              if (classname == null) {
                  throw new BuildException(
                      "classname attribute of " + getTaskName() + " element "
                      + "is undefined", getLocation());
              }
              addDefinition(al, name, classname);
          } else {
              if (classname != null) {
