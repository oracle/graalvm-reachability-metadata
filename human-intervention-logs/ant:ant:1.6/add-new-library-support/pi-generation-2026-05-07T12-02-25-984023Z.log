       */
      public void setNamespace(String namespace) {
          if (namespace.equals(ProjectHelper.ANT_CURRENT_URI)) {
              ComponentHelper helper = ComponentHelper.getComponentHelper(
                  getProject());
              namespace = helper.getCurrentAntlibUri();
          }
