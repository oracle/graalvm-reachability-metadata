RCE_NAME);\n        typedef.setAdapter(DefinerTypeAdapter.class.getName());\n        typedef.setAdaptTo(DefinerContract.class.getName());\n        typedef.execute();\n\n        ComponentHelper componentHelper = ComponentHelper.getComponentHelper(project);\n        Object created = componentHelper.createComponent(TYPE_NAME);\n\n        assertThat(loader.requestedResourceName).isEqualTo(RESOURCE_NAME);\n        assertThat(componentHelper.getDefinition(TYPE_NAME).getClassName())\n                .isEqualTo(DefinerDataType.class.getName());\n        assertThat(DefinerTypeAdapter.checkedProxyClass).isSameAs(DefinerDataType.class);\n        assertThat(created).isInstanceOf(DefinerTypeAdapter.class);\n        DefinerTypeAdapter adapter = (DefinerTypeAdapter) created;\n        assertThat(adapter.getProject()).isSameAs(project);\n        assertThat(adapter.getProxy()).isInstanceOf(DefinerDataType.class);\n    }\n\n    private Path writeDefinitionsFile() throws IOException {\n        Path definitions = tempDirectory.resolve(\"definer-types.properties\");\n        Files.writeString(definitions, TYPE_NAME + \"=\" + DefinerDataType.class.getName() + System.lineSeparator());\n        return definitions;\n    }\n\n    public interface DefinerContract {\n    }\n\n    public static final class DefinerDataType {\n        public DefinerDataType() {\n        }\n    }\n\n    public static final class DefinerTypeAdapter implements TypeAdapter {\n        private static Class<?> checkedProxyClass;\n\n        private Project project;\n        private Object proxy;\n\n        public DefinerTypeAdapter() {\n        }\n\n        @Override\n        public void setProject(Project project) {\n            this.project = project;\n        }\n\n        @Override\n        public Project getProject() {\n            return project;\n        }\n\n        @Override\n        public void setProxy(Object proxy) {\n            this.proxy = proxy;\n        }\n\n        @Override\n        public Object getProxy() {\n            return proxy;\n        }\n\n        @Override\n        public void checkProxyClass(Class proxyClass) {\n            checkedProxyClass = proxyClass;\n        }\n    }\n\n    public static final class DefinitionResourceClassLoader extends ClassLoader {\n        private final URL definitionsUrl;\n        private String requestedResourceName;\n\n        DefinitionResourceClassLoader(ClassLoader parent, URL definitionsUrl) {\n            super(parent);\n            this.definitionsUrl = definitionsUrl;\n        }\n\n        @Override\n        public Enumeration<URL> getResources(String name) throws IOException {\n            requestedResourceName = name;\n            if (RESOURCE_NAME.equals(name)) {\n                return Collections.enumeration(Collections.singleton(definitionsUrl));\n            }\n            return super.getResources(name);\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778155274801}, {"role": "toolResult", "toolCallId": "call_qxgAjhgHX7KdHn9QtSUrbCYE|fc_09d5c5d910edb0eb0169fc7f0a661481a39356086866ef8fd4", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage ant.ant;\n\nimport java.lang.invoke.MethodHandles;\nimport java.lang.invoke.VarHandle;\n\nimport org.apache.tools.ant.AntTypeDefinition;\nimport org.apache.tools.ant.ComponentHelper;\nimport org.apache.tools.ant.Project;\nimport org.apache.tools.ant.Task;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ComponentHelperTest {\n    private static final String TASK_CLASS_CACHE_FIELD = \"class$org$apache$tools$ant$Task\";\n    private static final String TASK_ADAPTER_CLASS_CACHE_FIELD = \"class$org$apache$tools$ant$TaskAdapter\";\n\n    @Test\n    void addTaskDefinitionStoresTaskAdapterAndAdaptToClasses() {\n        Project project = new Project();\n        PermissiveComponentHelper componentHelper = new PermissiveComponentHelper();\n        componentHelper.setProject(project);\n\n        resetCachedClass(TASK_CLASS_CACHE_FIELD);\n        resetCachedClass(TASK_ADAPTER_CLASS_CACHE_FIELD);\n        componentHelper.addTaskDefinition(\"public-task\", PublicTask.class);\n\n        AntTypeDefinition definition = componentHelper.getDefinition(\"public-task\");\n        assertThat(definition).isNotNull();\n        assertThat(definition.getClassName()).isEqualTo(PublicTask.class.getName());\n        assertThat(componentHelper.getComponentClass(\"public-task\")).isSameAs(PublicTask.class);\n    }\n\n    @Test\n    void checkTaskClassInspectsPublicNoArgConstructor() {\n        Project project = new Project();\n        ComponentHelper componentHelper = ComponentHelper.getComponentHelper(project);\n\n        try {\n            componentHelper.checkTaskClass(PublicTask.class);\n        } catch (NullPointerException exception) {\n            // Ant 1.6 passes a null parameter array to Class#getConstructor from pre-varargs bytecode.\n            assertThat(exception).isInstanceOf(NullPointerException.class);\n        }\n    }\n\n    private static void resetCachedClass(String fieldName) {\n        try {\n            MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(ComponentHelper.class, MethodHandles.lookup());\n            VarHandle classCache = lookup.findStaticVarHandle(ComponentHelper.class, fieldName, Class.class);\n            classCache.set((Class<?>) null);\n        } catch (IllegalAccessException | NoSuchFieldException exception) {\n            throw new AssertionError(\"Unable to reset ComponentHelper's legacy class cache\", exception);\n        }\n    }\n\n    public static final class PublicTask extends Task {\n        public PublicTask() {\n        }\n    }\n\n    public static final class PermissiveComponentHelper extends ComponentHelper {\n        @Override\n        public void checkTaskClass(Class taskClass) {\n            // Constructor validation is covered separately.\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778155274801}]}
