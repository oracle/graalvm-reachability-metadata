  package ant.ant;
  
  import java.lang.invoke.MethodHandle;
  import java.lang.invoke.MethodHandles;
  import java.lang.invoke.MethodType;
  import java.lang.invoke.VarHandle;
  import java.util.concurrent.atomic.AtomicInteger;
  
  import org.apache.tools.ant.Project;
  import org.apache.tools.ant.Task;
  import org.apache.tools.ant.taskdefs.Parallel;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ParallelTest {
      @Test
      void legacyClassLiteralHelperLoadsRuntimeClassByName() throws Throwable {
          MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(Parallel.class, MethodHandles.lookup());
          MethodHandle classLiteralHelper = lookup.findStatic(
              Parallel.class,
              "class$",
              MethodType.methodType(Class.class, String.class));
  
          Object loadedClass = classLiteralHelper.invoke("java.lang.Runtime");
  
          assertThat(loadedClass).isSameAs(Runtime.class);
      }
  
      @Test
      void executeUsesRuntimeProcessorCountWhenThreadsPerProcessorIsConfigured() throws Throwable {
          Project project = new Project();
          project.init();
          AtomicInteger executions = new AtomicInteger();
  
          Parallel parallel = new Parallel();
          parallel.setProject(project);
          parallel.setThreadsPerProcessor(1);
          parallel.addTask(new CountingTask(project, executions));
          MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(Parallel.class, MethodHandles.lookup());
          VarHandle runtimeClass = lookup.findStaticVarHandle(
              Parallel.class,
              "class$java$lang$Runtime",
              Class.class);
          Object previousRuntimeClass = runtimeClass.get();
          try {
              runtimeClass.set(null);
  
              parallel.execute();
  
              assertThat(executions).hasValue(1);
              assertThat(runtimeClass.get()).isSameAs(Runtime.class);
          } finally {
              runtimeClass.set(previousRuntimeClass);
          }
      }
  
      private static final class CountingTask extends Task {
          private final AtomicInteger executions;
  
          private CountingTask(Project project, AtomicInteger executions) {
              setProject(project);
              this.executions = executions;
          }
  
          @Override
          public void execute() {
              executions.incrementAndGet();
          }
      }
  }
