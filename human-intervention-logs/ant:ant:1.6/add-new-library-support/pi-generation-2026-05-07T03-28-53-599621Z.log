  package ant.ant;
  
  import java.lang.reflect.Field;
  import java.lang.reflect.InvocationTargetException;
  import java.lang.reflect.Method;
  import java.net.URL;
  import java.net.URLClassLoader;
  import java.security.CodeSource;
  
  import org.apache.tools.ant.BuildException;
  import org.apache.tools.ant.Task;
  import org.apache.tools.ant.taskdefs.Javac;
  import org.apache.tools.ant.taskdefs.compilers.CompilerAdapter;
  import org.apache.tools.ant.taskdefs.compilers.CompilerAdapterFactory;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class CompilerAdapterFactoryTest {
      @Test
      void legacyClassLiteralHelperLoadsFactoryClassByName() throws Exception {
          Method classLiteralHelper = CompilerAdapterFactory.class.getDeclaredMethod("class$", String.class);
          classLiteralHelper.setAccessible(true);
  
          Object loadedClass = classLiteralHelper.invoke(
              null,
              "org.apache.tools.ant.taskdefs.compilers.CompilerAdapterFactory");
  
          assertThat(loadedClass).isSameAs(CompilerAdapterFactory.class);
      }
  
      @Test
      void getCompilerLoadsCustomCompilerAdapterClassByName() {
          String adapterClassName = RecordingCompilerAdapter.class.getName();
  
          CompilerAdapter adapter = CompilerAdapterFactory.getCompiler(adapterClassName, new Javac());
  
          assertThat(adapter).isInstanceOf(RecordingCompilerAdapter.class);
          RecordingCompilerAdapter recordingAdapter = (RecordingCompilerAdapter) adapter;
          Javac javac = new Javac();
          recordingAdapter.setJavac(javac);
          assertThat(recordingAdapter.javac).isSameAs(javac);
          assertThat(recordingAdapter.execute()).isTrue();
      }
  
      @Test
      void modernCompilerLookupUsesLegacyClassLiteralHelperWhenJavacMainIsHidden() throws Exception {
          try (JavacMainHidingClassLoader hidingClassLoader = JavacMainHidingClassLoader.create()) {
              Class<?> factoryClass = Class.forName(CompilerAdapterFactory.class.getName(), true, hidingClassLoader);
              Method getCompiler = factoryClass.getMethod("getCompiler", String.class, Task.class);
  
              try {
                  getCompiler.invoke(null, "modern", null);
                  throw new AssertionError("Expected the hidden modern compiler lookup to fail");
              } catch (InvocationTargetException exception) {
                  assertThat(exception.getCause())
                      .isInstanceOf(BuildException.class)
                      .hasMessageContaining("Unable to find a javac compiler");
                  Field cachedFactoryClass = factoryClass.getDeclaredField(
                      "class$org$apache$tools$ant$taskdefs$compilers$CompilerAdapterFactory");
                  cachedFactoryClass.setAccessible(true);
                  assertThat(cachedFactoryClass.get(null)).isSameAs(factoryClass);
              }
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
      }
  
      public static final class RecordingCompilerAdapter implements CompilerAdapter {
          private Javac javac;
  
          @Override
          public void setJavac(Javac attributes) {
              javac = attributes;
          }
  
          @Override
          public boolean execute() throws BuildException {
              return javac != null;
          }
      }
  
      private static final class JavacMainHidingClassLoader extends URLClassLoader {
          private static final String FACTORY_CLASS_NAME = CompilerAdapterFactory.class.getName();
          private static final String MODERN_COMPILER_CLASS_NAME = "com.sun.tools.javac.Main";
  
          private JavacMainHidingClassLoader(URL[] urls, ClassLoader parent) {
              super(urls, parent);
          }
  
          private static JavacMainHidingClassLoader create() {
              CodeSource codeSource = CompilerAdapterFactory.class.getProtectionDomain().getCodeSource();
              if (codeSource == null) {
                  throw new AssertionError("Unable to locate the Ant classes code source");
              }
              return new JavacMainHidingClassLoader(
                  new URL[] {codeSource.getLocation()},
                  CompilerAdapterFactoryTest.class.getClassLoader());
          }
  
          @Override
          protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {
              if (MODERN_COMPILER_CLASS_NAME.equals(name)) {
                  throw new ClassNotFoundException(name);
              }
              synchronized (getClassLoadingLock(name)) {
                  Class<?> loadedClass = findLoadedClass(name);
                  if (loadedClass == null) {
                      if (FACTORY_CLASS_NAME.equals(name)) {
                          loadedClass = findClass(name);
                      } else {
                          loadedClass = super.loadClass(name, false);
                      }
                  }
                  if (resolve) {
                      resolveClass(loadedClass);
                  }
                  return loadedClass;
              }
          }
