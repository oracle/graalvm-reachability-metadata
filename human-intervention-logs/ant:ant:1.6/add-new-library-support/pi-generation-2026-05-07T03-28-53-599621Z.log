RY_CLASS_NAME = CompilerAdapterFactory.class.getName();\n        private static final String MODERN_COMPILER_CLASS_NAME = \"com.sun.tools.javac.Main\";\n\n        private JavacMainHidingClassLoader(ClassLoader parent) {\n            super(parent);\n        }\n\n        @Override\n        protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {\n            if (MODERN_COMPILER_CLASS_NAME.equals(name)) {\n                throw new ClassNotFoundException(name);\n            }\n            synchronized (getClassLoadingLock(name)) {\n                Class<?> loadedClass = findLoadedClass(name);\n                if (loadedClass == null) {\n                    if (FACTORY_CLASS_NAME.equals(name)) {\n                        loadedClass = loadFactoryClass();\n                    } else {\n                        loadedClass = super.loadClass(name, false);\n                    }\n                }\n                if (resolve) {\n                    resolveClass(loadedClass);\n                }\n                return loadedClass;\n            }\n        }\n\n        private Class<?> loadFactoryClass() throws ClassNotFoundException {\n            String resourceName = FACTORY_CLASS_NAME.replace('.', '/') + \".class\";\n            try (InputStream inputStream = getParent().getResourceAsStream(resourceName)) {\n                if (inputStream == null) {\n                    throw new ClassNotFoundException(FACTORY_CLASS_NAME);\n                }\n                byte[] classBytes = inputStream.readAllBytes();\n                return defineClass(FACTORY_CLASS_NAME, classBytes, 0, classBytes.length);\n            } catch (IOException exception) {\n                throw new ClassNotFoundException(FACTORY_CLASS_NAME, exception);\n            }\n        }\n    }\n}\n"}]}
