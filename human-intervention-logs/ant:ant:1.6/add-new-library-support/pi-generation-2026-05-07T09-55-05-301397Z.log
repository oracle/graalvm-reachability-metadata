  package ant.ant;
  
  import java.io.File;
  import java.io.IOException;
  import java.io.InputStream;
  import java.net.URL;
  import java.nio.file.Files;
  import java.nio.file.Path;
  import java.util.Base64;
  
  import org.apache.tools.ant.AntClassLoader;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  import static org.assertj.core.api.Assertions.assertThatThrownBy;
  import static org.assertj.core.api.Assertions.fail;
  
  public class AntClassLoaderTest {
      private static final String TEST_CLASS_RESOURCE = "ant/ant/AntClassLoaderTest.class";
  
      @Test
      void initializeClassUsesDeclaredConstructorCompatibilityPath() {
          AntClassLoader.initializeClass(InitializationTarget.class);
          AntClassLoader.initializeClass(AntClassLoader.class);
          AntClassLoader.initializeClass(String.class);
  
          assertThat(InitializationTarget.initialized).isTrue();
      }
  
      @Test
      void defaultConstructorUsesAntClassLoaderParent() throws ClassNotFoundException {
          AntClassLoader loader = new AntClassLoader();
          try {
              Class<?> systemClass = loader.forceLoadSystemClass(Long.class.getName());
              assertThat(systemClass).isSameAs(Long.class);
          } finally {
              loader.cleanup();
          }
      }
  
      @Test
      void nullParentConstructorUsesAntClassLoaderParent() throws ClassNotFoundException {
          AntClassLoader loader = new AntClassLoader(null, true);
          try {
              Class<?> systemClass = loader.forceLoadSystemClass(Short.class.getName());
              assertThat(systemClass).isSameAs(Short.class);
          } finally {
              loader.cleanup();
          }
      }
  
      @Test
      void getResourceConsultsParentBeforeAndAfterLoaderPath() {
          AntClassLoader loader = new AntClassLoader(getClass().getClassLoader(), true);
          try {
              URL parentFirstResource = loader.getResource(TEST_CLASS_RESOURCE);
              assertThat(parentFirstResource).isNotNull();
  
              loader.setParentFirst(false);
              URL parentFallbackResource = loader.getResource(TEST_CLASS_RESOURCE);
              assertThat(parentFallbackResource).isNotNull();
          } finally {
              loader.cleanup();
          }
      }
  
      @Test
      void getResourceAsStreamConsultsParentLoader() throws IOException {
          AntClassLoader loader = new AntClassLoader(getClass().getClassLoader(), true);
          try (InputStream stream = loader.getResourceAsStream(TEST_CLASS_RESOURCE)) {
              assertThat(stream).isNotNull();
              assertThat(stream.read()).isNotNegative();
          } finally {
              loader.cleanup();
          }
      }
  
      @Test
      void getResourceAsStreamFallsBackToSystemLoaderWhenParentIsNull() throws IOException {
          AntClassLoader loader = new NoParentAntClassLoader();
          try (InputStream stream = loader.getResourceAsStream("java/lang/String.class")) {
              if (stream != null) {
                  assertThat(stream.read()).isNotNegative();
              }
          } finally {
              loader.cleanup();
          }
      }
  
      @Test
      void forceLoadSystemClassUsesFindSystemClassWhenParentIsNull() throws ClassNotFoundException {
          AntClassLoader loader = new NoParentAntClassLoader();
          try {
              Class<?> systemClass = loader.forceLoadSystemClass(String.class.getName());
              assertThat(systemClass).isSameAs(String.class);
          } finally {
              loader.cleanup();
          }
      }
  
      @Test
      void classLookupUsesParentDelegationAndForceLoadEntryPoints() throws ClassNotFoundException {
          AntClassLoader loader = new AntClassLoader(getClass().getClassLoader(), true);
          try {
              Class<?> loadedByParent = loader.loadClass(String.class.getName());
              assertThat(loadedByParent).isSameAs(String.class);
  
              Class<?> forceLoadedSystemClass = loader.forceLoadSystemClass(Integer.class.getName());
              assertThat(forceLoadedSystemClass).isSameAs(Integer.class);
  
              assertThatThrownBy(() -> loader.forceLoadClass("ant.ant.DoesNotExist"))
                  .isInstanceOf(ClassNotFoundException.class);
          } finally {
              loader.cleanup();
          }
      }
  
      @Test
      void defineClassFromDataUsesProtectionDomainReflectionPath() throws IOException {
          ExposedAntClassLoader loader = new ExposedAntClassLoader(getClass().getClassLoader(), false);
          try {
              try {
                  loader.defineInvalidClass("ant.ant.InvalidClassBytes");
                  fail("Invalid class bytes should not define a class");
              } catch (ClassFormatError expected) {
                  assertThat(expected).isNotNull();
              } catch (Error error) {
                  if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                      throw error;
                  }
              } catch (IOException expectedOnStronglyEncapsulatedJdks) {
                  String message = expectedOnStronglyEncapsulatedJdks.getMessage();
                  assertThat(message).isNotNull();
                  assertThat(message.contains("IllegalAccess") || message.contains("UnsupportedFeatureError"))
                      .isTrue();
              }
          } finally {
              loader.cleanup();
          }
      }
  
      @Test
      void forceLoadClassDefinesClassFromLoaderPath() throws IOException, ClassNotFoundException {
          Path tempDirectory = Files.createTempDirectory("ant-class-loader");
          Path packageDirectory = tempDirectory.resolve("ant").resolve("ant");
          Path classFile = packageDirectory.resolve("GeneratedAntClassLoaderTarget.class");
          AntClassLoader loader = new AntClassLoader(getClass().getClassLoader(), false);
          try {
              Files.createDirectories(packageDirectory);
              Files.write(classFile, generatedClassBytes());
  
              loader.addPathElement(tempDirectory.toFile().getAbsolutePath());
              try {
                  Class<?> loadedClass = loader.forceLoadClass("ant.ant.GeneratedAntClassLoaderTarget");
                  assertThat(loadedClass.getName()).isEqualTo("ant.ant.GeneratedAntClassLoaderTarget");
                  assertThat(loadedClass.getClassLoader()).isSameAs(loader);
              } catch (ClassNotFoundException expectedWhenRuntimeDefinitionIsRejected) {
                  assertThat(expectedWhenRuntimeDefinitionIsRejected)
                      .hasMessage("ant.ant.GeneratedAntClassLoaderTarget");
              } catch (Error error) {
                  if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                      throw error;
                  }
              }
          } finally {
              loader.cleanup();
              Files.deleteIfExists(classFile);
              Files.deleteIfExists(packageDirectory);
              Files.deleteIfExists(packageDirectory.getParent());
              Files.deleteIfExists(tempDirectory);
          }
      }
  
      @Test
      void forceLoadFreshAntClassLoaderCopyRunsStaticCompatibilityHelper() throws IOException, ClassNotFoundException {
          Path tempDirectory = Files.createTempDirectory("fresh-ant-class-loader");
          Path packageDirectory = tempDirectory.resolve("org").resolve("apache").resolve("tools").resolve("ant");
          Path classFile = packageDirectory.resolve("AntClassLoader.class");
          AntClassLoader loader = new AntClassLoader(getClass().getClassLoader(), false);
          try (InputStream classBytes = AntClassLoader.class.getResourceAsStream("AntClassLoader.class")) {
              assertThat(classBytes).isNotNull();
              Files.createDirectories(packageDirectory);
              Files.write(classFile, classBytes.readAllBytes());
  
              loader.addPathElement(tempDirectory.toFile().getAbsolutePath());
              try {
                  Class<?> reloadedClass = loader.forceLoadClass(AntClassLoader.class.getName());
                  assertThat(reloadedClass.getName()).isEqualTo(AntClassLoader.class.getName());
                  assertThat(reloadedClass.getClassLoader())
                      .isIn(loader, AntClassLoader.class.getClassLoader());
  
                  AntClassLoader.initializeClass(reloadedClass);
              } catch (Error error) {
                  if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                      throw error;
                  }
              }
          } finally {
              loader.cleanup();
              Files.deleteIfExists(classFile);
              Files.deleteIfExists(packageDirectory);
              Files.deleteIfExists(packageDirectory.getParent());
              Files.deleteIfExists(packageDirectory.getParent().getParent());
              Files.deleteIfExists(packageDirectory.getParent().getParent().getParent());
              Files.deleteIfExists(packageDirectory.getParent().getParent().getParent().getParent());
              Files.deleteIfExists(tempDirectory);
          }
      }
  
