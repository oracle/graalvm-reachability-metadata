  package ant.ant;
  
  import org.apache.tools.ant.Project;
  import org.apache.tools.ant.taskdefs.Property;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class PropertyTest {
      private static final String ANT_DEFAULT_TASKS_RESOURCE =
          "org/apache/tools/ant/taskdefs/defaults.properties";
  
      @Test
      void executeLoadsPropertiesFromResource() {
          Project project = new Project();
          Property property = new Property();
          property.setProject(project);
          property.setPrefix("ant.task");
          property.setResource(ANT_DEFAULT_TASKS_RESOURCE);
  
          property.execute();
  
          assertThat(project.getProperty("ant.task.property"))
              .isEqualTo("org.apache.tools.ant.taskdefs.Property");
      }
  }
