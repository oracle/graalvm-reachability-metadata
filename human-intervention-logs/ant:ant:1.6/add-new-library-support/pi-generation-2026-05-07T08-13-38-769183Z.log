  package ant.ant;
  
  import java.lang.invoke.MethodHandles;
  import java.lang.invoke.VarHandle;
  
  import org.apache.tools.ant.ComponentHelper;
  import org.apache.tools.ant.Project;
  import org.apache.tools.ant.Task;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ProjectTest {
      private static final String COMPONENT_HELPER_REFERENCE = "ant.ComponentHelper";
      private static final String PROJECT_CLASS_CACHE_FIELD = "class$org$apache$tools$ant$Project";
  
      @Test
      void checkTaskClassInspectsPublicNoArgConstructor() {
          Project project = new Project();
          PermissiveComponentHelper componentHelper = new PermissiveComponentHelper();
          componentHelper.setProject(project);
          project.addReference(COMPONENT_HELPER_REFERENCE, componentHelper);
  
          try {
              project.checkTaskClass(PublicTask.class);
          } catch (NullPointerException exception) {
              // Ant 1.6 passes a null parameter array to Class#getConstructor from pre-varargs bytecode.
              assertThat(exception).isInstanceOf(NullPointerException.class);
          }
      }
  
      @Test
      void setProjectReferenceResolvesProjectParameterTypeForPlainObjects() {
          Project project = new Project();
          ProjectAwareObject object = new ProjectAwareObject();
  
          resetCachedProjectClass();
          project.setProjectReference(object);
  
          assertThat(object.project).isSameAs(project);
      }
  
      private static void resetCachedProjectClass() {
          try {
              MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(Project.class, MethodHandles.lookup());
              VarHandle projectClassCache = lookup.findStaticVarHandle(
                      Project.class,
                      PROJECT_CLASS_CACHE_FIELD,
                      Class.class
              );
              projectClassCache.set((Class<?>) null);
          } catch (IllegalAccessException | NoSuchFieldException exception) {
              throw new AssertionError("Unable to reset Project's legacy Project class cache", exception);
          }
      }
  
      public static final class PublicTask extends Task {
          public PublicTask() {
          }
      }
  
      public static final class ProjectAwareObject {
          private Project project;
  
          public void setProject(Project project) {
              this.project = project;
          }
      }
  
      public static final class PermissiveComponentHelper extends ComponentHelper {
          @Override
          public void checkTaskClass(Class taskClass) {
              // Constructor validation is covered by Project.
          }
      }
  }
