     323	     *                  Must not be <code>null</code>.
     324	     *
     325	     * @exception BuildException if the class is unsuitable for being an Ant
     326	     *                           task. An error level message is logged before
     327	     *                           this exception is thrown.
     328	     */
     329	    public void checkTaskClass(final Class taskClass) throws BuildException {
     330	        if (!Modifier.isPublic(taskClass.getModifiers())) {
     331	            final String message = taskClass + " is not public";
     332	            project.log(message, Project.MSG_ERR);
     333	            throw new BuildException(message);
     334	        }
     335	        if (Modifier.isAbstract(taskClass.getModifiers())) {
     336	            final String message = taskClass + " is abstract";
     337	            project.log(message, Project.MSG_ERR);
     338	            throw new BuildException(message);
     339	        }
     340	        try {
     341	            taskClass.getConstructor(null);
     342	            // don't have to check for public, since
     343	            // getConstructor finds public constructors only.
     344	        } catch (NoSuchMethodException e) {
     345	            final String message = "No public no-arg constructor in "
     346	                    + taskClass;
     347	            project.log(message, Project.MSG_ERR);
     348	            throw new BuildException(message);
     349	        }
     350	        if (!Task.class.isAssignableFrom(taskClass)) {
     351	            TaskAdapter.checkTaskClass(taskClass, project);
     352	        }
     353	    }
