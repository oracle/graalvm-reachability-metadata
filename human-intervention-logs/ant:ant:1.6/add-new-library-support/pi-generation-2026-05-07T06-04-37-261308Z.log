  package ant.ant;
  
  import java.lang.invoke.MethodHandles;
  import java.lang.invoke.VarHandle;
  
  import org.apache.tools.ant.AntTypeDefinition;
  import org.apache.tools.ant.ComponentHelper;
  import org.apache.tools.ant.Project;
  import org.apache.tools.ant.Task;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ComponentHelperTest {
      private static final String TASK_CLASS_CACHE_FIELD = "class$org$apache$tools$ant$Task";
      private static final String TASK_ADAPTER_CLASS_CACHE_FIELD = "class$org$apache$tools$ant$TaskAdapter";
  
      @Test
      void addTaskDefinitionStoresTaskAdapterAndAdaptToClasses() {
          Project project = new Project();
          PermissiveComponentHelper componentHelper = new PermissiveComponentHelper();
          componentHelper.setProject(project);
  
          resetCachedClass(TASK_CLASS_CACHE_FIELD);
          resetCachedClass(TASK_ADAPTER_CLASS_CACHE_FIELD);
          componentHelper.addTaskDefinition("public-task", PublicTask.class);
  
          AntTypeDefinition definition = componentHelper.getDefinition("public-task");
          assertThat(definition).isNotNull();
          assertThat(definition.getClassName()).isEqualTo(PublicTask.class.getName());
          assertThat(componentHelper.getComponentClass("public-task")).isSameAs(PublicTask.class);
      }
  
      @Test
      void checkTaskClassInspectsPublicNoArgConstructor() {
          Project project = new Project();
          ComponentHelper componentHelper = ComponentHelper.getComponentHelper(project);
  
          try {
              componentHelper.checkTaskClass(PublicTask.class);
          } catch (NullPointerException exception) {
              // Ant 1.6 passes a null parameter array to Class#getConstructor from pre-varargs bytecode.
              assertThat(exception).isInstanceOf(NullPointerException.class);
          }
      }
  
      private static void resetCachedClass(String fieldName) {
          try {
              MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(ComponentHelper.class, MethodHandles.lookup());
              VarHandle classCache = lookup.findStaticVarHandle(ComponentHelper.class, fieldName, Class.class);
              classCache.set((Class<?>) null);
          } catch (IllegalAccessException | NoSuchFieldException exception) {
              throw new AssertionError("Unable to reset ComponentHelper's legacy class cache", exception);
          }
      }
  
      public static final class PublicTask extends Task {
          public PublicTask() {
          }
      }
  
      public static final class PermissiveComponentHelper extends ComponentHelper {
          @Override
          public void checkTaskClass(Class taskClass) {
              // Constructor validation is covered separately.
          }
      }
  }
