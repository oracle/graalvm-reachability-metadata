[tool-exec] end id=call_LuNg831XNGBvf5mZfjYnYKGu|fc_0f717fba81042b930169fc2ae944948194a8eceb71d15a7039 name=read status=success
  /*
   * Copyright and related rights waived via CC0
   *
   * You should have received a copy of the CC0 legalcode along with this
   * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.
   */
  plugins {
      id "org.graalvm.internal.tck"
  }
  
  String libraryVersion = tck.testedLibraryVersion.get()
  
  configurations {
      jacocoRuntimeAgent
  }
  
  dependencies {
      testImplementation "ant:ant:$libraryVersion"
      testImplementation "ant:ant-launcher:$libraryVersion"
      testImplementation "ant:ant-nodeps:$libraryVersion"
      testImplementation "ant:ant-trax:$libraryVersion"
      testImplementation "ant:ant-xalan1:$libraryVersion"
      testImplementation "ant:ant-xslp:$libraryVersion"
      testImplementation 'xml-resolver:xml-resolver:1.2'
      jacocoRuntimeAgent "org.jacoco:org.jacoco.agent:${jacoco.toolVersion}:runtime"
      testImplementation 'org.assertj:assertj-core:3.22.0'
  }
  
  jar {
      from sourceSets.test.output
  }
  
  tasks.withType(Test).configureEach {
      jvmArgs '--add-opens=java.base/java.lang=ALL-UNNAMED'
  }
  
  def availableBootstrapTest = tasks.register('availableBootstrapTest', Test) {
      description = 'Runs AvailableTest with ant appended to the bootstrap class path.'
      group = 'verification'
      testClassesDirs = sourceSets.test.output.classesDirs
      classpath = sourceSets.test.runtimeClasspath
      include 'ant/ant/AvailableTest.class'
      shouldRunAfter tasks.named('test')
      useJUnitPlatform()
  
      if (extensions.findByName('jacoco') != null) {
          jacoco.enabled = false
      }
  
      doFirst {
          File antJar = configurations.testRuntimeClasspath.files.find { File file ->
              file.name == "ant-${libraryVersion}.jar"
          }
          if (antJar == null) {
              throw new GradleException("Could not find ant:${libraryVersion} on the test runtime classpath")
          }
          File jacocoAgent = configurations.jacocoRuntimeAgent.singleFile
          File jacocoDestination = layout.buildDirectory.file('jacoco/availableBootstrapTest.exec').get().asFile
          jvmArgs "-Xbootclasspath/a:${antJar.absolutePath}",
                  "-javaagent:${jacocoAgent.absolutePath}=destfile=${jacocoDestination.absolutePath},append=false,inclbootstrapclasses=true,includes=org.apache.tools.ant.taskdefs.Available"
      }
  }
  
  tasks.named('test') {
      finalizedBy availableBootstrapTest
  }
  
