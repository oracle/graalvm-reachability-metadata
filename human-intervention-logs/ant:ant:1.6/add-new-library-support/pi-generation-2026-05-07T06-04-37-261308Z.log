  package ant.ant;
  
  import java.io.IOException;
  import java.net.URL;
  import java.nio.file.Files;
  import java.nio.file.Path;
  import java.util.Collections;
  import java.util.Enumeration;
  
  import org.apache.tools.ant.ComponentHelper;
  import org.apache.tools.ant.Project;
  import org.apache.tools.ant.TypeAdapter;
  import org.apache.tools.ant.taskdefs.Typedef;
  import org.junit.jupiter.api.Test;
  import org.junit.jupiter.api.io.TempDir;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class DefinerTest {
      private static final String RESOURCE_NAME = "ant/ant/definer-types.properties";
      private static final String TYPE_NAME = "resource-defined-type";
  
      @TempDir
      Path tempDirectory;
  
      @Test
      void resourceTypedefLoadsDefinitionAdapterAndAdaptToClasses() throws IOException {
          Project project = new Project();
          project.init();
          Path definitions = writeDefinitionsFile();
          DefinitionResourceClassLoader loader = new DefinitionResourceClassLoader(
                  getClass().getClassLoader(),
                  definitions.toUri().toURL()
          );
          DefinerTypeAdapter.checkedProxyClass = null;
  
          Typedef typedef = new Typedef();
          typedef.setProject(project);
          typedef.setAntlibClassLoader(loader);
          typedef.setResource(RESOURCE_NAME);
          typedef.setAdapter(DefinerTypeAdapter.class.getName());
          typedef.setAdaptTo(DefinerContract.class.getName());
          typedef.execute();
  
          ComponentHelper componentHelper = ComponentHelper.getComponentHelper(project);
          Object created = componentHelper.createComponent(TYPE_NAME);
  
          assertThat(loader.requestedResourceName).isEqualTo(RESOURCE_NAME);
          assertThat(componentHelper.getDefinition(TYPE_NAME).getClassName())
                  .isEqualTo(DefinerDataType.class.getName());
          assertThat(DefinerTypeAdapter.checkedProxyClass).isSameAs(DefinerDataType.class);
          assertThat(created).isInstanceOf(DefinerTypeAdapter.class);
          DefinerTypeAdapter adapter = (DefinerTypeAdapter) created;
          assertThat(adapter.getProject()).isSameAs(project);
          assertThat(adapter.getProxy()).isInstanceOf(DefinerDataType.class);
      }
  
      private Path writeDefinitionsFile() throws IOException {
          Path definitions = tempDirectory.resolve("definer-types.properties");
          Files.writeString(definitions, TYPE_NAME + "=" + DefinerDataType.class.getName() + System.lineSeparator());
          return definitions;
      }
  
      public interface DefinerContract {
      }
  
      public static final class DefinerDataType {
          public DefinerDataType() {
          }
      }
  
      public static final class DefinerTypeAdapter implements TypeAdapter {
          private static Class<?> checkedProxyClass;
  
          private Project project;
          private Object proxy;
  
          public DefinerTypeAdapter() {
          }
  
          @Override
          public void setProject(Project project) {
              this.project = project;
          }
  
          @Override
          public Project getProject() {
              return project;
          }
  
          @Override
          public void setProxy(Object proxy) {
              this.proxy = proxy;
          }
  
          @Override
          public Object getProxy() {
              return proxy;
          }
  
          @Override
          public void checkProxyClass(Class proxyClass) {
              checkedProxyClass = proxyClass;
          }
      }
  
      public static final class DefinitionResourceClassLoader extends ClassLoader {
          private final URL definitionsUrl;
          private String requestedResourceName;
  
          DefinitionResourceClassLoader(ClassLoader parent, URL definitionsUrl) {
              super(parent);
              this.definitionsUrl = definitionsUrl;
          }
  
          @Override
          public Enumeration<URL> getResources(String name) throws IOException {
              requestedResourceName = name;
              if (RESOURCE_NAME.equals(name)) {
                  return Collections.enumeration(Collections.singleton(definitionsUrl));
              }
              return super.getResources(name);
          }
      }
  }
