s = lookup.findStaticVarHandle(\n            Main.class,\n            \"class$org$apache$tools$ant$Main\",\n            Class.class);\n        Object previousAntVersion = antVersion.get();\n        Object previousMainClass = mainClass.get();\n        try {\n            antVersion.set(null);\n            mainClass.set(null);\n\n            String version = Main.getAntVersion();\n\n            assertThat(version).startsWith(\"Apache Ant version \");\n            assertThat(mainClass.get()).isSameAs(Main.class);\n        } finally {\n            antVersion.set(previousAntVersion);\n            mainClass.set(previousMainClass);\n        }\n    }\n"}]}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 16929, "output": 1417, "cacheRead": 50688, "cacheWrite": 0, "totalTokens": 69034, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778105486054, "responseId": "resp_05006304cb6521f80169fbbc8f60f481a28e68a5020457ae5c"}}
