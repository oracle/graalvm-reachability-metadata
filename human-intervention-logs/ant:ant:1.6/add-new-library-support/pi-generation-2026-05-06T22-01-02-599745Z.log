[tool-call] delta {"path":"tests/src/ant/ant/1.6/src/test/java/ant/ant/MainTest.java","edits":[{"oldText":"import java.nio.file.Path;\nimport java.security.Permission;\nimport java.util.concurrent.atomic.AtomicInteger;","newText":"import java.nio.file.Path;\nimport java.util.concurrent.CountDownLatch;\nimport java.util.concurrent.TimeUnit;\nimport java.util.concurrent.atomic.AtomicInteger;"},{"oldText":"import static org.assertj.core.api.Assertions.assertThat;\nimport static org.assertj.core.api.Assertions.catchThrowableOfType;","newText":"import static org.assertj.core.api.Assertions.assertThat;"},{"oldText":"    @Test\n    void startAntLoadsConfiguredInputHandlerClassByNameBeforeRunningBuild() throws IOException {\n        Path buildFile = createBuildFile();\n        CustomInputHandler.reset();\n        SecurityManager previousSecurityManager = System.getSecurityManager();\n        ExitInterceptingSecurityManager exitSecurityManager = new ExitInterceptingSecurityManager();\n        System.setSecurityManager(exitSecurityManager);\n        try {\n            Main main = new Main();\n\n            ExitInterceptedException exit = catchThrowableOfType(\n                () -> main.startAnt(new String[] {\n                    \"-buildfile\", buildFile.toString(),\n                    \"-inputhandler\", CustomInputHandler.class.getName()\n                }, null, null),\n                ExitInterceptedException.class);\n\n            assertThat(exit).isNotNull();\n            assertThat(exit.status).isZero();\n            assertThat(CustomInputHandler.instances).hasValue(1);\n            assertThat(CustomInputHandler.project).isNotNull();\n        } finally {\n            System.setSecurityManager(previousSecurityManager);\n        }\n    }\n","newText":"    @Test\n    void startAntLoadsConfiguredInputHandlerClassByNameBeforeRunningBuild() throws IOException, InterruptedException {\n        Path buildFile = createBuildFile();\n        CustomInputHandler.reset();\n        Thread antThread = new Thread(\n            () -> new Main().startAnt(new String[] {\n                \"-buildfile\", buildFile.toString(),\n                \"-inputhandler\", CustomInputHandler.class.getName()\n            }, null, null),\n            \"ant-main-input-handler\");\n        antThread.setDaemon(true);\n\n        antThread.start();\n\n        assertThat(CustomInputHandler.projectReferenceSet.await(10, TimeUnit.SECONDS)).isTrue();\n        assertThat(CustomInputHandler.instances).hasValue(1);\n        assertThat(CustomInputHandler.project).isNotNull();\n    }\n"},{"oldText":"    public static final class CustomInputHandler implements InputHandler {\n        private static final AtomicInteger instances = new AtomicInteger();\n        private static Project project;\n\n        public CustomInputHandler() {\n            instances.incrementAndGet();\n        }\n\n        static void reset() {\n            instances.set(0);\n            project = null;\n        }\n\n        public void setProject(Project project) {\n            CustomInputHandler.project = project;\n        }\n\n        @Override\n        public void handleInput(InputRequest request) throws BuildException {\n            request.setInput(\"\");\n        }\n    }\n\n    private static final class ExitInterceptingSecurityManager extends SecurityManager {\n        @Override\n        public void checkPermission(Permission permission) {\n        }\n\n        @Override\n        public void checkPermission(Permission permission, Object context) {\n        }\n\n        @Override\n        public void checkExit(int status) {\n            throw new ExitInterceptedException(status);\n        }\n    }\n\n    private static final class ExitInterceptedException extends SecurityException {\n        private final int status;\n\n        ExitInterceptedException(int status) {\n            this.status = status;\n        }\n    }\n","newText":"    public static final class CustomInputHandler implements InputHandler {\n        private static final AtomicInteger instances = new AtomicInteger();\n        private static CountDownLatch projectReferenceSet;\n        private static CountDownLatch keepStartAntFromExiting;\n        private static Project project;\n\n        public CustomInputHandler() {\n            instances.incrementAndGet();\n        }\n\n        static void reset() {\n            instances.set(0);\n            projectReferenceSet = new CountDownLatch(1);\n            keepStartAntFromExiting = new CountDownLatch(1);\n            project = null;\n        }\n\n        public void setProject(Project project) throws InterruptedException {\n            CustomInputHandler.project = project;\n            projectReferenceSet.countDown();\n            keepStartAntFromExiting.await();\n        }\n\n        @Override\n        public void handleInput(InputRequest request) throws BuildException {\n            request.setInput(\"\");\n        }\n    }\n"}]}
