mageSupport;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\nimport static org.assertj.core.api.Assertions.assertThatThrownBy;\nimport static org.assertj.core.api.Assertions.fail;\n\npublic class AntClassLoaderTest {\n    private static final String TEST_CLASS_RESOURCE = \"ant/ant/AntClassLoaderTest.class\";\n\n    @Test\n    void initializeClassUsesDeclaredConstructorCompatibilityPath() {\n        AntClassLoader.initializeClass(InitializationTarget.class);\n        AntClassLoader.initializeClass(AntClassLoader.class);\n        AntClassLoader.initializeClass(String.class);\n\n        assertThat(InitializationTarget.initialized).isTrue();\n    }\n\n    @Test\n    void defaultConstructorUsesAntClassLoaderParent() throws ClassNotFoundException {\n        AntClassLoader loader = new AntClassLoader();\n        try {\n            Class<?> systemClass = loader.forceLoadSystemClass(Long.class.getName());\n            assertThat(systemClass).isSameAs(Long.class);\n        } finally {\n            loader.cleanup();\n        }\n    }\n\n    @Test\n    void nullParentConstructorUsesAntClassLoaderParent() throws ClassNotFoundException {\n        AntClassLoader loader = new AntClassLoader(null, true);\n        try {\n            Class<?> systemClass = loader.forceLoadSystemClass(Short.class.getName());\n            assertThat(systemClass).isSameAs(Short.class);\n        } finally {\n            loader.cleanup();\n        }\n    }\n\n    @Test\n    void getResourceConsultsParentBeforeAndAfterLoaderPath() {\n        AntClassLoader loader = new AntClassLoader(getClass().getClassLoader(), true);\n        try {\n            URL parentFirstResource = loader.getResource(TEST_CLASS_RESOURCE);\n            assertThat(parentFirstResource).isNotNull();\n\n            loader.setParentFirst(false);\n            URL parentFallbackResource = loader.getResource(TEST_CLASS_RESOURCE);\n            assertThat(parentFallbackResource).isNotNull();\n        } finally {\n            loader.cleanup();\n        }\n    }\n\n    @Test\n    void getResourceAsStreamConsultsParentLoader() throws IOException {\n        AntClassLoader loader = new AntClassLoader(getClass().getClassLoader(), true);\n        try (InputStream stream = loader.getResourceAsStream(TEST_CLASS_RESOURCE)) {\n            assertThat(stream).isNotNull();\n            assertThat(stream.read()).isNotNegative();\n        } finally {\n            loader.cleanup();\n        }\n    }\n\n    @Test\n    void getResourceAsStreamFallsBackToSystemLoaderWhenParentIsNull() throws IOException {\n        AntClassLoader loader = new NoParentAntClassLoader();\n        try (InputStream stream = loader.getResourceAsStream(\"java/lang/String.class\")) {\n            if (stream != null) {\n                assertThat(stream.read()).isNotNegative();\n            }\n        } finally {\n            loader.cleanup();\n        }\n    }\n\n    @Test\n    void forceLoadSystemClassUsesFindSystemClassWhenParentIsNull() throws ClassNotFoundException {\n        AntClassLoader loader = new NoParentAntClassLoader();\n        try {\n            Class<?> systemClass = loader.forceLoadSystemClass(String.class.getName());\n            assertThat(systemClass).isSameAs(String.class);\n        } finally {\n            loader.cleanup();\n        }\n    }\n\n    @Test\n    void classLookupUsesParentDelegationAndForceLoadEntryPoints() throws ClassNotFoundException {\n        AntClassLoader loader = new AntClassLoader(getClass().getClassLoader(), true);\n        try {\n            Class<?> loadedByParent = loader.loadClass(String.class.getName());\n            assertThat(loadedByParent).isSameAs(String.class);\n\n            Class<?> forceLoadedSystemClass = loader.forceLoadSystemClass(Integer.class.getName());\n            assertThat(forceLoadedSystemClass).isSameAs(Integer.class);\n\n            assertThatThrownBy(() -> loader.forceLoadClass(\"ant.ant.DoesNotExist\"))\n                .isInstanceOf(ClassNotFoundException.class);\n        } finally {\n            loader.cleanup();\n        }\n    }\n\n    @Test\n    void defineClassFromDataUsesProtectionDomainReflectionPath() throws IOException {\n        ExposedAntClassLoader loader = new ExposedAntClassLoader(getClass().getClassLoader(), false);\n        try {\n            try {\n                loader.defineInvalidClass(\"ant.ant.InvalidClassBytes\");\n                fail(\"Invalid class bytes should not define a class\");\n            } catch (ClassFormatError expected) {\n                assertThat(expected).isNotNull();\n            } catch (Error error) {\n                if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                    throw error;\n                }\n            } catch (IOException expectedOnStronglyEncapsulatedJdks) {\n                String message = expectedOnStronglyEncapsulatedJdks.getMessage();\n                assertThat(message).isNotNull();\n                assertThat(message.contains(\"IllegalAccess\") || message.contains(\"UnsupportedFeatureError\"))\n                    .isTrue();\n            }\n        } finally {\n            loader.cleanup();\n        }\n    }\n\n    @Test\n    void forceLoadClassDefinesClassFromLoaderPath() throws IOException, ClassNotFoundException {\n        Path tempDirectory = Files.createTempDirectory(\"ant-class-loader\");\n        Path packageDirectory = tempDirectory.resolve(\"ant\").resolve(\"ant\");\n        Path classFile = packageDirectory.resolve(\"GeneratedAntClassLoaderTarget.class\");\n        AntClassLoader loader = new AntClassLoader(getClass().getClassLoader(), false);\n        try {\n            Files.createDirectories(packageDirectory);\n            Files.write(classFile, generatedClassBytes());\n\n            loader.addPathElement(tempDirectory.toFile().getAbsolutePath());\n            try {\n                Class<?> loadedClass = loader.forceLoadClass(\"ant.ant.GeneratedAntClassLoaderTarget\");\n                assertThat(loadedClass.getName()).isEqualTo(\"ant.ant.GeneratedAntClassLoaderTarget\");\n                assertThat(loadedClass.getClassLoader()).isSameAs(loader);\n            } catch (ClassNotFoundException expectedWhenRuntimeDefinitionIsRejected) {\n                assertThat(expectedWhenRuntimeDefinitionIsRejected)\n                    .hasMessage(\"ant.ant.GeneratedAntClassLoaderTarget\");\n            } catch (Error error) {\n                if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                    throw error;\n                }\n            }\n        } finally {\n            loader.cleanup();\n            Files.deleteIfExists(classFile);\n            Files.deleteIfExists(packageDirectory);\n            Files.deleteIfExists(packageDirectory.getParent());\n            Files.deleteIfExists(tempDirectory);\n        }\n    }\n\n    @Test\n    void forceLoadFreshAntClassLoaderCopyRunsStaticCompatibilityHelper() throws IOException, ClassNotFoundException {\n        Path tempDirectory = Files.createTempDirectory(\"fresh-ant-class-loader\");\n        Path packageDirectory = tempDirectory.resolve(\"org\").resolve(\"apache\").resolve(\"tools\").resolve(\"ant\");\n        Path classFile = packageDirectory.resolve(\"AntClassLoader.class\");\n        AntClassLoader loader = new AntClassLoader(getClass().getClassLoader(), false);\n        try (InputStream classBytes = AntClassLoader.class.getResourceAsStream(\"AntClassLoader.class\")) {\n            assertThat(classBytes).isNotNull();\n            Files.createDirectories(packageDirectory);\n            Files.write(classFile, classBytes.readAllBytes());\n\n            loader.addPathElement(tempDirectory.toFile().getAbsolutePath());\n            try {\n                Class<?> reloadedClass = loader.forceLoadClass(AntClassLoader.class.getName());\n                assertThat(reloadedClass.getName()).isEqualTo(AntClassLoader.class.getName());\n                assertThat(reloadedClass.getClassLoader())\n                    .isIn(loader, AntClassLoader.class.getClassLoader());\n\n                AntClassLoader.initializeClass(reloadedClass);\n            } catch (Error error) {\n                if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                    throw error;\n                }\n            }\n        } finally {\n            loader.cleanup();\n            Files.deleteIfExists(classFile);\n            Files.deleteIfExists(packageDirectory);\n            Files.deleteIfExists(packageDirectory.getParent());\n            Files.deleteIfExists(packageDirectory.getParent().getParent());\n            Files.deleteIfExists(packageDirectory.getParent().getParent().getParent());\n            Files.deleteIfExists(packageDirectory.getParent().getParent().getParent().getParent());\n            Files.deleteIfExists(tempDirectory);\n        }\n    }\n\n    private byte[] generatedClassBytes() {\n        return Base64.getDecoder().decode(\"\"\"\n            yv66vgAAADQADAoAAgADBwAEDAAFAAYBABBqYXZhL2xhbmcvT2JqZWN0AQAGPGluaXQ+\n            AQADKClWBwAIAQAlYW50L2FudC9HZW5lcmF0ZWRBbnRDbGFzc0xvYWRlclRhcmdldAEA\n            BENvZGUBAApTb3VyY2VGaWxlAQAiR2VuZXJhdGVkQW50Q2xhc3NMb2FkZXJUYXJnZXQu\n            amF2YQAhAAcAAgAAAAAAAQABAAUABgABAAkAAAARAAEAAQAAAAUqtwABsQAAAAAAAQAK\n            AAAAAgAL\n            \"\"\".replaceAll(\"\\\\s\", \"\"));\n    }\n\n    public static class InitializationTarget {\n        static boolean initialized;\n\n        static {\n            initialized = true;\n        }\n\n        public InitializationTarget() {\n        }\n    }\n\n    public static class NoParentAntClassLoader extends AntClassLoader {\n        NoParentAntClassLoader() {\n            super(null, true);\n        }\n\n        @Override\n        public void setParent(ClassLoader parent) {\n        }\n    }\n\n    public static class ExposedAntClassLoader extends AntClassLoader {\n        ExposedAntClassLoader(ClassLoader parent, boolean parentFirst) {\n            