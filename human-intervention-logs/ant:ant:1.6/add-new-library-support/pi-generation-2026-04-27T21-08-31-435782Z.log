n delegate.next();\n                }\n            };\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 862, "output": 2458, "cacheRead": 31232, "cacheWrite": 0, "totalTokens": 34552, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777323991393, "responseId": "resp_0a06459efd4f30360169efcfd7f87881958ff2c98f1c88f90b"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_8NxzNPnIJzd95DboePaN70iI|fc_0a06459efd4f30360169efcfef484881959e544ab0e785f0d2", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 3389 bytes to tests/src/ant/ant/1.6/src/test/java/ant/ant/ModifiedSelectorTest.java"}], "isError": false, "timestamp": 1777324020107}]}
