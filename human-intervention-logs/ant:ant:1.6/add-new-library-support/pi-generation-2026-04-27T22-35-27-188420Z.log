[tool-call] delta {"path":"tests/src/ant/ant/1.6/src/test/java/ant/ant/FileUtilsTest.java","edits":[{"oldText":"import java.io.IOException;\nimport java.nio.file.Files;\nimport java.nio.file.Path;\nimport org.apache.tools.ant.util.FileUtils;\nimport org.junit.jupiter.api.Test;\nimport org.junit.jupiter.api.io.TempDir;\n\npublic class FileUtilsTest {\n    @Test\n    void updatesLastModifiedTimeThroughPublicApi(@TempDir Path temporaryDirectory) throws IOException {","newText":"import java.io.IOException;\nimport java.lang.reflect.Field;\nimport java.nio.file.Files;\nimport java.nio.file.Path;\nimport org.apache.tools.ant.util.FileUtils;\nimport org.junit.jupiter.api.BeforeEach;\nimport org.junit.jupiter.api.Test;\nimport org.junit.jupiter.api.io.TempDir;\n\npublic class FileUtilsTest {\n    @BeforeEach\n    void resetLastModifiedMethodCache() throws ReflectiveOperationException {\n        resetStaticField(\"class$java$io$File\");\n        resetStaticField(\"setLastModified\");\n    }\n\n    @Test\n    void updatesLastModifiedTimeThroughPublicApi(@TempDir Path temporaryDirectory) throws IOException {"},{"oldText":"        assertThat(file.toFile().lastModified()).isEqualTo(expectedModifiedTime);\n    }\n}\n","newText":"        assertThat(file.toFile().lastModified()).isEqualTo(expectedModifiedTime);\n    }\n\n    private static void resetStaticField(String fieldName) throws ReflectiveOperationException {\n        Field field = FileUtils.class.getDeclaredField(fieldName);\n        field.setAccessible(true);\n        field.set(null, null);\n    }\n}\n"}]}
