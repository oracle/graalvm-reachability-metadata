                          + file.getPath();
                      throw new BuildException(msg);
                  }
              } else if (part.equals(".")) {
                  // Do nothing here
              } else {
                  helpFile = new File(helpFile, part);
              }
          }
  
          return new File(helpFile.getAbsolutePath());
      }
  
