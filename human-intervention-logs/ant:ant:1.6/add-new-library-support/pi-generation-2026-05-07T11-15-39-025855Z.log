  package ant.ant;
  
  import org.apache.tools.ant.IntrospectionHelper;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class IntrospectionHelperAnonymous5Test {
  
      @Test
      void setsStringAttributeWithoutConversion() {
          StringAttributeTarget target = new StringAttributeTarget();
          IntrospectionHelper helper = IntrospectionHelper.getHelper(StringAttributeTarget.class);
  
          helper.setAttribute(null, target, "label", "plain text");
  
          assertThat(target.label).isEqualTo("plain text");
      }
  
      public static final class StringAttributeTarget {
          private String label;
  
          public void setLabel(String value) {
              this.label = value;
          }
      }
