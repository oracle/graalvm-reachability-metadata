  package ant.ant;
  
  import org.apache.tools.ant.IntrospectionHelper;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class IntrospectionHelperAnonymous8Test {
  
      @Test
      void setsClassAttributeFromClassName() {
          ClassAttributeTarget target = new ClassAttributeTarget();
          IntrospectionHelper helper = IntrospectionHelper.getHelper(ClassAttributeTarget.class);
  
          helper.setAttribute(null, target, "implementation", String.class.getName());
  
          assertThat(target.implementation).isSameAs(String.class);
      }
  
      public static final class ClassAttributeTarget {
          private Class<?> implementation;
  
          public void setImplementation(Class<?> value) {
              this.implementation = value;
          }
      }
  }
