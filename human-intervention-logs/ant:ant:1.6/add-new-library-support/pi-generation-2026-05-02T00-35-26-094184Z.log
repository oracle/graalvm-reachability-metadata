   assertThat(report)\n                .contains(\"------- Ant diagnostics report -------\")\n                .contains(Main.getAntVersion())\n                .contains(\"Implementation Version\")\n                .contains(\"core tasks     :\")\n                .contains(\"optional tasks :\")\n                .contains(\"Tasks availability\")\n                .doesNotContain(\"None available\");\n        assertThat(Diagnostics.isOptionalAvailable()).isTrue();\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1604, "output": 926, "cacheRead": 22528, "cacheWrite": 0, "totalTokens": 25058, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777682088392, "responseId": "resp_04c632c4c1f0bd7c0169f546a8d87081908dd680c8cc478ca2"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_cw9QmZuQNxvTsiDg8kFlTZeF|fc_04c632c4c1f0bd7c0169f546b339c08190bd15717f365e4246", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1636 bytes to tests/src/ant/ant/1.6/src/test/java/ant/ant/DiagnosticsTest.java"}], "isError": false, "timestamp": 1777682101738}]}
