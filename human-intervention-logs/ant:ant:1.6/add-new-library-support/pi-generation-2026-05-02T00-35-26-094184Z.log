      20	public class DiagnosticsTest {
      21	    @Test
      22	    void reportsImplementationVersionsAndTaskAvailabilityFromPublicDiagnostics() {
      23	        ByteArrayOutputStream output = new ByteArrayOutputStream();
      24	
