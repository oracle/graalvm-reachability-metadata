          for (int i = 0; i < children.size(); ++i) {
              UnknownElement child = (UnknownElement) children.get(i);
              if (!child.similar(other.children.get(i))) {
                  return false;
              }
          }
          return true;
      }
  
      private boolean equalsString(String a, String b) {
          if (a == null) {
              return b == null;
          }
          return a.equals(b);
      }
