  package ant.ant;
  
  import java.lang.invoke.MethodHandle;
  import java.lang.invoke.MethodHandles;
  import java.lang.invoke.MethodType;
  
  import org.apache.tools.zip.ZipEntry;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ZipEntryTest {
  
      @Test
      void setComprSizeUpdatesCompressedSize() {
          ZipEntry entry = new ZipEntry("archive/data.txt");
  
          assertThat(entry.getCompressedSize()).isEqualTo(-1L);
  
          entry.setComprSize(1234L);
  
          assertThat(entry.getCompressedSize()).isEqualTo(1234L);
      }
  
      @Test
      void classLiteralHelperLoadsRequestedClass() throws Throwable {
          MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(ZipEntry.class, MethodHandles.lookup());
          MethodHandle classLiteralHelper = lookup.findStatic(
                  ZipEntry.class,
                  "class$",
                  MethodType.methodType(Class.class, String.class));
  
          Class<?> loadedClass = (Class<?>) classLiteralHelper.invoke("java.util.zip.ZipEntry");
  
          assertThat(loadedClass).isSameAs(java.util.zip.ZipEntry.class);
      }
  }
