       *
       * @since 1.1
       */
      public void setExtra(byte[] extra) throws RuntimeException {
          try {
              setExtraFields(ExtraFieldUtils.parse(extra));
          } catch (Exception e) {
              throw new RuntimeException(e.getMessage());
          }
      }
  
