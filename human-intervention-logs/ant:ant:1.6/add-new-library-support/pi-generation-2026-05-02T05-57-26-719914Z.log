setsAndRestoresContextClassLoader() {\n        ClassLoader originalLoader = LoaderUtils.getContextClassLoader();\n        ClassLoader replacementLoader = new ClassLoader(originalLoader) {\n        };\n\n        try {\n            LoaderUtils.setContextClassLoader(replacementLoader);\n\n            assertThat(LoaderUtils.isContextLoaderAvailable()).isTrue();\n            assertThat(LoaderUtils.getContextClassLoader()).isSameAs(replacementLoader);\n        } finally {\n            LoaderUtils.setContextClassLoader(originalLoader);\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 603, "output": 1030, "cacheRead": 24064, "cacheWrite": 0, "totalTokens": 25697, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777701412140, "responseId": "resp_0a5db0cb0aaf79500169f59224957c8197b2ebd182d92e4f81"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_JMe7qXbHGCZQdNcBf6o8JoHe|fc_0a5db0cb0aaf79500169f5922d07c88197bad28d074b612e7e", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1555 bytes to tests/src/ant/ant/1.6/src/test/java/ant/ant/LoaderUtilsTest.java"}], "isError": false, "timestamp": 1777701423413}]}
