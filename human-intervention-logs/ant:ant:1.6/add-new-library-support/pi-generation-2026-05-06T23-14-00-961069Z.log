code along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage ant.ant;\n\nimport java.lang.invoke.MethodHandles;\nimport java.lang.invoke.VarHandle;\nimport java.util.Comparator;\n\nimport org.apache.tools.ant.types.Parameter;\nimport org.apache.tools.ant.types.selectors.modifiedselector.Algorithm;\nimport org.apache.tools.ant.types.selectors.modifiedselector.Cache;\nimport org.apache.tools.ant.types.selectors.modifiedselector.ModifiedSelector;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ModifiedSelectorTest {\n\n    @Test\n    void configureLoadsNamedComponentsFromLegacyCacheSelectorPackage() {\n        ModifiedSelector selector = new ModifiedSelector();\n        ModifiedSelector.AlgorithmName algorithmName = new ModifiedSelector.AlgorithmName();\n        algorithmName.setValue(\"digest\");\n        ModifiedSelector.CacheName cacheName = new ModifiedSelector.CacheName();\n        cacheName.setValue(\"propertyfile\");\n        ModifiedSelector.ComparatorName comparatorName = new ModifiedSelector.ComparatorName();\n        comparatorName.setValue(\"equal\");\n        selector.setAlgorithm(algorithmName);\n        selector.setCache(cacheName);\n        selector.setComparator(comparatorName);\n        selector.addParam(new ResetComponentsParameter(selector));\n\n        selector.configure();\n\n        assertThat(selector.getAlgorithm())\n                .isInstanceOf(org.apache.tools.ant.types.selectors.cacheselector.DigestAlgorithm.class);\n        assertThat(selector.getCache())\n                .isInstanceOf(org.apache.tools.ant.types.selectors.cacheselector.PropertiesfileCache.class);\n        assertThat(selector.getComparator())\n                .isInstanceOf(org.apache.tools.ant.types.selectors.cacheselector.EqualComparator.class);\n    }\n\n    private static final class ResetComponentsParameter extends Parameter {\n        private static final VarHandle ALGORITHM = privateField(\"algorithm\", Algorithm.class);\n        private static final VarHandle CACHE = privateField(\"cache\", Cache.class);\n        private static final VarHandle COMPARATOR = privateField(\"comparator\", Comparator.class);\n\n        private final ModifiedSelector selector;\n\n        ResetComponentsParameter(ModifiedSelector selector) {\n            this.selector = selector;\n        }\n\n        @Override\n        public String getName() {\n            ALGORITHM.set(selector, null);\n            CACHE.set(selector, null);\n            COMPARATOR.set(selector, null);\n            return \"update\";\n        }\n\n        @Override\n        public String getValue() {\n            return \"true\";\n        }\n\n        private static VarHandle privateField(String name, Class<?> type) {\n            try {\n                MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(ModifiedSelector.class, MethodHandles.lookup());\n                return lookup.findVarHandle(ModifiedSelector.class, name, type);\n            } catch (ReflectiveOperationException e) {\n                throw new AssertionError(\"Cannot access ModifiedSelector field \" + name, e);\n            }\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 943, "output": 1346, "cacheRead": 31232, "cacheWrite": 0, "totalTokens": 33521, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778109142119, "responseId": "resp_0578797f6b788f850169fbcad6c8308197936545ecb93b3004"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_QtE4DevZqe7Fdqn8dFynTp3g|fc_0578797f6b788f850169fbcadf7108819796e83906f638d404", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 3251 bytes to tests/src/ant/ant/1.6/src/test/java/ant/ant/ModifiedSelectorTest.java"}], "isError": false, "timestamp": 1778109155638}]}
