  package ant.ant;
  
  import java.io.File;
  import java.io.Reader;
  import java.io.StringReader;
  import java.net.URISyntaxException;
  import java.util.Vector;
  
  import org.apache.tools.ant.AntClassLoader;
  import org.apache.tools.ant.Project;
  import org.apache.tools.ant.filters.ClassConstants;
  import org.apache.tools.ant.filters.util.ChainReaderHelper;
  import org.apache.tools.ant.filters.util.JavaClassHelper;
  import org.apache.tools.ant.types.AntFilterReader;
  import org.apache.tools.ant.types.FilterChain;
  import org.apache.tools.ant.types.Path;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ClassConstantsTest {
      private static final String LS = System.getProperty("line.separator");
  
      @Test
      void readLoadsHelperMethodAndInvokesItReflectively() throws Exception {
          ClassConstants reader = new ClassConstants(new StringReader("not a class file"));
  
          assertThat(readFully(reader)).isEqualTo("payloadLength=16" + LS);
      }
  
      @Test
      void readThroughConfiguredFilterInitializesParameterTypeInFreshClassConstantsClass()
          throws Exception {
          try {
              Project project = new ChildFirstProject();
              ChainReaderHelper helper = helperFor(
                  new StringReader("fresh loader"), filterNamed(project));
              helper.setProject(project);
  
              Reader assembledReader = helper.getAssembledReader();
  
              assertThat(readFully(assembledReader)).isEqualTo("payloadLength=12" + LS);
          } catch (Error error) {
              if (NativeImageSupport.isUnsupportedFeatureError(error)) {
                  return;
              }
              throw error;
          }
      }
  
      private static String readFully(Reader reader) throws Exception {
          StringBuffer buffer = new StringBuffer();
          int ch = reader.read();
          while (ch != -1) {
              buffer.append((char) ch);
              ch = reader.read();
          }
          return buffer.toString();
      }
  
      private static ChainReaderHelper helperFor(Reader primaryReader, AntFilterReader filterReader) {
          FilterChain filterChain = new FilterChain();
          filterChain.addFilterReader(filterReader);
          Vector filterChains = new Vector();
          filterChains.addElement(filterChain);
  
          ChainReaderHelper helper = new ChainReaderHelper();
          helper.setPrimaryReader(primaryReader);
          helper.setFilterChains(filterChains);
          return helper;
      }
  
      private static AntFilterReader filterNamed(Project project) throws URISyntaxException {
          Path classpath = new Path(project);
          classpath.createPathElement().setLocation(codeSourceLocation(JavaClassHelper.class));
          classpath.createPathElement().setLocation(codeSourceLocation(ClassConstants.class));
  
          AntFilterReader filterReader = new AntFilterReader();
          filterReader.setProject(project);
          filterReader.setClassName(ClassConstants.class.getName());
          filterReader.setClasspath(classpath);
          return filterReader;
      }
  
      private static File codeSourceLocation(Class<?> type) throws URISyntaxException {
          return new File(type.getProtectionDomain().getCodeSource().getLocation().toURI());
      }
  
      private static final class ChildFirstProject extends Project {
          @Override
          public AntClassLoader createClassLoader(Path path) {
              AntClassLoader loader = new AntClassLoader(
                  getClass().getClassLoader(), this, path, false);
              loader.addLoaderPackageRoot("org.apache.tools.ant.filters");
              return loader;
          }
      }
  }
