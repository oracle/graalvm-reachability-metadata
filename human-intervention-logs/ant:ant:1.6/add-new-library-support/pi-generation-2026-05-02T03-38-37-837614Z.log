                  name.toLowerCase(Locale.US));
          }
          if (nc == null) {
              nc = createAddTypeCreator(project, parent, elementName);
          }
          if (nc == null && parent instanceof DynamicConfigurator) {
              DynamicConfigurator dc = (DynamicConfigurator) parent;
