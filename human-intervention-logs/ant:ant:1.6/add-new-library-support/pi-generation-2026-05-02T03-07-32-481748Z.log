  plugins {
      id "org.graalvm.internal.tck"
  }
  
  String libraryVersion = tck.testedLibraryVersion.get()
  
  dependencies {
      testImplementation "ant:ant:$libraryVersion"
      testImplementation "ant:ant-launcher:$libraryVersion"
      testImplementation "ant:ant-nodeps:$libraryVersion"
      testImplementation "ant:ant-trax:$libraryVersion"
      testImplementation "ant:ant-xalan1:$libraryVersion"
      testImplementation "ant:ant-xslp:$libraryVersion"
      testImplementation 'bcel:bcel:5.1'
      testImplementation 'xml-resolver:xml-resolver:1.2'
      testImplementation 'org.assertj:assertj-core:3.22.0'
  }
  
  tasks.withType(Test).configureEach {
      jvmArgs '-Dfile.encoding=ISO-8859-1'
  }
  
  graalvmNative {
      binaries {
          test {
              buildArgs('-Dfile.encoding=ISO-8859-1')
              runtimeArgs('-Dfile.encoding=ISO-8859-1')
              runtimeArgs("-Djava.class.path=${sourceSets.test.runtimeClasspath.asPath}")
          }
      }
      agent {
          defaultMode = "conditional"
          modes {
              conditional {
                  userCodeFilterPath = "user-code-filter.json"
              }
          }
      }
  }
