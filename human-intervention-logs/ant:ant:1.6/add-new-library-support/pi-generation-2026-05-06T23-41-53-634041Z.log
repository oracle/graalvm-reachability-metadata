d(\n            CountingUpperCaseFilterReader.class.getName(), classpath));\n\n        helper.setProject(project);\n        Reader assembledReader = helper.getAssembledReader();\n\n        assertThat(helper.readFully(assembledReader)).isEqualTo(\"CLASSPATH BRANCH\");\n        assertThat(CountingUpperCaseFilterReader.constructorCalls).hasValue(1);\n    }\n\n    private static ChainReaderHelper helperFor(Reader primaryReader, AntFilterReader filterReader) {\n        FilterChain filterChain = new FilterChain();\n        filterChain.addFilterReader(filterReader);\n        Vector filterChains = new Vector();\n        filterChains.addElement(filterChain);\n\n        ChainReaderHelper helper = new ChainReaderHelper();\n        helper.setPrimaryReader(primaryReader);\n        helper.setFilterChains(filterChains);\n        return helper;\n    }\n\n    private static AntFilterReader filterNamed(String className, Path classpath) {\n        Project project = new Project();\n        AntFilterReader filterReader = new AntFilterReader();\n        filterReader.setProject(project);\n        filterReader.setClassName(className);\n        if (classpath != null) {\n            filterReader.setClasspath(classpath);\n        }\n        return filterReader;\n    }\n\n    public static final class CountingUpperCaseFilterReader extends FilterReader {\n        private static final AtomicInteger constructorCalls = new AtomicInteger();\n\n        public CountingUpperCaseFilterReader(Reader in) {\n            super(in);\n            constructorCalls.incrementAndGet();\n        }\n\n        static void reset() {\n            constructorCalls.set(0);\n        }\n\n        @Override\n        public int read() throws IOException {\n            int next = super.read();\n            if (next == -1) {\n                return -1;\n            }\n            return Character.toUpperCase((char) next);\n        }\n\n        @Override\n        public int read(char[] buffer, int offset, int length) throws I