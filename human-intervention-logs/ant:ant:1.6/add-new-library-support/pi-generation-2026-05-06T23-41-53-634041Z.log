  package ant.ant;
  
  import java.io.FilterReader;
  import java.io.IOException;
  import java.io.Reader;
  import java.io.StringReader;
  import java.util.Vector;
  import java.util.concurrent.atomic.AtomicInteger;
  
  import org.apache.tools.ant.Project;
  import org.apache.tools.ant.filters.util.ChainReaderHelper;
  import org.apache.tools.ant.types.AntFilterReader;
  import org.apache.tools.ant.types.FilterChain;
  import org.apache.tools.ant.types.Path;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ChainReaderHelperTest {
  
      @Test
      void getAssembledReaderLoadsFilterReaderClassAndInvokesReaderConstructor() throws IOException {
          CountingUpperCaseFilterReader.reset();
          Project project = new Project();
          ChainReaderHelper helper = helperFor(new StringReader("mixed Case"), filterNamed(
              project, CountingUpperCaseFilterReader.class.getName(), null));
  
          helper.setProject(project);
          Reader assembledReader = helper.getAssembledReader();
  
          assertThat(assembledReader).isInstanceOf(CountingUpperCaseFilterReader.class);
          assertThat(helper.readFully(assembledReader)).isEqualTo("MIXED CASE");
          assertThat(CountingUpperCaseFilterReader.constructorCalls).hasValue(1);
      }
  
      @Test
      void getAssembledReaderLoadsFilterReaderThroughConfiguredClasspath() throws IOException {
          CountingUpperCaseFilterReader.reset();
          Project project = new Project();
          Path classpath = new Path(project);
          ChainReaderHelper helper = helperFor(new StringReader("classpath branch"), filterNamed(
              project, CountingUpperCaseFilterReader.class.getName(), classpath));
  
          helper.setProject(project);
          Reader assembledReader = helper.getAssembledReader();
  
          assertThat(helper.readFully(assembledReader)).isEqualTo("CLASSPATH BRANCH");
          assertThat(CountingUpperCaseFilterReader.constructorCalls).hasValue(1);
      }
  
      private static ChainReaderHelper helperFor(Reader primaryReader, AntFilterReader filterReader) {
          FilterChain filterChain = new FilterChain();
          filterChain.addFilterReader(filterReader);
          Vector filterChains = new Vector();
          filterChains.addElement(filterChain);
  
          ChainReaderHelper helper = new ChainReaderHelper();
          helper.setPrimaryReader(primaryReader);
          helper.setFilterChains(filterChains);
          return helper;
      }
  
      private static AntFilterReader filterNamed(Project project, String className, Path classpath) {
          AntFilterReader filterReader = new AntFilterReader();
          filterReader.setProject(project);
          filterReader.setClassName(className);
          if (classpath != null) {
              filterReader.setClasspath(classpath);
          }
          return filterReader;
      }
  
      public static final class CountingUpperCaseFilterReader extends FilterReader {
          private static final AtomicInteger constructorCalls = new AtomicInteger();
  
          public CountingUpperCaseFilterReader(Reader in) {
              super(in);
              constructorCalls.incrementAndGet();
          }
  
          static void reset() {
              constructorCalls.set(0);
          }
  
          @Override
          public int read() throws IOException {
              int next = super.read();
              if (next == -1) {
                  return -1;
              }
              return Character.toUpperCase((char) next);
          }
  
          @Override
          public int read(char[] buffer, int offset, int length) throws IOException {
              int charsRead = super.read(buffer, offset, length);
              if (charsRead == -1) {
                  return -1;
              }
              for (int i = offset; i < offset + charsRead; i++) {
                  buffer[i] = Character.toUpperCase(buffer[i]);
              }
              return charsRead;
          }
      }
  }
