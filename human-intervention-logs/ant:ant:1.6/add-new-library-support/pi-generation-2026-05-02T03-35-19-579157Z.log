[tool-call] delta {"path":"tests/src/ant/ant/1.6/src/test/java/ant/ant/ClasspathUtilsTest.java","edits":[{"oldText":"import org.apache.tools.ant.ProjectComponent;\nimport org.apache.tools.ant.util.ClasspathUtils;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ClasspathUtilsTest {\n    @Test\n    void instantiatesAntClassWithProvidedLoader() {\n        Object instance = ClasspathUtils.newInstance(\n                Project.class.getName(),\n                Project.class.getClassLoader());\n\n        assertThat(instance).isInstanceOf(Project.class);\n    }\n\n    @Test\n    void delegateInstantiatesConfiguredAntClass() {\n        Project project = new Project();\n        project.init();\n        ClasspathUtils.Delegate delegate = ClasspathUtils.getDelegate(newProjectComponent(project));\n        delegate.setClassname(Project.class.getName());\n\n        Object instance = delegate.newInstance();\n\n        assertThat(instance).isInstanceOf(Project.class);\n    }\n\n    private ProjectComponent newProjectComponent(Project project) {\n        TestProjectComponent component = new TestProjectComponent();\n        component.setProject(project);\n        return component;\n    }\n\n    private static final class TestProjectComponent extends ProjectComponent {\n    }\n}\n","newText":"import org.apache.tools.ant.util.ClasspathUtils;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ClasspathUtilsTest {\n    @Test\n    void instantiatesAntClassWithProvidedLoader() {\n        Object instance = ClasspathUtils.newInstance(\n                Project.class.getName(),\n                Project.class.getClassLoader());\n\n        assertThat(instance).isInstanceOf(Project.class);\n    }\n}\n"}]}
