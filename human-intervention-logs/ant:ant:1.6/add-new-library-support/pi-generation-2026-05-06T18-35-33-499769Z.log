      @Test
      void forceLoadSystemClassUsesFindSystemClassWhenParentIsNull() throws ClassNotFoundException {
          AntClassLoader loader = new NoParentAntClassLoader();
          try {
              Class<?> systemClass = loader.forceLoadSystemClass(String.class.getName());
              assertThat(systemClass).isSameAs(String.class);
          } finally {
              loader.cleanup();
          }
      }
  
      @Test
      void classLookupUsesParentDelegationAndForceLoadEntryPoints() throws ClassNotFoundException {
          AntClassLoader loader = new AntClassLoader(getClass().getClassLoader(), true);
          try {
              Class<?> loadedByParent = loader.loadClass(String.class.getName());
              assertThat(loadedByParent).isSameAs(String.class);
  
              Class<?> forceLoadedSystemClass = loader.forceLoadSystemClass(Integer.class.getName());
              assertThat(forceLoadedSystemClass).isSameAs(Integer.class);
  
              assertThatThrownBy(() -> loader.forceLoadClass("ant.ant.DoesNotExist"))
                  .isInstanceOf(ClassNotFoundException.class);
          } finally {
              loader.cleanup();
          }
      }
  
      @Test
      void defineClassFromDataUsesProtectionDomainReflectionPath() throws IOException {
          ExposedAntClassLoader loader = new ExposedAntClassLoader(getClass().getClassLoader(), false);
          try {
              try {
                  loader.defineInvalidClass("ant.ant.InvalidClassBytes");
                  fail("Invalid class bytes should not define a class");
              } catch (ClassFormatError expected) {
                  assertThat(expected).isNotNull();
              } catch (Error error) {
                  if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                      throw error;
                  }
              } catch (IOException expectedOnStronglyEncapsulatedJdks) {
                  assertThat(expectedOnStronglyEncapsulatedJdks).hasMessageContaining("IllegalAccess");
              }
          } finally {
              loader.cleanup();
          }
      }
  
      @Test
      void forceLoadClassDefinesClassFromLoaderPath() throws IOException, ClassNotFoundException {
          AntClassLoader loader = new AntClassLoader(getClass().getClassLoader(), false);
          try {
              loader.addPathElement(testClassesDirectory().getAbsolutePath());
              try {
                  Class<?> loadedClass = loader.forceLoadClass(LoaderDefinedTarget.class.getName());
                  assertThat(loadedClass.getName()).isEqualTo(LoaderDefinedTarget.class.getName());
                  assertThat(loadedClass.getClassLoader()).isSameAs(loader);
              } catch (Error error) {
                  if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                      throw error;
                  }
              } catch (IOException expectedOnStronglyEncapsulatedJdks) {
                  assertThat(expectedOnStronglyEncapsulatedJdks).hasMessageContaining("IllegalAccess");
              }
          } finally {
              loader.cleanup();
          }
      }
  
      private File testClassesDirectory() {
          URL resource = getClass().getClassLoader().getResource(TEST_CLASS_RESOURCE);
          assertThat(resource).isNotNull();
          assertThat(resource.getProtocol()).isEqualTo("file");
  
          String testClassPath = resource.getPath();
          String testClassResourcePath = TEST_CLASS_RESOURCE.replace('/', File.separatorChar);
          return new File(testClassPath.substring(0, testClassPath.length() - testClassResourcePath.length()));
      }
  
      public static class InitializationTarget {
          static boolean initialized;
  
          static {
              initialized = true;
          }
  
          public InitializationTarget() {
          }
      }
  
      public static class LoaderDefinedTarget {
      }
  
      public static class NoParentAntClassLoader extends AntClassLoader {
          NoParentAntClassLoader() {
              super(null, true);
          }
  
          @Override
  
