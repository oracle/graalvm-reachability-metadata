      private Class getClassFromStream(InputStream stream, String classname,
                                         File container)
                  throws IOException, SecurityException {
          ByteArrayOutputStream baos = new ByteArrayOutputStream();
          int bytesRead = -1;
          byte[] buffer = new byte[BUFFER_SIZE];
  
