().getAbsolutePath());\n            try {\n                Class<?> loadedClass = loader.forceLoadClass(LoaderDefinedTarget.class.getName());\n                assertThat(loadedClass.getName()).isEqualTo(LoaderDefinedTarget.class.getName());\n                assertThat(loadedClass.getClassLoader()).isSameAs(loader);\n            } catch (Error error) {\n                if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                    throw error;\n                }\n            }\n        } finally {\n            loader.cleanup();\n        }\n    }\n\n    private File testClassesDirectory() {\n        URL resource = getClass().getClassLoader().getResource(TEST_CLASS_RESOURCE);\n        assertThat(resource).isNotNull();\n        assertThat(resource.getProtocol()).isEqualTo(\"file\");\n\n        String testClassPath = resource.getPath();\n        String testClassResourcePath = TEST_CLASS_RESOURCE.replace('/', File.separatorChar);\n        return new File(testClassPath.substring(0, testClassPath.length() - testClassResourcePath.length()));\n    }\n", "newText": "    @Test\n    void forceLoadClassDefinesClassFromLoaderPath() throws IOException, ClassNotFoundException {\n        Path tempDirectory = Files.createTempDirectory(\"ant-class-loader\");\n        Path packageDirectory = tempDirectory.resolve(\"ant\").resolve(\"ant\");\n        Path classFile = packageDirectory.resolve(\"GeneratedAntClassLoaderTarget.class\");\n        AntClassLoader loader = new AntClassLoader(getClass().getClassLoader(), false);\n        try {\n            Files.createDirectories(packageDirectory);\n            Files.write(classFile, generatedClassBytes());\n\n            loader.addPathElement(tempDirectory.toFile().getAbsolutePath());\n            try {\n                Class<?> loadedClass = loader.forceLoadClass(\"ant.ant.GeneratedAntClassLoaderTarget\");\n                assertThat(loadedClass.getName()).isEqualTo(\"ant.ant.GeneratedAntClassLoaderTarget\");\n                assertThat(loadedClass.getClassLoader()).isSameAs(loader);\n            } catch (Error error) {\n                if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                    throw error;\n                }\n            }\n        } finally {\n            loader.cleanup();\n            Files.deleteIfExists(classFile);\n            Files.deleteIfExists(packageDirectory);\n            Files.deleteIfExists(packageDirectory.getParent());\n            Files.deleteIfExists(tempDirectory);\n        }\n    }\n\n    private byte[] generatedClassBytes() {\n        return Base64.getDecoder().decode(\"\"\"\n            yv66vgAAADQADAoAAgADBwAEDAAFAAYBABBqYXZhL2xhbmcvT2JqZWN0AQAGPGluaXQ+\n            AQADKClWBwAIAQAlYW50L2FudC9HZW5lcmF0ZWRBbnRDbGFzc0xvYWRlclRhcmdldAEA\n            BENvZGUBClNvdXJjZUZpbGUBIkdlbmVyYXRlZEFudENsYXNzTG9hZGVyVGFyZ2V0Lmph\n            dmEAIQAHAAIAAAAAAAEAAQAFAAYAAQAJAAAAEQABAAEAAAAFKrcAAbEAAAAAAAEACgAA\n            AAIAAw==\n            \"\"\".replaceAll(\"\\\\s\", \"\"));\n    }\n"}]}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 2181, "output": 2736, "cacheRead": 38912, "cacheWrite": 0, "totalTokens": 43829, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778093729634, "responseId": "resp_058403cf174cd2400169fb8ea4f5e08192944e079dff0a6ad3"}}
