  package ant.ant;
  
  import java.lang.invoke.MethodHandles;
  import java.lang.invoke.VarHandle;
  import java.lang.reflect.Method;
  import java.nio.file.Files;
  import java.nio.file.Path;
  
  import org.apache.tools.ant.util.FileUtils;
  import org.junit.jupiter.api.Test;
  import org.junit.jupiter.api.io.TempDir;
  
  import static org.assertj.core.api.Assertions.assertThat;
  import static org.assertj.core.data.Offset.offset;
  
  public class FileUtilsTest {
  
      @TempDir
      Path temporaryDirectory;
  
      @Test
      void setFileLastModifiedUpdatesTimestampThroughFileSetLastModifiedMethod() throws Exception {
          Path file = temporaryDirectory.resolve("timestamp.txt");
          Files.writeString(file, "content");
          long requestedTimestamp = 946684800000L;
          MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(FileUtils.class, MethodHandles.lookup());
          VarHandle cachedFileClass = lookup.findStaticVarHandle(
              FileUtils.class,
              "class$java$io$File",
              Class.class);
          VarHandle cachedSetLastModified = lookup.findStaticVarHandle(
              FileUtils.class,
              "setLastModified",
              Method.class);
          Object previousFileClass = cachedFileClass.get();
          Object previousSetLastModified = cachedSetLastModified.get();
          try {
              cachedFileClass.set(null);
              cachedSetLastModified.set(null);
  
              FileUtils.newFileUtils().setFileLastModified(file.toFile(), requestedTimestamp);
  
              assertThat(file.toFile().lastModified())
                  .isCloseTo(requestedTimestamp, offset(FileUtils.FAT_FILE_TIMESTAMP_GRANULARITY));
              assertThat(cachedFileClass.get()).isSameAs(java.io.File.class);
          } finally {
              cachedFileClass.set(previousFileClass);
              cachedSetLastModified.set(previousSetLastModified);
          }
      }
  }
