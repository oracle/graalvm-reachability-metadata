  package ant.ant;
  
  import java.lang.invoke.MethodHandle;
  import java.lang.invoke.MethodHandles;
  import java.lang.invoke.MethodType;
  import java.lang.invoke.VarHandle;
  import java.nio.file.Files;
  import java.nio.file.Path;
  import java.util.concurrent.atomic.AtomicInteger;
  import java.util.concurrent.atomic.AtomicReference;
  
  import org.apache.tools.ant.Project;
  import org.apache.tools.ant.taskdefs.Ant;
  import org.junit.jupiter.api.Test;
  import org.junit.jupiter.api.io.TempDir;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class AntTest {
  
      @TempDir
      Path temporaryDirectory;
  
      @Test
      void legacyClassLiteralHelperLoadsProjectClassByName() throws Throwable {
          MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(Ant.class, MethodHandles.lookup());
          MethodHandle classLiteralHelper = lookup.findStatic(
              Ant.class,
              "class$",
              MethodType.methodType(Class.class, String.class));
  
          Object loadedClass = classLiteralHelper.invoke("org.apache.tools.ant.Project");
  
          assertThat(loadedClass).isSameAs(Project.class);
      }
  
      @Test
      void executeCopiesExplicitReferenceByCloningAndSettingNewProject() throws Throwable {
          Path buildFile = temporaryDirectory.resolve("build.xml");
          Files.writeString(buildFile, """
                  <project name="child" default="copy-reference">
                      <target name="copy-reference"/>
                  </project>
                  """);
          CloneableReference.reset();
          Project parentProject = new Project();
          parentProject.init();
          parentProject.setBaseDir(temporaryDirectory.toFile());
          CloneableReference original = new CloneableReference("original");
          parentProject.addReference("source.reference", original);
  
          Ant task = new Ant();
          task.setProject(parentProject);
          task.setTaskName("ant");
          task.init();
          task.setDir(temporaryDirectory.toFile());
          task.setAntfile(buildFile.getFileName().toString());
          task.setTarget("copy-reference");
          Ant.Reference reference = new Ant.Reference();
          reference.setRefId("source.reference");
          reference.setToRefid("target.reference");
          task.addReference(reference);
          MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(Ant.class, MethodHandles.lookup());
          VarHandle projectClass = lookup.findStaticVarHandle(
              Ant.class,
              "class$org$apache$tools$ant$Project",
              Class.class);
          Object previousProjectClass = projectClass.get();
          try {
              projectClass.set(null);
  
              task.execute();
  
              assertThat(CloneableReference.cloneCalls).hasValue(1);
              assertThat(CloneableReference.clonedInstance.get()).isNotNull().isNotSameAs(original);
              assertThat(CloneableReference.clonedInstance.get().name).isEqualTo("original-clone");
              assertThat(CloneableReference.setProjectReceiver.get()).isSameAs(CloneableReference.clonedInstance.get());
              assertThat(CloneableReference.setProjectArgument.get()).isNotNull().isNotSameAs(parentProject);
              assertThat(CloneableReference.setProjectArgument.get().getName()).isEqualTo("child");
              assertThat(projectClass.get()).isSameAs(Project.class);
          } finally {
              projectClass.set(previousProjectClass);
          }
      }
  
      public static final class CloneableReference {
          private static final AtomicInteger cloneCalls = new AtomicInteger();
          private static final AtomicReference<CloneableReference> clonedInstance = new AtomicReference<>();
          private static final AtomicReference<CloneableReference> setProjectReceiver = new AtomicReference<>();
          private static final AtomicReference<Project> setProjectArgument = new AtomicReference<>();
  
          private final String name;
  
          public CloneableReference(String name) {
              this.name = name;
          }
  
          public Object clone() {
              cloneCalls.incrementAndGet();
              CloneableReference copy = new CloneableReference(name + "-clone");
              clonedInstance.set(copy);
              return copy;
          }
  
          public void setProject(Project project) {
              setProjectReceiver.set(this);
              setProjectArgument.set(project);
          }
  
          private static void reset() {
              cloneCalls.set(0);
              clonedInstance.set(null);
              setProjectReceiver.set(null);
              setProjectArgument.set(null);
          }
      }
  }
