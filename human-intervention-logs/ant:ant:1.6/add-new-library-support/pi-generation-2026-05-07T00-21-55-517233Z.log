  package ant.ant;
  
  import org.apache.tools.ant.Project;
  import org.apache.tools.ant.taskdefs.Available;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class AvailableTest {
      private static final String ANT_DEFAULT_TASKS_RESOURCE = "org/apache/tools/ant/taskdefs/defaults.properties";
  
      @Test
      void evalFindsClassThroughTaskClassLoader() {
          Available available = newAvailable();
          available.setClassname(String.class.getName());
  
          assertThat(available.eval()).isTrue();
      }
  
      @Test
      void evalFindsClassThroughConfiguredAntClassLoader() {
          Available available = newAvailable();
          available.createClasspath();
          available.setClassname(String.class.getName());
  
          assertThat(available.eval()).isTrue();
      }
  
      @Test
      void evalFindsResourceThroughTaskClassLoader() {
          Available available = newAvailable();
          available.setResource(ANT_DEFAULT_TASKS_RESOURCE);
  
          assertThat(available.eval()).isTrue();
      }
  
      private static Available newAvailable() {
          Project project = new Project();
          Available available = new Available();
          available.setProject(project);
          return available;
