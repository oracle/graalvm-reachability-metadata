ughSystemClassLoader() {\n        ExposedXSLTProcess task = newTask();\n        task.setProcessor(\"xslp\");\n\n        XSLTLiaison liaison = task.resolveConfiguredLiaison();\n\n        assertThat(liaison.getClass().getName()).isEqualTo(XSLP_LIAISON);\n    }\n\n    @Test\n    void resolvesXalanProcessorThroughSystemClassLoader() {\n        ExposedXSLTProcess task = newTask();\n        task.setProcessor(\"xalan\");\n\n        XSLTLiaison liaison = task.resolveConfiguredLiaison();\n\n        assertThat(liaison.getClass().getName()).isEqualTo(XALAN_LIAISON);\n    }\n\n    @Test\n    void resolvesCustomProcessorThroughSystemClassLoader() {\n        ExposedXSLTProcess task = newTask();\n        task.setProcessor(TRAX_LIAISON);\n\n        XSLTLiaison liaison = task.resolveConfiguredLiaison();\n\n        assertThat(liaison.getClass().getName()).isEqualTo(TRAX_LIAISON);\n    }\n\n    @Test\n    void resolvesCustomProcessorThroughConfiguredAntClassLoader() {\n        ExposedXSLTProcess task = newTask();\n        task.setProcessor(TRAX_LIAISON);\n        task.setClasspath(new Path(task.getProject(), System.getProperty(\"java.class.path\", \"\")));\n\n        XSLTLiaison liaison = task.resolveConfiguredLiaison();\n\n        assertThat(liaison.getClass().getName()).isEqualTo(TRAX_LIAISON);\n    }\n\n    private static ExposedXSLTProcess newTask() {\n        Project project = new ParentFirstProject();\n\n        ExposedXSLTProcess task = new ExposedXSLTProcess();\n        task.setProject(project);\n        return task;\n    }\n}\n\nfinal class ParentFirstProject extends Project {\n    @Override\n    public AntClassLoader createClassLoader(Path path) {\n        AntClassLoader loader = new AntClassLoader(getClass().getClassLoader(), true);\n        loader.setProject(this);\n        loader.setClassPath(path);\n        return loader;\n    }\n}\n\nfinal class ExposedXSLTProcess extends XSLTProcess {\n    XSLTLiaison resolveConfiguredLiaison() {\n        return getLiaison();\n    }\n}