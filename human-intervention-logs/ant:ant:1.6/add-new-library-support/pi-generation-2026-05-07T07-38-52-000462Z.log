\n    private static final String TYPE_NAME = \"resource-defined-type\";\n\n    @TempDir\n    Path tempDirectory;\n\n    @Test\n    void resourceTypedefLoadsDefinitionAdapterAndAdaptToClasses() throws IOException {\n        Project project = new Project();\n        project.init();\n        Path definitions = writeDefinitionsFile();\n        DefinitionResourceClassLoader loader = new DefinitionResourceClassLoader(\n                getClass().getClassLoader(),\n                definitions.toUri().toURL()\n        );\n        DefinerTypeAdapter.checkedProxyClass = null;\n\n        Typedef typedef = new Typedef();\n        typedef.setProject(project);\n        typedef.setAntlibClassLoader(loader);\n        typedef.setResource(RESOURCE_NAME);\n        typedef.setAdapter(DefinerTypeAdapter.class.getName());\n        typedef.setAdaptTo(DefinerContract.class.getName());\n        typedef.execute();\n\n        ComponentHelper componentHelper = ComponentHelper.getComponentHelper(project);\n        Object created = componentHelper.createComponent(TYPE_NAME);\n\n        assertThat(loader.requestedResourceName).isEqualTo(RESOURCE_NAME);\n        assertThat(componentHelper.getDefinition(TYPE_NAME).getClassName())\n                .isEqualTo(DefinerDataType.class.getName());\n        assertThat(DefinerTypeAdapter.checkedProxyClass).isSameAs(DefinerDataType.class);\n        assertThat(created).isInstanceOf(DefinerTypeAdapter.class);\n        DefinerTypeAdapter adapter = (DefinerTypeAdapter) created;\n        assertThat(adapter.getProject()).isSameAs(project);\n        assertThat(adapter.getProxy()).isInstanceOf(DefinerDataType.class);\n    }\n\n    private Path writeDefinitionsFile() throws IOException {\n        Path definitions = tempDirectory.resolve(\"definer-types.properties\");\n        Files.writeString(definitions, TYPE_NAME + \"=\" + DefinerDataType.class.getName() + System.lineSeparator());\n        return definitions;\n    }\n\n    public interface DefinerContract {\n    }\n\n    public static final class DefinerDataType {\n        public DefinerDataType() {\n        }\n    }\n\n    public static final class DefinerTypeAdapter implements TypeAdapter {\n        private static Class<?> checkedProxyClass;\n\n        private Project project;\n        private Object proxy;\n\n        public DefinerTypeAdapter() {\n        }\n\n        @Override\n        public void setProject(Project project) {\n            this.project = project;\n        }\n\n        @Override\n        public Project getProject() {\n            return project;\n        }\n\n        @Override\n        public void setProxy(Object proxy) {\n            this.proxy = proxy;\n        }\n\n        @Override\n        public Object getProxy() {\n            return proxy;\n        }\n\n        @Override\n        public void checkProxyClass(Class proxyClass) {\n            checkedProxyClass = proxyClass;\n        }\n    }\n\n    public static final class DefinitionResourceClassLoader extends ClassLoader {\n        private final URL definitionsUrl;\n        private String requestedResourceName;\n\n        DefinitionResourceClassLoader(ClassLoader parent, URL definitionsUrl) {\n            super(parent);\n            this.definitionsUrl = definitionsUrl;\n        }\n\n        @Override\n        public Enumeration<URL> getResources(String name) throws IOException {\n            requestedResourceName = name;\n            if (RESOURCE_NAME.equals(name)) {\n                return Collections.enumeration(Collections.singleton(definitionsUrl));\n            }\n            return super.getResources(name);\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778139441994}, {"role": "toolResult", "toolCallId": "call_cbxPlNlxe6iFy8RclC8U4SuY|fc_015b5ba69f539c620169fc4131a8e08196a3d4ea738abf3f4d", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage ant.ant;\n\nimport java.lang.invoke.MethodHandles;\nimport java.lang.invoke.VarHandle;\n\nimport org.apache.tools.ant.ComponentHelper;\nimport org.apache.tools.ant.Project;\nimport org.apache.tools.ant.Task;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ProjectTest {\n    private static final String COMPONENT_HELPER_REFERENCE = \"ant.ComponentHelper\";\n    private static final String PROJECT_CLASS_CACHE_FIELD = \"class$org$apache$tools$ant$Project\";\n\n    @Test\n    void checkTaskClassInspectsPublicNoArgConstructor() {\n        Project project = new Project();\n        PermissiveComponentHelper componentHelper = new PermissiveComponentHelper();\n        componentHelper.setProject(project);\n        project.addReference(COMPONENT_HELPER_REFERENCE, componentHelper);\n\n        try {\n            project.checkTaskClass(PublicTask.class);\n        } catch (NullPointerException exception) {\n            // Ant 1.6 passes a null parameter array to Class#getConstructor from pre-varargs bytecode.\n            assertThat(exception).isInstanceOf(NullPointerException.class);\n        }\n    }\n\n    @Test\n    void setProjectReferenceResolvesProjectParameterTypeForPlainObjects() {\n        Project project = new Project();\n        ProjectAwareObject object = new ProjectAwareObject();\n\n        resetCachedProjectClass();\n        project.setProjectReference(object);\n\n        assertThat(object.project).isSameAs(project);\n    }\n\n    private static void resetCachedProjectClass() {\n        try {\n            MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(Project.class, MethodHandles.lookup());\n            VarHandle projectClassCache = lookup.findStaticVarHandle(\n                    Project.class,\n                    PROJECT_CLASS_CACHE_FIELD,\n                    Class.class\n            );\n            projectClassCache.set((Class<?>) null);\n        } catch (IllegalAccessException | NoSuchFieldException exception) {\n            throw new AssertionError(\"Unable to reset Project's legacy Project class cache\", exception);\n        }\n    }\n\n    public static final class PublicTask extends Task {\n        public PublicTask() {\n        }\n    }\n\n    public static final class ProjectAwareObject {\n        private Project project;\n\n        public void setProject(Project project) {\n            this.project = project;\n        }\n    }\n\n    public static final class PermissiveComponentHelper extends ComponentHelper {\n        @Override\n        public void checkTaskClass(Class taskClass) {\n            // Constructor validation is covered by Project.\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778139441994}, {"role": "toolResult", "toolCallId": "call_S1uH7LIYgZ2jfF6fLmOtp98E|fc_015b5ba69f539c620169fc4131a8f08196adb5446d77a9ce77", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage ant.ant;\n\nimport org.apache.tools.ant.AntClassLoader;\nimport org.apache.tools.ant.Project;\nimport org.apache.tools.ant.taskdefs.Available;\nimport org.apache.tools.ant.types.Path;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class AvailableTest {\n    private static final String ANT_DEFAULT_TASKS_RESOURCE =\n        \"org/apache/tools/ant/taskdefs/defaults.properties\";\n\n    @Test\n    void evalFindsClassThroughTaskClassLoader() {\n        Available available = newAvailable();\n        available.setClassname(String.class.getName());\n\n        assertThat(available.eval()).isTrue();\n    }\n\n    @Test\n    void evalFindsClassThroughConfiguredAntClassLoader() {\n        Available available = newAvailable();\n        available.createClasspath();\n        available.setClassname(String.class.getName());\n\n        assertThat(available.eval()).isTrue();\n    }\n\n    @Test\n    void evalFindsResourceThroughTaskClassLoader() {\n        Available available = newAvailable();\n        available.setResource(ANT_DEFAULT_TASKS_RESOURCE);\n\n        assertThat(available.eval()).isTrue();\n    }\n\n    private static Available newAvailable() {\n        Project project = new AvailableProject();\n        Available available = new Available();\n        available.setProject(project);\n        return available;\n    }\n}\n\nfinal class AvailableProject extends Project {\n    @Override\n    public AntClassLoader createClassLoader(Path path) {\n        AntClassLoader loader = new AntClassLoader(getClass().getClassLoader(), true);\n        loader.setProject(this);\n        loader.setClassPath(path);\n        return loader;\n    }\n}\n"}], "isError": false, "timestamp": 1778139441994}]}
