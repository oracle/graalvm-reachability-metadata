  package org.apache.tools.ant;
  
  
  /**
   * This class contains all the information
   * on a particular ant type,
   * the classname, adaptor and the class
   * it should be assignable from.
   * This type replaces the task/datatype split
   * of pre ant 1.6.
   *
   * @author Peter Reilly
