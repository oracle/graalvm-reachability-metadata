  package ant.ant;
  
  import java.io.IOException;
  import java.io.PrintStream;
  import java.lang.invoke.MethodHandles;
  import java.lang.invoke.VarHandle;
  import java.nio.charset.StandardCharsets;
  import java.nio.file.Files;
  import java.nio.file.Path;
  import java.util.concurrent.CountDownLatch;
  import java.util.concurrent.TimeUnit;
  import java.util.concurrent.atomic.AtomicInteger;
  
  import org.apache.tools.ant.BuildEvent;
  import org.apache.tools.ant.BuildException;
  import org.apache.tools.ant.BuildListener;
  import org.apache.tools.ant.BuildLogger;
  import org.apache.tools.ant.Main;
  import org.apache.tools.ant.Project;
  import org.apache.tools.ant.input.InputHandler;
  import org.apache.tools.ant.input.InputRequest;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class MainTest {
  
      @Test
      void addBuildListenersLoadsConfiguredLoggerAndListenerClassesByName() throws IOException {
          Path buildFile = createBuildFile();
          CustomBuildLogger.reset();
          CustomBuildListener.reset();
  
          ConfiguredMain main = new ConfiguredMain(
              "-buildfile", buildFile.toString(),
              "-logger", CustomBuildLogger.class.getName(),
              "-listener", CustomBuildListener.class.getName(),
              "-emacs",
              "-quiet");
          Project project = new Project();
  
          main.addListenersTo(project);
  
          assertThat(CustomBuildLogger.instances).hasValue(1);
          assertThat(CustomBuildLogger.messageOutputLevel).isEqualTo(Project.MSG_WARN);
          assertThat(CustomBuildLogger.output).isNotNull();
          assertThat(CustomBuildLogger.error).isNotNull();
          assertThat(CustomBuildLogger.emacsMode).isTrue();
          assertThat(CustomBuildListener.instances).hasValue(1);
          assertThat(CustomBuildListener.project).isSameAs(project);
          assertThat(project.getBuildListeners())
              .hasAtLeastOneElementOfType(CustomBuildLogger.class)
              .hasAtLeastOneElementOfType(CustomBuildListener.class);
      }
  
      @Test
      void startAntLoadsConfiguredInputHandlerClassByNameBeforeRunningBuild() throws IOException, InterruptedException {
          Path buildFile = createBuildFile();
          CustomInputHandler.reset();
          Thread antThread = new Thread(
              () -> new Main().startAnt(new String[] {
                  "-buildfile", buildFile.toString(),
                  "-inputhandler", CustomInputHandler.class.getName()
              }, null, null),
              "ant-main-input-handler");
          antThread.setDaemon(true);
  
          antThread.start();
  
          assertThat(CustomInputHandler.projectReferenceSet.await(10, TimeUnit.SECONDS)).isTrue();
          assertThat(CustomInputHandler.instances).hasValue(1);
          assertThat(CustomInputHandler.project).isNotNull();
      }
  
      @Test
      void getAntVersionLoadsVersionResourceThroughMainClassLiteralCompatibilityPath() {
          String antVersion = Main.getAntVersion();
  
          assertThat(antVersion).startsWith("Apache Ant version ");
          assertThat(antVersion).contains(" compiled on ");
      }
  
      @Test
      void getAntVersionInitializesLegacyClassLiteralCacheByName() throws Throwable {
          MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(Main.class, MethodHandles.lookup());
          VarHandle antVersion = lookup.findStaticVarHandle(Main.class, "antVersion", String.class);
          VarHandle mainClass = lookup.findStaticVarHandle(
              Main.class,
              "class$org$apache$tools$ant$Main",
              Class.class);
          Object previousAntVersion = antVersion.get();
          Object previousMainClass = mainClass.get();
          try {
              antVersion.set(null);
              mainClass.set(null);
  
              String version = Main.getAntVersion();
  
              assertThat(version).startsWith("Apache Ant version ");
              assertThat(mainClass.get()).isSameAs(Main.class);
          } finally {
              antVersion.set(previousAntVersion);
              mainClass.set(previousMainClass);
          }
      }
  
      private static Path createBuildFile() throws IOException {
          Path directory = Files.createTempDirectory("ant-main");
          Path buildFile = directory.resolve("build.xml");
          Files.writeString(buildFile, """
              <project name="main-test" default="ok">
                  <target name="ok"/>
              </project>
              """, StandardCharsets.UTF_8);
          buildFile.toFile().deleteOnExit();
          directory.toFile().deleteOnExit();
          return buildFile;
      }
  
      private static final class ConfiguredMain extends Main {
          ConfiguredMain(String... args) throws BuildException {
              super(args);
          }
  
          void addListenersTo(Project project) {
              addBuildListeners(project);
          }
      }
  
      public static final class CustomBuildLogger implements BuildLogger {
          private static final AtomicInteger instances = new AtomicInteger();
          private static int messageOutputLevel;
          private static PrintStream output;
          private static PrintStream error;
          private static boolean emacsMode;
  
          public CustomBuildLogger() {
              instances.incrementAndGet();
          }
  
          static void reset() {
              instances.set(0);
              messageOutputLevel = -1;
              output = null;
              error = null;
              emacsMode = false;
          }
  
          @Override
          public void setMessageOutputLevel(int level) {
              messageOutputLevel = level;
          }
  
          @Override
  
