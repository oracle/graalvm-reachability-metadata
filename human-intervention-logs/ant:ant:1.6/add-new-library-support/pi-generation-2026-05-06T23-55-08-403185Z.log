  package ant.ant;
  
  import java.util.concurrent.atomic.AtomicInteger;
  
  import org.apache.tools.ant.BuildException;
  import org.apache.tools.ant.Project;
  import org.apache.tools.ant.ProjectHelper;
  import org.apache.tools.ant.helper.ProjectHelper2;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ProjectHelperTest {
  
      @Test
      void getProjectHelperLoadsSystemPropertyHelperWithContextClassLoader() {
          ClassLoader originalLoader = Thread.currentThread().getContextClassLoader();
          String originalHelper = System.getProperty(ProjectHelper.HELPER_PROPERTY);
          CustomProjectHelper.reset();
          try {
              Thread.currentThread().setContextClassLoader(ProjectHelperTest.class.getClassLoader());
              System.setProperty(ProjectHelper.HELPER_PROPERTY, CustomProjectHelper.class.getName());
  
              ProjectHelper helper = ProjectHelper.getProjectHelper();
  
              assertThat(helper).isInstanceOf(CustomProjectHelper.class);
              assertThat(CustomProjectHelper.instances).hasValue(1);
          } finally {
              restoreProjectHelperProperty(originalHelper);
              Thread.currentThread().setContextClassLoader(originalLoader);
          }
      }
  
      @Test
      void getProjectHelperFallsBackToClassForNameWhenContextClassLoaderIsUnavailable() {
          ClassLoader originalLoader = Thread.currentThread().getContextClassLoader();
          String originalHelper = System.getProperty(ProjectHelper.HELPER_PROPERTY);
          CustomProjectHelper.reset();
          try {
              Thread.currentThread().setContextClassLoader(null);
              System.setProperty(ProjectHelper.HELPER_PROPERTY, CustomProjectHelper.class.getName());
  
              ProjectHelper helper = ProjectHelper.getProjectHelper();
  
              assertThat(helper).isInstanceOf(CustomProjectHelper.class);
              assertThat(CustomProjectHelper.instances).hasValue(1);
          } finally {
              restoreProjectHelperProperty(originalHelper);
              Thread.currentThread().setContextClassLoader(originalLoader);
          }
      }
  
      @Test
      void getProjectHelperSearchesContextAndSystemServiceResourcesBeforeDefaulting() {
          ClassLoader originalLoader = Thread.currentThread().getContextClassLoader();
          String originalHelper = System.getProperty(ProjectHelper.HELPER_PROPERTY);
          try {
              Thread.currentThread().setContextClassLoader(ProjectHelperTest.class.getClassLoader());
              System.clearProperty(ProjectHelper.HELPER_PROPERTY);
  
              ProjectHelper helper = ProjectHelper.getProjectHelper();
  
              assertThat(helper).isInstanceOf(ProjectHelper2.class);
          } finally {
              restoreProjectHelperProperty(originalHelper);
              Thread.currentThread().setContextClassLoader(originalLoader);
          }
      }
  
      private static void restoreProjectHelperProperty(String originalHelper) {
          if (originalHelper == null) {
              System.clearProperty(ProjectHelper.HELPER_PROPERTY);
          } else {
              System.setProperty(ProjectHelper.HELPER_PROPERTY, originalHelper);
          }
      }
  
      public static final class CustomProjectHelper extends ProjectHelper {
          private static final AtomicInteger instances = new AtomicInteger();
  
          public CustomProjectHelper() {
              instances.incrementAndGet();
          }
  
          static void reset() {
              instances.set(0);
          }
  
          @Override
          public void parse(Project project, Object source) throws BuildException {
              project.setProperty("project-helper-test.source", String.valueOf(source));
          }
      }
  }
