         .contains(\"------- Ant diagnostics report -------\")\n                .contains(\"Implementation Version\")\n                .contains(\"core tasks     :\")\n                .contains(\"ANT_HOME/lib jar listing\")\n                .contains(\"diagnostic.jar\")\n                .contains(\"Tasks availability\")\n                .contains(\"org.apache.env.Which diagnostics\")\n                .contains(\"XML Parser information\")\n                .contains(\"System properties\");\n            assertThat(report)\n                .containsAnyOf(\n                    \"All defined tasks are available\",\n                    \" : Not Available\",\n                    \" : Missing dependency \",\n                    \"None available\");\n            assertThat(Which.wasCalled()).isTrue();\n        } finally {\n            if (previousAntHome == null) {\n                System.clearProperty(\"ant.home\");\n            } else {\n                System.setProperty(\"ant.home\", previousAntHome);\n            }\n        }\n    }\n\n    @Test\n    void availabilityAndVersionValidationUseOptionalTaskLookup() {\n        boolean firstLookup = Diagnostics.isOptionalAvailable();\n\n        Diagnostics.validateVersion();\n\n        assertThat(Diagnostics.isOptionalAvailable()).isEqualTo(firstLookup);\n    }\n}\n"}], "isError": false, "timestamp": 1778104269754}, {"role": "toolResult", "toolCallId": "call_dJjXIG3y1gmznWVEMwYAieJu|fc_06426b067a42cc6a0169fbb7cd855c819c878ec120d64ce4bd", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org.apache.env;\n\npublic final class Which {\n    private static boolean called;\n\n    private Which() {\n    }\n\n    public static void main(String[] args) {\n        called = true;\n    }\n\n    public static void reset