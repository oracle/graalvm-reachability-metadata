  package ant.ant;
  
  import java.io.ByteArrayOutputStream;
  import java.io.PrintStream;
  import java.nio.charset.StandardCharsets;
  import java.nio.file.Files;
  import java.nio.file.Path;
  
  import org.apache.tools.ant.Diagnostics;
  import org.junit.jupiter.api.Test;
  import org.junit.jupiter.api.io.TempDir;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class DiagnosticsTest {
  
      @TempDir
      Path tempDirectory;
  
      @Test
      void reportLoadsTaskDefinitionsAndImplementationVersionReflectively() throws Exception {
          Path libDirectory = tempDirectory.resolve("lib");
          Files.createDirectories(libDirectory);
          Files.writeString(libDirectory.resolve("diagnostic.jar"), "diagnostic fixture", StandardCharsets.UTF_8);
  
          String previousAntHome = System.getProperty("ant.home");
          System.setProperty("ant.home", tempDirectory.toString());
          try {
              ByteArrayOutputStream bytes = new ByteArrayOutputStream();
              try (PrintStream stream = new PrintStream(bytes, true, StandardCharsets.UTF_8)) {
                  Diagnostics.doReport(stream);
              }
  
              String report = bytes.toString(StandardCharsets.UTF_8);
              assertThat(report)
                  .contains("------- Ant diagnostics report -------")
                  .contains("Implementation Version")
                  .contains("core tasks     :")
                  .contains("ANT_HOME/lib jar listing")
                  .contains("diagnostic.jar")
                  .contains("Tasks availability")
                  .contains("XML Parser information")
                  .contains("System properties");
              assertThat(report)
                  .containsAnyOf(
                      "All defined tasks are available",
                      " : Not Available",
                      " : Missing dependency ",
                      "None available");
          } finally {
              if (previousAntHome == null) {
                  System.clearProperty("ant.home");
              } else {
                  System.setProperty("ant.home", previousAntHome);
              }
          }
      }
  
      @Test
      void availabilityAndVersionValidationUseOptionalTaskLookup() {
          boolean firstLookup = Diagnostics.isOptionalAvailable();
  
          Diagnostics.validateVersion();
  
          assertThat(Diagnostics.isOptionalAvailable()).isEqualTo(firstLookup);
      }
  }
