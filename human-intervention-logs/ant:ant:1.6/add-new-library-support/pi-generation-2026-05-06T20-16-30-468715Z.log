elper = IntrospectionHelper.getHelper(IntrospectionTarget.class);\n\n        assertThat(helper.supportsCharacters()).isTrue();\n        helper.addText(project, target, \"body text\");\n        assertThat(target.text).isEqualTo(\"body text\");\n\n        helper.setAttribute(project, target, \"custom\", \"attribute value\");\n        assertThat(target.custom.value).isEqualTo(\"attribute value\");\n\n        Object noArgConfigured = helper.createElement(project, target, \"noargconfigured\");\n        assertThat(noArgConfigured).isInstanceOf(NoArgNested.class);\n        helper.storeElement(project, target, noArgConfigured, \"noargconfigured\");\n        assertThat(target.noArgConfigured).isSameAs(noArgConfigured);\n\n        Object projectConfigured = helper.createElement(project, target, \"projectconfigured\");\n        assertThat(projectConfigured).isInstanceOf(ProjectNested.class);\n        assertThat(((ProjectNested) projectConfigured).project).isNull();\n        helper.storeElement(project, target, projectConfigured, \"projectconfigured\");\n        assertThat(target.projectConfigured).isSameAs(projectConfigured);\n\n        Object noArgAdded = helper.createElement(project, target, \"noarg\");\n        assertThat(noArgAdded).isInstanceOf(NoArgNested.class);\n        assertThat(target.noArgAdded).isSameAs(noArgAdded);\n\n        Object projectAdded = helper.createElement(project, target, \"project\");\n        assertThat(projectAdded).isInstanceOf(ProjectNested.class);\n        assertThat(((ProjectNested) projectAdded).project).isNull();\n        assertThat(target.projectAdded).isSameAs(projectAdded);\n    }\n\n    public static final class IntrospectionTarget {\n        private String text;\n        private CustomAttribute custom;\n        private NoArgNested noArgConfigured;\n        private ProjectNested projectConfigured;\n        private NoArgNested noArgAdded;\n        private ProjectNested projectAdded;\n\n        public void addText(String value) {\n        