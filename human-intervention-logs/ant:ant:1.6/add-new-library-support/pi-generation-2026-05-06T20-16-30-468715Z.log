  /*
   * Copyright and related rights waived via CC0
   *
   * You should have received a copy of the CC0 legalcode along with this
   * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.
   */
  package ant.ant;
  
  import java.io.IOException;
  import java.io.InputStream;
  import java.nio.charset.StandardCharsets;
  import java.nio.file.Files;
  import java.nio.file.Path;
  
  import javax.xml.transform.Source;
  import javax.xml.transform.sax.SAXSource;
  
  import org.apache.tools.ant.Project;
  import org.apache.tools.ant.types.Path.PathElement;
  import org.apache.tools.ant.types.ResourceLocation;
  import org.apache.tools.ant.types.XMLCatalog;
  import org.junit.jupiter.api.Test;
  import org.junit.jupiter.api.io.TempDir;
  import org.xml.sax.InputSource;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class XMLCatalogInnerExternalResolverTest {
      private static final String EXTERNAL_PUBLIC_ID = "-//Ant Test//DTD External 1.0//EN";
      private static final String INLINE_PUBLIC_ID = "-//Ant Test//DTD Inline Missing 1.0//EN";
      private static final String INLINE_URI = "missing-inline.xml";
  
      @TempDir
      Path tempDirectory;
  
      @Test
      void resolveEntityUsesXmlCommonsBridgeForExternalCatalogAndFallbacks() throws Exception {
          XMLCatalog catalog = createCatalogWithExternalResolver();
          catalog.addDTD(resourceLocation(INLINE_PUBLIC_ID, "missing-inline.dtd"));
  
          InputSource externalSource = catalog.resolveEntity(EXTERNAL_PUBLIC_ID, null);
          assertThat(externalSource).isNotNull();
          closeByteStream(externalSource);
  
          InputSource inlineFallback = catalog.resolveEntity(INLINE_PUBLIC_ID, null);
          assertThat(inlineFallback).isNull();
  
          InputSource unresolvedFallback = catalog.resolveEntity("-//Ant Test//DTD Absent 1.0//EN", null);
          assertThat(unresolvedFallback).isNull();
      }
  
      @Test
      void resolveUsesXmlCommonsBridgeForMatchingAndUnmatchedUris() throws Exception {
          XMLCatalog catalog = createCatalogWithExternalResolver();
          catalog.addEntity(resourceLocation(INLINE_URI, "missing-inline.xml"));
  
          Source matchingSource = catalog.resolve(INLINE_URI + "#fragment", tempDirectory.toUri().toString());
          assertThat(matchingSource).isInstanceOf(SAXSource.class);
          assertThat(((SAXSource) matchingSource).getInputSource()).isNotNull();
  
          Source unmatchedSource = catalog.resolve("absent.xml", tempDirectory.toUri().toString());
          assertThat(unmatchedSource).isInstanceOf(SAXSource.class);
          assertThat(((SAXSource) unmatchedSource).getInputSource()).isNotNull();
      }
  
      private XMLCatalog createCatalogWithExternalResolver() throws Exception {
          Path externalDtd = tempDirectory.resolve("external.dtd");
          Files.writeString(externalDtd, "<!ELEMENT external EMPTY>", StandardCharsets.UTF_8);
  
          Path catalogFile = tempDirectory.resolve("catalog.cat");
          Files.writeString(catalogFile,
              "PUBLIC \"" + EXTERNAL_PUBLIC_ID + "\" \"" + externalDtd.getFileName() + "\"\n",
              StandardCharsets.UTF_8);
  
          Project project = new Project();
          project.setBaseDir(tempDirectory.toFile());
  
          XMLCatalog catalog = new XMLCatalog();
          catalog.setProject(project);
          PathElement catalogPathElement = catalog.createCatalogPath().createPathElement();
          catalogPathElement.setLocation(catalogFile.toFile());
          return catalog;
      }
  
      private ResourceLocation resourceLocation(String publicId, String location) {
          ResourceLocation resourceLocation = new ResourceLocation();
          resourceLocation.setPublicId(publicId);
          resourceLocation.setLocation(location);
          return resourceLocation;
      }
  
      private void closeByteStream(InputSource source) throws IOException {
          InputStream byteStream = source.getByteStream();
          if (byteStream != null) {
              byteStream.close();
          }
      }
  }
