\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage ant.ant;\n\nimport org.apache.tools.ant.util.regexp.Jdk14RegexpMatcher;\nimport org.apache.tools.ant.util.regexp.RegexpMatcher;\nimport org.apache.tools.ant.util.regexp.RegexpMatcherFactory;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class RegexpMatcherFactoryTest {\n    @Test\n    void defaultMatcherUsesAvailableJdkRegexpImplementation() {\n        String originalImplementation = System.getProperty(\"ant.regexp.regexpimpl\");\n        System.clearProperty(\"ant.regexp.regexpimpl\");\n        try {\n            RegexpMatcher matcher = new RegexpMatcherFactory().newRegexpMatcher();\n\n            assertThat(matcher).isInstanceOf(Jdk14RegexpMatcher.class);\n            matcher.setPattern(\"native-[0-9]+\");\n            assertThat(matcher.matches(\"ant native-16 test\")).isTrue();\n            assertThat(matcher.matches(\"ant native test\")).isFalse();\n        } finally {\n            if (originalImplementation == null) {\n                System.clearProperty(\"ant.regexp.regexpimpl\");\n            } else {\n                System.setProperty(\"ant.regexp.regexpimpl\", originalImplementation);\n            }\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1453, "output": 751, "cacheRead": 15360, "cacheWrite": 0, "totalTokens": 17564, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778130070927, "responseId": "resp_00af2004bcad47290169fc1c974a7c819789dd277f52b72c54"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_TjtvgIfO2XlhpoAM97iwjtIV|fc_00af2004bcad47290169fc1c9de0808197a5239e7bab5e6298", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1379 bytes to tests/src/ant/ant/1.6/src/test/java/ant/ant/RegexpMatcherFactoryTest.java"}], "isError"