                          "org.apache.tools.ant.taskdefs.optional.XslpLiaison";
  
      /** Name of the now-deprecated Xalan liaison class */
      private static final String XALAN_LIAISON_CLASS =
                          "org.apache.tools.ant.taskdefs.optional.XalanLiaison";
  
