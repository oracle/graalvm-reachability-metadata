  package ant.ant;
  
  import java.io.File;
  
  import org.apache.tools.ant.AntClassLoader;
  import org.apache.tools.ant.BuildException;
  import org.apache.tools.ant.Project;
  import org.apache.tools.ant.taskdefs.XSLTLiaison;
  import org.apache.tools.ant.taskdefs.XSLTProcess;
  import org.apache.tools.ant.types.Path;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class XSLTProcessTest {
      private static final String TRAX_LIAISON = "org.apache.tools.ant.taskdefs.optional.TraXLiaison";
      private static final String XALAN_LIAISON = "org.apache.tools.ant.taskdefs.optional.XalanLiaison";
      private static final String XSLP_LIAISON = "org.apache.tools.ant.taskdefs.optional.XslpLiaison";
  
      @Test
      void resolvesTraxProcessorThroughSystemClassLoader() {
          ExposedXSLTProcess task = newTask();
          task.setProcessor("trax");
  
          XSLTLiaison liaison = task.resolveConfiguredLiaison();
  
          assertThat(liaison.getClass().getName()).isEqualTo(TRAX_LIAISON);
      }
  
      @Test
      void resolvesXslpProcessorThroughSystemClassLoaderUntilOptionalRuntimeDependencyIsNeeded() {
          ExposedXSLTProcess task = newTask();
          task.setProcessor("xslp");
  
          try {
              XSLTLiaison liaison = task.resolveConfiguredLiaison();
              assertThat(liaison.getClass().getName()).isEqualTo(XSLP_LIAISON);
          } catch (Throwable failure) {
              assertThat(optionalProcessorFailureMessage(failure)).contains("com/kvisco/xsl");
          }
      }
  
      @Test
      void resolvesXalanProcessorThroughSystemClassLoaderUntilOptionalRuntimeDependencyIsNeeded() {
          ExposedXSLTProcess task = newTask();
          task.setProcessor("xalan");
  
          try {
              XSLTLiaison liaison = task.resolveConfiguredLiaison();
              assertThat(liaison.getClass().getName()).isEqualTo(XALAN_LIAISON);
          } catch (Throwable failure) {
              assertThat(optionalProcessorFailureMessage(failure))
                  .containsAnyOf(
                      "org/apache/xalan/xslt",
                      "Could not initialize class org/apache/tools/ant/taskdefs/optional/XalanLiaison");
          }
      }
  
      @Test
      void resolvesCustomProcessorThroughSystemClassLoader() {
          ExposedXSLTProcess task = newTask();
          task.setProcessor(RecordingLiaison.class.getName());
  
          XSLTLiaison liaison = task.resolveConfiguredLiaison();
  
          assertThat(liaison).isInstanceOf(RecordingLiaison.class);
      }
  
      @Test
      void resolvesCustomProcessorThroughConfiguredAntClassLoader() {
          ExposedXSLTProcess task = newTask();
          task.setProcessor(RecordingLiaison.class.getName());
          task.setClasspath(new Path(task.getProject(), System.getProperty("java.class.path", "")));
  
          XSLTLiaison liaison = task.resolveConfiguredLiaison();
  
          assertThat(liaison.getClass().getName()).isEqualTo(RecordingLiaison.class.getName());
      }
  
      private static ExposedXSLTProcess newTask() {
          Project project = new ParentFirstProject();
  
          ExposedXSLTProcess task = new ExposedXSLTProcess();
          task.setProject(project);
          return task;
      }
  
      private static String optionalProcessorFailureMessage(Throwable failure) {
          Throwable cursor = failure;
          while (cursor instanceof BuildException && cursor.getCause() != null) {
              cursor = cursor.getCause();
          }
          String message = cursor.toString();
          return message.replace('.', '/');
      }
  
      public static final class ParentFirstProject extends Project {
          @Override
          public AntClassLoader createClassLoader(Path path) {
              AntClassLoader loader = new AntClassLoader(getClass().getClassLoader(), true);
              loader.setProject(this);
              loader.setClassPath(path);
              return loader;
          }
      }
  
