       * @since Ant 1.6
       */
      private Factory factory = null;
  
      /**
       * whether to reuse Transformer if transforming multiple files.
       * @since 1.5.2
       */
      private boolean reuseLoadedStylesheet = true;
  
      /**
       * Creates a new XSLTProcess Task.
       */
      public XSLTProcess() {
          fileUtils = FileUtils.newFileUtils();
      } //-- XSLTProcess
  
