reateClassLoader(Path path) {\n            AntClassLoader loader = new AntClassLoader(getClass().getClassLoader(), true);\n            loader.setProject(this);\n            loader.setClassPath(path);\n            return loader;\n        }\n    }\n\n    public static final class ExposedXSLTProcess extends XSLTProcess {\n        XSLTLiaison resolveConfiguredLiaison() {\n            return getLiaison();\n        }\n    }\n\n    public static final class RecordingLiaison implements XSLTLiaison {\n        public RecordingLiaison() {\n        }\n\n        @Override\n        public void setStylesheet(File stylesheet) {\n        }\n\n        @Override\n        public void addParam(String name, String expression) {\n        }\n\n        @Override\n        public void transform(File infile, File outfile) {\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778107052566}]}
