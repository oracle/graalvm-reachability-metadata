              throw new BuildException(ex);
          }
  
  
          Method executeM = null;
          try {
              Class c = proxy.getClass();
              executeM = c.getMethod("execute", new Class[0]);
              if (executeM == null) {
                  log("No public execute() in " + proxy.getClass(),
