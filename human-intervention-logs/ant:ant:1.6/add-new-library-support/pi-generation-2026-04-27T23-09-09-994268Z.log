                      log("Unable to create Class Loader: "
                          + e.getMessage(), Project.MSG_DEBUG);
              }
          }
  
          if (loader == null) {
              loader = new AntClassLoader();
          }
  
          loader.setProject(this);
          return loader;
      }
  
      /**
