[tool-call] delta {"path":"tests/src/ant/ant/1.6/build.gradle","edits":[{"oldText":"dependencies {\n    testImplementation \"ant:ant:$libraryVersion\"\n    testImplementation \"ant:ant-launcher:$libraryVersion\"\n    testImplementation \"ant:ant-nodeps:$libraryVersion\"\n    testImplementation \"ant:ant-trax:$libraryVersion\"\n    testImplementation \"ant:ant-xalan1:$libraryVersion\"\n    testImplementation \"ant:ant-xslp:$libraryVersion\"\n    testImplementation 'bcel:bcel:5.1'\n    testImplementation 'xml-resolver:xml-resolver:1.2'\n    testImplementation 'org.assertj:assertj-core:3.22.0'\n}\n\ntasks.withType(Test).configureEach {\n    jvmArgs '-Dfile.encoding=ISO-8859-1'\n}\n","newText":"dependencies {\n    testImplementation \"ant:ant:$libraryVersion\"\n    testImplementation \"ant:ant-launcher:$libraryVersion\"\n    testImplementation \"ant:ant-nodeps:$libraryVersion\"\n    testImplementation \"ant:ant-trax:$libraryVersion\"\n    testImplementation \"ant:ant-xalan1:$libraryVersion\"\n    testImplementation \"ant:ant-xslp:$libraryVersion\"\n    testImplementation 'bcel:bcel:5.1'\n    testImplementation 'xml-resolver:xml-resolver:1.2'\n    testImplementation 'org.assertj:assertj-core:3.22.0'\n}\n\nProvider<Directory> legacyBase64Classes = layout.buildDirectory.dir(\"classes/java/legacyBase64\")\nDirectory legacyBase64Sources = layout.projectDirectory.dir(\"src/legacyBase64/java\")\n\nTaskProvider<JavaCompile> compileLegacyBase64Encoder = tasks.register(\"compileLegacyBase64Encoder\", JavaCompile) {\n    source = fileTree(legacyBase64Sources)\n    destinationDirectory = legacyBase64Classes\n    classpath = files()\n    options.release.set(null)\n    options.compilerArgs.addAll([\n            \"--add-modules\",\n            \"jdk.unsupported\",\n            \"--patch-module\",\n            \"jdk.unsupported=${legacyBase64Sources.asFile.absolutePath}\"\n    ])\n}\n\ntasks.withType(Test).configureEach {\n    dependsOn compileLegacyBase64Encoder\n    jvmArgs '-Dfile.encoding=ISO-8859-1'\n    jvmArgs '--add-modules', 'jdk.unsupported'\n    doFirst {\n        jvmArgs '--patch-module', \"jdk.unsupported=${legacyBase64Classes.get().asFile.absolutePath}\"\n    }\n}\n"}]}
