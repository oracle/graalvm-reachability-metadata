 with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage ant.ant;\n\nimport org.apache.tools.ant.IntrospectionHelper;\nimport org.apache.tools.ant.Project;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class IntrospectionHelperTest {\n\n    @Test\n    void introspectsAttributesTextAndNestedElements() {\n        Project project = new Project();\n        IntrospectionTarget target = new IntrospectionTarget();\n\n        IntrospectionHelper helper = IntrospectionHelper.getHelper(project, IntrospectionTarget.class);\n\n        assertThat(helper.supportsCharacters()).isTrue();\n        helper.addText(project, target, \"body text\");\n        assertThat(target.text).isEqualTo(\"body text\");\n\n        helper.setAttribute(project, target, \"custom\", \"attribute value\");\n        assertThat(target.custom.value).isEqualTo(\"attribute value\");\n\n        Object noArgConfigured = helper.createElement(project, target, \"noargconfigured\");\n        assertThat(noArgConfigured).isInstanceOf(NoArgNested.class);\n        helper.storeElement(project, target, noArgConfigured, \"noargconfigured\");\n        assertThat(target.noArgConfigured).isSameAs(noArgConfigured);\n\n        Object projectConfigured = helper.createElement(project, target, \"projectconfigured\");\n        assertThat(projectConfigured).isInstanceOf(ProjectNested.class);\n        assertThat(((ProjectNested) projectConfigured).project).isSameAs(project);\n        helper.storeElement(project, target, projectConfigured, \"projectconfigured\");\n        assertThat(target.projectConfigured).isSameAs(projectConfigured);\n\n        Object noArgAdded = helper.createElement(project, target, \"noarg\");\n        assertThat(noArgAdded).isInstanceOf(NoArgNested.class);\n        assertThat(target.noArgAdded).isSameAs(noArgAdded);\n\n        Object projectAdded = helper.createElement(project, target, \"project\");\n        assertThat(projectAdded).isInstanceOf(ProjectNested.class);\n        assertThat(((ProjectNested) projectAdded).project).isSameAs(project);\n        assertThat(target.projectAdded).isSameAs(projectAdded);\n    }\n\n    public static final class IntrospectionTarget {\n        private String text;\n        private CustomAttribute custom;\n        private NoArgNested noArgConfigured;\n        private ProjectNested projectConfigured;\n        private NoArgNested noArgAdded;\n        private ProjectNested projectAdded;\n\n        public void addText(String value) {\n            this.text = value;\n        }\n\n        public void setCustom(CustomAttribute value) {\n            this.custom = value;\n        }\n\n        public void addConfiguredNoArgConfigured(NoArgNested value) {\n            this.noArgConfigured = value;\n        }\n\n        public void addConfiguredProjectConfigured(ProjectNested value) {\n            this.projectConfigured = value;\n        }\n\n        public void addNoArg(NoArgNested value) {\n            this.noArgAdded = value;\n        }\n\n        public void addProject(ProjectNested value) {\n            this.projectAdded = value;\n        }\n    }\n\n    public static final class CustomAttribute {\n        private final String value;\n\n        public CustomAttribute(String value) {\n            this.value = value;\n        }\n    }\n\n    public static final class NoArgNested {\n    }\n\n    public static final class ProjectNested {\n        private final Project project;\n\n        public ProjectNested(Project project) {\n            this.project = project;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1444, "output": 1395, "cacheRead": 23040, "cacheWrite": 0, "totalTokens": 25879, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778096790322, "responseId": "resp_04024c650bad74260169fb9a971dc081a39d21c237c7