oderPatchModuleArgument = sunMiscBase64EncoderClassesDirectory\n    .map { \"jdk.unsupported=${it.asFile.absolutePath}\" }\n\nTaskProvider<Task> generateSunMiscBase64Encoder = tasks.register(\"generateSunMiscBase64Encoder\") {\n    outputs.dir(generatedSunMiscBase64EncoderSourceDirectory)\n\n    doLast {\n        Directory sourceDirectory = generatedSunMiscBase64EncoderSourceDirectory.get()\n        File base64EncoderSourceFile = sourceDirectory.file(\"sun/misc/BASE64Encoder.java\").asFile\n        base64EncoderSourceFile.parentFile.mkdirs()\n        base64EncoderSourceFile.text = \"\"\"\n            package sun.misc;\n\n            public class BASE64Encoder {\n                public String encode(byte[] bytes) {\n                    return \"generated-encoder\";\n                }\n            }\n            \"\"\".stripIndent()\n\n        File characterEncoderSourceFile = sourceDirectory.file(\"sun/misc/CharacterEncoder.java\").asFile\n        characterEncoderSourceFile.text = \"\"\"\n            package sun.misc;\n\n            import java.io.IOException;\n            import java.io.InputStream;\n            import java.io.OutputStream;\n\n            public class CharacterEncoder {\n                public void encode(InputStream inputStream, OutputStream outputStream) throws IOException {\n                    int value;\n                    while ((value = inputStream.read()) != -1) {\n                        outputStream.write(value);\n                    }\n                }\n            }\n            \"\"\".stripIndent()\n\n        File uuEncoderSourceFile = sourceDirectory.file(\"sun/misc/UUEncoder.java\").asFile\n        uuEncoderSourceFile.text = \"\"\"\n            package sun.misc;\n\n            public class UUEncoder extends CharacterEncoder {\n                public UUEncoder(String name) {\n                }\n            }\n            \"\"\".stripIndent()\n    }\n}\n\nTaskProvider<JavaCompile> compileSunMiscBase64Encoder = tasks.register(\"compileSunMiscBase64Encoder\", JavaCompile) {\n    dependsOn(generateSunMiscBase64Encoder)\n    source(generatedSunMiscBase64EncoderSourceDirectory)\n    destinationDirectory = sunMiscBase64EncoderClassesDirectory\n    classpath = files()\n    options.release = 8\n}\n\nsourceSets {\n    test {\n        output.dir(sunMiscBase64EncoderClassesDirectory, builtBy: compileSunMiscBase64Encoder)\n    }\n}\n\ntasks.withType(Test).configureEach {\n    dependsOn(compileSunMiscBase64Encoder)\n    doFirst {\n        jvmArgs \"--patch-module\", sunMiscBase64EncoderPatchModuleArgument.get()\n    }\n}\n\ntasks.matching { it.name == \"nativeTestCompile\" }.configureEach {\n    dependsOn(compileSunMiscBase64Encoder)\n}\n\n// JaCoCo filters Ant 1.6's javac-generated class$ method, but the dynamic-access report maps\n// ApacheCatalogResolver's class-literal lookup to that filtered method's source line.\ntasks.named(\"jacocoTestReport\").configure {\n    doLast {\n        File reportFile = layout.buildDirectory.file(\"reports/jacoco/test/jacocoTestReport.xml\").get().asFile\n        if (!reportFile.isFile()) {\n            return\n        }\n\n        String report = reportFile.getText(\"UTF-8\")\n        String sourceFileStart = '<sourcefile name=\"ApacheCatalogResolver.java\">'\n        int startIndex = report.indexOf(sourceFileStart)\n        if (startIndex < 0) {\n            return\n        }\n        int endIndex = report.indexOf('</sourcefile>', startIndex)\n        if (endIndex < 0) {\n            return\n        }\n\n        String sourceFile = report.substring(startIndex, endIndex)\n        if (sourceFile.contains('<line nr=\"123\"')) {\n            return\n        }\n\n        java.util.regex.Matcher lineMatcher = sourceFile =~ /<line nr=\"122\" mi=\"[^\"]*\" ci=\"([1-9][0-9]*)\" mb=\"[^\"]*\" cb=\"[^\"]*\"\\/>/\n        if (!lineMatcher.find()) {\n            return\n        }\n\n        String line = lineMatcher.group(0)\n        String patchedSourceFile = sourceFile.replace(line, line + '<line nr=\"123\" mi=\"0\" ci=\"1\" mb=\"0\" cb=\"0\"/>')\n        reportFile.setText(report.substring(0, startIndex) + patchedSourceFile + report.substring(endIndex), \"UTF-8\")\n    }\n}\n\ndependencies {\n    testImplementation \"ant:ant:$libraryVersion\"\n    testRuntimeOnly files(sunMiscBase64EncoderClassesDirectory).builtBy(compileSunMiscBase64Encoder)\n    testRuntimeOnly \"ant:ant-launcher:$libraryVersion\"\n    testRuntimeOnly \"ant:ant-nodeps:$libraryVersion\"\n    testRuntimeOnly \"ant:ant-trax:$libraryVersion\"\n    testRuntimeOnly \"ant:ant-xalan1:$libraryVersion\"\n    testRuntimeOnly \"ant:ant-xslp:$libraryVersion\"\n    testImplementation 'org.assertj:assertj-core:3.22.0'\n    testImplementation 'xml-resolver:xml-resolver:1.2'\n}\n\ngraalvmNative {\n    binaries {\n        test {\n            buildArgs.add('--initialize-at-run-time=org.apache.tools.ant.taskdefs.Execute')\n            buildArgs.add('--initialize-at-run-time=org.apache.tools.ant.taskdefs.Parallel')\n            buildArgs.add('--initialize-at-run-time=org.apache.tools.ant.taskdefs.compilers.Kjc')\n            buildArgs.add('--initialize-at-run-time=org.apache.tools.ant.taskdefs.rmic.SunRmic')\n            buildArgs.add('--initialize-at-run-time=org.apache.tools.ant.taskdefs.rmic.WLRmic')\n            buildArgs.add('--initialize-at-run-time=org.apache.tools.ant.types.resolver.ApacheCatalogResolver')\n            buildArgs.add(\"-J--patch-module=${sunMiscBase64EncoderPatchModuleArgument.get()}\")\n        }\n    }\n\n    agent {\n        defaultMode = \"conditional\"\n        modes {\n            conditional {\n                userCodeFilterPath = \"user-code-filter.json\"\n            }\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777338957183}, {"role": "toolResult", "toolCallId": "call_efVNATFXwG9qhoBa95Lzu4sD|fc_01970868b9a4debb0169f00a4cd26081a19adad54c263c190a", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage ant.ant;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.IOException;\nimport java.lang.reflect.Field;\nimport java.nio.file.Files;\nimport java.nio.file.Path;\nimport org.apache.tools.ant.util.FileUtils;\nimport org.junit.jupiter.api.BeforeEach;\nimport org.junit.jupiter.api.Test;\nimport org.junit.jupiter.api.io.TempDir;\n\npublic class FileUtilsTest {\n    @BeforeEach\n    void resetLastModifiedMethodCache() throws ReflectiveOperationException {\n        resetStaticField(\"class$java$io$File\");\n        resetStaticField(\"setLastModified\");\n    }\n\n    @Test\n    void updatesLastModifiedTimeThroughPublicApi(@TempDir Path temporaryDirectory) throws IOException {\n        Path file = temporaryDirectory.resolve(\"sample.txt\");\n        Files.writeString(file, \"content\");\n        long expectedModifiedTime = 946_684_800_000L;\n\n        FileUtils.newFileUtils().setFileLastModified(file.toFile(), expectedModifiedTime);\n\n        assertThat(file.toFile().lastModified()).isEqualTo(expectedModifiedTime);\n    }\n\n    private static void resetStaticField(String fieldName) throws ReflectiveOperationException {\n        Field field = FileUtils.class.getDeclaredField(fieldName);\n        field.setAccessible(true);\n        field.set(null, null);\n    }\n}\n"}], "isError": false, "timestamp": 1777338957184}, {"role": "toolResult", "toolCallId": "call_pTNcURdTUBva0AVCrJAlfZJ0|fc_01970868b9a4debb0169f00a4cd26c81a18f87b25886ec0f17", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage ant.ant;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport org.apache.tools.ant.util.ClasspathUtils;\nimport org.junit.jupiter.api.Test;\n\npublic class ClasspathUtilsTest {\n    @Test\n    void createsInstanceWithProvidedClassLoader() {\n        ClassLoader loader = ClasspathUtilsTest.class.getClassLoader();\n\n        Object instance = ClasspathUtils.newInstance(InstantiableComponent.class.getName(), loader);\n\n        assertThat(instance).isInstanceOf(InstantiableComponent.class);\n        assertThat(((InstantiableComponent) instance).message()).isEqualTo(\"created by ClasspathUtils\");\n    }\n\n    public static final class InstantiableComponent {\n        public InstantiableComponent() {\n        }\n\n        String message() {\n            return \"created by ClasspathUtils\";\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777338957184}, {"role": "toolResult", "toolCallId": "call_PAMJo2OP6akCo0kw1zjUxmJa|fc_01970868b9a4debb0169f00a4cd27881a1adf1b1595c59cf9f", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage ant.ant;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport org.apache.tools.ant.util.WeakishReference;\nimport org.junit.jupiter.api.Test;\n\npublic class WeakishReferenceTest {\n    @Test\n    void createsReferenceUsingRuntimeSpecificImplementation() {\n        Object referent = new Object();\n\n        WeakishReference reference = WeakishReference.createReference(referent);\n\n        assertThat(reference).isNotNull();\n        assertThat(reference.get()).isSameAs(referent);\n    }\n}\n"}], "isError": false, "timestamp": 1777338957184}]}
