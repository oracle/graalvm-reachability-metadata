@Override\n        public Logger getParentLogger() {\n            return Logger.getGlobal();\n        }\n    }\n\n    private static final class ExposedJDBCTask extends JDBCTask {\n        Connection openConnection() {\n            return getConnection();\n        }\n\n        AntClassLoader exposedLoader() {\n            return getLoader();\n        }\n    }\n\n    private static final class ParentFirstProject extends Project {\n        @Override\n        public AntClassLoader createClassLoader(Path path) {\n            AntClassLoader loader = new AntClassLoader(getClass().getClassLoader(), true);\n            loader.setProject(this);\n            loader.setClassPath(path);\n            return loader;\n        }\n    }\n}\n"}
