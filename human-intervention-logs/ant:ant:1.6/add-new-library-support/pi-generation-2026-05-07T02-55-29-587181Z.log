h(new Path(task.getProject()));\n\n        assertThatThrownBy(task::openConnection)\n            .isInstanceOf(BuildException.class)\n            .hasCauseInstanceOf(SQLException.class);\n\n        assertThat(NullConnectionDriver.instances()).isEqualTo(1);\n        assertThat(NullConnectionDriver.connectCalls()).isEqualTo(1);\n        assertThat(task.exposedLoader()).isNotNull();\n    }\n\n    private static ExposedJDBCTask newTask() {\n        ExposedJDBCTask task = new ExposedJDBCTask();\n        task.setProject(new ParentFirstProject());\n        task.setUserid(\"user\");\n        task.setPassword(\"password\");\n        task.setUrl(\"jdbc:ant-test:unhandled\");\n        return task;\n    }\n\n    public static final class NullConnectionDriver implements Driver {\n        private static final AtomicInteger INSTANCES = new AtomicInteger();\n        private static final AtomicInteger CONNECT_CALLS = new AtomicInteger();\n\n        public NullConnectionDriver() {\n            INSTANCES.incrementAndGet();\n        }\n\n        static void reset() {\n            INSTANCES.set(0);\n            CONNECT_CALLS.set(0);\n        }\n\n        static int instances() {\n            return INSTANCES.get();\n        }\n\n        static int connectCalls() {\n            return CONNECT_CALLS.get();\n        }\n\n        @Override\n        public Connection connect(String url, Properties info) {\n            CONNECT_CALLS.incrementAndGet();\n            return null;\n        }\n\n        @Override\n        public boolean acceptsURL(String url) {\n            return false;\n        }\n\n        @Override\n        public DriverPropertyInfo[] getPropertyInfo(String url, Properties info) {\n            return new DriverPropertyInfo[0];\n        }\n\n        @Override\n        public int getMajorVersion() {\n            return 1;\n        }\n\n        @Override\n        public int getMinorVersion() {\n            return 0;\n        }\n\n        @Override\n        public boolean jdbcComp