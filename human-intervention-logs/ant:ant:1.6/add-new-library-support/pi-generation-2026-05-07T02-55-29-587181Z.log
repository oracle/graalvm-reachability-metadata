[tool-call] delta {"path":"tests/src/ant/ant/1.6/src/test/java/ant/ant/JDBCTaskTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage ant.ant;\n\nimport java.sql.Connection;\nimport java.sql.Driver;\nimport java.sql.DriverPropertyInfo;\nimport java.sql.SQLException;\nimport java.util.Properties;\nimport java.util.concurrent.atomic.AtomicInteger;\nimport java.util.logging.Logger;\n\nimport org.apache.tools.ant.AntClassLoader;\nimport org.apache.tools.ant.BuildException;\nimport org.apache.tools.ant.Project;\nimport org.apache.tools.ant.taskdefs.JDBCTask;\nimport org.apache.tools.ant.types.Path;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\nimport static org.assertj.core.api.Assertions.assertThatThrownBy;\n\npublic class JDBCTaskTest {\n    private static final String DRIVER_CLASS_NAME = NullConnectionDriver.class.getName();\n\n    @Test\n    void getConnectionLoadsDriverWithSystemClassLoader() {\n        NullConnectionDriver.reset();\n        ExposedJDBCTask task = newTask();\n        task.setDriver(DRIVER_CLASS_NAME);\n\n        assertThatThrownBy(task::openConnection)\n            .isInstanceOf(BuildException.class)\n            .hasCauseInstanceOf(SQLException.class);\n\n        assertThat(NullConnectionDriver.instances()).isEqualTo(1);\n        assertThat(NullConnectionDriver.connectCalls()).isEqualTo(1);\n    }\n\n    @Test\n    void getConnectionLoadsDriverWithConfiguredAntClassLoader() {\n        NullConnectionDriver.reset();\n        ExposedJDBCTask task = newTask();\n        task.setDriver(DRIVER_CLASS_NAME);\n        task.setCaching(false);\n        task.setClasspath(new Path(task.getProject()));\n\n        assertThatThrownBy(task::openConnection)\n            .isInstanceOf(BuildException.class)\n            .hasCauseInstanceOf(SQLException.class);\n\n        assertThat(NullConnectionDriver.instances()).isEqualTo(1);\n        assertThat(NullConnectionDriver.connectCalls()).isEqualTo(1);\n        assertThat(task.exposedLoader()).isNotNull();\n    }\n\n    private static ExposedJDBCTask newTask() {\n        ExposedJDBCTask task = new ExposedJDBCTask();\n        task.setProject(new ParentFirstProject());\n        task.setUserid(\"user\");\n        task.setPassword(\"password\");\n        task.setUrl(\"jdbc:ant-test:unhandled\");\n        return task;\n    }\n\n    public static final class NullConnectionDriver implements Driver {\n        private static final AtomicInteger INSTANCES = new AtomicInteger();\n        private static final AtomicInteger CONNECT_CALLS = new AtomicInteger();\n\n        public NullConnectionDriver() {\n            INSTANCES.incrementAndGet();\n        }\n\n        static void reset() {\n            INSTANCES.set(0);\n            CONNECT_CALLS.set(0);\n        }\n\n        static int instances() {\n            return INSTANCES.get();\n        }\n\n        static int connectCalls() {\n            return CONNECT_CALLS.get();\n        }\n\n        @Override\n        public Connection connect(String url, Properties info) {\n            CONNECT_CALLS.incrementAndGet();\n            return null;\n        }\n\n        @Override\n        public boolean acceptsURL(String url) {\n            return false;\n        }\n\n        @Override\n        public DriverPropertyInfo[] getPropertyInfo(String url, Properties info) {\n            return new DriverPropertyInfo[0];\n        }\n\n        @Override\n        public int getMajorVersion() {\n            return 1;\n        }\n\n        @Override\n        public int getMinorVersion() {\n            return 0;\n        }\n\n        @Override\n        public boolean jdbcCompliant() {\n            return false;\n        }\n\n        @Override\n        public Logger getParentLogger() {\n            return Logger.getGlobal();\n        }\n    }\n\n    private static final class ExposedJDBCTask extends JDBCTask {\n        Connection openConnection() {\n            return getConnection();\n        }\n\n        AntClassLoader exposedLoader() {\n            return getLoader();\n        }\n    }\n\n    private static final class ParentFirstProject extends Project {\n        @Override\n        public AntClassLoader createClassLoader(Path path) {\n            AntClassLoader loader = new AntClassLoader(getClass().getClassLoader(), true);\n            loader.setProject(this);\n            loader.setClassPath(path);\n            return loader;\n        }\n    }\n}\n"}
