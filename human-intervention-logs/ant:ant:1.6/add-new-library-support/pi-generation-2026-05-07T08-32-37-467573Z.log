      protected URL getResourceURL(File file, String resourceName) {
          try {
              if (!file.exists()) {
                  return null;
              }
  
              if (file.isDirectory()) {
                  File resource = new File(file, resourceName);
  
                  if (resource.exists()) {
                      try {
