  package sun.misc;
  
  import java.io.IOException;
  import java.io.InputStream;
  import java.io.OutputStream;
  import java.nio.charset.StandardCharsets;
  
  public class UUEncoder {
      private final String name;
  
      public UUEncoder(String name) {
          this.name = name;
      }
  
      public void encode(InputStream input, OutputStream output) throws IOException {
          output.write(("begin 644 " + name + "\n").getBytes(StandardCharsets.US_ASCII));
          byte[] buffer = new byte[1024];
          int count = input.read(buffer);
          while (count != -1) {
              output.write(buffer, 0, count);
              count = input.read(buffer);
          }
          output.write("end\n".getBytes(StandardCharsets.US_ASCII));
