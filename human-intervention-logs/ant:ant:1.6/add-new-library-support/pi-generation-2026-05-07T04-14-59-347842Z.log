   */
  public class Mapper extends DataType implements Cloneable {
  
      protected MapperType type = null;
  
      public Mapper(Project p) {
          setProject(p);
      }
  
      /**
       * Set the type of FileNameMapper to use.
       */
      public void setType(MapperType type) {
          if (isReference()) {
