                  classname = type.getImplementation();
              }
  
              Class c = null;
              if (classpath == null) {
                  c = Class.forName(classname);
              } else {
                  AntClassLoader al = getProject().createClassLoader(classpath);
                  c = Class.forName(classname, true, al);
              }
  
