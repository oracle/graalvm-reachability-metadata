          InputSource source = null;
  
          AntClassLoader loader = null;
          Path cp = classpath;
          if (cp != null) {
              cp = classpath.concatSystemClasspath("ignore");
          } else {
              cp = (new Path(getProject())).concatSystemClasspath("last");
          }
  
