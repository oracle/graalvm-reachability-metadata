ityUsesXmlCommonsBridgeForExternalCatalogAndFallbacks() throws Exception {\n        XMLCatalog catalog = createCatalogWithExternalResolver();\n        catalog.addDTD(resourceLocation(INLINE_PUBLIC_ID, \"missing-inline.dtd\"));\n\n        InputSource externalSource = catalog.resolveEntity(EXTERNAL_PUBLIC_ID, \"ignored-system-id\");\n        assertThat(externalSource).isNotNull();\n        closeByteStream(externalSource);\n\n        InputSource inlineFallback = catalog.resolveEntity(INLINE_PUBLIC_ID, \"missing-inline-system-id\");\n        assertThat(inlineFallback).isNull();\n\n        InputSource unresolvedFallback = catalog.resolveEntity(\"-//Ant Test//DTD Absent 1.0//EN\", \"absent-system-id\");\n        assertThat(unresolvedFallback).isNull();\n    }\n\n    @Test\n    void resolveUsesXmlCommonsBridgeForMatchingAndUnmatchedUris() throws Exception {\n        XMLCatalog catalog = createCatalogWithExternalResolver();\n        catalog.addEntity(resourceLocation(INLINE_URI, \"missing-inline.xml\"));\n\n        Source matchingSource = catalog.resolve(INLINE_URI + \"#fragment\", tempDirectory.toUri().toString());\n        assertThat(matchingSource).isInstanceOf(SAXSource.class);\n        assertThat(((SAXSource) matchingSource).getInputSource()).isNotNull();\n\n        Source unmatchedSource = catalog.resolve(\"urn:ant-test:absent\", tempDirectory.toUri().toString());\n        assertThat(unmatchedSource).isInstanceOf(SAXSource.class);\n        assertThat(((SAXSource) unmatchedSource).getInputSource()).isNotNull();\n    }\n\n    private XMLCatalog createCatalogWithExternalResolver() throws Exception {\n        Path externalDtd = tempDirectory.resolve(\"external.dtd\");\n        Files.writeString(externalDtd, \"<!ELEMENT external EMPTY>\", StandardCharsets.UTF_8);\n\n        Path catalogFile = tempDirectory.resolve(\"catalog.cat\");\n        Files.writeString(catalogFile,\n            \"PUBLIC \\\"\" + EXTERNAL_PUBLIC_ID + \"\\\" \\\"\" + externalDtd.getFileName() + \"\\\"\\n\",\n            StandardCharsets.UTF_8);\n\n        Project project = new Project();\n        project.setBaseDir(tempDirectory.toFile());\n\n        XMLCatalog catalog = new XMLCatalog();\n        catalog.setProject(project);\n        PathElement catalogPathElement = catalog.createCatalogPath().createPathElement();\n        catalogPathElement.setLocation(catalogFile.toFile());\n        return catalog;\n    }\n\n    private ResourceLocation resourceLocation(String publicId, String location) {\n        ResourceLocation resourceLocation = new ResourceLocation();\n        resourceLocation.setPublicId(publicId);\n        resourceLocation.setLocation(location);\n        return resourceLocation;\n    }\n\n    private void closeByteStream(InputSource source) throws Exception {\n        InputStream byteStream = source.getByteStream();\n        if (byteStream != null) {\n            byteStream.close();\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778095190170}]}
