          } catch (NoClassDefFoundError e) {
              log("Unable to verify class " + classname
                  + ". It is not defined.", Project.MSG_WARN);
          } catch (Throwable t) {
              log("Unable to verify class " + classname
                  + ". Loading caused Exception: "
