          this.timeout = timeout;
      }
  
      public void execute(Project project) throws BuildException {
          final String classname = javaCommand.getExecutable();
  
          AntClassLoader loader = null;
          try {
              if (sysProperties != null) {
                  sysProperties.setSystem();
