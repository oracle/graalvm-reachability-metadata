urceManager);\\n\\n        InterfaceBackedTccAction action = new InterfaceBackedTccAction();\\n        new TccRegisterResourceParser().registerResource(action, \\\"interfaceBackedTccAction\\\");\\n\\n        assertThat(resourceManager.registeredResources).containsOnlyKeys(\\\"native-image-tcc-action\\\");\\n        assertThat(resourceManager.registeredResource).isInstanceOf(TCCResource.class);\\n        TCCResource resource = (TCCResource) resourceManager.registeredResource;\\n        assertThat(resource.getTargetBean()).isSameAs(action);\\n        assertThat(resource.getPrepareMethod().getName()).isEqualTo(\\\"prepare\\\");\\n        assertThat(resource.getCommitMethodName()).isEqualTo(\\\"confirm\\\");\\n        assertThat(resource.getCommitMethod().getName()).isEqualTo(\\\"confirm\\\");\\n        assertThat(resource.getRollbackMethodName()).isEqualTo(\\\"cancel\\\");\\n        assertThat(resource.getRollbackMethod().getName()).isEqualTo(\\\"cancel\\\");\\n        assertThat(resource.getPhaseTwoCommitKeys()).containsExactly((String) null);\\n        assertThat(resource.getPhaseTwoRollbackKeys()).containsExactly((String) null);\\n    }\\n\\n    public interface TccActionContract {\\n        @TwoPhaseBusinessAction(\\n                name = \\\"native-image-tcc-action\\\",\\n                commitMethod = \\\"confirm\\\",\\n                rollbackMethod = \\\"cancel\\\")\\n        boolean prepare(BusinessActionContext context);\\n\\n        boolean confirm(BusinessActionContext context);\\n\\n        boolean cancel(BusinessActionContext context);\\n    }\\n\\n    public static class InterfaceBackedTccAction implements TccActionContract {\\n        @Override\\n        public boolean prepare(BusinessActionContext context) {\\n            return true;\\n        }\\n\\n        @Override\\n        public boolean confirm(BusinessActionContext context) {\\n            return true;\\n        }\\n\\n        @Override\\n        public boolean cancel(BusinessActionContext context) {\\n            return true;\\n        }\\n    }\\n\\n    private static final class CapturingResourceManager implements ResourceManager {\\n        private final Map<String, Resource> registeredResources = new HashMap<>();\\n        private Resource registeredResource;\\n\\n        @Override\\n        public void registerResource(Resource resource) {\\n            registeredResource = resource;\\n            registeredResources.put(resource.getResourceId(), resource);\\n        }\\n\\n        @Override\\n        public void unregisterResource(Resource resource) {\\n            registeredResources.remove(resource.getResourceId());\\n        }\\n\\n        @Override\\n        public Map<String, Resource> getManagedResources() {\\n            return registeredResources;\\n        }\\n\\n        @Override\\n        public BranchType getBranchType() {\\n            return BranchType.TCC;\\n        }\\n\\n        @Override\\n        public GlobalStatus getGlobalStatus(BranchType branchType, String xid) {\\n            return GlobalStatus.UnKnown;\\n        }\\n\\n        @Override\\n        public BranchStatus branchCommit(BranchType branchType, String xid, long branchId, String resourceId,\\n                                         String applicationData) throws TransactionException {\\n            return BranchStatus.PhaseTwo_Committed;\\n        }\\n\\n        @Override\\n        public BranchStatus branchRollback(BranchType branchType, String xid, long branchId, String resourceId,\\n                                           String applicationData) throws TransactionException {\\n            return BranchStatus.PhaseTwo_Rollbacked;\\n        }\\n\\n        @Override\\n        public Long branchRegister(BranchType branchType, String resourceId, String clientId, String xid,\\n                                   String applicationData, String lockKeys) throws TransactionException {\\n            return 1L;\\n        }\\n\\n        @Override\\n        public void br