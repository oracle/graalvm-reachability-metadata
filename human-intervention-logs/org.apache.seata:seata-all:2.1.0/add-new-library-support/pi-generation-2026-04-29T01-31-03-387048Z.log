              return true;
          }
          return false;
      }
  
      private static Class<?>[] getProtocolInnerFields() {
          return new Class<?>[] {ResultCode.class, GlobalStatus.class, BranchStatus.class, BranchType.class, TransactionExceptionCode.class};
      }
  }
