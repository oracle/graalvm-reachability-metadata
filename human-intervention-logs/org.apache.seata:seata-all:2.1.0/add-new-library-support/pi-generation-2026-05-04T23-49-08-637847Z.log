n                \"integerCount\", \"7\",\n                \"ratio\", \"2.5\",\n                \"name\", \"seata\");\n\n        SampleBean bean = (SampleBean) BeanUtils.mapToObject(values, SampleBean.class);\n\n        assertThat(bean.getCreatedAt()).isEqualTo(new Date(CREATED_AT));\n        assertThat(bean.getLongCount()).isEqualTo(42L);\n        assertThat(bean.getIntegerCount()).isEqualTo(7);\n        assertThat(bean.getRatio()).isEqualTo(2.5D);\n        assertThat(bean.getName()).isEqualTo(\"seata\");\n        assertThat(bean.getMissingValue()).isNull();\n    }\n\n    @Test\n    void objectToMapReadsDateAndNonDateFields() {\n        SampleBean bean = new SampleBean();\n        bean.setCreatedAt(new Date(CREATED_AT));\n        bean.setLongCount(42L);\n        bean.setIntegerCount(7);\n        bean.setRatio(2.5D);\n        bean.setName(\"seata\");\n\n        Map<String, String> values = BeanUtils.objectToMap(bean);\n\n        assertThat(values)\n                .containsEntry(\"createdAt\", String.valueOf(CREATED_AT))\n                .containsEntry(\"longCount\", \"42\")\n                .containsEntry(\"integerCount\", \"7\")\n                .containsEntry(\"ratio\", \"2.5\")\n                .containsEntry(\"name\", \"seata\")\n                .containsEntry(\"missingValue\", \"\");\n    }\n\n    @Test\n    void beanToStringIncludesNonNullFields() {\n        SampleBean bean = new SampleBean();\n        bean.setCreatedAt(new Date(CREATED_AT));\n        bean.setLongCount(42L);\n        bean.setIntegerCount(7);\n        bean.setRatio(2.5D);\n        bean.setName(\"seata\");\n\n        String value = BeanUtils.beanToString(bean);\n\n        assertThat(value)\n                .startsWith(\"[\")\n                .endsWith(\"]\")\n                .contains(\"createdAt=\")\n                .contains(\"longCount=42\")\n                .contains(\"integerCount=7\")\n                .contains(\"ratio=2.5\")\n                .contains(\"name=seata\")\n                .doesNotContain(\"missingValue=\");\n    }\n\n    public static class SampleBean {\n        private Date createdAt;\n        private Long longCount;\n        private Integer integerCount;\n        private Double ratio;\n        private String name;\n        private String missingValue;\n\n        public SampleBean() {\n        }\n\n        public Date getCreatedAt() {\n            return createdAt;\n        }\n\n        public void setCreatedAt(Date createdAt) {\n            this.createdAt = createdAt;\n        }\n\n        public Long getLongCount() {\n            return longCount;\n        }\n\n        public void setLongCount(Long longCount) {\n            this.longCount = longCount;\n        }\n\n        public Integer getIntegerCount() {\n            return integerCount;\n        }\n\n        public void setIntegerCount(Integer integerCount) {\n            this.integerCount = integerCount;\n        }\n\n        public Double getRatio() {\n            return ratio;\n        }\n\n        public void setRatio(Double ratio) {\n            this.ratio = ratio;\n        }\n\n        public String getName() {\n            return name;\n        }\n\n        public void setName(String name) {\n            this.name = name;\n        }\n\n        public String getMissingValue() {\n            return missingValue;\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777938397827}, {"role": "toolResult", "toolCallId": "call_gfSFQ94WiZGdKqGl2BkjPtb2|fc_08fd2648efde006e0169f92fdd6d6c819599c080e0aac7dc87", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\nplugins {\n    id \"org.graalvm.internal.tck\"\n}\n\nString libraryVersion = tck.testedLibraryVersion.get()\n\ndependencies {\n    testImplementation \"org.apache.seata:seata-all:$libraryVersion\"\n    testImpl