  package org_apache_seata.seata_all;
  
  import org.apache.seata.core.compressor.Compressor;
  import org.apache.seata.core.compressor.CompressorFactory;
  import org.apache.seata.core.compressor.CompressorType;
  import org.apache.seata.integration.tx.api.json.JsonParserWrap;
  import org.apache.seata.rm.datasource.undo.UndoLogParser;
  import org.apache.seata.rm.datasource.undo.UndoLogParserFactory;
  import org.junit.jupiter.api.Test;
  
  import java.util.List;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class Seata_allTest {
      @Test
      void undoLogParserFactoryLoadsNamedParsers() {
          UndoLogParser fastjsonUndoLogParser = UndoLogParserFactory.getInstance("fastjson");
          UndoLogParser jacksonUndoLogParser = UndoLogParserFactory.getInstance("jackson");
          UndoLogParser protostuffUndoLogParser = UndoLogParserFactory.getInstance("protostuff");
          UndoLogParser kryoUndoLogParser = UndoLogParserFactory.getInstance("kryo");
  
          assertThat(fastjsonUndoLogParser.getClass().getName())
                  .isEqualTo("org.apache.seata.rm.datasource.undo.parser.FastjsonUndoLogParser");
          assertThat(jacksonUndoLogParser.getClass().getName())
                  .isEqualTo("org.apache.seata.rm.datasource.undo.parser.JacksonUndoLogParser");
          assertThat(protostuffUndoLogParser.getClass().getName())
                  .isEqualTo("org.apache.seata.rm.datasource.undo.parser.ProtostuffUndoLogParser");
          assertThat(kryoUndoLogParser.getClass().getName())
                  .isEqualTo("org.apache.seata.rm.datasource.undo.parser.KryoUndoLogParser");
      }
  
      @Test
      void compressorFactoryLoadsConfiguredTypes() {
          List<Compressor> compressors = List.of(
                  CompressorFactory.getCompressor(CompressorType.GZIP.getCode()),
                  CompressorFactory.getCompressor(CompressorType.ZIP.getCode()),
                  CompressorFactory.getCompressor(CompressorType.BZIP2.getCode()),
                  CompressorFactory.getCompressor(CompressorType.LZ4.getCode()),
                  CompressorFactory.getCompressor(CompressorType.DEFLATER.getCode()),
                  CompressorFactory.getCompressor(CompressorType.ZSTD.getCode()));
  
          assertThat(compressors)
                  .extracting(compressor -> compressor.getClass().getName())
                  .contains(
                          "org.apache.seata.compressor.gzip.GzipCompressor",
                          "org.apache.seata.compressor.bzip2.BZip2Compressor",
                          "org.apache.seata.compressor.zip.ZipCompressor",
                          "org.apache.seata.compressor.lz4.Lz4Compressor",
                          "org.apache.seata.compressor.deflater.DeflaterCompressor",
                          "org.apache.seata.compressor.zstd.ZstdCompressor");
      }
  
      @Test
      void integrationJsonParserFactoryLoadsNamedParsers() {
          JsonParserWrap fastjsonParser = org.apache.seata.integration.tx.api.json.JsonParserFactory.getInstance("fastjson");
          JsonParserWrap jacksonParser = org.apache.seata.integration.tx.api.json.JsonParserFactory.getInstance("jackson");
  
          assertThat(fastjsonParser.getName()).isEqualTo("fastjson");
          assertThat(jacksonParser.getName()).isEqualTo("jackson");
      }
  }
