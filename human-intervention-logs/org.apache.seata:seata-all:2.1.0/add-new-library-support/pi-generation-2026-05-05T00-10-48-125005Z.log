  26:public class SpringBeanServiceInvokerTest {
  27:    private static final String SERVICE_BEAN_NAME = "serviceBean";
  28:    private static final String CONTEXT_PARAMETER_CLASS_NAME = "dynamic.seata.ContextParameter";
  29:    private static final String CONTEXT_EXCEPTION_CLASS_NAME = "dynamic.seata.ContextRetryException";
  30:
  31:    @Test
  32:    void invokesSpringBeanMethodWithExplicitParameterType() throws Throwable {
  33:        StaticApplicationContext applicationContext = applicationContextWith(new ServiceBean());
  34:        try {
  35:            SpringBeanServiceInvoker invoker = new SpringBeanServiceInvoker();
  36:            invoker.setApplicationContext(applicationContext);
  37:            ServiceTaskStateImpl state = serviceTaskState("greet", List.of(String.class.getName()));
  38:
  39:            Object result = invoker.invoke(state, "Seata");
  40:
  41:            assertThat(result).isEqualTo("Hello Seata");
  42:        } finally {
  43:            applicationContext.close();
  44:        }
  45:    }
