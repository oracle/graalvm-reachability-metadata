  package org_apache_seata.seata_all;
  
  import org.apache.seata.common.util.BeanUtils;
  import org.junit.jupiter.api.Test;
  
  import java.util.Date;
  import java.util.Map;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class BeanUtilsTest {
      private static final long CREATED_AT = 1_234_567_890L;
  
      @Test
      void mapToObjectSetsSupportedFieldTypes() {
          Map<String, String> values = Map.of(
                  "createdAt", String.valueOf(CREATED_AT),
                  "longCount", "42",
                  "integerCount", "7",
                  "ratio", "2.5",
                  "name", "seata");
  
          SampleBean bean = (SampleBean) BeanUtils.mapToObject(values, SampleBean.class);
  
          assertThat(bean.getCreatedAt()).isEqualTo(new Date(CREATED_AT));
          assertThat(bean.getLongCount()).isEqualTo(42L);
          assertThat(bean.getIntegerCount()).isEqualTo(7);
          assertThat(bean.getRatio()).isEqualTo(2.5D);
          assertThat(bean.getName()).isEqualTo("seata");
          assertThat(bean.getMissingValue()).isNull();
      }
  
      @Test
      void objectToMapReadsDateAndNonDateFields() {
          SampleBean bean = new SampleBean();
          bean.setCreatedAt(new Date(CREATED_AT));
          bean.setLongCount(42L);
          bean.setIntegerCount(7);
          bean.setRatio(2.5D);
          bean.setName("seata");
  
          Map<String, String> values = BeanUtils.objectToMap(bean);
  
          assertThat(values)
                  .containsEntry("createdAt", String.valueOf(CREATED_AT))
                  .containsEntry("longCount", "42")
                  .containsEntry("integerCount", "7")
                  .containsEntry("ratio", "2.5")
                  .containsEntry("name", "seata")
                  .containsEntry("missingValue", "");
      }
  
      @Test
      void beanToStringIncludesNonNullFields() {
          SampleBean bean = new SampleBean();
          bean.setCreatedAt(new Date(CREATED_AT));
          bean.setLongCount(42L);
          bean.setIntegerCount(7);
          bean.setRatio(2.5D);
          bean.setName("seata");
  
          String value = BeanUtils.beanToString(bean);
  
          assertThat(value)
                  .startsWith("[")
                  .endsWith("]")
                  .contains("createdAt=")
                  .contains("longCount=42")
                  .contains("integerCount=7")
                  .contains("ratio=2.5")
                  .contains("name=seata")
                  .doesNotContain("missingValue=");
      }
  
      public static class SampleBean {
          private Date createdAt;
          private Long longCount;
          private Integer integerCount;
          private Double ratio;
          private String name;
          private String missingValue;
  
          public SampleBean() {
          }
  
          public Date getCreatedAt() {
              return createdAt;
          }
  
          public void setCreatedAt(Date createdAt) {
              this.createdAt = createdAt;
          }
  
          public Long getLongCount() {
              return longCount;
          }
  
          public void setLongCount(Long longCount) {
              this.longCount = longCount;
          }
  
          public Integer getIntegerCount() {
              return integerCount;
          }
  
          public void setIntegerCount(Integer integerCount) {
              this.integerCount = integerCount;
          }
  
          public Double getRatio() {
              return ratio;
          }
  
          public void setRatio(Double ratio) {
              this.ratio = ratio;
          }
  
          public String getName() {
              return name;
          }
  
          public void setName(String name) {
              this.name = name;
          }
  
          public String getMissingValue() {
              return missingValue;
          }
      }
  }
