llo Seata\");\n        } finally {\n            applicationContext.close();\n        }\n    }\n\n    @Test\n    void retryConfigLoadsExceptionWithServiceTaskStateHandlerClassLoader() {\n        StaticApplicationContext applicationContext = applicationContextWith(new ServiceBean());\n        try {\n            SpringBeanServiceInvoker invoker = new SpringBeanServiceInvoker();\n            invoker.setApplicationContext(applicationContext);\n            ServiceTaskStateImpl state = serviceTaskState(\"failWithIllegalArgumentException\", List.of());\n            state.setRetry(List.of(retryFor(IllegalArgumentException.class.getName())));\n\n            assertThatThrownBy(() -> invoker.invoke(state))\n                    .isInstanceOf(IllegalArgumentException.class)\n                    .hasMessage(\"retryable\");\n        } finally {\n            applicationContext.close();\n        }\n    }\n\n    @Test\n    void contextClassLoaderResolvesParameterTypeWhenInvokerClassLoaderCannot() {\n        ClassLoader originalClassLoader = Thread.currentThread().getContextClassLoader();\n        ByteArrayClassLoader contextClassLoader = new ByteArrayClassLoader(originalClassLoader,\n                Map.of(CONTEXT_PARAMETER_CLASS_NAME, classFile(CONTEXT_PARAMETER_CLASS_NAME, Object.class.getName())));\n        try {\n            Thread.currentThread().setContextClassLoader(contextClassLoader);\n\n            Class<?> parameterClass = new TestableSpringBeanServiceInvoker().loadClassForName(CONTEXT_PARAMETER_CLASS_NAME);\n\n            assertThat(parameterClass.getName()).isEqualTo(CONTEXT_PARAMETER_CLASS_NAME);\n            assertThat(parameterClass.getClassLoader()).isSameAs(contextClassLoader);\n        } catch (Error error) {\n            rethrowUnlessUnsupportedFeature(error);\n        } finally {\n            Thread.currentThread().setContextClassLoader(originalClassLoader);\n        }\n    }\n\n    @Test\n    void retryConfigUsesContextClassLoaderWhenServiceTaskStateHandlerClassLoaderCannotResolveException()\n            throws Throwable {\n        ClassLoader originalClassLoader = Thread.currentThread().getContextClassLoader();\n        ByteArrayClassLoader contextClassLoader = new ByteArrayClassLoader(originalClassLoader,\n                Map.of(CONTEXT_EXCEPTION_CLASS_NAME,\n                        classFile(CONTEXT_EXCEPTION_CLASS_NAME, RuntimeException.class.getName())));\n        try {\n            Thread.currentThread().setContextClassLoader(contextClassLoader);\n            Class<?> exceptionClass = contextClassLoader.loadClass(CONTEXT_EXCEPTION_CLASS_NAME);\n            RuntimeException exception = (RuntimeException) exceptionClass.getDeclaredConstructor().newInstance();\n\n            StaticApplicationContext applicationContext = applicationContextWith(new ServiceBean());\n            try {\n                SpringBeanServiceInvoker invoker = new SpringBeanServiceInvoker();\n                invoker.setApplicationContext(applicationContext);\n                ServiceTaskStateImpl state = serviceTaskState(\"failWithRuntimeException\",\n                        List.of(RuntimeException.class.getName()));\n                state.setRetry(List.of(retryFor(CONTEXT_EXCEPTION_CLASS_NAME)));\n\n                assertThatThrownBy(() -> invoker.invoke(state, exception)).isSameAs(exception);\n            } finally {\n                applicationContext.close();\n            }\n        } catch (Error error) {\n            rethrowUnlessUnsupportedFeature(error);\n        } finally {\n            Thread.currentThread().setContextClassLoader(originalClassLoader);\n        }\n    }\n\n    private static StaticApplicationContext applicationContextWith(Object serviceBean) {\n        StaticApplicationContext applicationContext = new StaticApplicationContext();\n        applicationContext.getBeanFactory().registerSingleton(SERVICE_BEAN_NAME, serviceBean);\n        return applicationContext;\n    }\n\n    private static ServiceTaskStateImpl serviceTaskState(String serviceMethod, List<String> parameterTypes) {\n        ServiceTaskStateImpl state = new ServiceTaskStateImpl();\n        state.setServiceName(SERVICE_BEAN_NAME);\n        state.setServiceMethod(serviceMethod);\n        state.setParameterTypes(parameterTypes);\n        return state;\n    }\n\n    private static RetryImpl retryFor(String exceptionClassName) {\n        RetryImpl retry = new RetryImpl();\n        retry.setExceptions(List.of(exceptionClassName));\n        retry.setIntervalSeconds(0.0D);\n        retry.setBackoffRate(1.0D);\n        retry.setMaxAttempts(0);\n        return retry;\n    }\n\n    private static byte[] classFile(String binaryClassName, String binarySuperClassName) {\n        try {\n            ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n            DataOutputStream output = new DataOutputStream(bytes);\n            output.writeInt(0xCAFEBABE);\n            output.writeShort(0);\n            output.writeShort(52);\n            output.writeShort(10);\n            writeUtf8(output, binaryClassName.replace('.', '/'));\n            output.writeByte(7);\n            output.writeShort(1);\n            writeUtf8(output, binarySuperClassName.replace('.', '/'));\n            output.writeByte(7);\n            output.writeShort(3);\n            writeUtf8(output, \"<init>\");\n            writeUtf8(output, \"()V\");\n            writeUtf8(output, \"Code\");\n            output.writeByte(12);\n            output.writeShort(5);\n            output.writeShort(6);\n            output.writeByte(10);\n            output.writeShort(4);\n            output.writeShort(8);\n            output.writeShort(0x0021);\n            output.writeShort(2);\n            output.writeShort(4);\n            output.writeShort(0);\n            output.writeShort(0);\n            output.writeShort(1);\n            output.writeShort(0x0001);\n            output.writeShort(5);\n            output.writeShort(6);\n            output.writeShort(1);\n            output.writeShort(7);\n            output.writeInt(17);\n            output.writeShort(1);\n            output.writeShort(1);\n            output.writeInt(5);\n            output.writeByte(0x2A);\n            output.writeByte(0xB7);\n            output.writeShort(9);\n            output.writeByte(0xB1);\n            output.writeShort(0);\n            output.writeShort(0);\n            output.writeShort(0);\n            output.flush();\n            return bytes.toByteArray();\n        } catch (IOException e) {\n            throw new UncheckedIOException(e);\n        }\n    }\n\n    private static void writeUtf8(DataOutputStream output, String value) throws IOException {\n        output.writeByte(1);\n        output.writeUTF(value);\n    }\n\n    private static void rethrowUnlessUnsupportedFeature(Error error) {\n        if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n            throw error;\n        }\n    }\n\n    private static final class TestableSpringBeanServiceInvoker extends SpringBeanServiceInvoker {\n        Class<?> loadClassForName(String className) {\n            return classForName(className);\n        }\n    }\n\n    private static final class ByteArrayClassLoader extends ClassLoader {\n        private final Map<String, byte[]> definitions;\n\n        private ByteArrayClassLoader(ClassLoader parent, Map<String, byte[]> definitions) {\n            super(parent);\n            this.definitions = definitions;\n        }\n\n        @Override\n        protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {\n            byte[] definition = definitions.get(name);\n            if (definition == null) {\n                return super.loadClass(name, resolve);\n            }\n\n            Class<?> loadedClass = findLoadedClass(name);\n            if (loadedClass == null) {\n                loadedClass = defineClass(name, definition, 0, definition.length);\n            }\n            if (resolve) {\n                resolveClass(loadedClass);\n            }\n            return loadedClass;\n        }\n    }\n\n    public static final class ServiceBean {\n        public String greet(String name) {\n            return \"Hello \" + name;\n        }\n\n        public String failWithIllegalArgumentException() {\n            throw new IllegalArgumentException(\"retryable\");\n        }\n\n        public String failWithRuntimeException(RuntimeException exception) {\n            throw exception;\n        }\n    }\n}\n"}
