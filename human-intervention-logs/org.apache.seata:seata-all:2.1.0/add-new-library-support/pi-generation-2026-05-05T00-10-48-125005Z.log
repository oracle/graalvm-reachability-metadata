 */\n7:package org_apache_seata.seata_all;\n8:\n9:import org.apache.seata.saga.engine.invoker.impl.SpringBeanServiceInvoker;\n10:import org.apache.seata.saga.statelang.domain.impl.AbstractTaskState.RetryImpl;\n11:import org.apache.seata.saga.statelang.domain.impl.ServiceTaskStateImpl;\n12:import org.graalvm.internal.tck.NativeImageSupport;\n13:import org.junit.jupiter.api.Test;\n14:import org.springframework.context.support.StaticApplicationContext;\n15:\n16:import java.io.ByteArrayOutputStream;\n17:import java.io.DataOutputStream;\n18:import java.io.IOException;\n19:import java.io.UncheckedIOException;\n20:import java.util.List;\n21:import java.util.Map;\n22:\n23:import static org.assertj.core.api.Assertions.assertThat;\n24:import static org.assertj.core.api.Assertions.assertThatThrownBy;\n25:\n26:public class SpringBeanServiceInvokerTest {\n27:    private static final String SERVICE_BEAN_NAME = \"serviceBean\";\n28:    private static final String CONTEXT_PARAMETER_CLASS_NAME = \"dynamic.seata.ContextParameter\";\n29:    private static final String CONTEXT_EXCEPTION_CLASS_NAME = \"dynamic.seata.ContextRetryException\";\n30:\n31:    @Test\n32:    void invokesSpringBeanMethodWithExplicitParameterType() throws Throwable {\n33:        StaticApplicationContext applicationContext = applicationContextWith(new ServiceBean());\n34:        try {\n35:            SpringBeanServiceInvoker invoker = new SpringBeanServiceInvoker();\n36:            invoker.setApplicationContext(applicationContext);\n37:            ServiceTaskStateImpl state = serviceTaskState(\"greet\", List.of(String.class.getName()));\n38:\n39:            Object result = invoker.invoke(state, \"Seata\");\n40:\n41:            assertThat(result).isEqualTo(\"Hello Seata\");\n42:        } finally {\n43:            applicationContext.close();\n44:        }\n45:    }\n46:\n47:    @Test\n48:    void retryConfigLoadsExceptionWithServiceTaskStateHandlerClassLoader() {\n49:        StaticApplicationContext applicationContext = applicationContextWith(new ServiceBean());\n50:        try {\n51:            SpringBeanServiceInvoker invoker = new SpringBeanServiceInvoker();\n52:            invoker.setApplicationContext(applicationContext);\n53:            ServiceTaskStateImpl state = serviceTaskState(\"failWithIllegalArgumentException\", List.of());\n54:            state.setRetry(List.of(retryFor(IllegalArgumentException.class.getName())));\n55:\n56:            assertThatThrownBy(() -> invoker.invoke(state))\n57:                    .isInstanceOf(IllegalArgumentException.class)\n58:                    .hasMessage(\"retryable\");\n59:        } finally {\n60:            applicationContext.close();\n61:        }\n62:    }\n63:\n64:    @Test\n65:    void contextClassLoaderResolvesParameterTypeWhenInvokerClassLoaderCannot() {\n66:        ClassLoader originalClassLoader = Thread.currentThread().getContextClassLoader();\n67:        ByteArrayClassLoader contextClassLoader = new ByteArrayClassLoader(originalClassLoader,\n68:                Map.of(CONTEXT_PARAMETER_CLASS_NAME, classFile(CONTEXT_PARAMETER_CLASS_NAME, Object.class.getName())));\n69:        try {\n70:            Thread.currentThread().setContextClassLoader(contextClassLoader);\n71:\n72:            TestableSpringBeanServiceInvoker invoker = new TestableSpringBeanServiceInvoker();\n73:            Class<?> parameterClass = invoker.loadClassForName(CONTEXT_PARAMETER_CLASS_NAME);\n74:\n75:            assertThat(parameterClass.getName()).isEqualTo(CONTEXT_PARAMETER_CLASS_NAME);\n76:            assertThat(parameterClass.getClassLoader()).isSameAs(contextClassLoader);\n77:        } catch (Error error) {\n78:            rethrowUnlessUnsupportedFeature(error);\n79:        } finally {\n80:            Thread.currentThread().setContextClassLoader(originalClassLoader);\n81:        }\n82:    }\n83:\n84:    @Test\n85:    void retryConfigUsesContextClassLoaderWhenServiceTaskStateHandlerClassLoaderCannotResolveException()\n86:            throws Throwable {\n87:        ClassLoader originalClassLoader = Thread.currentThread().getContextClassLoader();\n88:        ByteArrayClassLoader contextClassLoader = new ByteArrayClassLoader(originalClassLoader,\n89:                Map.of(CONTEXT_EXCEPTION_CLASS_NAME,\n90:                        classFile(CONTEXT_EXCEPTION_CLASS_NAME, RuntimeException.class.getName())));\n91:        try {\n92:            Thread.currentThread().setContextClassLoader(contextClassLoader);\n93:            Class<?> exceptionClass = contextClassLoader.loadClass(CONTEXT_EXCEPTION_CLASS_NAME);\n94:            RuntimeException exception = (RuntimeException) exceptionClass.getDeclaredConstructor().newInstance();\n95:\n96:            StaticApplicationContext applicationContext = applicationContextWith(new ServiceBean());\n97:            try {\n98:                SpringBeanServiceInvoker invoker = new SpringBeanServiceInvoker();\n99:                invoker.setApplicationContext(applicationContext);\n100:                ServiceTaskStateImpl state = serviceTaskState(\"failWithRuntimeException\",\n101:                        List.of(RuntimeException.class.getName()));\n102:                state.setRetry(List.of(retryFor(CONTEXT_EXCEPTION_CLASS_NAME)));\n103:\n104:                assertThatThrownBy(() -> invoker.invoke(state, exception)).isSameAs(exception);\n105:            } finally {\n106:                applicationContext.close();\n107:            }\n108:        } catch (Error error) {\n109:            rethrowUnlessUnsupportedFeature(error);\n110:        } finally {\n111:            Thread.currentThread().setContextClassLoader(originalClassLoader);\n112:        }\n113:    }\n114:\n115:    private static StaticApplicationContext applicationContextWith(Object serviceBean) {\n116:        StaticApplicationContext applicationContext = new StaticApplicationContext();\n117:        applicationContext.getBeanFactory().registerSingleton(SERVICE_BEAN_NAME, serviceBean);\n118:        return applicationContext;\n119:    }\n120:\n121:    private static ServiceTaskStateImpl serviceTaskState(String serviceMethod, List<String> parameterTypes) {\n122:        ServiceTaskStateImpl state = new ServiceTaskStateImpl();\n123:        state.setServiceName(SERVICE_BEAN_NAME);\n124:        state.setServiceMethod(serviceMethod);\n125:        state.setParameterTypes(parameterTypes);\n126:        return state;\n127:    }\n128:\n129:    private static RetryImpl retryFor(String exceptionClassName) {\n130:        RetryImpl retry = new RetryImpl();\n131:        retry.setExceptions(List.of(exceptionClassName));\n132:        retry.setIntervalSeconds(0.0D);\n133:        retry.setBackoffRate(1.0D);\n134:        retry.setMaxAttempts(0);\n135:        return retry;\n136:    }\n137:\n138:    private static byte[] classFile(String binaryClassName, String binarySuperClassName) {\n139:        try {\n140:            ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n141:            DataOutputStream output = new DataOutputStream(bytes);\n142:            output.writeInt(0xCAFEBABE);\n143:            output.writeShort(0);\n144:            output.writeShort(52);\n145:            output.writeShort(10);\n146:            writeUtf8(output, binaryClassName.replace('.', '/'));\n147:            output.writeByte(7);\n148:            output.writeShort(1);\n149:            writeUtf8(output, binarySuperClassName.replace('.', '/'));\n150:            output.writeByte(7);\n151:            output.writeShort(3);\n152:            writeUtf8(output, \"<init>\");\n153:            writeUtf8(output, \"()V\");\n154:            writeUtf8(output, \"Code\");\n155:            output.writeByte(12);\n156:            output.writeShort(5);\n157:            output.writeShort(6);\n158:            output.writeByte(10);\n159:            output.writeShort(4);\n160:            output.writeShort(8);\n161:            output.writeShort(0x0021);\n162:            output.writeShort(2);\n163:            output.writeShort(4);\n164:            output.write