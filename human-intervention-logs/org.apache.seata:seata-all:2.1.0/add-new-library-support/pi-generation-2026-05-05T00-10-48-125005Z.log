                  || clazz == Byte.class //
                  || clazz == Short.class //
                  || clazz == Integer.class //
                  || clazz == Long.class //
                  || clazz == Float.class //
                  || clazz == Double.class //
                  || clazz == BigInteger.class //
                  || clazz == BigDecimal.class //
                  || clazz == String.class //
