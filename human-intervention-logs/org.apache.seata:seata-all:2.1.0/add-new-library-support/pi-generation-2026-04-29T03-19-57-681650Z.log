[tool-call] delta {"path":"tests/src/org.apache.seata/seata-all/2.1.0/src/test/java/org_apache_seata/seata_all/DefaultDruidLoaderTest.java","edits":[{"oldText":"import java.util.ServiceLoader;\nimport java.util.concurrent.Callable;\n","newText":"import java.util.ServiceLoader;\nimport java.util.function.BooleanSupplier;\n"},{"oldText":"            Callable<?> exercise = loadDruidLoaderExercise(classLoader);\n\n            Object dbType = exercise.call();\n\n            assertThat(dbType).isEqualTo(\"mysql\");\n","newText":"            BooleanSupplier exercise = loadDruidLoaderExercise(classLoader);\n\n            assertThat(exercise.getAsBoolean()).isTrue();\n"},{"oldText":"    private static Callable<?> loadDruidLoaderExercise(ClassLoader classLoader) {\n        ServiceLoader<Callable> exercises = ServiceLoader.load(Callable.class, classLoader);\n        for (Callable<?> exercise : exercises) {\n            if (exercise.getClass().getName().equals(DRUID_LOADER_EXERCISE)) {\n                return exercise;\n            }\n        }\n        throw new IllegalStateException(\"Druid loader exercise service was not found\");\n    }\n","newText":"    private static BooleanSupplier loadDruidLoaderExercise(ClassLoader classLoader) {\n        ServiceLoader<BooleanSupplier> exercises = ServiceLoader.load(BooleanSupplier.class, classLoader);\n        for (BooleanSupplier exercise : exercises) {\n            if (exercise.getClass().getName().equals(DRUID_LOADER_EXERCISE)) {\n                return exercise;\n            }\n        }\n        throw new IllegalStateException(\"Druid loader exercise service was not found\");\n    }\n"},{"oldText":"    public static final class DruidLoaderExercise implements Callable<String> {\n        @Override\n        public String call() {\n            DbTypeParser parser = new DruidDelegatingDbTypeParser();\n            return parser.parseFromJdbcUrl(\"jdbc:mysql://localhost:3306/seata\");\n        }\n    }\n","newText":"    public static final class DruidLoaderExercise implements BooleanSupplier {\n        @Override\n        public boolean getAsBoolean() {\n            DbTypeParser parser = new DruidDelegatingDbTypeParser();\n            return \"mysql\".equals(parser.parseFromJdbcUrl(\"jdbc:mysql://localhost:3306/seata\"));\n        }\n    }\n"}]}
