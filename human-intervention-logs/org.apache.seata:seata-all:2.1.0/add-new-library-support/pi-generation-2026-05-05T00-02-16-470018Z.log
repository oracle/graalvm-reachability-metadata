de along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_apache_seata.seata_all;\n\nimport org.apache.seata.integration.tx.api.util.DubboUtil;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class DubboUtilTest {\n    @Test\n    void getAssistInterfaceExtractsInterfaceFromDubboProxyShape() throws Exception {\n        ServiceInvoker serviceInvoker = new ServiceInvoker(SampleDubboService.class);\n        ClusterInvoker clusterInvoker = new ClusterInvoker(serviceInvoker);\n        InvokerInvocationHandler handler = new InvokerInvocationHandler(clusterInvoker);\n        DubboProxyClient proxy = new DubboProxyClient(handler);\n\n        Class<?> assistInterface = DubboUtil.getAssistInterface(proxy);\n\n        assertThat(assistInterface).isSameAs(SampleDubboService.class);\n    }\n\n    private interface SampleDubboService {\n        String call();\n    }\n\n    private static class DubboProxyClient {\n        private final InvokerInvocationHandler handler;\n\n        DubboProxyClient(InvokerInvocationHandler handler) {\n            this.handler = handler;\n        }\n    }\n\n    private static class InvokerInvocationHandler {\n        private final ClusterInvoker invoker;\n\n        InvokerInvocationHandler(ClusterInvoker invoker) {\n            this.invoker = invoker;\n        }\n    }\n\n    private static class ClusterInvoker {\n        private final ServiceInvoker invoker;\n\n        ClusterInvoker(ServiceInvoker invoker) {\n            this.invoker = invoker;\n        }\n    }\n\n    private static class ServiceInvoker {\n        private final Class<?> interfaceClass;\n\n        ServiceInvoker(Class<?> interfaceClass) {\n            this.interfaceClass = interfaceClass;\n        }\n\n        private Class<?> getInterface() {\n            return interfaceClass;\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777939330692}]}
