  package org_apache_seata.seata_all;
  
  import org.apache.seata.common.util.ReflectionUtil;
  import org.junit.jupiter.api.Test;
  
  import java.lang.reflect.Field;
  import java.lang.reflect.InvocationTargetException;
  import java.lang.reflect.Method;
  import java.util.Arrays;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ReflectionUtilTest {
      @Test
      void getClassByNameLoadsReachableClassWithContextClassLoader() throws ClassNotFoundException {
          Class<?> loadedClass = ReflectionUtil.getClassByName("org.apache.seata.common.util.ReflectionUtil");
  
          assertThat(loadedClass).isSameAs(ReflectionUtil.class);
      }
  
      @Test
      void fieldUtilitiesDiscoverReadAndWriteInheritedPrivateFields() throws NoSuchFieldException {
          SampleChild sample = new SampleChild();
  
          assertThat(Arrays.stream(ReflectionUtil.getAllFields(SampleChild.class)).map(Field::getName))
                  .contains("childValue", "baseValue")
                  .doesNotContain("STATIC_VALUE");
  
          Field inheritedField = ReflectionUtil.getField(SampleChild.class, "baseValue");
          String baseValue = ReflectionUtil.getFieldValue(sample, inheritedField);
          assertThat(baseValue).isEqualTo("base");
  
          ReflectionUtil.setFieldValue(sample, "childValue", "changed");
  
          assertThat(sample.childValue()).isEqualTo("changed");
      }
  
      @Test
      void modifyStaticFinalFieldUpdatesMutableStaticField() throws NoSuchFieldException, IllegalAccessException {
          String originalValue = StaticHolder.value();
          try {
              ReflectionUtil.modifyStaticFinalField(StaticHolder.class, "mutableStaticValue", "updated");
  
              assertThat(StaticHolder.value()).isEqualTo("updated");
          } finally {
              if (!originalValue.equals(StaticHolder.value())) {
                  ReflectionUtil.modifyStaticFinalField(StaticHolder.class, "mutableStaticValue", originalValue);
              }
          }
      }
  
      @Test
      void methodUtilitiesFindAndInvokePrivateMethods() throws NoSuchMethodException, InvocationTargetException {
          SampleChild sample = new SampleChild();
  
          Method method = ReflectionUtil.getMethod(SampleChild.class, "combine", String.class);
          Object result = ReflectionUtil.invokeMethod(sample, method, "suffix");
  
          assertThat(result).isEqualTo("child-suffix");
      }
  
      private static class SampleBase {
          private String baseValue = "base";
      }
  
      private static class SampleChild extends SampleBase {
          private static final String STATIC_VALUE = "static";
          private String childValue = "child";
  
          String childValue() {
              return childValue;
          }
  
          private String combine(String suffix) {
              return childValue + "-" + suffix;
          }
      }
  
      private static class StaticHolder {
          private static String mutableStaticValue = "initial";
  
          static String value() {
              return mutableStaticValue;
          }
      }
  }
