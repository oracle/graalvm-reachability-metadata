ents": {"path": "tests/src/org.apache.seata/seata-all/2.1.0/src/test/java/org_apache_seata/seata_all/ReflectionUtilTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_apache_seata.seata_all;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.lang.reflect.Field;\nimport java.util.Arrays;\nimport java.util.Set;\nimport java.util.stream.Collectors;\n\nimport org.apache.seata.common.util.ReflectionUtil;\nimport org.junit.jupiter.api.Test;\n\npublic class ReflectionUtilTest {\n    @Test\n    void classLookupAndFieldScanningUseReflectionUtilities() throws Exception {\n        Class<?> loadedClass = ReflectionUtil.getClassByName(ReflectiveFixture.class.getName());\n\n        Field[] fields = ReflectionUtil.getAllFields(loadedClass);\n        Set<String> fieldNames = Arrays.stream(fields)\n                .map(Field::getName)\n                .collect(Collectors.toSet());\n\n        assertThat(loadedClass).isSameAs(ReflectiveFixture.class);\n        assertThat(fieldNames).contains(\"baseValue\", \"message\", \"counter\");\n        assertThat(fieldNames).doesNotContain(\"staticValue\");\n    }\n\n    @Test\n    void fieldValuesCanBeReadAndUpdatedByName() throws Exception {\n        ReflectiveFixture fixture = new ReflectiveFixture(\"initial\", 3);\n\n        assertThat((String) ReflectionUtil.getFieldValue(fixture, \"message\")).isEqualTo(\"initial\");\n        assertThat((Integer) ReflectionUtil.getFieldValue(fixture, \"baseValue\")).isEqualTo(3);\n\n        ReflectionUtil.setFieldValue(fixture, \"message\", \"updated\");\n        ReflectionUtil.setFieldValue(fixture, \"baseValue\", 9);\n\n        assertThat(fixture.describe()).isEqualTo(\"updated:9:1\");\n    }\n\n    @Test\n    void staticFieldsCanBeUpdatedByName() throws Exception {\n        String originalValue = ReflectiveFixture.staticValue;\n        try {\n            ReflectionUtil.modifyStaticFinalField(ReflectiveFixture.class, \"staticValue\", \"changed\");\n\n            assertThat(ReflectiveFixture.staticValue).isEqualTo(\"changed\");\n        } finally {\n            ReflectionUtil.modifyStaticFinalField(ReflectiveFixture.class, \"staticValue\", originalValue);\n        }\n    }\n\n    @Test\n    void methodsCanBeFoundAndInvokedByName() throws Exception {\n        ReflectiveFixture fixture = new ReflectiveFixture(\"segment\", 4);\n\n        Object result = ReflectionUtil.invokeMethod(\n                fixture,\n                \"format\",\n                new Class<?>[] {String.class, int.class},\n                \"prefix\",\n                2);\n\n        assertThat(result).isEqualTo(\"prefix-segment:8\");\n    }\n\n    public static class BaseFixture {\n        private int baseValue;\n\n        protected BaseFixture(int baseValue) {\n            this.baseValue = baseValue;\n        }\n    }\n\n    public static class ReflectiveFixture extends BaseFixture {\n        private static String staticValue = \"original\";\n\n        private String message;\n        private int counter = 1;\n\n        public ReflectiveFixture(String message, int baseValue) {\n            super(baseValue);\n            this.message = message;\n        }\n\n        public String describe() {\n            return message + \":\" + baseValue + \":\" + counter;\n        }\n\n        private String format(String prefix, int multiplier) {\n            return prefix + \"-\" + message + \":\" + (baseValue * multiplier);\n        }\n    }\n}\n"}, "partialJson": "{\"path\":\"tests/src/org.apache.seata/seata-all/2.1.0/src/test/java/org_apache_seata/seata_all/ReflectionUtilTest.java\",\"content\":\"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage org_apache_seata.seata_all;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\n\\nimport java.lang.reflect.Field;\\nimport java.util.Arrays;\\nimport java.util.Set;\\nimport java.util.stream.Collectors;\\n\\nimport org.apache.seata.common.util.ReflectionUtil;\\nimport org.junit.jupiter.api.Test;\\n\\npublic class ReflectionUtilTest {\\n    @Test\\n    void classLookupAndFieldScanningUseReflectionUtilities() throws Exception {\\n        Class<?> loadedClass = ReflectionUtil.getClassByName(ReflectiveFixture.class.getName());\\n\\n        Field[] fields = ReflectionUtil.getAllFields(loadedClass);\\n        Set<String> fieldNames = Arrays.stream(fields)\\n                .map(Field::getName)\\n                .collect(Collectors.toSet());\\n\\n        assertThat(loadedClass).isSameAs(ReflectiveFixture.class);\\n        assertThat(fieldNames).contains(\\\"baseValue\\\", \\\"message\\\", \\\"counter\\\");\\n        assertThat(fieldNames).doesNotContain(\\\"staticValue\\\");\\n    }\\n\\n    @Test\\n    void fieldValuesCanBeReadAndUpdatedByName() throws Exception {\\n        ReflectiveFixture fixture = new ReflectiveFixture(\\\"initial\\\", 3);\\n\\n        assertThat((String) ReflectionUtil.getFieldValue(fixture, \\\"message\\\")).isEqualTo(\\\"initial\\\");\\n        assertThat((Integer) ReflectionUtil.getFieldValue(fixture, \\\"baseValue\\\")).isEqualTo(3);\\n\\n        ReflectionUtil.setFieldValue(fixture, \\\"message\\\", \\\"updated\\\");\\n        ReflectionUtil.setFieldValue(fixture, \\\"baseValue\\\", 9);\\n\\n        assertThat(fixture.describe()).isEqualTo(\\\"updated:9:1\\\");\\n    }\\n\\n    @Test\\n    void staticFieldsCanBeUpdatedByName() throws Exception {\\n        String originalValue = ReflectiveFixture.staticValue;\\n        try {\\n            ReflectionUtil.modifyStaticFinalField(ReflectiveFixture.class, \\\"staticValue\\\", \\\"changed\\\");\\n\\n            assertThat(ReflectiveFixture.staticValue).isEqualTo(\\\"changed\\\");\\n        } finally {\\n            ReflectionUtil.modifyStaticFinalField(ReflectiveFixture.class, \\\"staticValue\\\", originalValue);\\n        }\\n    }\\n\\n    @Test\\n    void methodsCanBeFoundAndInvokedByName() throws Exception {\\n        ReflectiveFixture fixture = new ReflectiveFixture(\\\"segment\\\", 4);\\n\\n        Object result = ReflectionUtil.invokeMethod(\\n                fixture,\\n                \\\"format\\\",\\n                new Class<?>[] {String.class, int.class},\\n                \\\"prefix\\\",\\n                2);\\n\\n        assertThat(result).isEqualTo(\\\"prefix-segment:8\\\");\\n    }\\n\\n    public static class BaseFixture {\\n        private int baseValue;\\n\\n        protected BaseFixture(int baseValue) {\\n            this.baseValue = baseValue;\\n        }\\n    }\\n\\n    public static class ReflectiveFixture extends BaseFixture {\\n        private static String staticValue = \\\"original\\\";\\n\\n        private String message;\\n        private int counter = 1;\\n\\n        public ReflectiveFixture(String message, int baseValue) {\\n            super(baseValue);\\n            this.message = message;\\n        }\\n\\n        public String describe() {\\n            return message + \\\":\\\" + baseValue + \\\":\\\" + counter;\\n        }\\n\\n        private String format(String prefix, int multiplier) {\\n            return prefix + \\\"-\\\" + message + \\\":\\\" + (baseValue * multiplier);\\n        }\\n    }\\n}\\n\"}"}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 997, "output": 1287, "cacheRead": 18944, "cacheWrite": 0, "totalTokens": 21228, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777420890957, "responseId": "resp_024f9def40ee419f0169f14a5ba1ac8192b9e4d0e1c41b5095"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_tXgjPvMfY8ZfdvrShQ7Wz8f0|fc_024f9def40ee419f0169f14a620