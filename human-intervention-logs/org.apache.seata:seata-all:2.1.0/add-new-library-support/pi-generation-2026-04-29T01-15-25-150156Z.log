                  implConstructor.setAccessible(false);
              }
          } catch (Exception e) {
              throw new RuntimeException(e);
          }
      }
  
      @Override
      public String parseFromJdbcUrl(String jdbcUrl) {
          return dbTypeParserImpl.parseFromJdbcUrl(jdbcUrl);
      }
  }
