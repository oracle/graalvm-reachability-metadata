      default String getTableAlias(String tableName) {
          return null;
      }
  
      /**
       * Gets update columns is Simplified.
       *
       * @return (`a`, `b`, `c`)  ->  (a, b, c)
       */
      List<String> getUpdateColumnsUnEscape();
  }
