     163	    /**
     164	     * Gets all fields, excluding static or synthetic fields
     165	     *
     166	     * @param targetClazz the target class
     167	     */
     168	    public static Field[] getAllFields(final Class<?> targetClazz) {
     169	        if (targetClazz == Object.class || targetClazz.isInterface()) {
     170	            return EMPTY_FIELD_ARRAY;
     171	        }
     172	
     173	        // get from the cache
     174	        Field[] fields = CLASS_FIELDS_CACHE.get(targetClazz);
     175	        if (fields != null) {
     176	            return fields;
     177	        }
     178	
     179	        // load current class declared fields
     180	        fields = targetClazz.getDeclaredFields();
     181	        final LinkedList<Field> fieldList = new LinkedList<>(Arrays.asList(fields));
     182	
     183	        // remove the static or synthetic fields
     184	        fieldList.removeIf(f -> Modifier.isStatic(f.getModifiers()) || f.isSynthetic());
     185	
     186	        // load super class all fields, and add to the field list
     187	        Field[] superFields = getAllFields(targetClazz.getSuperclass());
     188	        if (CollectionUtils.isNotEmpty(superFields)) {
     189	            fieldList.addAll(Arrays.asList(superFields));
     190	        }
     191	
     192	        // list to array
     193	        Field[] resultFields;
     194	        if (!fieldList.isEmpty()) {
     195	            resultFields = fieldList.toArray(new Field[0]);
     196	        } else {
     197	            // reuse the EMPTY_FIELD_ARRAY
     198	            resultFields = EMPTY_FIELD_ARRAY;
     199	        }
     200	
     201	        // set cache
     202	        CLASS_FIELDS_CACHE.put(targetClazz, resultFields);
     203	
     204	        return resultFields;
     205	    }
     206	
     207	    /**
     208	     * get Field
     209	     *
     210	     * @param clazz     the class
     211	     * @param fieldName the field name
     212	     * @return the field
     213	     * @throws NoSuchFieldException if the field named {@code fieldName} does not exist
     214	     * @throws SecurityException    the security exception
     215	     */
     216	    public static Field getField(final Class<?> clazz, final String fieldName) throws NoSuchFieldException, SecurityException {
     217	        Map<String, Field> fieldMap = CollectionUtils.computeIfAbsent(FIELD_CACHE, clazz, k -> new ConcurrentHashMap<>());
     218	        Field field = CollectionUtils.computeIfAbsent(fieldMap, fieldName, k -> {
     219	            Class<?> cl = clazz;
     220	            while (cl != null && cl != Object.class && !cl.isInterface()) {
     221	                try {
     222	                    return cl.getDeclaredField(fieldName);
     223	                } catch (NoSuchFieldException e) {
     224	                    cl = cl.getSuperclass();
     225	                }
     226	            }
     227	            return null;
     228	        });
     229	
     230	        if (field == null) {
     231	            throw new NoSuchFieldException("field not found: " + clazz.getName() + ", field: " + fieldName);
     232	        }
     233	
     234	        if (!field.isAccessible()) {
     235	            field.setAccessible(true);
     236	        }
     237	
     238	        return field;
     239	    }
