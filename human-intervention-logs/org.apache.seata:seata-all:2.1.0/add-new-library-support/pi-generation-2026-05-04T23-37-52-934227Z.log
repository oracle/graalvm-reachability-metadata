     346	    /**
     347	     * modify `static` or `static final` field value
     348	     * <p>
     349	     * In java17, this method cannot be used for final fields.
     350	     *
     351	     * @param staticField the static field
     352	     * @param newValue    the new value
     353	     * @throws IllegalArgumentException if {@code staticField} is {@code null} or not a static field
     354	     * @throws NoSuchFieldException     if the class of the staticField has no `modifiers` field
     355	     * @throws IllegalAccessException   the illegal access exception
     356	     */
     357	    public static void modifyStaticFinalField(Field staticField, Object newValue)
     358	            throws NoSuchFieldException, IllegalAccessException {
     359	        if (staticField == null) {
     360	            throw new IllegalArgumentException("staticField must be not null");
     361	        }
     362	
     363	        // check is static field
     364	        if (!Modifier.isStatic(staticField.getModifiers())) {
     365	            throw new IllegalArgumentException("the `" + fieldToString(staticField) + "` is not a static field, cannot modify value.");
     366	        }
     367	
     368	        // remove the `final` keyword from the field
     369	        if (Modifier.isFinal(staticField.getModifiers())) {
     370	            // In java17, can't get the field `modifiers` from class `java.lang.reflect.Field`.
     371	            Field modifiers = staticField.getClass().getDeclaredField("modifiers");
     372	            modifiers.setAccessible(true);
     373	            modifiers.setInt(staticField, staticField.getModifiers() & ~Modifier.FINAL);
     374	        }
     375	
     376	        // set new value
     377	        staticField.setAccessible(true);
     378	        staticField.set(staticField.getDeclaringClass(), newValue);
     379	    }
     380	
     381	    /**
     382	     * modify `static` or `static final` field value
     383	     *
     384	     * @param targetClass     the target class
     385	     * @param staticFieldName the static field name
     386	     * @param newValue        the new value
     387	     * @throws IllegalArgumentException if {@code targetClass} is {@code null}
     388	     * @throws NullPointerException     if {@code staticFieldName} is {@code null}
     389	     * @throws NoSuchFieldException     if the field named {@code modifyFieldName} does not exist
     390	     * @throws IllegalAccessException   the illegal access exception
     391	     */
     392	    public static void modifyStaticFinalField(Class<?> targetClass, String staticFieldName, Object newValue)
     393	            throws NoSuchFieldException, IllegalAccessException {
     394	        if (targetClass == null) {
     395	            throw new IllegalArgumentException("targetClass must be not null");
     396	        }
     397	
     398	        // get field
     399	        Field field = targetClass.getDeclaredField(staticFieldName);
     400	
     401	        // modify static final field value
     402	        modifyStaticFinalField(field, newValue);
     403	    }
