     241	    /**
     242	     * get field value
     243	     *
     244	     * @param target the target
     245	     * @param field  the field of the target
     246	     * @param <T>    the field type
     247	     * @return field value
     248	     * @throws IllegalArgumentException if {@code target} is {@code null}
     249	     * @throws SecurityException        the security exception
     250	     * @throws ClassCastException       if the type of the variable receiving the field value is not equals to the field type
     251	     */
     252	    public static <T> T getFieldValue(Object target, Field field)
     253	            throws IllegalArgumentException, SecurityException {
     254	        if (target == null) {
     255	            throw new IllegalArgumentException("target must be not null");
     256	        }
     257	
     258	        while (true) {
     259	            if (!field.isAccessible()) {
     260	                field.setAccessible(true);
     261	            }
     262	            try {
     263	                return (T)field.get(target);
     264	            } catch (IllegalAccessException ignore) {
     265	                // avoid other threads executing `field.setAccessible(false)`
     266	            }
     267	        }
     268	    }
     269	
     270	    /**
     271	     * get field value
     272	     *
     273	     * @param target    the target
     274	     * @param fieldName the field name
     275	     * @param <T>       the field type
     276	     * @return field value
     277	     * @throws IllegalArgumentException if {@code target} is {@code null}
     278	     * @throws NoSuchFieldException     if the field named {@code fieldName} does not exist
     279	     * @throws SecurityException        the security exception
     280	     * @throws ClassCastException       if the type of the variable receiving the field value is not equals to the field type
     281	     */
     282	    public static <T> T getFieldValue(Object target, String fieldName)
     283	            throws IllegalArgumentException, NoSuchFieldException, SecurityException {
     284	        if (target == null) {
     285	            throw new IllegalArgumentException("target must be not null");
     286	        }
     287	
     288	        // get field
     289	        Field field = getField(target.getClass(), fieldName);
     290	
     291	        // get field value
     292	        return getFieldValue(target, field);
     293	    }
