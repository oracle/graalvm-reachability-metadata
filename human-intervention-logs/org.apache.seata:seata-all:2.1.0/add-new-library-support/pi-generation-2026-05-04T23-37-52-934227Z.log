     419	     * @throws NullPointerException     if {@code methodName} is {@code null}
     420	     * @throws NoSuchMethodException    if the method named {@code methodName} does not exist
     421	     * @throws SecurityException        the security exception
     422	     */
     423	    public static Method getMethod(final Class<?> clazz, final String methodName, final Class<?>... parameterTypes)
     424	            throws NoSuchMethodException, SecurityException {
     425	        if (clazz == null) {
     426	            throw new IllegalArgumentException("clazz must be not null");
     427	        }
     428	
     429	        Map<String, Method> methodMap = CollectionUtils.computeIfAbsent(METHOD_CACHE, clazz, k -> new ConcurrentHashMap<>());
     430	
     431	        String cacheKey = generateMethodCacheKey(methodName, parameterTypes);
     432	        Method method = CollectionUtils.computeIfAbsent(methodMap, cacheKey, k -> {
     433	            Class<?> cl = clazz;
     434	            while (cl != null) {
     435	                try {
     436	                    return cl.getDeclaredMethod(methodName, parameterTypes);
     437	                } catch (NoSuchMethodException e) {
     438	                    cl = cl.getSuperclass();
     439	                }
     440	            }
     441	            return null;
     442	        });
     443	
     444	        if (method == null) {
     445	            throw new NoSuchMethodException("method not found: " + methodToString(clazz, methodName, parameterTypes));
     446	        }
     447	
     448	        if (!method.isAccessible()) {
     449	            method.setAccessible(true);
     450	        }
     451	
     452	        return method;
     453	    }
