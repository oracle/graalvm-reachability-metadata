[tool-call] delta {"path":"tests/src/org.apache.seata/seata-all/2.1.0/src/test/java/org_apache_seata/seata_all/ReflectionUtilTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_apache_seata.seata_all;\n\nimport org.apache.seata.common.util.ReflectionUtil;\nimport org.junit.jupiter.api.Test;\n\nimport java.lang.reflect.Field;\nimport java.lang.reflect.Method;\nimport java.util.Arrays;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ReflectionUtilTest {\n    @Test\n    void getClassByNameLoadsReachableClassWithContextClassLoader() throws ClassNotFoundException {\n        Class<?> loadedClass = ReflectionUtil.getClassByName(\"org.apache.seata.common.util.ReflectionUtil\");\n\n        assertThat(loadedClass).isSameAs(ReflectionUtil.class);\n    }\n\n    @Test\n    void fieldUtilitiesDiscoverReadAndWriteInheritedPrivateFields() throws NoSuchFieldException {\n        SampleChild sample = new SampleChild();\n\n        assertThat(Arrays.stream(ReflectionUtil.getAllFields(SampleChild.class)).map(Field::getName))\n                .contains(\"childValue\", \"baseValue\")\n                .doesNotContain(\"STATIC_VALUE\");\n\n        Field inheritedField = ReflectionUtil.getField(SampleChild.class, \"baseValue\");\n        assertThat(ReflectionUtil.getFieldValue(sample, inheritedField)).isEqualTo(\"base\");\n\n        ReflectionUtil.setFieldValue(sample, \"childValue\", \"changed\");\n\n        assertThat(sample.childValue()).isEqualTo(\"changed\");\n    }\n\n    @Test\n    void modifyStaticFinalFieldUpdatesMutableStaticField() throws NoSuchFieldException, IllegalAccessException {\n        String originalValue = StaticHolder.value();\n        try {\n            ReflectionUtil.modifyStaticFinalField(StaticHolder.class, \"mutableStaticValue\", \"updated\");\n\n            assertThat(StaticHolder.value()).isEqualTo(\"updated\");\n        } finally {\n            ReflectionUtil.modifyStaticFinalField(StaticHolder.class, \"mutableStaticValue\", originalValue);\n        }\n    }\n\n    @Test\n    void methodUtilitiesFindAndInvokePrivateMethods() throws Exception {\n        SampleChild sample = new SampleChild();\n\n        Method method = ReflectionUtil.getMethod(SampleChild.class, \"combine\", String.class);\n        Object result = ReflectionUtil.invokeMethod(sample, method, \"suffix\");\n\n        assertThat(result).isEqualTo(\"child-suffix\");\n    }\n\n    private static class SampleBase {\n        private String baseValue = \"base\";\n    }\n\n    private static class SampleChild extends SampleBase {\n        private static final String STATIC_VALUE = \"static\";\n        private String childValue = \"child\";\n\n        String childValue() {\n            return childValue;\n        }\n\n        private String combine(String suffix) {\n            return childValue + \"-\" + suffix;\n        }\n    }\n\n    private static class StaticHolder {\n        private static String mutableStaticValue = \"initial\";\n\n        static String value() {\n            return mutableStaticValue;\n        }\n    }\n}\n"}
[tool-call] end id=call_UiyTpSVYUNdEOBZigTSIMx9K|fc_07a8f078fa5bb6410169f92d9a6674819ead9bd57303284424 name=write args={"path": "tests/src/org.apache.seata/seata-all/2.1.0/src/test/java/org_apache_seata/seata_all/ReflectionUtilTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_apache_seata.seata_all;\n\nimport org.apache.seata.common.util.ReflectionUtil;\nimport org.junit.jupiter.api.Test;\n\nimport java.lang.reflect.Field;\nimport java.lang.reflect.Method;\nimport java.util.Arrays;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ReflectionUtilTest {\n    @Test\n    void getClassByNameLoadsReachableClassWithContextClassLoader() throws ClassNotFoundException {\n        Class<?> loadedClass = ReflectionUtil.getClassByName(\"org.apache.seata.common.util.ReflectionUtil\");\n\n        assertThat(loadedClass).isSameAs(ReflectionUtil.class);\n    }\n\n    @Test\n    void fieldUtilitiesDiscoverReadAndWriteInheritedPrivateFields() throws NoSuchFieldException {\n        SampleChild sample = new SampleChild();\n\n        assertThat(Arrays.stream(ReflectionUtil.getAllFields(SampleChild.class)).map(Field::getName))\n                .contains(\"childValue\", \"baseValue\")\n                .doesNotContain(\"STATIC_VALUE\");\n\n        Field inheritedField = ReflectionUtil.getField(SampleChild.class, \"baseValue\");\n        assertThat(ReflectionUtil.getFieldValue(sample, inheritedField)).isEqualTo(\"base\");\n\n        ReflectionUtil.setFieldValue(sample, \"childValue\", \"changed\");\n\n        assertThat(sample.childValue()).isEqualTo(\"changed\");\n    }\n\n    @Test\n    void modifyStaticFinalFieldUpdatesMutableStaticField() throws NoSuchFieldException, IllegalAccessException {\n        String originalValue = StaticHolder.value();\n        try {\n            ReflectionUtil.modifyStaticFinalField(StaticHolder.class, \"mutableStaticValue\", \"updated\");\n\n            assertThat(StaticHolder.value()).isEqualTo(\"updated\");\n        } finally {\n            ReflectionUtil.modifyStaticFinalField(StaticHolder.class, \"mutableStaticValue\", originalValue);\n        }\n    }\n\n    @Test\n    void methodUtilitiesFindAndInvokePrivateMethods() throws Exception {\n        SampleChild sample = new SampleChild();\n\n        Method method = ReflectionUtil.getMethod(SampleChild.class, \"combine\", String.class);\n        Object result = ReflectionUtil.invokeMethod(sample, method, \"suffix\");\n\n        assertThat(result).isEqualTo(\"child-suffix\");\n    }\n\n    private static class SampleBase {\n        private String baseValue = \"base\";\n    }\n\n    private static class SampleChild extends SampleBase {\n        private static final String STATIC_VALUE = \"static\";\n        private String childValue = \"child\";\n\n        String childValue() {\n            return childValue;\n        }\n\n        private String combine(String suffix) {\n            return childValue + \"-\" + suffix;\n        }\n    }\n\n    private static class StaticHolder {\n        private static String mutableStaticValue = \"initial\";\n\n        static String value() {\n            return mutableStaticValue;\n        }\n    }\n}\n"}
