     455	    private static String generateMethodCacheKey(String methodName, Class<?>[] parameterTypes) {
     456	        StringBuilder key = new StringBuilder(methodName);
     457	        if (parameterTypes != null && parameterTypes.length > 0) {
     458	            key.append("|");
     459	            for (Class<?> parameterType : parameterTypes) {
     460	                key.append(parameterType.getName()).append(",");
     461	            }
     462	        }
     463	        return key.toString();
     464	    }
