     466	    /**
     467	     * get method.
     468	     * If you want to get the public method, please use {@link Class#getMethod(String, Class[])}.
     469	     *
     470	     * @param clazz      the class
     471	     * @param methodName the method name
     472	     * @return the method
     473	     * @throws IllegalArgumentException if {@code clazz} is {@code null}
     474	     * @throws NullPointerException     if {@code methodName} is {@code null}
     475	     * @throws NoSuchMethodException    if the method named {@code methodName} does not exist
     476	     * @throws SecurityException        the security exception
     477	     */
     478	    public static Method getMethod(final Class<?> clazz, final String methodName)
     479	            throws NoSuchMethodException, SecurityException {
     480	        return getMethod(clazz, methodName, EMPTY_CLASS_ARRAY);
     481	    }
