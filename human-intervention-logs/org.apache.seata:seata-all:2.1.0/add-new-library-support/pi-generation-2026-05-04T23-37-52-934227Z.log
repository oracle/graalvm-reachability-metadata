     295	    /**
     296	     * set field value
     297	     *
     298	     * @param target     the target
     299	     * @param field      the field of the target
     300	     * @param fieldValue the field value
     301	     * @throws IllegalArgumentException if {@code target} is {@code null}
     302	     * @throws SecurityException        the security exception
     303	     */
     304	    public static void setFieldValue(Object target, Field field, Object fieldValue)
     305	            throws IllegalArgumentException, SecurityException {
     306	        if (target == null) {
     307	            throw new IllegalArgumentException("target must be not null");
     308	        }
     309	
     310	        while (true) {
     311	            if (!field.isAccessible()) {
     312	                field.setAccessible(true);
     313	            }
     314	            try {
     315	                field.set(target, fieldValue);
     316	                return;
     317	            } catch (IllegalAccessException ignore) {
     318	                // avoid other threads executing `field.setAccessible(false)`
     319	            }
     320	        }
     321	    }
     322	
     323	    /**
     324	     * get field value
     325	     *
     326	     * @param target     the target
     327	     * @param fieldName  the field name
     328	     * @param fieldValue the field value
     329	     * @throws IllegalArgumentException if {@code target} is {@code null}
     330	     * @throws NoSuchFieldException     if the field named {@code fieldName} does not exist
     331	     * @throws SecurityException        the security exception
     332	     */
     333	    public static void setFieldValue(Object target, String fieldName, Object fieldValue)
     334	            throws IllegalArgumentException, NoSuchFieldException, SecurityException {
     335	        if (target == null) {
     336	            throw new IllegalArgumentException("target must be not null");
     337	        }
     338	
     339	        // get field
     340	        Field field = getField(target.getClass(), fieldName);
     341	
     342	        // set new value
     343	        setFieldValue(target, field, fieldValue);
     344	    }
