     483	    /**
     484	     * invoke Method
     485	     *
     486	     * @param target the target
     487	     * @param method the method
     488	     * @param args   the args
     489	     * @return the result of the underlying method
     490	     * @throws InvocationTargetException if the underlying method throws an exception.
     491	     * @throws IllegalArgumentException  the illegal argument exception
     492	     * @throws SecurityException         the security exception
     493	     */
     494	    public static Object invokeMethod(Object target, Method method, Object... args)
     495	            throws InvocationTargetException, IllegalArgumentException, SecurityException {
     496	        while (true) {
     497	            if (!method.isAccessible()) {
     498	                method.setAccessible(true);
     499	            }
     500	            try {
     501	                return method.invoke(target, args);
     502	            } catch (IllegalAccessException ignore) {
     503	                // avoid other threads executing `method.setAccessible(false)`
     504	            }
     505	        }
     506	    }
