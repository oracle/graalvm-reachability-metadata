     143	    public static Set<Class<?>> getInterfaces(Class<?> clazz) {
     144	        if (clazz.isInterface()) {
     145	            return Collections.singleton(clazz);
     146	        }
     147	        Set<Class<?>> interfaces = new LinkedHashSet<>();
     148	        while (clazz != null) {
     149	            Class<?>[] ifcs = clazz.getInterfaces();
     150	            for (Class<?> ifc : ifcs) {
