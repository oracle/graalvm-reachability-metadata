    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>org.glassfish.jersey.bundles.repackaged</groupId>
        <artifactId>project</artifactId>
        <version>2.23.2</version>
    </parent>

    <artifactId>jersey-guava</artifactId>
    <packaging>bundle</packaging>
    <name>jersey-repackaged-guava</name>

    <description>Jersey Guava Repackaged</description>

    <build>
        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-shade-plugin</artifactId>
                <inherited>true</inherited>
                <configuration>
                    <minimizeJar>false</minimizeJar>
                    <createSourcesJar>true</createSourcesJar>
                    <shadeSourcesContent>true</shadeSourcesContent>
                    <artifactSet>
                        <includes>
                            <include>com.google.guava:guava:*</include>
                        </includes>
                    </artifactSet>
                    <relocations>
                        <relocation>
                            <pattern>com.google.common</pattern>
                            <shadedPattern>${shade.package}</shadedPattern>
                        </relocation>
                        <relocation>
                            <pattern>com.google.thirdparty</pattern>
                            <shadedPattern>${shade.package.thirdparty}</shadedPattern>
                        </relocation>
                    </relocations>
                </configuration>
            </plugin>
            <plugin>
                <groupId>org.apache.felix</groupId>
                <artifactId>maven-bundle-plugin</artifactId>
                <inherited>true</inherited>
                <extensions>true</extensions>
                <executions>
                    <execution>
                        <id>osgi-bundle</id>
                        <goals>
                            <goal>manifest</goal>
                        </goals>
                    </execution>
                </executions>
                <configuration>
                    <instructions>
                        <Import-Package>
                            !${jersey.repackaged.prefix}.com.google.common.*,
                            !${jersey.repackaged.prefix}.com.google.thirdparty.*,
                            javax.annotation;resolution:=optional;version="[1.2,2)",
                            javax.inject;resolution:=optional;version="[1.0,2)",
                            sun.misc.*;resolution:=optional,
                            *
                        </Import-Package>
                        <Export-Package>
                            !${jersey.repackaged.prefix}.com.google.common.base.internal,
                            ${jersey.repackaged.prefix}.com.google.common.*,
                            ${jersey.repackaged.prefix}.com.google.thirdparty.*
                        </Export-Package>
                        <_include>src/main/resources/META-INF/MANIFEST.MF</_include>
                    </instructions>
                    <unpackBundle>true</unpackBundle>
                </configuration>
            </plugin>
        </plugins>
    </build>

