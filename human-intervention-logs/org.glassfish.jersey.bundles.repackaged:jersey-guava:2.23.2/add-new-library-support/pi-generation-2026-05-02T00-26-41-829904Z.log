  package org_glassfish_jersey_bundles_repackaged.jersey_guava;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import jersey.repackaged.com.google.common.collect.ObjectArrays;
  
  import org.junit.jupiter.api.Test;
  
  public class ObjectArraysTest {
      @Test
      void newArrayCreatesTypedArrayWithRequestedLength() {
          final String[] values = ObjectArrays.newArray(String.class, 3);
  
          assertThat(values).hasSize(3);
          assertThat(values).isInstanceOf(String[].class);
          assertThat(values).containsExactly(null, null, null);
      }
  }
