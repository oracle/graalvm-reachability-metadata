anager(Thread.currentThread().getContextClassLoader()));\\n            if (methodMapping.getOnClose() != null || methodMapping.getOnOpen() != null ||\\n                    methodMapping.getOnError() != null || methodMapping.hasMessageHandlers()) {\\n                sec.getUserProperties().put(org.apache.tomcat.websocket.pojo.Constants.POJO_METHOD_MAPPING_KEY,\\n                        methodMapping);\\n            }\\n\\n            UriTemplate uriTemplate = new UriTemplate(path);\\n            if (uriTemplate.hasParameters()) {\\n                Integer key = Integer.valueOf(uriTemplate.getSegmentCount());\\n                ConcurrentSkipListMap<String, TemplatePathMatch> templateMatches = configTemplateMatchMap.get(key);\\n                if (templateMatches == null) {\\n                    // Ensure that if concurrent threads execute this block they\\n                    // all end up using the same ConcurrentSkipListMap instance\\n                    templateMatches = new ConcurrentSkipListMap<>();\\n                    configTemplateMatchMap.putIfAbsent(key, templateMatches);\\n                    templateMatches = configTemplateMatchMap.get(key);\\n\\n[388 more lines in file. Use offset=161 to continue.]\"}], \"isError\": false, \"timestamp\": 1777394184978}]}\nhuman-intervention-logs/org.apache.tomcat.embed:tomcat-embed-websocket:9.0.83/add-new-library-support/pi-generation-2026-04-28T16-37-49-985712Z.log:1934:[tool-call] delta {\"path\":\"tests/src/org.apache.tomcat.embed/tomcat-embed-websocket/9.0.83/src/test/java/org_apache_tomcat_embed/tomcat_embed_websocket/WsSciTest.java\",\"content\":\"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage org_apache_tomcat_embed.tomcat_embed_websocket;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\n\\nimport java.io.InputStream;\\nimpo