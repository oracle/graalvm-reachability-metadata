  import javax.servlet.descriptor.JspConfigDescriptor;
  import javax.websocket.Endpoint;
  import javax.websocket.EndpointConfig;
  import javax.websocket.Session;
  import javax.websocket.server.ServerApplicationConfig;
  import javax.websocket.server.ServerEndpoint;
  import javax.websocket.server.ServerEndpointConfig;
  
  import org.apache.tomcat.websocket.server.Constants;
  import org.apache.tomcat.websocket.server.WsSci;
  import org.apache.tomcat.websocket.server.WsServerContainer;
  import org.junit.jupiter.api.Test;
  
  public class WsSciTest {
  
      @Test
      public void startupInstantiatesServerApplicationConfigAndPassesDiscoveredEndpoints() throws Exception {
          RecordingServerApplicationConfig.reset();
          TestServletContext servletContext = new TestServletContext();
          Set<Class<?>> scannedClasses = new HashSet<>(Arrays.asList(
                  RecordingServerApplicationConfig.class,
                  AnnotatedEndpoint.class,
                  ProgrammaticEndpoint.class));
  
          new WsSci().onStartup(scannedClasses, servletContext);
  
          assertThat(RecordingServerApplicationConfig.constructed).isTrue();
          assertThat(RecordingServerApplicationConfig.endpointCandidates)
                  .containsExactlyInAnyOrder(ProgrammaticEndpoint.class);
          assertThat(RecordingServerApplicationConfig.pojoCandidates)
                  .containsExactlyInAnyOrder(AnnotatedEndpoint.class);
          assertThat(servletContext.getAttribute(Constants.SERVER_CONTAINER_SERVLET_CONTEXT_ATTRIBUTE))
                  .isInstanceOf(WsServerContainer.class);
      }
  
      public static class RecordingServerApplicationConfig implements ServerApplicationConfig {
          private static boolean constructed;
          private static Set<Class<? extends Endpoint>> endpointCandidates;
          private static Set<Class<?>> pojoCandidates;
  
          public RecordingServerApplicationConfig() {
              constructed = true;
          }
  
          private static void reset() {
              constructed = false;
              endpointCandidates = Collections.emptySet();
              pojoCandidates = Collections.emptySet();
          }
  
          @Override
          public Set<ServerEndpointConfig> getEndpointConfigs(Set<Class<? extends Endpoint>> endpointClasses) {
              endpointCandidates = new HashSet<>(endpointClasses);
              return Collections.emptySet();
          }
  
          @Override
          public Set<Class<?>> getAnnotatedEndpointClasses(Set<Class<?>> scanned) {
              pojoCandidates = new HashSet<>(scanned);
              return Collections.emptySet();
          }
      }
  
      @ServerEndpoint("/recorded")
      public static class AnnotatedEndpoint {
      }
  
      public static class ProgrammaticEndpoint extends Endpoint {
          @Override
          public void onOpen(Session session, EndpointConfig config) {
          }
      }
  
      private static class TestServletContext implements ServletContext {
          private final Map<String, Object> attributes = new HashMap<>();
  
          @Override
          public String getContextPath() {
              return "/test";
          }
  
          @Override
          public ServletContext getContext(String uripath) {
              return null;
          }
  
          @Override
          public int getMajorVersion() {
              return 4;
          }
  
          @Override
          public int getMinorVersion() {
              return 0;
          }
  
          @Override
          public int getEffectiveMajorVersion() {
              return 4;
          }
  
          @Override
          public int getEffectiveMinorVersion() {
              return 0;
          }
  
  
