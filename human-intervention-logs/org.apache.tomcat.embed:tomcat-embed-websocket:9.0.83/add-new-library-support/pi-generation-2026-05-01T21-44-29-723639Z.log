ax.servlet.Filter;\nimport javax.servlet.FilterRegistration;\nimport javax.servlet.RequestDispatcher;\nimport javax.servlet.Servlet;\nimport javax.servlet.ServletContext;\nimport javax.servlet.ServletException;\nimport javax.servlet.ServletRegistration;\nimport javax.servlet.SessionCookieConfig;\nimport javax.servlet.SessionTrackingMode;\nimport javax.servlet.descriptor.JspConfigDescriptor;\nimport javax.websocket.Endpoint;\nimport javax.websocket.EndpointConfig;\nimport javax.websocket.Session;\nimport javax.websocket.server.ServerApplicationConfig;\nimport javax.websocket.server.ServerContainer;\nimport javax.websocket.server.ServerEndpointConfig;\n\nimport org.apache.tomcat.websocket.server.WsSci;\nimport org.junit.jupiter.api.Test;\n\npublic class WsSciTest {\n\n    @Test\n    void onStartupInstantiatesDiscoveredServerApplicationConfig() throws Exception {\n        CountingServerApplicationConfig.reset();\n        TestServletContext servletContext = new TestServletContext();\n\n        new WsSci().onStartup(Collections.singleton(CountingServerApplicationConfig.class), servletContext);\n\n        assertThat(CountingServerApplicationConfig.constructions).isEqualTo(1);\n        assertThat(CountingServerApplicationConfig.endpointConfigCalls).isEqualTo(1);\n        assertThat(CountingServerApplicationConfig.annotatedEndpointCalls).isEqualTo(1);\n        assertThat(servletContext.getAttribute(ServerContainer.class.getName())).isNotNull();\n    }\n\n    public static class CountingServerApplicationConfig implements ServerApplicationConfig {\n        private static int constructions;\n        private static int endpointConfigCalls;\n        private static int annotatedEndpointCalls;\n\n        public CountingServerApplicationConfig() {\n            constructions++;\n        }\n\n        private static void reset() {\n            constructions = 0;\n            endpointConfigCalls = 0;\n            annotatedEndpointCalls = 0;\n        }\n\n        @Override\n        public Set<ServerEndpointConfig> getEndpointConfigs(Set<Class<? extends Endpoint>> endpointClasses) {\n            endpointConfigCalls++;\n            assertThat(endpointClasses).isEmpty();\n            return Collections.emptySet();\n        }\n\n        @Override\n        public Set<Class<?>> getAnnotatedEndpointClasses(Set<Class<?>> scanned) {\n            annotatedEndpointCalls++;\n            assertThat(scanned).isEmpty();\n            return Collections.emptySet();\n        }\n    }\n\n    private static final class TestServletContext implements ServletContext {\n        private final Map<String, Object> attributes = new HashMap<>();\n\n        @Override\n        public String getContextPath() {\n            return \"\";\n        }\n\n        @Override\n        public ServletContext getContext(String uripath) {\n            return null;\n        }\n\n        @Override\n        public int getMajorVersion() {\n            return 4;\n        }\n\n        @Override\n        public int getMinorVersion() {\n            return 0;\n        }\n\n        @Override\n        public int getEffectiveMajorVersion() {\n            return 4;\n        }\n\n        @Override\n        public int getEffectiveMinorVersion() {\n            return 0;\n        }\n\n        @Override\n        public String getMimeType(String file) {\n            return null;\n        }\n\n        @Override\n        public Set<String> getResourcePaths(String path) {\n            return Collections.emptySet();\n        }\n\n        @Override\n        public URL getResource(String path) throws MalformedURLException {\n            return null;\n        }\n\n        @Override\n        public InputStream getResourceAsStream(String path) {\n            return null;\n        }\n\n        @Override\n        public RequestDispatcher getRequestDispatcher(String path) {\n            return null;\n        }\n\n        @Override\n        public RequestDispatcher getNamedDispatcher(String name) {\n            return null