  public class WsSciTest {
  
      @Test
      void onStartupInstantiatesDiscoveredServerApplicationConfig() throws Exception {
          CountingServerApplicationConfig.reset();
          TestServletContext servletContext = new TestServletContext();
  
          new WsSci().onStartup(Collections.singleton(CountingServerApplicationConfig.class), servletContext);
  
          assertThat(CountingServerApplicationConfig.constructions).isEqualTo(1);
          assertThat(CountingServerApplicationConfig.endpointConfigCalls).isEqualTo(1);
          assertThat(CountingServerApplicationConfig.annotatedEndpointCalls).isEqualTo(1);
          assertThat(servletContext.getAttribute(ServerContainer.class.getName())).isNotNull();
      }
  
      public static class CountingServerApplicationConfig implements ServerApplicationConfig {
          private static int constructions;
          private static int endpointConfigCalls;
          private static int annotatedEndpointCalls;
  
          public CountingServerApplicationConfig() {
              constructions++;
          }
  
          private static void reset() {
              constructions = 0;
              endpointConfigCalls = 0;
              annotatedEndpointCalls = 0;
          }
  
          @Override
          public Set<ServerEndpointConfig> getEndpointConfigs(Set<Class<? extends Endpoint>> endpointClasses) {
              endpointConfigCalls++;
              assertThat(endpointClasses).isEmpty();
              return Collections.emptySet();
          }
  
          @Override
          public Set<Class<?>> getAnnotatedEndpointClasses(Set<Class<?>> scanned) {
              annotatedEndpointCalls++;
              assertThat(scanned).isEmpty();
              return Collections.emptySet();
          }
      }
  
