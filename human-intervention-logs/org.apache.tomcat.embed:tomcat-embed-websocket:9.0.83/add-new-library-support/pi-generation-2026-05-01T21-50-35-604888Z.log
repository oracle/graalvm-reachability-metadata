 discovery, my class could be loaded after others but potentially executed first. I wonder if JUnit loads all test classes before executing the tests.\"}]}"}, {"type": "toolCall", "id": "call_HGDEYlWoZuIT4Je3a2DQn4tU|fc_06cd92e7e05971380169f520aac7788196bda38bd39195cd39", "name": "edit", "arguments": {"path": "tests/src/org.apache.tomcat.embed/tomcat-embed-websocket/9.0.83/src/test/java/org_apache_tomcat_embed/tomcat_embed_websocket/ServerEndpointConfigInnerConfiguratorTest.java", "edits": [{"oldText": "public class ServerEndpointConfigInnerConfiguratorTest {\n\n    @Test\n    void checkOriginLoadsFallbackDefaultConfiguratorWhenNoServiceProviderIsVisible() {\n        ClassLoader originalContextClassLoader = Thread.currentThread().getContextClassLoader();\n        ClassLoader serviceHidingClassLoader = new ServiceHidingClassLoader(originalContextClassLoader,\n                ServerEndpointConfig.Configurator.class);\n        Thread.currentThread().setContextClassLoader(serviceHidingClassLoader);\n        try {\n            ServerEndpointConfig.Configurator configurator = new ServerEndpointConfig.Configurator();\n\n            assertThat(configurator.checkOrigin(\"https://example.test\")).isTrue();\n        } finally {\n            Thread.currentThread().setContextClassLoader(originalContextClassLoader);\n        }\n    }\n", "newText": "public class ServerEndpointConfigInnerConfiguratorTest {\n    private static final boolean FALLBACK_CONFIGURATOR_LOADED = loadFallbackDefaultConfigurator();\n\n    @Test\n    void checkOriginLoadsFallbackDefaultConfiguratorWhenNoServiceProviderIsVisible() {\n        assertThat(FALLBACK_CONFIGURATOR_LOADED).isTrue();\n    }\n\n    private static boolean loadFallbackDefaultConfigurator() {\n        Thread thread = Thread.currentThread();\n        ClassLoader originalContextClassLoader = thread.getContextClassLoader();\n        ClassLoader serviceHidingClassLoader = new ServiceHidingClassLoader(originalContextClassLoader,\n              