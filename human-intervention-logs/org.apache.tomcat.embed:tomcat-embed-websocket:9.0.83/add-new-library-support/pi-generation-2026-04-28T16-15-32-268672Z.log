                  }
                  if (Endpoint.class.isAssignableFrom(clazz)) {
                      @SuppressWarnings("unchecked")
                      Class<? extends Endpoint> endpoint = (Class<? extends Endpoint>) clazz;
                      scannedEndpointClazzes.add(endpoint);
  
