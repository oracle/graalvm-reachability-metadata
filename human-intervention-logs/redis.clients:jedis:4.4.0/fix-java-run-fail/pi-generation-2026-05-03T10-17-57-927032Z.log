eptionally(exception);\n                }\n            }\n        }, \"jedis-test-server\");\n        serverThread.setDaemon(true);\n        serverThread.start();\n        return acceptedConnection;\n    }\n\n    private static void replyOkToHandshakeCommands(Socket socket) throws IOException {\n        InputStream inputStream = socket.getInputStream();\n        OutputStream outputStream = socket.getOutputStream();\n        byte[] buffer = new byte[512];\n        try {\n            while (true) {\n                int read = inputStream.read(buffer);\n                if (read < 0) {\n                    return;\n                }\n                int commandCount = countRedisProtocolCommands(buffer, read);\n                for (int i = 0; i < commandCount; i++) {\n                    outputStream.write(bytes(\"+OK\\r\\n\"));\n                }\n                outputStream.flush();\n            }\n        } catch (SocketTimeoutException exception) {\n            // The constructor handshake completed and the client kept the socket open.\n        }\n    }\n\n    private static int countRedisProtocolCommands(byte[] buffer, int length) {\n        int commandCount = 0;\n        for (int i = 0; i < length; i++) {\n            if (buffer[i] == '*') {\n                commandCount++;\n            }\n        }\n        return commandCount;\n    }\n"}]}
