              if (acceptedConnection.isDone() || serverSocket.isClosed()) {\n                    acceptedConnection.complete(null);\n                } else {\n                    acceptedConnection.completeExceptionally(exception);\n                }\n            }\n        }, \"jedis-test-server\");\n        serverThread.setDaemon(true);\n        serverThread.start();\n        return acceptedConnection;\n    }\n", "newText": "    private static CompletableFuture<Void> acceptSingleConnection(ServerSocket serverSocket) {\n        CompletableFuture<Void> acceptedConnection = new CompletableFuture<>();\n        Thread serverThread = new Thread(() -> {\n            try (Socket socket = serverSocket.accept()) {\n                socket.setSoTimeout(5_000);\n                socket.getOutputStream().write(bytes(\"+OK\\r\\n+OK\\r\\n\"));\n                socket.getOutputStream().flush();\n                acceptedConnection.complete(null);\n                while (socket.getInputStream().read() != -1) {\n                    // Drain startup commands until the Jedis client closes the connection.\n                }\n            } catch (IOException exception) {\n                if (acceptedConnection.isDone() || serverSocket.isClosed()) {\n                    acceptedConnection.complete(null);\n                } else {\n                    acceptedConnection.completeExceptionally(exception);\n                }\n            }\n        }, \"jedis-test-server\");\n        serverThread.setDaemon(true);\n        serverThread.start();\n        return acceptedConnection;\n    }\n"}]}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 5948, "output": 1478, "cacheRead": 11776, "cacheWrite": 0, "totalTokens": 19202, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777803868480, "responseId": "resp_035c3093fce308820169f7225cd12c819c928e2a5cf65a5bff"}}
