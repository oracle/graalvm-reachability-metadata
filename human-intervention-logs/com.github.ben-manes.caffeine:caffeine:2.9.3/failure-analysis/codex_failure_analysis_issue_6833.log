r().maximumWeight(10_000).weigher((String key, String graph) -> graph.length())\\n                .build(key -> key.equals(\\\"Hello\\\") ? \\\"World\\\" : \\\"Universe\\\");\\n        assertThat(secondGraphs.get(\\\"Hello\\\")).isEqualTo(\\\"World\\\");\\n    }\\n\\n    @Test\\n    void testTimeBased() {\\n        LoadingCache<String, String> firstGraphs = Caffeine.newBuilder().expireAfterAccess(5, TimeUnit.MINUTES)\\n                .build(key -> key.equals(\\\"Hello\\\") ? \\\"World\\\" : \\\"Universe\\\");\\n        assertThat(firstGraphs.get(\\\"Hello\\\")).isEqualTo(\\\"World\\\");\\n        LoadingCache<String, String> secondGraphs = Caffeine.newBuilder().expireAfterWrite(10, TimeUnit.MINUTES)\\n                .build(key -> key.equals(\\\"Hello\\\") ? \\\"World\\\" : \\\"Universe\\\");\\n        assertThat(secondGraphs.get(\\\"Hello\\\")).isEqualTo(\\\"World\\\");\\n        LoadingCache<String, String> thirdGraphs = Caffeine.newBuilder().expireAfter(new Expiry<String, String>() {\\n            public long expireAfterCreate(String key, String graph, long currentTime) {\\n                long seconds = ZonedDateTime.now().plusHours(5).minus(System.currentTimeMillis(), MILLIS).toEpochSecond();\\n                return TimeUnit.SECONDS.toNanos(seconds);\\n            }\\n\\n            public long expireAfterUpdate(String key, String graph, long currentTime, long currentDuration) {\\n                return currentDuration;\\n            }\\n\\n            public long expireAfterRead(String key, String graph, long currentTime, long currentDuration) {\\n                return currentDuration;\\n            }\\n        }).build(key -> key.equals(\\\"Hello\\\") ? \\\"World\\\" : \\\"Universe\\\");\\n        assertThat(thirdGraphs.get(\\\"Hello\\\")).isEqualTo(\\\"World\\\");\\n    }\\n\\n    @Test\\n    void testReferenceBased() {\\n        LoadingCache<String, String> firstGraphs = Caffeine.newBuilder().weakKeys().weakValues().build(key -> key.equals(\\\"Hello\\\") ? \\\"World\\\" : \\\"Universe\\\");\\n        assertThat(firstGraphs.get(\\\"Hello\\\")).isEqualTo(\\\"World\\\");\\n        LoadingCache<String, String> secondGraphs = Caffeine.newBuilder().softValues().build(key -> key.equals(\\\"Hello\\\") ? \\\"World\\\" : \\\"Universe\\\");\\n        assertThat(secondGraphs.get(\\\"Hello\\\")).isEqualTo(\\\"World\\\");\\n    }\\n}\\n\",\"exit_code\":0,\"status\":\"completed\"}}\n{\"type\":\"item.started\",\"item\":{\"id\":\"item_67\",\"type\":\"command_execution\",\"command\":\"/usr/bin/bash -lc 'javap -classpath /home/vjovanov/.m2/repository/com/github/ben-manes/caffeine/caffeine/2.9.3/caffeine-2.9.3.jar -p com.github.benmanes.caffeine.cache.FS'\",\"aggregated_output\":\"\",\"exit_code\":null,\"status\":\"in_progress\"}}\n{\"type\":\"item.started\",\"item\":{\"id\":\"item_68\",\"type\":\"command_execution\",\"command\":\"/usr/bin/bash -lc 'javap -classpath /home/vjovanov/.m2/repository/com/github/ben-manes/caffeine/caffeine/2.9.3/caffeine-2.9.3.jar -p com.github.benmanes.caffeine.cache.WS'\",\"aggregated_output\":\"\",\"exit_code\":null,\"status\":\"in_progress\"}}\n{\"type\":\"item.completed\",\"item\":{\"id\":\"item_67\",\"type\":\"command_execution\",\"command\":\"/usr/bin/bash -lc 'javap -classpath /home/vjovanov/.m2/repository/com/github/ben-manes/caffeine/caffeine/2.9.3/caffeine-2.9.3.jar -p com.github.benmanes.caffeine.cache.FS'\",\"aggregated_output\":\"Compiled from \\\"FS.java\\\"\\nclass com.github.benmanes.caffeine.cache.FS<K, V> extends com.github.benmanes.caffeine.cache.Node<K, V> implements com.github.benmanes.caffeine.cache.NodeFactory<K, V> {\\n  protected static final long KEY_OFFSET;\\n  protected static final long VALUE_OFFSET;\\n  volatile com.github.benmanes.caffeine.cache.References$WeakKeyReference<K> key;\\n  volatile V value;\\n  com.github.benmanes.caffeine.cache.FS();\\n  com.github.benmanes.caffeine.cache.FS(K, java.lang.ref.ReferenceQueue<K>, V, java.lang.ref.ReferenceQueue<V>, int, long);\\n  c