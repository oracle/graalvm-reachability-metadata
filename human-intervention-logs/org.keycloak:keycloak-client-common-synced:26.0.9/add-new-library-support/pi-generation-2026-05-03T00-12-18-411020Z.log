hodOrType instanceof Method);\n        assertEquals(\"finalMethod\", Method.class.cast(finalMethodOrType).getName());\n    }\n\n    @Test\n    public void resolvesRawListTypeFromFieldValue() throws Exception {\n        Field rawListField = Reflections.findDeclaredField(RawListHolder.class, \"values\");\n        assertNotNull(rawListField);\n        Reflections.setAccessible(rawListField);\n\n        assertSame(String.class, Reflections.resolveListType(rawListField, new RawListHolder()));\n    }\n\n    @Test\n    @SuppressWarnings(\"deprecation\")\n    public void createsNewInstancesByClassName() throws Exception {\n        NewInstanceSubject subject = Reflections.newInstance(NewInstanceSubject.class);\n\n        assertTrue(subject.created);\n    }\n\n    private static boolean containsField(Set<Field> fields, String name) {\n        for (Field field : fields) {\n            if (field.getName().equals(name)) {\n                return true;\n            }\n        }\n        return false;\n    }\n\n    private static boolean containsMethod(Set<Method> methods, String name) {\n        for (Method method : methods) {\n            if (method.getName().equals(name)) {\n                return true;\n            }\n        }\n        return false;\n    }\n\n    private static final class BlockingClassLoader extends ClassLoader {\n        BlockingClassLoader() {\n            super(null);\n        }\n\n        @Override\n        protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {\n            throw new ClassNotFoundException(name);\n        }\n    }\n\n    public static class ParentSubject {\n        private final String parentField = \"parent\";\n\n        private String parentGreeting(String prefix) {\n            return prefix + \" \" + parentField;\n        }\n    }\n\n    public static class ChildSubject extends ParentSubject {\n        private final String childField = \"child\";\n\n        public String childGreeting() {\n            return childField;\n        }\n    }\n\n    public static class ConstructorSubject {\n        public ConstructorSubject() {\n        }\n\n        public ConstructorSubject(String value) {\n            assertNotNull(value);\n        }\n    }\n\n    public static class FinalMethodSubject {\n        public final String finalMethod() {\n            return \"final\";\n        }\n    }\n\n    public static class RawListHolder {\n        @SuppressWarnings(\"rawtypes\")\n        private final List values = new ArrayList<String>();\n\n        RawListHolder() {\n            values.add(\"item\");\n        }\n    }\n\n    public static class NewInstanceSubject {\n        private final boolean created;\n\n        public NewInstanceSubject() {\n            this.created = true;\n        }\n    }\n\n    public static class ClassForNameSubject {\n    }\n}\n"}], "isError": false, "timestamp": 1777767096299}]}
