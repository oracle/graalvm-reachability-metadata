jgss.Oid;\n", "newText": "import org.ietf.jgss.GSSManager;\nimport org.ietf.jgss.GSSName;\nimport org.ietf.jgss.Oid;\n"}, {"oldText": "import javax.security.auth.kerberos.KerberosPrincipal;\nimport javax.security.auth.kerberos.KerberosTicket;\nimport java.util.Date;\n", "newText": "import javax.security.auth.Subject;\nimport javax.security.auth.kerberos.KerberosPrincipal;\nimport javax.security.auth.kerberos.KerberosTicket;\nimport java.security.PrivilegedExceptionAction;\nimport java.util.Date;\nimport java.util.Set;\n"}, {"oldText": "        String originalJavaVendor = System.getProperty(\"java.vendor\");\n        System.setProperty(\"java.vendor\", \"IBM Corporation\");\n\n        try {\n            String serializedCredential = KerberosSerializationUtils.serializeCredential(\n                    kerberosTicket(), new MinimalGssCredential());\n", "newText": "        KerberosTicket kerberosTicket = kerberosTicket();\n        GSSCredential gssCredential = gssCredentialFor(kerberosTicket);\n        String originalJavaVendor = System.getProperty(\"java.vendor\");\n        System.setProperty(\"java.vendor\", \"IBM Corporation\");\n\n        try {\n            String serializedCredential = KerberosSerializationUtils.serializeCredential(\n                    kerberosTicket, gssCredential);\n"}, {"oldText": "    private static KerberosTicket kerberosTicket() {\n", "newText": "    private static GSSCredential gssCredentialFor(KerberosTicket kerberosTicket) throws GSSException {\n        GSSManager gssManager = GSSManager.getInstance();\n        Oid kerberosMechanism = new Oid(\"1.2.840.113554.1.2.2\");\n        Oid kerberosPrincipalName = new Oid(\"1.2.840.113554.1.2.2.1\");\n        GSSName gssName = gssManager.createName(kerberosTicket.getClient().getName(), kerberosPrincipalName);\n        Subject subject = new Subject(\n                false,\n                Set.of(kerberosTicket.getClient()),\n                Set.of(gssName),\n                Set.of(kerberosTicket))