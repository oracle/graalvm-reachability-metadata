 class RefusingClassLoader extends ClassLoader {\n        private final String refusedClassName;\n\n        RefusingClassLoader(ClassLoader parent, String refusedClassName) {\n            super(parent);\n            this.refusedClassName = refusedClassName;\n        }\n\n        @Override\n        protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {\n            if (refusedClassName.equals(name)) {\n                throw new ClassNotFoundException(name);\n            }\n            return super.loadClass(name, resolve);\n        }\n    }\n}\n"}
