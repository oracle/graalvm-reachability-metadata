          EdECPoint edEcPoint = eddsaPublicKey.getPoint();
          BigInteger yCoordinate = edEcPoint.getY();
  
          // JWK representation "x" of a public key
          int bytesLength = 0;
          if (Algorithm.Ed25519.equals(eddsaPublicKey.getParams().getName())) {
