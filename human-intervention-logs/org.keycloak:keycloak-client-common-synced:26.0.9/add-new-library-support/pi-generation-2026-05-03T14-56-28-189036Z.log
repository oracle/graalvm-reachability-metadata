n    }\n\n    @Test\n    void legacyJdkAdapterInitializationResolvesExpectedCompatibilityMethods() throws Throwable {\n        try {\n            initializeLegacyAdapterInIsolatedClassLoader();\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    private static void initializeLegacyAdapterInIsolatedClassLoader() throws Throwable {\n        Thread thread = Thread.currentThread();\n        ClassLoader originalClassLoader = thread.getContextClassLoader();\n        String originalJavaSpecificationVersion = System.getProperty(\"java.specification.version\");\n        LegacyObjectInputFilterClassLoader legacyClassLoader =\n                new LegacyObjectInputFilterClassLoader(originalClassLoader);\n\n        try (URLClassLoader filterClassLoader = new ChildFirstFilterClassLoader(\n                libraryLocation(), originalClassLoader)) {\n            System.setProperty(\"java.specification.version\", \"1.8\");\n            thread.setContextClassLoader(legacyClassLoader);\n\n            Class<?> filterClass = Class.forName(FILTER_CLASS_NAME, true, filterClassLoader);\n            Object builder = filterClass.getMethod(\"builder\").invoke(null);\n\n            assertThat(filterClass.getClassLoader()).isSameAs(filterClassLoader);\n            assertThat(builder).isNotNull();\n            assertThat(legacyClassLoader.loadedClassNames())\n                    .contains(\"sun.misc.ObjectInputFilter\", \"sun.misc.ObjectInputFilter$Config\");\n        } catch (InvocationTargetException exception) {\n            throw exception.getCause();\n        } finally {\n            restoreJavaSpecificationVersion(originalJavaSpecificationVersion);\n            thread.setContextClassLoader(originalClassLoader);\n        }\n    }\n\n    private static URL libraryLocation() {\n        return DelegatingSerializationFilter.class.getProtectionDomain().getCodeSource().getLocation();\n    }\n\n    private static void restoreJavaSpecificationVersion(String originalJavaSpecificationVersion) {\n        if (originalJavaSpecificationVersion == null) {\n            System.clearProperty(\"java.specification.version\");\n        } else {\n            System.setProperty(\"java.specification.version\", originalJavaSpecificationVersion);\n        }\n    }\n\n    private static byte[] serializedStreamHeader() throws IOException {\n        ByteArrayOutputStream output = new ByteArrayOutputStream();\n        try (ObjectOutputStream objectOutput = new ObjectOutputStream(output)) {\n            objectOutput.flush();\n        }\n        return output.toByteArray();\n    }\n\n    private static final class ChildFirstFilterClassLoader extends URLClassLoader {\n        ChildFirstFilterClassLoader(URL libraryLocation, ClassLoader parent) {\n            super(new URL[] {libraryLocation}, parent);\n        }\n\n        @Override\n        protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {\n            synchronized (getClassLoadingLock(name)) {\n                Class<?> loadedClass = findLoadedClass(name);\n                if (loadedClass == null && name.startsWith(FILTER_CLASS_NAME)) {\n                    loadedClass = findFilterClass(name);\n                }\n                if (loadedClass == null) {\n                    loadedClass = super.loadClass(name, resolve);\n                }\n                if (resolve) {\n                    resolveClass(loadedClass);\n                }\n                return loadedClass;\n            }\n        }\n\n        private Class<?> findFilterClass(String name) throws ClassNotFoundException {\n            try {\n                return findClass(name);\n            } catch (ClassNotFoundException exception) {\n                if (name.equals(FILTER_CLASS_NAME)) {\n                    throw exception;\n                }\n                return null;\n            }\n        }\n    }\n\n    private static final class LegacyObjectInputFilterClassLoader extends ClassLoader {\n        private final Set<String> loadedClassNames = new LinkedHashSet<>();\n\n        LegacyObjectInputFilterClassLoader(ClassLoader parent) {\n            super(parent);\n        }\n\n        @Override\n        protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {\n            if (\"sun.misc.ObjectInputFilter\".equals(name)) {\n                loadedClassNames.add(name);\n                return ObjectInputFilter.class;\n            }\n            if (\"sun.misc.ObjectInputFilter$Config\".equals(name)) {\n                loadedClassNames.add(name);\n                return LegacyObjectInputFilterConfig.class;\n            }\n            return super.loadClass(name, resolve);\n        }\n\n        Set<String> loadedClassNames() {\n            return loadedClassNames;\n        }\n    }\n\n    public static final class LegacyObjectInputFilterConfig {\n        private LegacyObjectInputFilterConfig() {\n        }\n\n        public static Object getObjectInputFilter(ObjectInputStream input) {\n            return input.getObjectInputFilter();\n        }\n\n        public static void setObjectInputFilter(ObjectInputStream input, ObjectInputFilter filter) {\n            input.setObjectInputFilter(filter);\n        }\n\n        public static ObjectInputFilter createFilter(String pattern) {\n            return ObjectInputFilter.Config.createFilter(pattern);\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777820164204}]}
