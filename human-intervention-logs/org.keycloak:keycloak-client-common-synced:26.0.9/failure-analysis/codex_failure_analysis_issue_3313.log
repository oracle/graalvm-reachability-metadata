blicdomain/zero/1.0/>.\\\\n */\\\\npackage org_keycloak.keycloak_client_common_synced;\\\\n\\\\nimport java.lang.reflect.Constructor;\\\\nimport java.lang.reflect.Field;\\\\nimport java.lang.reflect.Method;\\\\nimport java.util.Arrays;\\\\nimport java.util.List;\\\\nimport java.util.Set;\\\\n\\\\nimport org.junit.jupiter.api.Test;\\\\nimport org.keycloak.common.util.reflections.Reflections;\\\\n\\\\nimport static org.assertj.core.api.Assertions.assertThat;\\\\n\\\\npublic class ReflectionsTest {\\\\n    @Test\\\\n    void discoversDeclaredMembersAcrossClassHierarchy() {\\\\n        Set<Field> fields = Reflections.getAllDeclaredFields(ChildTarget.class);\\\\n        Field inheritedField = Reflections.findDeclaredField(ChildTarget.class, \\\\\\\"baseText\\\\\\\");\\\\n        Field localField = Reflections.findDeclaredField(ChildTarget.class, \\\\\\\"localText\\\\\\\");\\\\n\\\\n        assertThat(fields).extracting(Field::getName).contains(\\\\\\\"baseText\\\\\\\", \\\\\\\"localText\\\\\\\");\\\\n        assertThat(inheritedField).isNotNull();\\\\n        assertThat(localField).isNotNull();\\\\n\\\\n        Set<Method> methods = Reflections.getAllDeclaredMethods(ChildTarget.class);\\\\n        Method inheritedMethod = Reflections.findDeclaredMethod(ChildTarget.class, \\\\\\\"greet\\\\\\\", String.class);\\\\n\\\\n        assertThat(methods).extracting(Method::getName).contains(\\\\\\\"greet\\\\\\\", \\\\\\\"localMethod\\\\\\\");\\\\n        assertThat(Reflections.methodExists(ChildTarget.class, \\\\\\\"greet\\\\\\\")).isTrue();\\\\n        assertThat(inheritedMethod).isNotNull();\\\\n\\\\n        Set<Constructor<?>> constructors = Reflections.getAllDeclaredConstructors(ConstructedTarget.class);\\\\n        Constructor<?> stringConstructor = Reflections.findDeclaredConstructor(ConstructedTarget.class, String.class);\\\\n\\\\n        assertThat(constructors).extracting(Constructor::getParameterCount).contains(0, 1);\\\\n        assertThat(stringConstructor).isNotNull();\\\\n    }\\\\n\\\\n    @Test\\\\n    void invokesMethodsAndReadsFieldsThroughReflectionUtility() {\\\\n        ChildTarget target = new ChildTarget();\\\\n        Method greet = Reflections.findDeclaredMethod(ChildTarget.class, \\\\\\\"greet\\\\\\\", String.class);\\\\n        Field baseText = Reflections.findDeclaredField(ChildTarget.class, \\\\\\\"baseText\\\\\\\");\\\\n\\\\n        Reflections.setAccessible(baseText);\\\\n\\\\n        String greeting = Reflections.invokeMethod(greet, String.class, target, \\\\\\\"Keycloak\\\\\\\");\\\\n        String value = Reflections.getFieldValue(baseText, target, String.class);\\\\n\\\\n        assertThat(greeting).isEqualTo(\\\\\\\"hello Keycloak\\\\\\\");\\\\n        assertThat(value).isEqualTo(\\\\\\\"base-value\\\\\\\");\\\\n    }\\\\n\\\\n    @Test\\\\n    void loadsClassesWithContextDefaultAndAdditionalClassLoaders() throws Exception {\\\\n        Thread thread = Thread.currentThread();\\\\n        ClassLoader originalClassLoader = thread.getContextClassLoader();\\\\n        ClassLoader testClassLoader = ReflectionsTest.class.getClassLoader();\\\\n        String loadTargetName = LoadTarget.class.getName();\\\\n\\\\n        try {\\\\n            thread.setContextClassLoader(testClassLoader);\\\\n            assertThat(Reflections.classForName(loadTargetName)).isEqualTo(LoadTarget.class);\\\\n\\\\n            thread.setContextClassLoader(null);\\\\n            assertThat(Reflections.classForName(String.class.getName())).isEqualTo(String.class);\\\\n\\\\n            thread.setContextClassLoader(new RefusingClassLoader(testClassLoader, loadTargetName));\\\\n            assertThat(Reflections.classForName(loadTargetName, testClassLoader)).isEqualTo(LoadTarget.class);\\\\n        } finally {\\\\n            thread.setContextClassLoader(originalClassLoader);\\\\n        }\\\\n    }\\\\n\\\\n    @Test\\\\n    @SuppressWarnings(\\\\\\\"deprecation\\\\\\\")\\\\n    void createsInstancesWithClassLoaderFromSourceType() throws Exception {\\\\n        ConstructedTarget instance = Reflections.newInstance(ConstructedTarget.class);\\\\n\\\\n        assertThat(instance.value).isEqualTo(\\\\\\\"default-value\\\\\\\");\\\\n    }\\\\n\\\\n    @Test\\\\n    void detectsFinalMethodsAndResolvesRawListElementTypes() throws Exception {\\\\n        Object finalMember = Reflections.getNonPrivateFinalMethodOrType(ChildTarget.class);\\\\n        Field rawItems = Reflections.findDeclaredField(ListHolder.class, \\\\\\\"rawItems\\\\\\\");\\\\n        ListHolder holder = new ListHolder(Arrays.asList(\\\\\\\"first\\\\\\\", \\\\\\\"second\\\\\\\"));\\\\n\\\\n        Reflections.setAccessible(rawItems);\\\\n\\\\n        assertThat(finalMember).isInstanceOf(Method.class);\\\\n        assertThat(((Method) finalMember).getName()).isEqualTo(\\\\\\\"finalMethod\\\\\\\");\\\\n        assertThat(Reflections.resolveListType(rawItems, holder)).isEqualTo(String.class);\\\\n    }\\\\n\\\\n    public static class BaseTarget {\\\\n        private final String baseText = \\\\\\\"base-value\\\\\\\";\\\\n\\\\n        public String greet(String name) {\\\\n            return \\\\\\\"hello \\\\\\\" + name;\\\\n        }\\\\n    }\\\\n\\\\n    public static class ChildTarget extends BaseTarget {\\\\n        private final String localText = \\\\\\\"local-value\\\\\\\";\\\\n\\\\n        public String localMethod() {\\\\n            return localText;\\\\n        }\\\\n\\\\n        public final String finalMethod() {\\\\n            return \\\\\\\"final-value\\\\\\\";\\\\n        }\\\\n    }\\\\n\\\\n    public static class ConstructedTarget {\\\\n        private final String value;\\\\n\\\\n        public ConstructedTarget() {\\\\n            this.value = \\\\\\\"default-value\\\\\\\";\\\\n        }\\\\n\\\\n        public ConstructedTarget(String value) {\\\\n            this.value = value;\\\\n        }\\\\n    }\\\\n\\\\n    public static class LoadTarget {\\\\n    }\\\\n\\\\n    public static class ListHolder {\\\\n        @Suppres