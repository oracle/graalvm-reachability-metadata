{\\\\n            thread.setContextClassLoader(DelegatingSerializationFilterTest.class.getClassLoader());\\\\n\\\\n            DelegatingSerializationFilter.builder()\\\\n                    .addAllowedPattern(\\\\\\\"java.lang.*\\\\\\\")\\\\n                    .setFilter(input);\\\\n\\\\n            assertThat(input.getObjectInputFilter()).isNotNull();\\\\n        } finally {\\\\n            thread.setContextClassLoader(originalClassLoader);\\\\n        }\\\\n    }\\\\n\\\\n    @Test\\\\n    void legacyJdkAdapterInitializationResolvesExpectedCompatibilityMethods() throws Throwable {\\\\n        try {\\\\n            initializeLegacyAdapterInIsolatedClassLoader();\\\\n        } catch (Error error) {\\\\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\\\\n                throw error;\\\\n            }\\\\n        }\\\\n    }\\\\n\\\\n    private static void initializeLegacyAdapterInIsolatedClassLoader() throws Throwable {\\\\n        Thread thread = Thread.currentThread();\\\\n        ClassLoader originalClassLoader = thread.getContextClassLoader();\\\\n        String originalJavaSpecificationVersion = System.getProperty(\\\\\\\"java.specification.version\\\\\\\");\\\\n        LegacyObjectInputFilterClassLoader legacyClassLoader = new LegacyObjectInputFilterClassLoader(originalClassLoader);\\\\n\\\\n        try (URLClassLoader filterClassLoader = new ChildFirstFilterClassLoader(libraryLocation(), originalClassLoader)) {\\\\n            System.setProperty(\\\\\\\"java.specification.version\\\\\\\", \\\\\\\"1.8\\\\\\\");\\\\n            thread.setContextClassLoader(legacyClassLoader);\\\\n\\\\n            Class<?> filterClass = Class.forName(FILTER_CLASS_NAME, true, filterClassLoader);\\\\n            Object builder = filterClass.getMethod(\\\\\\\"builder\\\\\\\").invoke(null);\\\\n\\\\n            assertThat(filterClass.getClassLoader()).isSameAs(filterClassLoader);\\\\n            assertThat(builder).isNotNull();\\\\n            assertThat(le