aryVersion\"\n    testImplementation 'com.hazelcast:hazelcast:4.2.8'\n    hazelcastLegacy 'com.hazelcast:hazelcast:3.12.13'\n    testImplementation 'org.assertj:assertj-core:3.22.0'\n}\n\ntasks.withType(Test).configureEach {\n    systemProperty 'hazelcastLegacyClasspath', configurations.hazelcastLegacy.asPath\n}\n"}]}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 2602, "output": 1992, "cacheRead": 48640, "cacheWrite": 0, "totalTokens": 53234, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777692709993, "responseId": "resp_0f8b2de55a1680c70169f5702692c88193a6fbd3deffed0bd1"}}
