  import com.hazelcast.map.IMap;
  import com.hazelcast.monitor.LocalMapStats;
  import com.hazelcast.monitor.NearCacheStats;
  import io.micrometer.core.instrument.binder.cache.HazelcastCacheMetrics;
  import io.micrometer.core.instrument.simple.SimpleMeterRegistry;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class HazelcastIMapAdapterTest {
      @Test
      void bindsMetricsForHazelcastIMap() {
          SimpleMeterRegistry registry = new SimpleMeterRegistry();
          try {
              FakeMap cache = new FakeMap();
  
              Object monitored = HazelcastCacheMetrics.monitor(registry, cache, "cluster", "primary");
  
              assertThat(monitored).isSameAs(cache);
              assertThat(registry.find("cache.size").tag("cache", "test-map").gauge().value()).isEqualTo(7.0);
              assertThat(registry.find("cache.entries").tag("ownership", "backup").gauge().value()).isEqualTo(2.0);
              assertThat(registry.find("cache.near.requests").tag("result", "hit").gauge().value()).isEqualTo(11.0);
          } finally {
              registry.close();
          }
      }
  
      private static final class FakeMap implements IMap {
          private final LocalMapStats stats = new FakeLocalMapStats();
  
          @Override
          public String getName() {
              return "test-map";
          }
  
          @Override
          public LocalMapStats getLocalMapStats() {
              return stats;
          }
      }
  
      private static final class FakeLocalMapStats implements LocalMapStats {
          private final NearCacheStats nearCacheStats = new FakeNearCacheStats();
  
          @Override
          public NearCacheStats getNearCacheStats() {
              return nearCacheStats;
          }
  
          @Override
          public long getOwnedEntryCount() {
              return 7L;
          }
  
          @Override
          public long getHits() {
              return 5L;
          }
  
          @Override
          public long getPutOperationCount() {
              return 3L;
          }
  
          @Override
          public long getBackupEntryCount() {
              return 2L;
          }
  
          @Override
          public long getBackupEntryMemoryCost() {
              return 128L;
          }
  
          @Override
          public long getOwnedEntryMemoryCost() {
              return 256L;
          }
  
          @Override
          public long getGetOperationCount() {
              return 13L;
          }
  
          @Override
          public long getTotalGetLatency() {
              return 21L;
          }
  
          @Override
          public long getTotalPutLatency() {
              return 34L;
          }
  
          @Override
          public long getRemoveOperationCount() {
              return 1L;
          }
  
          @Override
          public long getTotalRemoveLatency() {
              return 8L;
          }
      }
  
      private static final class FakeNearCacheStats implements NearCacheStats {
          @Override
          public long getHits() {
              return 11L;
          }
  
          @Override
          public long getMisses() {
              return 4L;
          }
  
          @Override
          public long getEvictions() {
              return 1L;
          }
  
          @Override
          public long getPersistenceCount() {
              return 6L;
          }
      }
  }
