[tool-call] delta {"path":"tests/src/io.micrometer/micrometer-core/1.8.2/src/test/java/io_micrometer/micrometer_core/HazelcastIMapAdapterTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_micrometer.micrometer_core;\n\nimport com.hazelcast.core.IMap;\nimport com.hazelcast.monitor.LocalMapStats;\nimport com.hazelcast.monitor.NearCacheStats;\nimport io.micrometer.core.instrument.simple.SimpleMeterRegistry;\nimport io.micrometer.core.instrument.binder.cache.HazelcastCacheMetrics;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class HazelcastIMapAdapterTest {\n    @Test\n    void bindsMetricsForHazelcastThreeIMap() {\n        SimpleMeterRegistry registry = new SimpleMeterRegistry();\n        try {\n            FakeMap cache = new FakeMap();\n\n            Object monitored = HazelcastCacheMetrics.monitor(registry, cache, \"cluster\", \"primary\");\n\n            assertThat(monitored).isSameAs(cache);\n            assertThat(registry.find(\"cache.size\").tag(\"cache\", \"test-map\").gauge().value()).isEqualTo(7.0);\n            assertThat(registry.find(\"cache.entries\").tag(\"ownership\", \"backup\").gauge().value()).isEqualTo(2.0);\n            assertThat(registry.find(\"cache.near.requests\").tag(\"result\", \"hit\").gauge().value()).isEqualTo(11.0);\n        } finally {\n            registry.close();\n        }\n    }\n\n    private static final class FakeMap implements IMap {\n        private final LocalMapStats stats = new FakeLocalMapStats();\n\n        @Override\n        public String getName() {\n            return \"test-map\";\n        }\n\n        @Override\n        public LocalMapStats getLocalMapStats() {\n            return stats;\n        }\n    }\n\n    private static final class FakeLocalMapStats implements LocalMapStats {\n        private final NearCacheStats nearCacheStats = new FakeNearCacheStats();\n\n        @Override\n        public NearCacheStats getNearCacheStats() {\n            return nearCacheStats;\n        }\n\n        @Override\n        public long getOwnedEntryCount() {\n            return 7L;\n        }\n\n        @Override\n        public long getHits() {\n            return 5L;\n        }\n\n        @Override\n        public long getPutOperationCount() {\n            return 3L;\n        }\n\n        @Override\n        public long getBackupEntryCount() {\n            return 2L;\n        }\n\n        @Override\n        public long getBackupEntryMemoryCost() {\n            return 128L;\n        }\n\n        @Override\n        public long getOwnedEntryMemoryCost() {\n            return 256L;\n        }\n\n        @Override\n        public long getGetOperationCount() {\n            return 13L;\n        }\n\n        @Override\n        public long getTotalGetLatency() {\n            return 21L;\n        }\n\n        @Override\n        public long getTotalPutLatency() {\n            return 34L;\n        }\n\n        @Override\n        public long getRemoveOperationCount() {\n            return 1L;\n        }\n\n        @Override\n        public long getTotalRemoveLatency() {\n            return 8L;\n        }\n    }\n\n    private static final class FakeNearCacheStats implements NearCacheStats {\n        @Override\n        public long getHits() {\n            return 11L;\n        }\n\n        @Override\n        public long getMisses() {\n            return 4L;\n        }\n\n        @Override\n        public long getEvictions() {\n            return 1L;\n        }\n\n        @Override\n        public long getPersistenceCount() {\n            return 6L;\n        }\n    }\n}\n"}
