              this.value = value;
          }
  
          @Override
          public boolean isValid() {
              return true;
          }
  
          @NonNull
          @Override
          public Iterator<Validated<T>> iterator() {
              return Stream.of((Validated<T>) this).iterator();
          }
  
          @Override
          public T get() {
              return value;
