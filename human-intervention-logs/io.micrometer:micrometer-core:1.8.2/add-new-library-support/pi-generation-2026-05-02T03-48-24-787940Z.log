   * @since 1.5.0
   */
  @Incubating(since = "1.5.0")
  public interface Validated<T> extends Iterable<Validated<T>> {
      boolean isValid();
  
      default boolean isInvalid() {
          return !isValid();
      }
  
      default List<Invalid<?>> failures() {
          return stream(spliterator(), false)
