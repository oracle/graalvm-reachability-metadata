              case "equals":
                  return proxy == args[0];
              case "toString":
                  return CACHE_NAME;
              default:
                  return defaultValue(method.getReturnType());
          }
      }
  
      private static Object handleLocalMapStatsInvocation(Object proxy, Method method, Object[] args) {
          switch (method.getName()) {
              case "getOwnedEntryCount":
