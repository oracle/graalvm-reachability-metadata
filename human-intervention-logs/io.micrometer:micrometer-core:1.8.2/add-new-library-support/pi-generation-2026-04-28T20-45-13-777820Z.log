n:78:    \"interfaces\": [\nmetadata/org.jboss.interceptor/jboss-interceptor-api/index.json:9:    \"description\" : \"This library provides the EJB 3.1 Interceptor API annotations and interfaces in the javax.interceptor package. It defines interceptor bindings, invocation lifecycle annotations, and InvocationContext contracts used by containers and applications to intercept method calls and lifecycle events.\",\ntests/src/org.jooq/jooq/3.17.7/src/test/resources/META-INF/native-image/tests-only/proxy-config.json:6:        \"interfaces\": [\nmetadata/com.google.auth/google-auth-library-credentials/index.json:9:    \"description\" : \"This artifact provides the base classes and interfaces used to represent Google credentials in Java. It supports authorized identities, request metadata callbacks, and service account signing abstractions for authentication flows.\",\nmetadata/javax.servlet/javax.servlet-api/index.json:17:    \"description\" : \"Defines the Java Servlet 3.1 API for handling HTTP requests and responses in Java web applications. It provides the standard interfaces, classes, annotations, and asynchronous processing contracts used by servlet containers and web components.\"\nmetadata/org.eclipse.aether/aether-api/index.json:9:    \"description\" : \"Aether API defines the public interfaces and value types for Eclipse Aether's repository system. It models artifacts, dependencies, repositories, sessions, metadata, transfers, and the requests and results used to collect, install, deploy, and resolve repository content.\",\nmetadata/org.eclipse.aether/aether-spi/index.json:9:    \"description\" : \"Aether SPI defines the service provider interfaces used by Eclipse Aether repository system implementations and repository connectors. It supplies extension contracts for connector layout, metadata generation, local repository management, and version resolution within the artifact repository system.\",\nmetadata/org.codehaus.woodstox/stax2-api/index.json:9:    \"description\" : \"Stax2 API extends the standard StAX API for streaming XML processing with additional reader, writer, validation, and utility interfaces. It provides a common higher-level API for features such as typed access and XML validation used by StAX implementations like Woodstox.\",\nmetadata/aopalliance/aopalliance/index.json:9:    \"description\" : \"AOP Alliance defines a small set of standard Java interfaces for aspect-oriented programming, especially method and constructor interception. Libraries use these interfaces to expose portable advice and interceptor contracts without depending on a particular AOP implementation.\",\nmetadata/org.apache.santuario/xmlsec/4.0.4/reachability-metadata.json:91:      \"type\": \"java.security.interfaces.RSAPrivateKey\"\nmetadata/org.apache.santuario/xmlsec/4.0.4/reachability-metadata.json:97:      \"type\": \"java.security.interfaces.RSAPrivateKey\"\nmetadata/org.apache.santuario/xmlsec/4.0.4/reachability-metadata.json:103:      \"type\": \"java.security.interfaces.RSAPublicKey\"\nmetadata/org.apache.santuario/xmlsec/4.0.4/reachability-metadata.json:109:      \"type\": \"java.security.interfaces.RSAPublicKey\"\nmetadata/javax.jcr/jcr/index.json:9:    \"description\" : \"Defines the Java Content Repository (JCR) 1.0 API for accessing content repositories independently of a specific implementation. It provides the standard javax.jcr interfaces, classes, and exceptions for sessions, workspaces, nodes, properties, queries, observation, locking, and versioning.\",\nmetadata/org.sonatype.aether/aether-api/index.json:9:    \"description\" : \"Aether API defines the core interfaces for artifact resolution and repository access in a Maven-style dependency system. It provides contracts for dependency collection, version resolution, and local or remote repository interactions that implementations execute.\",\nmetadata/org.sonatype.aether/aether-spi/index.json:9:    \"description\" : \"Aether SPI defines service provider interfaces for repository system implementations and repository connectors. It lets implementations plug repository services and connector behavior into the Aether repository system behind its public API.\",\nmetadata/io.netty/netty-common/4.1.80.Final/reachability-metadata.json:4352:      \"type\": \"java.security.interfaces.ECPrivateKey\"\nmetadata/io.netty/netty-common/4.1.80.Final/reachability-metadata.json:4358:      \"type\": \"java.security.interfaces.ECPrivateKey\"\nmetadata/io.netty/netty-common/4.1.80.Final/reachability-metadata.json:4364:      \"type\": \"java.security.interfaces.ECPublicKey\"\nmetadata/io.netty/netty-common/4.1.80.Final/reachability-metadata.json:4370:      \"type\": \"java.security.interfaces.ECPublicKey\"\nmetadata/io.netty/netty-common/4.1.80.Final/reachability-metadata.json:4376:      \"type\": \"java.security.interfaces.RSAPrivateKey\"\nmetadata/io.netty/netty-common/4.1.80.Final/reachability-metadata.json:4382:      \"type\": \"java.security.interfaces.RSAPrivateKey\"\nmetadata/io.netty/netty-common/4.1.80.Final/reachability-metadata.json:4388:      \"type\": \"java.security.interfaces.RSAPublicKey\"\nmetadata/io.netty/netty-common/4.1.80.Final/reachability-metadata.json:4394:      \"type\": \"java.security.interfaces.RSAPublicKey\"\nmetadata/io.netty/netty-common/4.1.115.Final/reachability-metadata.json:4407:      \"type\": \"java.security.interfaces.ECPrivateKey\"\nmetadata/io.netty/netty-common/4.1.115.Final/reachability-metadata.json:4413:      \"type\": \"java.security.interfaces.ECPrivateKey\"\nmetadata/io.netty/netty-common/4.1.115.Final/reachability-metadata.json:4419:      \"type\": \"java.security.interfaces.ECPublicKey\"\nmetadata/io.netty/netty-common/4.1.115.Final/reachability-metadata.json:4425:      \"type\": \"java.security.interfaces.ECPublicKey\"\nmetadata/io.netty/netty-common/4.1.115.Final/reachability-metadata.json:4431:      \"type\": \"java.security.interfaces.RSAPrivateKey\"\nmetadata/io.netty/netty-common/4.1.115.Final/