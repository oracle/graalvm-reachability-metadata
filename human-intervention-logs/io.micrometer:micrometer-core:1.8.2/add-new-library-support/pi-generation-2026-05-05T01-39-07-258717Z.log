              return (Validated<U>) this;
          }
  
          @SuppressWarnings("unchecked")
          @Override
          public <U> Validated<U> flatMap(BiFunction<T, Valid<T>, Validated<U>> mapping) {
              return (Validated<U>) this;
          }
  
          @Override
          public T get() {
              return null;
          }
  
          @Override
