lTo(5.0);\\n        assertThat(registry.find(\\\"cache.entries\\\").tag(\\\"cache\\\", CACHE_NAME).tag(\\\"ownership\\\", \\\"backup\\\").gauge().value())\\n                .isEqualTo(2.0);\\n        assertThat(registry.find(\\\"cache.entry.memory\\\").tag(\\\"cache\\\", CACHE_NAME).tag(\\\"ownership\\\", \\\"owned\\\").gauge().value())\\n                .isEqualTo(256.0);\\n        assertThat(registry.find(\\\"cache.near.requests\\\").tag(\\\"cache\\\", CACHE_NAME).tag(\\\"result\\\", \\\"hit\\\").gauge().value())\\n                .isEqualTo(3.0);\\n        assertThat(registry.find(\\\"cache.near.evictions\\\").tag(\\\"cache\\\", CACHE_NAME).gauge().value()).isEqualTo(1.0);\\n    }\\n\\n    @SuppressWarnings(\\\"unchecked\\\")\\n    private static IMap<String, String> hazelcastMapWithStats() {\\n        LocalMapStats localMapStats = localMapStats();\\n        return (IMap<String, String>) Proxy.newProxyInstance(HazelcastIMapAdapterTest.class.getClassLoader(),\\n                new Class<?>[] { IMap.class }, (proxy, method, args) -> handleIMapInvocation(proxy, method, args, localMapStats));\\n    }\\n\\n    private static Object handleIMapInvocation(Object proxy, Method method, Object[] args, LocalMapStats localMapStats) {\\n        switch (method.getName()) {\\n            case \\\"getName\\\":\\n                return CACHE_NAME;\\n            case \\\"getLocalMapStats\\\":\\n                return localMapStats;\\n            case \\\"hashCode\\\":\\n                return System.identityHashCode(proxy);\\n            case \\\"equals\\\":\\n                return proxy == args[0];\\n            case \\\"toString\\\":\\n                return CACHE_NAME;\\n            default:\\n                return defaultValue(method.getReturnType());\\n        }\\n    }\\n\\n    private static LocalMapStats localMapStats() {\\n        NearCacheStats nearCacheStats = nearCacheStats();\\n        return (LocalMapStats) Proxy.newProxyInstance(HazelcastIMapAdapterTest.class.getClassLoader(),\\n                new Class<?>[] { LocalMapStats.class },\\n                (proxy, method, args) -> handleLocalMapStatsInvocation(proxy, method, args, nearCacheStats));\\n    }\\n\\n    private static Object handleLocalMapStatsInvocation(Object proxy, Method method, Object[] args, NearCacheStats nearCacheStats) {\\n        switch (method.getName()) {\\n            case \\\"getOwnedEntryCount\\\":\\n                return 11L;\\n            case \\\"getHits\\\":\\n                return 7L;\\n            case \\\"getPutOperationCount\\\":\\n                return 5L;\\n            case \\\"getBackupEntryCount\\\":\\n                return 2L;\\n            case \\\"getBackupEntryMemoryCost\\\":\\n                return 128L;\\n            case \\\"getOwnedEntryMemoryCost\\\":\\n                return 256L;\\n            case \\\"getGetOperationCount\\\":\\n                return 9L;\\n            case \\\"getTotalGetLatency\\\":\\n                return 90L;\\n            case \\\"getTotalPutLatency\\\":\\n                return 40L;\\n            case \\\"getRemoveOperationCount\\\":\\n                return 4L;\\n            case \\\"getTotalRemoveLatency\\\":\\n                return 12L;\\n            case \\\"getNearCacheStats\\\":\\n                return nearCacheStats;\\n            case \\\"hashCode\\\":\\n                return System.identityHashCode(proxy);\\n            case \\\"equals\\\":\\n                return proxy == args[0];\\n            case \\\"toString\\\":\\n                return \\\"localMapStats\\\";\\n            default:\\n                return defaultValue(method.getReturnType());\\n        }\\n    }\\n\\n    private static NearCacheStats nearCacheStats() {\\n        return (NearCacheStats) Proxy.newProxyInstance(HazelcastIMapAdapterTest.class.getClassLoader(),\\n                new Class<?>[] { NearCacheStats.class }, HazelcastIMapAdapterTest::handleNearCacheStatsInvocation);\\n    }\\n\\n    private static Object handleNearCacheStatsInvocation(Object proxy, Method method, Object[] args) {\\n        switch (method.getName()) {\\n            case \\\"getHits\\\":\\n                return 3L;\\n            case \\\"getMisses\\\":\\n                return 4L;\\n            case \\\"getEvictions\\\":\\n                return 1L;\\n            case \\\"getPersistenceCount\\\":\\n                return 6L;\\n            case \\\"hashCode\\\":\\n                return System.identityHashCode(proxy);\\n            case \\\"equals\\\":\\n                return proxy == args[0];\\n            case \\\"toString\\\":\\n                return \\\"nearCacheStats\\\";\\n            default:\\n                return defaultValue(method.getReturnType());\\n        }\\n    }\\n\\n    private static Object defaultValue(Class<?> returnType) {\\n        if (!returnType.isPrimitive()) {\\n            return null;\\n        }\\n        if (returnType == boolean.class) {\\n            return false;\\n        }\\n        if (returnType == char.class) {\\n            return '\\\\0';\\n        }\\n        if (returnType == byte.class) {\\n            return (byte) 0;\\n        }\\n        if (returnType == short.class) {\\n            return (short) 0;\\n        }\\n        if (returnType == int.class) {\\n            return 0;\\n        }\\n        if (returnType == long.class) {\\n            return 0L;\\n        }\\n        if (returnType == float.class) {\\n            return 0F;\\n        }\\n        if (returnType == double.class) {\\n            return 0D;\\n        }\\n        return null;\\n    }\\n}\\n\"}}], \"api\": \"openai-responses\", \"provider\": \"OCA\", \"model\": \"gpt-5.5\", \"usage\": {\"input\": 2739, \"output\": 2930, \"cacheRead\": 20992, \"cacheWrite\": 0, \"totalTokens\": 26661, \"cost\": {\"input\": 0, \"output\": 0, \"cacheRead\": 0, \"cacheWrite\": 0, \"total\": 0}}, \"stopReason\": \"toolUse\", \"timestamp\": 1777692107182, \"responseId\": \"resp_0f8b2de55a1680c70169f56dcba1488