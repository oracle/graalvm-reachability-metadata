        val details: Details = failures.collect { case Failure(_,_,_,d) if d != NoDetails => d }.headOption.getOrElse(NoDetails)
  
        (timesMin, timesMax) match {
          case (None,  None) =>
            Matcher.result(successes.size == seq.size, okMessage, koMessage, t, details)
