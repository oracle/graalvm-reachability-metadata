oovy/org/graalvm/internal/tck/harness/TckExtension.java\\\"\",\"aggregated_output\":\"        List<String> parts = splitCoordinates(coordinateFilter);\\n        String versionFilter = parts.get(2);\\n\\n        Set<String> results = new HashSet<>();\\n        loadMatchingIndices(parts.get(0), parts.get(1)).forEach((fullDir, index) -> {\\n            String g = fullDir.getParent().getFileName().toString();\\n            String a = fullDir.getFileName().toString();\\n\\n            for (Map<String, ?> entry : index) {\\n                List<String> tested = (List<String>) entry.get(\\\"tested-versions\\\");\\n                if (tested == null) continue;\\n\\n                tested.stream()\\n                        .filter(v -> versionFilter == null || versionFilter.equals(v))\\n                        .filter(v -> Files.isDirectory(fullDir.resolve(v)))\\n                        .forEach(v -> results.add(g + \\\":\\\" + a + \\\":\\\" + v));\\n            }\\n        });\\n        return new ArrayList<>(results);\\n    }\\n\\n    /**\\n     * Internal helper to load and group index.json files for matching directories.\\n     */\\n    private Map<Path, List<Map<String, ?>>> loadMatchingIndices(String groupId, String artifactId) {\\n        Map<Path, List<Map<String, ?>>> indices = new HashMap<>();\\n        for (String directory : getMatchingMetadataDirs(groupId, artifactId)) {\\n            Path fullDir = metadataRoot().resolve(directory);\\n            Path indexFile = fullDir.resolve(\\\"index.json\\\");\\n\\n            @SuppressWarnings(\\\"unchecked\\\")\\n            List<Map<String, ?>> metadataIndex = (List<Map<String, ?>>) extractJsonFile(indexFile);\\n            if (metadataIndex != null) {\\n                indices.put(fullDir, metadataIndex);\\n            }\\n        }\\n        return indices;\\n    }\\n\\n    /**\\n     * Returns a list of metadata files in a given directory.\\n     *\\n     * @return list of json files contained in it\\n     */\\n    public List<String> getMetadataFileList(Path directory) throws IOException {\\n        try (Stream<Path> paths = Files.walk(directory)) {\\n            return paths\\n                    .filter(Files::isRegularFile)\\n                    .map(p -> p.getFileName().toString())\\n                    .filter(name -> name.endsWith(\\\".json\\\"))\\n                    .collect(Collectors.toList());\\n        }\\n    }\\n}\\n\",\"exit_code\":0,\"status\":\"completed\"}}\n{\"type\":\"item.started\",\"item\":{\"id\":\"item_43\",\"type\":\"command_execution\",\"command\":\"/usr/bin/bash -lc 'rg -n \\\"extractLibraryTestParams\\\" tests/tck-build-logic/src/main/groovy/org.graalvm.internal.tck-harness.gradle tests/tck-build-logic/src/main/groovy/org/graalvm/internal/tck/harness/TckExtension.java tests/tck-build-logic/src/main/groovy/org/graalvm/internal/tck/harness/tasks -S'\",\"aggregated_output\":\"\",\"exit_code\":null,\"status\":\"in_progress\"}}\n{\"type\":\"item.completed\",\"item\":{\"id\":\"item_43\",\"type\":\"command_execution\",\"command\":\"/usr/bin/bash -lc 'rg -n \\\"extractLibraryTestParams\\\" tests/tck-build-logic/src/main/groovy/org.graalvm.internal.tck-harness.gradle tests/tck-build-logic/src/main/groovy/org/graalvm/internal/tck/harness/TckExtension.java tests/tck-build-logic/src/main/groovy/org/graalvm/internal/tck/harness/tasks -S'\",\"aggregated_output\":\"tests/tck-build-logic/src/main/groovy/org.graalvm.internal.tck-harness.gradle:789:// gradle extractLibraryTestParams -Pcoordinates=<group:artifact[:version]>\\ntests/tck-build-logic/src/main/groovy/org.graalvm.internal.tck-harness.gradle:790:tasks.register(\\\"extractLibraryTestParams\\\", DefaultTask) { task ->\\n\",\"exit_code\":0,\"status\":\"completed\"}}\n{\"type\":\"item.started\",\"item\":{\"id\":\"item_44\",\"type\":\"command_execution\",\"command\":\"/usr/bin/bash -lc \\\"sed -n '789,860p' tests/tck-build-logic/src/main/groovy/org.graalvm.internal.tck-harness.gradle\\\"\",\"aggregated_output\"