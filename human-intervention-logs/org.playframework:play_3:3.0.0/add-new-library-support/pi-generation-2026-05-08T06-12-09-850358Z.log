  package org_playframework.play_3
  
  import org.junit.jupiter.api.Assertions.{assertArrayEquals, assertEquals}
  import org.junit.jupiter.api.Test
  import play.libs.{Scala => PlayScala}
  
  class ScalaTest {
    @Test
    def asArrayCreatesTypedJavaArrayFromScalaSeq(): Unit = {
      val values: scala.collection.immutable.Seq[String] = PlayScala.toSeq(java.util.Arrays.asList("one", "two", "three"))
  
      val array: Array[String] = PlayScala.asArray(classOf[String], values)
  
      assertEquals(classOf[Array[String]], array.getClass)
      assertArrayEquals(Array("one", "two", "three"), array)
    }
  }
