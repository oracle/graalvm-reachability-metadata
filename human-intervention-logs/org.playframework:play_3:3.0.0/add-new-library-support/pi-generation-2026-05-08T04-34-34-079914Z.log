sNames: Seq[String] = modules.map(_.getClass.getName)\n\n      assertTrue(moduleClassNames.contains(\"controllers.ModulesConfiguredTestModule\"))\n      assertTrue(moduleClassNames.contains(\"Module\"))\n    }\n\n    @Test\n    def locatesConfiguredModuleThroughEnvironmentClassLoader(): Unit = {\n      val moduleClassName: String = \"controllers.ModulesConfiguredTestModule\"\n      val configuration: Configuration = Configuration(\n        ConfigFactory.parseString(s\"\"\"\n          play.modules.enabled = [\"$moduleClassName\"]\n          play.modules.disabled = [\"Module\"]\n        \"\"\")\n      )\n      val classLoader: RecordingModuleClassLoader = new RecordingModuleClassLoader(getClass.getClassLoader)\n      val environment: Environment = Environment(new File(\".\"), classLoader, Mode.Test)\n\n      val modules: Seq[Any] = Modules.locate(environment, configuration)\n      val moduleClassNames: Seq[String] = modules.map(_.getClass.getName)\n\n      assertTrue(classLoader.requestedClassNames.contains(moduleClassName))\n      assertTrue(moduleClassNames.contains(moduleClassName))\n    }\n  }\n\n  class RecordingModuleClassLoader(parent: ClassLoader) extends ClassLoader(parent) {\n    val requestedClassNames: ListBuffer[String] = ListBuffer.empty[String]\n\n    override def loadClass(name: String): Class[_] = {\n      requestedClassNames += name\n      super.loadClass(name)\n    }\n  }\n}"}]}
