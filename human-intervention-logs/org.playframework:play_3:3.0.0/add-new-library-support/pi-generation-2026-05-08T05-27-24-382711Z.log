[tool-call] delta {"path":"tests/src/org.playframework/play_3/3.0.0/src/test/scala/org_playframework/play_3/EnabledFiltersTest.scala","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_playframework.play_3\n\nimport java.io.File\n\nimport scala.collection.mutable.ListBuffer\nimport scala.reflect.ClassTag\n\nimport com.typesafe.config.ConfigFactory\nimport org.junit.jupiter.api.Assertions.assertSame\nimport org.junit.jupiter.api.Assertions.assertTrue\nimport org.junit.jupiter.api.Test\nimport play.api.Configuration\nimport play.api.Environment\nimport play.api.Mode\nimport play.api.http.EnabledFilters\nimport play.api.inject.BindingKey\nimport play.api.inject.Injector\nimport play.api.mvc.EssentialAction\nimport play.api.mvc.EssentialFilter\n\nclass EnabledFiltersTest {\n  @Test\n  def loadsEnabledFilterClassesThroughEnvironmentClassLoader(): Unit = {\n    val filterClassName: String = classOf[EnabledFiltersIdentityFilter].getName\n    val configuration: Configuration = Configuration(\n      ConfigFactory.parseString(s\"\"\"\n        play.filters.enabled = [\"$filterClassName\"]\n        play.filters.disabled = []\n      \"\"\")\n    )\n    val classLoader: EnabledFiltersRecordingClassLoader = new EnabledFiltersRecordingClassLoader(getClass.getClassLoader)\n    val environment: Environment = Environment(new File(\".\"), classLoader, Mode.Test)\n    val filter: EnabledFiltersIdentityFilter = new EnabledFiltersIdentityFilter\n    val injector: EnabledFiltersRecordingInjector = new EnabledFiltersRecordingInjector(classOf[EnabledFiltersIdentityFilter], filter)\n\n    val enabledFilters: EnabledFilters = new EnabledFilters(environment, configuration, injector)\n\n    assertTrue(classLoader.requestedClassNames.contains(filterClassName))\n    assertTrue(injector.requestedBindingClassNames.contains(filterClassName))\n    assertSame(filter, enabledFilters.filters.head)\n  }\n}\n\nfinal class EnabledFiltersRecordingClassLoader(parent: ClassLoader) extends ClassLoader(parent) {\n  val requestedClassNames: ListBuffer[String] = ListBuffer.empty[String]\n\n  @throws[ClassNotFoundException]\n  override def loadClass(name: String): Class[?] = {\n    requestedClassNames += name\n    super.loadClass(name)\n  }\n}\n\nfinal class EnabledFiltersRecordingInjector(expectedClass: Class[? <: EssentialFilter], filter: EssentialFilter) extends Injector {\n  val requestedBindingClassNames: ListBuffer[String] = ListBuffer.empty[String]\n\n  override def instanceOf[T](using classTag: ClassTag[T]): T = instanceOf(classTag.runtimeClass.asInstanceOf[Class[T]])\n\n  override def instanceOf[T](clazz: Class[T]): T = {\n    if (clazz == expectedClass) {\n      filter.asInstanceOf[T]\n    } else {\n      throw new IllegalArgumentException(s\"Unexpected filter class: ${clazz.getName}\")\n    }\n  }\n\n  override def instanceOf[T](key: BindingKey[T]): T = {\n    requestedBindingClassNames += key.clazz.getName\n    instanceOf(key.clazz)\n  }\n}\n\nfinal class EnabledFiltersIdentityFilter extends EssentialFilter {\n  override def apply(next: EssentialAction): EssentialAction = next\n}\n"}
[tool-call] end id=call_QD97w8YTb3CpGVx2qE33doLL|fc_0c5681154ed6a8170169fd74264690819dbeab292951b09bfa name=write args={"path": "tests/src/org.playframework/play_3/3.0.0/src/test/scala/org_playframework/play_3/EnabledFiltersTest.scala", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_playframework.play_3\n\nimport java.io.File\n\nimport scala.collection.mutable.ListBuffer\nimport scala.reflect.ClassTag\n\nimport com.typesafe.config.ConfigFactory\nimport org.junit.jupiter.api.Assertions.assertSame\nimport org.junit.jupiter.api.Assertions.assertTrue\nimport org.junit.jupiter.api.Test\nimport play.api.Configuration\nimport play.api.Environment\nimport play.api.Mode\nimport play.api.http.EnabledFilters\nimport play.api.inject.BindingKey\nimport play.api.inject.Injector\nimport play.api.mvc.EssentialAction\nimport play.api.mvc.EssentialFilter\n\nclass EnabledFiltersTest {\n  @Test\n  def loadsEnabledFilterClassesThroughEnvironmentClassLoader(): Unit = {\n    val filterClassName: String = classOf[EnabledFiltersIdentityFilter].getName\n    val configuration: Configuration = Configuration(\n      ConfigFactory.parseString(s\"\"\"\n        play.filters.enabled = [\"$filterClassName\"]\n        play.filters.disabled = []\n      \"\"\")\n    )\n    val classLoader: EnabledFiltersRecordingClassLoader = new EnabledFiltersRecordingClassLoader(getClass.getClassLoader)\n    val environment: Environment = Environment(new File(\".\"), classLoader, Mode.Test)\n    val filter: EnabledFiltersIdentityFilter = new EnabledFiltersIdentityFilter\n    val injector: EnabledFiltersRecordingInjector = new EnabledFiltersRecordingInjector(classOf[EnabledFiltersIdentityFilter], filter)\n\n    val enabledFilters: EnabledFilters = new EnabledFilters(environment, configuration, injector)\n\n    assertTrue(classLoader.requestedClassNames.contains(filterClassName))\n    assertTrue(injector.requestedBindingClassNames.contains(filterClassName))\n    assertSame(filter, enabledFilters.filters.head)\n  }\n}\n\nfinal class EnabledFiltersRecordingClassLoader(parent: ClassLoader) extends ClassLoader(parent) {\n  val requestedClassNames: ListBuffer[String] = ListBuffer.empty[String]\n\n  @throws[ClassNotFoundException]\n  override def loadClass(name: String): Class[?] = {\n    requestedClassNames += name\n    super.loadClass(name)\n  }\n}\n\nfinal class EnabledFiltersRecordingInjector(expectedClass: Class[? <: EssentialFilter], filter: EssentialFilter) extends Injector {\n  val requestedBindingClassNames: ListBuffer[String] = ListBuffer.empty[String]\n\n  override def instanceOf[T](using classTag: ClassTag[T]): T = instanceOf(classTag.runtimeClass.asInstanceOf[Class[T]])\n\n  override def instanceOf[T](clazz: Class[T]): T = {\n    if (clazz == expectedClass) {\n      filter.asInstanceOf[T]\n    } else {\n      throw new IllegalArgumentException(s\"Unexpected filter class: ${clazz.getName}\")\n    }\n  }\n\n  override def instanceOf[T](key: BindingKey[T]): T = {\n    requestedBindingClassNames += key.clazz.getName\n    instanceOf(key.clazz)\n  }\n}\n\nfinal class EnabledFiltersIdentityFilter extends EssentialFilter {\n  override def apply(next: EssentialAction): EssentialAction = next\n}\n"}
