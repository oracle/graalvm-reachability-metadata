  class Module
  
  package org_playframework.play_3 {
    import java.io.File
  
    import com.typesafe.config.ConfigFactory
    import org.junit.jupiter.api.Assertions.assertTrue
    import org.junit.jupiter.api.Test
    import play.api.Configuration
    import play.api.Environment
    import play.api.Mode
    import play.api.inject.Modules
    import scala.collection.mutable.ListBuffer
  
    class ModulesTest {
      @Test
      def locatesConfiguredAndDefaultModulesWithApplicationClassLoader(): Unit = {
        val configuration: Configuration = Configuration(
          ConfigFactory.parseString("""
            play.modules.enabled = ["controllers.ModulesLocateConfiguredModule"]
          """)
        )
        val environment: Environment = Environment(new File("."), getClass.getClassLoader, Mode.Test)
  
        val modules: Seq[Any] = Modules.locate(environment, configuration)
        val moduleClassNames: Seq[String] = modules.map(_.getClass.getName)
  
        assertTrue(moduleClassNames.contains("controllers.ModulesLocateConfiguredModule"))
        assertTrue(moduleClassNames.contains("Module"))
      }
  
      @Test
      def locatesConfiguredModuleThroughEnvironmentClassLoader(): Unit = {
        val moduleClassName: String = "controllers.ModulesLocateConfiguredModule"
        val configuration: Configuration = Configuration(
          ConfigFactory.parseString(s"""
            play.modules.enabled = ["$moduleClassName"]
            play.modules.disabled = ["Module"]
          """)
        )
        val classLoader: RecordingModuleClassLoader = new RecordingModuleClassLoader(getClass.getClassLoader)
        val environment: Environment = Environment(new File("."), classLoader, Mode.Test)
  
        val modules: Seq[Any] = Modules.locate(environment, configuration)
        val moduleClassNames: Seq[String] = modules.map(_.getClass.getName)
  
        assertTrue(classLoader.requestedClassNames.contains(moduleClassName))
        assertTrue(moduleClassNames.contains(moduleClassName))
      }
    }
  
    class RecordingModuleClassLoader(parent: ClassLoader) extends ClassLoader(parent) {
      val requestedClassNames: ListBuffer[String] = ListBuffer.empty[String]
  
      @throws[ClassNotFoundException]
      override def loadClass(name: String): Class[_] = {
        requestedClassNames += name
        super.loadClass(name)
      }
    }
  }
