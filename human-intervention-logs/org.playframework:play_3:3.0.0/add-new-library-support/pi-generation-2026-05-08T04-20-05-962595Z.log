[tool-call] delta {"path":"tests/src/org.playframework/play_3/3.0.0/src/test/scala/models/PathBindableAnonymous12Test.scala","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage models\n\nimport org.junit.jupiter.api.Assertions.{assertEquals, fail}\nimport org.junit.jupiter.api.Test\nimport play.api.mvc.PathBindable\nimport play.mvc.{PathBindable => JavaPathBindable}\n\nclass PathBindableAnonymous12Test {\n  @Test\n  def bindsJavaPathBindableWithNoArgumentConstructor(): Unit = {\n    val binder: PathBindable[JavaPathBoundValue] = PathBindable.javaPathBindable[JavaPathBoundValue]\n\n    binder.bind(\"item\", \"alpha\") match {\n      case Right(value) =>\n        assertEquals(\"item\", value.boundKey)\n        assertEquals(\"alpha\", value.boundText)\n      case Left(error) =>\n        fail(s\"Expected a successfully bound value, but binding failed with: $error\")\n    }\n  }\n\n  @Test\n  def obtainsJavascriptUnbindFromJavaPathBindableInstance(): Unit = {\n    val binder: PathBindable[JavaPathBoundValue] = PathBindable.javaPathBindable[JavaPathBoundValue]\n\n    assertEquals(\"function(k,v){return v.boundText}\", binder.javascriptUnbind)\n  }\n}\n\nclass JavaPathBoundValue extends JavaPathBindable[JavaPathBoundValue] {\n  var boundKey: String = \"\"\n  var boundText: String = \"\"\n\n  override def bind(key: String, txt: String): JavaPathBoundValue = {\n    val value: JavaPathBoundValue = new JavaPathBoundValue()\n    value.boundKey = key\n    value.boundText = txt\n    value\n  }\n\n  override def unbind(key: String): String = s\"$key:$boundKey:$boundText\"\n\n  override def javascriptUnbind(): String = \"function(k,v){return v.boundText}\"\n}\n"}
[tool-call] end id=call_gJ6L7aXSdyeDIBrcpIfUQAgH|fc_05e8327f20ca3c6e0169fd64681a5c819fbed6816fb6a39bbb name=write args={"path": "tests/src/org.playframework/play_3/3.0.0/src/test/scala/models/PathBindableAnonymous12Test.scala", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage models\n\nimport org.junit.jupiter.api.Assertions.{assertEquals, fail}\nimport org.junit.jupiter.api.Test\nimport play.api.mvc.PathBindable\nimport play.mvc.{PathBindable => JavaPathBindable}\n\nclass PathBindableAnonymous12Test {\n  @Test\n  def bindsJavaPathBindableWithNoArgumentConstructor(): Unit = {\n    val binder: PathBindable[JavaPathBoundValue] = PathBindable.javaPathBindable[JavaPathBoundValue]\n\n    binder.bind(\"item\", \"alpha\") match {\n      case Right(value) =>\n        assertEquals(\"item\", value.boundKey)\n        assertEquals(\"alpha\", value.boundText)\n      case Left(error) =>\n        fail(s\"Expected a successfully bound value, but binding failed with: $error\")\n    }\n  }\n\n  @Test\n  def obtainsJavascriptUnbindFromJavaPathBindableInstance(): Unit = {\n    val binder: PathBindable[JavaPathBoundValue] = PathBindable.javaPathBindable[JavaPathBoundValue]\n\n    assertEquals(\"function(k,v){return v.boundText}\", binder.javascriptUnbind)\n  }\n}\n\nclass JavaPathBoundValue extends JavaPathBindable[JavaPathBoundValue] {\n  var boundKey: String = \"\"\n  var boundText: String = \"\"\n\n  override def bind(key: String, txt: String): JavaPathBoundValue = {\n    val value: JavaPathBoundValue = new JavaPathBoundValue()\n    value.boundKey = key\n    value.boundText = txt\n    value\n  }\n\n  override def unbind(key: String): String = s\"$key:$boundKey:$boundText\"\n\n  override def javascriptUnbind(): String = \"function(k,v){return v.boundText}\"\n}\n"}
