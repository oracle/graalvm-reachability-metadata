   */
  @implicitNotFound(
    "No JavaScript literal binder found for type ${A}. Try to implement an implicit JavascriptLiteral for this type."
  )
  trait JavascriptLiteral[A] {
  
    /**
     * Convert a value of A to a JavaScript literal.
     */
    def to(value: A): String
  }
  
