  package org_playframework.play_3
  
  import scala.concurrent.ExecutionContext
  
  import org.junit.jupiter.api.Assertions.assertInstanceOf
  import org.junit.jupiter.api.Test
  import play.api.http.HttpConfiguration
  import play.api.routing.HandlerDef
  import play.core.j.{JavaContextComponents, JavaHandler, JavaHandlerComponents}
  import play.core.routing.HandlerInvokerFactory
  import play.http.ActionCreator
  import play.mvc.{Action => JAction, BodyParser => JBodyParser, Results}
  
  class HandlerInvokerFactoryTest {
    @Test
    def createsJavaActionForFullyQualifiedControllerClass(): Unit = {
      val handlerDef: HandlerDef = javaHandlerDef(
        routerPackage = "",
        controller = "controllers.HandlerInvokerFactoryDirectController"
      )
  
      val handler: JavaHandler = HandlerInvokerFactory.wrapJava
        .createInvoker(Results.ok("unused"), handlerDef)
        .call(Results.ok("direct"))
        .asInstanceOf[JavaHandler]
  
      assertInstanceOf(classOf[play.core.j.JavaAction], handler.withComponents(new MinimalJavaHandlerComponents))
    }
  
    @Test
    def createsJavaActionForControllerRelativeToRouterPackage(): Unit = {
      val handlerDef: HandlerDef = javaHandlerDef(
        routerPackage = "controllers",
        controller = "HandlerInvokerFactoryRelativeController"
      )
  
      val handler: JavaHandler = HandlerInvokerFactory.wrapJava
        .createInvoker(Results.ok("unused"), handlerDef)
        .call(Results.ok("relative"))
        .asInstanceOf[JavaHandler]
  
      assertInstanceOf(classOf[play.core.j.JavaAction], handler.withComponents(new MinimalJavaHandlerComponents))
    }
  
    private def javaHandlerDef(routerPackage: String, controller: String): HandlerDef = {
      HandlerDef(
        classLoader = getClass.getClassLoader,
        routerPackage = routerPackage,
        controller = controller,
        method = "index",
        parameterTypes = Seq.empty[Class[_]],
        verb = "GET",
        path = "/handler-invoker-factory-test"
      )
    }
  }
  
  class MinimalJavaHandlerComponents extends JavaHandlerComponents {
    override def getBodyParser[A <: JBodyParser[_]](parserClass: Class[A]): A = {
      new JBodyParser.Empty().asInstanceOf[A]
    }
  
    override def getAction[A <: JAction[_]](actionClass: Class[A]): A = {
      throw new UnsupportedOperationException("Action mixins are not used by this test")
    }
  
    override def actionCreator: ActionCreator = { (_, _) =>
      throw new UnsupportedOperationException("The action is not invoked by this test")
    }
  
    override def httpConfiguration: HttpConfiguration = HttpConfiguration()
  
    override def executionContext: ExecutionContext = ExecutionContext.global
  
    override def contextComponents: JavaContextComponents = null
  }
