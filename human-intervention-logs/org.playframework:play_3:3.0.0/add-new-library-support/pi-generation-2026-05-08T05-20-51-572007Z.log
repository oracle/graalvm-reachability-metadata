  import play.api.inject.NewInstanceInjector
  
  class NewInstanceInjectorTest {
    @Test
    def createsInstanceUsingNoArgConstructor(): Unit = {
      val instance: NewInstanceInjectable = NewInstanceInjector.instanceOf(classOf[NewInstanceInjectable])
  
      assertInstanceOf(classOf[NewInstanceInjectable], instance)
      assertEquals("created", instance.value)
