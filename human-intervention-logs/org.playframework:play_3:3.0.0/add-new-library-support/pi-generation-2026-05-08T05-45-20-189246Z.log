          clockSkew = 5 minutes
  
          # The claim key under which all user data is stored in the JWT.
          dataClaim = "data"
        }
      }
      # #session-configuration
  
      # Flash configuration
      flash = {
        # The cookie name
        cookieName = "PLAY_FLASH"
  
        # Whether the flash cookie should be secure or not
        secure = false
  
