  package org_playframework.play_3
  
  import java.io.File
  
  import com.typesafe.config.ConfigFactory
  import org.junit.jupiter.api.Assertions.{assertInstanceOf, assertNotNull}
  import org.junit.jupiter.api.Test
  import play.api.{Application, Configuration, Environment, Mode}
  import play.api.inject.DefaultApplicationLifecycle
  import play.api.{ApplicationLoader => ScalaApplicationLoader}
  import scala.Option
  
  class ApplicationLoaderTest {
    @Test
    def instantiatesConfiguredScalaApplicationLoader(): Unit = {
      val loader: ScalaApplicationLoader = ScalaApplicationLoader(contextFor("org_playframework.play_3.TestScalaApplicationLoader"))
  
      assertInstanceOf(classOf[TestScalaApplicationLoader], loader)
    }
  
    @Test
    def instantiatesConfiguredJavaApplicationLoaderAndReturnsScalaAdapter(): Unit = {
      val loader: ScalaApplicationLoader = ScalaApplicationLoader(contextFor("org_playframework.play_3.TestJavaApplicationLoader"))
  
      assertNotNull(loader)
    }
  
    private def contextFor(loaderClassName: String): ScalaApplicationLoader.Context = {
      val configuration: Configuration = Configuration(
        ConfigFactory.parseString(s"play.application.loader = \"$loaderClassName\"")
      )
      val environment: Environment = Environment(new File("."), getClass.getClassLoader, Mode.Test)
  
      ScalaApplicationLoader.Context(
        environment,
        configuration,
        new DefaultApplicationLifecycle(),
        Option.empty[ScalaApplicationLoader.DevContext]
      )
    }
  }
  
  class TestScalaApplicationLoader extends ScalaApplicationLoader {
    override def load(context: ScalaApplicationLoader.Context): Application = {
      throw new UnsupportedOperationException("This test only verifies configured Scala loader instantiation")
    }
  }
  
  class TestJavaApplicationLoader extends play.ApplicationLoader {
    override def load(context: play.ApplicationLoader.Context): play.Application = {
      throw new UnsupportedOperationException("This test only verifies configured Java loader instantiation")
    }
  }
