          logger.warn("application.langs is deprecated, use play.i18n.langs instead")
          langsStr.split(",").map(_.trim).toSeq
        }
        .getOrElse(config.get[Seq[String]]("play.i18n.langs"))
  
      langs.map { lang =>
        try {
          Lang(lang)
        } catch {
  
