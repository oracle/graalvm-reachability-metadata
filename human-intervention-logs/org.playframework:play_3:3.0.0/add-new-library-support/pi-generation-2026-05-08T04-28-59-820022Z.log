  package org_playframework.play_3
  
  import java.lang.reflect.Method
  
  import org.junit.jupiter.api.Assertions.{assertEquals, assertNotNull}
  import org.junit.jupiter.api.Test
  import play.libs.reflect.MethodUtils
  
  class MethodUtilsTest {
    @Test
    def getAccessibleMethodFindsPublicMethodDeclaredOnImplementedInterface(): Unit = {
      val target: MethodUtilsAccessTargets.Greeting = MethodUtilsAccessTargets.greeting()
      val implementationMethod: Method = target.getClass.getMethod("greet", classOf[String])
  
      val accessibleMethod: Method = MethodUtils.getAccessibleMethod(implementationMethod)
  
      assertNotNull(accessibleMethod)
      assertEquals(classOf[MethodUtilsAccessTargets.Greeting], accessibleMethod.getDeclaringClass)
      assertEquals("hello play", accessibleMethod.invoke(target, "play"))
    }
  
    @Test
    def getAccessibleMethodFindsPublicMethodDeclaredOnSuperclass(): Unit = {
      val target: MethodUtilsAccessTargets.Base = MethodUtilsAccessTargets.overrideTarget()
      val implementationMethod: Method = target.getClass.getMethod("inheritedEcho", classOf[String])
  
      val accessibleMethod: Method = MethodUtils.getAccessibleMethod(implementationMethod)
  
      assertNotNull(accessibleMethod)
      assertEquals(classOf[MethodUtilsAccessTargets.Base], accessibleMethod.getDeclaringClass)
      assertEquals("child:play", accessibleMethod.invoke(target, "play"))
    }
  
    @Test
    def getMatchingAccessibleMethodUsesDirectPublicLookupWhenSignatureMatches(): Unit = {
      val method: Method = MethodUtils.getMatchingAccessibleMethod(
        classOf[MethodUtilsExactTarget],
        "echo",
        classOf[String]
      )
  
      assertNotNull(method)
      assertEquals(classOf[MethodUtilsExactTarget], method.getDeclaringClass)
      assertEquals(classOf[String], method.getParameterTypes()(0))
    }
  
    @Test
    def getMatchingAccessibleMethodScansPublicMethodsForAssignableParameters(): Unit = {
      val method: Method = MethodUtils.getMatchingAccessibleMethod(
        classOf[MethodUtilsCompatibleTarget],
        "describe",
        classOf[String]
      )
  
      assertNotNull(method)
      assertEquals(classOf[MethodUtilsCompatibleTarget], method.getDeclaringClass)
      assertEquals(classOf[CharSequence], method.getParameterTypes()(0))
    }
  }
  
  class MethodUtilsExactTarget {
    def echo(value: String): String = s"echo:$value"
  }
  
  class MethodUtilsCompatibleTarget {
    def describe(value: CharSequence): String = s"chars:$value"
  }
