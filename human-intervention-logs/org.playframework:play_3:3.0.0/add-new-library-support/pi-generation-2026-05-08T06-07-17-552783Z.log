[tool-call] delta {"path":"tests/src/org.playframework/play_3/3.0.0/src/test/scala/org_playframework/play_3/ResultsInnerStatusTest.scala","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_playframework.play_3\n\nimport scala.concurrent.ExecutionContext\n\nimport org.junit.jupiter.api.Assertions.assertEquals\nimport org.junit.jupiter.api.Assertions.assertTrue\nimport org.junit.jupiter.api.Test\nimport play.api.http.FileMimeTypes\nimport play.api.http.HeaderNames.CONTENT_DISPOSITION\nimport play.api.http.Status.OK\nimport play.api.mvc.Result\nimport play.api.mvc.Results\n\nclass ResultsInnerStatusTest {\n  @Test\n  def sendsClasspathResourceThroughScalaStatusResult(): Unit = {\n    implicit val executionContext: ExecutionContext = ExecutionContext.parasitic\n    implicit val fileMimeTypes: FileMimeTypes = new FileMimeTypes {\n      override def forFileName(name: String): Option[String] =\n        Option.when(name.endsWith(\".txt\"))(\"text/plain\")\n    }\n    val resourceName: String = \"org_playframework/play_3/results-status-resource.txt\"\n    val classLoader: ClassLoader = Thread.currentThread().getContextClassLoader\n\n    val result: Result = Results.Ok.sendResource(\n      resourceName,\n      classLoader,\n      inline = false\n    )\n\n    assertEquals(OK, result.header.status)\n    assertEquals(Some(\"text/plain\"), result.body.contentType)\n    assertTrue(result.body.contentLength.exists(_ > 0L))\n    val contentDisposition: String = result.header.headers(CONTENT_DISPOSITION)\n    assertTrue(contentDisposition.contains(\"attachment\"))\n    assertTrue(contentDisposition.contains(\"results-status-resource.txt\"))\n  }\n}\n"}
