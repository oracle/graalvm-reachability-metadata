  package models
  
  import org.junit.jupiter.api.Assertions.{assertEquals, fail}
  import org.junit.jupiter.api.Test
  import play.api.mvc.PathBindable
  import play.mvc.{PathBindable => JavaPathBindable}
  
  class PathBindableAnonymous12Test {
    @Test
    def bindsJavaPathBindableWithNoArgumentConstructor(): Unit = {
      val binder: PathBindable[JavaPathBoundValue] = PathBindable.javaPathBindable[JavaPathBoundValue]
  
      binder.bind("item", "alpha") match {
        case Right(value) =>
          assertEquals("item", value.boundKey)
          assertEquals("alpha", value.boundText)
        case Left(error) =>
          fail(s"Expected a successfully bound value, but binding failed with: $error")
      }
    }
  
    @Test
    def obtainsJavascriptUnbindFromJavaPathBindableInstance(): Unit = {
      val binder: PathBindable[JavaPathBoundValue] = PathBindable.javaPathBindable[JavaPathBoundValue]
  
      assertEquals("function(k,v){return v.boundText}", binder.javascriptUnbind)
    }
  }
  
  class JavaPathBoundValue extends JavaPathBindable[JavaPathBoundValue] {
    var boundKey: String = ""
    var boundText: String = ""
  
    override def bind(key: String, txt: String): JavaPathBoundValue = {
      val value: JavaPathBoundValue = new JavaPathBoundValue()
      value.boundKey = key
      value.boundText = txt
      value
    }
  
    override def unbind(key: String): String = s"$key:$boundKey:$boundText"
  
    override def javascriptUnbind(): String = "function(k,v){return v.boundText}"
  }
