[tool-call] delta {"path":"tests/src/org.playframework/play_3/3.0.0/src/test/scala/models/QueryStringBindableAnonymous11Test.scala","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage models\n\nimport java.util.{Map => JMap, Optional}\n\nimport org.junit.jupiter.api.Assertions.{assertEquals, fail}\nimport org.junit.jupiter.api.Test\nimport play.api.mvc.QueryStringBindable\nimport play.mvc.{QueryStringBindable => JavaQueryStringBindable}\n\nclass QueryStringBindableAnonymous11Test {\n  @Test\n  def bindsJavaQueryStringBindableWithNoArgumentConstructor(): Unit = {\n    val binder: QueryStringBindable[JavaQueryStringBoundValue] =\n      QueryStringBindable.javaQueryStringBindable[JavaQueryStringBoundValue]\n\n    binder.bind(\"item\", Map(\"item.name\" -> Seq(\"play\"), \"item.count\" -> Seq(\"3\"))) match {\n      case Some(Right(value)) =>\n        assertEquals(\"item\", value.boundKey)\n        assertEquals(\"play\", value.name)\n        assertEquals(3, value.count)\n      case Some(Left(error)) =>\n        fail(s\"Expected a successfully bound value, but binding failed with: $error\")\n      case None =>\n        fail(\"Expected query string data to bind to a value\")\n    }\n  }\n\n  @Test\n  def obtainsJavascriptUnbindFromJavaQueryStringBindableInstance(): Unit = {\n    val binder: QueryStringBindable[JavaQueryStringBoundValue] =\n      QueryStringBindable.javaQueryStringBindable[JavaQueryStringBoundValue]\n\n    assertEquals(\"function(k,v){return k + '=' + v.name + ':' + v.count}\", binder.javascriptUnbind)\n  }\n}\n\nclass JavaQueryStringBoundValue extends JavaQueryStringBindable[JavaQueryStringBoundValue] {\n  var boundKey: String = \"\"\n  var name: String = \"\"\n  var count: Int = 0\n\n  override def bind(key: String, data: JMap[String, Array[String]]): Optional[JavaQueryStringBoundValue] = {\n    if (!data.containsKey(s\"$key.name\") || !data.containsKey(s\"$key.count\")) {\n      Optional.empty[JavaQueryStringBoundValue]()\n    } else {\n      val value: JavaQueryStringBoundValue = new JavaQueryStringBoundValue()\n      value.boundKey = key\n      value.name = data.get(s\"$key.name\")(0)\n      value.count = data.get(s\"$key.count\")(0).toInt\n      Optional.of(value)\n    }\n  }\n\n  override def unbind(key: String): String = s\"$key.name=$name&$key.count=$count\"\n\n  override def javascriptUnbind(): String = \"function(k,v){return k + '=' + v.name + ':' + v.count}\"\n}\n"}
