    import play.api.Configuration
    import play.api.Environment
    import play.api.LoggerConfigurator
    import play.api.Mode
  
    class TestLoggerConfigurator extends LoggerConfigurator {
      override def init(rootPath: File, mode: Mode): Unit = ()
  
      override def configure(env: Environment): Unit = ()
  
      override def configure(
          env: Environment,
          configuration: Configuration,
          optionalProperties: Map[String, String]
      ): Unit = ()
  
      override def configure(properties: Map[String, String], config: Option[URL]): Unit = ()
  
      override def loggerFactory: ILoggerFactory = LoggerFactory.getILoggerFactory
  
      override def shutdown(): Unit = ()
    }
  }
  
  package org_playframework.play_3 {
    import controllers.TestLoggerConfigurator
    import org.junit.jupiter.api.Assertions.{assertInstanceOf, assertTrue}
    import org.junit.jupiter.api.Test
    import play.api.LoggerConfigurator
  
    class LoggerConfiguratorTest {
      @Test
      def instantiatesConfiguredLoggerConfiguratorClass(): Unit = {
        val classLoader: ClassLoader = Thread.currentThread().getContextClassLoader
        val configurator: Option[LoggerConfigurator] = LoggerConfigurator(
          "controllers.TestLoggerConfigurator",
          classLoader
        )
  
        assertTrue(configurator.isDefined)
        assertInstanceOf(classOf[TestLoggerConfigurator], configurator.get)
      }
  
      @Test
      def discoversLoggerConfiguratorFromClasspathResource(): Unit = {
        val classLoader: ClassLoader = Thread.currentThread().getContextClassLoader
        val configurator: Option[LoggerConfigurator] = LoggerConfigurator(classLoader)
  
        assertTrue(configurator.isDefined)
        assertInstanceOf(classOf[TestLoggerConfigurator], configurator.get)
      }
    }
  }
