[tool-call] delta {"path":"tests/src/org.playframework/play_3/3.0.0/src/test/scala/org_playframework/play_3/StatusHeaderTest.scala","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_playframework.play_3\n\nimport java.util.Optional\nimport java.util.concurrent.TimeUnit\n\nimport org.apache.pekko.actor.ActorSystem\nimport org.apache.pekko.stream.Materializer\nimport org.apache.pekko.stream.SystemMaterializer\nimport org.apache.pekko.util.ByteString\nimport org.junit.jupiter.api.Assertions.assertEquals\nimport org.junit.jupiter.api.Assertions.assertTrue\nimport org.junit.jupiter.api.Test\nimport play.mvc.Http.Status.OK\nimport play.mvc.Result\nimport play.mvc.Results\n\nclass StatusHeaderTest {\n  @Test\n  def sendsClasspathResourceThroughJavaStatusHeader(): Unit = {\n    val actorSystem: ActorSystem = ActorSystem.create(\"status-header-test\")\n    try {\n      val materializer: Materializer = SystemMaterializer.get(actorSystem).materializer()\n      val resourceName: String = \"org_playframework/play_3/results-status-resource.txt\"\n      val classLoader: ClassLoader = Thread.currentThread().getContextClassLoader\n\n      val result: Result = Results.ok().sendResource(\n        resourceName,\n        classLoader,\n        false,\n        Optional.of(\"status-header-resource.txt\")\n      )\n      val bytes: ByteString = result.body().consumeData(materializer).toCompletableFuture.get(10L, TimeUnit.SECONDS)\n\n      assertEquals(OK, result.status())\n      assertEquals(Optional.of(\"text/plain\"), result.contentType())\n      assertEquals(\"Results.Status.sendResource test resource\\n\", bytes.utf8String)\n      val contentDisposition: String = result.header(\"Content-Disposition\").orElseThrow()\n      assertTrue(contentDisposition.contains(\"attachment\"))\n      assertTrue(contentDisposition.contains(\"status-header-resource.txt\"))\n    } finally {\n      actorSystem.terminate()\n      actorSystem.getWhenTerminated.toCompletableFuture.get(10L, TimeUnit.SECONDS)\n    }\n  }\n}\n"}
