ef detectsBundleResourceDirectoryUsingClassLoaderResources(): Unit = {\n    val resourcePath: String = \"org_playframework/play_3/bundle-resource-directory\"\n    val classLoader: RecordingResourceClassLoader = new RecordingResourceClassLoader(resourcePath)\n    val url: URL = bundleUrl(resourcePath)\n\n    val isDirectory: Boolean = Resources.isDirectory(classLoader, url)\n\n    assertTrue(isDirectory)\n    assertEquals(Seq(resourcePath, s\"$resourcePath/\"), classLoader.requestedResourceNames)\n  }\n\n  private def bundleUrl(path: String): URL = {\n    new URL(null, s\"bundle:$path\", new FixedPathUrlStreamHandler(\"bundle\", path))\n  }\n}\n\nfinal class RecordingResourceClassLoader(private val directoryPath: String) extends ClassLoader(null) {\n  private val requestedNames = scala.collection.mutable.ArrayBuffer.empty[String]\n\n  override def getResource(name: String): URL = {\n    requestedNames += name\n    if (name == directoryPath || name == s\"$directoryPath/\") {\n      new URL(\"file\", \"\", s\"/virtual/$name\")\n    } else {\n      null\n    }\n  }\n\n  def requestedResourceNames: Seq[String] = requestedNames.toSeq\n}\n\nfinal class FixedPathUrlStreamHandler(private val protocolName: String, private val fixedPath: String) extends URLStreamHandler {\n  override protected def parseURL(url: URL, spec: String, start: Int, limit: Int): Unit = {\n    setURL(url, protocolName, \"\", -1, null, null, fixedPath, null, null)\n  }\n\n  override protected def openConnection(url: URL): URLConnection = new URLConnection(url) {\n    override def connect(): Unit = ()\n  }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 3057, "output": 1473, "cacheRead": 12288, "cacheWrite": 0, "totalTokens": 16818, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778221411526, "responseId": "resp_0fa0b504ce9b41530169fd8164717081979c7cbc7907f4a4e4"}, "toolResults": [{"rol