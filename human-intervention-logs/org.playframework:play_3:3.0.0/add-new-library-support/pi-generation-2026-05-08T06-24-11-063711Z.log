String, private val fixedPath: String) extends URLStreamHandler {\n  override protected def parseURL(url: URL, spec: String, start: Int, limit: Int): Unit = {\n    setURL(url, protocolName, \"\", -1, null, null, fixedPath, null, null)\n  }\n\n  override protected def openConnection(url: URL): URLConnection = new URLConnection(url) {\n    override def connect(): Unit = ()\n  }\n}\n"}
