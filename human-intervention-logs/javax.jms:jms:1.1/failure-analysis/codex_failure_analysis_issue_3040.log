 for (MetadataVersionsIndexEntry entry : entries) {\n            if (newVersion.equals(entry.metadataVersion())) {\n                return;\n            }\n            List<String> tv = entry.testedVersions();\n            if (tv != null && tv.contains(newVersion)) {\n                return;\n            }\n","exit_code":0,"status":"completed"}}
