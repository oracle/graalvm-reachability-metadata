commit_and_push(\n            metrics_repo_path,\n            coordinates,\n            extra_paths_to_stage=_large_library_extra_paths(large_library_state_path, metrics_repo_path),\n        )\n\n\nif __name__ == \"__main__\":\n    if any(a in (\"-h\", \"--help\") for a in sys.argv[1:]):\n        build_parser().print_help()\n        sys.exit(0)\n    main()\n","exit_code":0,"status":"completed"}}
