n   327\t                .newDocumentBuilder()\n   328\t                .parse(new InputSource(new StringReader('<records><record id=\"b1\"/></records>')))\n   329\t        RecordingHandler handler = new RecordingHandler()\n   330\t        FactorySupport.createSaxParserFactory()\n   331\t                .newSAXParser()\n   332\t                .parse(new InputSource(new StringReader('<records><record id=\"b2\">Groovy</record></records>')), handler)\n   333\t\n   334\t        assertThat(document.documentElement.nodeName).isEqualTo('records')\n   335\t        assertThat(document.getElementsByTagName('record').item(0).attributes.getNamedItem('id').nodeValue).isEqualTo('b1')\n   336\t        assertThat(handler.events).contains('start:record:b2', 'text:Groovy')\n   337\t    }\n   338\t\n   339\t    @Test\n   340\t    void domToGroovyPrintsBuilderSourceForDomDocuments() {\n   341\t        Document document = DOMBuilder.parse(new StringReader('<records><record id=\"b1\"><title>Groovy</title></record></records>'))\n   342\t        StringWriter writer = new StringWriter()\n   343\t        DomToGroovy printer = new DomToGroovy(new PrintWriter(writer))\n   344\t\n   345\t        printer.print(document)\n   346\t\n   347\t        String source = writer.toString()\n   348\t        assertThat(source).contains('records')\n   349\t        assertThat(source).contains('record')\n   350\t        assertThat(source).contains('title')\n   351\t        assertThat(source).contains('Groovy')\n   352\t    }\n   353\t\n   354\t    private static final class RecordingHandler extends DefaultHandler {\n   355\t        final List<String> events = []\n   356\t\n   357\t        @Override\n   358\t        void startElement(String uri, String localName, String qName, Attributes attributes) {\n   359\t            String elementName = localName ?: qName\n   360\t            String id = attributes.getValue('id') ?: attributes.getValue('region') ?: ''\n   361\t            events.add(\"start:${elementName}:${id}\".toString())\n   362\t        }\n   363\t\n   364\t        @Override\n   365\t        void characters(char[] ch, int start, int length) {\n   366\t            String text = new String(ch, start, length).trim()\n   367\t            if (!text.isEmpty()) {\n   368\t                events.add(\"text:${text}\".toString())\n   369\t            }\n   370\t        }\n   371\t\n   372\t        @Override\n   373\t        void endElement(String uri, String localName, String qName) {\n   374\t            String elementName = localName ?: qName\n   375\t            events.add(\"end:${elementName}\".toString())\n   376\t        }\n   377\t    }\n   378\t}\n"}], "isError": false, "timestamp": 1780924213374}}
