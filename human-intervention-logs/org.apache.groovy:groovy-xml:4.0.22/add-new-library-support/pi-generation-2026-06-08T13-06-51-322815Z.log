          <title>Groovy &amp; XML</title>\n    45\t                <author>Apache Groovy</author>\n    46\t              </book>\n    47\t              <book id=\"b2\" category=\"reference\">\n    48\t                <title>Native Image Guide</title>\n    49\t                <author>GraalVM</author>\n    50\t              </book>\n    51\t            </catalog>\n    52\t            '''.stripIndent()\n    53\t\n    54\t    @Test\n    55\t    void xmlSlurperNavigatesAttributesTextAndNamespaces() {\n    56\t        XmlSlurper slurper = new XmlSlurper(false, true)\n    57\t        GPathResult catalog = slurper.parseText(CATALOG_XML)\n    58\t\n    59\t        assertThat(catalog.@region.text()).isEqualTo('EU')\n    60\t        assertThat(catalog.book.find { it.@id == 'b1' }.title.text()).isEqualTo('Groovy & XML')\n    61\t        assertThat(catalog.book.collect { it.@category.text() }).containsExactly('programming', 'reference')\n    62\t\n    63\t        GPathResult namespaced = new XmlSlurper(false, true)\n    64\t                .parseText('''\\\n    65\t                        <bk:catalog xmlns:bk=\"urn:books\">\n    66\t                          <bk:book id=\"b1\"><bk:title>Groovy</bk:title></bk:book>\n    67\t                          <bk:book id=\"b2\"><bk:title>GraalVM</bk:title></bk:book>\n    68\t                        </bk:catalog>\n    69\t                        '''.stripIndent())\n    70\t                .declareNamespace(bk: 'urn:books')\n    71\t\n    72\t        assertThat(namespaced.'bk:book'.find { it.@id == 'b2' }.'bk:title'.text()).isEqualTo('GraalVM')\n    73\t    }\n    74\t\n    75\t    @Test\n    76\t    void xmlParserBuildsMutableNodeTrees() {\n    77\t        XmlParser parser = new XmlParser(false, true)\n    78\t        parser.trimWhitespace = true\n    79\t        Node catalog = parser.parseText(CATALOG_XML)\n    80\t\n    81\t        catalog.appendNode('book', [id: 'b3', category: 'testing'])\n    82\t                .appendNode('title', 'Reachability Metadata')\n    83\t\n    84\t        assertThat(catalog.name()).isEqualTo('catalog')\n    85\t        assertThat(catalog.attribute('region')).isEqualTo('EU')\n    86\t        assertThat(catalog.book.collect { it.attribute('id') }).containsExactly('b1', 'b2', 'b3')\n    87\t        assertThat(catalog.book.find { it.@id == 'b3' }.title.text()).isEqualTo('Reachability Metadata')\n    88\t    }\n    89\t\n    90\t    @Test\n    91\t    void markupBuilderEmitsEscapedMarkupCommentsProcessingInstructionsAndEntities() {\n    92\t        StringWriter writer = new StringWriter()\n    93\t        MarkupBuilder builder = new MarkupBuilder(writer)\n    94\t        builder.doubleQuotes = true\n    95\t        builder.omitNullAttributes = true\n    96\t        builder.omitEmptyAttributes = true\n    97\t        builder.expandEmptyElements = true\n    98\t\n    99\t        builder.records(empty: '', missing: null, region: 'EU') {\n   100\t            mkp.comment('generated catalog')\n   101\t            mkp.pi('xml-stylesheet': [type: 'text/xsl', href: 'catalog.xsl'])\n   102\t            record(id: 'b1', category: 'programming') {\n   103\t                title('Groovy & XML')\n   104\t                description {\n   105\t                    mkp.'yield'('Fast ')\n   106\t                    Entity.copy.build(builder)\n   107\t                    mkp.'yield'(' safe')\n   108\t                }\n   109\t                mkp.yieldUnescaped('<raw enabled=\"true\"/>')\n   110\t                emptyElement()\n   111\t            }\n   112\t        }\n   113\t\n   114\t        String xml = writer.toString()\n   115\t        assertThat(xml).contains('<records region=\"EU\">')\n   116\t        assertThat(xml).doesNotContain('empty=').doesNotContain('missing=')\n   117\t        assertThat(xml).contains('<!-- generated catalog -->')\n   118\t        assertThat(xml).contains('<?xml-stylesheet type=\"text/xsl\" href=\"catalog.xsl\"?>')\n   119\t        assertThat(xml).contains('<title>Groovy &amp; XML</title>')\n   120\t        assertThat(xml).contains('Fast &copy; safe')\n   121\t        assertThat(xml).contains('<raw enabled=\"true\"/>')\n   122\t        assertThat(xml).contains('<emptyElement></emptyElement>')\n   123\t    }\n   124\t\n   125\t    @Test\n   126\t    void namespaceBuilderAppliesPrefixDeclarationsToMarkupBuilderOutput() {\n   127\t        StringWriter writer = new StringWriter()\n   128\t        MarkupBuilder markupBuilder = new MarkupBuilder(writer)\n   129\t        def books = NamespaceBuilder.newInstance(markupBuilder, 'urn:books', 'bk')\n   130\t\n   131\t        books.catalog(region: 'EU') {\n   132\t            book(id: 'b1') {\n   133\t                title('Groovy')\n   134\t            }\n   135\t        }\n   136\t\n   137\t        String xml = writer.toString()\n   138\t        assertThat(xml).contains('<bk:catalog')\n   139\t        assertThat(xml).contains(\"xmlns:bk='urn:books'\")\n   140\t        assertThat(xml).contains(\"<bk:book id='b1'>\")\n   141\t        assertThat(xml).contains('<bk:title>Groovy</bk:title>')\n   142\t    }\n   143\t\n   144\t    @Test\n   145\t    void namespaceCreatesQualifiedNamesUsedByParserNodes() {\n   146\t        Namespace namespace = new Namespace('urn:books', 'bk')\n   147\t        QName bookName = namespace.book\n   148\t        QName titleName = namespace.get('title')\n   149\t\n   150\t        Node node = new Node(null, bookName, [id: 'b1'])\n   151\t        node.appendNode(titleName, 'Groovy')\n   152\t\n   153\t        assertThat(bookName.namespaceURI).isEqualTo('urn:books')\n   154\t        assertThat(bookName.localPart).isEqualTo('book')\n   155\t        assertThat(bookName.prefix).isEqualTo('bk')\n   156\t        assertThat(node.name()).isEqualTo(bookName)\n   157\t        assertThat(node.children().first().name()).isEqualTo(titleName)\n   158\t        assertThat(node.children().first().text()).isEqualTo('Groovy')\n   159\t    }\n   160\t\n   161\t    @Test\n   162\t    void streamingMarkupBuilderProducesWritableXmlWithDeclarationsAndNamespaces() {\n   163\t        StreamingMarkupBuilder builder = new StreamingMarkupBuilder()\n   164\t        builder.useDoubleQuotes = true\n   165\t        builder.expandEmptyElements = true\n   166\t\n   167\t        String xml = builder.bind {\n   168\t            mkp.xmlDeclaration()\n   169\t            mkp.comment('streamed catalog')\n   170\t            catalog(xmlns: 'urn:books') {\n   171\t                book(id: 'b1') {\n   172\t                    title('Groovy')\n   173\t                    empty()\n   174\t                }\n   175\t            }\n   176\t        }.toString()\n   177\t\n   178\t        assertThat(xml).contains('<?xml version=')\n   179\t        assertThat(xml).contains('streamed catalog')\n   180\t        assertThat(xml).contains('<catalog xmlns=\"urn:books\">')\n   181\t        assertThat(xml).contains('<book id=\"b1\"><title>Groovy</title><empty></empty></book>')\n   182\t    }\n   183\t\n   184\t    @Test\n   185\t    void xmlUtilSerializesNodesGPathResultsWritableMarkupAndDomElements() {\n   186\t        Node node = new XmlParser(false, true).parseText('<records><record id=\"b1\">Groovy</record></records>')\n   187\t        GPathResult result = new XmlSlurper(false, true).parseText('<records><record id=\"b2\">GraalVM</record></records>')\n   188\t        Document document = DOMBuilder.parse(new StringReader('<records><record id=\"b3\">Native</record></records>'))\n   189\t        def writable = new StreamingMarkupBuilder().bind { records { record(id: 'b4', 'Streaming') } }\n   190\t\n   191\t        String nodeXml = XmlUtil.serialize(node)\n   192\t        String resultXml = XmlUtil.serialize(result)\n   193\t        String elementXml = XmlUtil.serialize(document.documentElement, false)\n   194\t        String writableXml = XmlUtil.serialize(writable)\n   195\t        String stringXml = XmlUtil.serialize('<records><record id=\"b5\">String</record></records>', false)\n   196\t        String escaped = XmlUtil.escapeXml('<record id=\"b6\">Groovy & XML</record>')\n   197\t\n   198\t        assertThat(nodeXml).contains('<record id=\"b1\">Groovy</record>')\n   199\t        assertThat(resultXml).contains('<record id=\"b2\">GraalVM</record>')\n   200\t        assertThat(elementXml).contains('<record id=\"b3\">Native</record>')\n   201\t        assertThat(writableXml).contains('<record id=\"b4\">Streaming</record>')\n   202\t        assertThat(stringXml).contains('<record id=\"b5\">String</record>')\n   203\t        assertThat(escaped).contains('&lt;record')\n   204\t        assertThat(escaped).contains('Groovy &amp; XML')\n   205\t        assertThat(escaped).contains('&lt;/record&gt;')\n   206\t    }\n   207\t\n   208\t    @Test\n   209\t    void xmlNodePrinterRendersParserNodesWithConfiguredFormatting() {\n   210\t        Node node = new XmlParser(false, true).parseText('<records><record id=\"b1\"><title>Groovy</title></record></records>')\n   211\t        StringWriter writer = new StringWriter()\n   212\t        XmlNodePrinter printer = new XmlNodePrinter(new PrintWriter(writer), '  ')\n   213\t        printer.quote = '\"'\n   214\t        printer.expandEmptyElements = true\n   215\t        printer.preserveWhitespace = true\n   216\t\n   217\t        printer.print(node)\n   218\t\n   219\t        String xml = writer.toString()\n   220\t        assertThat(xml).contains('<records>')\n   221\t        assertThat(xml).contains('<record id=\"b1\">')\n   222\t        assertThat(xml).contains('<title>Groovy</title>')\n   223\t    }\n   224\t\n   225\t    @Test\n   226\t    void domBuilderParsesDocumentsAndDomCategoryNavigatesThem() {\n   227\t        Document document = DOMBuilder.parse(new StringReader(CATALOG_XML), false, true)\n   228\t\n   229\t        assertThat(document.documentElement.nodeName).isEqualTo('catalog')\n   230\t        assertThat(document.documentElement.getAttribute('region')).isEqualTo('EU')\n   231\t\n   232\t     