      38	import static org.assertj.core.api.Assertions.assertThat
      39	
      40	public class Groovy_xmlTest {
      41	    private static final String CATALOG_XML = '''\
      42	            <catalog region="EU">
      43	              <book id="b1" category="programming">
      44	                <title>Groovy &amp; XML</title>
      45	                <author>Apache Groovy</author>
      46	              </book>
      47	              <book id="b2" category="reference">
      48	                <title>Native Image Guide</title>
      49	                <author>GraalVM</author>
      50	              </book>
      51	            </catalog>
      52	            '''.stripIndent()
      53	
      54	    @Test
      55	    void xmlSlurperNavigatesAttributesTextAndNamespaces() {
      56	        XmlSlurper slurper = new XmlSlurper(false, true)
      57	        GPathResult catalog = slurper.parseText(CATALOG_XML)
      58	
      59	        assertThat(catalog.@region.text()).isEqualTo('EU')
      60	        assertThat(catalog.book.find { it.@id == 'b1' }.title.text()).isEqualTo('Groovy & XML')
      61	        assertThat(catalog.book.collect { it.@category.text() }).containsExactly('programming', 'reference')
      62	
      63	        GPathResult namespaced = new XmlSlurper(false, true)
      64	                .parseText('''\
      65	                        <bk:catalog xmlns:bk="urn:books">
      66	                          <bk:book id="b1"><bk:title>Groovy</bk:title></bk:book>
      67	                          <bk:book id="b2"><bk:title>GraalVM</bk:title></bk:book>
      68	                        </bk:catalog>
      69	                        '''.stripIndent())
      70	                .declareNamespace(bk: 'urn:books')
      71	
      72	        assertThat(namespaced.'bk:book'.find { it.@id == 'b2' }.'bk:title'.text()).isEqualTo('GraalVM')
      73	    }
      74	
      75	    @Test
      76	    void xmlParserBuildsMutableNodeTrees() {
      77	        XmlParser parser = new XmlParser(false, true)
      78	        parser.trimWhitespace = true
      79	        Node catalog = parser.parseText(CATALOG_XML)
      80	
      81	        catalog.appendNode('book', [id: 'b3', category: 'testing'])
      82	                .appendNode('title', 'Reachability Metadata')
      83	
      84	        assertThat(catalog.name()).isEqualTo('catalog')
      85	        assertThat(catalog.attribute('region')).isEqualTo('EU')
      86	        assertThat(catalog.book.collect { it.attribute('id') }).containsExactly('b1', 'b2', 'b3')
      87	        assertThat(catalog.book.find { it.@id == 'b3' }.title.text()).isEqualTo('Reachability Metadata')
      88	    }
      89	
      90	    @Test
      91	    void markupBuilderEmitsEscapedMarkupCommentsProcessingInstructionsAndEntities() {
      92	        StringWriter writer = new StringWriter()
      93	        MarkupBuilder builder = new MarkupBuilder(writer)
      94	        builder.doubleQuotes = true
      95	        builder.omitNullAttributes = true
      96	        builder.omitEmptyAttributes = true
