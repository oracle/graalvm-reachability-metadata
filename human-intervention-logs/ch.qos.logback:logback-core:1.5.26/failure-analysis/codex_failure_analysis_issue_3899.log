   appender.stop();\\n        }\\n    }\\n\\n    private ConsoleAppender<String> newAppender(String target) {\\n        ContextBase context = new ContextBase();\\n        context.setName(\\\"console-appender-test\\\");\\n\\n        EchoEncoder<String> encoder = new EchoEncoder<>();\\n        encoder.setContext(context);\\n\\n        ConsoleAppender<String> appender = new ConsoleAppender<>();\\n        appender.setContext(context);\\n        appender.setName(\\\"console\\\");\\n        appender.setEncoder(encoder);\\n        appender.setTarget(target);\\n        appender.setWithJansi(true);\\n        return appender;\\n    }\\n}\\n\"}], \"isError\": false, \"timestamp\": 1777801066645}]}\nhuman-intervention-logs/ch.qos.logback:logback-core:1.5.26/add-new-library-support/pi-generation-2026-05-03T09-39-26-571737Z.log:2256:[tool-exec] end id=call_usyW1nEOff0ghJ6TtTJcJnae|fc_0a05747ff7814e5b0169f71772cacc8196be85ff36576ac517 name=edit status=error\nhuman-intervention-logs/ch.qos.logback:logback-core:1.5.26/add-new-library-support/pi-generation-2026-05-03T09-39-26-571737Z.log:2270:[tool-exec] end id=call_L0bOhwvktn3fgkZujAR5XUk2|fc_0a05747ff7814e5b0169f71775fd948196a2cab61f75606882 name=read status=success\nhuman-intervention-logs/ch.qos.logback:logback-core:1.5.26/add-new-library-support/pi-generation-2026-05-03T09-39-26-571737Z.log:2355:[tool-exec] end id=call_ZTb1KO2k4iQCf534nODSS0kh|fc_0a05747ff7814e5b0169f71777ac648196be39aa2c68c2a812 name=edit status=success\nhuman-intervention-logs/ch.qos.logback:logback-core:1.5.26/add-new-library-support/pi-generation-2026-05-03T09-39-26-571737Z.log:2373:[tool-exec] end id=call_FbCU85byKSu8UvFicSWCZ2Vt|fc_0a05747ff7814e5b0169f717811c808196b1c4384728b2fff4 name=read status=success\nhuman-intervention-logs/ch.qos.logback:logback-core:1.5.26/add-new-library-support/pi-generation-2026-05-03T09-39-26-571737Z.log:2399:      void reportsJaninoAvailabilityWhenJaninoIsResolvableFromTheEnvUtilClassLoader() throws Exception {\nhuman-interve