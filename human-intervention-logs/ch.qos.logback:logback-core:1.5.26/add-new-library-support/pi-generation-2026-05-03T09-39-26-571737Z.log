          addWarn("See also " + CODES_URL + "#layoutInsteadOfEncoder for details");
          LayoutWrappingEncoder<E> lwe = new LayoutWrappingEncoder<E>();
          lwe.setLayout(layout);
          lwe.setContext(context);
          this.encoder = lwe;
      }
  
      @Override
      protected void append(E eventObject) {
