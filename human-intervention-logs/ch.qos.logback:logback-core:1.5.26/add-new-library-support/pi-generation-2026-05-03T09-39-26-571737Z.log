  package ch_qos_logback.logback_core;
  
  import ch.qos.logback.core.ConsoleAppender;
  import ch.qos.logback.core.ContextBase;
  import ch.qos.logback.core.encoder.EchoEncoder;
  import org.fusesource.jansi.AnsiConsole;
  import org.junit.jupiter.api.AfterEach;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ConsoleAppenderTest {
      @AfterEach
      void resetAnsiConsole() {
          AnsiConsole.reset();
      }
  
      @Test
      void startsWithJansi2OutStreamWhenOutMethodIsAvailable() {
          ConsoleAppender<String> appender = newAppender("System.out");
  
          appender.start();
          try {
              assertThat(appender.isStarted()).isTrue();
              assertThat(appender.getOutputStream()).isSameAs(AnsiConsole.outStream());
              assertThat(AnsiConsole.systemInstallCalls()).isOne();
              assertThat(AnsiConsole.outCalls()).isOne();
              assertThat(AnsiConsole.wrapSystemErrCalls()).isZero();
          } finally {
              appender.stop();
          }
      }
  
      @Test
      void startsWithJansi1ErrWrapperWhenErrMethodIsUnavailable() {
          ConsoleAppender<String> appender = newAppender("System.err");
  
          appender.start();
          try {
              assertThat(appender.isStarted()).isTrue();
              assertThat(appender.getOutputStream()).isSameAs(AnsiConsole.errWrapperStream());
              assertThat(AnsiConsole.systemInstallCalls()).isOne();
              assertThat(AnsiConsole.outCalls()).isZero();
              assertThat(AnsiConsole.wrapSystemErrCalls()).isOne();
              assertThat(AnsiConsole.lastWrappedErrStream()).isNotNull();
          } finally {
              appender.stop();
          }
      }
  
      private ConsoleAppender<String> newAppender(String target) {
          ContextBase context = new ContextBase();
          context.setName("console-appender-test");
  
          EchoEncoder<String> encoder = new EchoEncoder<>();
          encoder.setContext(context);
  
          ConsoleAppender<String> appender = new ConsoleAppender<>();
          appender.setContext(context);
          appender.setName("console");
          appender.setEncoder(encoder);
          appender.setTarget(target);
          appender.setWithJansi(true);
          return appender;
      }
  }
