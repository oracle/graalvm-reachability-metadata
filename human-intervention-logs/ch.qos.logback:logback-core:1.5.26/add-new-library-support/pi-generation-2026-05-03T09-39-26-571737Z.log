      public void start() {
          int errors = 0;
          if (this.encoder == null) {
              addStatus(new ErrorStatus("No encoder set for the appender named \"" + name + "\".", this));
              errors++;
          }
  
          if (this.outputStream == null) {
              addStatus(new ErrorStatus("No output stream set for the appender named \"" + name + "\".", this));
              errors++;
          }
  
