  package org.fusesource.jansi;
  
  import java.io.ByteArrayOutputStream;
  import java.io.PrintStream;
  import java.nio.charset.StandardCharsets;
  
  public final class AnsiConsole {
      private static final ByteArrayOutputStream OUT_BYTES = new ByteArrayOutputStream();
      private static final ByteArrayOutputStream ERR_BYTES = new ByteArrayOutputStream();
      private static final PrintStream OUT_STREAM = new PrintStream(OUT_BYTES, true, StandardCharsets.UTF_8);
      private static final PrintStream ERR_WRAPPER_STREAM = new PrintStream(ERR_BYTES, true, StandardCharsets.UTF_8);
  
      private static int systemInstallCalls;
      private static int outCalls;
      private static int wrapSystemErrCalls;
      private static PrintStream lastWrappedErrStream;
  
      private AnsiConsole() {
      }
  
      public static void systemInstall() {
          systemInstallCalls++;
      }
  
      public static PrintStream out() {
          outCalls++;
          return OUT_STREAM;
      }
  
      public static PrintStream wrapSystemErr(PrintStream targetStream) {
          wrapSystemErrCalls++;
          lastWrappedErrStream = targetStream;
          return ERR_WRAPPER_STREAM;
      }
  
      public static void reset() {
          systemInstallCalls = 0;
          outCalls = 0;
          wrapSystemErrCalls = 0;
          lastWrappedErrStream = null;
          OUT_BYTES.reset();
          ERR_BYTES.reset();
      }
  
      public static int systemInstallCalls() {
          return systemInstallCalls;
      }
  
      public static int outCalls() {
          return outCalls;
      }
  
      public static int wrapSystemErrCalls() {
          return wrapSystemErrCalls;
      }
  
      public static PrintStream lastWrappedErrStream() {
          return lastWrappedErrStream;
      }
  
      public static PrintStream outStream() {
          return OUT_STREAM;
      }
  
      public static PrintStream errWrapperStream() {
          return ERR_WRAPPER_STREAM;
      }
  }
