                  assertThat(loadedClass).isInstanceOf(Class.class);
                  assertThat(((Class<?>) loadedClass).getName()).isEqualTo(LOADABLE_CLASS_NAME);
              } finally {
                  restoreProperty(Loader.IGNORE_TCL_PROPERTY_NAME, previousValue);
              }
          } catch (Error error) {
