\\t * </p>\\n    47\\t *\\n    48\\t * @author Bill Venners\\n    49\\t * @author Chua Chee Seng\\n    50\\t */\\n    51\\ttrait MockitoSugar {\\n    52\\t\\n    53\\t  /**\\n    54\\t   * Invokes the <code>mock(classToMock: Class[T])</code> method on the <code>Mockito</code> companion object (<em>i.e.</em>, the\\n    55\\t   * static <code>mock(java.lang.Class<T> classToMock)</code> method in Java class <code>org.mockito.Mockito</code>).\\n    56\\t   *\\n    57\\t   * <p>\\n    58\\t   * Using the Mockito API directly, you create a mock with:\\n    59\\t   * </p>\\n    60\\t   *\\n    61\\t   * <pre class=\\\"stHighlight\\\">\\n    62\\t   * val mockCollaborator = mock(classOf[Collaborator])\\n    63\\t   * </pre>\\n    64\\t   *\\n    65\\t   * <p>\\n    66\\t   * Using this method, you can shorten that to:\\n    67\\t   * </p>\\n    68\\t   *\\n    69\\t   * <pre class=\\\"stHighlight\\\">\\n    70\\t   * val mockCollaborator = mock[Collaborator]\\n    71\\t   * </pre>\\n    72\\t   */\\n    73\\t  def mock[T <: AnyRef](implicit classTag: ClassTag[T]): T = {\\n    74\\t    mockitoMock(classTag.runtimeClass.asInstanceOf[Class[T]])\\n    75\\t  }\\n    76\\t  \\n    77\\t  /**\\n    78\\t   * Invokes the <code>mock(classToMock: Class[T], defaultAnswer: Answer[_])</code> method on the <code>Mockito</code> companion object (<em>i.e.</em>, the\\n    79\\t   * static <code>mock(java.lang.Class<T> classToMock, org.mockito.stubbing.Answer defaultAnswer)</code> method in Java class <code>org.mockito.Mockito</code>).\\n    80\\t   *\\n    81\\t   * <p>\\n    82\\t   * Using the Mockito API directly, you create a mock with:\\n    83\\t   * </p>\\n    84\\t   *\\n    85\\t   * <pre class=\\\"stHighlight\\\">\\n    86\\t   * val mockCollaborator = mock(classOf[Collaborator], defaultAnswer)\\n    87\\t   * </pre>\\n    88\\t   *\\n    89\\t   * <p>\\n    90\\t   * Using this method, you can shorten that to:\\n    91\\t   * </p>\\n    92\\t   *\\n    93\\t   * <pre class=\\\"stHighlight\\\">\\n    94\\t   * val mockCollaborator = mock[Collaborator](defaultAnswer)\\n    95\\t   * </pre>\\n    96\\t   */\\n    97\\t  def mock[T <: AnyRef](defaultAnswer: Answer[_])(implicit classTag: ClassTag[T]): T = {\\n    98\\t    mockitoMock(classTag.runtimeClass.asInstanceOf[Class[T]], defaultAnswer)\\n    99\\t  }\\n   100\\t  \\n   101\\t  /**\\n   102\\t   * Invokes the <code>mock(classToMock: Class[T], mockSettings: MockSettings)</code> method on the <code>Mockito</code> companion object (<em>i.e.</em>, the\\n   103\\t   * static <code>mock(java.lang.Class<T> classToMock, org.mockito.MockSettings mockSettings)</code> method in Java class <code>org.mockito.Mockito</code>).\\n   104\\t   *\\n   105\\t   * <p>\\n   106\\t   * Using the Mockito API directly, you create a mock with:\\n   107\\t   * </p>\\n   108\\t   *\\n   109\\t   * <pre class=\\\"stHighlight\\\">\\n   110\\t   * val mockCollaborator = mock(classOf[Collaborator], mockSettings)\\n   111\\t   * </pre>\\n   112\\t   *\\n   113\\t   * <p>\\n   114\\t   * Using this method, you can shorten that to:\\n   115\\t   * </p>\\n   116\\t   *\\n   117\\t   * <pre class=\\\"stHighlight\\\">\\n   118\\t   * val mockCollaborator = mock[Collaborator](mockSettings)\\n   119\\t   * </pre>\\n   120\\t   */\\n   121\\t  def mock[T <: AnyRef](mockSettings: MockSettings)(implicit classTag: ClassTag[T]): T = {\\n   122\\t    mockitoMock(classTag.runtimeClass.asInstanceOf[Class[T]], mockSettings)\\n   123\\t  }\\n   124\\t  \\n   125\\t  /**\\n   126\\t   * Invokes the <code>mock(classToMock: Class[T], name: String)</code> method on the <code>Mockito</code> companion object (<em>i.e.</em>, the\\n   127\\t   * static <code>mock(java.lang.Class<T> classToMock, java.lang.String name)</code> method in Java class <code>org.mockito.Mockito</code>).\\n   128\\t   *\\n   129\\t   * <p>\\n   130\\t   * Using the Mockito API directly, you create a mock with:\\n   131\\t   * </p>\\n   132\\t   *\\n   133\\t   * <pre class=\\\"stHighlight\\\">\\n   134\\t   * val mockCollaborator = mock(classOf[Collaborator], name)\\n   135\\t   * </pre>\\n   136\\t   *\\n   137\\t   * <p>\\n   138\\t   * Using this method, you can shorten that to:\\n   139\\t   * </p>\\n   140\\t   *\\n   141\\t   * <pre class=\\\"stHighlight\\\">\\n   142\\t   * val mockCollaborator = mock[Collaborator](name)\\n   143\\t   * </pre>\\n   144\\t   */\\n   145\\t  def mock[T <: AnyRef](name: String)(implicit classTag: ClassTag[T]): T = {\\n   146\\t    mockitoMock(classTag.runtimeClass.asInstanceOf[Class[T]], name)\\n   147\\t  }\\n   148\\t\\n   149\\t\\n   150\\t  /**\\n   151\\t   * Invokes the <code>forClass(classToMock: Class[T])</code> method on the <code>ArgumentCaptor</code> companion object (<em>i.e.</em>, the\\n   152\\t   * static <code>forClass(java.lang.Class<T> classToMock)</code> method in Java class <code>org.mockito.Mockito</code>).\\n   153\\t   *\\n   154\\t   * <p>\\n   155\\t   * Using the Mockito API directly, you create a ArgumentCaptor with:\\n   156\\t   * </p>\\n   157\\t   *\\n   158\\t   * <pre class=\\\"stHighlight\\\">\\n   159\\t   * val collaboratorCaptor = ArgumentCaptor.forClass(classOf[Collaborator])\\n   160\\t   * </pre>\\n   161\\t   *\\n   162\\t   * <p>\\n   163\\t   * Using this method, you can shorten that to:\\n   164\\t   * </p>\\n   165\\t   *\\n   166\\t   * <pre class=\\\"stHighlight\\\">\\n   167\\t   * val collaboratorCaptor = capture[Collaborator]\\n   168\\t   * </pre>\\n   169\\t   */\\n   170\\t  def capture[T <: AnyRef](implicit classTag: ClassTag[T]): ArgumentCaptor[T] = {\\n   171\\t    ArgumentCaptor.forClass(classTag.runtimeClass.asInstanceOf[Class[T]])\\n   172\\t  }\\n   173\\t\\n   174\\t  /**\\n   175\\t   * Invoke the <code>capture(): T</code> method on the <code>ArgumentCaptor</code> for convenience.\\n   176\\t   */\\n   177\\t  implicit def invokeCaptureOnArgumentCaptor[T](captor: ArgumentCaptor[T]): T = {\\n   178\\t    captor.capture()\\n   179\\t  }\\n   180\\t}\\n   181\\t\\n   182\\t/**\\n   183\\t * Companion object that facilitates the importing of <code>MockitoSugar</code> members as \\n   184\\t * an alternative to mixing it in. One use case is to import <code>MockitoSugar</code> members so you can use\\n   185\\t * them in the Scala interpreter.\\n   186\\t */\\n   187\\t// TODO: Fill in an example\\n   188\\tobject MockitoSugar extends MockitoSugar\\n   189\\t\\n\"}], \"isError\": false, \"timestamp\": 1778021519672}}\n1135:[recv] {\"type\": \"message_end\", \"message\": {\"role\": \"toolResult\", \"toolCallId\": \"call_KnGbKkI1j4tfCBjABoHp2Up1|fc_08ddc8a46a65d68c0169fa748f05108192860ea23d35076f9d\", \"toolName\": \"bash\", \"content\": [{\"type\": \"text\", \"text\": \"     1\\t/*\\n     2\\t * Copyright 2001-2013 Artima, Inc.\\n     3\\t *\\n     4\\t * Licensed under the Apache License, Version 2.0 (the \\\"License\\\");\\n     5\\t * you may not use this file except in compliance with the License.\\n     6\\t * You may obtain a copy of the License at\\n     7\\t *\\n     8\\t *     http://www.apache.org/licenses/LICENSE-2.0\\n     9\\t *\\n    10\\t * Unless required by applicable law or agreed to in writing, software\\n    11\\t * distributed under the License is distributed on an \\\"AS IS\\\" BASIS,\\n    12\\t * WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\\n    13\\t * See the License for the specific language governing permissions and\\n    14\\t * limitations under the License.\\n    15\\t */\\n    16\\tpackage org.scalatestplus.mockito\\n    17\\t\\n    18\\timport org.mockito.Mockito.{mock => mockitoMock}\\n    19\\timport reflect.ClassTag\\n    20\\timport org.mockito.stubbing.Answer\\n    21\\timport org.mockito.ArgumentCaptor\\n    22\\timport org.mockito.MockSettings\\n    23\\t\\n    24\\t/**\\n    25\\t * Trait that provides some basic syntax sugar for <a href=\\\"http://mockito.org/\\\" target=\\\"_blank\\\">Mockito</a>.\\n    26\\t *\\n    27\\t * <p>\