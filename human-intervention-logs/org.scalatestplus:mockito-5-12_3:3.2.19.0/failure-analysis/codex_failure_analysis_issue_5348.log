borator]\\n    41\\t * </pre>\\n    42\\t *\\n    43\\t * <p>\\n    44\\t * This trait also provides shorthands for the three other (non-deprecated) overloaded <code>mock</code> methods,\\n    45\\t * which allow you to pass in a default answer, a name, or settings.\\n    46\\t * </p>\\n    47\\t *\\n    48\\t * @author Bill Venners\\n    49\\t * @author Chua Chee Seng\\n    50\\t */\\n    51\\ttrait MockitoSugar {\\n    52\\t\\n    53\\t  /**\\n    54\\t   * Invokes the <code>mock(classToMock: Class[T])</code> method on the <code>Mockito</code> companion object (<em>i.e.</em>, the\\n    55\\t   * static <code>mock(java.lang.Class<T> classToMock)</code> method in Java class <code>org.mockito.Mockito</code>).\\n    56\\t   *\\n    57\\t   * <p>\\n    58\\t   * Using the Mockito API directly, you create a mock with:\\n    59\\t   * </p>\\n    60\\t   *\\n    61\\t   * <pre class=\\\"stHighlight\\\">\\n    62\\t   * val mockCollaborator = mock(classOf[Collaborator])\\n    63\\t   * </pre>\\n    64\\t   *\\n    65\\t   * <p>\\n    66\\t   * Using this method, you can shorten that to:\\n    67\\t   * </p>\\n    68\\t   *\\n    69\\t   * <pre class=\\\"stHighlight\\\">\\n    70\\t   * val mockCollaborator = mock[Collaborator]\\n    71\\t   * </pre>\\n    72\\t   */\\n    73\\t  def mock[T <: AnyRef](implicit classTag: ClassTag[T]): T = {\\n    74\\t    mockitoMock(classTag.runtimeClass.asInstanceOf[Class[T]])\\n    75\\t  }\\n    76\\t  \\n    77\\t  /**\\n    78\\t   * Invokes the <code>mock(classToMock: Class[T], defaultAnswer: Answer[_])</code> method on the <code>Mockito</code> companion object (<em>i.e.</em>, the\\n    79\\t   * static <code>mock(java.lang.Class<T> classToMock, org.mockito.stubbing.Answer defaultAnswer)</code> method in Java class <code>org.mockito.Mockito</code>).\\n    80\\t   *\\n    81\\t   * <p>\\n    82\\t   * Using the Mockito API directly, you create a mock with:\\n    83\\t   * </p>\\n    84\\t   *\\n    85\\t   * <pre class=\\\"stHighlight\