      24	/**
      25	 * Trait that provides some basic syntax sugar for <a href="http://mockito.org/" target="_blank">Mockito</a>.
      26	 *
      27	 * <p>
      28	 * Using the Mockito API directly, you create a mock with:
      29	 * </p>
      30	 *
      31	 * <pre class="stHighlight">
      32	 * val mockCollaborator = mock(classOf[Collaborator])
      33	 * </pre>
      34	 *
      35	 * <p>
      36	 * Using this trait, you can shorten that to:
      37	 * </p>
      38	 *
      39	 * <pre class="stHighlight">
      40	 * val mockCollaborator = mock[Collaborator]
      41	 * </pre>
      42	 *
      43	 * <p>
      44	 * This trait also provides shorthands for the three other (non-deprecated) overloaded <code>mock</code> methods,
      45	 * which allow you to pass in a default answer, a name, or settings.
      46	 * </p>
      47	 *
      48	 * @author Bill Venners
      49	 * @author Chua Chee Seng
      50	 */
      51	trait MockitoSugar {
      52	
      53	  /**
      54	   * Invokes the <code>mock(classToMock: Class[T])</code> method on the <code>Mockito</code> companion object (<em>i.e.</em>, the
      55	   * static <code>mock(java.lang.Class<T> classToMock)</code> method in Java class <code>org.mockito.Mockito</code>).
      56	   *
      57	   * <p>
      58	   * Using the Mockito API directly, you create a mock with:
      59	   * </p>
      60	   *
      61	   * <pre class="stHighlight">
      62	   * val mockCollaborator = mock(classOf[Collaborator])
      63	   * </pre>
      64	   *
      65	   * <p>
      66	   * Using this method, you can shorten that to:
      67	   * </p>
      68	   *
      69	   * <pre class="stHighlight">
      70	   * val mockCollaborator = mock[Collaborator]
      71	   * </pre>
      72	   */
      73	  def mock[T <: AnyRef](implicit classTag: ClassTag[T]): T = {
      74	    mockitoMock(classTag.runtimeClass.asInstanceOf[Class[T]])
      75	  }
      76	  
      77	  /**
      78	   * Invokes the <code>mock(classToMock: Class[T], defaultAnswer: Answer[_])</code> method on the <code>Mockito</code> companion object (<em>i.e.</em>, the
      79	   * static <code>mock(java.lang.Class<T> classToMock, org.mockito.stubbing.Answer defaultAnswer)</code> method in Java class <code>org.mockito.Mockito</code>).
      80	   *
      81	   * <p>
      82	   * Using the Mockito API directly, you create a mock with:
      83	   * </p>
      84	   *
      85	   * <pre class="stHighlight">
      86	   * val mockCollaborator = mock(classOf[Collaborator], defaultAnswer)
      87	   * </pre>
      88	   *
      89	   * <p>
      90	   * Using this method, you can shorten that to:
      91	   * </p>
      92	   *
      93	   * <pre class="stHighlight">
      94	   * val mockCollaborator = mock[Collaborator](defaultAnswer)
      95	   * </pre>
      96	   */
      97	  def mock[T <: AnyRef](defaultAnswer: Answer[_])(implicit classTag: ClassTag[T]): T = {
      98	    mockitoMock(classTag.runtimeClass.asInstanceOf[Class[T]], defaultAnswer)
      99	  }
     100	  
     101	  /**
     102	   * Invokes the <code>mock(classToMock: Class[T], mockSettings: MockSettings)</code> method on the <code>Mockito</code> companion object (<em>i.e.</em>, the
     103	   * static <code>mock(java.lang.Class<T> classToMock, org.mockito.MockSettings mockSettings)</code> method in Java class <code>org.mockito.Mockito</code>).
     104	   *
     105	   * <p>
     106	   * Using the Mockito API directly, you create a mock with:
     107	   * </p>
     108	   *
     109	   * <pre class="stHighlight">
     110	   * val mockCollaborator = mock(classOf[Collaborator], mockSettings)
     111	   * </pre>
     112	   *
     113	   * <p>
     114	   * Using this method, you can shorten that to:
     115	   * </p>
     116	   *
     117	   * <pre class="stHighlight">
     118	   * val mockCollaborator = mock[Collaborator](mockSettings)
     119	   * </pre>
     120	   */
     121	  def mock[T <: AnyRef](mockSettings: MockSettings)(implicit classTag: ClassTag[T]): T = {
     122	    mockitoMock(classTag.runtimeClass.asInstanceOf[Class[T]], mockSettings)
     123	  }
     124	  
     125	  /**
     126	   * Invokes the <code>mock(classToMock: Class[T], name: String)</code> method on the <code>Mockito</code> companion object (<em>i.e.</em>, the
     127	   * static <code>mock(java.lang.Class<T> classToMock, java.lang.String name)</code> method in Java class <code>org.mockito.Mockito</code>).
     128	   *
     129	   * <p>
     130	   * Using the Mockito API directly, you create a mock with:
     131	   * </p>
     132	   *
     133	   * <pre class="stHighlight">
     134	   * val mockCollaborator = mock(classOf[Collaborator], name)
     135	   * </pre>
     136	   *
     137	   * <p>
     138	   * Using this method, you can shorten that to:
     139	   * </p>
     140	   *
     141	   * <pre class="stHighlight">
     142	   * val mockCollaborator = mock[Collaborator](name)
     143	   * </pre>
     144	   */
     145	  def mock[T <: AnyRef](name: String)(implicit classTag: ClassTag[T]): T = {
     146	    mockitoMock(classTag.runtimeClass.asInstanceOf[Class[T]], name)
     147	  }
     148	
     149	
     150	  /**
     151	   * Invokes the <code>forClass(classToMock: Class[T])</code> method on the <code>ArgumentCaptor</code> companion object (<em>i.e.</em>, the
     152	   * static <code>forClass(java.lang.Class<T> classToMock)</code> method in Java class <code>org.mockito.Mockito</code>).
     153	   *
     154	   * <p>
     155	   * Using the Mockito API directly, you create a ArgumentCaptor with:
     156	   * </p>
     157	   *
     158	   * <pre class="stHighlight">
     159	   * val collaboratorCaptor = ArgumentCaptor.forClass(classOf[Collaborator])
     160	   * </pre>
     161	   *
     162	   * <p>
     163	   * Using this method, you can shorten that to:
     164	   * </p>
     165	   *
     166	   * <pre class="stHighlight">
     167	   * val collaboratorCaptor = capture[Collaborator]
     168	   * </pre>
     169	   */
     170	  def capture[T <: AnyRef](implicit classTag: ClassTag[T]): ArgumentCaptor[T] = {
     171	    ArgumentCaptor.forClass(classTag.runtimeClass.asInstanceOf[Class[T]])
     172	  }
     173	
     174	  /**
     175	   * Invoke the <code>capture(): T</code> method on the <code>ArgumentCaptor</code> for convenience.
     176	   */
     177	  implicit def invokeCaptureOnArgumentCaptor[T](captor: ArgumentCaptor[T]): T = {
     178	    captor.capture()
     179	  }
     180	}
     181	
     182	/**
     183	 * Companion object that facilitates the importing of <code>MockitoSugar</code> members as 
     184	 * an alternative to mixing it in. One use case is to import <code>MockitoSugar</code> members so you can use
     185	 * them in the Scala interpreter.
     186	 */
     187	// TODO: Fill in an example
     188	object MockitoSugar extends MockitoSugar
