      16	package org.scalatestplus.mockito
      17	
      18	import org.mockito.Mockito.{mock => mockitoMock}
      19	import reflect.ClassTag
      20	import org.mockito.stubbing.Answer
      21	import org.mockito.ArgumentCaptor
      22	import org.mockito.MockSettings
