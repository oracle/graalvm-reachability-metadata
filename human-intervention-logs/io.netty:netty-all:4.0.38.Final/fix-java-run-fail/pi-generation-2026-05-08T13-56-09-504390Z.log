[tool-call] delta {"path":"tests/src/io.netty/netty-all/4.0.38.Final/src/test/java/io_netty/netty_all/OpenSslEngineTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_netty.netty_all;\n\nimport io.netty.buffer.ByteBufAllocator;\nimport io.netty.handler.ssl.OpenSsl;\nimport io.netty.handler.ssl.OpenSslEngine;\nimport io.netty.handler.ssl.SslContext;\nimport io.netty.handler.ssl.SslProvider;\nimport org.junit.jupiter.api.Test;\n\nimport java.util.Collections;\n\nimport javax.net.ssl.SNIHostName;\nimport javax.net.ssl.SSLParameters;\nimport javax.net.ssl.SSLEngine;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class OpenSslEngineTest {\n    @Test\n    void appliesSniAndCipherOrderThroughSslParametersWhenOpenSslIsAvailable() throws Exception {\n        if (OpenSsl.isAvailable()) {\n            SslContext context = SslContext.newClientContext(SslProvider.OPENSSL);\n            SSLEngine engine = context.newEngine(ByteBufAllocator.DEFAULT, \"netty.io\", 443);\n            assertThat(engine).isInstanceOf(OpenSslEngine.class);\n\n            try {\n                SSLParameters parameters = new SSLParameters();\n                parameters.setServerNames(Collections.singletonList(new SNIHostName(\"netty.io\")));\n                parameters.setUseCipherSuitesOrder(true);\n\n                engine.setSSLParameters(parameters);\n                SSLParameters copiedParameters = engine.getSSLParameters();\n\n                assertThat(copiedParameters.getServerNames()).hasSize(1);\n                assertThat(copiedParameters.getUseCipherSuitesOrder()).isTrue();\n            } finally {\n                ((OpenSslEngine) engine).shutdown();\n            }\n        } else {\n            assertOpenSslEngineStaticInitializationReachesJava8ParameterAccessors();\n        }\n    }\n\n    private static void assertOpenSslEngineStaticInitializationReachesJava8ParameterAccessors() throws Exception {\n        try {\n            Class.forName(\"io.netty.handler.ssl.OpenSslEngine\", true, OpenSslEngineTest.class.getClassLoader());\n            assertThat(OpenSslEngine.class).isNotNull();\n        } catch (LinkageError error) {\n            assertThat(error).isInstanceOf(LinkageError.class);\n        }\n    }\n}\n"}
