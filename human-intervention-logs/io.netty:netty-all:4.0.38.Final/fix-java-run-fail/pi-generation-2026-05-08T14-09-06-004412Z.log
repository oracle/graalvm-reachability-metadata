evel previousLevel = ResourceLeakDetector.getLevel();\n        ResourceLeakDetector.setLevel(Level.PARANOID);\n        try {\n            ResourceLeakDetector<StringBuilder> detector = ResourceLeakDetectorFactory.instance()\n                    .newResourceLeakDetector(StringBuilder.class, 1, 7L);\n\n            ResourceLeak leak = detector.open(new StringBuilder(\"tracked\"));\n\n            assertThat(detector).isNotNull();\n            assertThat(leak).isNotNull();\n            leak.close();\n        } finally {\n            ResourceLeakDetector.setLevel(previousLevel);\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 774, "output": 1019, "cacheRead": 40960, "cacheWrite": 0, "totalTokens": 42753, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778249296187, "responseId": "resp_03ea9111bf0888220169fdee50e6c0819c922b77e02b13fcd1"}}
