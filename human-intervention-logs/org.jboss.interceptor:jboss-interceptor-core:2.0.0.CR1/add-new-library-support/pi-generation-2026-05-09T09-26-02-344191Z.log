<?>[] {},\n                    new Object[] {});\n\n            assertThat(proxy).isInstanceOf(DefaultInvocationContextFactory.class);\n        } catch (InterceptorException exception) {\n            rethrowIfNotNativeImageDynamicClassLoadingFailure(exception);\n        } catch (Error error) {\n            rethrowIfNotNativeImageDynamicClassLoadingFailure(error);\n        }\n    }\n\n    private static void rethrowIfNotNativeImageDynamicClassLoadingFailure(InterceptorException exception) {\n        Throwable cause = exception;\n        while (cause != null) {\n            if (cause instanceof Error error && NativeImageSupport.isUnsupportedFeatureError(error)) {\n                return;\n            }\n            cause = cause.getCause();\n        }\n        throw exception;\n    }\n\n    private static void rethrowIfNotNativeImageDynamicClassLoadingFailure(Error error) {\n        if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n            throw error;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 695, "output": 1417, "cacheRead": 37376, "cacheWrite": 0, "totalTokens": 39488, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778318703061, "responseId": "resp_081a31340e2e054b0169fefd6fb51881a3892861af10ccee99"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_r1ltRFwlvOlvO4RdDUSiTwvS|fc_081a31340e2e054b0169fefd7c603081a3a1513a762c2d77b3", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2502 bytes to tests/src/org.jboss.interceptor/jboss-interceptor-core/2.0.0.CR1/src/test/java/org_jboss_interceptor/jboss_interceptor_core/InterceptorProxyCreatorImplTest.java"}], "isError": false, "timestamp": 1778318719062}]}
