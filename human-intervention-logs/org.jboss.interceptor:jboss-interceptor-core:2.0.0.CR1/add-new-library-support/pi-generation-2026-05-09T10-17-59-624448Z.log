tor_core/InterceptorMethodHandlerAnonymous1Test.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_jboss_interceptor.jboss_interceptor_core;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.io.Serializable;\n\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.jboss.interceptor.builder.InterceptionModelBuilder;\nimport org.jboss.interceptor.proxy.DefaultInvocationContextFactory;\nimport org.jboss.interceptor.proxy.InterceptorException;\nimport org.jboss.interceptor.proxy.InterceptorProxyCreatorImpl;\nimport org.jboss.interceptor.reader.ReflectiveClassMetadata;\nimport org.jboss.interceptor.spi.context.InvocationContextFactory;\nimport org.jboss.interceptor.spi.instance.InterceptorInstantiator;\nimport org.jboss.interceptor.spi.metadata.ClassMetadata;\nimport org.jboss.interceptor.spi.model.InterceptionModel;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class InterceptorMethodHandlerAnonymous1Test {\n\n    @Test\n    void restoredDefaultMethodHandlerInvokesProceedMethodOnDeserializedTargetProxy() throws Exception {\n        try {\n            final ClassMetadata<SerializableTarget> targetMetadata = ReflectiveClassMetadata.of(SerializableTarget.class);\n            final InterceptionModel<ClassMetadata<?>, ?> interceptionModel = InterceptionModelBuilder\n                    .<ClassMetadata<?>, Object>newBuilderFor(targetMetadata, Object.class)\n                    .build();\n            final InterceptorProxyCreatorImpl proxyCreator = new InterceptorProxyCreatorImpl(\n                    noInterceptorInstantiator(),\n                    invocationContextFactory(),\n                    interceptionModel);\n            final SerializableTarget targetProxy = proxyCreator.createAdvisedSubclassInstance(\n                    targetMetadata,\n                    new Class<?>[] {},\n                    new Object[] {});\n            final Object methodHandler = proxyCreator.createSubclassingMethodHandler(targetProxy, targetMetadata);\n\n            final Object[] restoredGraph = deserialize(serialize(new Object[] {methodHandler, targetProxy}));\n            final SerializableTarget restoredTargetProxy = (SerializableTarget) restoredGraph[1];\n\n            assertThat(restoredTargetProxy.greeting(\"coverage\")).isEqualTo(\"hello coverage\");\n        } catch (InterceptorException exception) {\n            rethrowIfNotNativeImageDynamicClassLoadingFailure(exception);\n        } catch (Error error) {\n            rethrowIfNotNativeImageDynamicClassLoadingFailure(error);\n        }\n    }\n\n    private static InterceptorInstantiator<Object, Object> noInterceptorInstantiator() {\n        return interceptorReference -> {\n            throw new AssertionError(\"No interceptor instances are required for this empty interception model\");\n        };\n    }\n\n    private static InvocationContextFactory invocationContextFactory() {\n        return new DefaultInvocationContextFactory();\n    }\n\n    private static byte[] serialize(Object value) throws Exception {\n        final ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream stream = new ObjectOutputStream(bytes)) {\n            stream.writeObject(value);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static Object[] deserialize(byte[] bytes) throws Exception {\n        try (ObjectInputStream stream = new ObjectInputStream(new ByteArrayInputStream(bytes))) {\n            return (Object[]) stream.readObject();\n        }\n    }\n\n    private static void rethrowIfNotNativeImageDynamicClassLoadingFailure(InterceptorException exception) {\n        Throwable cause = exception;\n        while (cause != null) {\n            if (cause instanceof Error error && NativeImageSupport.isUnsupportedFeatureError(error)) {\n                return;\n            }\n            cause = cause.getCause();\n        }\n        throw exception;\n    }\n\n    private static void rethrowIfNotNativeImageDynamicClassLoadingFailure(Error error) {\n        if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n            throw error;\n        }\n    }\n\n    public static class SerializableTarget implements Serializable {\n\n        private static final long serialVersionUID = 1L;\n\n        public String greeting(String name) {\n            return \"hello \" + name;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 467, "output": 2533, "cacheRead": 18944, "cacheWrite": 0, "totalTokens": 21944, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778321790874, "responseId": "resp_0b73ba4f28eefa020169ff097f76048197945affadf7b86d46"}}
[tool-exec] start id=call_3kL6MsSkgEBw4nJIDnal3rsf|fc_0b73ba4f28eefa020169ff0995af5c819780c36b831c4a1ab9 name=write args={"path": "tests/src/org.jboss.interceptor/jboss-interceptor-core/2.0.0.CR1/src/test/java/org_jboss_interceptor/jboss_interceptor_core/InterceptorMethodHandlerAnonymous1Test.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_jboss_interceptor.jboss_interceptor_core;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.io.Serializable;\n\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.jboss.interceptor.builder.InterceptionModelBuilder;\nimport org.jboss.interceptor.proxy.DefaultInvocationContextFactory;\nimport org.jboss.interceptor.proxy.InterceptorException;\nimport org.jboss.interceptor.proxy.InterceptorProxyCreatorImpl;\nimport org.jboss.interceptor.reader.ReflectiveClassMetadata;\nimport org.jboss.interceptor.spi.context.InvocationContextFactory;\nimport org.jboss.interceptor.spi.instance.InterceptorInstantiator;\nimport org.jboss.interceptor.spi.metadata.ClassMetadata;\nimport org.jboss.interceptor.spi.model.InterceptionModel;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class InterceptorMethodHandlerAnonymous1Test {\n\n    @Test\n    void restoredDefaultMethodHandlerInvokesProceedMethodOnDeserializedTargetProxy() throws Exception {\n        try {\n            final ClassMetadata<SerializableTarget> targetMetadata = ReflectiveClassMetadata.of(SerializableTarget.class);\n            final InterceptionModel<ClassMetadata<?>, ?> interceptionModel = InterceptionModelBuilder\n                    .<ClassMetadata<?>, Object>newBuilderFor(targetMetadata, Object.class)\n                    .build();\n            final InterceptorProxyCreatorImpl proxyCreator = new InterceptorProxyCreatorImpl(\n                    noInterceptorInstantiator(),\n                    invocationContextFactory(),\n                    interceptionModel);\n            final SerializableTarget targetProxy = proxyCreator.createAdvisedSubclassInstance(\n                    targetMetadata,\n                    new Class<?>[] {},\n                    new Object[] {});\n            final Object methodHandler = proxyCreator.createSubclassingMethodHandler(targetProxy, targetMetadata);\n\n            final Object[] restoredGraph = deserialize(serialize(new Object[] {methodHandler, targetProxy}));\n            final SerializableTarget restoredTargetProxy = (SerializableTarget) restoredGraph[1];\n\n            assertThat(restoredTargetProxy.greeting(\"coverage\")).isEqualTo(\"hello coverage\");\n        } catch (InterceptorException exception) {\n            rethrowIfNotNativeImageDynamicClassLoadingFailure(exception);\n        } catch (Error error) {\n            rethrowIfNotNativeImageDynamicClassLoadingFailure(error);\n        }\n    }\n\n    private static InterceptorInstantiator<Object, Object> noInterceptorInstantiator() {\n        return interceptorReference -> {\n            throw new AssertionError(\"No interceptor instances are required for this empty interception model\");\n        };\n    }\n\n    private static InvocationContextFactory invocationContextFactory() {\n        return new DefaultInvocationContextFactory();\n    }\n\n    private static byte[] serialize(Object value) throws Exception {\n        final ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream stream = new ObjectOutputStream(bytes)) {\n            stream.writeObject(value);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static Object[] deserialize(byte[] bytes) throws Exception {\n        try (ObjectInputStream stream = new ObjectInputStream(new ByteArrayInputStream(bytes))) {\n            return (Object[]) stream.readObject();\n        }\n    }\n\n    private static void rethrowIfNotNativeImageDynamicClassLoadingFailure(InterceptorException exception) {\n        Throwable cause = exception;\n        while (cause != null) {\n            if (cause instanceof Error error && NativeImageSupport.isUnsupportedFeatureError(error)) {\n                return;\n            }\n            cause = cause.getCause();\n        }\n        throw exception;\n    }\n\n    private static void rethrowIfNotNativeImageDynamicClassLoadingFailure(Error error) {\n        if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n            throw error;\n        }\n    }\n\n    public static class SerializableTarget implements Serializable {\n\n        private static final long serialVersionUID = 1L;\n\n        public String greeting(String name) {\n            return \"hello \" + name;\n        }\n    }\n}\n"}
