                                            <name>REST Assured: BOM</name>
                                            <description>Centralized dependencyManagement for the Rest Assured Project</description>
                                            <properties>
                                                <skipStagingRepositoryClose>true</skipStagingRepositoryClose>
                                                <sonar.skip>true</sonar.skip>
