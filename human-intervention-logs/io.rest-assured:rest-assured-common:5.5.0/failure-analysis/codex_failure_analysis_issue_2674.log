ions.assertThat\\nimport static org.junit.jupiter.api.Assertions.assertThrows\\n\\npublic class AssertParameterTest {\\n    @Test\\n    void returnsNonNullValueWhenClassParameterIsSupplied() {\\n        String value = AssertParameter.notNull('payload', String)\\n\\n        assertThat(value).isEqualTo('payload')\\n    }\\n\\n    @Test\\n    void rejectsNullValueUsingClassSimpleName() {\\n        IllegalArgumentException exception = assertThrows(IllegalArgumentException) {\\n            AssertParameter.notNull(null, AssertParameterTest)\\n        }\\n\\n        assertThat(exception).hasMessage('AssertParameterTest cannot be null')\\n    }\\n\\n    @Test\\n    void resolvesClassNameWithGroovyClassResolver() {\\n        Method classResolver = AssertParameter.getDeclaredMethod('class$', String)\\n        classResolver.setAccessible(true)\\n\\n        Class<?> resolvedClass = classResolver.invoke(null, AssertParameter.name) as Class<?>\\n\\n        assertThat(resolvedClass).isSameAs(AssertParameter)\\n    }\\n}\\n== tests/src/io.rest-assured/rest-assured-common/5.5.0/src/test/groovy/io_rest_assured/rest_assured_common/AssertionSupportAnonymous1Test.groovy ==\\n/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage io_rest_assured.rest_assured_common\\n\\nimport io.restassured.internal.common.assertion.AssertionSupport\\nimport io.restassured.internal.common.assertion.PathFragmentEscaper\\nimport org.junit.jupiter.api.Test\\n\\nimport static org.assertj.core.api.Assertions.assertThat\\n\\npublic class AssertionSupportAnonymous1Test {\\n    @Test\\n    void escapesHyphenatedPathFragments() {\\n        PathFragmentEscaper escaper = AssertionSupport.hyphen() as PathFragmentEscaper\\n\\n        assertThat(escaper.shouldEscape('item-name')).isTrue()\\n        assertThat(escaper.shouldEscape(\\\"'item-name'\\\")).