onymous1Test.groovy ==\n/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_rest_assured.rest_assured_common\n\nimport io.restassured.internal.common.assertion.AssertionSupport\nimport io.restassured.internal.common.assertion.PathFragmentEscaper\nimport org.junit.jupiter.api.Test\n\nimport static org.assertj.core.api.Assertions.assertThat\n\npublic class AssertionSupportAnonymous1Test {\n    @Test\n    void escapesHyphenatedPathFragments() {\n        PathFragmentEscaper escaper = AssertionSupport.hyphen() as PathFragmentEscaper\n\n        assertThat(escaper.shouldEscape('item-name')).isTrue()\n        assertThat(escaper.shouldEscape(\"'item-name'\")).isFalse()\n        assertThat(escaper.shouldEscape('items[-1]')).isFalse()\n        assertThat(escaper.escape('item-name[0]')).isEqualTo(\"'item-name'[0]\")\n    }\n}\n== tests/src/io.rest-assured/rest-assured-common/5.5.0/src/test/groovy/io_rest_assured/rest_assured_common/AssertionSupportAnonymous2Test.groovy ==\n/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_rest_assured.rest_assured_common\n\nimport io.restassured.internal.common.assertion.AssertionSupport\nimport io.restassured.internal.common.assertion.PathFragmentEscaper\nimport org.junit.jupiter.api.Test\n\nimport java.lang.invoke.MethodHandle\nimport java.lang.invoke.MethodHandles\nimport java.lang.invoke.MethodType\n\nimport static org.assertj.core.api.Assertions.assertThat\n\npublic class AssertionSupportAnonymous2Test {\n    @Test\n    void escapesPropertiesPathFragmentsWithGetAtSyntax() {\n        PathFragmentEscaper escaper = AssertionSupport.properties() as PathFragmentEscaper\n\n        assertThat(escaper.shouldEscape('properties')).isTrue()\n        assertThat(escaper.shouldEscape('response.properties')).isTrue()\n        assertThat(escaper.shouldEscape(\"'properties'\")).isFalse()\n        assertThat(escaper.shouldEscape('properties[0]')).isFalse()\n        assertThat(escaper.shouldEscape('properties value')).isFalse()\n        assertThat(escaper.escape('properties')).isEqualTo(\"getAt('properties')\")\n    }\n\n    @Test\n    void appliesPropertiesEscaperWhenEscapingFullPath() {\n        String escapedPath = AssertionSupport.escapePath(\n                'response.properties.value',\n                AssertionSupport.properties()) as String\n\n        assertThat(escapedPath).isEqualTo(\"response.getAt('properties').value\")\n    }\n\n    @Test\n    void resolvesTypesThroughGeneratedClassLiteralHelperOnPropertiesEscaperClass() {\n        PathFragmentEscaper escaper = AssertionSupport.properties() as PathFragmentEscaper\n        Class<?> escaperType = escaper.getClass()\n        MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(escaperType, MethodHandles.lookup())\n        MethodHandle classLookup = lookup.findStatic(escaperType, 'class$', MethodType.methodType(Class, String))\n\n        Class<?> resolvedType = classLookup.invokeWithArguments('java.lang.String') as Class<?>\n\n        assertThat(resolvedType).isSameAs(String)\n    }\n}\n== tests/src/io.rest-assured/rest-assured-common/5.5.0/src/test/groovy/io_rest_assured/rest_assured_common/AssertionSupportAnonymous3Test.groovy ==\n/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_rest_assured.rest_assured_common\n\nimport io.restassured.internal.common.assertion.AssertionSupport\nimport io.restassured.internal.common.assertion.PathFragmentEscaper\nimport org.junit.jupiter.api.Test\n\nimport static org.assertj.core.api.Assertions.assertThat\n\npublic class AssertionSupportAnonymous3Test {\n    @Test\n    void escapesClassKeywordPathFragmentsWithGetAtSyntax() {\n        PathFragmentEscaper escaper = AssertionSupport.classKeyword() as PathFragmentEscaper\n\n        assertThat(escaper.shouldEscape('class')).isTrue()\n        assertThat(escaper.shouldEscape('response.class')).isTrue()\n        assertThat(escaper.shouldEscape(\"'class'\")).isFalse()\n        assertThat(escaper.shouldEscape('class[0]')).isFalse()\n        assertThat(escaper.shouldEscape('class value')).isFalse()\n        assertThat(escaper.escape('class')).isEqualTo(\"getAt('class')\")\n    }\n\n    @Test\n    void appliesClassKeywordEscaperWhenEscapingFullPath() {\n        String escapedPath = AssertionSupport.escapePath(\n                'response.class.name',\n                AssertionSupport.classKeyword()) as String\n\n        assertThat(escapedPath).isEqualTo(\"response.getAt('class').name\")\n    }\n\n    @Test\n    void leavesClassKeywordFragmentsUntouchedWhenTheyArePartOfUnsupportedExpressions() {\n        PathFragmentEscaper escaper = AssertionSupport.classKeyword() as PathFragmentEscaper\n\n        assertThat(escaper.shouldEscape('class[0]')).isFalse()\n        assertThat(escaper.shouldEscape('class value')).isFalse()\n        assertThat(escaper.shouldEscape('class.find { it.simpleName }')).isFalse()\n        assertThat(escaper.shouldEscape('class()')).isFalse()\n    }\n}\n== tests/src/io.rest-assured/rest-assured-common/5.5.0/src/test/groovy/io_rest_assured/rest_assured_common/AssertionSupportAnonymous4Test.groovy ==\n/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_rest_assured.rest_assured_common\n\nimport io.restassured.internal.common.assertion.AssertionSupport\nimport io.restassured.internal.common.assertion.PathFragmentEscaper\nimport org.junit.jupiter.api.Test\n\nimport static org.assertj.core.api.Assertions.assertThat\n\npublic class AssertionSupportAnonymous4Test {\n    @Test\n    void escapesAttributeGetterPathFragmentsWithQuotedSyntax() {\n        PathFragmentEscaper escaper = AssertionSupport.attributeGetter() as PathFragmentEscaper\n\n        assertThat(escaper.shouldEscape('@id')).isTrue()\n        assertThat(escaper.shouldEscape('@type')).isTrue()\n        assertThat(escaper.shouldEscape(\"'@id'\")).isFalse()\n        assertThat(escaper.shouldEscape('@id value')).isFalse()\n        assertThat(escaper.shouldEscape('@id.find { it != null }')).isFalse()\n        assertThat(escaper.escape('@id')).isEqualTo(\"'@id'\")\n    }\n\n    @Test\n    void appliesAttributeGetterEscaperWhenEscapingFullPath() {\n        String escapedPath = AssertionSupport.escapePath(\n                'response.@id.item.@type',\n                AssertionSupport.attributeGetter()) as String\n\n        assertThat(escapedPath).isEqualTo(\"response.'@id'.item.'@type'\")\n    }\n}\n== tests/src/io.rest-assured/rest-assured-common/5.5.0/src/test/groovy/io_rest_assured/rest_assured_common/AssertionSupportAnonymous5Test.groovy ==\n/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_rest_assured.rest_assured_common\n\nimport io.restassured.internal.common.assertion.AssertionSupport\nimport io.restassured.internal.common.assertion.PathFragmentEscaper\nimport org.junit.jupiter.api.Test\n\nimport static org.assertj.core.api.Assertions.assertThat\n\npublic class AssertionSupportAnonymous5Test {\n    @Test\n    void escapesDoubleStarPathFragmentsWithQuotedSyntax() {\n        PathFragmentEscaper escaper = AssertionSupport.doubleStar() as PathFragmentEscaper\n\n        assertThat(escaper.shouldEscape('**')).isTrue()\n        assertThat(escaper.shouldEscape('*')).isFalse()\n        assertThat(escaper.shouldEscape('items**')).isFalse()\n        assertThat(escaper.escape('**')).isEqualTo(\"'**'\")\n    }\n\n    @Test\n    void appliesDoubleStarEscaperWhenEscapingFullPath() {\n        String escapedPath = AssertionSupport.escapePath(\n                'store.**.name',\n                AssertionSupport.doubleStar()) as String\n\n        assertThat(escapedPath).isEqualTo(\"store.'**'.name\")\n    }\n}\n== tests/src/io.rest-assured/rest-assured-common/5.5.0/src/test/groovy/io_rest_assured/rest_assured_common/AssertionSupportAnonymous6Test.groovy ==\n/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_rest_assured.rest_assured_common\n\nimport io.restassured.internal.common.assertion.AssertionSupport\nimport io.restassured.internal.common.assertion.PathFragmentEscaper\nimport org.junit.jupiter.api.Test\n\nimport static org.assertj.core.api.Assertions.assertThat\n\npublic class AssertionSupportAnonymous6Test {\n    @Test\n    void escapesColonPathFragmentsWithQuotedSyntax() {\n        PathFragmentEscaper escaper = AssertionSupport.colon() as PathFragmentEscaper\n\n        assertThat(escaper.shouldEscape('http://example.com')).isTrue()\n        assertThat(escaper.shouldEscape('items:name')).isTrue()\n        assertThat(escaper.shouldEscape(\"'items:name'\")).isFalse()\n        assertThat(escaper.shouldEscape('items:name()')).isFalse()\n        assertThat(escaper.shouldEscape('items:name.find { it != null }')).isFalse()\n        assertThat(escaper.escape('items:name[0]')).isEqualTo(\"'items:name'[0]\")\n    }\n\n    @Test\n    void appliesColonEscaperWhenEscapingFullPath() {\n        String escapedPath = AssertionSupport.escapePath(\n                'response.items:name.value',\n                AssertionSupport.colon()) as String\n\n        assertThat(escapedPath).isEqualTo(\"response.'items:name'.value\")\n    }\n}\n== tests/src/io.rest-assured/rest-assured-common/5.5.0/src/test/groovy/io_rest_assured/rest_assured_common/AssertionSupportAnonymous7Test.groovy ==\n/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_rest_assured.rest_assured_common\n\nimport io.restassured.internal.common.assertion.AssertionSupport\nimport io.restassured.internal.common.assertion.PathFragmentEscaper\nimport org.junit.jupiter.api.Test\n\nimport static org.assertj.core.api.Assertions.assertThat\n\npublic class AssertionSupportAnonymous7Test {\n    @Test\n    void escapesIntegerPathFragmentsWithQuotedSyntax() {\n        PathFragmentEscaper escaper = AssertionSupport.integer() as PathFragmentEscaper\n\n        assertThat(escaper.shouldEscape('2024')).isTrue()\n        assertThat(escaper.shouldEscape('1stPlace')).isTrue()\n        assertThat(escaper.shouldEscape('item2')).isFalse()\n        assertThat(escaper.shouldEscape('2024 value')).isFalse()\n        assertThat(escaper.shouldEscape('2024[0]')).isFalse()\n        assertThat(escaper.shouldEscape('2024()')).isFalse()\n        assertThat(escaper.escape('2024')).isEqualTo(\"'2024'\")\n    }\n\n    @Test\n    void appliesIntegerEscaperWhenEscapingFullPath() {\n        String escapedPath = AssertionSupport.escapePath(\n                'store.2024.1stPlace.item2',\n                AssertionSupport.integer()) as String\n\n        assertThat(escapedPath).isEqualTo(\"store.'2024'.'1stPlace'.item2\")\n    }\n}\n== tests/src/io.rest-assured/rest-assured-common/5.5.0/src/test/groovy/io_rest_assured/rest_assured_common/AssertionSupportTest.groovy ==\n/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_rest_assured.rest_assured_common\n\nimport io.restassured.internal.common.assertion.AssertionSupport\nimport org.junit.jupiter.api.Test\n\nimport static org.assertj.core.api.Assertions.assertThat\n\npublic class AssertionSupportTest {\n    @Test\n    void escapesPathFragmentsWithSupportedEscapers() {\n        String escapedPath = AssertionSupport.escapePath(\n                'store.item-name.properties.class.@id.2024',\n                AssertionSupport.hyphen(),\n                AssertionSupport.properties(),\n                AssertionSupport.classKeyword(),\n                AssertionSupport.attributeGetter(),\n                AssertionSupport.integer()) as String\n\n        assertThat(escapedPath).isEqualTo(\"store.'item-name'.getAt('properties').getAt('class').'@id'.'2024'\")\n    }\n\n    @Test\n    void generatesWhitespaceForPositiveCounts() {\n        assertThat(AssertionSupport.generateWhitespace(3)).isEqualTo('   ')\n        assertThat(AssertionSupport.generateWhitespace(0)).isEqualTo('')\n    }\n\n    @Test\n    void leavesAlreadySafePathFragmentsUntouched() {\n        String escapedPath = AssertionSupport.escapePath(\n                \"store.'item-name'.items[0].find { it.name == 'tea' }\",\n                AssertionSupport.hyphen(),\n                AssertionSupport.properties(),\n                AssertionSupport.classKeyword(),\n                AssertionSupport.attributeGetter(),\n                AssertionSupport.doubleStar(),\n                AssertionSupport.colon(),\n                AssertionSupport.integer()) as String\n\n        assertThat(escapedPath).isEqualTo(\"store.'item-name'.items[0].find { it.name == 'tea' }\")\n    }\n}\n== tests/src/io.rest-assured/rest-assured-common/5.5.0/src/test/groovy/io_rest_assured/rest_assured_common/ClassPathResolverTest.groovy ==\n/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_rest_assured.rest_assured_common\n\nimport io.restassured.internal.common.classpath.ClassPathResolver\nimport org.junit.jupiter.api.Test\n\nimport static org.assertj.core.api.Assertions.assertThat\n\npublic class ClassPathResolverTest {\n    @Test\n    void detectsClassesAvailableToTheApplicationClassLoader() {\n        assertThat(ClassPathResolver.existInCP(ClassPathResolver.name)).isTrue()\n        assertThat(ClassPathResolver.existInCP(String.name)).isTrue()\n    }\n\n    @Test\n    void returnsFalseForClassesThatAreNotOnTheClasspath() {\n        assertThat(ClassPathResolver.existInCP('example.missing.TypeNotPresentOnTheClasspath')).isFalse()\n    }\n}\n== tests/src/io.rest-assured/rest-assured-common/5.5.0/src/test/groovy/io_rest_assured/rest_assured_common/EndToEndQuoteFragmentEscaperTest.groovy ==\n/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_rest_assured.rest_assured_common\n\nimport io.restassured.internal.common.assertion.EndToEndQuoteFragmentEscaper\nimport io.restassured.internal.common.assertion.PathFragmentEscaper\nimport org.junit.jupiter.api.Test\n\nimport static org.assertj.core.api.Assertions.assertThat\n\npublic class EndToEndQuoteFragmentEscaperTest {\n    @Test\n    void quotesCompletePathFragments() {\n        PathFragmentEscaper escaper = new EndToEndQuoteFragmentEscaper() {\n            @Override\n            boolean shouldEscape(String pathFragment) {\n                pathFragment == 'customer-id'\n            }\n        }\n\n        assertThat(escaper.shouldEscape('customer-id')).isTrue()\n        assertThat(escaper.shouldEscape('customer')).isFalse()\n        assertThat(escaper.escape('customer-id')).isEqualTo(\"'customer-id'\")\n    }\n}\n== tests/src/io.rest-assured/rest-assured-common/5.5.0/src/test/groovy/io_rest_assured/rest_assured_common/GetAtPathFragmentEscaperTest.groovy ==\n/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_rest_assured.rest_assured_common\n\nimport io.restassured.internal.common.assertion.AssertionSupport\nimport io.restassured.internal.common.assertion.GetAtPathFragmentEscaper\nimport io.restassured.internal.common.assertion.PathFragmentEscaper\nimport org.junit.jupiter.api.Test\n\nimport static org.assertj.core.api.Assertions.assertThat\n\npublic class GetAtPathFragmentEscaperTest {\n    @Test\n    void escapesSupportedPathFragmentsWithGetAtSyntax() {\n        PathFragmentEscaper propertiesEscaper = AssertionSupport.properties() as PathFragmentEscaper\n        PathFragmentEscaper classKeywordEscaper = AssertionSupport.classKeyword() as PathFragmentEscaper\n\n        assertThat(propertiesEscaper).isInstanceOf(GetAtPathFragmentEscaper)\n        assertThat(propertiesEscaper.shouldEscape('properties')).isTrue()\n        assertThat(propertiesEscaper.shouldEscape('properties[0]')).isFalse()\n        assertThat(propertiesEscaper.escape('properties')).isEqualTo(\"getAt('properties')\")\n\n        assertThat(classKeywordEscaper).isInstanceOf(GetAtPathFragmentEscaper)\n        assertThat(classKeywordEscaper.shouldEscape('class')).isTrue()\n        assertThat(classKeywordEscaper.shouldEscape(\"'class'\")).isFalse()\n        assertThat(classKeywordEscaper.escape('class')).isEqualTo(\"getAt('class')\")\n    }\n\n    @Test\n    void resolvesTypesThroughGeneratedClassLiteralHelper() {\n        Class<?> resolvedType = invokeSyntheticClassLookup(GetAtPathFragmentEscaper.name)\n\n        assertThat(resolvedType).isSameAs(GetAtPathFragmentEscaper)\n    }\n\n    private static Class<?> invokeSyntheticClassLookup(String className) {\n        return GetAtPathFragmentEscaper.'class$'(className) as Class<?>\n    }\n}\n== tests/src/io.rest-assured/rest-assured-common/5.5.0/src/test/groovy/io_rest_assured/rest_assured_common/HyphenQuoteFragmentEscaperTest.groovy ==\n/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_rest_assured.rest_assured_common\n\nimport io.restassured.internal.common.assertion.AssertionSupport\nimport io.restassured.internal.common.assertion.HyphenQuoteFragmentEscaper\nimport io.restassured.internal.common.assertion.PathFragmentEscaper\nimport org.codehaus.groovy.runtime.ScriptBytecodeAdapter\nimport org.junit.jupiter.api.Test\n\nimport static org.assertj.core.api.Assertions.assertThat\n\npublic class HyphenQuoteFragmentEscaperTest {\n    @Test\n    void quotesEscapedFragmentsAndPreservesCollectionIndexLookups() {\n        PathFragmentEscaper hyphenEscaper = AssertionSupport.hyphen() as PathFragmentEscaper\n        PathFragmentEscaper colonEscaper = AssertionSupport.colon() as PathFragmentEscaper\n\n        assertThat(hyphenEscaper).isInstanceOf(HyphenQuoteFragmentEscaper)\n        assertThat(hyphenEscaper.escape('item-name')).isEqualTo(\"'item-name'\")\n        assertThat(hyphenEscaper.escape('item-name[0]')).isEqualTo(\"'item-name'[0]\")\n\n        assertThat(colonEscaper).isInstanceOf(HyphenQuoteFragmentEscaper)\n        assertThat(colonEscaper.escape('items:name')).isEqualTo(\"'items:name'\")\n        assertThat(colonEscaper.escape('items:name[1]')).isEqualTo(\"'items:name'[1]\")\n    }\n\n    @Test\n    void resolvesClassNameWithGeneratedGroovyDispatch() {\n        Class<?> resolvedType = ScriptBytecodeAdapter.invokeStaticMethodN(\n                HyphenQuoteFragmentEscaper,\n                HyphenQuoteFragmentEscaper,\n                'class$',\n                [HyphenQuoteFragmentEscaper.name] as Object[]) as Class<?>\n\n        assertThat(resolvedType).isSameAs(HyphenQuoteFragmentEscaper)\n    }\n}\n== tests/src/io.rest-assured/rest-assured-common/5.5.0/src/test/groovy/io_rest_assured/rest_assured_common/ObjectConverterTest.groovy ==\n/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_rest_assured.rest_assured_common\n\nimport io.restassured.internal.common.path.ObjectConverter\nimport org.junit.jupiter.api.Test\n\nimport java.math.BigDecimal\nimport java.util.UUID\n\nimport static org.assertj.core.api.Assertions.assertThat\n\npublic class ObjectConverterTest {\n    @Test\n    void convertsTextValuesToSupportedTargetTypes() {\n        UUID uuid = UUID.fromString('123e4567-e89b-12d3-a456-426614174000')\n\n        assertThat(ObjectConverter.convertObjectTo('42', Integer)).isEqualTo(42)\n        assertThat(ObjectConverter.convertObjectTo('true', Boolean)).isEqualTo(true)\n        assertThat(ObjectConverter.convertObjectTo('A', Character)).isEqualTo('A' as Character)\n        assertThat(ObjectConverter.convertObjectTo('7', Byte)).isEqualTo((byte) 7)\n        assertThat(ObjectConverter.convertObjectTo('8', Short)).isEqualTo((short) 8)\n        assertThat(ObjectConverter.convertObjectTo('1.5', Float)).isEqualTo(1.5f)\n        assertThat(ObjectConverter.convertObjectTo('2.5', Double)).isEqualTo(2.5d)\n        assertThat(ObjectConverter.convertObjectTo('9000', Long)).isEqualTo(9000L)\n        assertThat(ObjectConverter.convertObjectTo('12.75', BigDecimal)).isEqualByComparingTo(new BigDecimal('12.75'))\n        assertThat(ObjectConverter.convertObjectTo(123, String)).isEqualTo('123')\n        assertThat(ObjectConverter.convertObjectTo(uuid.toString(), UUID)).isEqualTo(uuid)\n    }\n\n    @Test\n    void returnsNullWhenConvertingNullValue() {\n        assertThat(ObjectConverter.convertObjectTo(null, String)).isNull()\n    }\n\n    @Test\n    void returnsOriginalValueWhenItAlreadyMatchesTargetType() {\n        String value = 'unchanged'\n\n        assertThat(ObjectConverter.convertObjectTo(value, String)).isSameAs(value)\n    }\n\n    @Test\n    void reportsWhetherValuesCanBeConverted() {\n        assertThat(ObjectConverter.canConvert('11', Integer)).isTrue()\n        assertThat(ObjectConverter.canConvert('not-a-number', Integer)).isFalse()\n    }\n}\n","exit_code":0,"status":"completed"}}
