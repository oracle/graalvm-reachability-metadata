  package io_rest_assured.rest_assured_common;
  
  import static org.junit.jupiter.api.Assertions.assertEquals;
  import static org.junit.jupiter.api.Assertions.assertFalse;
  import static org.junit.jupiter.api.Assertions.assertSame;
  import static org.junit.jupiter.api.Assertions.assertTrue;
  
  import java.lang.invoke.MethodHandle;
  import java.lang.invoke.MethodHandles;
  import java.lang.invoke.MethodType;
  
  import io.restassured.internal.common.assertion.AssertionSupport;
  import io.restassured.internal.common.assertion.PathFragmentEscaper;
  import org.junit.jupiter.api.Test;
  
  public class AssertionSupportAnonymous3Test {
      @Test
      void classKeywordEscaperOnlyEscapesUnquotedSimpleClassPathFragments() {
          PathFragmentEscaper escaper = (PathFragmentEscaper) AssertionSupport.classKeyword();
  
          assertTrue(escaper.shouldEscape("class"));
          assertTrue(escaper.shouldEscape("userclass"));
          assertFalse(escaper.shouldEscape("'class'"));
          assertFalse(escaper.shouldEscape("class[0]"));
      }
  
      @Test
      void classKeywordEscaperWrapsMatchingFragmentsWithGetAtAccess() {
          PathFragmentEscaper escaper = (PathFragmentEscaper) AssertionSupport.classKeyword();
  
          String escaped = escaper.escape("class");
  
          assertEquals("getAt('class')", escaped);
      }
  
      @Test
      void syntheticClassLookupCanResolveClassKeywordEscaperImplementationClassName() throws Throwable {
          PathFragmentEscaper escaper = (PathFragmentEscaper) AssertionSupport.classKeyword();
          Class<?> escaperClass = escaper.getClass();
          MethodHandle syntheticClassLookup = MethodHandles.privateLookupIn(escaperClass, MethodHandles.lookup())
                  .findStatic(escaperClass, "class$", MethodType.methodType(Class.class, String.class));
  
          Class<?> resolvedClass = (Class<?>) syntheticClassLookup.invoke(escaperClass.getName());
  
          assertSame(escaperClass, resolvedClass);
      }
  }
