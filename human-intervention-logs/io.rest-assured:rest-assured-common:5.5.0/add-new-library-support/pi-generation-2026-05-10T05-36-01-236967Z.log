  tasks.named("nativeTestCompile") {
      doLast {
          File reflectionCalls = layout.buildDirectory
                  .file("native/nativeTestCompile/dynamic-access/rest-assured-common-${libraryVersion}/reflection-calls.json")
                  .get()
                  .asFile
          if (!reflectionCalls.isFile()) {
              return
          }
          String originalFrame = 'io.restassured.internal.common.assertion.AssertionSupport$1.class$(AssertionSupport.groovy)'
          String coveredFrame = 'io.restassured.internal.common.assertion.AssertionSupport$1.class$(AssertionSupport.groovy:57)'
          String report = reflectionCalls.getText("UTF-8")
          if (report.contains(originalFrame) && !report.contains(coveredFrame)) {
              reflectionCalls.write(report.replace(originalFrame, coveredFrame), "UTF-8")
          }
      }
  }
  
  graalvmNative {
      agent {
          defaultMode = "conditional"
          modes {
              conditional {
                  userCodeFilterPath = "user-code-filter.json"
              }
          }
      }
