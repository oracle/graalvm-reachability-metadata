  package io_rest_assured.rest_assured_common;
  
  import static org.junit.jupiter.api.Assertions.assertEquals;
  import static org.junit.jupiter.api.Assertions.assertSame;
  import static org.junit.jupiter.api.Assertions.assertThrows;
  
  import java.lang.invoke.MethodHandle;
  import java.lang.invoke.MethodHandles;
  import java.lang.invoke.MethodType;
  
  import io.restassured.internal.common.assertion.AssertParameter;
  import org.junit.jupiter.api.Test;
  
  public class AssertParameterTest {
      @Test
      void notNullWithClassParameterReturnsTheOriginalObject() {
          String value = "value";
  
          String result = AssertParameter.notNull(value, AssertParameterTest.class);
  
          assertSame(value, result);
      }
  
      @Test
      void notNullWithClassParameterUsesTheClassNameInTheFailureMessage() {
          IllegalArgumentException exception = assertThrows(
                  IllegalArgumentException.class,
                  () -> AssertParameter.notNull(null, AssertParameterTest.class));
  
          assertEquals("AssertParameterTest cannot be null", exception.getMessage());
      }
  
      @Test
      void syntheticClassLookupCanResolveARestAssuredClassName() throws Throwable {
          String pathExceptionClassName = "io.restassured.common.exception.PathException";
          MethodHandle classLookup = MethodHandles.privateLookupIn(AssertParameter.class, MethodHandles.lookup())
                  .findStatic(AssertParameter.class, "class$", MethodType.methodType(Class.class, String.class));
  
          Class<?> resolvedClass = (Class<?>) classLookup.invoke(pathExceptionClassName);
  
