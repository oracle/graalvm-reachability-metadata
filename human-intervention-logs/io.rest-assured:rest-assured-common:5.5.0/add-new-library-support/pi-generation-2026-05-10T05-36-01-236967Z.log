  package io_rest_assured.rest_assured_common;
  
  import static org.junit.jupiter.api.Assertions.assertEquals;
  import static org.junit.jupiter.api.Assertions.assertFalse;
  import static org.junit.jupiter.api.Assertions.assertSame;
  import static org.junit.jupiter.api.Assertions.assertTrue;
  
  import java.lang.reflect.Method;
  
  import io.restassured.internal.common.assertion.AssertionSupport;
  import io.restassured.internal.common.assertion.PathFragmentEscaper;
  import org.junit.jupiter.api.Test;
  
  public class AssertionSupportAnonymous2Test {
      @Test
      void propertiesEscaperOnlyEscapesUnquotedSimplePropertiesPathFragments() {
          PathFragmentEscaper escaper = (PathFragmentEscaper) AssertionSupport.properties();
  
          assertTrue(escaper.shouldEscape("properties"));
          assertTrue(escaper.shouldEscape("userproperties"));
          assertFalse(escaper.shouldEscape("'properties'"));
          assertFalse(escaper.shouldEscape("properties[0]"));
      }
  
      @Test
      void propertiesEscaperWrapsMatchingFragmentsWithGetAtAccess() {
          PathFragmentEscaper escaper = (PathFragmentEscaper) AssertionSupport.properties();
  
          String escaped = escaper.escape("properties");
  
          assertEquals("getAt('properties')", escaped);
      }
  
      @Test
      void syntheticClassLookupCanResolvePropertiesEscaperImplementationClassName() throws Throwable {
          PathFragmentEscaper escaper = (PathFragmentEscaper) AssertionSupport.properties();
          Class<?> escaperClass = escaper.getClass();
          Method syntheticClassLookup = escaperClass.getDeclaredMethod("class$", String.class);
          syntheticClassLookup.setAccessible(true);
  
          Class<?> resolvedClass = (Class<?>) syntheticClassLookup.invoke(null, escaperClass.getName());
  
          assertSame(escaperClass, resolvedClass);
      }
  }
