aper escaper = (PathFragmentEscaper) AssertionSupport.properties();\n        Class<?> escaperClass = escaper.getClass();\n        MethodHandle classLookup = MethodHandles.privateLookupIn(escaperClass, MethodHandles.lookup())\n                .findStatic(escaperClass, \"class$\", MethodType.methodType(Class.class, String.class));\n\n        Class<?> resolvedClass = (Class<?>) classLookup.invoke(escaperClass.getName());\n\n        assertSame(escaperClass, resolvedClass);\n    }\n}\n"}
