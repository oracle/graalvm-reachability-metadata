  package io_rest_assured.rest_assured_common;
  
  import static org.junit.jupiter.api.Assertions.assertEquals;
  import static org.junit.jupiter.api.Assertions.assertSame;
  
  import java.lang.invoke.MethodHandle;
  import java.lang.invoke.MethodHandles;
  import java.lang.invoke.MethodType;
  
  import io.restassured.internal.common.assertion.AssertionSupport;
  import io.restassured.internal.common.assertion.PathFragmentEscaper;
  import org.junit.jupiter.api.Test;
  
  public class AssertionSupportTest {
      @Test
      void escapePathAppliesBuiltInEscapersToPathFragments() {
          Object escapedPath = AssertionSupport.escapePath(
                  "user-name.@id.class.properties.10.http:status.**",
                  (PathFragmentEscaper) AssertionSupport.hyphen(),
                  (PathFragmentEscaper) AssertionSupport.attributeGetter(),
                  (PathFragmentEscaper) AssertionSupport.classKeyword(),
                  (PathFragmentEscaper) AssertionSupport.properties(),
                  (PathFragmentEscaper) AssertionSupport.integer(),
                  (PathFragmentEscaper) AssertionSupport.colon(),
                  (PathFragmentEscaper) AssertionSupport.doubleStar());
  
          assertEquals("'user-name'.'@id'.getAt('class').getAt('properties').'10'.'http:status'.'**'", escapedPath);
      }
  
      @Test
      void generateWhitespaceReturnsRequestedNumberOfSpaces() {
          assertEquals("", AssertionSupport.generateWhitespace(0));
          assertEquals("   ", AssertionSupport.generateWhitespace(3));
      }
  
      @Test
      void syntheticClassLookupCanResolveAssertionSupportClassName() throws Throwable {
          String assertionSupportClassName = new StringBuilder(AssertionSupport.class.getPackageName())
                  .append('.')
                  .append(AssertionSupport.class.getSimpleName())
                  .toString();
          MethodHandle classLookup = MethodHandles.privateLookupIn(AssertionSupport.class, MethodHandles.lookup())
                  .findStatic(AssertionSupport.class, "class$", MethodType.methodType(Class.class, String.class));
  
          Class<?> resolvedClass = (Class<?>) classLookup.invoke(assertionSupportClassName);
  
          assertSame(AssertionSupport.class, resolvedClass);
      }
  }
