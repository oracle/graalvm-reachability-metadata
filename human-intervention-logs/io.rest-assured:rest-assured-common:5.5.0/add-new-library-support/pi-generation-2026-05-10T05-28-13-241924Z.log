[tool-call] delta {"path":"tests/src/io.rest-assured/rest-assured-common/5.5.0/src/test/java/io_rest_assured/rest_assured_common/AssertionSupportAnonymous1Test.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_rest_assured.rest_assured_common;\n\nimport static org.junit.jupiter.api.Assertions.assertSame;\nimport static org.junit.jupiter.api.Assertions.assertTrue;\n\nimport java.lang.invoke.MethodHandle;\nimport java.lang.invoke.MethodHandles;\nimport java.lang.invoke.MethodType;\n\nimport io.restassured.internal.common.assertion.AssertionSupport;\nimport io.restassured.internal.common.assertion.PathFragmentEscaper;\nimport org.junit.jupiter.api.Test;\n\npublic class AssertionSupportAnonymous1Test {\n    @Test\n    void hyphenEscaperDetectsUnquotedHyphenatedPathFragments() {\n        PathFragmentEscaper escaper = (PathFragmentEscaper) AssertionSupport.hyphen();\n\n        assertTrue(escaper.shouldEscape(\"user-name\"));\n    }\n\n    @Test\n    void syntheticClassLookupCanResolveHyphenEscaperImplementationClassName() throws Throwable {\n        PathFragmentEscaper escaper = (PathFragmentEscaper) AssertionSupport.hyphen();\n        Class<?> escaperClass = escaper.getClass();\n        MethodHandle classLookup = MethodHandles.privateLookupIn(escaperClass, MethodHandles.lookup())\n                .findStatic(escaperClass, \"class$\", MethodType.methodType(Class.class, String.class));\n\n        Class<?> resolvedClass = (Class<?>) classLookup.invoke(escaperClass.getName());\n\n        assertSame(escaperClass, resolvedClass);\n    }\n}\n"}
