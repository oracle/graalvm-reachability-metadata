caper\nimport org.codehaus.groovy.runtime.InvokerHelper\nimport org.junit.jupiter.api.Test\n\nimport static org.assertj.core.api.Assertions.assertThat\n\npublic class AssertionSupportAnonymous1Test {\n    @Test\n    void escapesHyphenatedPathFragments() {\n        PathFragmentEscaper escaper = AssertionSupport.hyphen() as PathFragmentEscaper\n\n        assertThat(escaper.shouldEscape('item-name')).isTrue()\n        assertThat(escaper.shouldEscape(\"'item-name'\")).isFalse()\n        assertThat(escaper.shouldEscape('items[-1]')).isFalse()\n        assertThat(escaper.escape('item-name[0]')).isEqualTo(\"'item-name'[0]\")\n    }\n\n    @Test\n    void resolvesClassThroughGroovyClassHelper() {\n        PathFragmentEscaper escaper = AssertionSupport.hyphen() as PathFragmentEscaper\n\n        Class<?> resolvedClass = InvokerHelper.invokeStaticMethod(\n                escaper.getClass(),\n                'class$',\n                String.name) as Class<?>\n\n        assertThat(resolvedClass).isSameAs(String)\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 462, "output": 1536, "cacheRead": 29696, "cacheWrite": 0, "totalTokens": 31694, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1779525983613, "responseId": "resp_0c7b5b3cfc004706016a1169604e288197aa872eb2a5741954"}}
