l.common.assertion.AssertionSupport\nimport org.junit.jupiter.api.Test\n\nimport static org.assertj.core.api.Assertions.assertThat\n\npublic class AssertionSupportTest {\n    @Test\n    void escapesPathFragmentsWithSupportedEscapers() {\n        String escapedPath = AssertionSupport.escapePath(\n                'store.item-name.properties.class.@id.2024',\n                AssertionSupport.hyphen(),\n                AssertionSupport.properties(),\n                AssertionSupport.classKeyword(),\n                AssertionSupport.attributeGetter(),\n                AssertionSupport.integer()) as String\n\n        assertThat(escapedPath).isEqualTo(\"store.'item-name'.getAt('properties').getAt('class').'@id'.'2024'\")\n    }\n\n    @Test\n    void generatesWhitespaceForPositiveCounts() {\n        assertThat(AssertionSupport.generateWhitespace(3)).isEqualTo('   ')\n        assertThat(AssertionSupport.generateWhitespace(0)).isEqualTo('')\n    }\n\n    @Test\n    void resolvesClassNameWithGroovyClassResolver() {\n        Class<?> resolvedClass = AssertionSupport.'class$'(AssertionSupport.name) as Class<?>\n\n        assertThat(resolvedClass).isSameAs(AssertionSupport)\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1957, "output": 724, "cacheRead": 22016, "cacheWrite": 0, "totalTokens": 24697, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1779525568028, "responseId": "resp_00c0bbeae979aada016a1167c0c1548197a55e8a66920073c8"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_xbeJi3dFYvIlUKZkJ6Cb8i7O|fc_00c0bbeae979aada016a1167c5e7ec8197ad752aa6a9fb7022", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1434 bytes to tests/src/io.rest-assured/rest-assured-common/5.5.0/src/test/groovy/io_rest_assured/rest_assured_common/AssertionSupportTest.groovy"}], "isError": false, "timestamp": 1779525576333}]}
