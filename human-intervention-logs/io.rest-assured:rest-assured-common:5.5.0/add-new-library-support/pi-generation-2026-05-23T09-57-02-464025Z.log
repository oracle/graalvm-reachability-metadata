ncies {\n    testImplementation \"io.rest-assured:rest-assured-common:$libraryVersion\"\n    testImplementation localGroovy()\n    testImplementation 'org.assertj:assertj-core:3.22.0'\n}\n\njava {\n    toolchain {\n        languageVersion = JavaLanguageVersion.of(21)\n    }\n}\n\ngraalvmNative {\n    agent {\n        defaultMode = \"conditional\"\n        modes {\n            conditional {\n                userCodeFilterPath = \"user-code-filter.json\"\n            }\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1779530209268}, {"role": "toolResult", "toolCallId": "call_t6PwTaxaXV2YWBCQfRgju9rn|fc_086f9a699fb2d999016a1179e1081481a387c5f714e7d80207", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_rest_assured.rest_assured_common\n\nimport io.restassured.internal.common.assertion.AssertParameter\nimport org.junit.jupiter.api.Test\n\nimport java.lang.reflect.Method\n\nimport static org.assertj.core.api.Assertions.assertThat\nimport static org.junit.jupiter.api.Assertions.assertThrows\n\npublic class AssertParameterTest {\n    @Test\n    void returnsNonNullValueWhenClassParameterIsSupplied() {\n        String value = AssertParameter.notNull('payload', String)\n\n        assertThat(value).isEqualTo('payload')\n    }\n\n    @Test\n    void rejectsNullValueUsingClassSimpleName() {\n        IllegalArgumentException exception = assertThrows(IllegalArgumentException) {\n            AssertParameter.notNull(null, AssertParameterTest)\n        }\n\n        assertThat(exception).hasMessage('AssertParameterTest cannot be null')\n    }\n\n    @Test\n    void resolvesClassNameWithGroovyClassResolver() {\n        Method classResolver = AssertParameter.getDeclaredMethod('class$', String)\n        classResolver.setAccessible(true)\n\n        Class<?> resolvedClass = classResolver.invoke(null, AssertParameter.name) as Class<?>\n\n        assertThat(resolvedClass).isSameAs(AssertParameter)\n    }\n}\n"}], "isError": false, "timestamp": 1779530209268}, {"role": "toolResult", "toolCallId": "call_ocEJ4cZwt2JMlk74G7eWFrz8|fc_086f9a699fb2d999016a1179e1082081a394d8daf2e6ce462c", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_rest_assured.rest_assured_common\n\nimport io.restassured.internal.common.assertion.AssertionSupport\nimport org.junit.jupiter.api.Test\n\nimport static org.assertj.core.api.Assertions.assertThat\n\npublic class AssertionSupportTest {\n    @Test\n    void escapesPathFragmentsWithSupportedEscapers() {\n        String escapedPath = AssertionSupport.escapePath(\n                'store.item-name.properties.class.@id.2024',\n                AssertionSupport.hyphen(),\n                AssertionSupport.properties(),\n                AssertionSupport.classKeyword(),\n                AssertionSupport.attributeGetter(),\n                AssertionSupport.integer()) as String\n\n        assertThat(escapedPath).isEqualTo(\"store.'item-name'.getAt('properties').getAt('class').'@id'.'2024'\")\n    }\n\n    @Test\n    void generatesWhitespaceForPositiveCounts() {\n        assertThat(AssertionSupport.generateWhitespace(3)).isEqualTo('   ')\n        assertThat(AssertionSupport.generateWhitespace(0)).isEqualTo('')\n    }\n\n    @Test\n    void leavesAlreadySafePathFragmentsUntouched() {\n        String escapedPath = AssertionSupport.escapePath(\n                \"store.'item-name'.items[0].find { it.name == 'tea' }\",\n                AssertionSupport.hyphen(),\n                AssertionSupport.properties(),\n                AssertionSupport.classKeyword(),\n                AssertionSupport.attributeGetter(),\n                AssertionSupport.doubleStar(),\n                AssertionSupport.colon(),\n                AssertionSupport.integer()) as String\n\n        assertThat(escapedPath).isEqualTo(\"store.'item-name'.items[0].find { it.name == 'tea' }\")\n    }\n}\n"}], "isError": false, "timestamp": 1779530209268}]}
