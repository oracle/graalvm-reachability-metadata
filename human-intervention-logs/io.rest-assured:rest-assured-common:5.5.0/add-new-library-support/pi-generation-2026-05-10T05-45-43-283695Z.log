[tool-call] delta {"path":"tests/src/io.rest-assured/rest-assured-common/5.5.0/src/test/java/io_rest_assured/rest_assured_common/AssertionSupportAnonymous5Test.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_rest_assured.rest_assured_common;\n\nimport static org.junit.jupiter.api.Assertions.assertEquals;\nimport static org.junit.jupiter.api.Assertions.assertFalse;\nimport static org.junit.jupiter.api.Assertions.assertSame;\nimport static org.junit.jupiter.api.Assertions.assertTrue;\n\nimport java.lang.invoke.MethodHandle;\nimport java.lang.invoke.MethodHandles;\nimport java.lang.invoke.MethodType;\n\nimport io.restassured.internal.common.assertion.AssertionSupport;\nimport io.restassured.internal.common.assertion.PathFragmentEscaper;\nimport org.junit.jupiter.api.Test;\n\npublic class AssertionSupportAnonymous5Test {\n    @Test\n    void doubleStarEscaperOnlyEscapesExactDoubleStarPathFragment() {\n        PathFragmentEscaper escaper = (PathFragmentEscaper) AssertionSupport.doubleStar();\n\n        assertTrue(escaper.shouldEscape(\"**\"));\n        assertFalse(escaper.shouldEscape(\"*\"));\n        assertFalse(escaper.shouldEscape(\"items.**\"));\n    }\n\n    @Test\n    void doubleStarEscaperQuotesMatchingFragmentsEndToEnd() {\n        PathFragmentEscaper escaper = (PathFragmentEscaper) AssertionSupport.doubleStar();\n\n        String escaped = escaper.escape(\"**\");\n\n        assertEquals(\"'**'\", escaped);\n    }\n\n    @Test\n    void syntheticClassLookupCanResolveDoubleStarEscaperImplementationClassName() throws Throwable {\n        PathFragmentEscaper escaper = (PathFragmentEscaper) AssertionSupport.doubleStar();\n        Class<?> escaperClass = escaper.getClass();\n        MethodHandle syntheticClassLookup = MethodHandles.privateLookupIn(escaperClass, MethodHandles.lookup())\n                .findStatic(escaperClass, \"class$\", MethodType.methodType(Class.class, String.class));\n\n        Class<?> resolvedClass = (Class<?>) syntheticClassLookup.invoke(escaperClass.getName());\n\n        assertSame(escaperClass, resolvedClass);\n    }\n}\n"}
