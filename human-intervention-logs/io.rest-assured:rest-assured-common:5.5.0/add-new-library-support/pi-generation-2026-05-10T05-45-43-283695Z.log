  import java.lang.invoke.MethodType;
  
  import io.restassured.internal.common.assertion.AssertionSupport;
  import io.restassured.internal.common.assertion.PathFragmentEscaper;
  import org.junit.jupiter.api.Test;
  
  public class AssertionSupportAnonymous3Test {
      @Test
      void classKeywordEscaperOnlyEscapesUnquotedSimpleClassPathFragments() {
          PathFragmentEscaper escaper = (PathFragmentEscaper) AssertionSupport.classKeyword();
  
          assertTrue(escaper.shouldEscape("class"));
          assertTrue(escaper.shouldEscape("userclass"));
          assertFalse(escaper.shouldEscape("'class'"));
          assertFalse(escaper.shouldEscape("class[0]"));
      }
  
      @Test
      void classKeywordEscaperWrapsMatchingFragmentsWithGetAtAccess() {
          PathFragmentEscaper escaper = (PathFragmentEscaper) AssertionSupport.classKeyword();
  
