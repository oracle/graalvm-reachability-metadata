ter.api.Assertions.assertTrue;\n\nimport java.lang.invoke.MethodHandle;\nimport java.lang.invoke.MethodHandles;\nimport java.lang.invoke.MethodType;\n\nimport io.restassured.internal.common.assertion.AssertionSupport;\nimport io.restassured.internal.common.assertion.PathFragmentEscaper;\nimport org.junit.jupiter.api.Test;\n\npublic class AssertionSupportAnonymous4Test {\n    @Test\n    void attributeGetterEscaperOnlyEscapesSimpleAttributePathFragments() {\n        PathFragmentEscaper escaper = (PathFragmentEscaper) AssertionSupport.attributeGetter();\n\n        assertTrue(escaper.shouldEscape(\"@id\"));\n        assertFalse(escaper.shouldEscape(\"@id'\"));\n        assertFalse(escaper.shouldEscape(\"@id value\"));\n        assertFalse(escaper.shouldEscape(\"{@id}\"));\n    }\n\n    @Test\n    void attributeGetterEscaperQuotesMatchingFragmentsEndToEnd() {\n        PathFragmentEscaper escaper = (PathFragmentEscaper) AssertionSupport.attributeGetter();\n\n        String escaped = escaper.escape(\"@id\");\n\n        assertEquals(\"'@id'\", escaped);\n    }\n\n    @Test\n    void syntheticClassLookupCanResolveAttributeGetterEscaperImplementationClassName() throws Throwable {\n        PathFragmentEscaper escaper = (PathFragmentEscaper) AssertionSupport.attributeGetter();\n        Class<?> escaperClass = escaper.getClass();\n        MethodHandle syntheticClassLookup = MethodHandles.privateLookupIn(escaperClass, MethodHandles.lookup())\n                .findStatic(escaperClass, \"class$\", MethodType.methodType(Class.class, String.class));\n\n        Class<?> resolvedClass = (Class<?>) syntheticClassLookup.invoke(escaperClass.getName());\n\n        assertSame(escaperClass, resolvedClass);\n    }\n}\n"}], "isError": false, "timestamp": 1778391883379}, {"role": "toolResult", "toolCallId": "call_fksrETwozrIM1IkfEkYT1zQk|fc_01caec457ff1266a016a001b4afee8819cba9c0d9d49144438", "toolName": "read", "content": [{"type": "text", "text": "ENOENT: no such file or directory, access '/h