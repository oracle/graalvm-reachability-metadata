per.shouldEscape('properties[0]')).isFalse()\n        assertThat(propertiesEscaper.escape('properties')).isEqualTo(\"getAt('properties')\")\n\n        assertThat(classKeywordEscaper).isInstanceOf(GetAtPathFragmentEscaper)\n        assertThat(classKeywordEscaper.shouldEscape('class')).isTrue()\n        assertThat(classKeywordEscaper.shouldEscape(\"'class'\")).isFalse()\n        assertThat(classKeywordEscaper.escape('class')).isEqualTo(\"getAt('class')\")\n    }\n\n    @Test\n    void resolvesTypesThroughGeneratedClassLiteralHelper() {\n        MethodHandle classLookup = syntheticClassLookup()\n\n        Class<?> resolvedType = invokeSyntheticClassLookup(classLookup, GetAtPathFragmentEscaper.name)\n\n        assertThat(resolvedType).isSameAs(GetAtPathFragmentEscaper)\n    }\n\n    private static MethodHandle syntheticClassLookup() {\n        MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(GetAtPathFragmentEscaper, MethodHandles.lookup())\n        return lookup.findStatic(GetAtPathFragmentEscaper, 'class$', MethodType.methodType(Class, String))\n    }\n\n    @CompileStatic\n    private static Class<?> invokeSyntheticClassLookup(MethodHandle classLookup, String className) {\n        return (Class<?>) classLookup.invokeExact(className)\n    }\n}\n"}], "isError": false, "timestamp": 1779529618317}]}
