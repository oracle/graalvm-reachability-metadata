        @Override
        boolean shouldEscape(String pathFragment) {
          !pathFragment.startsWith("'") && !pathFragment.endsWith("'") && pathFragment.contains(':') && !containsAny(pathFragment, [closureStartFragment, closureEndFragment, listGetterFragment])
        }
      }
    }
  
    def static integer() {
