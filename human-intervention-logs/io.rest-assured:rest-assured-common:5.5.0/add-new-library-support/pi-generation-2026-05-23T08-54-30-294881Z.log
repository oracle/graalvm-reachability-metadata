.hyphen(),\n                AssertionSupport.properties(),\n                AssertionSupport.classKeyword(),\n                AssertionSupport.attributeGetter(),\n                AssertionSupport.integer()) as String\n\n        assertThat(escapedPath).isEqualTo(\"store.'item-name'.getAt('properties').getAt('class').'@id'.'2024'\")\n    }\n\n    @Test\n    void generatesWhitespaceForPositiveCounts() {\n        assertThat(AssertionSupport.generateWhitespace(3)).isEqualTo('   ')\n        assertThat(AssertionSupport.generateWhitespace(0)).isEqualTo('')\n    }\n\n    @Test\n    void leavesAlreadySafePathFragmentsUntouched() {\n        String escapedPath = AssertionSupport.escapePath(\n                \"store.'item-name'.items[0].find { it.name == 'tea' }\",\n                AssertionSupport.hyphen(),\n                AssertionSupport.properties(),\n                AssertionSupport.classKeyword(),\n                AssertionSupport.attributeGetter(),\n                AssertionSupport.doubleStar(),\n                AssertionSupport.colon(),\n                AssertionSupport.integer()) as String\n\n        assertThat(escapedPath).isEqualTo(\"store.'item-name'.items[0].find { it.name == 'tea' }\")\n    }\n}\n"}], "isError": false, "timestamp": 1779526387182}, {"role": "toolResult", "toolCallId": "call_GamiUw1l2Jv2CfcdxXPeSoFo|fc_02446b3188bb27ee016a116af2fc2481a29f6a1021caeb6f4a", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_rest_assured.rest_assured_common\n\nimport io.restassured.internal.common.assertion.AssertionSupport\nimport io.restassured.internal.common.assertion.PathFragmentEscaper\nimport org.junit.jupiter.api.Test\n\nimport static org.assertj.core.api.Assertions.assertThat\n\npublic class AssertionSupportAnonymous1Test {\n    @Test\n    void escapesHyphenatedPathFragments() {\n        PathFragmentEscaper escaper = AssertionSupport.hyphen() as PathFragmentEscaper\n\n        assertThat(escaper.shouldEscape('item-name')).isTrue()\n        assertThat(escaper.shouldEscape(\"'item-name'\")).isFalse()\n        assertThat(escaper.shouldEscape('items[-1]')).isFalse()\n        assertThat(escaper.escape('item-name[0]')).isEqualTo(\"'item-name'[0]\")\n    }\n}\n"}], "isError": false, "timestamp": 1779526387182}, {"role": "toolResult", "toolCallId": "call_YYJOEV46Y84SExBkmvtKpl0n|fc_02446b3188bb27ee016a116af2fc2c81a2ba7d3cc537c7b5ac", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\nplugins {\n    id \"org.graalvm.internal.tck\"\n    id \"groovy\"\n}\n\nString libraryVersion = tck.testedLibraryVersion.get()\n\ndependencies {\n    testImplementation \"io.rest-assured:rest-assured-common:$libraryVersion\"\n    testImplementation localGroovy()\n    testImplementation 'org.assertj:assertj-core:3.22.0'\n}\n\njava {\n    toolchain {\n        languageVersion = JavaLanguageVersion.of(21)\n    }\n}\n\ngraalvmNative {\n    agent {\n        defaultMode = \"conditional\"\n        modes {\n            conditional {\n                userCodeFilterPath = \"user-code-filter.json\"\n            }\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1779526387182}]}
