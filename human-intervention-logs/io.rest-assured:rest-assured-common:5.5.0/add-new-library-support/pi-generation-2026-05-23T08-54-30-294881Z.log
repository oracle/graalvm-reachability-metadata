  package io_rest_assured.rest_assured_common
  
  import io.restassured.internal.common.assertion.AssertionSupport
  import io.restassured.internal.common.assertion.PathFragmentEscaper
  import org.junit.jupiter.api.Test
  
  import static org.assertj.core.api.Assertions.assertThat
  
  public class AssertionSupportAnonymous1Test {
      @Test
      void escapesHyphenatedPathFragments() {
          PathFragmentEscaper escaper = AssertionSupport.hyphen() as PathFragmentEscaper
  
          assertThat(escaper.shouldEscape('item-name')).isTrue()
          assertThat(escaper.shouldEscape("'item-name'")).isFalse()
          assertThat(escaper.shouldEscape('items[-1]')).isFalse()
          assertThat(escaper.escape('item-name[0]')).isEqualTo("'item-name'[0]")
      }
  }
