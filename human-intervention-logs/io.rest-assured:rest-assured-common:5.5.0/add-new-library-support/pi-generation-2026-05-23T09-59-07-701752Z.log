  package io_rest_assured.rest_assured_common
  
  import io.restassured.internal.common.classpath.ClassPathResolver
  import org.junit.jupiter.api.Test
  
  import static org.assertj.core.api.Assertions.assertThat
  
  public class ClassPathResolverTest {
      @Test
      void detectsClassesAvailableToTheApplicationClassLoader() {
          assertThat(ClassPathResolver.existInCP(ClassPathResolver.name)).isTrue()
          assertThat(ClassPathResolver.existInCP(String.name)).isTrue()
      }
  
      @Test
      void returnsFalseForClassesThatAreNotOnTheClasspath() {
          assertThat(ClassPathResolver.existInCP('example.missing.TypeNotPresentOnTheClasspath')).isFalse()
      }
  }
