11', Integer)).isTrue()\n        assertThat(ObjectConverter.canConvert('not-a-number', Integer)).isFalse()\n    }\n\n    @Test\n    void resolvesClassNameWithGroovyClassResolver() {\n        Method classResolver = ObjectConverter.getDeclaredMethod('class$', String)\n        classResolver.setAccessible(true)\n\n        Class<?> resolvedClass = classResolver.invoke(null, ObjectConverter.name) as Class<?>\n\n        assertThat(resolvedClass).isSameAs(ObjectConverter)\n    }\n}\n"}
