  package io_rest_assured.rest_assured_common
  
  import io.restassured.internal.common.assertion.AssertionSupport
  import io.restassured.internal.common.assertion.HyphenQuoteFragmentEscaper
  import io.restassured.internal.common.assertion.PathFragmentEscaper
  import org.codehaus.groovy.runtime.ScriptBytecodeAdapter
  import org.junit.jupiter.api.Test
  
  import static org.assertj.core.api.Assertions.assertThat
  
  public class HyphenQuoteFragmentEscaperTest {
      @Test
      void quotesEscapedFragmentsAndPreservesCollectionIndexLookups() {
          PathFragmentEscaper hyphenEscaper = AssertionSupport.hyphen() as PathFragmentEscaper
          PathFragmentEscaper colonEscaper = AssertionSupport.colon() as PathFragmentEscaper
  
          assertThat(hyphenEscaper).isInstanceOf(HyphenQuoteFragmentEscaper)
          assertThat(hyphenEscaper.escape('item-name')).isEqualTo("'item-name'")
          assertThat(hyphenEscaper.escape('item-name[0]')).isEqualTo("'item-name'[0]")
  
          assertThat(colonEscaper).isInstanceOf(HyphenQuoteFragmentEscaper)
          assertThat(colonEscaper.escape('items:name')).isEqualTo("'items:name'")
          assertThat(colonEscaper.escape('items:name[1]')).isEqualTo("'items:name'[1]")
      }
  
      @Test
      void resolvesClassNameWithGeneratedGroovyDispatch() {
          Class<?> resolvedType = ScriptBytecodeAdapter.invokeStaticMethodN(
                  HyphenQuoteFragmentEscaper,
                  HyphenQuoteFragmentEscaper,
                  'class$',
                  [HyphenQuoteFragmentEscaper.name] as Object[]) as Class<?>
  
          assertThat(resolvedType).isSameAs(HyphenQuoteFragmentEscaper)
      }
  }
