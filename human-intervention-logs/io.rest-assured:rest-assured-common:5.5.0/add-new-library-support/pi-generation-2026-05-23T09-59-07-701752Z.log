  package io_rest_assured.rest_assured_common
  
  import io.restassured.internal.common.assertion.AssertionSupport
  import io.restassured.internal.common.assertion.GetAtPathFragmentEscaper
  import io.restassured.internal.common.assertion.PathFragmentEscaper
  import org.junit.jupiter.api.Test
  
  import static org.assertj.core.api.Assertions.assertThat
  
  public class GetAtPathFragmentEscaperTest {
      @Test
      void escapesSupportedPathFragmentsWithGetAtSyntax() {
          PathFragmentEscaper propertiesEscaper = AssertionSupport.properties() as PathFragmentEscaper
          PathFragmentEscaper classKeywordEscaper = AssertionSupport.classKeyword() as PathFragmentEscaper
  
          assertThat(propertiesEscaper).isInstanceOf(GetAtPathFragmentEscaper)
          assertThat(propertiesEscaper.shouldEscape('properties')).isTrue()
          assertThat(propertiesEscaper.shouldEscape('properties[0]')).isFalse()
          assertThat(propertiesEscaper.escape('properties')).isEqualTo("getAt('properties')")
  
          assertThat(classKeywordEscaper).isInstanceOf(GetAtPathFragmentEscaper)
          assertThat(classKeywordEscaper.shouldEscape('class')).isTrue()
          assertThat(classKeywordEscaper.shouldEscape("'class'")).isFalse()
          assertThat(classKeywordEscaper.escape('class')).isEqualTo("getAt('class')")
      }
  
      @Test
      void resolvesTypesThroughGeneratedClassLiteralHelper() {
          Class<?> resolvedType = invokeSyntheticClassLookup(GetAtPathFragmentEscaper.name)
  
          assertThat(resolvedType).isSameAs(GetAtPathFragmentEscaper)
      }
  
      private static Class<?> invokeSyntheticClassLookup(String className) {
          return GetAtPathFragmentEscaper.'class$'(className) as Class<?>
      }
  }
