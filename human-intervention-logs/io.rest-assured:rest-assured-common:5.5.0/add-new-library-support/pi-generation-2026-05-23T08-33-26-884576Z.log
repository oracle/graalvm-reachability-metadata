.Test\n\nimport static org.assertj.core.api.Assertions.assertThat\nimport static org.junit.jupiter.api.Assertions.assertThrows\n\npublic class AssertParameterTest {\n    @Test\n    void returnsNonNullValueWhenClassParameterIsSupplied() {\n        String value = AssertParameter.notNull('payload', String)\n\n        assertThat(value).isEqualTo('payload')\n    }\n\n    @Test\n    void rejectsNullValueUsingClassSimpleName() {\n        IllegalArgumentException exception = assertThrows(IllegalArgumentException) {\n            AssertParameter.notNull(null, AssertParameterTest)\n        }\n\n        assertThat(exception).hasMessage('AssertParameterTest cannot be null')\n    }\n\n    @Test\n    void resolvesClassNameWithGroovyClassResolver() {\n        Class<?> resolvedClass = AssertParameter.'class$'('java.lang.String')\n\n        assertThat(resolvedClass).isSameAs(String)\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 731, "output": 1383, "cacheRead": 23040, "cacheWrite": 0, "totalTokens": 25154, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1779525161617, "responseId": "resp_0cb44ea23374a6f4016a11662a346881a0b15b1f57f3f82be5"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_qIwjEu0vBA6aj9GAE60lw9rd|fc_0cb44ea23374a6f4016a11663847dc81a0b4df43b0e024a188", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1200 bytes to tests/src/io.rest-assured/rest-assured-common/5.5.0/src/test/groovy/io_rest_assured/rest_assured_common/AssertParameterTest.groovy"}], "isError": false, "timestamp": 1779525178494}]}
