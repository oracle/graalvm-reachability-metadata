  package io_rest_assured.rest_assured_common
  
  import io.restassured.internal.common.assertion.AssertionSupport
  import io.restassured.internal.common.assertion.PathFragmentEscaper
  import org.junit.jupiter.api.Test
  
  import java.lang.invoke.MethodHandle
  import java.lang.invoke.MethodHandles
  import java.lang.invoke.MethodType
  
  import static org.assertj.core.api.Assertions.assertThat
  
  public class AssertionSupportAnonymous4Test {
      @Test
      void escapesAttributeGetterPathFragmentsWithQuotedSyntax() {
          PathFragmentEscaper escaper = AssertionSupport.attributeGetter() as PathFragmentEscaper
  
          assertThat(escaper.shouldEscape('@id')).isTrue()
          assertThat(escaper.shouldEscape('@type')).isTrue()
          assertThat(escaper.shouldEscape("'@id'")).isFalse()
          assertThat(escaper.shouldEscape('@id value')).isFalse()
          assertThat(escaper.shouldEscape('@id.find { it != null }')).isFalse()
          assertThat(escaper.escape('@id')).isEqualTo("'@id'")
      }
  
      @Test
      void appliesAttributeGetterEscaperWhenEscapingFullPath() {
          String escapedPath = AssertionSupport.escapePath(
                  'response.@id.item.@type',
                  AssertionSupport.attributeGetter()) as String
  
          assertThat(escapedPath).isEqualTo("response.'@id'.item.'@type'")
      }
  
      @Test
      void resolvesLibraryTypesThroughGeneratedClassLiteralHelperOnAttributeGetterEscaperClass() {
          PathFragmentEscaper escaper = AssertionSupport.attributeGetter() as PathFragmentEscaper
          Class<?> escaperType = escaper.getClass()
          MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(escaperType, MethodHandles.lookup())
          MethodHandle classLookup = lookup.findStatic(escaperType, 'class$', MethodType.methodType(Class, String))
  
          Class<?> resolvedType = classLookup.invokeWithArguments(PathFragmentEscaper.getName()) as Class<?>
  
          assertThat(resolvedType).isSameAs(PathFragmentEscaper)
      }
  }
