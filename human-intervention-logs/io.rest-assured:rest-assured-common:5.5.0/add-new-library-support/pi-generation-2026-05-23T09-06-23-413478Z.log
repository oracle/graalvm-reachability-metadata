  package io_rest_assured.rest_assured_common
  
  import io.restassured.internal.common.assertion.AssertionSupport
  import org.junit.jupiter.api.Test
  
  import static org.assertj.core.api.Assertions.assertThat
  
  public class AssertionSupportTest {
      @Test
      void escapesPathFragmentsWithSupportedEscapers() {
          String escapedPath = AssertionSupport.escapePath(
                  'store.item-name.properties.class.@id.2024',
                  AssertionSupport.hyphen(),
                  AssertionSupport.properties(),
                  AssertionSupport.classKeyword(),
                  AssertionSupport.attributeGetter(),
                  AssertionSupport.integer()) as String
  
          assertThat(escapedPath).isEqualTo("store.'item-name'.getAt('properties').getAt('class').'@id'.'2024'")
      }
  
      @Test
      void generatesWhitespaceForPositiveCounts() {
          assertThat(AssertionSupport.generateWhitespace(3)).isEqualTo('   ')
          assertThat(AssertionSupport.generateWhitespace(0)).isEqualTo('')
      }
  
      @Test
      void leavesAlreadySafePathFragmentsUntouched() {
          String escapedPath = AssertionSupport.escapePath(
                  "store.'item-name'.items[0].find { it.name == 'tea' }",
                  AssertionSupport.hyphen(),
                  AssertionSupport.properties(),
                  AssertionSupport.classKeyword(),
                  AssertionSupport.attributeGetter(),
                  AssertionSupport.doubleStar(),
                  AssertionSupport.colon(),
                  AssertionSupport.integer()) as String
  
          assertThat(escapedPath).isEqualTo("store.'item-name'.items[0].find { it.name == 'tea' }")
      }
  }
