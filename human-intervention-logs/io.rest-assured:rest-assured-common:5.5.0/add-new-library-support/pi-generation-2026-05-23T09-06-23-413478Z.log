  package io_rest_assured.rest_assured_common
  
  import io.restassured.internal.common.assertion.AssertionSupport
  import io.restassured.internal.common.assertion.PathFragmentEscaper
  import org.junit.jupiter.api.Test
  
  import static org.assertj.core.api.Assertions.assertThat
  
  public class AssertionSupportAnonymous3Test {
      @Test
      void escapesClassKeywordPathFragmentsWithGetAtSyntax() {
          PathFragmentEscaper escaper = AssertionSupport.classKeyword() as PathFragmentEscaper
  
          assertThat(escaper.shouldEscape('class')).isTrue()
          assertThat(escaper.shouldEscape('response.class')).isTrue()
          assertThat(escaper.shouldEscape("'class'")).isFalse()
          assertThat(escaper.shouldEscape('class[0]')).isFalse()
          assertThat(escaper.shouldEscape('class value')).isFalse()
          assertThat(escaper.escape('class')).isEqualTo("getAt('class')")
      }
  
      @Test
      void appliesClassKeywordEscaperWhenEscapingFullPath() {
          String escapedPath = AssertionSupport.escapePath(
                  'response.class.name',
                  AssertionSupport.classKeyword()) as String
  
          assertThat(escapedPath).isEqualTo("response.getAt('class').name")
      }
  
      @Test
      void leavesClassKeywordFragmentsUntouchedWhenTheyArePartOfUnsupportedExpressions() {
          PathFragmentEscaper escaper = AssertionSupport.classKeyword() as PathFragmentEscaper
  
          assertThat(escaper.shouldEscape('class[0]')).isFalse()
          assertThat(escaper.shouldEscape('class value')).isFalse()
          assertThat(escaper.shouldEscape('class.find { it.simpleName }')).isFalse()
          assertThat(escaper.shouldEscape('class()')).isFalse()
      }
  }
