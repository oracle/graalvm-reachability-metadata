[tool-call] delta {"path":"tests/src/io.rest-assured/rest-assured-common/5.5.0/src/test/groovy/io_rest_assured/rest_assured_common/AssertionSupportAnonymous7Test.groovy","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_rest_assured.rest_assured_common\n\nimport io.restassured.internal.common.assertion.AssertionSupport\nimport io.restassured.internal.common.assertion.PathFragmentEscaper\nimport org.junit.jupiter.api.Test\n\nimport static org.assertj.core.api.Assertions.assertThat\n\npublic class AssertionSupportAnonymous7Test {\n    @Test\n    void escapesIntegerPathFragmentsWithQuotedSyntax() {\n        PathFragmentEscaper escaper = AssertionSupport.integer() as PathFragmentEscaper\n\n        assertThat(escaper.shouldEscape('2024')).isTrue()\n        assertThat(escaper.shouldEscape('1stPlace')).isTrue()\n        assertThat(escaper.shouldEscape('item2')).isFalse()\n        assertThat(escaper.shouldEscape('2024 value')).isFalse()\n        assertThat(escaper.shouldEscape('2024[0]')).isFalse()\n        assertThat(escaper.shouldEscape('2024()')).isFalse()\n        assertThat(escaper.escape('2024')).isEqualTo(\"'2024'\")\n    }\n\n    @Test\n    void appliesIntegerEscaperWhenEscapingFullPath() {\n        String escapedPath = AssertionSupport.escapePath(\n                'store.2024.1stPlace.item2',\n                AssertionSupport.integer()) as String\n\n        assertThat(escapedPath).isEqualTo(\"store.'2024'.'1stPlace'.item2\")\n    }\n}\n"}
