eativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_rest_assured.rest_assured_common\n\nimport io.restassured.internal.common.assertion.AssertionSupport\nimport io.restassured.internal.common.assertion.PathFragmentEscaper\nimport org.junit.jupiter.api.Test\n\nimport static org.assertj.core.api.Assertions.assertThat\n\npublic class AssertionSupportAnonymous6Test {\n    @Test\n    void escapesColonPathFragmentsWithQuotedSyntax() {\n        PathFragmentEscaper escaper = AssertionSupport.colon() as PathFragmentEscaper\n\n        assertThat(escaper.shouldEscape('http://example.com')).isTrue()\n        assertThat(escaper.shouldEscape('items:name')).isTrue()\n        assertThat(escaper.shouldEscape(\"'items:name'\")).isFalse()\n        assertThat(escaper.shouldEscape('items:name()')).isFalse()\n        assertThat(escaper.shouldEscape('items:name.find { it != null }')).isFalse()\n        assertThat(escaper.escape('items:name[0]')).isEqualTo(\"'items:name'[0]\")\n    }\n\n    @Test\n    void appliesColonEscaperWhenEscapingFullPath() {\n        String escapedPath = AssertionSupport.escapePath(\n                'response.items:name.value',\n                AssertionSupport.colon()) as String\n\n        assertThat(escapedPath).isEqualTo(\"response.'items:name'.value\")\n    }\n}\n"}], "isError": false, "timestamp": 1779528441969}, {"role": "toolResult", "toolCallId": "call_V6mFt1cvTgx4kkruZYwITUoX|fc_0893b83730542fb4016a1172f9aa48819194b2fe0b3bbc895a", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_rest_assured.rest_assured_common\n\nimport io.restassured.internal.common.assertion.AssertionSupport\nimport org.junit.jupiter.api.Test\n\nimport static org.assertj.core.api.Assertions.assertThat\n\npublic class AssertionSupportTest {\n    @Test\n    void escapesPathFragmentsWithSupportedEscapers() {\n        String escapedPath = AssertionSupport.escapePath(\n                'store.item-name.properties.class.@id.2024',\n                AssertionSupport.hyphen(),\n                AssertionSupport.properties(),\n                AssertionSupport.classKeyword(),\n                AssertionSupport.attributeGetter(),\n                AssertionSupport.integer()) as String\n\n        assertThat(escapedPath).isEqualTo(\"store.'item-name'.getAt('properties').getAt('class').'@id'.'2024'\")\n    }\n\n    @Test\n    void generatesWhitespaceForPositiveCounts() {\n        assertThat(AssertionSupport.generateWhitespace(3)).isEqualTo('   ')\n        assertThat(AssertionSupport.generateWhitespace(0)).isEqualTo('')\n    }\n\n    @Test\n    void leavesAlreadySafePathFragmentsUntouched() {\n        String escapedPath = AssertionSupport.escapePath(\n                \"store.'item-name'.items[0].find { it.name == 'tea' }\",\n                AssertionSupport.hyphen(),\n                AssertionSupport.properties(),\n                AssertionSupport.classKeyword(),\n                AssertionSupport.attributeGetter(),\n                AssertionSupport.doubleStar(),\n                AssertionSupport.colon(),\n                AssertionSupport.integer()) as String\n\n        assertThat(escapedPath).isEqualTo(\"store.'item-name'.items[0].find { it.name == 'tea' }\")\n    }\n}\n"}], "isError": false, "timestamp": 1779528441969}, {"role": "toolResult", "toolCallId": "call_YbCLgByaCexytYAegKy8phFj|fc_0893b83730542fb4016a1172f9aa50819191c6d5c32de6d8f4", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\nplugins {\n    id \"org.graalvm.internal.tck\"\n    id \"groovy\"\n}\n\nString libraryVersion = tck.testedLibraryVersion.get()\n\nde