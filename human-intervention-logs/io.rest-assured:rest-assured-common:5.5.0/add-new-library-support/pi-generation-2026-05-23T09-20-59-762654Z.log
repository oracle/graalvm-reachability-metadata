  package io_rest_assured.rest_assured_common
  
  import io.restassured.internal.common.assertion.AssertionSupport
  import io.restassured.internal.common.assertion.PathFragmentEscaper
  import org.junit.jupiter.api.Test
  
  import static org.assertj.core.api.Assertions.assertThat
  
  public class AssertionSupportAnonymous5Test {
      @Test
      void escapesDoubleStarPathFragmentsWithQuotedSyntax() {
          PathFragmentEscaper escaper = AssertionSupport.doubleStar() as PathFragmentEscaper
  
          assertThat(escaper.shouldEscape('**')).isTrue()
          assertThat(escaper.shouldEscape('*')).isFalse()
          assertThat(escaper.shouldEscape('items**')).isFalse()
          assertThat(escaper.escape('**')).isEqualTo("'**'")
      }
  
