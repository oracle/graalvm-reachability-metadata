  +import org.junit.jupiter.api.Test;
  +
  +public class AssertionSupportAnonymous4Test {
  +    @Test
  +    void attributeGetterEscaperOnlyEscapesSimpleAttributePathFragments() {
  +        PathFragmentEscaper escaper = (PathFragmentEscaper) AssertionSupport.attributeGetter();
  +
  +        assertTrue(escaper.shouldEscape("@id"));
  +        assertFalse(escaper.shouldEscape("@id'"));
  +        assertFalse(escaper.shouldEscape("@id value"));
  +        assertFalse(escaper.shouldEscape("{@id}"));
  +    }
  +
  +    @Test
