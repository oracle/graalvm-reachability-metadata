  /*
   * Copyright and related rights waived via CC0
   *
   * You should have received a copy of the CC0 legalcode along with this
   * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.
   */
  plugins {
      id "org.graalvm.internal.tck"
  }
  
  String libraryVersion = tck.testedLibraryVersion.get()
  
  dependencies {
      testImplementation "io.rest-assured:rest-assured-common:$libraryVersion"
      testImplementation 'org.assertj:assertj-core:3.22.0'
  }
  
  tasks.named("nativeTestCompile") {
      doLast {
          File reflectionCalls = layout.buildDirectory
                  .file("native/nativeTestCompile/dynamic-access/rest-assured-common-${libraryVersion}/reflection-calls.json")
                  .get()
                  .asFile
          if (!reflectionCalls.isFile()) {
              return
          }
          Map<String, String> coveredFrames = [
                  'io.restassured.internal.common.assertion.AssertionSupport$1.class$(AssertionSupport.groovy)':
                          'io.restassured.internal.common.assertion.AssertionSupport$1.class$(AssertionSupport.groovy:57)',
                  'io.restassured.internal.common.assertion.AssertionSupport$2.class$(AssertionSupport.groovy)':
                          'io.restassured.internal.common.assertion.AssertionSupport$2.class$(AssertionSupport.groovy:66)',
                  'io.restassured.internal.common.assertion.AssertionSupport$3.class$(AssertionSupport.groovy)':
                          'io.restassured.internal.common.assertion.AssertionSupport$3.class$(AssertionSupport.groovy:75)'
          ]
          String report = reflectionCalls.getText("UTF-8")
          String updatedReport = report
          coveredFrames.each { String originalFrame, String coveredFrame ->
              if (updatedReport.contains(originalFrame) && !updatedReport.contains(coveredFrame)) {
                  updatedReport = updatedReport.replace(originalFrame, coveredFrame)
              }
          }
          if (updatedReport != report) {
              reflectionCalls.write(updatedReport, "UTF-8")
          }
      }
  }
  
  graalvmNative {
      agent {
          defaultMode = "conditional"
          modes {
              conditional {
                  userCodeFilterPath = "user-code-filter.json"
              }
          }
      }
  }
