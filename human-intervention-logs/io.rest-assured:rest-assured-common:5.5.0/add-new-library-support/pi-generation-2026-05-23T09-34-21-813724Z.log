  package io_rest_assured.rest_assured_common
  
  import io.restassured.internal.common.assertion.AssertionSupport
  import io.restassured.internal.common.assertion.PathFragmentEscaper
  import org.junit.jupiter.api.Test
  
  import static org.assertj.core.api.Assertions.assertThat
  
  public class AssertionSupportAnonymous7Test {
      @Test
      void escapesIntegerPathFragmentsWithQuotedSyntax() {
          PathFragmentEscaper escaper = AssertionSupport.integer() as PathFragmentEscaper
  
          assertThat(escaper.shouldEscape('2024')).isTrue()
          assertThat(escaper.shouldEscape('1stPlace')).isTrue()
          assertThat(escaper.shouldEscape('item2')).isFalse()
          assertThat(escaper.shouldEscape('2024 value')).isFalse()
          assertThat(escaper.shouldEscape('2024[0]')).isFalse()
          assertThat(escaper.shouldEscape('2024()')).isFalse()
          assertThat(escaper.escape('2024')).isEqualTo("'2024'")
      }
  
      @Test
      void appliesIntegerEscaperWhenEscapingFullPath() {
          String escapedPath = AssertionSupport.escapePath(
                  'store.2024.1stPlace.item2',
                  AssertionSupport.integer()) as String
  
          assertThat(escapedPath).isEqualTo("store.'2024'.'1stPlace'.item2")
      }
  }
