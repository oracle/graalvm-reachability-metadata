  package io_rest_assured.rest_assured_common
  
  import io.restassured.internal.common.assertion.AssertionSupport
  import io.restassured.internal.common.assertion.PathFragmentEscaper
  import org.junit.jupiter.api.Test
  
  import java.lang.invoke.MethodHandle
  import java.lang.invoke.MethodHandles
  import java.lang.invoke.MethodType
  
  import static org.assertj.core.api.Assertions.assertThat
  
  public class AssertionSupportAnonymous2Test {
      @Test
      void escapesPropertiesPathFragmentsWithGetAtSyntax() {
          PathFragmentEscaper escaper = AssertionSupport.properties() as PathFragmentEscaper
  
          assertThat(escaper.shouldEscape('properties')).isTrue()
          assertThat(escaper.shouldEscape('response.properties')).isTrue()
          assertThat(escaper.shouldEscape("'properties'")).isFalse()
          assertThat(escaper.shouldEscape('properties[0]')).isFalse()
          assertThat(escaper.shouldEscape('properties value')).isFalse()
          assertThat(escaper.escape('properties')).isEqualTo("getAt('properties')")
      }
  
      @Test
      void appliesPropertiesEscaperWhenEscapingFullPath() {
          String escapedPath = AssertionSupport.escapePath(
                  'response.properties.value',
                  AssertionSupport.properties()) as String
  
          assertThat(escapedPath).isEqualTo("response.getAt('properties').value")
      }
  
      @Test
      void resolvesTypesThroughGeneratedClassLiteralHelperOnPropertiesEscaperClass() {
          PathFragmentEscaper escaper = AssertionSupport.properties() as PathFragmentEscaper
          Class<?> escaperType = escaper.getClass()
          MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(escaperType, MethodHandles.lookup())
          MethodHandle classLookup = lookup.findStatic(escaperType, 'class$', MethodType.methodType(Class, String))
  
          Class<?> resolvedType = classLookup.invokeWithArguments('java.lang.String') as Class<?>
  
          assertThat(resolvedType).isSameAs(String)
      }
  }
