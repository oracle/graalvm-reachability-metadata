  package io_rest_assured.rest_assured_common
  
  import io.restassured.internal.common.assertion.EndToEndQuoteFragmentEscaper
  import io.restassured.internal.common.assertion.PathFragmentEscaper
  import org.junit.jupiter.api.Test
  
  import java.lang.reflect.Method
  
  import static org.assertj.core.api.Assertions.assertThat
  
  public class EndToEndQuoteFragmentEscaperTest {
      @Test
      void quotesCompletePathFragments() {
          PathFragmentEscaper escaper = new EndToEndQuoteFragmentEscaper() {
              @Override
              boolean shouldEscape(String pathFragment) {
                  pathFragment == 'customer-id'
              }
          }
  
          assertThat(escaper.shouldEscape('customer-id')).isTrue()
          assertThat(escaper.shouldEscape('customer')).isFalse()
          assertThat(escaper.escape('customer-id')).isEqualTo("'customer-id'")
      }
  
      @Test
      void resolvesTypesThroughGeneratedClassResolver() {
          Method classResolver = EndToEndQuoteFragmentEscaper.getDeclaredMethod('class$', String)
          classResolver.setAccessible(true)
  
          Class<?> resolvedType = classResolver.invoke(null, 'java.lang.Integer') as Class<?>
  
          assertThat(resolvedType).isSameAs(Integer)
      }
  }
