ssured.rest_assured_common\n\nimport io.restassured.internal.common.assertion.AssertionSupport\nimport io.restassured.internal.common.assertion.PathFragmentEscaper\nimport org.junit.jupiter.api.Test\n\nimport static org.assertj.core.api.Assertions.assertThat\n\npublic class AssertionSupportAnonymous1Test {\n    @Test\n    void escapesHyphenatedPathFragments() {\n        PathFragmentEscaper escaper = AssertionSupport.hyphen() as PathFragmentEscaper\n\n        assertThat(escaper.shouldEscape('item-name')).isTrue()\n        assertThat(escaper.shouldEscape(\"'item-name'\")).isFalse()\n        assertThat(escaper.shouldEscape('items[-1]')).isFalse()\n        assertThat(escaper.escape('item-name[0]')).isEqualTo(\"'item-name'[0]\")\n    }\n}\n"}], "isError": false, "timestamp": 1779527618514}, {"role": "toolResult", "toolCallId": "call_040R9jIvxUAcuHSbVXppTAgJ|fc_0eb937ad0b8287a0016a116fc237b88195ae02ff67929b256c", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_rest_assured.rest_assured_common\n\nimport io.restassured.internal.common.assertion.AssertionSupport\nimport io.restassured.internal.common.assertion.PathFragmentEscaper\nimport org.junit.jupiter.api.Test\n\nimport java.lang.invoke.MethodHandle\nimport java.lang.invoke.MethodHandles\nimport java.lang.invoke.MethodType\n\nimport static org.assertj.core.api.Assertions.assertThat\n\npublic class AssertionSupportAnonymous2Test {\n    @Test\n    void escapesPropertiesPathFragmentsWithGetAtSyntax() {\n        PathFragmentEscaper escaper = AssertionSupport.properties() as PathFragmentEscaper\n\n        assertThat(escaper.shouldEscape('properties')).isTrue()\n        assertThat(escaper.shouldEscape('response.properties')).isTrue()\n        assertThat(escaper.shouldEscape(\"'properties'\")).isFalse()\n        assertThat(escaper.shouldEscape('properties[0]')).isFalse()\n        assertThat(escaper.shouldEscape('properties value')).isFalse()\n        assertThat(escaper.escape('properties')).isEqualTo(\"getAt('properties')\")\n    }\n\n    @Test\n    void appliesPropertiesEscaperWhenEscapingFullPath() {\n        String escapedPath = AssertionSupport.escapePath(\n                'response.properties.value',\n                AssertionSupport.properties()) as String\n\n        assertThat(escapedPath).isEqualTo(\"response.getAt('properties').value\")\n    }\n\n    @Test\n    void resolvesTypesThroughGeneratedClassLiteralHelperOnPropertiesEscaperClass() {\n        PathFragmentEscaper escaper = AssertionSupport.properties() as PathFragmentEscaper\n        Class<?> escaperType = escaper.getClass()\n        MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(escaperType, MethodHandles.lookup())\n        MethodHandle classLookup = lookup.findStatic(escaperType, 'class$', MethodType.methodType(Class, String))\n\n        Class<?> resolvedType = classLookup.invokeWithArguments('java.lang.String') as Class<?>\n\n        assertThat(resolvedType).isSameAs(String)\n    }\n}\n"}], "isError": false, "timestamp": 1779527618514}, {"role": "toolResult", "toolCallId": "call_3VyWUrqIve1KovRX1XEymHKm|fc_0eb937ad0b8287a0016a116fc237c08195a0f1e136730c3772", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_rest_assured.rest_assured_common\n\nimport io.restassured.internal.common.assertion.AssertionSupport\nimport io.restassured.internal.common.assertion.PathFragmentEscaper\nimport org.junit.jupiter.api.Test\n\nimport static org.assertj.core.api.Assertions.assertThat\n\npublic class AssertionSupportAnonymous3Test {\n    @Test\n    void escapesClassKeywordPathFragmentsWithGetAtSyntax() {\n        PathFragmentEscaper escaper = AssertionSupport.classKeyword() as PathFragmentEscaper\n\n        assertThat(escaper.shouldEscape('class')).isTrue()\n        assertThat(escaper.shouldEscape('response.class')).isTrue()\n        assertThat(escaper.shouldEscape(\"'class'\")).isFalse()\n        assertThat(escaper.shouldEscape('class[0]')).isFalse()\n        assertThat(escaper.shouldEscape('class value')).isFalse()\n        assertThat(escaper.escape('class')).isEqualTo(\"getAt('class')\")\n    }\n\n    @Test\n    void appliesClassKeywordEscaperWhenEscapingFullPath() {\n        String escapedPath = AssertionSupport.escapePath(\n                'response.class.name',\n                AssertionSupport.classKeyword()) as String\n\n        assertThat(escapedPath).isEqualTo(\"response.getAt('class').name\")\n    }\n\n    @Test\n    void leavesClassKeywordFragmentsUntouchedWhenTheyArePartOfUnsupportedExpressions() {\n        PathFragmentEscaper escaper = AssertionSupport.classKeyword() as PathFragmentEscaper\n\n        assertThat(escaper.shouldEscape('class[0]')).isFalse()\n        assertThat(escaper.shouldEscape('class value')).isFalse()\n        assertThat(escaper.shouldEscape('class.find { it.simpleName }')).isFalse()\n        assertThat(escaper.shouldEscape('class()')).isFalse()\n    }\n}\n"}], "isError": false, "timestamp": 1779527618515}, {"role": "toolResult", "toolCallId": "call_wYfFp1MegGJUGonj4trw9SHF|fc_0eb937ad0b8287a0016a116fc237c48195a36b96d891303ead", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_rest_assured.rest_assured_common\n\nimport io.restassured.internal.common.assertion.AssertionSupport\nimport io.restassured.internal.common.assertion.PathFragmentEscaper\nimport org.junit.jupiter.api.Test\n\nimport static org.assertj.core.api.Assertions.assertThat\n\npublic class AssertionSupportAnonymous4Test {\n    @Test\n    void escapesAttributeGetterPathFragmentsWithQuotedSyntax() {\n        PathFragmentEscaper escaper = AssertionSupport.attributeGetter() as PathFragmentEscaper\n\n        assertThat(escaper.shouldEscape('@id')).isTrue()\n        assertThat(escaper.shouldEscape('@type')).isTrue()\n        assertThat(escaper.shouldEscape(\"'@id'\")).isFalse()\n        assertThat(escaper.shouldEscape('@id value')).isFalse()\n        assertThat(escaper.shouldEscape('@id.find { it != null }')).isFalse()\n        assertThat(escaper.escape('@id')).isEqualTo(\"'@id'\")\n    }\n\n    @Test\n    void appliesAttributeGetterEscaperWhenEscapingFullPath() {\n        String escapedPath = AssertionSupport.escapePath(\n                'response.@id.item.@type',\n                AssertionSupport.attributeGetter()) as String\n\n        assertThat(escapedPath).isEqualTo(\"response.'@id'.item.'@type'\")\n    }\n}\n"}], "isError": false, "timestamp": 1779527618515}, {"role": "toolResult", "toolCallId": "call_oUgBzsjvJG8qDGH8A5dm9wS9|fc_0eb937ad0b8287a0016a116fc237cc8195b571a9de1f064443", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_rest_assured.rest_assured_common\n\nimport io.restassured.internal.common.assertion.AssertionSupport\nimport org.junit.jupiter.api.Test\n\nimport static org.assertj.core.api.Assertions.assertThat\n\npublic class AssertionSupportTest {\n    @Test\n    void escapesPathFragmentsWithSupportedEscapers() {\n        String escapedPath = AssertionSupport.escapePath(\n                'store.item-name.properties.class.@id.2024',\n                AssertionSupport.hyphen(),\n                AssertionSupport.properties(),\n                AssertionSupport.classKeyword(),\n                AssertionSupport.attributeGetter(),\n                AssertionSupport.integer()) as String\n\n        assertThat(escapedPath).isEqualTo(\"store.'item-name'.getAt('properties').getAt('class').'@id'.'2024'\")\n    }\n\n    @Test\n    void generatesWhitespaceForPositiveCounts() {\n        assertThat(AssertionSupport.generateWhitespace(3)).isEqualTo('   ')\n        assertThat(AssertionSupport.generateWhitespace(0)).isEqualTo('')\n    }\n\n    @Test\n    void leavesAlreadySafePathFragmentsUntouched() {\n        String escapedPath = AssertionSupport.escapePath(\n                \"store.'item-name'.items[0].find { it.name == 'tea' }\",\n                AssertionSupport.hyphen(),\n                AssertionSupport.properties(),\n                AssertionSupport.classKeyword(),\n                AssertionSupport.attributeGetter(),\n                AssertionSupport.doubleStar(),\n                AssertionSupport.colon(),\n                AssertionSupport.integer()) as String\n\n        assertThat(escapedPath).isEqualTo(\"store.'item-name'.items[0].find { it.name == 'tea' }\")\n    }\n}\n"}], "isError": false, "timestamp": 1779527618515}, {"role": "toolResult", "toolCallId": "call_A0UZuKGeEoYEhwo3PH2Ipx0S|fc_0eb937ad0b8287a0016a116fc237d081958ee3ed67933feb3c", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\nplugins {\n    id \"org.graalvm.internal.tck\"\n    id \"groovy\"\n}\n\nString libraryVersion = tck.testedLibraryVersion.get()\n\ndependencies {\n    testImplementation \"io.rest-assured:rest-assured-common:$libraryVersion\"\n    testImplementation localGroovy()\n    testImplementation 'org.assertj:assertj-core:3.22.0'\n}\n\njava {\n    toolchain {\n        languageVersion = JavaLanguageVersion.of(21)\n    }\n}\n\n