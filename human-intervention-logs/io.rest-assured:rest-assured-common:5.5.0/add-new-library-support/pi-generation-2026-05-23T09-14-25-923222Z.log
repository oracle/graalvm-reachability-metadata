  package io_rest_assured.rest_assured_common
  
  import io.restassured.internal.common.assertion.AssertionSupport
  import io.restassured.internal.common.assertion.PathFragmentEscaper
  import org.junit.jupiter.api.Test
  
  import java.lang.invoke.MethodHandle
  import java.lang.invoke.MethodHandles
  import java.lang.invoke.MethodType
  
  import static org.assertj.core.api.Assertions.assertThat
  
  public class AssertionSupportAnonymous5Test {
      @Test
      void escapesDoubleStarPathFragmentsWithQuotedSyntax() {
          PathFragmentEscaper escaper = AssertionSupport.doubleStar() as PathFragmentEscaper
  
          assertThat(escaper.shouldEscape('**')).isTrue()
          assertThat(escaper.shouldEscape('*')).isFalse()
          assertThat(escaper.shouldEscape('items**')).isFalse()
          assertThat(escaper.escape('**')).isEqualTo("'**'")
      }
  
      @Test
      void appliesDoubleStarEscaperWhenEscapingFullPath() {
          String escapedPath = AssertionSupport.escapePath(
                  'store.**.name',
                  AssertionSupport.doubleStar()) as String
  
          assertThat(escapedPath).isEqualTo("store.'**'.name")
      }
  
      @Test
      void resolvesTypesThroughGeneratedClassLiteralHelperOnDoubleStarEscaperClass() {
          PathFragmentEscaper escaper = AssertionSupport.doubleStar() as PathFragmentEscaper
          Class<?> escaperType = escaper.getClass()
          MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(escaperType, MethodHandles.lookup())
          MethodHandle classLookup = lookup.findStatic(escaperType, 'class$', MethodType.methodType(Class, String))
  
          Class<?> resolvedType = classLookup.invokeWithArguments(
                  'io.restassured.internal.common.assertion.AssertionSupport') as Class<?>
  
          assertThat(resolvedType).isSameAs(AssertionSupport)
      }
  }
