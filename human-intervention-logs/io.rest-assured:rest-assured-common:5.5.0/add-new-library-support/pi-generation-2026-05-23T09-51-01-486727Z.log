on.EndToEndQuoteFragmentEscaper\nimport io.restassured.internal.common.assertion.PathFragmentEscaper\nimport org.junit.jupiter.api.Test\n\nimport static org.assertj.core.api.Assertions.assertThat\n\npublic class EndToEndQuoteFragmentEscaperTest {\n    @Test\n    void quotesCompletePathFragments() {\n        PathFragmentEscaper escaper = new EndToEndQuoteFragmentEscaper() {\n            @Override\n            boolean shouldEscape(String pathFragment) {\n                pathFragment == 'customer-id'\n            }\n        }\n\n        assertThat(escaper.shouldEscape('customer-id')).isTrue()\n        assertThat(escaper.shouldEscape('customer')).isFalse()\n        assertThat(escaper.escape('customer-id')).isEqualTo(\"'customer-id'\")\n    }\n}\n"}], "isError": false, "timestamp": 1779529814694}, {"role": "toolResult", "toolCallId": "call_r1hkNpkttkeiCSvVlEx1CxhQ|fc_002e1a1cdd2231fa016a11785669c0819facaa794dac6d05c1", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_rest_assured.rest_assured_common\n\nimport io.restassured.internal.common.assertion.AssertionSupport\nimport io.restassured.internal.common.assertion.GetAtPathFragmentEscaper\nimport io.restassured.internal.common.assertion.PathFragmentEscaper\nimport org.junit.jupiter.api.Test\n\nimport static org.assertj.core.api.Assertions.assertThat\n\npublic class GetAtPathFragmentEscaperTest {\n    @Test\n    void escapesSupportedPathFragmentsWithGetAtSyntax() {\n        PathFragmentEscaper propertiesEscaper = AssertionSupport.properties() as PathFragmentEscaper\n        PathFragmentEscaper classKeywordEscaper = AssertionSupport.classKeyword() as PathFragmentEscaper\n\n        assertThat(propertiesEscaper).isInstanceOf(GetAtPathFragmentEscaper)\n        assertThat(propertiesEscaper.shouldEscape('properties')).isTrue()\n        assertThat(propertiesEscaper.shouldEscape('properties[0]')).isFalse()\n        assertThat(propertiesEscaper.escape('properties')).isEqualTo(\"getAt('properties')\")\n\n        assertThat(classKeywordEscaper).isInstanceOf(GetAtPathFragmentEscaper)\n        assertThat(classKeywordEscaper.shouldEscape('class')).isTrue()\n        assertThat(classKeywordEscaper.shouldEscape(\"'class'\")).isFalse()\n        assertThat(classKeywordEscaper.escape('class')).isEqualTo(\"getAt('class')\")\n    }\n\n    @Test\n    void resolvesTypesThroughGeneratedClassLiteralHelper() {\n        Class<?> resolvedType = invokeSyntheticClassLookup(GetAtPathFragmentEscaper.name)\n\n        assertThat(resolvedType).isSameAs(GetAtPathFragmentEscaper)\n    }\n\n    private static Class<?> invokeSyntheticClassLookup(String className) {\n        return GetAtPathFragmentEscaper.'class$'(className) as Class<?>\n    }\n}\n"}], "isError": false, "timestamp": 1779529814694}, {"role": "toolResult", "toolCallId": "call_q310BI4uBqQRexa3kHyG0QMC|fc_002e1a1cdd2231fa016a11785669c4819f914448e3ba65797f", "toolName": "read", "content": [{"type": "text", "text": "{\n  \"classes\" : [ {\n    \"callSites\" : [ {\n      \"covered\" : false,\n      \"frame\" : \"io.restassured.internal.common.assertion.AssertParameter.class$(AssertParameter.groovy)\",\n      \"line\" : null,\n      \"metadataType\" : \"reflection\",\n      \"trackedApi\" : \"java.lang.Class#forName(java.lang.String)\"\n    } ],\n    \"className\" : \"io.restassured.internal.common.assertion.AssertParameter\",\n    \"coveredCalls\" : 0,\n    \"sourceFile\" : \"AssertParameter.groovy\",\n    \"totalCalls\" : 1\n  }, {\n    \"callSites\" : [ {\n      \"covered\" : false,\n      \"frame\" : \"io.restassured.internal.common.assertion.AssertionSupport.class$(AssertionSupport.groovy)\",\n      \"line\" : null,\n      \"metadataType\" : \"reflection\",\n      \"trackedApi\" : \"java.lang.Class#forName(java.lang.String)\"\n    } 