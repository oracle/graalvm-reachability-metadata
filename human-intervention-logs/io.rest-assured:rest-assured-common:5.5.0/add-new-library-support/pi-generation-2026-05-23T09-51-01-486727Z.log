est.groovy", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_rest_assured.rest_assured_common\n\nimport io.restassured.internal.common.assertion.AssertionSupport\nimport io.restassured.internal.common.assertion.HyphenQuoteFragmentEscaper\nimport io.restassured.internal.common.assertion.PathFragmentEscaper\nimport org.junit.jupiter.api.Test\n\nimport static org.assertj.core.api.Assertions.assertThat\n\npublic class HyphenQuoteFragmentEscaperTest {\n    @Test\n    void quotesEscapedFragmentsAndPreservesCollectionIndexLookups() {\n        PathFragmentEscaper hyphenEscaper = AssertionSupport.hyphen() as PathFragmentEscaper\n        PathFragmentEscaper colonEscaper = AssertionSupport.colon() as PathFragmentEscaper\n\n        assertThat(hyphenEscaper).isInstanceOf(HyphenQuoteFragmentEscaper)\n        assertThat(hyphenEscaper.escape('item-name')).isEqualTo(\"'item-name'\")\n        assertThat(hyphenEscaper.escape('item-name[0]')).isEqualTo(\"'item-name'[0]\")\n\n        assertThat(colonEscaper).isInstanceOf(HyphenQuoteFragmentEscaper)\n        assertThat(colonEscaper.escape('items:name')).isEqualTo(\"'items:name'\")\n        assertThat(colonEscaper.escape('items:name[1]')).isEqualTo(\"'items:name'[1]\")\n    }\n\n    @Test\n    void resolvesTypesThroughGeneratedClassLiteralHelper() {\n        Class<?> resolvedType = HyphenQuoteFragmentEscaper.'class$'(HyphenQuoteFragmentEscaper.name) as Class<?>\n\n        assertThat(resolvedType).isSameAs(HyphenQuoteFragmentEscaper)\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1290, "output": 880, "cacheRead": 18944, "cacheWrite": 0, "totalTokens": 21114, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1779529839165, "responseId": "