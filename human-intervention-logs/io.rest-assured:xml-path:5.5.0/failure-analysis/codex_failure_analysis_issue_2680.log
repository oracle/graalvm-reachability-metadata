ghts waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage io_rest_assured.xml_path\\n\\nimport io.restassured.path.xml.XmlPath\\nimport io.restassured.path.xml.config.XmlPathConfig\\nimport io.restassured.path.xml.element.Node\\nimport io.restassured.path.xml.element.NodeChildren\\nimport io.restassured.path.xml.exception.XmlPathException\\nimport org.junit.jupiter.api.AfterEach\\nimport org.junit.jupiter.api.Test\\nimport org.junit.jupiter.api.io.TempDir\\nimport org.xml.sax.InputSource\\n\\nimport java.nio.charset.StandardCharsets\\nimport java.nio.file.Files\\nimport java.nio.file.Path\\n\\nimport static io.restassured.path.xml.XmlPath.CompatibilityMode.HTML\\nimport static io.restassured.path.xml.config.XmlPathConfig.xmlPathConfig\\nimport static org.assertj.core.api.Assertions.assertThat\\nimport static org.assertj.core.api.Assertions.assertThatThrownBy\\n\\npublic class Xml_pathTest {\\n    private static final String CATALOG_XML = '''\\\\\\n        <catalog generated=\\\"true\\\">\\n          <book id=\\\"b1\\\" category=\\\"reference\\\">\\n            <title>Effective XML</title>\\n            <price>39</price>\\n            <published>2022-01-05</published>\\n            <available>true</available>\\n            <code>A</code>\\n          </book>\\n          <book id=\\\"b2\\\" category=\\\"fiction\\\">\\n            <title>Native Tales</title>\\n            <price>12</price>\\n            <published>2021-11-10</published>\\n            <available>false</available>\\n            <code>B</code>\\n          </book>\\n          <book id=\\\"b3\\\" category=\\\"reference\\\">\\n            <title>Groovy Paths</title>\\n            <price>27</price>\\n            <published>2023-03-18</published>\\n            <available>true</available>\\n            <code>C</code>\\n          </book>\\n          <metrics>\\n            <smallByte>7</smallByte>\\n            <shortNumber>32000</shortNumber>\\n            <longNumber>922337203685477580</longNumber>\\n            <floatNumber>3.5</floatNumber>\\n            <doubleNumber>19.25</doubleNumber>\\n            <uuid>123e4567-e89b-12d3-a456-426614174000</uuid>\\n          </metrics>\\n        </catalog>\\n        '''\\n\\n    @AfterEach\\n    void resetGlobalConfiguration() {\\n        XmlPath.reset()\\n    }\\n\\n    @Test\\n    void readsScalarValuesListsMapsAndParameterizedGPathExpressions() {\\n        XmlPath xmlPath = XmlPath.from(CATALOG_XML)\\n\\n        assertThat(xmlPath.getString('catalog.@generated')).isEqualTo('true')\\n        assertThat(xmlPath.getInt('catalog.book.size()')).isEqualTo(3)\\n        assertThat(xmlPath.getBoolean('catalog.book[0].available')).isTrue()\\n        assertThat(xmlPath.getChar('catalog.book[2].code')).isEqualTo('C' as char)\\n        assertThat(xmlPath.getByte('catalog.metrics.smallByte')).isEqualTo((byte) 7)\\n        assertThat(xmlPath.getShort('catalog.metrics.shortNumber')).isEqualTo((short) 32000)\\n        assertThat(xmlPath.getLong('catalog.metrics.longNumber')).isEqualTo(922337203685477580L)\\n        assertThat(xmlPath.getFloat('catalog.metrics.floatNumber')).isEqualTo(3.5F)\\n        assertThat(xmlPath.getDouble('catalog.metrics.doubleNumber')).isEqualTo(19.25D)\\n        assertThat(xmlPath.getUUID('catalog.metrics.uuid').toString()).isEqualTo('123e4567-e89b-12d3-a456-426614174000')\\n\\n        assertThat(xmlPath.getList('catalog.book.title', String))\\n                .containsExactly('Effective XML', 'Native Tales', 'Groovy Paths')\\n        assertThat(xmlPath.getList('catalog.book.price', Integer))\\n                .containsExactly(39, 12, 27)\\n        assertThat(xmlPath.getMap('catalog.book[0].attributes()', String, String))\\n                .containsEntry('id', 'b1')\\n                .containsEntry('category', 'reference')\\n\\n        XmlPath withParameter = xmlPath.param('maximumPrice', 30)\\n        assertThat(withParameter.getList('catalog.book.findAll { it.price.toInteger() <= maximumPrice }.collect { it.@id.toString() }', String))\\n                .containsExactly('b2', 'b3')\\n    }\\n\\n    @Test\\n    void exposesRootNodesNodeChildrenAndRelativeGPathNavigation() {\\n        XmlPath xmlPath = new XmlPath(CATALOG_XML)\\n\\n        Node root = xmlPath.get()\\n        assertThat(root.name()).isEqualTo('catalog')\\n        assertThat(root.getAttribute('generated')).isEqualTo('true')\\n        assertThat(root.children().size()).isEqualTo(4)\\n        assertThat(root.children().isEmpty()).isFalse()\\n\\n        Node firstBook = xmlPath.getNode('catalog.book[0]')\\n        assertThat(firstBook.name()).isEqualTo('book')\\n        assertThat(firstBook.attributes())\\n                .containsEntry('id', 'b1')\\n                .containsEntry('category', 'reference')\\n        assertThat(firstBook.getNode('title').value()).isEqualTo('Effective XML')\\n        assertThat(firstBook.getNodes('title')).hasSize(1)\\n        assertThat(firstBook.get('@category')).isEqualTo('reference')\\n        assertThat(firstBook.getPath('price', Integer)).isEqualTo(39)\\n        assertThat(firstBook.iterator().next()).isEqualTo('Effective XML')\\n\\n        NodeChildren books = xmlPath.getNodeChildren('catalog.book')\\n        assertThat(books.size()).isEqualTo(3)\\n        assertThat(books.get(1).getAttribute('id')).isEqualTo('b2')\\n        assertThat(books.list()).extracting { Node node -> node.getAttribute('category') }\\n                .containsExactly('reference', 'fiction', 'reference')\\n        assertThat(books.nodeIterable()).extracting { Node node -> node.getNode('title').value() }\\n                .containsExactly('Effective XML', 'Native Tales', 'Groovy Paths')\\n        assertThat(books.nodeIterator().next().name()).isEqualTo('book')\\n        assertThat(books.getPath('findAll { it.@category == \\\"reference\\\" }.title.collect { it.text() }'))\\n                .isEqualTo(['Effective XML', 'Groovy Paths'])\\n        assertThat(books.iterator().next()).contains('Effective XML')\\n    }\\n\\n    @Test\\n    void supportsRootPathAndInputSources(@TempDir Path tempDir) {\\n        String xml = '<root><items><item id=\\\"1\\\">alpha</item><item id=\\\"2\\\">beta</item></items></root>'\\n        Path xmlFile = tempDir.resolve('document.xml')\\n        Files.writeString(xmlFile, xml, StandardCharsets.UTF_8)\\n\\n        XmlPath rootedPath = XmlPath.with(xml).setRootPath('root.items')\\n        assertThat(rootedPath.getInt('item.size()')).isEqualTo(2)\\n        assertThat(rootedPath.getString('item[1]')).isEqualTo('beta')\\n\\n        assertThat(XmlPath.given(new ByteArrayInputStream(xml.getBytes(StandardCharsets.UTF_8))).getString('root.items.item[0]'))\\n                .isEqualTo('alpha')\\n        assertThat(XmlPath.from(new StringReader(xml)).getString('root.items.item[1].@id'))\\n                .isEqualTo('2')\\n        assertThat(XmlPath.with(new InputSource(new StringReader(xml))).getInt('root.items.item.size()'))\\n                .isEqualTo(2)\\n        assertThat(XmlPath.given(xmlFile.toFile()).getString('root.items.item[0]'))\\n                .isEqualTo('alpha')\\n        assertThat(XmlPath.from(xmlFile.toUri()).getString('root.items.item[1]'))\\n                .isEqualTo('beta')\\n    }\\n\\n    @Test\\n    void appliesNamespacesDoctypeSettingsAndGlobalConfigurationReset() {\\n        String namespacedXml = '''\\\\\\n            <store xmlns:bk=\\\"urn:books\\\">\\n              <bk:book bk:id=\\\"n1\\\"><bk:title>Namespaced Book</bk:title></bk:book>\\n            </store>\\n            '''\\n        XmlPathConfig namespaceConfig = xmlPathConfig().declaredNamespace('bk', 'urn:books')\\n        XmlPath namespacedPath = new XmlPath(namespacedXml).using(namespaceConfig)\\n\\n        assertThat(namespacedPath.getString(\\\"store.'bk:book'.'bk:title'\\\")).isEqualTo('Namespaced Book')\\n        assertThat(namespaceConfig.declaredNamespaces()).containsEntry('bk', 'urn:books')\\n        assertThat(namespaceConfig.isNamespaceAware()).isTrue()\\n\\n        String documentWithInternalDtd = '''\\\\\\n            <!DOCTYPE note [\\n              <!ELEMENT note (message)>\\n              <!ELEMENT message (#PCDATA)>\\n            ]>\\n            <note><message>Hello from DTD</message></note>\\n            '''\\n        assertThatThrownBy { new XmlPath(documentWithInternalDtd).getString('note.message') }\\n                .isInstanceOf(XmlPathException)\\n\\n        XmlPathConfig dtdConfig = xmlPathConfig().allowDocTypeDeclaration(true).disableLoadingOfExternalDtd()\\n        assertThat(new XmlPath(documentWithInternalDtd).using(dtdConfig).getString('note.message'))\\n                .isEqualTo('Hello from DTD')\\n        assertThat(dtdConfig.features())\\n                .containsEntry('http://apache.org/xml/features/nonvalidating/load-external-dtd', false)\\n\\n        XmlPath.config = dtdConfig\\n        assertThat(XmlPath.from(documentWithInternalDtd).getString('note.message'))\\n                .isEqualTo('Hello from DTD')\\n        XmlPath.reset()\\n        assertThatThrownBy { XmlPath.from(documentWithInternalDtd).getString('note.message') }\\n                .isInstanceOf(XmlPathException)\\n    }\\n\\n    @Test\\n    void parsesLenientHtmlAndRendersPrettyXml() {\\n        String html = '<html><body><main><h1>REST Assured</h1><a href=\\\"/xml\\\">XML</a><a href=\\\"/json\\\">JSON</a></main></body></html>'\\n        XmlPath htmlPath = new XmlPath(HTML, html)\\n\\n        assertThat(htmlPath.getString('html.body.main.h1')).isEqualTo('REST Assured')\\n        assertThat(htmlPath.getList('html.body.main.a.@href', String)).containsExactly('/xml', '/json')\\n        assertThat(htmlPath.getString('html.body.main.a[1]')).isEqualTo('JSON')\\n\\n        String prettified = XmlPath.with('<root><child attribute=\\\"value\\\">text</child></root>').prettify()\\n        assertThat(pretti