via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage io_rest_assured.xml_path\\n\\nimport io.restassured.common.mapper.ObjectDeserializationContext\\nimport io.restassured.path.xml.XmlPath\\nimport io.restassured.path.xml.config.XmlPathConfig\\nimport io.restassured.path.xml.element.Node\\nimport io.restassured.path.xml.element.NodeChildren\\nimport io.restassured.path.xml.mapping.XmlPathObjectDeserializer\\nimport org.junit.jupiter.api.Test\\nimport org.junit.jupiter.api.io.TempDir\\n\\nimport java.nio.charset.StandardCharsets\\nimport java.nio.file.Files\\nimport java.nio.file.Path\\n\\nimport static io.restassured.path.xml.config.XmlPathConfig.xmlPathConfig\\nimport static org.assertj.core.api.Assertions.assertThat\\n\\npublic class Xml_pathTest {\\n    private static final String CATALOG_XML = '''\\\\\\n<library location=\\\"online\\\">\\n  <book id=\\\"b1\\\" available=\\\"true\\\">\\n    <title>Effective XML</title>\\n    <price>39.95</price>\\n    <pages>320</pages>\\n    <isbn>978-1-234567-89-7</isbn>\\n    <authors>\\n      <author role=\\\"primary\\\">Ada</author>\\n      <author role=\\\"contributor\\\">Linus</author>\\n    </authors>\\n  </book>\\n  <book id=\\\"b2\\\" available=\\\"false\\\">\\n    <title>Native Testing</title>\\n    <price>49.50</price>\\n    <pages>280</pages>\\n    <isbn>978-0-987654-32-1</isbn>\\n    <authors>\\n      <author role=\\\"primary\\\">Grace</author>\\n    </authors>\\n  </book>\\n  <magazine id=\\\"m1\\\">\\n    <title>XML Monthly</title>\\n    <issue>7</issue>\\n  </magazine>\\n</library>'''\\n\\n    @TempDir\\n    Path tempDirectory\\n\\n    @Test\\n    void readsScalarValuesAndCollectionsWithGPathExpressions() {\\n        XmlPath xmlPath = XmlPath.from(CATALOG_XML)\\n\\n        assertThat(xmlPath.getString('library.@location')).isEqualTo('online')\\n        assertThat(xmlPath.getString('library.book[0].title')).isEqualTo('Effective XML')\\n        assertThat(xmlPath.getBoolean('library.book[0].@available')).isTrue()\\n        assertThat(xmlPath.getInt('library.book[0].pages')).isEqualTo(320)\\n        assertThat(xmlPath.getFloat('library.book[0].price')).isEqualTo(39.95f)\\n        assertThat(xmlPath.getDouble('library.book[1].price')).isEqualTo(49.50d)\\n        assertThat(xmlPath.getList('library.book.title')).containsExactly('Effective XML', 'Native Testing')\\n        assertThat(xmlPath.getList('library.book.pages', Integer)).containsExactly(320, 280)\\n    }\\n\\n    @Test\\n    void supportsPathParametersAndRootPaths() {\\n        XmlPath xmlPath = new XmlPath(CATALOG_XML)\\n                .param('selectedId', 'b2')\\n                .setRootPath('library')\\n\\n        assertThat(xmlPath.getString(\\\"book.find { it.@id == selectedId }.title\\\")).isEqualTo('Native Testing')\\n        assertThat(xmlPath.getList(\\\"book.findAll { it.@available == 'true' }.title\\\")).containsExactly('Effective XML')\\n\\n        xmlPath.setRootPath('library.book[0]')\\n        assertThat(xmlPath.getString('title')).isEqualTo('Effective XML')\\n        assertThat(xmlPath.getString('authors.author.find { it.@role == \\\"primary\\\" }')).isEqualTo('Ada')\\n    }\\n\\n    @Test\\n    void exposesNodesAttributesChildrenAndNestedPathElements() {\\n        XmlPath xmlPath = XmlPath.with(CATALOG_XML)\\n\\n        Node root = xmlPath.get()\\n        assertThat(root.name()).isEqualTo('library')\\n        assertThat(root.getAttribute('location')).isEqualTo('online')\\n        assertThat(root.attributes()).containsEntry('location', 'online')\\n\\n        Node firstBook = xmlPath.getNode('library.book[0]')\\n        assertThat(firstBook.name()).isEqualTo('book')\\n        assertThat(firstBook.getAttribute('id')).isEqualTo('b1')\\n        assertThat(firstBook.getNode('title').value()).isEqualTo('Effective XML')\\n        assertThat(firstBook.getNodes('authors.author')*.value()).containsExactly('Ada', 'Linus')\\n\\n        NodeChildren books = xmlPath.getNodeChildren('library.book')\\n        assertThat(books.size()).isEqualTo(2)\\n        assertThat(books.isEmpty()).isFalse()\\n        assertThat(books.get(1).getAttribute('id')).isEqualTo('b2')\\n        assertThat(books.list()*.name()).containsExactly('book', 'book')\\n        assertThat(books.nodeIterable().collect { Node node -> node.getNode('title').value() })\\n                .containsExactly('Effective XML', 'Native Testing')\\n    }\\n\\n    @Test\\n    void parsesXmlFromSupportedInputSources() {\\n        Path xmlFile = tempDirectory.resolve('catalog.xml')\\n        Files.writeString(xmlFile, CATALOG_XML, StandardCharsets.UTF_8)\\n\\n        ByteArrayInputStream inputStream = new ByteArrayInputStream(CATALOG_XML.getBytes(StandardCharsets.UTF_8))\\n        StringReader reader = new StringReader(CATALOG_XML)\\n\\n        assertThat(new XmlPath(xmlFile.toFile()).getString('library.magazine.title')).isEqualTo('XML Monthly')\\n        assertThat(new XmlPath(xmlFile.toUri()).getString('library.book[1].title')).isEqualTo('Native Testing')\\n        assertThat(XmlPath.with(inputStream).getString('library.book[0].isbn')).isEqualTo('978-1-234567-89-7')\\n        assertThat(XmlPath.given(reader).getString('library.magazine.@id')).isEqualTo('m1')\\n    }\\n\\n    @Test\\n    void appliesParserConfigurationAndPrettifiesXml() {\\n        XmlPathConfig config = xmlPathConfig()\\n                .charset(StandardCharsets.UTF_8.name())\\n                .namespaceAware(false)\\n                .validating(false)\\n                .feature('http://xml.org/sax/features/namespaces', false)\\n                .property('http://javax.xml.XMLConstants/property/accessExternalDTD', '')\\n\\n        XmlPath xmlPath = XmlPath.from(CATALOG_XML).using(config)\\n\\n        assertThat(config.charset()).isEqualTo(StandardCharsets.UTF_8.name())\\n        assertThat(config.isNamespaceAware()).isFalse()\\n        assertThat(config.isValidating()).isFalse()\\n        assertThat(config.features()).containsEntry('http://xml.org/sax/features/namespaces', false)\\n        assertThat(config.properties()).containsEntry('http://javax.xml.XMLConstants/property/accessExternalDTD', '')\\n        assertThat(xmlPath.getString('library.book[0].title')).isEqualTo('Effective XML')\\n        assertThat(xmlPath.prettify()).contains('<library location=\\\"online\\\">')\\n                .contains('<title>Native Testing</title>')\\n    }\\n\\n    @Test\\n    void convertsPrimitiveScalarTypesAndUuidValues() {\\n        UUID uuid = UUID.fromString('123e4567-e89b-12d3-a456-426614174000')\\n        String xml = \\\"\\\"\\\"\\n<values>\\n  <letter>Z</letter>\\n  <byteValue>12</byteValue>\\n  <shortValue>1234</shortValue>\\n  <intValue>42</intValue>\\n  <longValue>9876543210</longValue>\\n  <floatValue>2.5</floatValue>\\n  <doubleValue>6.25</doubleValue>\\n  <flag>true</flag>\\n  <uuid>${uuid}</uuid>\\n</values>\\\"\\\"\\\"\\n\\n        XmlPath xmlPath = new XmlPath(xml)\\n\\n        assertThat(xmlPath.getChar('values.letter')).isEqualTo('Z' as char)\\n        assertThat(xmlPath.getByte('values.byteValue')).isEqualTo((byte) 12)\\n        assertThat(xmlPath.getShort('values.shortValue')).isEqualTo((short) 1234)\\n        assertThat(xmlPath.getInt('values.intValue')).isEqualTo(42)\\n        assertThat(xmlPath.getLong('values.longValue')).isEqualTo(9_876_543_210L)\\n        assertThat(xmlPath.getFloat('values.floatValue')).isEqualTo(2.5f)\\n        assertThat(xmlPath.getDouble('values.doubleValue')).isEqualTo(6.25d)\\n        assertThat(xmlPath.getBoolean('values.flag')).isTrue()\\n        assertThat(xmlPath.getUUID('values.uuid')).isEqualTo(uuid)\\n    }\\n\\n    @Test\\n    void parsesLenientHtmlInHtmlCompatibilityMode() {\\n        String html = '<html><body><section><p id=\\\"first\\\">Hello<br>World</p><p id=\\\"second\\\">Again</p></section></body></html>'\\n        XmlPath xmlPath = new XmlPath(XmlPath.CompatibilityMode.HTML, html)\\n\\n        assertThat(xmlPath.getString('html.body.section.p[0].@id')).isEqualTo('first')\\n        assertThat(xmlPath.getList('html.body.section.p.@id')).containsExactly('first', 'second')\\n        assertThat(xmlPath.getString('html.body.section.p[1]')).isEqualTo('Again')\\n    }\\n\\n    @Test\\n    void delegatesObjectConversionToConfiguredDeserializer() {\\n        XmlPathConfig config = xmlPathConfig().defaultObjectDeserializer(new BookSummaryDeserializer())\\n        XmlPath xmlPath = XmlPath.from(CATALOG_XML).using(config)\\n\\n        BookSummary summary = xmlPath.getObject('library.book[0]', BookSummary)\\n\\n        assertThat(summary.title).isEqualTo('Effective XML')\\n        assertThat(summary.pages).isEqualTo(320)\\n    }\\n\\n    private static final class BookSummary {\\n        final String title\\n        final int pages\\n\\n        private BookSummary(String title, int pages) {\\n            this.title = title\\n            this.pages = pages\\n        }\\n    }\\n\\n    private static final class BookSummaryDeserializer implements XmlPathObjectDeserializer {\\n        @Override\\n        @SuppressWarnings('unchecked')\\n        public <T> T deserialize(ObjectDeserializationContext context) {\\n            assertThat(context.type).isEqualTo(BookSummary)\\n            assertThat(context.charset).isNotBlank()\\n\\n            String xml = context.dataToDeserialize.asString()\\n            String title = extractElementValue(xml, 'title')\\n            int pages = extractElementValue(xml, 'pages') as int\\n            return (T) new BookSummary(title, pages)\\n        }\\n\\n        private static String extractElementValue(String xml, String elementName) {\\n            String quotedName = Pattern.quote(elementName)\\n            java.util.regex.Matcher matcher = xml =~ /<${quotedName}>\\\\s*(.*?)\\\\s*<\\\\/${quotedName}>/\\n            assertThat(matcher.find()).isTrue()\\n            return matcher.group(1)\