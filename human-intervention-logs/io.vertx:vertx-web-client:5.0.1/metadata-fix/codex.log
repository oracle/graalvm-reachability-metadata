lTo(1);\n   259\t        } finally {\n   260\t            close(client, server, vertx);\n   261\t        }\n   262\t    }\n   263\t\n   264\t    @Test\n   265\t    void sessionPersistsCookiesAndClientFollowsRedirects() throws Exception {\n   266\t        Vertx vertx = Vertx.vertx();\n   267\t        HttpServer server = null;\n   268\t        WebClientSession session = null;\n   269\t        try {\n   270\t            server = startServer(vertx, request -> {\n   271\t                if (\"/login\".equals(request.path())) {\n   272\t                    request.response()\n   273\t                            .putHeader(\"set-cookie\", \"sid=abc123; Path=/; HttpOnly\")\n   274\t                            .end(\"logged-in\");\n   275\t                    return;\n   276\t                }\n   277\t                if (\"/redirect\".equals(request.path())) {\n   278\t                    request.response()\n   279\t                            .setStatusCode(302)\n   280\t                            .putHeader(\"location\", \"/profile\")\n   281\t                            .end();\n   282\t                    return;\n   283\t                }\n   284\t                JsonObject body = new JsonObject()\n   285\t                        .put(\"cookie\", request.getHeader(\"cookie\"))\n   286\t                        .put(\"sessionHeader\", request.getHeader(\"X-Session-Header\"));\n   287\t                request.response().putHeader(\"content-type\", \"application/json\").end(body.encode());\n   288\t            });\n   289\t            WebClient baseClient = createClient(vertx, server.actualPort());\n   290\t            session = WebClientSession.create(baseClient)\n   291\t                    .addHeader(\"X-Session-Header\", \"present\");\n   292\t\n   293\t            HttpResponse<String> loginResponse = await(session.get(\"/login\")\n   294\t                    .as(BodyCodec.string())\n   295\t                    .send());\n   296\t            assertOk(loginResponse);\n   297\t            assertThat(loginResponse.body()).isEqualTo(\"logged-in\");\n   298\t\n   299\t            HttpResponse<JsonObject> profileResponse = await(session.get(\"/redirect\")\n   300\t                    .followRedirects(true)\n   301\t                    .as(BodyCodec.jsonObject())\n   302\t                    .send());\n   303\t\n   304\t            assertOk(profileResponse);\n   305\t            assertThat(profileResponse.getHeader(\"content-type\")).startsWith(\"application/json\");\n   306\t            assertThat(profileResponse.followedRedirects()).isNotEmpty();\n   307\t            assertThat(profileResponse.body().getString(\"cookie\")).contains(\"sid=abc123\");\n   308\t            assertThat(profileResponse.body().getString(\"sessionHeader\")).isEqualTo(\"present\");\n   309\t        } finally {\n   310\t            close(session, server, vertx);\n   311\t        }\n   312\t    }\n   313\t\n   314\t    private static void assertOk(HttpResponse<?> response) {\n   315\t        assertThat(response.statusCode()).isEqualTo(200);\n   316\t    }\n   317\t\n   318\t    private static WebClient createClient(Vertx vertx, int port) {\n   319\t        WebClientOptions options = new WebClientOptions()\n   320\t                .setDefaultHost(HOST)\n   321\t                .setDefaultPort(port)\n   322\t                .setConnectTimeout(2_000)\n   323\t                .setIdleTimeout(5)\n   324\t                .setFollowRedirects(false)\n   325\t                .setUserAgent(\"graalvm-reachability-metadata-test\");\n   326\t        return WebClient.create(vertx, options);\n   327\t    }\n   328\t\n   329\t    private static HttpServer startServer(Vertx vertx, Handler<HttpServerRequest> handler) throws Exception {\n   330\t        HttpServer server = vertx.createHttpServer().requestHandler(handler);\n   331\t        return await(server.listen(0, HOST));\n   332\t    }\n   333\t\n   334\t    private static <T> T await(Future<T> future) throws Exception {\n   335\t        return future.toCompletionStage().toCompletableFuture().get(TIMEOUT_SECONDS, TimeUnit.SECONDS);\n   336\t    }\n   337\t\n   338\t    private static void close(WebClient client, HttpServer server, Vertx vertx) throws Exception {\n   339\t        if (client != null) {\n   340\t            client.close();\n   341\t        }\n   342\t        if (server != null) {\n   343\t            await(server.close());\n   344\t        }\n   345\t        await(vertx.close());\n   346\t    }\n   347\t}\n","exit_code":0,"status":"completed"}}
