          <artifactId>maven-failsafe-plugin</artifactId>
          <configuration>
            <useModulePath>false</useModulePath>
          </configuration>
          <executions>
            <execution>
              <id>ssl-engine:default</id>
              <goals>
                <goal>integration-test</goal>
                <goal>verify</goal>
              </goals>
              <configuration>
