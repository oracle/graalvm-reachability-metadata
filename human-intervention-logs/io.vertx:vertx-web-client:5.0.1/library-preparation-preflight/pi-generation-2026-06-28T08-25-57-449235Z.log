xt/web/client/it/**/*.java</exclude>\n          </excludes>\n          <classpathDependencyExcludes>\n            <classpathDependencyExclude>com.fasterxml.jackson.core:jackson-databind</classpathDependencyExclude>\n          </classpathDependencyExcludes>\n        </configuration>\n      </plugin>\n      <plugin>\n        <groupId>org.apache.maven.plugins</groupId>\n        <artifactId>maven-failsafe-plugin</artifactId>\n        <executions>\n          <execution>\n            <id>databind-itest</id>\n            <goals>\n              <goal>integration-test</goal>\n              <goal>verify</goal>\n            </goals>\n            <configuration>\n              <includes>\n                <include>io/vertx/ext/web/client/it/WebClientDatabindTest.java</include>\n              </includes>\n            </configuration>\n          </execution>\n        </executions>\n      </plugin>\n    </plugins>\n  </build>\n\n</project>\n\n\n--- https://repo1.maven.org/maven2/io/vertx/vertx-core/5.0.1/vertx-core-5.0.1.pom\n<?xml version=\"1.0\"?>\n<!--\n  ~ Copyright (c) 2011-2019 Contributors to the Eclipse Foundation\n  ~\n  ~ This program and the accompanying materials are made available under the\n  ~ terms of the Eclipse Public License 2.0 which is available at\n  ~\n  ~ http://www.eclipse.org/legal/epl-2.0, or the Apache License, Version 2.0\n  ~ which is available at https://www.apache.org/licenses/LICENSE-2.0.\n  ~\n  ~ SPDX-License-Identifier: EPL-2.0 OR Apache-2.0\n  ~\n  -->\n<project xmlns=\"http://maven.apache.org/POM/4.0.0\" xmlns:xsi=\"http://www.w3.org/2001/XMLSchema-instance\" xsi:schemaLocation=\"http://maven.apache.org/POM/4.0.0                              http://maven.apache.org/xsd/maven-4.0.0.xsd\">\n  <modelVersion>4.0.0</modelVersion>\n\n  <parent>\n    <groupId>io.vertx</groupId>\n    <artifactId>vertx-core-aggregator</artifactId>\n    <version>5.0.1</version>\n  </parent>\n\n  <artifactId>vertx-core</artifactId>\n  <version>5.0.1</version>\n\n  <name>Vert.x Core</name>\n\n  <properties>\n    <apacheds-protocol-dns.version>2.0.0.AM27</apacheds-protocol-dns.version>\n    <generated.dir>${project.basedir}/src/main/generated</generated.dir>\n    <jmh.version>1.37</jmh.version>\n    <vertx.surefire.nettyTransport>jdk</vertx.surefire.nettyTransport>\n    <vertx.surefire.useDomainSockets>false</vertx.surefire.useDomainSockets>\n  </properties>\n\n  <dependencies>\n\n    <dependency>\n      <groupId>io.vertx</groupId>\n      <artifactId>vertx-core-logging</artifactId>\n    </dependency>\n\n    <!-- We depend on the specific Netty dependencies not netty-all to reduce the size of fatjars -->\n    <dependency>\n      <groupId>io.netty</groupId>\n      <artifactId>netty-common</artifactId>\n    </dependency>\n    <dependency>\n      <groupId>io.netty</groupId>\n      <artifactId>netty-buffer</artifactId>\n    </dependency>\n    <dependency>\n      <groupId>io.netty</groupId>\n      <artifactId>netty-transport</artifactId>\n    </dependency>\n    <dependency>\n      <groupId>io.netty</groupId>\n      <artifactId>netty-handler</artifactId>\n    </dependency>\n    <dependency>\n      <groupId>io.netty</groupId>\n      <artifactId>netty-handler-proxy</artifactId>\n    </dependency>\n    <dependency>\n      <groupId>io.netty</groupId>\n      <artifactId>netty-codec-http</artifactId>\n    </dependency>\n    <dependency>\n      <groupId>io.netty</groupId>\n      <artifactId>netty-codec-http2</artifactId>\n    </dependency>\n    <dependency>\n      <groupId>io.netty</groupId>\n      <artifactId>netty-resolver</artifactId>\n    </dependency>\n    <dependency>\n      <groupId>io.netty</groupId>\n      <artifactId>netty-resolver-dns</artifactId>\n    </dependency>\n    <dependency>\n      <groupId>io.netty</groupId>\n      <artifactId>netty-codec-haproxy</artifactId>\n      <optional>true</optional>\n    </dependency>\n    <dependency>\n      <groupId>io.netty</groupId>\n      <artifactId>netty-transport-classes-epoll</artifactId>\n      <optional>true</optional>\n    </dependency>\n    <dependency>\n      <groupId>io.netty</groupId>\n      <artifactId>netty-transport-classes-io_uring</artifactId>\n      <optional>true</optional>\n    </dependency>\n    <dependency>\n      <groupId>io.netty</groupId>\n      <artifactId>netty-transport-classes-kqueue</artifactId>\n      <optional>true</optional>\n    </dependency>\n\n    <!-- Jackson -->\n    <dependency>\n      <groupId>com.fasterxml.jackson.core</groupId>\n      <artifactId>jackson-core</artifactId>\n    </dependency>\n    <dependency>\n      <groupId>com.fasterxml.jackson.core</groupId>\n      <artifactId>jackson-databind</artifactId>\n      <optional>true</optional>\n    </dependency>\n\n    <!-- Loggers -->\n    <dependency>\n      <groupId>org.apache.logging.log4j</groupId>\n      <artifactId>log4j-api</artifactId>\n      <optional>true</optional>\n    </dependency>\n    <dependency>\n      <groupId>org.slf4j</groupId>\n      <artifactId>slf4j-api</artifactId>\n      <optional>true</optional>\n    </dependency>\n\n    <!-- Generators -->\n    <dependency>\n      <groupId>io.vertx</groupId>\n      <artifactId>vertx-codegen-api</artifactId>\n      <optional>true</optional>\n    </dependency>\n    <dependency>\n      <groupId>io.vertx</groupId>\n      <artifactId>vertx-codegen-json</artifactId>\n      <optional>true</optional>\n    </dependency>\n    <dependency>\n      <groupId>io.vertx</groupId>\n      <artifactId>vertx-docgen-api</artifactId>\n      <optional>true</optional>\n    </dependency>\n\n    <!-- Testing -->\n    <dependency>\n      <groupId>junit</groupId>\n      <artifactId>junit</artifactId>\n      <version>${junit.version}</version>\n      <scope>test</scope>\n    </dependency>\n    <dependency>\n      <groupId>org.hamcrest</groupId>\n      <artifactId>hamcrest-core</artifactId>\n      <version>${harmcrest.version}</version>\n      <scope>test</scope>\n    </dependency>\n    <dependency>\n      <groupId>org.apache.directory.server</groupId>\n      <artifactId>apacheds-protocol-dns</artifactId>\n      <version>${apacheds-protocol-dns.version}</version>\n      <scope>test</scope>\n    </dependency>\n    <dependency>\n      <groupId>org.assertj</groupId>\n      <artifactId>assertj-core</artifactId>\n      <version>${assertj.version}</version>\n      <scope>test</scope>\n    </dependency>\n    <dependency>\n      <groupId>org.slf4j</groupId>\n      <artifactId>slf4j-simple</artifactId>\n      <scope>test</scope>\n    </dependency>\n    <dependency>\n      <groupId>org.apache.logging.log4j</groupId>\n      <artifactId>log4j-core</artifactId>\n      <scope>test</scope>\n    </dependency>\n    <dependency>\n      <groupId>io.netty</groupId>\n      <artifactId>netty-tcnative-boringssl-static</artifactId>\n      <scope>test</scope>\n    </dependency>\n    <dependency>\n      <groupId>com.aayushatharva.brotli4j</groupId>\n      <artifactId>brotli4j</artifactId>\n      <version>1.16.0</version>\n      <scope>test</scope>\n    </dependency>\n    <dependency>\n      <groupId>com.github.luben</groupId>\n      <artifactId>zstd-jni</artifactId>\n      <version>1.5.6-5</version>\n      <scope>test</scope>\n    </dependency>\n\n    <!-- Scope test to declare soft dependency related to maven-compiler-plugin usage -->\n    <dependency>\n      <groupId>io.vertx</groupId>\n      <artifactId>vertx-codegen</artifactId>\n      <scope>test</scope>\n    </dependency>\n\n    <!-- JMH -->\n    <dependency>\n      <groupId>org.openjdk.jmh</groupId>\n      <artifactId>jmh-core</artifactId>\n      <version>${jmh.version}</version>\n      <scope>test</scope>\n    </dependency>\n\n  </dependencies>\n\n  <build>\n    <pluginManagement>\n      <plugins>\n\n        <plugin>\n          <artifactId>maven-compiler-plugin</artifactId>\n          <executions>\n            <execution>\n              <id>default-compile</id>\n              <configuration>\n                <annotationProcessorPaths>\n                  <annotationProcessorPath>\n                    <groupId>io.vertx</groupId>\n                    <artifactId>vertx-codegen</artifactId>\n                    <classifier>processor</classifier>\n                  </annotationProcessorPath>\n                  <annotationProcessorPath>\n                    <groupId>io.vertx</groupId>\n                    <artifactId>vertx-docgen-processor</artifactId>\n                    <classifier>processor</classifier>\n                  </annotationProcessorPath>\n                </annotationProcessorPaths>\n              </configuration>\n            </execution>\n          </executions>\n        </plugin>\n\n        <plugin>\n          <groupId>org.apache.maven.plugins</groupId>\n          <artifactId>maven-surefire-plugin</artifactId>\n          <configuration>\n            <failIfNoSpecifiedTests>false</failIfNoSpecifiedTests>\n            <additionalClasspathElements>\n              <!-- Can we remove this one ??? -->\n              <additionalClasspathElement>${project.build.testSourceDirectory}</additionalClasspathElement>\n              <additionalClasspathElement>${project.basedir}/src/test/classpath/jul</additionalClasspathElement>\n              <additionalClasspathElement>${project.basedir}/src/test/classpath/sourceverticle</addi\n"}], "isError": false, "timestamp": 1782635134070}]}
