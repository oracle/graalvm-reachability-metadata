  23: /**
  24:  * An asynchronous OAuth2/OIDC aware HTTP / HTTP/2 client called {@code WebClientOAuth2}.
  25:  * <p>
  26:  * This client wraps a {@link WebClient} and makes it session aware adding features to it:
  27:  * <ul>
  28:  *   <li>Request an {@code access_token} if no user is created</li>
  29:  *   <li>Refresh {@code access_token} if current user is expired</li>
  30:  * </ul>
  31:  * <p>
  32:  */
  33: @VertxGen
  34: public interface OAuth2WebClient extends WebClient {
  35: 
  36:   /**
  37:    * Create a session aware web client using the provided {@code webClient} instance.
  38:    *
  39:    * @param webClient the web client instance
  40:    * @param oAuth2Auth Configured oAuth2Auth provider to be used when {@link #withCredentials(Credentials)} used
  41:    * @return the created client
  42:    */
  43:   static OAuth2WebClient create(WebClient webClient, OAuth2Auth oAuth2Auth) {
  44:     return create(webClient, oAuth2Auth, new OAuth2WebClientOptions());
  45:   }
  46: 
  47:   /**
  48:    * Create a session aware web client using the provided {@code webClient} instance.
  49:    *
  50:    * @param webClient the web client instance
  51:    * @param oAuth2Auth Configured oAuth2Auth provider to be used when {@link #withCredentials(Credentials)} used
  52:    * @param options extra configuration for this object
  53:    * @return the created client
  54:    */
  55:   static OAuth2WebClient create(WebClient webClient, OAuth2Auth oAuth2Auth, OAuth2WebClientOptions options) {
  56:     return new Oauth2WebClientAware(webClient, oAuth2Auth, options);
  57:   }
  58: 
