static class RecordingLoadedTypeInitializer implements LoadedTypeInitializer {\n        private Class<?> loadedType;\n\n        @Override\n        public void onLoad(Class<?> type) {\n            loadedType = type;\n        }\n\n        @Override\n        public boolean isAlive() {\n            return true;\n        }\n\n        Class<?> getLoadedType() {\n            return loadedType;\n        }\n    }\n}\n"}
