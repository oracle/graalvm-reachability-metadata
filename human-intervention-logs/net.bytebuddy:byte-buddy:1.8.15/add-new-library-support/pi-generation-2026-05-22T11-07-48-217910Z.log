  package net_bytebuddy.byte_buddy;
  
  import java.lang.reflect.Method;
  import java.net.URL;
  import java.security.ProtectionDomain;
  
  import net.bytebuddy.ByteBuddy;
  import net.bytebuddy.ClassFileVersion;
  import net.bytebuddy.dynamic.DynamicType;
  import net.bytebuddy.dynamic.loading.ClassInjector;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ClassInjectorInnerUsingReflectionInnerDispatcherInnerDirectTest {
      @Test
      void invokesDirectDispatcherAccessorMethods() throws Exception {
          try {
              invokeDirectDispatcherAccessorMethods();
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
      }
  
      private static void invokeDirectDispatcherAccessorMethods() throws Exception {
          String packageName = "net_bytebuddy.byte_buddy.direct";
          String typeName = packageName + ".DirectlyInjectedType";
          DynamicType.Unloaded<?> dynamicType = makeType(typeName);
          DirectOperations operations = UsingReflectionAccess.makeDirectOperations();
          TestClassLoader classLoader = new TestClassLoader();
          ProtectionDomain protectionDomain = ClassInjector.UsingReflection.class.getProtectionDomain();
  
          assertThat(operations.findClass(classLoader, typeName)).isNull();
          assertThat(operations.getPackage(classLoader, packageName)).isNull();
  
          Package definedPackage = operations.definePackage(classLoader, packageName);
          assertThat(definedPackage).isNotNull();
          assertThat(definedPackage.getName()).isEqualTo(packageName);
  
          Class<?> loadedType = operations.defineClass(classLoader, typeName, dynamicType.getBytes(), protectionDomain);
          assertThat(loadedType.getName()).isEqualTo(typeName);
          assertThat(loadedType.getClassLoader()).isSameAs(classLoader);
          assertThat(operations.findClass(classLoader, typeName)).isSameAs(loadedType);
          assertThat(operations.getPackage(classLoader, packageName)).isSameAs(definedPackage);
      }
  
      private static DynamicType.Unloaded<?> makeType(String typeName) {
          return new ByteBuddy(ClassFileVersion.JAVA_V8)
                  .subclass(Object.class)
                  .name(typeName)
                  .make();
      }
  
      private interface DirectOperations {
          Class<?> findClass(ClassLoader classLoader, String name);
  
          Class<?> defineClass(ClassLoader classLoader,
                               String name,
                               byte[] binaryRepresentation,
                               ProtectionDomain protectionDomain);
  
          Package getPackage(ClassLoader classLoader, String name);
  
          Package definePackage(ClassLoader classLoader, String name);
      }
  
      private static class UsingReflectionAccess extends ClassInjector.UsingReflection {
          UsingReflectionAccess() {
              super(ClassLoader.getSystemClassLoader());
          }
  
          static DirectOperations makeDirectOperations() throws NoSuchMethodException {
              Dispatcher dispatcher = new TestDirect(
                      TestClassLoader.class.getMethod("findLoadedClassPublic", String.class),
                      TestClassLoader.class.getMethod("defineClassPublic",
                              String.class,
                              byte[].class,
                              int.class,
                              int.class,
                              ProtectionDomain.class),
                      TestClassLoader.class.getMethod("getPackagePublic", String.class),
                      TestClassLoader.class.getMethod("definePackagePublic",
                              String.class,
                              String.class,
                              String.class,
                              String.class,
                              String.class,
                              String.class,
                              String.class,
                              URL.class)).initialize();
              return toDirectOperations(dispatcher);
          }
  
          private static DirectOperations toDirectOperations(final Dispatcher dispatcher) {
              return new DirectOperations() {
                  @Override
                  public Class<?> findClass(ClassLoader classLoader, String name) {
                      return dispatcher.findClass(classLoader, name);
                  }
  
                  @Override
                  public Class<?> defineClass(ClassLoader classLoader,
                                              String name,
                                              byte[] binaryRepresentation,
                                              ProtectionDomain protectionDomain) {
                      return dispatcher.defineClass(classLoader, name, binaryRepresentation, protectionDomain);
                  }
  
                  @Override
                  public Package getPackage(ClassLoader classLoader, String name) {
                      return dispatcher.getPackage(classLoader, name);
                  }
  
                  @Override
                  public Package definePackage(ClassLoader classLoader, String name) {
                      return dispatcher.definePackage(classLoader, name, null, null, null, null, null, null, null);
                  }
              };
          }
  
          private static class TestDirect extends Dispatcher.Direct {
              TestDirect(Method findLoadedClass, Method defineClass, Method getPackage, Method definePackage) {
                  super(findLoadedClass, defineClass, getPackage, definePackage);
              }
  
              @Override
              public Object getClassLoadingLock(ClassLoader classLoader, String name) {
                  return classLoader;
              }
  
              @Override
              protected void onInitialization() {
                  /* do nothing */
              }
          }
      }
  
      public static class TestClassLoader extends ClassLoader {
          public TestClassLoader() {
              super(null);
          }
  
          public Class<?> findLoadedClassPublic(String name) {
              return findLoadedClass(name);
          }
  
          public Class<?> defineClassPublic(String name,
                                            byte[] binaryRepresentation,
                                            int offset,
                                            int length,
                                            ProtectionDomain protectionDomain) {
              return defineClass(name, binaryRepresentation, offset, length, protectionDomain);
          }
  
          public Package getPackagePublic(String name) {
              return getPackage(name);
          }
  
          public Package definePackagePublic(String name,
                                             String specificationTitle,
                                             String specificationVersion,
                                             String specificationVendor,
                                             String implementationTitle,
                                             String implementationVersion,
                                             String implementationVendor,
                                             URL sealBase) {
              return definePackage(name,
                      specificationTitle,
                      specificationVersion,
                      specificationVendor,
                      implementationTitle,
                      implementationVersion,
                      implementationVendor,
                      sealBase);
          }
      }
  }
