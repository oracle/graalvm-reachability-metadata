              @Override
              public String getSymbol() {
                  return resolve().getSymbol();
              }
  
              @Override
              public String getActualName() {
                  return resolve().getActualName();
              }
  
              @Override
              public <T> T accept(Visitor<T> visitor) {
                  return resolve().accept(visitor);
