      boolean reset(Instrumentation instrumentation,
                    AgentBuilder.RedefinitionStrategy redefinitionStrategy,
                    AgentBuilder.RedefinitionStrategy.DiscoveryStrategy redefinitionDiscoveryStrategy);
  
