  plugins {
      id "org.graalvm.internal.tck"
  }
  
  String libraryVersion = tck.testedLibraryVersion.get()
  File compiledTestClassesDir = layout.buildDirectory.dir("classes/java/test").get().asFile
  File processedTestResourcesDir = layout.buildDirectory.dir("resources/test").get().asFile
  File generatedNexusMarkerFile = layout.buildDirectory.dir("generated/predefined-nexus-test-class").get().file("done.marker").asFile
  File generatedNexusClassFile = new File(
          compiledTestClassesDir,
          "net_bytebuddy/byte_buddy/generated/NexusInitializationSample.class")
  String javaHome = System.getenv("JAVA_HOME")
  
  configurations {
      byteBuddyAgent {
          canBeConsumed = false
          canBeResolved = true
      }
  }
  
  dependencies {
      byteBuddyAgent "net.bytebuddy:byte-buddy-agent:$libraryVersion"
      testImplementation "net.bytebuddy:byte-buddy:$libraryVersion"
      testRuntimeOnly "net.bytebuddy:byte-buddy-agent:$libraryVersion"
      testImplementation 'org.assertj:assertj-core:3.22.0'
  }
  
  tasks.withType(Test).configureEach {
      jvmArgs "-javaagent:${configurations.byteBuddyAgent.singleFile}"
      doFirst {
          delete(generatedNexusClassFile)
          delete(generatedNexusMarkerFile)
      }
  }
  
  graalvmNative {
      agent {
          defaultMode = "conditional"
          modes {
              conditional {
                  userCodeFilterPath = "user-code-filter.json"
              }
          }
      }
  }
  
  tasks.register("generatePredefinedNexusClasses", JavaExec) { JavaExec task ->
      task.dependsOn(tasks.named("testClasses"))
      task.mustRunAfter(tasks.named("test"))
      task.inputs.files(compiledTestClassesDir, processedTestResourcesDir, configurations.testRuntimeClasspath)
      task.outputs.file(generatedNexusMarkerFile)
      task.classpath = files(compiledTestClassesDir, processedTestResourcesDir, configurations.testRuntimeClasspath)
