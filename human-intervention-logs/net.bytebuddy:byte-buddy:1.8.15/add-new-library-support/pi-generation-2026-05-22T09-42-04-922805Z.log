[tool-call] delta {"path":"tests/src/net.bytebuddy/byte-buddy/1.8.15/src/test/java/net_bytebuddy/byte_buddy/ByteArrayClassLoaderInnerChildFirstTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage net_bytebuddy.byte_buddy;\n\nimport java.io.IOException;\nimport java.net.MalformedURLException;\nimport java.net.URL;\nimport java.security.ProtectionDomain;\nimport java.util.Collections;\nimport java.util.Enumeration;\nimport java.util.HashMap;\nimport java.util.Map;\nimport java.util.Vector;\n\nimport net.bytebuddy.ByteBuddy;\nimport net.bytebuddy.ClassFileVersion;\nimport net.bytebuddy.description.type.TypeDescription;\nimport net.bytebuddy.dynamic.DynamicType;\nimport net.bytebuddy.dynamic.loading.ByteArrayClassLoader;\nimport net.bytebuddy.dynamic.loading.ClassLoadingStrategy;\nimport net.bytebuddy.dynamic.loading.PackageDefinitionStrategy;\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ByteArrayClassLoaderInnerChildFirstTest {\n    @Test\n    void loadsTypesWithChildFirstStaticStrategy() {\n        try {\n            String typeName = \"net_bytebuddy.byte_buddy.generated.ChildFirstStaticLoadedType\";\n            DynamicType.Unloaded<?> dynamicType = makeType(typeName);\n            Map<TypeDescription, byte[]> types = new HashMap<TypeDescription, byte[]>();\n            types.put(dynamicType.getTypeDescription(), dynamicType.getBytes());\n\n            Map<TypeDescription, Class<?>> loadedTypes = ByteArrayClassLoader.ChildFirst.load(\n                    ClassLoader.getSystemClassLoader(),\n                    types,\n                    ClassLoadingStrategy.NO_PROTECTION_DOMAIN,\n                    ByteArrayClassLoader.PersistenceHandler.LATENT,\n                    PackageDefinitionStrategy.Trivial.INSTANCE,\n                    true,\n                    true);\n\n            Class<?> loadedType = loadedTypes.get(dynamicType.getTypeDescription());\n            assertThat(loadedType).isNotNull();\n            assertThat(loadedType.getName()).isEqualTo(typeName);\n            assertThat(loadedType.getClassLoader()).isInstanceOf(ByteArrayClassLoader.ChildFirst.class);\n            assertThat(loadedType.getClassLoader().loadClass(typeName)).isSameAs(loadedType);\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        } catch (ClassNotFoundException exception) {\n            throw new AssertionError(exception);\n        }\n    }\n\n    @Test\n    void delegatesParentOnlyResourceLookups() throws IOException {\n        try {\n            URL parentOnlyResource = url(\"file:/byte-buddy-parent-only-resource.txt\");\n            ParentResourceClassLoader parent = new ParentResourceClassLoader(\n                    \"byte-buddy-parent-only-resource.txt\",\n                    parentOnlyResource);\n            ByteArrayClassLoader.ChildFirst classLoader = new ByteArrayClassLoader.ChildFirst(\n                    parent,\n                    Collections.<String, byte[]>emptyMap(),\n                    ByteArrayClassLoader.PersistenceHandler.LATENT);\n\n            assertThat(classLoader.getResource(\"byte-buddy-parent-only-resource.txt\")).isEqualTo(parentOnlyResource);\n            Enumeration<URL> resources = classLoader.getResources(\"byte-buddy-parent-only-resource.txt\");\n            assertThat(resources.hasMoreElements()).isTrue();\n            assertThat(resources.nextElement()).isEqualTo(parentOnlyResource);\n            assertThat(resources.hasMoreElements()).isFalse();\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    @Test\n    void handlesChildClassResourcesBeforeAndAfterLoading() throws Exception {\n        try {\n            String latentTypeName = \"net_bytebuddy.byte_buddy.generated.ChildFirstLatentLoadedType\";\n            DynamicType.Unloaded<?> latentType = makeType(latentTypeName);\n            Map<String, byte[]> latentTypes = new HashMap<String, byte[]>();\n            latentTypes.put(latentTypeName, latentType.getBytes());\n            ByteArrayClassLoader.ChildFirst latentClassLoader = new ByteArrayClassLoader.ChildFirst(\n                    ClassLoader.getSystemClassLoader(),\n                    latentTypes,\n                    ByteArrayClassLoader.PersistenceHandler.LATENT);\n\n            Class<?> loadedLatentType = latentClassLoader.loadClass(latentTypeName);\n\n            assertThat(loadedLatentType.getClassLoader()).isSameAs(latentClassLoader);\n            assertThat(latentClassLoader.getResource(resourceName(latentTypeName))).isNull();\n\n            String manifestTypeName = \"net_bytebuddy.byte_buddy.generated.ChildFirstManifestResourceType\";\n            DynamicType.Unloaded<?> manifestType = makeType(manifestTypeName);\n            Map<String, byte[]> manifestTypes = new HashMap<String, byte[]>();\n            manifestTypes.put(manifestTypeName, manifestType.getBytes());\n            String manifestResourceName = resourceName(manifestTypeName);\n            URL parentResource = url(\"file:/byte-buddy-parent-class-resource.class\");\n            ByteArrayClassLoader.ChildFirst manifestClassLoader = new ByteArrayClassLoader.ChildFirst(\n                    new ParentResourceClassLoader(manifestResourceName, parentResource),\n                    manifestTypes,\n                    ByteArrayClassLoader.PersistenceHandler.MANIFEST);\n\n            Enumeration<URL> resources = manifestClassLoader.getResources(manifestResourceName);\n\n            assertThat(resources.hasMoreElements()).isTrue();\n            assertThat(resources.nextElement().getProtocol()).isEqualTo(ByteArrayClassLoader.URL_SCHEMA);\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    private static DynamicType.Unloaded<?> makeType(String typeName) {\n        return new ByteBuddy(ClassFileVersion.JAVA_V8)\n                .subclass(Object.class)\n                .name(typeName)\n                .make();\n    }\n\n    private static String resourceName(String typeName) {\n        return typeName.replace('.', '/') + \".class\";\n    }\n\n    private static URL url(String value) throws MalformedURLException {\n        return new URL(value);\n    }\n\n    private static class ParentResourceClassLoader extends ClassLoader {\n        private final String resourceName;\n        private final URL resource;\n\n        ParentResourceClassLoader(String resourceName, URL resource) {\n            super(null);\n            this.resourceName = resourceName;\n            this.resource = resource;\n        }\n\n        @Override\n        protected URL findResource(String name) {\n            return resourceName.equals(name)\n                    ? resource\n                    : null;\n        }\n\n        @Override\n        protected Enumeration<URL> findResources(String name) {\n            Vector<URL> resources = new Vector<URL>();\n            if (resourceName.equals(name)) {\n                resources.add(resource);\n            }\n            return resources.elements();\n        }\n    }\n}\n"}
