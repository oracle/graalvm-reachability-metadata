      @HashCodeAndEqualsPlugin.Enhance
      class ManifestReading implements PackageDefinitionStrategy {
  
          /**
           * The path to the manifest file.
           */
          private static final String MANIFEST_FILE = "/META-INF/MANIFEST.MF";
  
