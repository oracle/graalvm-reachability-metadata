  import net.bytebuddy.utility.JavaModule;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class JavaModuleInnerDispatcherInnerEnabledTest {
      @Test
      void accessesCurrentModuleThroughEnabledDispatcher() throws Exception {
          JavaModule currentModule = JavaModule.ofType(JavaModuleInnerDispatcherInnerEnabledTest.class);
  
          assertThat(JavaModule.isSupported()).isTrue();
          assertThat(currentModule).isNotNull();
          assertThat(currentModule.isNamed()).isFalse();
          assertThat(currentModule.getActualName()).isNull();
          assertThat(currentModule.getClassLoader())
                  .isSameAs(JavaModuleInnerDispatcherInnerEnabledTest.class.getClassLoader());
          assertThat(currentModule.unwrap()).isEqualTo(JavaModuleInnerDispatcherInnerEnabledTest.class.getModule());
          assertThat(currentModule)
                  .isEqualTo(JavaModule.of(JavaModuleInnerDispatcherInnerEnabledTest.class.getModule()));
  
          assertThat(currentModule.getResourceAsStream("net_bytebuddy/byte_buddy/missing-resource.txt")).isNull();
      }
  
      @Test
      void checksAndAddsReadEdgeThroughEnabledDispatcher() {
          JavaModule currentModule = JavaModule.ofType(JavaModuleInnerDispatcherInnerEnabledTest.class);
          JavaModule javaBaseModule = JavaModule.ofType(String.class);
          RecordingInstrumentation instrumentation = new RecordingInstrumentation();
  
          assertThat(currentModule.canRead(javaBaseModule)).isTrue();
  
          currentModule.addReads(instrumentation, javaBaseModule);
  
          assertThat(instrumentation.modifiableModule).isSameAs(currentModule.unwrap());
          assertThat(instrumentation.redefinedModule).isSameAs(currentModule.unwrap());
          assertThat(instrumentation.extraReads).containsExactly((Module) javaBaseModule.unwrap());
          assertThat(instrumentation.extraExports).isEmpty();
          assertThat(instrumentation.extraOpens).isEmpty();
          assertThat(instrumentation.extraUses).isEmpty();
          assertThat(instrumentation.extraProvides).isEmpty();
      }
  
