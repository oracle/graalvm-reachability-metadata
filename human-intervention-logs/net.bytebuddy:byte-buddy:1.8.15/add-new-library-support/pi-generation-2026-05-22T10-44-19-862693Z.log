[tool-call] delta {"path":"tests/src/net.bytebuddy/byte-buddy/1.8.15/src/test/java/net_bytebuddy/byte_buddy/AgentBuilderInnerDefaultTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage net_bytebuddy.byte_buddy;\n\nimport java.lang.instrument.ClassDefinition;\nimport java.lang.instrument.ClassFileTransformer;\nimport java.lang.instrument.Instrumentation;\nimport java.lang.instrument.UnmodifiableClassException;\nimport java.util.List;\nimport java.util.Map;\nimport java.util.Set;\nimport java.util.jar.JarFile;\n\nimport net.bytebuddy.agent.Installer;\nimport net.bytebuddy.agent.builder.AgentBuilder;\nimport net.bytebuddy.agent.builder.ResettableClassFileTransformer;\nimport org.junit.jupiter.api.AfterEach;\nimport org.junit.jupiter.api.BeforeEach;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class AgentBuilderInnerDefaultTest {\n    private final RecordingInstrumentation instrumentation = new RecordingInstrumentation();\n\n    @BeforeEach\n    void installInstrumentation() {\n        Installer.premain(\"\", instrumentation);\n    }\n\n    @AfterEach\n    void clearInstrumentation() {\n        Installer.premain(\"\", null);\n    }\n\n    @Test\n    void installsDefaultTransformerOnByteBuddyAgentInstrumentation() {\n        ResettableClassFileTransformer transformer = new AgentBuilder.Default()\n                .installOnByteBuddyAgent();\n\n        assertThat(transformer).isNotNull();\n        assertThat(instrumentation.transformer).isSameAs(transformer);\n        assertThat(instrumentation.canRetransform).isFalse();\n    }\n\n    private static class RecordingInstrumentation implements Instrumentation {\n        private ClassFileTransformer transformer;\n        private boolean canRetransform;\n\n        @Override\n        p