  package net_bytebuddy.byte_buddy;
  
  import java.io.IOException;
  import java.net.MalformedURLException;
  import java.net.URL;
  import java.util.Collections;
  import java.util.Enumeration;
  import java.util.HashMap;
  import java.util.Map;
  import java.util.Vector;
  
  import net.bytebuddy.ByteBuddy;
  import net.bytebuddy.ClassFileVersion;
  import net.bytebuddy.description.type.TypeDescription;
  import net.bytebuddy.dynamic.DynamicType;
  import net.bytebuddy.dynamic.loading.ByteArrayClassLoader;
  import net.bytebuddy.dynamic.loading.ClassLoadingStrategy;
  import net.bytebuddy.dynamic.loading.PackageDefinitionStrategy;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ByteArrayClassLoaderInnerChildFirstTest {
      @Test
      void loadsTypesWithChildFirstStaticStrategy() {
          try {
              String typeName = "net_bytebuddy.byte_buddy.generated.ChildFirstStaticLoadedType";
              DynamicType.Unloaded<?> dynamicType = makeType(typeName);
              Map<TypeDescription, byte[]> types = new HashMap<TypeDescription, byte[]>();
              types.put(dynamicType.getTypeDescription(), dynamicType.getBytes());
  
              Map<TypeDescription, Class<?>> loadedTypes = ByteArrayClassLoader.ChildFirst.load(
                      ClassLoader.getSystemClassLoader(),
                      types,
                      ClassLoadingStrategy.NO_PROTECTION_DOMAIN,
                      ByteArrayClassLoader.PersistenceHandler.LATENT,
                      PackageDefinitionStrategy.Trivial.INSTANCE,
                      true,
                      true);
  
              Class<?> loadedType = loadedTypes.get(dynamicType.getTypeDescription());
              assertThat(loadedType).isNotNull();
              assertThat(loadedType.getName()).isEqualTo(typeName);
              assertThat(loadedType.getClassLoader()).isInstanceOf(ByteArrayClassLoader.ChildFirst.class);
              assertThat(loadedType.getClassLoader().loadClass(typeName)).isSameAs(loadedType);
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          } catch (ClassNotFoundException exception) {
              throw new AssertionError(exception);
          }
      }
  
      @Test
      void delegatesParentOnlyResourceLookups() throws IOException {
          URL parentOnlyResource = url("file:/byte-buddy-parent-only-resource.txt");
          ParentResourceClassLoader parent = new ParentResourceClassLoader(
                  "byte-buddy-parent-only-resource.txt",
                  parentOnlyResource);
          ByteArrayClassLoader.ChildFirst classLoader = new ByteArrayClassLoader.ChildFirst(
                  parent,
                  Collections.<String, byte[]>emptyMap(),
                  ByteArrayClassLoader.PersistenceHandler.LATENT);
  
          assertThat(classLoader.getResource("byte-buddy-parent-only-resource.txt")).isEqualTo(parentOnlyResource);
          Enumeration<URL> resources = classLoader.getResources("byte-buddy-parent-only-resource.txt");
          assertThat(resources.hasMoreElements()).isTrue();
          assertThat(resources.nextElement()).isEqualTo(parentOnlyResource);
          assertThat(resources.hasMoreElements()).isFalse();
      }
  
      @Test
      void shadowsLatentClassResourceAfterLoading() throws Exception {
          try {
              String latentTypeName = "net_bytebuddy.byte_buddy.generated.ChildFirstLatentLoadedType";
              DynamicType.Unloaded<?> latentType = makeType(latentTypeName);
              Map<String, byte[]> latentTypes = new HashMap<String, byte[]>();
              latentTypes.put(latentTypeName, latentType.getBytes());
              ByteArrayClassLoader.ChildFirst latentClassLoader = new ByteArrayClassLoader.ChildFirst(
                      ClassLoader.getSystemClassLoader(),
                      latentTypes,
                      ByteArrayClassLoader.PersistenceHandler.LATENT);
  
              Class<?> loadedLatentType = latentClassLoader.loadClass(latentTypeName);
  
              assertThat(loadedLatentType.getClassLoader()).isSameAs(latentClassLoader);
              assertThat(latentClassLoader.getResource(resourceName(latentTypeName))).isNull();
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
      }
  
      @Test
      void prependsManifestClassResourceToParentResources() throws IOException {
          String manifestTypeName = "net_bytebuddy.byte_buddy.generated.ChildFirstManifestResourceType";
          DynamicType.Unloaded<?> manifestType = makeType(manifestTypeName);
          Map<String, byte[]> manifestTypes = new HashMap<String, byte[]>();
          manifestTypes.put(manifestTypeName, manifestType.getBytes());
          String manifestResourceName = resourceName(manifestTypeName);
          URL parentResource = url("file:/byte-buddy-parent-class-resource.class");
          ByteArrayClassLoader.ChildFirst manifestClassLoader = new ByteArrayClassLoader.ChildFirst(
                  new ParentResourceClassLoader(manifestResourceName, parentResource),
                  manifestTypes,
                  ByteArrayClassLoader.PersistenceHandler.MANIFEST);
  
          Enumeration<URL> resources = manifestClassLoader.getResources(manifestResourceName);
  
          assertThat(resources.hasMoreElements()).isTrue();
          assertThat(resources.nextElement().getProtocol()).isEqualTo(ByteArrayClassLoader.URL_SCHEMA);
          assertThat(resources.hasMoreElements()).isTrue();
          assertThat(resources.nextElement()).isEqualTo(parentResource);
          assertThat(resources.hasMoreElements()).isFalse();
      }
  
      private static DynamicType.Unloaded<?> makeType(String typeName) {
          return new ByteBuddy(ClassFileVersion.JAVA_V8)
                  .subclass(Object.class)
                  .name(typeName)
                  .make();
      }
  
      private static String resourceName(String typeName) {
          return typeName.replace('.', '/') + ".class";
      }
  
      private static URL url(String value) throws MalformedURLException {
          return new URL(value);
      }
  
      private static class ParentResourceClassLoader extends ClassLoader {
          private final String resourceName;
          private final URL resource;
  
          ParentResourceClassLoader(String resourceName, URL resource) {
              super(null);
              this.resourceName = resourceName;
              this.resource = resource;
          }
  
          @Override
          protected URL findResource(String name) {
              return resourceName.equals(name)
                      ? resource
                      : null;
          }
  
          @Override
          protected Enumeration<URL> findResources(String name) {
              Vector<URL> resources = new Vector<URL>();
              if (resourceName.equals(name)) {
                  resources.add(resource);
              }
              return resources.elements();
          }
      }
  }
