                      name,
                      specificationTitle,
                      specificationVersion,
                      specificationVendor,
                      implementationTitle,
                      implementationVersion,
                      implementationVendor,
                      sealBase);
          }
  
          private static TestClassLoader asTestClassLoader(ClassLoader classLoader) {
              assertThat(classLoader).isInstanceOf(TestClassLoader.class);
              return (TestClassLoader) classLoader;
          }
      }
  
