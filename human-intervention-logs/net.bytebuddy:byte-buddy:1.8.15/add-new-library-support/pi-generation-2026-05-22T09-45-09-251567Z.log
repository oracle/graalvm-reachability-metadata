thly.\"}]}"}, {"type": "toolCall", "id": "call_75DY9w285TIdmX4Lsxq2NxcK|fc_0ef5232842737908016a10256425ec81a2909234191d6a00bc", "name": "write", "arguments": {"path": "tests/src/net.bytebuddy/byte-buddy/1.8.15/src/test/java/net_bytebuddy/byte_buddy/ClassReloadingStrategyTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage net_bytebuddy.byte_buddy;\n\nimport java.lang.reflect.InvocationTargetException;\n\nimport net.bytebuddy.dynamic.loading.ClassReloadingStrategy;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ClassReloadingStrategyTest {\n    private static final String AGENT_NOT_ACCESSIBLE = \"The Byte Buddy agent is not installed or not accessible\";\n\n    @Test\n    void fromInstalledAgentLooksUpInstrumentationGetter() {\n        assertInstalledAgentLookup(ClassReloadingStrategy.fromInstalledAgent());\n    }\n\n    @Test\n    void fromInstalledAgentWithStrategyLooksUpInstrumentationGetter() {\n        assertInstalledAgentLookup(ClassReloadingStrategy.fromInstalledAgent(ClassReloadingStrategy.Strategy.REDEFINITION));\n    }\n\n    private static void assertInstalledAgentLookup(ClassReloadingStrategy reloadingStrategy) {\n        assertThat(reloadingStrategy).isNotNull();\n    }\n\n    private static void assertInstalledAgentLookup(InstalledAgentLookup installedAgentLookup) {\n        try {\n            assertInstalledAgentLookup(installedAgentLookup.lookup());\n        } catch (IllegalStateException exception) {\n            assertThat(exception).hasMessage(AGENT_NOT_ACCESSIBLE);\n            assertThat(exception).hasCauseInstanceOf(InvocationTargetException.class);\n        }\n    }\n\n    private interface InstalledAgentLookup {\n        ClassReloadingStrategy lookup();\n    }\n}\n"}}], "api": "openai-responses