                      }
                      if (classes.size() != 1) {
                          return super.locate(name);
                      }
                      Class<?> type = classes.get(ONLY);
                      return TypeDescription.ForLoadedType.getName(type).equals(name)
                              ? type
                              : super.locate(name);
                  }
  
