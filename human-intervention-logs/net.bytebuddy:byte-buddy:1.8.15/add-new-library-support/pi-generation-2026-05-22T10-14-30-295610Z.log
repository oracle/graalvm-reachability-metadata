  package net_bytebuddy.byte_buddy;
  
  import java.io.IOException;
  import java.net.MalformedURLException;
  import java.net.URL;
  import java.util.ArrayList;
  import java.util.Arrays;
  import java.util.Collections;
  import java.util.Enumeration;
  import java.util.List;
  import java.util.Vector;
  
  import net.bytebuddy.dynamic.loading.MultipleParentClassLoader;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class MultipleParentClassLoaderTest {
      @Test
      void loadsClassFromFirstParentThatCanResolveIt() throws ClassNotFoundException {
          ParentClassLoader missingParent = new ParentClassLoader("missing.Type", Object.class);
          ParentClassLoader matchingParent = new ParentClassLoader(ExampleLoadedType.class.getName(), ExampleLoadedType.class);
          MultipleParentClassLoader classLoader = new MultipleParentClassLoader(
                  Arrays.asList(missingParent, matchingParent));
  
          Class<?> loadedType = classLoader.loadClass(ExampleLoadedType.class.getName());
  
          assertThat(loadedType).isSameAs(ExampleLoadedType.class);
          assertThat(missingParent.getLoadClassCalls()).isEqualTo(1);
          assertThat(matchingParent.getLoadClassCalls()).isEqualTo(1);
      }
  
      @Test
      void returnsFirstResourceFromParentsBeforeExplicitParent() throws MalformedURLException {
          URL parentResource = url("file:/byte-buddy-multiple-parent-resource.txt");
          URL fallbackResource = url("file:/byte-buddy-explicit-parent-resource.txt");
          ResourceClassLoader resourceParent = new ResourceClassLoader(
                  "byte-buddy-resource.txt",
                  parentResource);
          ResourceClassLoader explicitParent = new ResourceClassLoader(
                  "byte-buddy-resource.txt",
                  fallbackResource);
          MultipleParentClassLoader classLoader = new MultipleParentClassLoader(
                  explicitParent,
                  Collections.singletonList(resourceParent));
  
          URL resource = classLoader.getResource("byte-buddy-resource.txt");
  
          assertThat(resource).isEqualTo(parentResource);
          assertThat(resourceParent.getResourceCalls()).isEqualTo(1);
      }
  
      @Test
      void fallsBackToExplicitParentResourceWhenParentsMiss() throws MalformedURLException {
          URL fallbackResource = url("file:/byte-buddy-explicit-parent-only-resource.txt");
          ResourceClassLoader missingParent = new ResourceClassLoader(
                  "different-resource.txt",
                  url("file:/byte-buddy-different-resource.txt"));
          ResourceClassLoader explicitParent = new ResourceClassLoader(
                  "byte-buddy-explicit-parent-only-resource.txt",
                  fallbackResource);
          MultipleParentClassLoader classLoader = new MultipleParentClassLoader(
                  explicitParent,
                  Collections.singletonList(missingParent));
  
          URL resource = classLoader.getResource("byte-buddy-explicit-parent-only-resource.txt");
  
          assertThat(resource).isEqualTo(fallbackResource);
          assertThat(missingParent.getResourceCalls()).isEqualTo(1);
      }
  
      @Test
      void combinesResourcesFromParentsAndExplicitParent() throws IOException {
          URL firstParentResource = url("file:/byte-buddy-first-parent-resource.txt");
          URL secondParentResource = url("file:/byte-buddy-second-parent-resource.txt");
          URL fallbackResource = url("file:/byte-buddy-fallback-resource.txt");
          ResourceClassLoader firstParent = new ResourceClassLoader(
                  "byte-buddy-combined-resource.txt",
                  firstParentResource);
          ResourceClassLoader secondParent = new ResourceClassLoader(
                  "byte-buddy-combined-resource.txt",
                  secondParentResource);
          ResourceClassLoader explicitParent = new ResourceClassLoader(
                  "byte-buddy-combined-resource.txt",
                  fallbackResource);
          MultipleParentClassLoader classLoader = new MultipleParentClassLoader(
                  explicitParent,
                  Arrays.asList(firstParent, secondParent));
  
          List<URL> resources = list(classLoader.getResources("byte-buddy-combined-resource.txt"));
  
          assertThat(resources).containsExactly(firstParentResource, secondParentResource, fallbackResource);
          assertThat(firstParent.getResourcesCalls()).isEqualTo(1);
          assertThat(secondParent.getResourcesCalls()).isEqualTo(1);
      }
  
      private static List<URL> list(Enumeration<URL> enumeration) {
          List<URL> resources = new ArrayList<URL>();
          while (enumeration.hasMoreElements()) {
              resources.add(enumeration.nextElement());
          }
          return resources;
      }
  
      private static URL url(String value) throws MalformedURLException {
          return new URL(value);
      }
  
      private static class ExampleLoadedType {
      }
  
      private static class ParentClassLoader extends ClassLoader {
          private final String typeName;
          private final Class<?> loadedType;
          private int loadClassCalls;
  
          ParentClassLoader(String typeName, Class<?> loadedType) {
              super(null);
              this.typeName = typeName;
              this.loadedType = loadedType;
          }
  
          @Override
          public Class<?> loadClass(String name) throws ClassNotFoundException {
              loadClassCalls++;
              if (typeName.equals(name)) {
                  return loadedType;
              }
              throw new ClassNotFoundException(name);
          }
  
          int getLoadClassCalls() {
              return loadClassCalls;
          }
      }
  
      private static class ResourceClassLoader extends ClassLoader {
          private final String resourceName;
          private final URL resource;
          private int resourceCalls;
          private int resourcesCalls;
  
          ResourceClassLoader(String resourceName, URL resource) {
              super(null);
              this.resourceName = resourceName;
              this.resource = resource;
          }
  
          @Override
          public URL getResource(String name) {
              resourceCalls++;
              return resourceName.equals(name)
                      ? resource
                      : null;
          }
  
          @Override
          public Enumeration<URL> getResources(String name) {
              resourcesCalls++;
              Vector<URL> resources = new Vector<URL>();
              if (resourceName.equals(name)) {
                  resources.add(resource);
              }
              return resources.elements();
          }
  
          int getResourceCalls() {
              return resourceCalls;
          }
  
          int getResourcesCalls() {
              return resourcesCalls;
          }
      }
  }
