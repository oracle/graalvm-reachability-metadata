"write", "arguments": {"path": "tests/src/net.bytebuddy/byte-buddy/1.8.15/src/test/java/net_bytebuddy/byte_buddy/TypeDescriptionInnerGenericInnerAnnotationReaderInnerForWildcardLowerBoundTypeTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage net_bytebuddy.byte_buddy;\n\nimport net.bytebuddy.description.field.FieldDescription;\nimport net.bytebuddy.description.type.TypeDescription;\nimport org.junit.jupiter.api.Test;\n\nimport java.lang.annotation.ElementType;\nimport java.lang.annotation.Retention;\nimport java.lang.annotation.RetentionPolicy;\nimport java.lang.annotation.Target;\nimport java.util.List;\n\nimport static net.bytebuddy.matcher.ElementMatchers.named;\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class TypeDescriptionInnerGenericInnerAnnotationReaderInnerForWildcardLowerBoundTypeTest {\n    @Test\n    void resolvesLowerBoundAnnotationsForLoadedWildcardField() {\n        TypeDescription typeDescription = TypeDescription.ForLoadedType.of(WildcardLowerBoundCarrier.class);\n\n        FieldDescription fieldDescription = typeDescription.getDeclaredFields()\n                .filter(named(\"values\"))\n                .getOnly();\n        TypeDescription.Generic parameterizedType = fieldDescription.getType();\n        TypeDescription.Generic wildcardType = parameterizedType.getTypeArguments().get(0);\n        TypeDescription.Generic lowerBound = wildcardType.getLowerBounds().get(0);\n\n        assertThat(parameterizedType.asErasure().represents(List.class)).isTrue();\n        assertThat(wildcardType.getSort().isWildcard()).isTrue();\n        assertThat(lowerBound.asErasure().represents(String.class)).isTrue();\n        assertThat(lowerBound.getDeclaredAnnotations().isAnnotationPresent(WildcardLowerBoundMarker.class)).isTrue();\n    }\n\n    @Target(ElementType.TYPE_USE)\n    @Retention(RetentionPolicy.RUNTIME)\n    private @interface WildcardLowerBoundMarker {\n    }\n\n    private static class WildcardLowerBoundCarrier {\n        private List<? super @WildcardLowerBoundMarker String> values;\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 1108, "output": 889, "cacheRead": 27136, "cacheWrite": 0, "totalTokens": 29133, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780834366955, "responseId": "resp_0eda8cb3325e97eb016a25603f6b88819587f543cdf2abdf33"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_d2a7LCFrUcfB4lEiaZFuwMlD|fc_0eda8cb3325e97eb016a25604996a88195b142ae6af241f7b7", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1992 bytes to tests/src/net.bytebuddy/byte-buddy/1.8.15/src/test/java/net_bytebuddy/byte_buddy/TypeDescriptionInnerGenericInnerAnnotationReaderInnerForWildcardLowerBoundTypeTest.java"}], "isError": false, "timestamp": 1780834382348}]}
