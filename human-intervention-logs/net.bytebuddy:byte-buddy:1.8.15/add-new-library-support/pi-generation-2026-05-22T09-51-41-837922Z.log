sLoadingLock(name)) {\n+                Class<?> type = findLoadedClass(name);\n+                if (type == null) {\n+                    if (ISOLATED_ACTION_NAME.equals(name)) {\n+                        type = defineIsolatedAction(name);\n+                    } else if (name.startsWith(\"net.bytebuddy.\")) {\n+                        try {\n+                            type = findClass(name);\n+                        } catch (ClassNotFoundException ignored) {\n+                            type = super.loadClass(name, false);\n+                        }\n+                    } else {\n+                        type = super.loadClass(name, false);\n+                    }\n+                }\n+                if (resolve) {\n+                    resolveClass(type);\n+                }\n+                return type;\n+            }\n+        }\n+\n+        private static URL byteBuddyLocation() {\n+            CodeSource codeSource = NexusAccessor.class.getProtectionDomain().getCodeSource();\n+            if (codeSource == null) {\n+                throw new IllegalStateException(\"Cannot locate Byte Buddy classes\");\n+            }\n+            return codeSource.getLocation();\n+        }\n+\n+        private Class<?> defineIsolatedAction(String name) throws ClassNotFoundException {\n+            String resourceName = name.replace('.', '/') + \".class\";\n+            try (InputStream inputStream = NexusAccessorInnerDispatcherInnerCreationActionTest.class\n+                    .getClassLoader()\n+                    .getResourceAsStream(resourceName)) {\n+                if (inputStream == null) {\n+                    throw new ClassNotFoundException(name);\n+                }\n+                byte[] binaryRepresentation = inputStream.readAllBytes();\n+                return defineClass(name, binaryRepresentation, 0, binaryRepresentation.length);\n+            } catch (IOException exception) {\n+                throw new ClassNotFoundException(name, exception);\