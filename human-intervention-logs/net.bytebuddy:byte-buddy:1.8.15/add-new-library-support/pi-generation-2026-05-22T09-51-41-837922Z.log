[tool-call] delta {"path":"tests/src/net.bytebuddy/byte-buddy/1.8.15/src/test/java/net_bytebuddy/byte_buddy/NexusAccessorInnerDispatcherInnerCreationActionTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage net_bytebuddy.byte_buddy;\n\nimport java.io.IOException;\nimport java.io.InputStream;\nimport java.net.URL;\nimport java.net.URLClassLoader;\nimport java.security.CodeSource;\n\nimport net.bytebuddy.ByteBuddy;\nimport net.bytebuddy.ClassFileVersion;\nimport net.bytebuddy.dynamic.DynamicType;\nimport net.bytebuddy.dynamic.NexusAccessor;\nimport net.bytebuddy.dynamic.TypeResolutionStrategy;\nimport net.bytebuddy.dynamic.loading.ClassLoadingStrategy;\nimport net.bytebuddy.implementation.LoadedTypeInitializer;\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class NexusAccessorInnerDispatcherInnerCreationActionTest {\n    private static final String NEXUS_DISABLED_PROPERTY = \"net.bytebuddy.nexus.disabled\";\n\n    @Test\n    void activeTypeResolutionCreatesNexusDispatcherAndRunsRegisteredInitializer() throws Exception {\n        String previousNexusDisabledValue = System.getProperty(NEXUS_DISABLED_PROPERTY);\n        System.setProperty(NEXUS_DISABLED_PROPERTY, Boolean.FALSE.toString());\n        try {\n            assertThat(NexusAccessor.isAlive()).isTrue();\n\n            RecordingLoadedTypeInitializer initializer = new RecordingLoadedTypeInitializer();\n            DynamicType.Loaded<?> loadedType = new ByteBuddy(ClassFileVersion.JAVA_V8)\n                    .subclass(Object.class)\n                    .name(\"net_bytebuddy.byte_buddy.generated.NexusAccessorCreationActionInitializedType\")\n                    .initializer(initializer)\n                    .make(new TypeResolutionStrategy.Active())\n                    .load(getClass().getClassLoader(), ClassLoadingStrategy.Default.WRAPPER);\n\n            loadedType.getLoaded().getDeclaredConstructor().newInstance();\n\n            assertThat(initializer.loadedType).isSameAs(loadedType.getLoaded());\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        } finally {\n            restoreNexusDisabledProperty(previousNexusDisabledValue);\n        }\n    }\n\n    @Test\n    void fallsBackToSystemLoadedNexusWhenClassFileForInjectionCannotBeRead() throws Exception {\n        String previousNexusDisabledValue = System.getProperty(NEXUS_DISABLED_PROPERTY);\n        System.setProperty(NEXUS_DISABLED_PROPERTY, Boolean.FALSE.toString());\n        try {\n            assertThat(NexusAccessor.isAlive()).isTrue();\n            try (IsolatedByteBuddyClassLoader classLoader = new IsolatedByteBuddyClassLoader()) {\n                IsolatedAction action = classLoader\n                        .loadClass(IsolatedNexusAccessorFallbackAction.class.getName())\n                        .asSubclass(IsolatedAction.class)\n                        .getConstructor()\n                        .newInstance();\n\n                action.run();\n            }\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        } finally {\n            restoreNexusDisabledProperty(previousNexusDisabledValue);\n        }\n    }\n\n    private static void restoreNexusDisabledProperty(String previousValue) {\n        if (previousValue == null) {\n            System.clearProperty(NEXUS_DISABLED_PROPERTY);\n        } else {\n            System.setProperty(NEXUS_DISABLED_PROPERTY, previousValue);\n        }\n    }\n\n    public interface IsolatedAction {\n        void run();\n    }\n\n    public static class IsolatedNexusAccessorFallbackAction implements IsolatedAction {\n        @Override\n        public void run() {\n            if (!NexusAccessor.isAlive()) {\n                throw new AssertionError(\"Nexus accessor should be alive\");\n            }\n        }\n    }\n\n    public static class RecordingLoadedTypeInitializer implements LoadedTypeInitializer {\n        private Class<?> loadedType;\n\n        @Override\n        public void onLoad(Class<?> type) {\n            loadedType = type;\n        }\n\n        @Override\n        public boolean isAlive() {\n            return true;\n        }\n    }\n\n    private static class IsolatedByteBuddyClassLoader extends URLClassLoader {\n        private static final String ISOLATED_ACTION_NAME = IsolatedNexusAccessorFallbackAction.class.getName();\n        private static final String NEXUS_CLASS_RESOURCE = \"net/bytebuddy/dynamic/Nexus.class\";\n\n        IsolatedByteBuddyClassLoader() {\n            super(new URL[]{byteBuddyLocation()},\n                    NexusAccessorInnerDispatcherInnerCreationActionTest.class.getClassLoader());\n        }\n\n        @Override\n        public InputStream getResourceAsStream(String name) {\n            return NEXUS_CLASS_RESOURCE.equals(name)\n                    ? null\n                    : super.getResourceAsStream(name);\n        }\n\n        @Override\n        protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {\n            synchronized (getClassLoadingLock(name)) {\n                Class<?> type = findLoadedClass(name);\n                if (type == null) {\n                    if (ISOLATED_ACTION_NAME.equals(name)) {\n                        type = defineIsolatedAction(name);\n                    } else if (name.startsWith(\"net.bytebuddy.\")) {\n                        try {\n                            type = findClass(name);\n                        } catch (ClassNotFoundException ignored) {\n                            type = super.loadClass(name, false);\n                        }\n                    } else {\n                        type = super.loadClass(name, false);\n                    }\n                }\n                if (resolve) {\n                    resolveClass(type);\n                }\n                return type;\n            }\n        }\n\n        private static URL byteBuddyLocation() {\n            CodeSource codeSource = NexusAccessor.class.getProtectionDomain().getCodeSource();\n            if (codeSource == null) {\n                throw new IllegalStateException(\"Cannot locate Byte Buddy classes\");\n            }\n            return codeSource.getLocation();\n        }\n\n        private Class<?> defineIsolatedAction(String name) throws ClassNotFoundException {\n            String resourceName = name.replace('.', '/') + \".class\";\n            try (InputStream inputStream = NexusAccessorInnerDispatcherInnerCreationActionTest.class\n                    .getClassLoader()\n                    .getResourceAsStream(resourceName)) {\n                if (inputStream == null) {\n                    throw new ClassNotFoundException(name);\n                }\n                byte[] binaryRepresentation = inputStream.readAllBytes();\n                return defineClass(name, binaryRepresentation, 0, binaryRepresentation.length);\n            } catch (IOException exception) {\n                throw new ClassNotFoundException(name, exception);\n            }\n        }\n    }\n}\n"}
