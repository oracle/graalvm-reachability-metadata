ypeDefinitions = new HashMap<String, byte[]>();\n            for (String typeName : ISOLATED_TYPES) {\n                typeDefinitions.put(typeName, readClassBytes(typeName));\n            }\n\n            ResourceHidingClassLoader classLoader = new ResourceHidingClassLoader(typeDefinitions);\n            Class<?> nexusAccessorType = Class.forName(NexusAccessor.class.getName(), true, classLoader);\n\n            assertThat(nexusAccessorType.getClassLoader()).isSameAs(classLoader);\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    private static byte[] readClassBytes(String typeName) throws IOException {\n        String resourceName = typeName.replace('.', '/') + \".class\";\n        InputStream inputStream = NexusAccessorInnerDispatcherInnerCreationActionTest.class\n                .getClassLoader()\n                .getResourceAsStream(resourceName);\n        if (inputStream == null) {\n            throw new IOException(\"Cannot locate class resource: \" + resourceName);\n        }\n        try {\n            ByteArrayOutputStream outputStream = new ByteArrayOutputStream();\n            byte[] buffer = new byte[1024];\n            int length;\n            while ((length = inputStream.read(buffer)) != -1) {\n                outputStream.write(buffer, 0, length);\n            }\n            return outputStream.toByteArray();\n        } finally {\n            inputStream.close();\n        }\n    }\n\n    public static class AliveLoadedTypeInitializer implements LoadedTypeInitializer {\n"}]}
