  package net_bytebuddy.byte_buddy;
  
  import net.bytebuddy.utility.JavaConstant;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  
  import java.lang.invoke.MethodHandles;
  import java.lang.invoke.MethodType;
  import java.io.ByteArrayOutputStream;
  import java.io.IOException;
  import java.io.InputStream;
  import java.lang.reflect.InvocationTargetException;
  import java.lang.reflect.Method;
  import java.net.URL;
  import java.net.URLClassLoader;
  import java.nio.charset.StandardCharsets;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class JavaConstantInnerMethodHandleInnerDispatcherInnerCreationActionTest {
      @Test
      void fallsBackWhenJava8LookupDispatcherCannotBeCreated() throws Exception {
          java.lang.invoke.MethodHandle loadedHandle = MethodHandles.publicLookup().findVirtual(
                  String.class,
                  "substring",
                  MethodType.methodType(String.class, int.class));
          URL byteBuddyLocation = JavaConstant.class.getProtectionDomain().getCodeSource().getLocation();
  
          try (FallbackDispatchingClassLoader classLoader = new FallbackDispatchingClassLoader(byteBuddyLocation)) {
              Class<?> methodHandleType = Class.forName(
                      "net.bytebuddy.utility.JavaConstant$MethodHandle",
                      false,
                      classLoader);
              Method ofLoaded = methodHandleType.getMethod("ofLoaded", Object.class);
  
              try {
                  Object methodHandle = ofLoaded.invoke(null, loadedHandle);
  
                  assertThat(methodHandle).isInstanceOf(methodHandleType);
              } catch (InvocationTargetException exception) {
                  assertThat(exception.getCause())
                          .isInstanceOf(IllegalStateException.class)
                          .hasMessageContaining("Unsupported type on current JVM: java.lang.invoke.MethodHandle");
              }
              assertThat(classLoader.hasPatchedCreationAction()).isTrue();
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
      }
  
      private static class FallbackDispatchingClassLoader extends URLClassLoader {
          private static final String CREATION_ACTION =
                  "net.bytebuddy.utility.JavaConstant$MethodHandle$Dispatcher$CreationAction";
          private static final byte[] JAVA_8_LOOKUP_METHOD = "revealDirect".getBytes(StandardCharsets.UTF_8);
          private static final byte[] MISSING_JAVA_8_LOOKUP_METHOD = "revealDirecx".getBytes(StandardCharsets.UTF_8);
  
          private final ClassLoader sourceClassLoader = JavaConstant.class.getClassLoader();
          private boolean patchedCreationAction;
  
          FallbackDispatchingClassLoader(URL byteBuddyLocation) {
              super(new URL[] {byteBuddyLocation}, null);
          }
  
          @Override
          protected Class<?> findClass(String name) throws ClassNotFoundException {
              if (!CREATION_ACTION.equals(name)) {
                  return super.findClass(name);
              }
              byte[] classFile = readClassFile(name);
              patchedCreationAction = replace(classFile, JAVA_8_LOOKUP_METHOD, MISSING_JAVA_8_LOOKUP_METHOD);
              return defineClass(name, classFile, 0, classFile.length);
          }
  
          private byte[] readClassFile(String className) throws ClassNotFoundException {
              String resourceName = className.replace('.', '/') + ".class";
              try (InputStream inputStream = sourceClassLoader.getResourceAsStream(resourceName)) {
                  if (inputStream == null) {
                      throw new ClassNotFoundException(className);
                  }
                  ByteArrayOutputStream outputStream = new ByteArrayOutputStream();
                  byte[] buffer = new byte[1024];
                  int length;
                  while ((length = inputStream.read(buffer)) != -1) {
                      outputStream.write(buffer, 0, length);
                  }
                  return outputStream.toByteArray();
              } catch (IOException exception) {
                  throw new ClassNotFoundException(className, exception);
              }
          }
  
          private static boolean replace(byte[] bytes, byte[] source, byte[] target) {
              for (int index = 0; index <= bytes.length - source.length; index++) {
                  if (matches(bytes, source, index)) {
                      System.arraycopy(target, 0, bytes, index, target.length);
                      return true;
                  }
              }
              return false;
          }
  
          private static boolean matches(byte[] bytes, byte[] source, int index) {
              for (int offset = 0; offset < source.length; offset++) {
                  if (bytes[index + offset] != source[offset]) {
                      return false;
                  }
              }
              return true;
          }
  
          boolean hasPatchedCreationAction() {
              return patchedCreationAction;
          }
      }
  }
