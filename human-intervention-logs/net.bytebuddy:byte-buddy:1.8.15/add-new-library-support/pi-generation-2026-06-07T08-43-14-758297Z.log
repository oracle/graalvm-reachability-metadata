anceOf(methodHandleType);\n            } catch (InvocationTargetException exception) {\n                assertThat(exception.getCause())\n                        .isInstanceOf(IllegalStateException.class)\n                        .hasMessageContaining(\"Unsupported type on current JVM: java.lang.invoke.MethodHandle\");\n            }\n            assertThat(classLoader.hasBlockedLookupLoad()).isTrue();\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    private static class LookupBlockingClassLoader extends URLClassLoader {\n        private static final String LOOKUP_TYPE = \"java.lang.invoke.MethodHandles$Lookup\";\n\n        private int lookupLoadCount;\n        private boolean blockedLookupLoad;\n\n        LookupBlockingClassLoader(URL byteBuddyLocation) {\n            super(new URL[] {byteBuddyLocation}, null);\n        }\n\n        @Override\n        protected synchronized Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {\n            if (LOOKUP_TYPE.equals(name) && ++lookupLoadCount == 2) {\n                blockedLookupLoad = true;\n                throw new ClassNotFoundException(name);\n            }\n            return super.loadClass(name, resolve);\n        }\n\n        boolean hasBlockedLookupLoad() {\n            return blockedLookupLoad;\n        }\n    }\n}\n"}
