g.reflect.Method;\nimport java.net.URL;\nimport java.net.URLClassLoader;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class JavaConstantInnerMethodHandleInnerDispatcherInnerCreationActionTest {\n    @Test\n    void fallsBackWhenJava8LookupDispatcherCannotBeCreated() throws Exception {\n        java.lang.invoke.MethodHandle loadedHandle = MethodHandles.publicLookup().findVirtual(\n                String.class,\n                \"substring\",\n                MethodType.methodType(String.class, int.class));\n        URL byteBuddyLocation = JavaConstant.class.getProtectionDomain().getCodeSource().getLocation();\n\n        try (LookupBlockingClassLoader classLoader = new LookupBlockingClassLoader(byteBuddyLocation)) {\n            Class<?> methodHandleType = Class.forName(\n                    \"net.bytebuddy.utility.JavaConstant$MethodHandle\",\n                    false,\n                    classLoader);\n            Method ofLoaded = methodHandleType.getMethod(\"ofLoaded\", Object.class);\n\n            try {\n                Object methodHandle = ofLoaded.invoke(null, loadedHandle);\n\n                assertThat(methodHandle).isInstanceOf(methodHandleType);\n            } catch (InvocationTargetException exception) {\n                assertThat(exception.getCause())\n                        .isInstanceOf(IllegalStateException.class)\n                        .hasMessageContaining(\"Unsupported type on current JVM: java.lang.invoke.MethodHandle\");\n            }\n            assertThat(classLoader.hasBlockedLookupLoad()).isTrue();\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    private static class LookupBlockingClassLoader extends URLClassLoader {\n        private static final String LOOKUP_TYPE = \"java.lang.invoke.MethodHandles$Lookup\";\n\n        private int lookupLoadCount;\n        private boolean blockedLookupLoad;\n\n        LookupBlockingClassLoader(URL byteBuddyLocation) {\n            super(new URL[] {byteBuddyLocation}, null);\n        }\n\n        @Override\n        protected synchronized Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {\n            if (LOOKUP_TYPE.equals(name) && ++lookupLoadCount == 2) {\n                blockedLookupLoad = true;\n                throw new ClassNotFoundException(name);\n            }\n            return super.loadClass(name, resolve);\n        }\n\n        boolean hasBlockedLookupLoad() {\n            return blockedLookupLoad;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 3484, "output": 2548, "cacheRead": 31744, "cacheWrite": 0, "totalTokens": 37776, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780821681807, "responseId": "resp_0d72e8b3a904c681016a252eb24ef081978dcbbe57a4938820"}}
