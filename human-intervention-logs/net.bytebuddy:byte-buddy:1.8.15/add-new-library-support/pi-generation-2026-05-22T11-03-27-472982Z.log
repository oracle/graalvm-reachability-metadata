e.api.Assertions.assertThat;\n\npublic class ClassInjectorInnerUsingLookupInnerDispatcherInnerForJava9CapableVmTest {\n    @Test\n    void resolvesLookupAndDefinesGeneratedType() {\n        try {\n            ClassInjector.UsingLookup injector = ClassInjector.UsingLookup.of(MethodHandles.lookup())\n                    .in(LookupScope.class);\n            String typeName = \"net_bytebuddy.byte_buddy.LookupDispatcherDefinedType\";\n            DynamicType.Unloaded<?> dynamicType = makeType(typeName);\n            TypeDescription typeDescription = dynamicType.getTypeDescription();\n            Map<TypeDescription, byte[]> types = new HashMap<TypeDescription, byte[]>();\n            types.put(typeDescription, dynamicType.getBytes());\n\n            Map<TypeDescription, Class<?>> loadedTypes = injector.inject(types);\n\n            Class<?> loadedType = loadedTypes.get(typeDescription);\n            assertThat(injector.lookupType()).isSameAs(LookupScope.class);\n            assertThat(loadedType).isNotNull();\n            assertThat(loadedType.getName()).isEqualTo(typeName);\n            assertThat(loadedType.getClassLoader()).isSameAs(LookupScope.class.getClassLoader());\n            assertThat(LookupScope.class.getClassLoader().loadClass(typeName)).isSameAs(loadedType);\n        } catch (IllegalStateException exception) {\n            if (!hasUnsupportedFeatureErrorCause(exception)) {\n                throw exception;\n            }\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        } catch (ClassNotFoundException exception) {\n            throw new AssertionError(exception);\n        }\n    }\n\n    private static DynamicType.Unloaded<?> makeType(String typeName) {\n        return new ByteBuddy(ClassFileVersion.JAVA_V8)\n                .subclass(Object.class)\n                .name(typeName)\n                .make();\n    }\n\n    private static boolean hasUnsupportedFeatureErrorCause(Throwable throwable) {\n        Throwable current = throwable;\n        while (current != null) {\n            if (current instanceof Error error && NativeImageSupport.isUnsupportedFeatureError(error)) {\n                return true;\n            }\n            current = current.getCause();\n        }\n        return false;\n    }\n\n    private static class LookupScope {\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1275, "output": 1189, "cacheRead": 27648, "cacheWrite": 0, "totalTokens": 30112, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1779447745491, "responseId": "resp_0ef4fa631fd63345016a1037c1f66081908d8c60ad20e27193"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_gWXBxr0b2L33sES5v6nRgo63|fc_0ef4fa631fd63345016a1037ce23a48190b238b563ea213a6e", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 3017 bytes to tests/src/net.bytebuddy/byte-buddy/1.8.15/src/test/java/net_bytebuddy/byte_buddy/ClassInjectorInnerUsingLookupInnerDispatcherInnerForJava9CapableVmTest.java"}], "isError": false, "timestamp": 1779447760449}]}
