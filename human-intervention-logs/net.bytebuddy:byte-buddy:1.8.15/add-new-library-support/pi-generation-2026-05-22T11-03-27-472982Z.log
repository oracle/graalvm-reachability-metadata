epresentation, protectionDomain);\n        assertThat(loadedType.getName()).isEqualTo(typeName);\n        assertThat(loadedType.getClassLoader()).isSameAs(classLoader);\n        assertThat(operations.findClass(classLoader, typeName)).isSameAs(loadedType);\n        assertThat(operations.getPackage(classLoader, packageName)).isSameAs(definedPackage);\n    }\n\n    private interface IndirectOperations {\n        Object getClassLoadingLock(ClassLoader classLoader, String name);\n\n        Class<?> findClass(ClassLoader classLoader, String name);\n\n        Class<?> defineClass(ClassLoader classLoader,\n                             String name,\n                             byte[] binaryRepresentation,\n                             ProtectionDomain protectionDomain);\n\n        Package getPackage(ClassLoader classLoader, String name);\n\n        Package definePackage(ClassLoader classLoader, String name);\n    }\n\n    private static class UsingReflectionAccess extends ClassInjector.UsingReflection {\n        private static final String BOOTSTRAP_ACCESSOR_NAME = \"java.lang.ClassLoader$ByteBuddyAccessor$Bootstrap\";\n\n        UsingReflectionAccess() {\n            super(ClassLoader.getSystemClassLoader());\n        }\n\n        static IndirectOperations makeBootstrapIndirectOperations() throws Exception {\n            Class<?> accessorType = makeBootstrapAccessorType();\n            Object accessor = UnsafeAccess.allocateInstance(accessorType);\n            return toIndirectOperations(new TestIndirect(accessor,\n                    accessorType.getMethod(\"findLoadedClass\", ClassLoader.class, String.class),\n                    accessorType.getMethod(\"defineClass\",\n                            ClassLoader.class,\n                            String.class,\n                            byte[].class,\n                            int.class,\n                            int.class,\n                            ProtectionDomain.class),\n                    accessorType.getMethod(\"getPackage\", ClassLoader.class, String.class),\n                    accessorType.getMethod(\"definePackage\",\n                            ClassLoader.class,\n                            String.class,\n                            String.class,\n                            String.class,\n                            String.class,\n                            String.class,\n                            String.class,\n                            String.class,\n                            URL.class),\n                    accessorType.getMethod(\"getClassLoadingLock\", ClassLoader.class, String.class)));\n        }\n\n        static IndirectOperations makeIndirectOperations() throws NoSuchMethodException {\n            return toIndirectOperations(new TestIndirect(new Accessor(),\n                    Accessor.class.getMethod(\"findLoadedClass\", ClassLoader.class, String.class),\n                    Accessor.class.getMethod(\"defineClass\",\n                            ClassLoader.class,\n                            String.class,\n                            byte[].class,\n                            int.class,\n                            int.class,\n                            ProtectionDomain.class),\n                    Accessor.class.getMethod(\"getPackage\", ClassLoader.class, String.class),\n                    Accessor.class.getMethod(\"definePackage\",\n                            ClassLoader.class,\n                            String.class,\n                            String.class,\n                            String.class,\n                            String.class,\n                            String.class,\n                            String.class,\n                            String.class,\n                            URL.class),\n                    Accessor.class.getMethod(\"getClassLoadingLock\", ClassLoader.class, String.class)));\n        }\n\n        private static IndirectOperations toIndirectOperations(final Dispatcher dispatcher) {\n          