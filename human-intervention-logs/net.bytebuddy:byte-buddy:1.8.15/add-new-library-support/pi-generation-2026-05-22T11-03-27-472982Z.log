class, String.class)\n                    .intercept(MethodCall.invoke(getPackageMethod)\n                            .onArgument(0)\n                            .withArgument(1))\n                    .defineMethod(\"definePackage\", Package.class, Visibility.PUBLIC)\n                    .withParameters(ClassLoader.class,\n                            String.class,\n                            String.class,\n                            String.class,\n                            String.class,\n                            String.class,\n                            String.class,\n                            String.class,\n                            URL.class)\n                    .intercept(MethodCall.invoke(\n                                    ClassLoader.class.getDeclaredMethod(\"definePackage\",\n                                            String.class,\n                                            String.class,\n                                            String.class,\n                                            String.class,\n                                            String.class,\n                                            String.class,\n                                            String.class,\n                                            URL.class))\n                            .onArgument(0)\n                            .withArgument(1, 2, 3, 4, 5, 6, 7, 8));\n\n            try {\n                builder = builder\n                        .defineMethod(\"getClassLoadingLock\", Object.class, Visibility.PUBLIC)\n                        .withParameters(ClassLoader.class, String.class)\n                        .intercept(MethodCall.invoke(\n                                        ClassLoader.class.getDeclaredMethod(\"getClassLoadingLock\", String.class))\n                                .onArgument(0)\n                                .withArgument(1));\n            } catch (NoSuchMethodException ignored) {\n                builder = builder\n                        .defineMethod(\"getClassLoadingLock\", Object.class, Visibility.PUBLIC)\n                        .withParameters(ClassLoader.class, String.class)\n                        .intercept(FixedValue.argument(0));\n            }\n\n            DynamicType.Unloaded<?> dynamicType = builder.make();\n            return UnsafeAccess.defineBootstrapClass(dynamicType.getTypeDescription().getName(), dynamicType.getBytes());\n        }\n    }\n\n    private static class UsingUnsafeAccess extends ClassInjector.UsingUnsafe {\n        UsingUnsafeAccess() {\n            super(ClassLoadingStrategy.BOOTSTRAP_LOADER);\n        }\n\n        static void installBootstrapDefiningDispatcher() throws Exception {\n            ClassInjector.UsingUnsafe.isAvailable();\n            Unsafe unsafe = UnsafeAccess.unsafe();\n            Field dispatcher = ClassInjector.UsingUnsafe.class.getDeclaredField(\"DISPATCHER\");\n            unsafe.putObjectVolatile(unsafe.staticFieldBase(dispatcher),\n                    unsafe.staticFieldOffset(dispatcher),\n                    new BootstrapDefiningDispatcher());\n        }\n\n        private static class BootstrapDefiningDispatcher implements Dispatcher, Dispatcher.Initializable {\n            private final MethodHandle defineClass;\n            private final Object unsafe;\n\n            BootstrapDefiningDispatcher() throws Exception {\n                Class<?> unsafeType = Class.forName(\"jdk.internal.misc.Unsafe\");\n                this.unsafe = UnsafeAccess.getStaticField(unsafeType, \"theUnsafe\");\n                this.defineClass = UnsafeAccess.trustedLookup().findVirtual(unsafeType,\n                        \"defineClass\",\n                        MethodType.methodType(Class.class,\n                                String.class,\n                                byte[].class,\n                                int.class,\n                                int.class,\n                                ClassLoader.class,\n                                ProtectionDomain.class));\n            }\n\n            @Override\n            public boolean isAvailable() {\n                return true;\n            }\n\n            @Override\n            public Dispatcher initialize() {\n                return this;\n            }\n\n            @Override\n            public Class<?> defineClass(ClassLoader classLoader,\n                                        String name,\n                                        byte[] binaryRepresentation,\n                                        ProtectionDomain protectionDomain) {\n                try {\n                    return (Class<?>) defineClass.invoke(unsafe,\n                            name,\n                            binaryRepresentation,\n                            0,\n                            binaryRepresentation.length,\n                            classLoader,\n                            protectionDomain);\n                } catch (RuntimeException exception) {\n                    throw exception;\n                } catch (Error error) {\n                    throw error;\n                } catch (Throwable throwable) {\n                    throw new IllegalStateException(\n                            \"Could not define class through jdk.internal.misc.Unsafe\",\n                            throwable);\n                }\n            }\n        }\n    }\n\n    private static class UnsafeAccess {\n        private static Unsafe unsafe() throws Exception {\n            Field theUnsafe = Unsafe.class.getDeclaredField(\"theUnsafe\");\n            theUnsafe.setAccessible(true);\n            return (Unsafe) theUnsafe.get(null);\n        }\n\n        private static Object allocateInstance(Class<?> type) throws Exception {\n            return unsafe().allocateInstance(type);\n        }\n\n        private static Class<?> defineBootstrapClass(String name, byte[] binaryRepresentation) throws Exception {\n            Class<?> unsafeType = Class.forName(\"jdk.internal.misc.Unsafe\");\n            Object unsafe = getStaticField(unsafeType, \"theUnsafe\");\n            MethodHandle defineClass = trustedLookup().findVirtual(unsafeType,\n                    \"defineClass\",\n                    MethodType.methodType(Class.class,\n                            String.class,\n                            byte[].class,\n                            int.class,\n                            int.class,\n                            ClassLoader.class,\n                            ProtectionDomain.class));\n            try {\n                return (Class<?>) defineClass.invoke(unsafe,\n                        name,\n                        binaryRepresentation,\n                        0,\n                        binaryRepresentation.length,\n                        ClassLoadingStrategy.BOOTSTRAP_LOADER,\n                        ClassInjector.UsingReflection.class.getProtectionDomain());\n            } catch (RuntimeException exception) {\n                throw exception;\n            } catch (Error error) {\n                throw error;\n            } catch (Throwable throwable) {\n                throw new IllegalStateException(\"Could not define bootstrap accessor\", throwable);\n            }\n        }\n\n        private static MethodHandles.Lookup trustedLookup() throws Exception {\n            return (MethodHandles.Lookup) getStaticField(MethodHandles.Lookup.class, \"IMPL_LOOKUP\");\n        }\n\n        private static Object getStaticField(Class<?> type, String name) throws Exception {\n            Unsafe unsafe = unsafe();\n            Field field = type.getDeclaredField(name);\n            return unsafe.getObject(unsafe.staticFieldBase(field), unsafe.staticFieldOffset(field));\n        }\n    }\n\n    public static class Accessor {\n        public Object getClassLoadingLock(ClassLoader classLoader, String name) {\n            return asTestClassLoader(classLoader).getClassLoadingLockPublic(name);\n        }\n\n        public Class<?> findLoadedClas