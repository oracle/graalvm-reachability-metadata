                              String.class,
                              String.class,
                              String.class,
                              String.class,
                              String.class,
                              String.class,
                              String.class,
                              URL.class),
                      accessorType.getMethod("getClassLoadingLock", ClassLoader.class, String.class)));
          }
  
          static IndirectOperations makeIndirectOperations() throws NoSuchMethodException {
              return toIndirectOperations(new TestIndirect(new Accessor(),
                      Accessor.class.getMethod("findLoadedClass", ClassLoader.class, String.class),
                      Accessor.class.getMethod("defineClass",
                              ClassLoader.class,
                              String.class,
                              byte[].class,
                              int.class,
                              int.class,
                              ProtectionDomain.class),
                      Accessor.class.getMethod("getPackage", ClassLoader.class, String.class),
                      Accessor.class.getMethod("definePackage",
                              ClassLoader.class,
                              String.class,
                              String.class,
                              String.class,
                              String.class,
                              String.class,
                              String.class,
                              String.class,
                              URL.class),
