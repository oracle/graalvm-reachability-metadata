  package net_bytebuddy.byte_buddy;
  
  import java.lang.invoke.MethodHandle;
  import java.lang.invoke.MethodHandles;
  import java.lang.invoke.MethodType;
  import java.lang.reflect.Field;
  import java.lang.reflect.Method;
  import java.net.URL;
  import java.net.URLClassLoader;
  import java.security.ProtectionDomain;
  import java.util.HashMap;
  import java.util.Map;
  
  import net.bytebuddy.ByteBuddy;
  import net.bytebuddy.description.modifier.Visibility;
  import net.bytebuddy.ClassFileVersion;
  import net.bytebuddy.description.type.TypeDescription;
  import net.bytebuddy.dynamic.DynamicType;
  import net.bytebuddy.dynamic.loading.ClassInjector;
  import net.bytebuddy.dynamic.loading.ClassLoadingStrategy;
  import net.bytebuddy.dynamic.scaffold.TypeValidation;
  import net.bytebuddy.dynamic.scaffold.subclass.ConstructorStrategy;
  import net.bytebuddy.dynamic.loading.PackageDefinitionStrategy;
  import net.bytebuddy.implementation.FixedValue;
  import net.bytebuddy.implementation.MethodCall;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  
  import sun.misc.Unsafe;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ClassInjectorInnerUsingReflectionInnerDispatcherInnerIndirectTest {
      @Test
      void invokesIndirectDispatcherAccessorMethods() throws Exception {
          try {
              invokeIndirectDispatcherAccessorMethods();
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
      }
  
      @Test
      void injectsGeneratedTypeThroughReflectionDispatcher() throws Exception {
          try {
              injectGeneratedTypeThroughReflectionDispatcher();
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
      }
  
      private static void invokeIndirectDispatcherAccessorMethods() throws Exception {
          String packageName = "net_bytebuddy.byte_buddy.manual";
          String typeName = packageName + ".ManuallyInjectedType";
          DynamicType.Unloaded<?> dynamicType = makeType(typeName);
          UsingUnsafeAccess.installBootstrapDefiningDispatcher();
  
          assertIndirectOperations(UsingReflectionAccess.makeBootstrapIndirectOperations(),
                  typeName,
                  packageName,
                  dynamicType.getBytes());
          assertIndirectOperations(UsingReflectionAccess.makeIndirectOperations(),
                  packageName + ".SecondManuallyInjectedType",
                  packageName,
                  makeType(packageName + ".SecondManuallyInjectedType").getBytes());
      }
  
      private static void injectGeneratedTypeThroughReflectionDispatcher() throws Exception {
          if (!ClassInjector.UsingReflection.isAvailable()) {
              return;
          }
  
          String typeName = "net_bytebuddy.byte_buddy.generated.ReflectionInjectedType";
          DynamicType.Unloaded<?> dynamicType = makeType(typeName);
          TypeDescription typeDescription = dynamicType.getTypeDescription();
          Map<TypeDescription, byte[]> types = new HashMap<TypeDescription, byte[]>();
          types.put(typeDescription, dynamicType.getBytes());
  
          try (URLClassLoader classLoader = new URLClassLoader(new URL[0], null)) {
              ClassInjector injector = new ClassInjector.UsingReflection(
                      classLoader,
                      ClassInjector.UsingReflection.class.getProtectionDomain(),
                      PackageDefinitionStrategy.Trivial.INSTANCE,
                      ClassInjector.ALLOW_EXISTING_TYPES);
  
              Map<TypeDescription, Class<?>> loadedTypes = injector.inject(types);
  
              Class<?> loadedType = loadedTypes.get(typeDescription);
              assertThat(loadedType).isNotNull();
              assertThat(loadedType.getName()).isEqualTo(typeName);
              assertThat(loadedType.getClassLoader()).isSameAs(classLoader);
              assertThat(loadedType.getPackage()).isNotNull();
              assertThat(loadedType.getPackage().getName()).isEqualTo("net_bytebuddy.byte_buddy.generated");
              assertThat(classLoader.loadClass(typeName)).isSameAs(loadedType);
          }
      }
  
      private static DynamicType.Unloaded<?> makeType(String typeName) {
          return new ByteBuddy(ClassFileVersion.JAVA_V8)
                  .subclass(Object.class)
                  .name(typeName)
                  .make();
      }
  
      private static void assertIndirectOperations(IndirectOperations operations,
                                                   String typeName,
                                                   String packageName,
                                                   byte[] binaryRepresentation) {
          TestClassLoader classLoader = new TestClassLoader();
          ProtectionDomain protectionDomain = ClassInjector.UsingReflection.class.getProtectionDomain();
  
          assertThat(operations.getClassLoadingLock(classLoader, typeName)).isSameAs(classLoader);
          assertThat(operations.findClass(classLoader, typeName)).isNull();
          assertThat(operations.getPackage(classLoader, packageName)).isNull();
  
          Package definedPackage = operations.definePackage(classLoader, packageName);
          assertThat(definedPackage).isNotNull();
          assertThat(definedPackage.getName()).isEqualTo(packageName);
  
          Class<?> loadedType = operations.defineClass(classLoader, typeName, binaryRepresentation, protectionDomain);
          assertThat(loadedType.getName()).isEqualTo(typeName);
          assertThat(loadedType.getClassLoader()).isSameAs(classLoader);
          assertThat(operations.findClass(classLoader, typeName)).isSameAs(loadedType);
          assertThat(operations.getPackage(classLoader, packageName)).isSameAs(definedPackage);
      }
  
      private interface IndirectOperations {
          Object getClassLoadingLock(ClassLoader classLoader, String name);
  
          Class<?> findClass(ClassLoader classLoader, String name);
  
          Class<?> defineClass(ClassLoader classLoader,
                               String name,
                               byte[] binaryRepresentation,
                               ProtectionDomain protectionDomain);
  
          Package getPackage(ClassLoader classLoader, String name);
  
          Package definePackage(ClassLoader classLoader, String name);
      }
  
      private static class UsingReflectionAccess extends ClassInjector.UsingReflection {
          private static final String BOOTSTRAP_ACCESSOR_NAME = "java.lang.ClassLoader$ByteBuddyAccessor$Bootstrap";
  
          UsingReflectionAccess() {
              super(ClassLoader.getSystemClassLoader());
          }
  
          static IndirectOperations makeBootstrapIndirectOperations() throws Exception {
              Class<?> accessorType = makeBootstrapAccessorType();
              Object accessor = UnsafeAccess.allocateInstance(accessorType);
              return toIndirectOperations(new TestIndirect(accessor,
                      accessorType.getMethod("findLoadedClass", ClassLoader.class, String.class),
                      accessorType.getMethod("defineClass",
                              ClassLoader.class,
                              String.class,
                              byte[].class,
                              int.class,
                              int.class,
                              ProtectionDomain.class),
                      accessorType.getMethod("getPackage", ClassLoader.class, String.class),
                      accessorType.getMethod("definePackage",
                              ClassLoader.class,
                              String.class,
                              String.class,
                              String.class,
                              String.class,
                              String.class,
                              String.class,
                              String.class,
                              URL.class),
                      accessorType.getMethod("getClassLoadingLock", ClassLoader.class, String.class)));
          }
  
          static IndirectOperations makeIndirectOperations() throws NoSuchMethodException {
              return toIndirectOperations(new TestIndirect(new Accessor(),
                      Accessor.class.getMethod("findLoadedClass", ClassLoader.class, String.class),
                      Accessor.class.getMethod("defineClass",
                              ClassLoader.class,
                              String.class,
                              byte[].class,
                              int.class,
