[tool-call] delta {"path":"tests/src/net.bytebuddy/byte-buddy/1.8.15/src/test/java/net_bytebuddy/byte_buddy/TypePoolInnerAbstractBaseInnerRawDescriptionArrayTest.java","edits":[{"oldText":"import java.lang.annotation.Retention;\nimport java.lang.annotation.RetentionPolicy;\n","newText":"import java.lang.reflect.Modifier;\nimport java.util.HashMap;\nimport java.util.Map;\n"},{"oldText":"    private static final String SAMPLE_TYPE = \"net_bytebuddy.byte_buddy.TypePoolRawDescriptionArraySample\";\n","newText":"    private static final String ANNOTATION_TYPE = \"net_bytebuddy.byte_buddy.TypePoolRawDescriptionArrayAnnotation\";\n    private static final String SAMPLE_TYPE = \"net_bytebuddy.byte_buddy.TypePoolRawDescriptionArraySample\";\n"},{"oldText":"        DynamicType.Unloaded<?> dynamicType = new ByteBuddy(ClassFileVersion.JAVA_V8)\n                .subclass(Object.class)\n                .name(SAMPLE_TYPE)\n                .annotateType(AnnotationDescription.Builder.ofType(ArrayValues.class)\n                        .defineTypeArray(\"types\", String.class, Integer.class)\n                        .build())\n                .make();\n        TypePool typePool = TypePool.Default.of(new ClassFileLocator.Compound(\n                ClassFileLocator.Simple.of(dynamicType),\n                ClassFileLocator.ForClassLoader.of(getClass().getClassLoader())));\n        return typePool.describe(SAMPLE_TYPE)\n                .resolve()\n                .getDeclaredAnnotations()\n                .ofType(ArrayValues.class);\n    }\n\n    @Retention(RetentionPolicy.RUNTIME)\n    public @interface ArrayValues {\n        Class<?>[] types();\n    }\n","newText":"        ByteBuddy byteBuddy = new ByteBuddy(ClassFileVersion.JAVA_V8);\n        DynamicType.Unloaded<?> annotationType = byteBuddy\n                .makeAnnotation()\n                .name(ANNOTATION_TYPE)\n                .defineMethod(\"types\", Class[].class, Modifier.PUBLIC | Modifier.ABSTRACT)\n                .withoutCode()\n                .make();\n        DynamicType.Unloaded<?> sampleType = byteBuddy\n                .subclass(Object.class)\n                .name(SAMPLE_TYPE)\n                .annotateType(AnnotationDescription.Builder.ofType(annotationType.getTypeDescription())\n                        .defineTypeArray(\"types\", String.class, Integer.class)\n                        .build())\n                .make();\n        Map<TypeDescription, byte[]> classFiles = new HashMap<TypeDescription, byte[]>();\n        classFiles.putAll(annotationType.getAllTypes());\n        classFiles.putAll(sampleType.getAllTypes());\n        TypePool typePool = TypePool.Default.of(new ClassFileLocator.Compound(\n                ClassFileLocator.Simple.of(classFiles),\n                ClassFileLocator.ForClassLoader.of(getClass().getClassLoader())));\n        return typePool.describe(SAMPLE_TYPE)\n                .resolve()\n                .getDeclaredAnnotations()\n                .getOnly();\n    }\n"}]}
