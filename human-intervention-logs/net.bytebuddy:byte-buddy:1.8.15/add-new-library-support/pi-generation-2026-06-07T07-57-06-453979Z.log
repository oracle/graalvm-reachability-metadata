[tool-call] delta {"path":"tests/src/net.bytebuddy/byte-buddy/1.8.15/src/test/java/net_bytebuddy/byte_buddy/ClassReloadingStrategyTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage net_bytebuddy.byte_buddy;\n\nimport net.bytebuddy.agent.ByteBuddyAgent;\nimport net.bytebuddy.dynamic.loading.ClassReloadingStrategy;\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\n\nimport java.lang.instrument.Instrumentation;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ClassReloadingStrategyTest {\n    @Test\n    void createsReloadingStrategiesFromInstalledByteBuddyAgent() {\n        try {\n            Instrumentation instrumentation = ByteBuddyAgent.install();\n\n            ClassReloadingStrategy inferredStrategy = ClassReloadingStrategy.fromInstalledAgent();\n            assertThat(inferredStrategy).isNotNull();\n\n            ClassReloadingStrategy explicitStrategy = ClassReloadingStrategy.fromInstalledAgent(\n                    supportedStrategy(instrumentation));\n            assertThat(explicitStrategy).isNotNull();\n        } catch (IllegalStateException exception) {\n            assertThat(exception).hasMessageNotContaining(\"The Byte Buddy agent is not installed or not accessible\");\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    private static ClassReloadingStrategy.Strategy supportedStrategy(Instrumentation instrumentation) {\n        if (instrumentation.isRetransformClassesSupported()) {\n            return ClassReloadingStrategy.Strategy.RETRANSFORMATION;\n        } else if (instrumentation.isRedefineClassesSupported()) {\n            return ClassReloadingStrategy.Strategy.REDEFINITION;\n        } else {\n            throw new IllegalStateException(\"Instrumentation does not support class reloading: \" + instrumentation);\n        }\n    }\n}\n"}
