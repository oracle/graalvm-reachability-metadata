  package net_bytebuddy.byte_buddy;
  
  import java.lang.invoke.MethodHandle;
  import java.lang.invoke.MethodHandles;
  import java.lang.invoke.MethodType;
  import java.lang.reflect.Field;
  import java.lang.reflect.Method;
  import java.net.URL;
  import java.net.URLClassLoader;
  import java.security.ProtectionDomain;
  import java.util.HashMap;
  import java.util.Map;
  
  import net.bytebuddy.ByteBuddy;
  import net.bytebuddy.ClassFileVersion;
  import net.bytebuddy.description.type.TypeDescription;
  import net.bytebuddy.dynamic.DynamicType;
  import net.bytebuddy.dynamic.loading.ClassInjector;
  import net.bytebuddy.dynamic.loading.ClassLoadingStrategy;
  import net.bytebuddy.dynamic.loading.PackageDefinitionStrategy;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  
  import sun.misc.Unsafe;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ClassInjectorInnerUsingReflectionInnerDispatcherInnerIndirectTest {
      @Test
      void invokesIndirectDispatcherAccessorMethods() throws Exception {
          try {
              invokeIndirectDispatcherAccessorMethods();
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
      }
  
      @Test
      void injectsGeneratedTypeThroughReflectionDispatcher() throws Exception {
          try {
              injectGeneratedTypeThroughReflectionDispatcher();
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
      }
  
      private static void invokeIndirectDispatcherAccessorMethods() throws Exception {
          String packageName = "net_bytebuddy.byte_buddy.manual";
          String typeName = packageName + ".ManuallyInjectedType";
          DynamicType.Unloaded<?> dynamicType = makeType(typeName);
          UsingUnsafeAccess.installBootstrapDefiningDispatcher();
  
          assertIndirectOperations(UsingReflectionAccess.makeBootstrapIndirectOperations(),
                  typeName,
                  packageName,
                  dynamicType.getBytes());
          assertIndirectOperations(UsingReflectionAccess.makeIndirectOperations(),
                  packageName + ".SecondManuallyInjectedType",
                  packageName,
                  makeType(packageName + ".SecondManuallyInjectedType").getBytes());
      }
  
      private static void injectGeneratedTypeThroughReflectionDispatcher() throws Exception {
          if (!ClassInjector.UsingReflection.isAvailable()) {
              return;
          }
  
          String typeName = "net_bytebuddy.byte_buddy.generated.ReflectionInjectedType";
          DynamicType.Unloaded<?> dynamicType = makeType(typeName);
          TypeDescription typeDescription = dynamicType.getTypeDescription();
          Map<TypeDescription, byte[]> types = new HashMap<TypeDescription, byte[]>();
          types.put(typeDescription, dynamicType.getBytes());
  
          try (URLClassLoader classLoader = new URLClassLoader(new URL[0], null)) {
              ClassInjector injector = new ClassInjector.UsingReflection(
                      classLoader,
                      ClassInjector.UsingReflection.class.getProtectionDomain(),
                      PackageDefinitionStrategy.Trivial.INSTANCE,
                      ClassInjector.ALLOW_EXISTING_TYPES);
  
              Map<TypeDescription, Class<?>> loadedTypes = injector.inject(types);
  
              Class<?> loadedType = loadedTypes.get(typeDescription);
              assertThat(loadedType).isNotNull();
              assertThat(loadedType.getName()).isEqualTo(typeName);
              assertThat(loadedType.getClassLoader()).isSameAs(classLoader);
              assertThat(loadedType.getPackage()).isNotNull();
              assertThat(loadedType.getPackage().getName()).isEqualTo("net_bytebuddy.byte_buddy.generated");
              assertThat(classLoader.loadClass(typeName)).isSameAs(loadedType);
          }
      }
  
      private static DynamicType.Unloaded<?> makeType(String typeName) {
          return new ByteBuddy(ClassFileVersion.JAVA_V8)
                  .subclass(Object.class)
                  .name(typeName)
                  .make();
      }
  
      private static void assertIndirectOperations(IndirectOperations operations,
                                                   String typeName,
                                                   String packageName,
                                                   byte[] binaryRepresentation) {
          TestClassLoader classLoader = new TestClassLoader();
          ProtectionDomain protectionDomain = ClassInjector.UsingReflection.class.getProtectionDomain();
  
          assertThat(operations.getClassLoadingLock(classLoader, typeName)).isSameAs(classLoader);
          assertThat(operations.findClass(classLoader, typeName)).isNull();
          assertThat(operations.getPackage(classLoader, packageName)).isNull();
  
          Package definedPackage = operations.definePackage(classLoader, packageName);
          assertThat(definedPackage).isNotNull();
          assertThat(definedPackage.getName()).isEqualTo(packageName);
  
          Class<?> loadedType = operations.defineClass(classLoader, typeName, binaryRepresentation, protectionDomain);
          assertThat(loadedType.getName()).isEqualTo(typeName);
          assertThat(loadedType.getClassLoader()).isSameAs(classLoader);
          assertThat(operations.findClass(classLoader, typeName)).isSameAs(loadedType);
          assertThat(operations.getPackage(classLoader, packageName)).isSameAs(definedPackage);
      }
  
      private interface IndirectOperations {
          Object getClassLoadingLock(ClassLoader classLoader, String name);
  
          Class<?> findClass(ClassLoader classLoader, String name);
  
          Class<?> defineClass(ClassLoader classLoader,
                               String name,
                               byte[] binaryRepresentation,
                               ProtectionDomain protectionDomain);
  
          Package getPackage(ClassLoader classLoader, String name);
  
          Package definePackage(ClassLoader classLoader, String name);
      }
  
      private static class UsingReflectionAccess extends ClassInjector.UsingReflection {
          UsingReflectionAccess() {
              super(ClassLoader.getSystemClassLoader());
          }
  
          static IndirectOperations makeBootstrapIndirectOperations() throws Exception {
              return toIndirectOperations(Dispatcher.Indirect.make().initialize());
          }
  
          static IndirectOperations makeIndirectOperations() throws NoSuchMethodException {
              return toIndirectOperations(new TestIndirect(new Accessor(),
                      Accessor.class.getMethod("findLoadedClass", ClassLoader.class, String.class),
                      Accessor.class.getMethod("defineClass",
                              ClassLoader.class,
                              String.class,
                              byte[].class,
                              int.class,
                              int.class,
                              ProtectionDomain.class),
                      Accessor.class.getMethod("getPackage", ClassLoader.class, String.class),
                      Accessor.class.getMethod("definePackage",
                              ClassLoader.class,
                              String.class,
                              String.class,
                              String.class,
                              String.class,
                              String.class,
                              String.class,
                              String.class,
                              URL.class),
                      Accessor.class.getMethod("getClassLoadingLock", ClassLoader.class, String.class)));
          }
  
          private static IndirectOperations toIndirectOperations(final Dispatcher dispatcher) {
              return new IndirectOperations() {
                  @Override
                  public Object getClassLoadingLock(ClassLoader classLoader, String name) {
                      return dispatcher.getClassLoadingLock(classLoader, name);
                  }
  
                  @Override
                  public Class<?> findClass(ClassLoader classLoader, String name) {
                      return dispatcher.findClass(classLoader, name);
                  }
  
                  @Override
                  public Class<?> defineClass(ClassLoader classLoader,
                                              String name,
                                              byte[] binaryRepresentation,
                                              ProtectionDomain protectionDomain) {
                      return dispatcher.defineClass(classLoader, name, binaryRepresentation, protectionDomain);
                  }
  
                  @Override
                  public Package getPackage(ClassLoader classLoader, String name) {
                      return dispatcher.getPackage(classLoader, name);
                  }
  
                  @Override
                  public Package definePackage(ClassLoader classLoader, String name) {
                      return dispatcher.definePackage(classLoader, name, null, null, null, null, null, null, null);
                  }
              };
          }
  
          private static class TestIndirect extends Dispatcher.Indirect {
              TestIndirect(Object accessor,
                           Method findLoadedClass,
                           Method defineClass,
                           Method getPackage,
                           Method definePackage,
                           Method getClassLoadingLock) {
                  super(accessor, findLoadedClass, defineClass, getPackage, definePackage, getClassLoadingLock);
              }
          }
      }
  
      private static class UsingUnsafeAccess extends ClassInjector.UsingUnsafe {
          UsingUnsafeAccess() {
              super(ClassLoadingStrategy.BOOTSTRAP_LOADER);
          }
  
          static void installBootstrapDefiningDispatcher() throws Exception {
              ClassInjector.UsingUnsafe.isAvailable();
              Unsafe unsafe = UnsafeAccess.unsafe();
              Field dispatcher = ClassInjector.UsingUnsafe.class.getDeclaredField("DISPATCHER");
              unsafe.putObjectVolatile(unsafe.staticFieldBase(dispatcher),
                      unsafe.staticFieldOffset(dispatcher),
                      new BootstrapDefiningDispatcher());
          }
  
          private static class BootstrapDefiningDispatcher implements Dispatcher, Dispatcher.Initializable {
              private final MethodHandle defineClass;
              private final Object unsafe;
  
              BootstrapDefiningDispatcher() throws Exception {
                  Class<?> unsafeType = Class.forName("jdk.internal.misc.Unsafe");
                  this.unsafe = UnsafeAccess.getStaticField(unsafeType, "theUnsafe");
                  this.defineClass = UnsafeAccess.trustedLookup().findVirtual(unsafeType,
                          "defineClass",
                          MethodType.methodType(Class.class,
                                  String.class,
                                  byte[].class,
                                  int.class,
                                  int.class,
                                  ClassLoader.class,
                                  ProtectionDomain.class));
              }
  
              @Override
              public boolean isAvailable() {
                  return true;
              }
  
              @Override
              public Dispatcher initialize() {
                  return this;
              }
  
              @Override
              public Class<?> defineClass(ClassLoader classLoader,
                                          String name,
                                          byte[] binaryRepresentation,
                                          ProtectionDomain protectionDomain) {
                  try {
                      return (Class<?>) defineClass.invoke(unsafe,
                              name,
                              binaryRepresentation,
                              0,
                              binaryRepresentation.length,
                              classLoader,
                              protectionDomain);
                  } catch (RuntimeException exception) {
                      throw exception;
                  } catch (Error error) {
                      throw error;
                  } catch (Throwable throwable) {
                      throw new IllegalStateException(
                              "Could not define class through jdk.internal.misc.Unsafe",
                              throwable);
                  }
              }
          }
      }
  
      private static class UnsafeAccess {
          private static Unsafe unsafe() throws Exception {
              Field theUnsafe = Unsafe.class.getDeclaredField("theUnsafe");
              theUnsafe.setAccessible(true);
              return (Unsafe) theUnsafe.get(null);
          }
  
          private static MethodHandles.Lookup trustedLookup() throws Exception {
              return (MethodHandles.Lookup) getStaticField(MethodHandles.Lookup.class, "IMPL_LOOKUP");
          }
  
          private static Object getStaticField(Class<?> type, String name) throws Exception {
              Unsafe unsafe = unsafe();
              Field field = type.getDeclaredField(name);
              return unsafe.getObject(unsafe.staticFieldBase(field), unsafe.staticFieldOffset(field));
          }
      }
  
      public static class Accessor {
          public Object getClassLoadingLock(ClassLoader classLoader, String name) {
              return asTestClassLoader(classLoader).getClassLoadingLockPublic(name);
          }
  
          public Class<?> findLoadedClass(ClassLoader classLoader, String name) {
              return asTestClassLoader(classLoader).findLoadedClassPublic(name);
          }
  
          public Class<?> defineClass(ClassLoader classLoader,
                                      String name,
                                      byte[] binaryRepresentation,
                                      int offset,
                                      int length,
                                      ProtectionDomain protectionDomain) {
              return asTestClassLoader(classLoader).defineClassPublic(
                      name,
                      binaryRepresentation,
                      offset,
                      length,
                      protectionDomain);
          }
  
          public Package getPackage(ClassLoader classLoader, String name) {
              return asTestClassLoader(classLoader).getPackagePublic(name);
          }
  
          public Package definePackage(ClassLoader classLoader,
                                       String name,
                                       String specificationTitle,
                                       String specificationVersion,
                                       String specificationVendor,
                                       String implementationTitle,
                                       String implementationVersion,
                                       String implementationVendor,
                                       URL sealBase) {
              return asTestClassLoader(classLoader).definePackagePublic(
                      name,
                      specificationTitle,
                      specificationVersion,
                      specificationVendor,
                      implementationTitle,
                      implementationVersion,
                      implementationVendor,
                      sealBase);
          }
  
          private static TestClassLoader asTestClassLoader(ClassLoader classLoader) {
              assertThat(classLoader).isInstanceOf(TestClassLoader.class);
              return (TestClassLoader) classLoader;
          }
      }
  
      private static class TestClassLoader extends ClassLoader {
          TestClassLoader() {
              super(null);
          }
  
          Object getClassLoadingLockPublic(String name) {
              return getClassLoadingLock(name);
          }
  
          Class<?> findLoadedClassPublic(String name) {
              return findLoadedClass(name);
          }
  
          Class<?> defineClassPublic(String name,
                                     byte[] binaryRepresentation,
                                     int offset,
                                     int length,
                                     ProtectionDomain protectionDomain) {
              return defineClass(name, binaryRepresentation, offset, length, protectionDomain);
          }
  
          Package getPackagePublic(String name) {
              return getPackage(name);
          }
  
          Package definePackagePublic(String name,
                                      String specificationTitle,
                                      String specificationVersion,
                                      String specificationVendor,
                                      String implementationTitle,
                                      String implementationVersion,
                                      String implementationVendor,
                                      URL sealBase) {
              return definePackage(name,
                      specificationTitle,
                      specificationVersion,
                      specificationVendor,
                      implementationTitle,
                      implementationVersion,
                      implementationVendor,
                      sealBase);
          }
      }
  }
