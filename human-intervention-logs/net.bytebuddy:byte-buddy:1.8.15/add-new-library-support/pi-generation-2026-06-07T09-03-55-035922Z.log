m.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\n\nimport java.util.Arrays;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ClassFileLocatorInnerAgentBasedTest {\n    @Test\n    void locatesLoadedClassFromInstalledByteBuddyAgent() throws Exception {\n        try {\n            ClassFileLocator classFileLocator = ClassFileLocator.AgentBased.fromInstalledAgent(\n                    ClassFileLocatorInnerAgentBasedTest.class.getClassLoader());\n            ClassFileLocator.Resolution resolution = classFileLocator.locate(\n                    ClassFileLocatorInnerAgentBasedTest.class.getName());\n\n            assertThat(resolution.isResolved()).isTrue();\n            byte[] binaryRepresentation = resolution.resolve();\n            assertThat(binaryRepresentation).isNotEmpty();\n            assertThat(Arrays.copyOf(binaryRepresentation, 4)).containsExactly(\n                    (byte) 0xCA,\n                    (byte) 0xFE,\n                    (byte) 0xBA,\n                    (byte) 0xBE);\n        } catch (IllegalStateException exception) {\n            assertThat(exception).hasMessageContaining(\"The Byte Buddy agent is not installed or not accessible\");\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 709, "output": 913, "cacheRead": 19456, "cacheWrite": 0, "totalTokens": 21078, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780822980546, "responseId": "resp_0bff74405fb9bb2b016a2533c505f88196bf40b7d30dbc307b"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_2AA2b7ZwjqqXT1HT6c2Nhy28|fc_0bff74405fb9bb2b016a2533d56cfc81968912aa4c9b9f86f0", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 16