  package net_bytebuddy.byte_buddy;
  
  import java.io.IOException;
  
  import net.bytebuddy.dynamic.ClassFileLocator;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ClassFileLocatorInnerForModuleTest {
      @Test
      void createsLocatorForBootLayerModules() throws IOException {
          ClassFileLocator classFileLocator = ClassFileLocator.ForModule.ofBootLayer();
  
          ClassFileLocator.Resolution missingResolution = classFileLocator.locate("java.lang.NoSuchByteBuddyFixture");
  
          assertThat(classFileLocator).isNotNull();
          assertThat(missingResolution.isResolved()).isFalse();
      }
  }
