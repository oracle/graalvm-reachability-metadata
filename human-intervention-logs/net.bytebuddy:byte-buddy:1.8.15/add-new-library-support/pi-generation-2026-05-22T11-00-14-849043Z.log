p(FieldDescription::getName)\n                .collect(Collectors.toSet());\n        assertThat(declaredFieldNames).containsExactlyInAnyOrder(\"name\", \"count\", \"active\");\n        assertThat(declaredFields.filter(named(\"name\")).getOnly().getType().asErasure().represents(String.class))\n                .isTrue();\n        assertThat(declaredFields.filter(named(\"count\")).getOnly().getType().asErasure().represents(int.class))\n                .isTrue();\n    }\n\n    private static class LoadedTypeFixture {\n        private final String name = \"byte-buddy\";\n\n        private int count;\n\n        boolean active;\n\n        private interface NestedContract {\n            String value();\n        }\n\n        private static class NestedImplementation implements NestedContract {\n            @Override\n            public String value() {\n                return \"loaded\";\n            }\n        }\n    }\n}\n"}
