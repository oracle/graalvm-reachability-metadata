[tool-call] delta {"path":"tests/src/net.bytebuddy/byte-buddy/1.8.15/src/test/java/net_bytebuddy/byte_buddy/AnnotationValueInnerForDescriptionArrayTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage net_bytebuddy.byte_buddy;\n\nimport java.lang.annotation.Deprecated;\n\nimport net.bytebuddy.description.annotation.AnnotationDescription;\nimport net.bytebuddy.description.annotation.AnnotationValue;\nimport net.bytebuddy.description.type.TypeDescription;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class AnnotationValueInnerForDescriptionArrayTest {\n    @Test\n    void resolvesAndLoadsAnnotationDescriptionArray() throws Exception {\n        AnnotationValue<AnnotationDescription[], Deprecated[]> annotationValue = AnnotationValue.ForDescriptionArray.of(\n                TypeDescription.ForLoadedType.of(Deprecated.class),\n                new AnnotationDescription[0]);\n\n        AnnotationDescription[] resolved = annotationValue.resolve();\n        AnnotationValue.Loaded<Deprecated[]> loaded = annotationValue.load(\n                AnnotationValueInnerForDescriptionArrayTest.class.getClassLoader());\n        Deprecated[] loadedAnnotations = loaded.resolve();\n\n        assertThat(resolved).isEmpty();\n        assertThat(loadedAnnotations).isEmpty();\n        assertThat(loadedAnnotations.getClass().getComponentType()).isEqualTo(Deprecated.class);\n    }\n}\n"}
