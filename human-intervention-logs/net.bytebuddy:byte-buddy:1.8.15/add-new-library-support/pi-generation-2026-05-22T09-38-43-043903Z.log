  package net_bytebuddy.byte_buddy;
  
  import java.lang.invoke.MethodHandles;
  import java.lang.invoke.MethodType;
  
  import net.bytebuddy.utility.JavaConstant.MethodHandle;
  import net.bytebuddy.utility.JavaConstant.MethodHandle.HandleType;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class JavaConstantInnerMethodHandleInnerDispatcherInnerAbstractBaseTest {
      @Test
      void describesLoadedPublicStaticMethodHandle() throws Exception {
          MethodHandle methodHandle = MethodHandle.ofLoaded(MethodHandles.lookup().findStatic(
                  JavaConstantInnerMethodHandleInnerDispatcherInnerAbstractBaseTest.class,
                  "joinValues",
                  MethodType.methodType(String.class, String.class, int.class)));
  
          assertThat(methodHandle.getHandleType()).isEqualTo(HandleType.INVOKE_STATIC);
          assertThat(methodHandle.getOwnerType().getName())
                  .isEqualTo(JavaConstantInnerMethodHandleInnerDispatcherInnerAbstractBaseTest.class.getName());
          assertThat(methodHandle.getName()).isEqualTo("joinValues");
          assertThat(methodHandle.getReturnType().represents(String.class)).isTrue();
          assertThat(methodHandle.getParameterTypes().get(0).represents(String.class)).isTrue();
          assertThat(methodHandle.getParameterTypes().get(1).represents(int.class)).isTrue();
      }
  
      @Test
      void resolvesLookupTypeFromLookupObject() {
          assertThat(MethodHandle.lookupType(MethodHandles.lookup()))
                  .isEqualTo(JavaConstantInnerMethodHandleInnerDispatcherInnerAbstractBaseTest.class);
      }
  
      public static String joinValues(String value, int count) {
          return value + count;
      }
  }
