e(),\n                ClassFileLocator.Simple.of(classFiles),\n                TypePool.Default.ReaderMode.FAST,\n                new LoadedTypesTypePool(\n                        Annotation.class,\n                        Mode.class,\n                        Object.class,\n                        Retention.class,\n                        RetentionPolicy.class));\n        return typePool.describe(SAMPLE_TYPE)\n                .resolve()\n                .getDeclaredAnnotations()\n                .getOnly();\n    }\n\n    public enum Mode {\n        ACTIVE,\n        PASSIVE\n    }\n\n    private static class LoadedTypesTypePool extends TypePool.AbstractBase {\n        private final Map<String, TypeDescription> typeDescriptions;\n\n        LoadedTypesTypePool(Class<?>... types) {\n            super(new TypePool.CacheProvider.Simple());\n            typeDescriptions = new HashMap<String, TypeDescription>();\n            for (Class<?> type : types) {\n                typeDescriptions.put(type.getName(), TypeDescription.ForLoadedType.of(type));\n            }\n        }\n\n        @Override\n        protected Resolution doDescribe(String name) {\n            TypeDescription typeDescription = typeDescriptions.get(name);\n            return typeDescription == null\n                    ? new Resolution.Illegal(name)\n                    : new Resolution.Simple(typeDescription);\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 534, "output": 1544, "cacheRead": 23552, "cacheWrite": 0, "totalTokens": 25630, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780839050926, "responseId": "resp_073beee18325d14c016a25728ba7b8819083bc120a18f94ae2"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_6wYscCSr79SVT7gxOUNAdliC|fc_073beee18325d14c016a25729640d8819092266ccb4c86e82a", "toolName": "write", "content": [{"type": "text", "text": "Suc