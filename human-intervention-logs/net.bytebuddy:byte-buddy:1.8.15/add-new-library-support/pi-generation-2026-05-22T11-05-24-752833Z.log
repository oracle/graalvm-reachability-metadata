  package net_bytebuddy.byte_buddy;
  
  import java.lang.invoke.MethodHandles;
  import java.util.HashMap;
  import java.util.Map;
  
  import net.bytebuddy.ByteBuddy;
  import net.bytebuddy.ClassFileVersion;
  import net.bytebuddy.description.type.TypeDescription;
  import net.bytebuddy.dynamic.DynamicType;
  import net.bytebuddy.dynamic.loading.ClassInjector;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ClassInjectorInnerUsingLookupInnerDispatcherInnerForJava9CapableVmTest {
      @Test
      void resolvesLookupAndDefinesGeneratedType() {
          try {
              ClassInjector.UsingLookup injector = new FullPrivilegeUsingLookup(MethodHandles.lookup())
                      .in(LookupScope.class);
              String typeName = "net_bytebuddy.byte_buddy.LookupDispatcherDefinedType";
              DynamicType.Unloaded<?> dynamicType = makeType(typeName);
              TypeDescription typeDescription = dynamicType.getTypeDescription();
              Map<TypeDescription, byte[]> types = new HashMap<TypeDescription, byte[]>();
              types.put(typeDescription, dynamicType.getBytes());
  
              Map<TypeDescription, Class<?>> loadedTypes = injector.inject(types);
  
              Class<?> loadedType = loadedTypes.get(typeDescription);
              assertThat(injector.lookupType()).isSameAs(LookupScope.class);
              assertThat(loadedType).isNotNull();
              assertThat(loadedType.getName()).isEqualTo(typeName);
              assertThat(loadedType.getClassLoader()).isSameAs(LookupScope.class.getClassLoader());
              assertThat(LookupScope.class.getClassLoader().loadClass(typeName)).isSameAs(loadedType);
          } catch (IllegalStateException exception) {
              if (!hasUnsupportedFeatureErrorCause(exception)) {
                  throw exception;
              }
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          } catch (ClassNotFoundException exception) {
              throw new AssertionError(exception);
          }
      }
  
      private static DynamicType.Unloaded<?> makeType(String typeName) {
          return new ByteBuddy(ClassFileVersion.JAVA_V8)
                  .subclass(Object.class)
                  .name(typeName)
                  .make();
      }
  
      private static boolean hasUnsupportedFeatureErrorCause(Throwable throwable) {
          Throwable current = throwable;
          while (current != null) {
              if (current instanceof Error error && NativeImageSupport.isUnsupportedFeatureError(error)) {
                  return true;
              }
              current = current.getCause();
          }
          return false;
      }
  
      private static class FullPrivilegeUsingLookup extends ClassInjector.UsingLookup {
          FullPrivilegeUsingLookup(Object lookup) {
              super(lookup);
          }
      }
  
      private static class LookupScope {
      }
  }
