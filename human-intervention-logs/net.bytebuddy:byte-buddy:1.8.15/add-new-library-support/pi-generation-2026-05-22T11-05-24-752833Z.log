rotectionDomain();\n\n        Class<?> loadedType = operations.defineClass(classLoader, typeName, dynamicType.getBytes(), protectionDomain);\n\n        assertThat(loadedType.getName()).isEqualTo(typeName);\n        assertThat(loadedType.getClassLoader()).isSameAs(classLoader);\n        assertThat(classLoader.loadClass(typeName)).isSameAs(loadedType);\n        assertThat(UnsafeLike.INSTANCE.lastName).isEqualTo(typeName);\n        assertThat(UnsafeLike.INSTANCE.lastProtectionDomain).isSameAs(protectionDomain);\n    }\n\n    private static DynamicType.Unloaded<?> makeType(String typeName) {\n        return new ByteBuddy(ClassFileVersion.JAVA_V8)\n                .subclass(Object.class)\n                .name(typeName)\n                .make();\n    }\n\n    private static boolean hasUnsupportedFeatureErrorCause(Throwable throwable) {\n        Throwable current = throwable;\n        while (current != null) {\n            if (current instanceof Error error && NativeImageSupport.isUnsupportedFeatureError(error)) {\n                return true;\n            }\n            current = current.getCause();\n        }\n        return false;\n    }\n\n    private interface UnsafeOperations {\n        Class<?> defineClass(ClassLoader classLoader,\n                             String name,\n                             byte[] binaryRepresentation,\n                             ProtectionDomain protectionDomain);\n    }\n\n    private static class UsingUnsafeAccess extends ClassInjector.UsingUnsafe {\n        UsingUnsafeAccess() {\n            super(ClassLoader.getSystemClassLoader());\n        }\n\n        static UnsafeOperations makeUnsafeOperations() throws NoSuchFieldException, NoSuchMethodException {\n            Dispatcher dispatcher = new TestEnabled(\n                    UnsafeLike.class.getDeclaredField(\"INSTANCE\"),\n                    UnsafeLike.class.getMethod(\"defineClass\",\n                            String.class,\n                            byte[].class,\n                            int.class,\n                            int.class,\n                            ClassLoader.class,\n                            ProtectionDomain.class)).initialize();\n            return new UnsafeOperations() {\n                @Override\n                public Class<?> defineClass(ClassLoader classLoader,\n                                            String name,\n                                            byte[] binaryRepresentation,\n                                            ProtectionDomain protectionDomain) {\n                    return dispatcher.defineClass(classLoader, name, binaryRepresentation, protectionDomain);\n                }\n            };\n        }\n\n        private static class TestEnabled extends Dispatcher.Enabled {\n            TestEnabled(Field theUnsafe, Method defineClass) {\n                super(theUnsafe, defineClass);\n            }\n        }\n    }\n\n    public static class UnsafeLike {\n        public static final UnsafeLike INSTANCE = new UnsafeLike();\n\n        private String lastName;\n        private ProtectionDomain lastProtectionDomain;\n\n        public Class<?> defineClass(String name,\n                                    byte[] binaryRepresentation,\n                                    int offset,\n                                    int length,\n                                    ClassLoader classLoader,\n                                    ProtectionDomain protectionDomain) {\n            lastName = name;\n            lastProtectionDomain = protectionDomain;\n            assertThat(offset).isZero();\n            assertThat(length).isEqualTo(binaryRepresentation.length);\n            return ((TestClassLoader) classLoader).defineClassPublic(name,\n                    binaryRepresentation,\n                    offset,\n                    length,\n                    protectionDomain);\n        }\n    }\n\n    public static class TestClassLoader extends ClassLoader {\n        public TestClassLoader() {\n            super(null);\n        }\n\n        public Class<?> defineClassPublic(String name,\n                                          byte[] binaryRepresentation,\n                                          int offset,\n                                          int length,\n                                          ProtectionDomain protectionDomain) {\n            return defineClass(name, binaryRepresentation, offset, length, protectionDomain);\n        }\n    }\n}\n"}
