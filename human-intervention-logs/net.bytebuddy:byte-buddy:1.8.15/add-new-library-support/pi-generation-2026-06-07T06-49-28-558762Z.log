n            assertThat(resource.read()).isNotEqualTo(-1);\n        }\n    }\n\n    @Test\n    void addsReadEdgeThroughInstrumentationApi() {\n        JavaModule sourceModule = JavaModule.ofType(JavaModuleInnerDispatcherInnerEnabledTest.class);\n        JavaModule targetModule = JavaModule.ofType(String.class);\n        RecordingInstrumentation recordingInstrumentation = new RecordingInstrumentation();\n        Instrumentation instrumentation = recordingInstrumentation.createProxy();\n\n        sourceModule.addReads(instrumentation, targetModule);\n\n        assertThat(recordingInstrumentation.modifiableModule).isSameAs(sourceModule.unwrap());\n        assertThat(recordingInstrumentation.redefinedModule).isSameAs(sourceModule.unwrap());\n        assertThat(recordingInstrumentation.extraReads).containsExactly(targetModule.unwrap());\n        assertThat(recordingInstrumentation.extraExports).isEmpty();\n        assertThat(recordingInstrumentation.extraOpens).isEmpty();\n        assertThat(recordingInstrumentation.extraUses).isEmpty();\n        assertThat(recordingInstrumentation.extraProvides).isEmpty();\n    }\n\n    private static class RecordingInstrumentation implements InvocationHandler {\n        Object modifiableModule;\n        Object redefinedModule;\n        Set<?> extraReads;\n        Map<?, ?> extraExports;\n        Map<?, ?> extraOpens;\n        Set<?> extraUses;\n        Map<?, ?> extraProvides;\n\n        Instrumentation createProxy() {\n            return (Instrumentation) Proxy.newProxyInstance(\n                    JavaModuleInnerDispatcherInnerEnabledTest.class.getClassLoader(),\n                    new Class<?>[] {Instrumentation.class},\n                    this);\n        }\n\n        @Override\n        public Object invoke(Object proxy, Method method, Object[] arguments) {\n            String methodName = method.getName();\n            if (methodName.equals(\"isModifiableModule\")) {\n                modifiableModule = arguments[0];\n           