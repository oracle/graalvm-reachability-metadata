\n\npublic class ByteArrayClassLoaderInnerChildFirstTest {\n    @Test\n    void loadsTypesWithChildFirstStaticStrategy() {\n        try {\n            String typeName = \"net_bytebuddy.byte_buddy.generated.ChildFirstStaticLoadedType\";\n            DynamicType.Unloaded<?> dynamicType = makeType(typeName);\n            Map<TypeDescription, byte[]> types = new HashMap<TypeDescription, byte[]>();\n            types.put(dynamicType.getTypeDescription(), dynamicType.getBytes());\n\n            Map<TypeDescription, Class<?>> loadedTypes = ByteArrayClassLoader.ChildFirst.load(\n                    ClassLoader.getSystemClassLoader(),\n                    types,\n                    ClassLoadingStrategy.NO_PROTECTION_DOMAIN,\n                    ByteArrayClassLoader.PersistenceHandler.LATENT,\n                    PackageDefinitionStrategy.Trivial.INSTANCE,\n                    true,\n                    true);\n\n            Class<?> loadedType = loadedTypes.get(dynamicType.getTypeDescription());\n            assertThat(loadedType).isNotNull();\n            assertThat(loadedType.getName()).isEqualTo(typeName);\n            assertThat(loadedType.getClassLoader()).isInstanceOf(ByteArrayClassLoader.ChildFirst.class);\n            assertThat(loadedType.getClassLoader().loadClass(typeName)).isSameAs(loadedType);\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        } catch (ClassNotFoundException exception) {\n            throw new AssertionError(exception);\n        }\n    }\n\n    @Test\n    void delegatesParentOnlyResourceLookups() throws IOException {\n        URL parentOnlyResource = url(\"file:/byte-buddy-parent-only-resource.txt\");\n        ParentResourceClassLoader parent = new ParentResourceClassLoader(\n                \"byte-buddy-parent-only-resource.txt\",\n                parentOnlyResource);\n        ByteArrayClassLoader.ChildFirst classLoader = new ByteArrayClassLoader.ChildFirst(\n                parent,\n                Collections.<String, byte[]>emptyMap(),\n                ByteArrayClassLoader.PersistenceHandler.LATENT);\n\n        assertThat(classLoader.getResource(\"byte-buddy-parent-only-resource.txt\")).isEqualTo(parentOnlyResource);\n        Enumeration<URL> resources = classLoader.getResources(\"byte-buddy-parent-only-resource.txt\");\n        assertThat(resources.hasMoreElements()).isTrue();\n        assertThat(resources.nextElement()).isEqualTo(parentOnlyResource);\n        assertThat(resources.hasMoreElements()).isFalse();\n    }\n\n    @Test\n    void shadowsLatentClassResourceAfterLoading() throws Exception {\n        try {\n            String latentTypeName = \"net_bytebuddy.byte_buddy.generated.ChildFirstLatentLoadedType\";\n            DynamicType.Unloaded<?> latentType = makeType(latentTypeName);\n            Map<String, byte[]> latentTypes = new HashMap<String, byte[]>();\n            latentTypes.put(latentTypeName, latentType.getBytes());\n            ByteArrayClassLoader.ChildFirst latentClassLoader = new ByteArrayClassLoader.ChildFirst(\n                    ClassLoader.getSystemClassLoader(),\n                    latentTypes,\n                    ByteArrayClassLoader.PersistenceHandler.LATENT);\n\n            Class<?> loadedLatentType = latentClassLoader.loadClass(latentTypeName);\n\n            assertThat(loadedLatentType.getClassLoader()).isSameAs(latentClassLoader);\n            assertThat(latentClassLoader.getResource(resourceName(latentTypeName))).isNull();\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    @Test\n    void prependsManifestClassResourceToParentResources() throws IOException {\n        String manifestTypeName = \"net_bytebuddy.byte_buddy.generated.ChildFirstManifestResourceType\";\n        DynamicType.Unloaded<?> manifestType = makeType(manifestTypeName);\n        Map<String, byte[]> manifestTypes = new HashMap<String, byte[]>();\n        manifestTypes.put(manifestTypeName, manifestType.getBytes());\n        String manifestResourceName = resourceName(manifestTypeName);\n        URL parentResource = url(\"file:/byte-buddy-parent-class-resource.class\");\n        ByteArrayClassLoader.ChildFirst manifestClassLoader = new ByteArrayClassLoader.ChildFirst(\n                new ParentResourceClassLoader(manifestResourceName, parentResource),\n                manifestTypes,\n                ByteArrayClassLoader.PersistenceHandler.MANIFEST);\n\n        Enumeration<URL> resources = manifestClassLoader.getResources(manifestResourceName);\n\n        assertThat(resources.hasMoreElements()).isTrue();\n        assertThat(resources.nextElement().getProtocol()).isEqualTo(ByteArrayClassLoader.URL_SCHEMA);\n        assertThat(resources.hasMoreElements()).isTrue();\n        assertThat(resources.nextElement()).isEqualTo(parentResource);\n        assertThat(resources.hasMoreElements()).isFalse();\n    }\n\n    private static DynamicType.Unloaded<?> makeType(String typeName) {\n        return new ByteBuddy(ClassFileVersion.JAVA_V8)\n                .subclass(Object.class)\n                .name(typeName)\n                .make();\n    }\n\n    private static String resourceName(String typeName) {\n        return typeName.replace('.', '/') + \".class\";\n    }\n\n    private static URL url(String value) throws MalformedURLException {\n        return new URL(value);\n    }\n\n    private static class ParentResourceClassLoader extends ClassLoader {\n        private final String resourceName;\n        private final URL resource;\n\n        ParentResourceClassLoader(String resourceName, URL resource) {\n            super(null);\n            this.resourceName = resourceName;\n            this.resource = resource;\n        }\n\n        @Override\n        protected URL findResource(String name) {\n            return resourceName.equals(name)\n                    ? resource\n                    : null;\n        }\n\n        @Override\n        protected Enumeration<URL> findResources(String name) {\n            Vector<URL> resources = new Vector<URL>();\n            if (resourceName.equals(name)) {\n                resources.add(resource);\n            }\n            return resources.elements();\n        }\n    }\n}\n\n=====\n/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage net_bytebuddy.byte_buddy;\n\nimport java.io.IOException;\nimport java.net.MalformedURLException;\nimport java.net.URL;\nimport java.util.ArrayList;\nimport java.util.Arrays;\nimport java.util.Collections;\nimport java.util.Enumeration;\nimport java.util.List;\nimport java.util.Vector;\n\nimport net.bytebuddy.dynamic.loading.MultipleParentClassLoader;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class MultipleParentClassLoaderTest {\n    @Test\n    void loadsClassFromFirstParentThatCanResolveIt() throws ClassNotFoundException {\n        ParentClassLoader missingParent = new ParentClassLoader(\"missing.Type\", Object.class);\n        ParentClassLoader matchingParent = new ParentClassLoader(\n                ExampleLoadedType.class.getName(),\n                ExampleLoadedType.class);\n        MultipleParentClassLoader classLoader = new MultipleParentClassLoader(\n                Arrays.asList(missingParent, matchingParent));\n\n        Class<?> loadedType = classLoader.loadClass(ExampleLoadedType.class.getName());\n\n        assertThat(loadedType).isSameAs(ExampleLoadedType.class);\n        assertThat(missingParent.getLoadClassCalls()).isEqualTo(1);\n        assertThat(matchingParent.getLoadClassCalls()).isEqualTo(1);\n    }\n\n    @Test\n    void returnsFirstResourceFromParentsBeforeExplicitParent() throws MalformedURLException {\n        URL parentResource = url(\"file:/byte-buddy-multiple-parent-resource.txt\");\n        URL fallbackResource = url(\"file:/byte-buddy-explicit-parent-resource.txt\");\n        ResourceClassLoader resourceParent = new ResourceClassLoader(\n                \"byte-buddy-resource.txt\",\n                parentResource);\n        ResourceClassLoader explicitParent = new ResourceClassLoader(\n                \"byte-buddy-resource.txt\",\n                fallbackResource);\n        MultipleParentClassLoader classLoader = new MultipleParentClassLoader(\n                explicitParent,\n                Collections.singletonList(resourceParent));\n\n        URL resource = classLoader.getResource(\"byte-buddy-resource.txt\");\n\n        assertThat(resource).isEqualTo(parentResource);\n        assertThat(resourceParent.getResourceCalls()).isEqualTo(1);\n    }\n\n    @Test\n    void fallsBackToExplicitParentResourceWhenParentsMiss() throws MalformedURLException {\n        URL fallbackResource = url(\"file:/byte-buddy-explicit-parent-only-resource.txt\");\n        ResourceClassLoader missingParent = new ResourceClassLoader(\n                \"different-resource.txt\",\n                url(\"file:/byte-buddy-different-resource.txt\"));\n        ResourceClassLoader explicitParent = new ResourceClassLoader(\n                \"byte-buddy-explicit-parent-only-resource.txt\",\n                fallbackResource);\n        MultipleParentClassLoader classLoader = new MultipleParentClassLoader(\n                explicitParent,\n                Collections.singletonList(missingParent));\n\n        URL resource = classLoader.getResource(\"byte-buddy-explicit-parent-only-resource.txt\");\n\n        assertThat(resource).isEqualTo(fallbackResource);\n        assertThat(missingParent.getResourceCalls()).isEqualTo(1);\n    }\n\n    @Test\n    void combinesResourcesFromParentsAndExplicitParent() throws IOException {\n        URL firstParentResource = url(\"file:/byte-buddy-first-parent-resource.txt\");\n        URL secondParentResource = url(\"file:/byte-buddy-second-parent-resource.txt\");\n        URL fallbackResource = url(\"file:/byte-buddy-fallback-resource.txt\");\n        ResourceClassLoader firstParent = new ResourceClassLoader(\n                \"byte-buddy-combined-resource.txt\",\n                firstParentResource);\n        ResourceClassLoader secondParent = new ResourceClassLoader(\n                \"byte-buddy-combined-resource.txt\",\n                secondParentResource);\n        ResourceClassLoader explicitParent = new ResourceClassLoader(\n                \"byte-buddy-combined-resource.txt\",\n                fallbackResource);\n        MultipleParentClassLoader classLoader = new MultipleParentClassLoader(\n                explicitParent,\n                Arrays.asList(firstParent, secondParent));\n\n        List<URL> resources = list(classLoader.getResources(\"byte-buddy-combined-resource.txt\"));\n\n        assertThat(resources).containsExactly(firstParentResource, secondParentResource, fallbackResource);\n        assertThat(firstParent.getResourcesCalls()).isEqualTo(1);\n        assertThat(secondParent.getResourcesCalls()).isEqualTo(1);\n    }\n\n    private static List<URL> list(Enumeration<URL> enumeration) {\n        List<URL> resources = new ArrayList<URL>();\n        while (enumeration.hasMoreElements()) {\n            resources.add(enumeration.nextElement());\n        }\n        return resources;\n    }\n\n    private static URL url(String value) throws MalformedURLException {\n        return new URL(value);\n    }\n\n    private static class ExampleLoadedType {\n    }\n\n    private static class ParentClassLoader extends ClassLoader {\n        private final String typeName;\n        private final Class<?> loadedType;\n        private int loadClassCalls;\n\n        ParentClassLoader(String typeName, Class<?> loadedType) {\n            super(null);\n            this.typeName = typeName;\n            this.loadedType = loadedType;\n        }\n\n        @Override\n        public Class<?> loadClass(String name) throws ClassNotFoundException {\n            loadClassCalls++;\n            if (typeName.equals(name)) {\n                return loadedType;\n            }\n            throw new ClassNotFoundException(name);\n        }\n\n        int getLoadClassCalls() {\n            return loadClassCalls;\n        }\n    }\n\n    private static class ResourceClassLoader extends ClassLoader {\n        private final String resourceName;\n        private final URL resource;\n        private int resourceCalls;\n        private int resourcesCalls;\n\n        ResourceClassLoader(String resourceName, URL resource) {\n            super(null);\n            this.resourceName = resourceName;\n            this.resource = resource;\n        }\n\n        @Override\n        public URL getResource(String name) {\n            resourceCalls++;\n            return resourceName.equals(name)\n                    ? resource\n                    : null;\n        }\n\n        @Override\n        public Enumeration<URL> getResources(String name) {\n            resourcesCalls++;\n            Vector<URL> resources = new Vector<URL>();\n            if (resourceName.equals(name)) {\n                resources.add(resource);\n            }\n            return resources.elements();\n        }\n\n        int getResourceCalls() {\n            return resourceCalls;\n        }\n\n        int getResourcesCalls() {\n            return resourcesCalls;\n        }\n    }\n}\n\n=====\n/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage net_bytebuddy.byte_buddy;\n\nimport java.io.IOException;\nimport java.io.InputStream;\nimport java.net.URL;\nimport java.net.URLClassLoader;\nimport java.security.CodeSource;\n\nimport net.bytebuddy.ByteBuddy;\nimport net.bytebuddy.ClassFileVersion;\nimport net.bytebuddy.dynamic.DynamicType;\nimport net.bytebuddy.dynamic.NexusAccessor;\nimport net.bytebuddy.dynamic.TypeResolutionStrategy;\nimport net.bytebuddy.dynamic.loading.ClassLoadingStrategy;\nimport net.bytebuddy.implementation.LoadedTypeInitializer;\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class NexusAccessorInnerDispatcherInnerCreationActionTest {\n    private static final String NEXUS_DISABLED_PROPERTY = \"net.bytebuddy.nexus.disabled\";\n\n    @Test\n    void activeTypeResolutionCreatesNexusDispatcherAndRunsRegisteredInitializer() throws Exception {\n        String previousNexusDisabledValue = System.getProperty(NEXUS_DISABLED_PROPERTY);\n        System.setProperty(NEXUS_DISABLED_PROPERTY, Boolean.FALSE.toString());\n        try {\n            assertThat(NexusAccessor.isAlive()).isTrue();\n\n            RecordingLoadedTypeInitializer initializer = new RecordingLoadedTypeInitializer();\n            DynamicType.Loaded<?> loadedType = new ByteBuddy(ClassFileVersion.JAVA_V8)\n                    .subclass(Object.class)\n                    .name(\"net_bytebuddy.byte_buddy.generated.NexusAccessorCreationActionInitializedType\")\n                    .initializer(initializer)\n                    .make(new TypeResolutionStrategy.Active())\n                    .load(getClass().getClassLoader(), ClassLoadingStrategy.Default.WRAPPER);\n\n            loadedType.getLoaded().getDeclaredConstructor().newInstance();\n\n            assertThat(initializer.loadedType).isSameAs(loadedType.getLoaded());\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        } finally {\n            restoreNexusDisabledProperty(previousNexusDisabledValue);\n        }\n    }\n\n    @Test\n    void fallsBackToSystemLoadedNexusWhenClassFileForInjectionCannotBeRead() throws Exception {\n        String previousNexusDisabledValue = System.getProperty(NEXUS_DISABLED_PROPERTY);\n        System.setProperty(NEXUS_DISABLED_PROPERTY, Boolean.FALSE.toString());\n        try {\n            assertThat(NexusAccessor.isAlive()).isTrue();\n            try (IsolatedByteBuddyClassLoader classLoader = new IsolatedByteBuddyClassLoader()) {\n                IsolatedAction action = classLoader\n                        .loadClass(IsolatedNexusAccessorFallbackAction.class.getName())\n                        .asSubclass(IsolatedAction.class)\n                        .getConstructor()\n                        .newInstance();\n\n                action.run();\n            }\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        } finally {\n            restoreNexusDisabledProperty(previousNexusDisabledValue);\n        }\n    }\n\n    private static void restoreNexusDisabledProperty(String previousValue) {\n        if (previousValue == null) {\n            System.clearProperty(NEXUS_DISABLED_PROPERTY);\n        } else {\n            System.setProperty(NEXUS_DISABLED_PROPERTY, previousValue);\n        }\n    }\n\n    public interface IsolatedAction {\n        void run();\n    }\n\n    public static class IsolatedNexusAccessorFallbackAction implements IsolatedAction {\n        @Override\n        public void run() {\n            if (!NexusAccessor.isAlive()) {\n                throw new AssertionError(\"Nexus accessor should be alive\");\n            }\n        }\n    }\n\n    public static class RecordingLoadedTypeInitializer implements LoadedTypeInitializer {\n        private Class<?> loadedType;\n\n        @Override\n        public void onLoad(Class<?> type) {\n            loadedType = type;\n        }\n\n        @Override\n        public boolean isAlive() {\n            return true;\n        }\n    }\n\n    private static class IsolatedByteBuddyClassLoader extends URLClassLoader {\n        private static final String ISOLATED_ACTION_NAME = IsolatedNexusAccessorFallbackAction.class.getName();\n        private static final String NEXUS_CLASS_RESOURCE = \"net/bytebuddy/dynamic/Nexus.class\";\n\n        IsolatedByteBuddyClassLoader() {\n            super(new URL[]{byteBuddyLocation()},\n                    NexusAccessorInnerDispatcherInnerCreationActionTest.class.getClassLoader());\n        }\n\n        @Override\n        public InputStream getResourceAsStream(String name) {\n            return NEXUS_CLASS_RESOURCE.equals(name)\n                    ? null\n                    : super.getResourceAsStream(name);\n        }\n\n        @Override\n        protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {\n            synchronized (getClassLoadingLock(name)) {\n                Class<?> type = findLoadedClass(name);\n                if (type == null) {\n                    if (ISOLATED_ACTION_NAME.equals(name)) {\n                        type = defineIsolatedAction(name);\n                    } else if (name.startsWith(\"net.bytebuddy.\")) {\n                        try {\n                            type = findClass(name);\n                        } catch (ClassNotFoundException ignored) {\n                            type = super.loadClass(name, false);\n                        }\n                    } else {\n                        type = super.loadClass(name, false);\n                    }\n                }\n                if (resolve) {\n                    resolveClass(type);\n                }\n                return type;\n            }\n        }\n\n        private static URL byteBuddyLocation() {\n            CodeSource codeSource = NexusAccessor.class.getProtectionDomain().getCodeSource();\n            if (codeSource == null) {\n                throw new IllegalStateException(\"Cannot locate Byte Buddy classes\");\n            }\n            return codeSource.getLocation();\n        }\n\n        private Class<?> defineIsolatedAction(String name) throws ClassNotFoundException {\n            String resourceName = name.replace('.', '/') + \".class\";\n            try (InputStream inputStream = NexusAccessorInnerDispatcherInnerCreationActionTest.class\n                    .getClassLoader()\n                    .getResourceAsStream(resourceName)) {\n                if (inputStream == null) {\n                    throw new ClassNotFoundException(name);\n                }\n                byte[] binaryRepresentation = inputStream.readAllBytes();\n                return defineClass(name, binaryRepresentation, 0, binaryRepresentation.length);\n            } catch (IOException exception) {\n                throw new ClassNotFoundException(name, exception);\n            }\n        }\n    }\n}\n\n=====\n/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage net_bytebuddy.byte_buddy;\n\nimport java.io.IOException;\nimport java.io.InputStream;\nimport java.net.URL;\nimport java.net.URLClassLoader;\nimport java.nio.charset.StandardCharsets;\nimport java.security.CodeSource;\nimport java.util.Collections;\n\nimport net.bytebuddy.ByteBuddy;\nimport net.bytebuddy.utility.JavaConstant.MethodHandle;\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class JavaConstantInnerMethodHandleInnerDispatcherInnerCreationActionTest {\n    @Test\n    void runsJavaSevenCreationPathWhenLookupTypeDoesNotExposeRevealDirect() throws Exception {\n        try (IsolatedByteBuddyClassLoader classLoader = new IsolatedByteBuddyClassLoader()) {\n            IsolatedAction action = classLoader\n                    .loadClass(IsolatedMethodHandleCreationAction.class.getName())\n                    .asSubclass(IsolatedAction.class)\n                    .getConstructor()\n                    .newInstance();\n\n            action.run();\n\n            assertThat(classLoader.transformedJavaType()).isTrue();\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    public interface IsolatedAction {\n        void run();\n    }\n\n    public static class IsolatedMethodHandleCreationAction implements IsolatedAction {\n        @Override\n        public void run() {\n            String dispatcherName = MethodHandleDispatcherAccessor.runCreationAction();\n\n            assertThat(dispatcherName).doesNotContain(\"ForJava8CapableVm\");\n            assertThat(dispatcherName.contains(\"ForJava7CapableVm\") || dispatcherName.contains(\"ForLegacyVm\"))\n                    .isTrue();\n        }\n    }\n\n    public static class MethodHandleDispatcherAccessor extends MethodHandle {\n        private MethodHandleDispatcherAccessor() {\n            super(null, null, null, null, Collections.emptyList());\n        }\n\n        public static String runCreationAction() {\n            Object dispatcher = Dispatcher.CreationAction.INSTANCE.run();\n            return dispatcher.getClass().getName();\n        }\n    }\n\n    private static class IsolatedByteBuddyClassLoader extends URLClassLoader {\n        private static final String ISOLATED_ACTION_NAME = IsolatedMethodHandleCreationAction.class.getName();\n        private static final String ACCESSOR_NAME = MethodHandleDispatcherAccessor.class.getName();\n        private static final String JAVA_TYPE_NAME = \"net.bytebuddy.utility.JavaType\";\n        private static final String METHOD_HANDLES_LOOKUP = \"java.lang.invoke.MethodHandles$Lookup\";\n        private static final String FAKE_LOOKUP = \"net_bytebuddy.byte_buddy.FakeLookupXX\";\n        private boolean transformedJavaType;\n\n        IsolatedByteBuddyClassLoader() {\n            super(new URL[]{byteBuddyLocation()},\n                    JavaConstantInnerMethodHandleInnerDispatcherInnerCreationActionTest.class.getClassLoader());\n        }\n\n        boolean transformedJavaType() {\n            return transformedJavaType;\n        }\n\n        @Override\n        protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {\n            synchronized (getClassLoadingLock(name)) {\n                Class<?> type = findLoadedClass(name);\n                if (type == null) {\n                    if (ISOLATED_ACTION_NAME.equals(name) || ACCESSOR_NAME.equals(name)) {\n                        type = defineIsolatedClass(name);\n                    } else if (JAVA_TYPE_NAME.equals(name)) {\n                        type = defineTransformedJavaType(name);\n                    } else if (name.startsWith(\"net.bytebuddy.\")) {\n                        try {\n                            type = findClass(name);\n                        } catch (ClassNotFoundException ignored) {\n                            type = super.loadClass(name, false);\n                        }\n                    } else {\n                        type = super.loadClass(name, false);\n                    }\n                }\n                if (resolve) {\n                    resolveClass(type);\n                }\n                return type;\n            }\n        }\n\n        private static URL byteBuddyLocation() {\n            CodeSource codeSource = ByteBuddy.class.getProtectionDomain().getCodeSource();\n            if (codeSource == null) {\n                throw new IllegalStateException(\"Cannot locate Byte Buddy classes\");\n            }\n            return codeSource.getLocation();\n        }\n\n        private Class<?> defineIsolatedClass(String name) throws ClassNotFoundException {\n            return defineClassFromResource(name, false);\n        }\n\n        private Class<?> defineTransformedJavaType(String name) throws ClassNotFoundException {\n            return defineClassFromResource(name, true);\n        }\n\n        private Class<?> defineClassFromResource(String name,\n                                                  boolean transformMethodHandlesLookup) throws ClassNotFoundException {\n            String resourceName = name.replace('.', '/') + \".class\";\n            try (InputStream inputStream = JavaConstantInnerMethodHandleInnerDispatcherInnerCreationActionTest.class\n                    .getClassLoader()\n                    .getResourceAsStream(resourceName)) {\n                if (inputStream == null) {\n                    throw new ClassNotFoundException(name);\n                }\n                byte[] binaryRepresentation = inputStream.readAllBytes();\n                if (transformMethodHandlesLookup) {\n                    binaryRepresentation = replaceUtf8Constant(binaryRepresentation,\n                            METHOD_HANDLES_LOOKUP,\n                            FAKE_LOOKUP);\n                    transformedJavaType = true;\n                }\n                return defineClass(name, binaryRepresentation, 0, binaryRepresentation.length);\n            } catch (IOException exception) {\n                throw new ClassNotFoundException(name, exception);\n            }\n        }\n\n        private static byte[] replaceUtf8Constant(byte[] binaryRepresentation, String target, String replacement) {\n            byte[] targetBytes = target.getBytes(StandardCharsets.UTF_8);\n            byte[] replacementBytes = replacement.getBytes(StandardCharsets.UTF_8);\n            if (targetBytes.length != replacementBytes.length) {\n                throw new IllegalArgumentException(\"Replacement must keep the constant-pool UTF-8 length\");\n            }\n            byte[] transformed = binaryRepresentation.clone();\n            int replacements = 0;\n            for (int index = 0; index <= transformed.length - targetBytes.length; index++) {\n                if (matches(transformed, targetBytes, index)) {\n                    System.arraycopy(replacementBytes, 0, transformed, index, replacementBytes.length);\n                    replacements++;\n                }\n            }\n            if (replacements != 1) {\n                throw new IllegalStateException(\"Expected one UTF-8 constant replacement but found \" + replacements);\n            }\n            return transformed;\n        }\n\n        private static boolean matches(byte[] source, byte[] target, int offset) {\n            for (int index = 0; index < target.length; index++) {\n                if (source[offset + index] != target[index]) {\n                    return false;\n                }\n            }\n            return true;\n        }\n    }\n}\n\nclass FakeLookupXX {\n    public Class<?> lookupClass() {\n        return FakeLookupXX.class;\n    }\n}\n\n=====\n/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage net_bytebuddy.byte_buddy;\n\nimport java.lang.reflect.Method;\nimport java.net.URL;\nimport java.security.ProtectionDomain;\n\nimport net.bytebuddy.ByteBuddy;\nimport net.bytebuddy.ClassFileVersion;\nimport net.bytebuddy.dynamic.DynamicType;\nimport net.bytebuddy.dynamic.loading.ClassInjector;\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ClassInjectorInnerUsingReflectionInnerDispatcherInnerDirectTest {\n    @Test\n    void invokesDirectDispatcherAccessorMethods() throws Exception {\n        try {\n            invokeDirectDispatcherAccessorMethods();\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    private static void invokeDirectDispatcherAccessorMethods() throws Exception {\n        String packageName = \"net_bytebuddy.byte_buddy.direct\";\n        String typeName = packageName + \".DirectlyInjectedType\";\n        DynamicType.Unloaded<?> dynamicType = makeType(typeName);\n        DirectOperations operations = UsingReflectionAccess.makeDirectOperations();\n        TestClassLoader classLoader = new TestClassLoader();\n        ProtectionDomain protectionDomain = ClassInjector.UsingReflection.class.getProtectionDomain();\n\n        assertThat(operations.findClass(classLoader, typeName)).isNull();\n        assertThat(operations.getPackage(classLoader, packageName)).isNull();\n\n        Package definedPackage = operations.definePackage(classLoader, packageName);\n        assertThat(definedPackage).isNotNull();\n        assertThat(definedPackage.getName()).isEqualTo(packageName);\n\n        Class<?> loadedType = operations.defineClass(classLoader, typeName, dynamicType.getBytes(), protectionDomain);\n        assertThat(loadedType.getName()).isEqualTo(typeName);\n        assertThat(loadedType.getClassLoader()).isSameAs(classLoader);\n        assertThat(operations.findClass(classLoader, typeName)).isSameAs(loadedType);\n        assertThat(operations.getPackage(classLoader, packageName)).isSameAs(definedPackage);\n    }\n\n    private static DynamicType.Unloaded<?> makeType(String typeName) {\n        return new ByteBuddy(ClassFileVersion.JAVA_V8)\n                .subclass(Object.class)\n                .name(typeName)\n                .make();\n    }\n\n    private interface DirectOperations {\n        Class<?> findClass(ClassLoader classLoader, String name);\n\n        Class<?> defineClass(ClassLoader classLoader,\n                             String name,\n                             byte[] binaryRepresentation,\n                             ProtectionDomain protectionDomain);\n\n        Package getPackage(ClassLoader classLoader, String name);\n\n        Package definePackage(ClassLoader classLoader, String name);\n    }\n\n    private static class UsingReflectionAccess extends ClassInjector.UsingReflection {\n        UsingReflectionAccess() {\n            super(ClassLoader.getSystemClassLoader());\n        }\n\n        static DirectOperations makeDirectOperations() throws NoSuchMethodException {\n            Dispatcher dispatcher = new TestDirect(\n                    TestClassLoader.class.getMethod(\"findLoadedClassPublic\", String.class),\n                    TestClassLoader.class.getMethod(\"defineClassPublic\",\n                            String.class,\n                            byte[].class,\n                            int.class,\n                            int.class,\n                            ProtectionDomain.class),\n                    TestClassLoader.class.getMethod(\"getPackagePublic\", String.class),\n                    TestClassLoader.class.getMethod(\"definePackagePublic\",\n                            String.class,\n                            String.class,\n                            String.class,\n                            String.class,\n                            String.class,\n                            String.class,\n                            String.class,\n                            URL.class)).initialize();\n            return toDirectOperations(dispatcher);\n        }\n\n        private static DirectOperations toDirectOperations(final Dispatcher dispatcher) {\n            return new DirectOperations() {\n                @Override\n                public Class<?> findClass(ClassLoader classLoader, String name) {\n                    return dispatcher.findClass(classLoader, name);\n                }\n\n                @Override\n                public Class<?> defineClass(ClassLoader classLoader,\n                                            String name,\n                                            byte[] binaryRepresentation,\n                                            ProtectionDomain protectionDomain) {\n                    return dispatcher.defineClass(classLoader, name, binaryRepresentation, protectionDomain);\n                }\n\n                @Override\n                public Package getPackage(ClassLoader classLoader, String name) {\n                    return dispatcher.getPackage(classLoader, name);\n                }\n\n                @Override\n                public Package definePackage(ClassLoader classLoader, String name) {\n                    return dispatcher.definePackage(classLoader, name, null, null, null, null, null, null, null);\n                }\n            };\n        }\n\n        private static class TestDirect extends Dispatcher.Direct {\n            TestDirect(Method findLoadedClass, Method defineClass, Method getPackage, Method definePackage) {\n                super(findLoadedClass, defineClass, getPackage, definePackage);\n            }\n\n            @Override\n            public Object getClassLoadingLock(ClassLoader classLoader, String name) {\n                return classLoader;\n            }\n\n            @Override\n            protected void onInitialization() {\n                /* do nothing */\n            }\n        }\n    }\n\n    public static class TestClassLoader extends ClassLoader {\n        public TestClassLoader() {\n            super(null);\n        }\n\n        public Class<?> findLoadedClassPublic(String name) {\n            return findLoadedClass(name);\n        }\n\n        public Class<?> defineClassPublic(String name,\n                                          byte[] binaryRepresentation,\n                                          int offset,\n                                          int length,\n                                          ProtectionDomain protectionDomain) {\n            return defineClass(name, binaryRepresentation, offset, length, protectionDomain);\n        }\n\n        public Package getPackagePublic(String name) {\n            return getPackage(name);\n        }\n\n        public Package definePackagePublic(String name,\n                                           String specificationTitle,\n                                           String specificationVersion,\n                                           String specificationVendor,\n                                           String implementationTitle,\n                                           String implementationVersion,\n                                           String implementationVendor,\n                                           URL sealBase) {\n            return definePackage(name,\n                    specificationTitle,\n                    specificationVersion,\n                    specificationVendor,\n                    implementationTitle,\n                    implementationVersion,\n                    implementationVendor,\n                    sealBase);\n        }\n    }\n}\n","exit_code":0,"status":"completed"}}
