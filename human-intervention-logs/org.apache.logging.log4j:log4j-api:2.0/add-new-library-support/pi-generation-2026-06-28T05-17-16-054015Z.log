      public void put(final String key, final String value) {
          if (!useMap) {
              return;
          }
          Map<String, String> map = localMap.get();
          map = map == null ? new HashMap<String, String>() : new HashMap<String, String>(map);
          map.put(key, value);
          localMap.set(Collections.unmodifiableMap(map));
