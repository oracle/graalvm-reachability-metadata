@Override\n+        public boolean containsKey(final String key) {\n+            final Map<String, String> map = context.get();\n+            return map != null && map.containsKey(key);\n+        }\n+\n+        @Override\n+        public Map<String, String> getCopy() {\n+            return getMutableContext();\n+        }\n+\n+        @Override\n+        public Map<String, String> getImmutableMapOrNull() {\n+            return context.get();\n+        }\n+\n+        @Override\n+        public boolean isEmpty() {\n+            final Map<String, String> map = context.get();\n+            return map == null || map.isEmpty();\n+        }\n+\n+        private Map<String, String> getMutableContext() {\n+            final Map<String, String> map = context.get();\n+            return map == null ? new HashMap<String, String>() : new HashMap<String, String>(map);\n+        }\n+    }\n }\ndiff --git i/tests/src/org.apache.logging.log4j/log4j-api/2.0/src/test/resources/META-INF/log4j-provider.properties w/tests/src/org.apache.logging.log4j/log4j-api/2.0/src/test/resources/META-INF/log4j-provider.properties\nindex afff8aa27b..fdd07fe106 100644\n--- i/tests/src/org.apache.logging.log4j/log4j-api/2.0/src/test/resources/META-INF/log4j-provider.properties\n+++ w/tests/src/org.apache.logging.log4j/log4j-api/2.0/src/test/resources/META-INF/log4j-provider.properties\n@@ -1,4 +1,4 @@\n Log4jAPIVersion=2.0.0\n FactoryPriority=10\n LoggerContextFactory=org.apache.logging.log4j.simple.SimpleLoggerContextFactory\n-ThreadContextMap=org.apache.logging.log4j.spi.DefaultThreadContextMap\n+ThreadContextMap=org_apache_logging_log4j.log4j_api.ThreadContextTest$ProviderThreadContextMap\ndiff --git i/tests/src/org.apache.logging.log4j/log4j-api/2.0/src/test/resources/log4j2.component.properties w/tests/src/org.apache.logging.log4j/log4j-api/2.0/src/test/resources/log4j2.component.properties\nindex 44d382a488..bdab89cec6 100644\n--- i/tests/src/org.apache.logging.log4j/log4j-api/2.0/src/test/resourc