      public List<StatusData> getStatusData() {
          msgLock.lock();
          try {
              return new ArrayList<StatusData>(messages);
          } finally {
              msgLock.unlock();
          }
      }
  
      /**
       * Clears the list of status events.
       */
      public void clear() {
          msgLock.lock();
          try {
              messages.clear();
          } finally {
              msgLock.unlock();
          }
      }
  
      @Override
      public Level getLevel() {
          return logger.getLevel();
      }
  
