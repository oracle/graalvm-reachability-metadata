.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_apache_logging_log4j.log4j_api;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.net.URI;\n\nimport org.apache.logging.log4j.LogManager;\nimport org.apache.logging.log4j.simple.SimpleLoggerContextFactory;\nimport org.apache.logging.log4j.spi.LoggerContext;\nimport org.apache.logging.log4j.spi.LoggerContextFactory;\nimport org.junit.jupiter.api.Test;\n\npublic class LogManagerTest {\n    private static final String FACTORY_PROPERTY = \"log4j2.loggerContextFactory\";\n\n    @Test\n    void fallsBackFromConfiguredFactoryToProviderFactory() {\n        System.setProperty(FACTORY_PROPERTY, ThrowingLoggerContextFactory.class.getName());\n        try {\n            LoggerContextFactory factory = LogManager.getFactory();\n\n            assertThat(factory).isInstanceOf(SimpleLoggerContextFactory.class);\n            assertThat(LogManager.getLogger(\"example.logger\").getName()).isEqualTo(\"example.logger\");\n        } finally {\n            System.clearProperty(FACTORY_PROPERTY);\n        }\n    }\n\n    public static class ThrowingLoggerContextFactory implements LoggerContextFactory {\n        public ThrowingLoggerContextFactory() {\n            throw new IllegalStateException(\"This test factory exercises LogManager's provider fallback\");\n        }\n\n        @Override\n        public LoggerContext getContext(final String fqcn, final ClassLoader loader, final Object externalContext,\n                                        final boolean currentContext) {\n            throw new UnsupportedOperationException(\"The constructor prevents this method from being called\");\n        }\n\n        @Override\n        public LoggerContext getContext(final String fqcn, final ClassLoader loader, final Object externalContext,\n                                        final boolean currentContext, final URI configLocation, final String name) {\n            throw new UnsupportedOperationException(\"The constructor prevents this method from being called\");\n        }\n\n        @Override\n        public void removeContext(final LoggerContext context) {\n            throw new UnsupportedOperationException(\"The constructor prevents this method from being called\");\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 804, "output": 1176, "cacheRead": 31744, "cacheWrite": 0, "totalTokens": 33724, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1782623312432, "responseId": "resp_0e9c8c8ef6d3ff98016a40ac50ebd48194bf965ea6b752f2b7"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_1VXcACuAMMoECM3UXZCZiFoG|fc_0e9c8c8ef6d3ff98016a40ac593d3481949cd72f638608c5ab", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2379 bytes to tests/src/org.apache.logging.log4j/log4j-api/2.0/src/test/java/org_apache_logging_log4j/log4j_api/LogManagerTest.java"}], "isError": false, "timestamp": 1782623325000}]}
