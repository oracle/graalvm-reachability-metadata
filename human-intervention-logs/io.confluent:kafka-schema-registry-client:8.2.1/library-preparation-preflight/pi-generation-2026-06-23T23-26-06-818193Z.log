        );
      } else {
        return mockScopes;
      }
    }
  
    private static List<String> parseBaseUrl(String baseUrls) {
      List<String> urls = Arrays.asList(baseUrls.split("\\s*,\\s*"));
      if (urls.isEmpty()) {
