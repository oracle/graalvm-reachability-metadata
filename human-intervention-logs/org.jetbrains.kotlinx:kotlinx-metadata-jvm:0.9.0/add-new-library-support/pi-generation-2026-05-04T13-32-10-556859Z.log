[tool-call] delta {"path":"tests/src/org.jetbrains.kotlinx/kotlinx-metadata-jvm/0.9.0/src/test/kotlin/org_jetbrains_kotlinx/kotlinx_metadata_jvm/GeneratedMessageLiteInnerSerializedFormTest.kt","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_jetbrains_kotlinx.kotlinx_metadata_jvm\n\nimport kotlinx.metadata.internal.metadata.ProtoBuf\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\nimport java.io.ByteArrayInputStream\nimport java.io.ByteArrayOutputStream\nimport java.io.ObjectInputStream\nimport java.io.ObjectOutputStream\n\npublic class GeneratedMessageLiteInnerSerializedFormTest {\n    @Test\n    fun `java serialization restores generated protobuf message`() {\n        val message: ProtoBuf.Function = ProtoBuf.Function.newBuilder()\n            .setName(7)\n            .setFlags(123)\n            .setReturnTypeId(11)\n            .buildPartial()\n\n        val serializedMessage: ByteArray = ByteArrayOutputStream().use { bytes ->\n            ObjectOutputStream(bytes).use { stream ->\n                stream.writeObject(message)\n            }\n            bytes.toByteArray()\n        }\n\n        val restored: Any = ObjectInputStream(ByteArrayInputStream(serializedMessage)).use { stream ->\n            stream.readObject()\n        }\n\n        assertThat(restored).isInstanceOf(ProtoBuf.Function::class.java)\n        val restoredFunction: ProtoBuf.Function = restored as ProtoBuf.Function\n        assertThat(restoredFunction.hasName()).isTrue()\n        assertThat(restoredFunction.name).isEqualTo(message.name)\n        assertThat(restoredFunction.hasFlags()).isTrue()\n        assertThat(restoredFunction.flags).isEqualTo(message.flags)\n        assertThat(restoredFunction.hasReturnTypeId()).isTrue()\n        assertThat(restoredFunction.returnTypeId).isEqualTo(message.returnTypeId)\n    }\n}\n"}
