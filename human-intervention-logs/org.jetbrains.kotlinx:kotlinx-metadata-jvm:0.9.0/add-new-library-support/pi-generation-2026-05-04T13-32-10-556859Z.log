f.Function = ProtoBuf.Function.newBuilder()\n            .setName(7)\n            .setFlags(123)\n            .setReturnTypeId(11)\n            .buildPartial()\n\n        val serializedMessage: ByteArray = ByteArrayOutputStream().use { bytes ->\n            ObjectOutputStream(bytes).use { stream ->\n                stream.writeObject(message)\n            }\n            bytes.toByteArray()\n        }\n\n        val restored: Any = ObjectInputStream(ByteArrayInputStream(serializedMessage)).use { stream ->\n            stream.readObject()\n        }\n\n        assertThat(restored).isInstanceOf(ProtoBuf.Function::class.java)\n        val restoredFunction: ProtoBuf.Function = restored as ProtoBuf.Function\n        assertThat(restoredFunction.hasName()).isTrue()\n        assertThat(restoredFunction.name).isEqualTo(message.name)\n        assertThat(restoredFunction.hasFlags()).isTrue()\n        assertThat(restoredFunction.flags).isEqualTo(message.flags)\n        assertThat(restoredFunction.hasReturnTypeId()).isTrue()\n        assertThat(restoredFunction.returnTypeId).isEqualTo(message.returnTypeId)\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 770, "output": 1000, "cacheRead": 33280, "cacheWrite": 0, "totalTokens": 35050, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777901486941, "responseId": "resp_0019164be2d836f80169f89faf8a28819091b8dfcc922683aa"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_mSmYNzAzyJHQ4qQmRXvYkWyw|fc_0019164be2d836f80169f89fb998988190923076c23d2dfda5", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1791 bytes to tests/src/org.jetbrains.kotlinx/kotlinx-metadata-jvm/0.9.0/src/test/kotlin/org_jetbrains_kotlinx/kotlinx_metadata_jvm/GeneratedMessageLiteInnerSerializedFormTest.kt"}], "isError": false, "timestamp": 1777901499011}]}
