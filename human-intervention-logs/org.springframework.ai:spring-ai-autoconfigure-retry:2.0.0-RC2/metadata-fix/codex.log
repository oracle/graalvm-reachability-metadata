{"type":"item.completed","item":{"id":"item_149","type":"command_execution","command":"/usr/bin/bash -lc \"nl -ba tests/src/org.springframework.ai/spring-ai-autoconfigure-retry/2.0.0-RC2/src/test/java/org_springframework_ai/spring_ai_autoconfigure_retry/Spring_ai_autoconfigure_retryTest.java | sed -n '1,260p'\"","aggregated_output":"     1\t/*\n     2\t * Copyright and related rights waived via CC0\n     3\t *\n     4\t * You should have received a copy of the CC0 legalcode along with this\n     5\t * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n     6\t */\n     7\tpackage org_springframework_ai.spring_ai_autoconfigure_retry;\n     8\t\n     9\timport java.io.ByteArrayInputStream;\n    10\timport java.io.IOException;\n    11\timport java.io.InputStream;\n    12\timport java.net.URI;\n    13\timport java.nio.charset.StandardCharsets;\n    14\timport java.time.Duration;\n    15\timport java.util.Arrays;\n    16\timport java.util.Map;\n    17\timport java.util.concurrent.atomic.AtomicInteger;\n    18\t\n    19\timport org.junit.jupiter.api.Test;\n    20\t\n    21\timport org.springframework.ai.retry.NonTransientAiException;\n    22\timport org.springframework.ai.retry.TransientAiException;\n    23\timport org.springframework.ai.retry.autoconfigure.SpringAiRetryAutoConfiguration;\n    24\timport org.springframework.ai.retry.autoconfigure.SpringAiRetryProperties;\n    25\timport org.springframework.boot.autoconfigure.AutoConfigurations;\n    26\timport org.springframework.boot.test.context.runner.ApplicationContextRunner;\n    27\timport org.springframework.context.annotation.Bean;\n    28\timport org.springframework.context.annotation.Configuration;\n    29\timport org.springframework.core.retry.RetryException;\n    30\timport org.springframework.core.retry.RetryPolicy;\n    31\timport org.springframework.core.retry.RetryTemplate;\n    32\timport org.springframework.http.HttpHeaders;\n    33\timport org.springframework.http.HttpMethod;\n    34\timport org.springframework.http.HttpStatus;\n    35\timport org.springframework.http.HttpStatusCode;\n    36\timport org.springframework.http.client.ClientHttpResponse;\n    37\timport org.springframework.web.client.ResourceAccessException;\n    38\timport org.springframework.web.client.ResponseErrorHandler;\n    39\t\n    40\timport static org.assertj.core.api.Assertions.assertThat;\n    41\timport static org.assertj.core.api.Assertions.assertThatThrownBy;\n    42\t\n    43\tpublic class Spring_ai_autoconfigure_retryTest {\n    44\t\n    45\t    private final ApplicationContextRunner contextRunner = new ApplicationContextRunner()\n    46\t            .withConfiguration(AutoConfigurations.of(SpringAiRetryAutoConfiguration.class));\n    47\t\n    48\t    @Test\n    49\t    void autoConfigurationCreatesRetryInfrastructureWithDefaultProperties() {\n    50\t        applicationContextRunner(Map.of()).run((context) -> {\n    51\t            SpringAiRetryProperties properties = context.getBean(SpringAiRetryProperties.class);\n    52\t            RetryTemplate retryTemplate = context.getBean(RetryTemplate.class);\n    53\t            ResponseErrorHandler responseErrorHandler = context.getBean(ResponseErrorHandler.class);\n    54\t\n    55\t            assertThat(properties.getMaxAttempts()).isEqualTo(10);\n    56\t            assertThat(properties.getBackoff().getInitialInterval()).isEqualTo(Duration.ofSeconds(2));\n    57\t            assertThat(properties.getBackoff().getMultiplier()).isEqualTo(5);\n    58\t            assertThat(properties.getBackoff().getMaxInterval()).isEqualTo(Duration.ofMinutes(3));\n    59\t            assertThat(properties.isOnClientErrors()).isFalse();\n    60\t            assertThat(properties.getOnHttpCodes()).isEmpty();\n    61\t            assertThat(properties.getExcludeOnHttpCodes()).isEmpty();\n    62\t            assertThat(retryTemplate.getRetryPolicy()).isNotNull();\n    63\t            assertThat(retryTemplate.getRetryListener()).isNotNull();\n    64\t            assertThat(responseErrorHandler.hasError(response(HttpStatus.OK, \"ok\"))).isFalse();\n    65\t            assertThat(responseErrorHandler.hasError(response(HttpStatus.INTERNAL_SERVER_ERROR, \"error\"))).isTrue();\n    66\t        });\n    67\t    }\n    68\t\n    69\t    @Test\n    70\t    void propertyBindingConfiguresRetryTemplateAndResponseErrorHandler() {\n    71\t        Map<String, Object> properties = Map.of(\n    72\t                \"spring.ai.retry.max-attempts\", \"2\",\n    73\t                \"spring.ai.retry.backoff.initial-interval\", \"1ms\",\n    74\t                \"spring.ai.retry.backoff.multiplier\", \"1\",\n    75\t                \"spring.ai.retry.backoff.max-interval\", \"1ms\",\n    76\t                \"spring.ai.retry.on-client-errors\", \"true\",\n    77\t                \"spring.ai.retry.on-http-codes\", \"429,418\",\n    78\t                \"spring.ai.retry.exclude-on-http-codes\", \"503\");\n    79\t\n    80\t        applicationContextRunner(properties).run((context) -> {\n    81\t            SpringAiRetryProperties boundProperties = context.getBean(SpringAiRetryProperties.class);\n    82\t            RetryTemplate retryTemplate = context.getBean(RetryTemplate.class);\n    83\t            ResponseErrorHandler responseErrorHandler = context.getBean(ResponseErrorHandler.class);\n    84\t\n    85\t            assertThat(boundProperties.getMaxAttempts()).isEqualTo(2);\n    86\t            assertThat(boundProperties.getBackoff().getInitialInterval()).isEqualTo(Duration.ofMillis(1));\n    87\t            assertThat(boundProperties.getBackoff().getMultiplier()).isEqualTo(1);\n    88\t            assertThat(boundProperties.getBackoff().getMaxInterval()).isEqualTo(Duration.ofMillis(1));\n    89\t            assertThat(boundProperties.isOnClientErrors()).isTrue();\n    90\t            assertThat(boundProperties.getOnHttpCodes()).containsExactly(429, 418);\n    91\t            assertThat(boundProperties.getExcludeOnHttpCodes()).containsExactly(503);\n    92\t\n    93\t            AtomicInteger transientAttempts = new AtomicInteger();\n    94\t            String result = retryTemplate.execute(() -> {\n    95\t                if (transientAttempts.incrementAndGet() == 1) {\n    96\t                    throw new TransientAiException(\"retry this failure\");\n    97\t                }\n    98\t                return \"recovered\";\n    99\t            });\n   100\t            assertThat(result).isEqualTo(\"recovered\");\n   101\t            assertThat(transientAttempts.get()).isEqualTo(2);\n   102\t\n   103\t            AtomicInteger nonTransientAttempts = new AtomicInteger();\n   104\t            assertThatThrownBy(() -> retryTemplate.execute(() -> {\n   105\t                nonTransientAttempts.incrementAndGet();\n   106\t                throw new NonTransientAiException(\"do not retry this failure\");\n   107\t            })).isInstanceOf(RetryException.class);\n   108\t            assertThat(nonTransientAttempts.get()).isEqualTo(1);\n   109\t\n   110\t            assertThatThrownBy(() -> handle(responseErrorHandler, HttpStatus.TOO_MANY_REQUESTS, \"rate limited\"))\n   111\t                    .isInstanceOf(TransientAiException.class)\n   112\t                    .hasMessageContaining(\"HTTP 429\")\n   113\t                    .hasMessageContaining(\"rate limited\");\n   114\t            assertThatThrownBy(() -> handle(responseErrorHandler, HttpStatus.SERVICE_UNAVAILABLE, \"maintenance\"))\n   115\t                    .isInstanceOf(NonTransientAiException.class)\n   116\t                    .hasMessageContaining(\"HTTP 503\")\n   117\t                    .hasMessageContaining(\"maintenance\");\n   118\t            assertThatThrownBy(() -> handle(responseErrorHandler, HttpStatus.NOT_FOUND, \"missing\"))\n   119\t                    .isInstanceOf(TransientAiException.class)\n   120\t                    .hasMessageContaining(\"HTTP 404\")\n   121\t                    .hasMessageContaining(\"missing\");\n   122\t        });\n   123\t    }\n   124\t\n   125\t    @Test\n   126\t    void retryTemplateRetriesResourceAccessExceptions() {\n   127\t        Map<String, Object> properties = Map.of(\n   128\t                \"spring.ai.retry.max-attempts\", \"2\",\n   129\t                \"spring.ai.retry.backoff.initial-interval\", \"1ms\",\n   130\t                \"spring.ai.retry.backoff.multiplier\", \"1\",\n   131\t                \"spring.ai.retry.backoff.max-interval\", \"1ms\");\n   132\t\n   133\t        applicationContextRunner(properties).run((context) -> {\n   134\t            RetryTemplate retryTemplate = context.getBean(RetryTemplate.class);\n   135\t            AtomicInteger attempts = new AtomicInteger();\n   136\t\n   137\t            String result = retryTemplate.execute(() -> {\n   138\t                if (attempts.incrementAndGet() == 1) {\n   139\t                    throw new ResourceAccessException(\"temporary connection failure\");\n   140\t                }\n   141\t                return \"connected\";\n   142\t            });\n   143\t\n   144\t            assertThat(result).isEqualTo(\"connected\");\n   145\t            assertThat(attempts.get()).isEqualTo(2);\n   146\t        });\n   147\t    }\n   148\t\n   149\t    @Test\n   150\t    void configuredHttpCodesAreRetryableWhenGeneralClientErrorRetriesAreDisabled() {\n   151\t        Map<String, Object> properties = Map.of(\"spring.ai.retry.on-http-codes\", \"409\");\n   152\t\n   153\t        applicationContextRunner(properties).run((context) -> {\n   154\t            SpringAiRetryProperties boundProperties = context.getBean(SpringAiRetryProperties.class);\n   155\t            ResponseErrorHandler responseErrorHandler = context.getBean(ResponseErrorHandler.class);\n   156\t\n   157\t            assertThat(boundProperties.isOnClientErrors()).isFalse();\n   158\t            assertThat(boundProperties.getOnHttpCodes()).containsExactly(409);\n   159\t            assertThatThrownBy(() -> handle(responseErrorHandler, HttpStatus.CONFLICT, \"\"))\n   160\t                    .isInstanceOf(TransientAiException.class)\n   161\t                    .hasMessageContaining(\"HTTP 409\")\n   162\t                    .hasMessageContaining(\"No response body available\");\n   163\t        });\n   164\t    }\n   165\t\n   166\t    @Test\n   167\t    void defaultResponseErrorHandlerDoesNotRetryClientErrorsUnlessConfigured() {\n   168\t        applicationContextRunner(Map.of()).run((context) -> {\n   169\t            ResponseErrorHandler responseErrorHandler = context.getBean(ResponseErrorHandler.class);\n   170\t\n   171\t            assertThatThrownBy(() -> handle(responseErrorHandler, HttpStatus.BAD_REQUEST, \"invalid request\"))\n   172\t                    .isInstanceOf(NonTransientAiException.class)\n   173\t                    .hasMessageContaining(\"HTTP 400\")\n   174\t                    .hasMessageContaining(\"invalid request\");\n   175\t            assertThatThrownBy(() -> handle(responseErrorHandler, HttpStatus.BAD_GATEWAY, \"upstream failed\"))\n   176\t                    .isInstanceOf(TransientAiException.class)\n   177\t                    .hasMessageContaining(\"HTTP 502\")\n   178\t                    .hasMessageContaining(\"upstream failed\");\n   179\t        });\n   180\t    }\n   181\t\n   182\t    @Test\n   183\t    void autoConfigurationBacksOffWhenApplicationProvidesRetryBeans() {\n   184\t        applicationContextRunner(Map.of(), CustomRetryConfiguration.class).run((context) -> {\n   185\t            RetryTemplate retryTemplate = context.getBean(RetryTemplate.class);\n   186\t            ResponseErrorHandler responseErrorHandler = context.getBean(ResponseErrorHandler.class);\n   187\t\n   188\t            assertThat(retryTemplate).isSameAs(context.getBean(\"customRetryTemplate\"));\n   189\t            assertThat(responseErrorHandler).isSameAs(context.getBean(\"customResponseErrorHandler\"));\n   190\t            assertThat(responseErrorHandler.hasError(response(HttpStatus.INTERNAL_SERVER_ERROR, \"ignored\"))).isFalse();\n   191\t        });\n   192\t    }\n   193\t\n   194\t    private ApplicationContextRunner applicationContextRunner(Map<String, Object> properties,\n   195\t            Class<?>... extraSources) {\n   196\t        ApplicationContextRunner runner = this.contextRunner.withPropertyValues(toPropertyValues(properties));\n   197\t        if (extraSources.length == 0) {\n   198\t            return runner;\n   199\t        }\n   200\t        return runner.withUserConfiguration(extraSources);\n   201\t    }\n   202\t\n   203\t    private static String[] toPropertyValues(Map<String, Object> properties) {\n   204\t        return properties.entrySet().stream()\n   205\t                .map((entry) -> entry.getKey() + \"=\" + entry.getValue())\n   206\t                .sorted()\n   207\t                .toArray(String[]::new);\n   208\t    }\n   209\t\n   210\t    private static void handle(ResponseErrorHandler responseErrorHandler, HttpStatus status, String body)\n   211\t            throws IOException {\n   212\t        ClientHttpResponse response = response(status, body);\n   213\t        responseErrorHandler.handleError(URI.create(\"https://example.test/retry\"), HttpMethod.GET, response);\n   214\t    }\n   215\t\n   216\t    private static ClientHttpResponse response(HttpStatusCode status, String body) {\n   217\t        return new StaticClientHttpResponse(status, body);\n   218\t    }\n   219\t\n   220\t    @Configuration(proxyBeanMethods = false)\n   221\t    static class CustomRetryConfiguration {\n   222\t\n   223\t        @Bean\n   224\t        RetryTemplate customRetryTemplate() {\n   225\t            return new RetryTemplate(RetryPolicy.withMaxRetries(0));\n   226\t        }\n   227\t\n   228\t        @Bean\n   229\t        ResponseErrorHandler customResponseErrorHandler() {\n   230\t            return response -> false;\n   231\t        }\n   232\t    }\n   233\t\n   234\t    private static final class StaticClientHttpResponse implements ClientHttpResponse {\n   235\t\n   236\t        private final HttpStatusCode status;\n   237\t\n   238\t        private final byte[] body;\n   239\t\n   240\t        private StaticClientHttpResponse(HttpStatusCode status, String body) {\n   241\t            this.status = status;\n   242\t            this.body = body.getBytes(StandardCharsets.UTF_8);\n   243\t        }\n   244\t\n   245\t        @Override\n   246\t        public HttpStatusCode getStatusCode() {\n   247\t            return this.status;\n   248\t        }\n   249\t\n   250\t        @Override\n   251\t        public String getStatusText() {\n   252\t            return this.status.toString();\n   253\t        }\n   254\t\n   255\t        @Override\n   256\t        public HttpHeaders getHeaders() {\n   257\t            return new HttpHeaders();\n   258\t        }\n   259\t\n   260\t        @Override\n","exit_code":0,"status":"completed"}}
