sing_3/index.json:8:    \"documentation-url\" : \"https://repo.maven.apache.org/maven2/org/apache/pekko/pekko-parsing_3/$version$/pekko-parsing_3-$version$-javadoc.jar\",\nmetadata/org.apache.pekko/pekko-parsing_3/index.json:9:    \"description\" : \"Apache Pekko Parsing is a Scala-specific internal support module for Pekko HTTP that provides compile-time logging guards and cross-Scala-version compatibility annotations used by the HTTP parsing implementation. It is published as a JVM JAR for each Scala binary version, including Scala 3, so downstream Pekko HTTP modules can share those internal helpers without duplicating them.\",\nmetadata/org.apache.pekko/pekko-parsing_3/index.json:18:      \"org.apache.pekko.http.ccompat\",\nmetadata/org.apache.pekko/pekko-parsing_3/index.json:19:      \"org.apache.pekko.macros\"\nmetadata/org.apache.pekko/pekko-protobuf-v3_2.13/index.json:5:    \"source-code-url\" : \"https://repo.maven.apache.org/maven2/org/apache/pekko/pekko-protobuf-v3_2.13/$version$/pekko-protobuf-v3_2.13-$version$-sources.jar\",\nmetadata/org.apache.pekko/pekko-protobuf-v3_2.13/index.json:6:    \"repository-url\" : \"https://github.com/apache/pekko\",\nmetadata/org.apache.pekko/pekko-protobuf-v3_2.13/index.json:7:    \"test-code-url\" : \"https://github.com/apache/pekko/blob/v$version$-RC1/remote/src/test/scala/org/apache/pekko/remote/serialization/ProtobufSerializerSpec.scala\",\nmetadata/org.apache.pekko/pekko-protobuf-v3_2.13/index.json:8:    \"documentation-url\" : \"https://repo.maven.apache.org/maven2/org/apache/pekko/pekko-protobuf-v3_2.13/$version$/pekko-protobuf-v3_2.13-$version$-javadoc.jar\",\nmetadata/org.apache.pekko/pekko-protobuf-v3_2.13/index.json:9:    \"description\" : \"Apache Pekko Protobuf V3 packages a shaded Google Protocol Buffers v3 Java runtime under the org.apache.pekko.protobufv3.internal namespace for Pekko modules. It lets Pekko use protobuf serialization without exposing or conflicting with application-level protobuf dependenci