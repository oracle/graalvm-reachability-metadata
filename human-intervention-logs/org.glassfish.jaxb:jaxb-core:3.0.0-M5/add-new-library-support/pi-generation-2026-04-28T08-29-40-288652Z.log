                                  if (m != null) {
                                      return Boolean.TRUE;
                                  }
                              } catch (NoSuchMethodException ignored) {
                                  // recursively go into the base class
                              }
                              clazz = clazz.getSuperclass();
                          }
                          return Boolean.FALSE;
                      }
