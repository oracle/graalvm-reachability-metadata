          final String name = method.getName();
          final Class[] params = method.getParameterTypes();
  
          return AccessController.doPrivileged(
                  new PrivilegedAction<Boolean>() {
  
                      @Override
                      public Boolean run() {
                          Class clazz = base;
                          while (clazz != null) {
                              try {
