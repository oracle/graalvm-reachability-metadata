                  }
              }
  
              for (Type i : c.getGenericInterfaces()) {
                  r = visit(i, sup);
                  if (r != null) {
                      return r;
                  }
              }
  
              return null;
          }
  
          public Type onParameterizdType(ParameterizedType p, Class sup) {
