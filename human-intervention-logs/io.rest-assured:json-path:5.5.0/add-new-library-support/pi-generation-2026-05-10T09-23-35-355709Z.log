[tool-call] delta {"path":"tests/src/io.rest-assured/json-path/5.5.0/src/test/java/io_rest_assured/json_path/ConfigurableJsonSlurperTest.java","edits":[{"oldText":"import java.math.BigDecimal;\nimport java.math.BigInteger;\nimport java.util.List;\nimport java.util.Map;\n","newText":"import java.lang.invoke.MethodHandle;\nimport java.lang.invoke.MethodHandles;\nimport java.lang.invoke.MethodType;\nimport java.math.BigDecimal;\nimport java.math.BigInteger;\nimport java.util.List;\nimport java.util.Map;\n"},{"oldText":"import io.restassured.internal.path.json.ConfigurableJsonSlurper;\nimport io.restassured.path.json.config.JsonPathConfig.NumberReturnType;\nimport org.codehaus.groovy.runtime.InvokerHelper;\nimport org.junit.jupiter.api.Test;\n","newText":"import io.restassured.internal.path.json.ConfigurableJsonSlurper;\nimport io.restassured.path.json.config.JsonPathConfig.NumberReturnType;\nimport org.junit.jupiter.api.Test;\n"},{"oldText":"    void generatedClassNameResolverCanResolveRuntimeClasses() {\n        Object resolvedClass = InvokerHelper.invokeStaticMethod(\n                ConfigurableJsonSlurper.class,\n                \"class$\",\n                new Object[] {String.class.getName()});\n\n        assertThat(resolvedClass).isSameAs(String.class);\n    }\n","newText":"    void generatedClassNameResolverCanResolveRuntimeClasses() throws Throwable {\n        MethodHandle classResolver = MethodHandles.privateLookupIn(ConfigurableJsonSlurper.class, MethodHandles.lookup())\n                .findStatic(ConfigurableJsonSlurper.class, \"class$\", MethodType.methodType(Class.class, String.class));\n\n        Class<?> resolvedClass = (Class<?>) classResolver.invokeExact(String.class.getName());\n\n        assertThat(resolvedClass).isSameAs(String.class);\n    }\n"}]}
