          DiscriminatingConnectionFactory acceptedHttp2 = new DiscriminatingConnectionFactory(HTTP_2, true);
          TestSslSession sslSession = new TestSslSession("TLSv1.2", "TLS_ECDHE_RSA_WITH_AES_128_GCM_SHA256");
