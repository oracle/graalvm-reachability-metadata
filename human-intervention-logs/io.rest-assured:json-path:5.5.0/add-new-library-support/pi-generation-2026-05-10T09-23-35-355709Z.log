                  if (!check(socket)) {
                      continue;
                  }
                  return;
              } catch (Exception e) {
                  lastConnectionException = e;
              }
          }
          throw new IllegalStateException("nginx container cannot be accessed on %s:%d".formatted(DOCKER_HOST, hostPort), lastConnectionException);
      }
  
