          try {
              // -1 indicates the socket has been closed immediately
              // Other responses or a timeout are considered as success
              if (socket.getInputStream().read() == -1) {
                  return false;
              }
          } catch (SocketTimeoutException ex) {
              // Ignore
          }
          return true;
      }
  
