[tool-call] delta {"path":"tests/src/io.rest-assured/json-path/5.5.0/src/test/java/io_rest_assured/json_path/JSONAssertionTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_rest_assured.json_path;\n\nimport java.util.List;\nimport java.util.Map;\n\nimport io.restassured.internal.path.json.JSONAssertion;\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class JSONAssertionTest {\n    @Test\n    void evaluatesNestedJsonPathAgainstJavaObjectGraph() {\n        JSONAssertion assertion = new JSONAssertion();\n        assertion.setKey(\"store.book[0].title\");\n        Map<String, Object> document = Map.of(\n                \"store\",\n                Map.of(\n                        \"book\",\n                        List.of(\n                                Map.of(\"title\", \"Sayings of the Century\", \"price\", 8.95d),\n                                Map.of(\"title\", \"Sword of Honour\", \"price\", 12.99d))));\n\n        try {\n            Object title = assertion.getAsJsonObject(document);\n\n            assertThat(title).isEqualTo(\"Sayings of the Century\");\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n}\n"}
[tool-call] end id=call_FYZ7PH6xCFVADrlM19mXqmMq|fc_0020177e95fb5f45016a0052262a2c8197ab8d169037ea333e name=write args={"path": "tests/src/io.rest-assured/json-path/5.5.0/src/test/java/io_rest_assured/json_path/JSONAssertionTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_rest_assured.json_path;\n\nimport java.util.List;\nimport java.util.Map;\n\nimport io.restassured.internal.path.json.JSONAssertion;\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class JSONAssertionTest {\n    @Test\n    void evaluatesNestedJsonPathAgainstJavaObjectGraph() {\n        JSONAssertion assertion = new JSONAssertion();\n        assertion.setKey(\"store.book[0].title\");\n        Map<String, Object> document = Map.of(\n                \"store\",\n                Map.of(\n                        \"book\",\n                        List.of(\n                                Map.of(\"title\", \"Sayings of the Century\", \"price\", 8.95d),\n                                Map.of(\"title\", \"Sword of Honour\", \"price\", 12.99d))));\n\n        try {\n            Object title = assertion.getAsJsonObject(document);\n\n            assertThat(title).isEqualTo(\"Sayings of the Century\");\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n}\n"}
