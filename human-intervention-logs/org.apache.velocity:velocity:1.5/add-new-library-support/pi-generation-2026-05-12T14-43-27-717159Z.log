e, final int count) {\n            invocations++;\n            StringBuilder message = new StringBuilder();\n            for (int index = 0; index < count; index++) {\n                if (index > 0) {\n                    message.append(' ');\n                }\n                message.append(prefix).append(' ').append(name).append('!');\n            }\n            return message.toString();\n        }\n    }\n}\n"}
