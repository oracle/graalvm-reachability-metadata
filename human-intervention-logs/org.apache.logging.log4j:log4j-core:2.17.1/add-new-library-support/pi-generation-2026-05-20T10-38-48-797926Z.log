_apache_logging_log4j.log4j_core;\n\nimport static org.assertj.core.api.Assertions.assertThat;\nimport static org.assertj.core.api.Assertions.assertThatExceptionOfType;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.InputStream;\nimport java.net.MalformedURLException;\nimport java.net.URL;\nimport java.nio.charset.StandardCharsets;\n\nimport org.apache.logging.log4j.core.util.Loader;\nimport org.junit.jupiter.api.Test;\n\npublic class LoaderTest {\n\n    private static final String RESOURCE_NAME = \"log4j-loader-test-resource.txt\";\n    private static final String RESOURCE_CONTENT = \"loaded by default test class loader\";\n    private static final String MISSING_RESOURCE_NAME = \"log4j-loader-test-missing-resource.txt\";\n\n    @Test\n    void searchesResourcesThroughContextLog4jDefaultAndSystemClassLoaders() throws Exception {\n        final ClassLoader originalContextClassLoader = Thread.currentThread().getContextClassLoader();\n        final ClassLoader emptyContextClassLoader = new EmptyResourceClassLoader();\n        final ClassLoader defaultClassLoader = new ResourceClassLoader();\n        try {\n            Thread.currentThread().setContextClassLoader(emptyContextClassLoader);\n\n            final URL resource = Loader.getResource(RESOURCE_NAME, defaultClassLoader);\n            assertThat(resource).isNotNull();\n            assertThat(resource.toString()).endsWith(RESOURCE_NAME);\n\n            final URL missingResource = Loader.getResource(MISSING_RESOURCE_NAME, new EmptyResourceClassLoader());\n            assertThat(missingResource).isNull();\n        } finally {\n            Thread.currentThread().setContextClassLoader(originalContextClassLoader);\n        }\n    }\n\n    @Test\n    void searchesResourceStreamsThroughContextLog4jDefaultAndSystemClassLoaders() throws Exception {\n        final ClassLoader originalContextClassLoader = Thread.currentThread().getContextClassLoader();\n        final ClassLoader emptyContextClassLoader = new EmptyResourceClassLoader();\n        final ClassLoader defaultClassLoader = new ResourceClassLoader();\n        try {\n            Thread.currentThread().setContextClassLoader(emptyContextClassLoader);\n\n            try (InputStream resource = Loader.getResourceAsStream(RESOURCE_NAME, defaultClassLoader)) {\n                assertThat(resource).isNotNull();\n                assertThat(new String(resource.readAllBytes(), StandardCharsets.UTF_8)).isEqualTo(RESOURCE_CONTENT);\n            }\n\n            final InputStream missingResource = Loader.getResourceAsStream(\n                    MISSING_RESOURCE_NAME,\n                    new EmptyResourceClassLoader());\n            assertThat(missingResource).isNull();\n        } finally {\n            Thread.currentThread().setContextClassLoader(originalContextClassLoader);\n        }\n    }\n\n    @Test\n    void initializesAndLoadsClassesWithProvidedClassLoader() throws Exception {\n        System.clearProperty(InitializationTarget.class.getName());\n\n        final Class<?> initializedClass = Loader.initializeClass(\n                InitializationTarget.class.getName(),\n                LoaderTest.class.getClassLoader());\n        assertThat(initializedClass).isSameAs(InitializationTarget.class);\n        assertThat(System.getProperty(InitializationTarget.class.getName())).isEqualTo(\"initialized\");\n\n        System.clearProperty(LoadOnlyTarget.class.getName());\n        final Class<?> loadedClass = Loader.loadClass(LoadOnlyTarget.class.getName(), LoaderTest.class.getClassLoader());\n        assertThat(loadedClass).isSameAs(LoadOnlyTarget.class);\n        assertThat(System.getProperty(LoadOnlyTarget.class.getName())).isNull();\n    }\n\n    @Test\n    void loadsSystemClassesAndExercisesFallbackLookup() throws Exception {\n        assertThat(Loader.loadSystemClass(String.class.getName())).isSameAs(String.class);\n\n        assertThatExceptionOfType(ClassNotFoundException.class)\n                .isThrownBy(() -> Loader.loadSystemClass(\"not.a.RealClassForLog4jLoaderTest\"));\n    }\n\n    public static final class InitializationTarget {\n        static {\n            System.setProperty(InitializationTarget.class.getName(), \"initialized\");\n        }\n    }\n\n    public static final class LoadOnlyTarget {\n        static {\n            System.setProperty(LoadOnlyTarget.class.getName(), \"initialized\");\n        }\n    }\n\n    private static final class EmptyResourceClassLoader extends ClassLoader {\n        private EmptyResourceClassLoader() {\n            super(null);\n        }\n    }\n\n    private static final class ResourceClassLoader extends ClassLoader {\n        private ResourceClassLoader() {\n            super(null);\n        }\n\n        @Override\n        public URL getResource(final String name) {\n            if (!RESOURCE_NAME.equals(name)) {\n                return null;\n            }\n            try {\n                return new URL(\"file:/\" + RESOURCE_NAME);\n            } catch (final MalformedURLException e) {\n                throw new IllegalStateException(e);\n            }\n        }\n\n        @Override\n        public InputStream getResourceAsStream(final String name) {\n            if (!RESOURCE_NAME.equals(name)) {\n                return null;\n            }\n            return new ByteArrayInputStream(RESOURCE_CONTENT.getBytes(StandardCharsets.UTF_8));\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 5515, "output": 4086, "cacheRead": 28672, "cacheWrite": 0, "totalTokens": 38273, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1779273456241, "responseId": "resp_0a8696abd43b90fd016a0d8ef0ba588194baf647454c295242"}}
