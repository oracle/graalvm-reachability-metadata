am;\nimport java.io.ByteArrayOutputStream;\nimport java.io.DataOutputStream;\nimport java.io.IOException;\nimport java.io.InputStream;\nimport java.lang.reflect.InvocationTargetException;\nimport java.lang.reflect.Method;\nimport java.net.MalformedURLException;\nimport java.net.URL;\nimport java.nio.charset.StandardCharsets;\n\nimport org.apache.logging.log4j.core.util.Loader;\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\n", "newText": "import java.io.ByteArrayInputStream;\nimport java.io.InputStream;\nimport java.net.MalformedURLException;\nimport java.net.URL;\nimport java.nio.charset.StandardCharsets;\n\nimport org.apache.logging.log4j.core.util.Loader;\nimport org.junit.jupiter.api.Test;\n"}, {"oldText": "    @Test\n    void fallbackLoadsClassWithLog4jDefiningClassLoaderWhenSystemLoaderCannotFindIt() throws Exception {\n        try {\n            final ClassLoader isolatedClassLoader = new IsolatingLoader(LoaderTest.class.getClassLoader());\n            final Class<?> isolatedLoaderClass = Class.forName(Loader.class.getName(), true, isolatedClassLoader);\n            final Method loadSystemClass = isolatedLoaderClass.getMethod(\"loadSystemClass\", String.class);\n\n            final Class<?> loadedClass = (Class<?>) loadSystemClass.invoke(\n                    null,\n                    IsolatingLoader.FALLBACK_TARGET_NAME);\n\n            assertThat(loadedClass.getName()).isEqualTo(IsolatingLoader.FALLBACK_TARGET_NAME);\n            assertThat(loadedClass.getClassLoader()).isSameAs(isolatedClassLoader);\n        } catch (final InvocationTargetException e) {\n            rethrowUnlessUnsupportedFeatureError(e.getCause());\n        } catch (final Error e) {\n            rethrowUnlessUnsupportedFeatureError(e);\n        }\n    }\n\n    private static void rethrowUnlessUnsupportedFeatureError(final Throwable throwable) throws Exception {\n        if (throwable instanceof Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n            return;\n        }\n        if (throwable instanceof Exception exception) {\n            throw exception;\n        }\n        throw new AssertionError(throwable);\n    }\n\n", "newText": "    @Test\n    void loadSystemClassFallsBackToLog4jDefiningClassLoaderForTestClass() throws Exception {\n        final Class<?> loadedClass = Loader.loadSystemClass(FallbackTarget.class.getName());\n\n        assertThat(loadedClass).isSameAs(FallbackTarget.class);\n    }\n\n"}, {"oldText": "    public static final class LoadOnlyTarget {\n        static {\n            System.setProperty(LoadOnlyTarget.class.getName(), \"initialized\");\n        }\n    }\n\n", "newText": "    public static final class LoadOnlyTarget {\n        static {\n            System.setProperty(LoadOnlyTarget.class.getName(), \"initialized\");\n        }\n    }\n\n    public static final class FallbackTarget {\n    }\n\n"}, {"oldText": "\n    private static final class IsolatingLoader extends ClassLoader {\n        private static final String FALLBACK_TARGET_NAME =\n                \"org_apache_logging_log4j.log4j_core.DynamicLoaderFallbackTarget\";\n\n        private IsolatingLoader(final ClassLoader parent) {\n            super(parent);\n        }\n\n        @Override\n        protected Class<?> loadClass(final String name, final boolean resolve) throws ClassNotFoundException {\n            if (Loader.class.getName().equals(name) || FALLBACK_TARGET_NAME.equals(name)) {\n                Class<?> loadedClass = findLoadedClass(name);\n                if (loadedClass == null) {\n                    loadedClass = findClass(name);\n                }\n                if (resolve) {\n                    resolveClass(loadedClass);\n                }\n                return loadedClass;\n            }\n            return super.loadClass(name, resolve);\n        }\n\n        @Override\n        protected Class<?> findClass(final String name) throws ClassNotFoundException {\n            if (Loader.class.getName().equals(name)) {\n                final byte[] bytes = readClassBytes(name);\n                return defineClass(name, bytes, 0, bytes.length);\n            }\n            if (FALLBACK_TARGET_NAME.equals(name)) {\n                final byte[] bytes = minimalClassBytes(name);\n                return defineClass(name, bytes, 0, bytes.length);\n            }\n            throw new ClassNotFoundException(name);\n        }\n\n        private byte[] readClassBytes(final String className) throws ClassNotFoundException {\n            final String resourceName = className.replace('.', '/') + \".class\";\n            try (InputStream input = getParent().getResourceAsStream(resourceName)) {\n                if (input == null) {\n                    throw new ClassNotFoundException(className);\n                }\n                return input.readAllBytes();\n            } catch (final IOException e) {\n                throw new ClassNotFoundException(className, e);\n            }\n        }\n    }\n\n    private static byte[] minimalClassBytes(final String binaryName) {\n        try {\n            final ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n            final DataOutputStream output = new DataOutputStream(bytes);\n            output.writeInt(0xCAFEBABE);\n            output.writeShort(0);\n            output.writeShort(52);\n            output.writeShort(5);\n            output.writeByte(7);\n            output.writeShort(2);\n            writeUtf(output, binaryName.replace('.', '/'));\n            output.writeByte(7);\n            output.writeShort(4);\n            writeUtf(output, \"java/lang/Object\");\n            output.writeShort(0x0021);\n            output.writeShort(1);\n            output.writeShort(3);\n            output.writeShort(0);\n            output.writeShort(0);\n            output.writeShort(0);\n            output.writeShort(0);\n            return bytes.toByteArray();\n        } catch (final IOException e) {\n            throw new IllegalStateException(e);\n        }\n    }\n\n    private static void writeUtf(final DataOutputStream output, final String value) throws IOException {\n        output.writeByte(1);\n        output.writeUTF(value);\n    }\n", "newText": ""}]}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1029, "output": 2608, "cacheRead": 53248, "cacheWrite": 0, "totalTokens": 56885, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1779273791983, "responseId": "resp_0a8696abd43b90fd016a0d90408fec8194b1224a580da456a1"}}
