  import java.net.Inet4Address
  import java.net.InetAddress
  import java.net.NetworkInterface
  
  plugins {
      id "org.graalvm.internal.tck"
  }
  
  String libraryVersion = tck.testedLibraryVersion.get()
  
  configurations {
      jmdnsVersion1
  }
  
  dependencies {
      testImplementation "org.apache.logging.log4j:log4j-core:$libraryVersion"
      testImplementation 'org.jmdns:jmdns:3.5.7'
      jmdnsVersion1 'jmdns:jmdns:1.0'
      testImplementation 'org.assertj:assertj-core:3.22.0'
  }
  
  String localHostName() {
      String hostName = System.getenv('HOSTNAME')
      if (hostName != null && !hostName.isBlank()) {
          return hostName
      }
      File linuxHostName = file('/proc/sys/kernel/hostname')
      if (linuxHostName.isFile()) {
          String hostNameFromProc = linuxHostName.text.trim()
          if (!hostNameFromProc.isBlank()) {
              return hostNameFromProc
          }
      }
      return InetAddress.localHost.hostName
  }
  
  InetAddress findNonLoopbackIpv4Address() {
      Enumeration<NetworkInterface> interfaces = NetworkInterface.networkInterfaces
      while (interfaces.hasMoreElements()) {
          NetworkInterface networkInterface = interfaces.nextElement()
          if (!networkInterface.up || networkInterface.loopback) {
              continue
          }
          Enumeration<InetAddress> addresses = networkInterface.inetAddresses
          while (addresses.hasMoreElements()) {
              InetAddress address = addresses.nextElement()
              if (address instanceof Inet4Address && !address.loopbackAddress) {
                  return address
              }
          }
      }
      throw new AssertionError('Expected a non-loopback IPv4 address for legacy JmDNS')
  }
  
  tasks.withType(Test).configureEach {
      File hostsFile = layout.buildDirectory.file('tmp/log4j-core-jmdns.hosts').get().asFile
  
      inputs.files(configurations.jmdnsVersion1)
      doFirst {
          hostsFile.parentFile.mkdirs()
          hostsFile.text = """\
  127.0.0.1 localhost
  ${findNonLoopbackIpv4Address().hostAddress} ${localHostName()}
  """
      }
      systemProperty 'jdk.net.hosts.file', hostsFile.absolutePath
      systemProperty 'log4jCore.jmdnsVersion1Jar', configurations.jmdnsVersion1.singleFile.absolutePath
  }
  
  graalvmNative {
      agent {
          defaultMode = "conditional"
          modes {
              conditional {
                  userCodeFilterPath = "user-code-filter.json"
              }
          }
      }
  }
