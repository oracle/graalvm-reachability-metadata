  package org_apache_logging_log4j.log4j_core;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.IOException;
  import java.net.JarURLConnection;
  import java.net.URL;
  import java.net.URLClassLoader;
  import java.nio.file.Path;
  import java.security.CodeSource;
  import java.util.Map;
  import java.util.ServiceLoader;
  import java.util.concurrent.Callable;
  
  import javax.jmdns.ServiceInfo;
  
  import org.apache.logging.log4j.core.net.MulticastDnsAdvertiser;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  
  public class MulticastDnsAdvertiserTest {
  
      private static final String CALLABLE_SERVICE_RESOURCE = "META-INF/services/java.util.concurrent.Callable";
      private static final String VERSION1_ACTION_CLASS_NAME = Version1Action.class.getName();
      private static final String JMDNS_VERSION1_JAR_PROPERTY = "log4jCore.jmdnsVersion1Jar";
  
      @Test
      void advertisesAndUnadvertisesWithJmDnsVersion3() {
          final MulticastDnsAdvertiser advertiser = new MulticastDnsAdvertiser();
          final String serviceName = "graalvm-log4j-core-test-" + Long.toUnsignedString(System.nanoTime());
          final Map<String, String> properties = Map.of(
                  "name", serviceName,
                  "protocol", "tcp",
                  "port", "4555");
  
          final Object serviceInfo = advertiser.advertise(properties);
          try {
              assertThat(serviceInfo).isInstanceOf(ServiceInfo.class);
          } finally {
              if (serviceInfo != null) {
                  advertiser.unadvertise(serviceInfo);
              }
          }
      }
  
      @Test
      void advertisesAndUnadvertisesWithJmDnsVersion1LoadedInIsolation() throws Exception {
          try (ChildFirstClassLoader classLoader = new ChildFirstClassLoader(new URL[] {
                  codeSourceUrl(MulticastDnsAdvertiserTest.class),
                  resourceRootUrl(CALLABLE_SERVICE_RESOURCE),
                  codeSourceUrl(MulticastDnsAdvertiser.class),
                  jmdnsVersion1JarUrl()
          }, MulticastDnsAdvertiserTest.class.getClassLoader())) {
              final Thread thread = Thread.currentThread();
              final ClassLoader previousClassLoader = thread.getContextClassLoader();
              thread.setContextClassLoader(classLoader);
              try {
                  final Callable<?> action = ServiceLoader.load(Callable.class, classLoader).stream()
                          .map(ServiceLoader.Provider::get)
                          .filter(provider -> provider.getClass().getName().equals(VERSION1_ACTION_CLASS_NAME))
                          .findFirst()
                          .orElseThrow(() -> new AssertionError(
                                  "Expected an isolated JmDNS version 1 callable provider"));
  
                  assertThat(action.call()).isEqualTo(ServiceInfo.class.getName());
              } finally {
                  thread.setContextClassLoader(previousClassLoader);
              }
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
      }
  
      private static URL codeSourceUrl(final Class<?> type) {
          final CodeSource codeSource = type.getProtectionDomain().getCodeSource();
  
          assertThat(codeSource).isNotNull();
          return codeSource.getLocation();
      }
  
      private static URL resourceRootUrl(final String resourceName) throws IOException {
          final URL resourceUrl = MulticastDnsAdvertiserTest.class.getClassLoader().getResource(resourceName);
  
          assertThat(resourceUrl).isNotNull();
          if ("jar".equals(resourceUrl.getProtocol())) {
              final JarURLConnection connection = (JarURLConnection) resourceUrl.openConnection();
              return connection.getJarFileURL();
          }
          final String externalForm = resourceUrl.toExternalForm();
          assertThat(externalForm).endsWith(resourceName);
          return new URL(externalForm.substring(0, externalForm.length() - resourceName.length()));
      }
  
      private static URL jmdnsVersion1JarUrl() throws IOException {
          final String jarPath = System.getProperty(JMDNS_VERSION1_JAR_PROPERTY);
  
          assertThat(jarPath).isNotBlank();
          return Path.of(jarPath).toUri().toURL();
      }
  
      public static final class Version1Action implements Callable<String> {
          @Override
          public String call() {
              final MulticastDnsAdvertiser advertiser = new MulticastDnsAdvertiser();
              final String serviceName = "graalvm-log4j-core-version1-test-" + Long.toUnsignedString(System.nanoTime());
              final Map<String, String> properties = Map.of(
                      "name", serviceName,
                      "protocol", "tcp",
                      "port", "4555");
  
              final Object serviceInfo = advertiser.advertise(properties);
              try {
                  if (serviceInfo == null) {
                      throw new AssertionError("Expected JmDNS version 1 ServiceInfo to be created");
                  }
                  return serviceInfo.getClass().getName();
              } finally {
                  if (serviceInfo != null) {
                      advertiser.unadvertise(serviceInfo);
                  }
              }
          }
      }
  
      private static final class ChildFirstClassLoader extends URLClassLoader {
          private ChildFirstClassLoader(final URL[] urls, final ClassLoader parent) {
              super(urls, parent);
          }
  
          @Override
          protected Class<?> loadClass(final String name, final boolean resolve) throws ClassNotFoundException {
              synchronized (getClassLoadingLock(name)) {
                  Class<?> loadedClass = findLoadedClass(name);
                  if (loadedClass == null) {
                      if (isChildFirst(name)) {
                          try {
                              loadedClass = findClass(name);
                          } catch (ClassNotFoundException ignored) {
                              loadedClass = super.loadClass(name, false);
                          }
                      } else {
                          loadedClass = super.loadClass(name, false);
                      }
                  }
                  if (resolve) {
                      resolveClass(loadedClass);
                  }
                  return loadedClass;
              }
          }
  
          private boolean isChildFirst(final String className) {
              return className.equals(MulticastDnsAdvertiser.class.getName())
                      || className.equals(MulticastDnsAdvertiserTest.class.getName())
                      || className.equals(VERSION1_ACTION_CLASS_NAME)
                      || className.startsWith(VERSION1_ACTION_CLASS_NAME + "$")
                      || className.startsWith("javax.jmdns.");
          }
      }
  }
