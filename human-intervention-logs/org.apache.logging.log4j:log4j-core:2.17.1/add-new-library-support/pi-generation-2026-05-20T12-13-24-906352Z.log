  /*
   * Copyright and related rights waived via CC0
   *
   * You should have received a copy of the CC0 legalcode along with this
   * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.
   */
  import java.net.Inet4Address
  import java.net.InetAddress
  import java.net.NetworkInterface
  
  plugins {
      id "org.graalvm.internal.tck"
  }
  
  String libraryVersion = tck.testedLibraryVersion.get()
  Provider<Directory> jansiStubDirectory = layout.buildDirectory.dir('jansi-stub')
  Provider<RegularFile> jansiStubLibrary = jansiStubDirectory.map { Directory directory ->
      directory.file(System.mapLibraryName('jansi'))
  }
  
  configurations {
      jmdnsVersion1
  }
  
  dependencies {
      testImplementation "org.apache.logging.log4j:log4j-core:$libraryVersion"
      testImplementation 'javax.xml.bind:jaxb-api:2.3.1'
      testImplementation 'org.jmdns:jmdns:3.5.7'
      testImplementation 'org.fusesource.jansi:jansi:1.18'
      jmdnsVersion1 'jmdns:jmdns:1.0'
      testImplementation 'org.assertj:assertj-core:3.22.0'
  }
  
  tasks.register('compileJansiStub') {
      File javaHome = file(System.getenv('JAVA_HOME') ?: System.getProperty('java.home'))
      File includeDirectory = new File(javaHome, 'include')
      File linuxIncludeDirectory = new File(includeDirectory, 'linux')
      File sourceFile = layout.buildDirectory.file('tmp/jansi-stub/jansi_stub.c').get().asFile
      File outputFile = jansiStubLibrary.get().asFile
  
      inputs.property('source', 'jansi-kernel32-stub')
      outputs.file(outputFile)
  
      doLast {
          sourceFile.parentFile.mkdirs()
          outputFile.parentFile.mkdirs()
          sourceFile.text = '''\
  #include <jni.h>
  
  JNIEXPORT void JNICALL Java_org_fusesource_jansi_internal_Kernel32_init(JNIEnv *env, jclass clazz) {
  }
  
  JNIEXPORT jlong JNICALL Java_org_fusesource_jansi_internal_Kernel32_GetStdHandle(JNIEnv *env, jclass clazz, jint handle) {
      return (jlong) handle;
  }
  
  JNIEXPORT jint JNICALL Java_org_fusesource_jansi_internal_Kernel32_GetConsoleScreenBufferInfo(JNIEnv *env, jclass clazz, jlong console, jobject info) {
      return 1;
  }
  
  JNIEXPORT jint JNICALL Java_org_fusesource_jansi_internal_Kernel32_GetLastError(JNIEnv *env, jclass clazz) {
      return 0;
  }
  
  JNIEXPORT jint JNICALL Java_org_fusesource_jansi_internal_Kernel32_FormatMessageW(JNIEnv *env, jclass clazz, jint flags, jlong source, jint messageId, jint languageId, jbyteArray buffer, jint size, jlongArray arguments) {
      return 0;
  }
  
  JNIEXPORT void JNICALL Java_org_fusesource_jansi_internal_Kernel32_00024COORD_init(JNIEnv *env, jclass clazz) {
  }
  
  JNIEXPORT void JNICALL Java_org_fusesource_jansi_internal_Kernel32_00024SMALL_1RECT_init(JNIEnv *env, jclass clazz) {
  }
  
  JNIEXPORT void JNICALL Java_org_fusesource_jansi_internal_Kernel32_00024CONSOLE_1SCREEN_1BUFFER_1INFO_init(JNIEnv *env, jclass clazz) {
  }
  '''
          List<String> command = [
                  'gcc',
                  '-shared',
                  '-fPIC',
                  '-I', includeDirectory.absolutePath,
                  '-I', linuxIncludeDirectory.absolutePath,
                  '-o', outputFile.absolutePath,
                  sourceFile.absolutePath
          ]
          Process process = new ProcessBuilder(command)
                  .redirectErrorStream(true)
                  .start()
          String output = process.inputStream.getText('UTF-8')
          int exitCode = process.waitFor()
          if (exitCode != 0) {
              throw new GradleException("Failed to compile Jansi stub with exit code ${exitCode}:\n${output}")
          }
      }
  }
  
  String localHostName() {
      String hostName = System.getenv('HOSTNAME')
      if (hostName != null && !hostName.isBlank()) {
          return hostName
      }
      File linuxHostName = file('/proc/sys/kernel/hostname')
      if (linuxHostName.isFile()) {
          String hostNameFromProc = linuxHostName.text.trim()
          if (!hostNameFromProc.isBlank()) {
              return hostNameFromProc
          }
      }
      return InetAddress.localHost.hostName
  }
  
  InetAddress findNonLoopbackIpv4Address() {
      Enumeration<NetworkInterface> interfaces = NetworkInterface.networkInterfaces
      while (interfaces.hasMoreElements()) {
          NetworkInterface networkInterface = interfaces.nextElement()
          if (!networkInterface.up || networkInterface.loopback) {
              continue
          }
          Enumeration<InetAddress> addresses = networkInterface.inetAddresses
          while (addresses.hasMoreElements()) {
              InetAddress address = addresses.nextElement()
              if (address instanceof Inet4Address && !address.loopbackAddress) {
                  return address
              }
          }
      }
      throw new AssertionError('Expected a non-loopback IPv4 address for legacy JmDNS')
  }
  
  tasks.withType(Test).configureEach {
      File hostsFile = layout.buildDirectory.file('tmp/log4j-core-jmdns.hosts').get().asFile
  
      dependsOn tasks.named('compileJansiStub')
      systemProperty 'log4jCore.jansiStubDirectory', jansiStubDirectory.get().asFile.absolutePath
  
      jvmArgs += [
          '--add-opens=java.base/java.nio=ALL-UNNAMED',
          '--add-opens=java.base/jdk.internal.ref=ALL-UNNAMED',
          '--add-exports=java.base/jdk.internal.ref=ALL-UNNAMED'
      ]
  
      inputs.files(configurations.jmdnsVersion1)
      doFirst {
          hostsFile.parentFile.mkdirs()
          hostsFile.text = """\
  127.0.0.1 localhost
  ${findNonLoopbackIpv4Address().hostAddress} ${localHostName()}
  """
      }
      systemProperty 'jdk.net.hosts.file', hostsFile.absolutePath
      systemProperty 'log4jCore.jmdnsVersion1Jar', configurations.jmdnsVersion1.singleFile.absolutePath
  }
  
  tasks.named('nativeTest') {
      dependsOn tasks.named('compileJansiStub')
      runtimeArgs.add("-Dlog4jCore.jansiStubDirectory=${jansiStubDirectory.get().asFile.absolutePath}".toString())
  }
  
  graalvmNative {
      agent {
          defaultMode = "conditional"
          modes {
              conditional {
                  userCodeFilterPath = "user-code-filter.json"
              }
          }
      }
      binaries {
          all {
              buildArgs.addAll([
                  '--add-opens=java.base/java.nio=ALL-UNNAMED',
                  '--add-opens=java.base/jdk.internal.ref=ALL-UNNAMED',
                  '--add-exports=java.base/jdk.internal.ref=ALL-UNNAMED'
              ])
          }
      }
  }
