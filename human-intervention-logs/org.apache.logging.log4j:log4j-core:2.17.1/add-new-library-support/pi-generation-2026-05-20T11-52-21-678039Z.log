[tool-call] delta {"path":"tests/src/org.apache.logging.log4j/log4j-core/2.17.1/src/test/java/org_apache_logging_log4j/log4j_core/OptionConverterTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_apache_logging_log4j.log4j_core;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport org.apache.logging.log4j.Level;\nimport org.apache.logging.log4j.core.util.OptionConverter;\nimport org.junit.jupiter.api.Test;\n\npublic class OptionConverterTest {\n\n    @Test\n    void resolvesCustomLevelThroughConfiguredToLevelMethod() {\n        final Level level = OptionConverter.toLevel(\"DEBUG#org.apache.logging.log4j.Level\", Level.ERROR);\n\n        assertThat(level).isEqualTo(Level.DEBUG);\n    }\n\n    @Test\n    void instantiatesAssignableClassByName() {\n        final Object value = OptionConverter.instantiateByClassName(\n                StringBuilder.class.getName(),\n                CharSequence.class,\n                \"fallback\");\n\n        assertThat(value).isInstanceOf(StringBuilder.class);\n        assertThat(value).hasToString(\"\");\n    }\n}\n"}
