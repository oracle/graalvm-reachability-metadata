[tool-call] delta {"command":"python3 - <<'PY'\nimport urllib.request, os, subprocess, tempfile\nversions=['1.11','1.12','1.13','1.14','1.15','1.16','1.17','1.17.1','1.18']\nfor v in versions:\n    url=f'https://repo.maven.apache.org/maven2/org/fusesource/jansi/jansi/{v}/jansi-{v}.jar'\n    path=f'/tmp/jansi-{v}.jar'\n    try:\n        urllib.request.urlretrieve(url,path)\n    except Exception as e:\n        print(v,'download fail',e); continue\n    tf=subprocess.check_output(['jar','tf',path], text=True)\n    has='org/fusesource/jansi/WindowsAnsiOutputStream.class' in tf\n    libs=[l for l in tf.splitlines() if 'linux64' in l and l.endswith('.so')]\n    print(v,'class',has,'libs',libs[:2])\n    if libs:\n        d=tempfile.mkdtemp(); subprocess.run(['jar','xf',path,libs[0]], cwd=d)\n        out=subprocess.run(['nm','-D',os.path.join(d,libs[0])], text=True, capture_output=True).stdout\n        print(' GetStdHandle sym', 'Java_org_fusesource_jansi_internal_Kernel32_GetStdHandle' in out)\nPY","timeout":60}
