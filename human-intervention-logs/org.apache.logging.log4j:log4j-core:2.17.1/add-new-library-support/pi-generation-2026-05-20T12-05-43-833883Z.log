[recv] {"type": "message_start", "message": {"role": "toolResult", "toolCallId": "call_2xmcCvKYblbqTcyEcvPLdaD1|fc_0bf8d8b01c02a1f1016a0da36d112481978856714b65606069", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_apache_logging_log4j.log4j_core;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.util.concurrent.TimeUnit;\n\nimport org.apache.logging.log4j.core.appender.ConsoleAppender;\nimport org.apache.logging.log4j.core.layout.PatternLayout;\nimport org.apache.logging.log4j.util.BiConsumer;\nimport org.apache.logging.log4j.util.PropertiesUtil;\nimport org.apache.logging.log4j.util.PropertySource;\nimport org.junit.jupiter.api.Test;\nimport org.junit.jupiter.api.parallel.ResourceLock;\n\npublic class ConsoleAppenderTest {\n\n    private static final String FORCE_WINDOWS_PROPERTY = ConsoleAppenderTest.class.getName() + \".forceWindows\";\n    private static final String SKIP_JANSI_PROPERTY = \"log4j.skipJansi\";\n\n    @Test\n    @ResourceLock(\"log4j-properties\")\n    void buildsConsoleAppenderThroughJansiLookupWhenWindowsAnsiIsEnabled() {\n        final String originalForceWindows = System.getProperty(FORCE_WINDOWS_PROPERTY);\n        final String originalSkipJansi = System.getProperty(SKIP_JANSI_PROPERTY);\n        try {\n            System.setProperty(FORCE_WINDOWS_PROPERTY, Boolean.TRUE.toString());\n            System.setProperty(SKIP_JANSI_PROPERTY, Boolean.FALSE.toString());\n            PropertiesUtil.getProperties().reload();\n\n            final ConsoleAppender.Builder<?> builder = ConsoleAppender.newBuilder();\n            builder.setName(\"console-jansi-lookup\");\n            builder.setTarget(ConsoleAppender.Target.SYSTEM_OUT);\n            builder.setFollow(false);\n            builder.setDirect(false);\n            builder.setLayout(PatternLayout.createDefaultLayout());\n\n            try {\n                final ConsoleAppender appender = builder.build();\n\n                assertThat(appender).isNotNull();\n                assertThat(appender.stop(1, TimeUnit.SECONDS)).isTrue();\n            } catch (final ExceptionInInitializerError error) {\n                assertExpectedJansiPlatformError(error);\n            } catch (final UnsatisfiedLinkError error) {\n                assertExpectedJansiPlatformError(error);\n            }\n        } finally {\n            restoreProperty(FORCE_WINDOWS_PROPERTY, originalForceWindows);\n            restoreProperty(SKIP_JANSI_PROPERTY, originalSkipJansi);\n            PropertiesUtil.getProperties().reload();\n        }\n    }\n\n    private static void assertExpectedJansiPlatformError(final Error error) {\n        assertThat(error).hasStackTraceContaining(\"org.fusesource.jansi\");\n    }\n\n    private static void restoreProperty(final String name, final String originalValue) {\n        if (originalValue == null) {\n            System.clearProperty(name);\n        } else {\n            System.setProperty(name, originalValue);\n        }\n    }\n\n    public static final class WindowsOverridePropertySource implements PropertySource {\n\n        private static final String OS_NAME_PROPERTY = \"os.name\";\n        private static final String WINDOWS_OS_NAME = \"Windows 10\";\n\n        @Override\n        public int getPriority() {\n            return 300;\n        }\n\n        @Override\n        public void forEach(final BiConsumer<String, String> action) {\n            if (Boolean.getBoolean(FORCE_WINDOWS_PROPERTY)) {\n                action.accept(OS_NAME_PROPERTY, WINDOWS_OS_NAME);\n            }\n        }\n\n        @Override\n        public CharSequence getNormalForm(final Iterable<? extends CharSequence> tokens) {\n            return Util.joinAsCamelCase(tokens);\n        }\n    }\n}\n"}], "isError": false, "ti