  package org_apache_logging_log4j.log4j_core;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.util.Collections;
  
  import org.apache.logging.log4j.core.impl.ContextDataFactory;
  import org.apache.logging.log4j.util.SortedArrayStringMap;
  import org.apache.logging.log4j.util.StringMap;
  import org.junit.jupiter.api.Test;
  
  public class ContextDataFactoryTest {
      static {
          System.setProperty("log4j2.ContextData", CustomContextDataMap.class.getName());
      }
  
      @Test
      void createsConfiguredContextDataMapWithDefaultAndInitialCapacityConstructors() {
          CustomContextDataMap.resetCounters();
  
          final StringMap defaultContextData = ContextDataFactory.createContextData();
          defaultContextData.putValue("default", "value");
  
          final StringMap initialCapacityContextData = ContextDataFactory.createContextData(4);
          initialCapacityContextData.putValue("capacity", "value");
  
          final StringMap copiedContextData = ContextDataFactory.createContextData(Collections.singletonMap("copy", "value"));
  
          assertThat(defaultContextData).isInstanceOf(CustomContextDataMap.class);
          assertThat(initialCapacityContextData).isInstanceOf(CustomContextDataMap.class);
          assertThat(copiedContextData).isInstanceOf(CustomContextDataMap.class);
          assertThat(defaultContextData.getValue("default")).isEqualTo("value");
          assertThat(initialCapacityContextData.getValue("capacity")).isEqualTo("value");
          assertThat(copiedContextData.getValue("copy")).isEqualTo("value");
          assertThat(CustomContextDataMap.defaultConstructorCalls).isEqualTo(1);
          assertThat(CustomContextDataMap.initialCapacityConstructorCalls).isGreaterThanOrEqualTo(2);
      }
  
      public static final class CustomContextDataMap extends SortedArrayStringMap {
          private static int defaultConstructorCalls;
          private static int initialCapacityConstructorCalls;
  
          public CustomContextDataMap() {
              defaultConstructorCalls++;
          }
  
          public CustomContextDataMap(final int initialCapacity) {
              super(initialCapacity);
              initialCapacityConstructorCalls++;
          }
  
          private static void resetCounters() {
              defaultConstructorCalls = 0;
              initialCapacityConstructorCalls = 0;
          }
      }
  }
