  /*
   * Copyright and related rights waived via CC0
   *
   * You should have received a copy of the CC0 legalcode along with this
   * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.
   */
  package org_apache_logging_log4j.log4j_core;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.util.ArrayList;
  import java.util.LinkedHashMap;
  import java.util.List;
  
  import org.apache.logging.log4j.core.tools.picocli.CommandLine;
  import org.apache.logging.log4j.core.tools.picocli.CommandLine.Command;
  import org.apache.logging.log4j.core.tools.picocli.CommandLine.Option;
  import org.junit.jupiter.api.Test;
  
  public class CommandLineInnerInterpreterTest {
  
      @Test
      void parsesSubcommandsAndPopulatesScalarArrayCollectionAndMapFields() {
          ChildCommand.reset();
          final RootCommand rootCommand = new RootCommand();
          final CommandLine commandLine = new CommandLine(rootCommand);
  
          final List<CommandLine> parsedCommands = commandLine.parse(
                  "-v",
                  "--name", "updated",
                  "--numbers", "2,3",
                  "--words", "red,blue",
                  "--entry", "one=1",
                  "--entry", "two=2",
                  "child", "--value", "7");
  
          assertThat(parsedCommands).hasSize(2);
          assertThat(rootCommand.verbose).isTrue();
          assertThat(rootCommand.name).isEqualTo("updated");
          assertThat(rootCommand.numbers).containsExactly(1, 2, 3);
          assertThat(rootCommand.words).containsExactly("red", "blue");
          assertThat(rootCommand.words).isInstanceOf(StringList.class);
          assertThat(rootCommand.entries).containsEntry("one", 1).containsEntry("two", 2);
          assertThat(rootCommand.entries).isInstanceOf(StringIntegerMap.class);
          assertThat(ChildCommand.constructedCount).isOne();
          assertThat(ChildCommand.lastInstance.value).isEqualTo(7);
      }
  
      @Command(name = "root", subcommands = ChildCommand.class)
      private static final class RootCommand {
          @Option(names = "-v")
          private boolean verbose;
  
          @Option(names = "--name")
          private String name = "initial";
  
          @Option(names = "--numbers", arity = "1..*", split = ",")
          private Integer[] numbers = {1};
  
          @Option(names = "--words", arity = "1..*", split = ",", type = String.class)
          private StringList words;
  
          @Option(names = "--entry", arity = "1..*", type = {String.class, Integer.class})
          private StringIntegerMap entries;
      }
  
      @Command(name = "child")
      private static final class ChildCommand {
          private static int constructedCount;
          private static ChildCommand lastInstance;
  
          @Option(names = "--value")
          private int value;
  
          private ChildCommand() {
              constructedCount++;
              lastInstance = this;
          }
  
          private static void reset() {
              constructedCount = 0;
              lastInstance = null;
          }
      }
  
      public static final class StringList extends ArrayList<String> {
      }
  
      public static final class StringIntegerMap extends LinkedHashMap<String, Integer> {
      }
  }
