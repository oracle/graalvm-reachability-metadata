  package org_apache_logging_log4j.log4j_core;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import org.apache.logging.log4j.core.config.Node;
  import org.apache.logging.log4j.core.config.NullConfiguration;
  import org.apache.logging.log4j.core.config.plugins.Plugin;
  import org.apache.logging.log4j.core.config.plugins.PluginAttribute;
  import org.apache.logging.log4j.core.config.plugins.PluginBuilderFactory;
  import org.apache.logging.log4j.core.config.plugins.PluginFactory;
  import org.apache.logging.log4j.core.config.plugins.processor.PluginEntry;
  import org.apache.logging.log4j.core.config.plugins.util.PluginBuilder;
  import org.apache.logging.log4j.core.config.plugins.util.PluginType;
  import org.apache.logging.log4j.core.util.Builder;
  import org.junit.jupiter.api.Test;
  
  public class PluginBuilderTest {
  
      @Test
      void buildsPluginThroughAnnotatedBuilderFactoryAndInjectsBuilderFields() {
          final Node node = nodeFor(BuilderBackedPlugin.class, "BuilderBackedPlugin");
          node.getAttributes().put("name", "builder-value");
  
          final Object plugin = new PluginBuilder(node.getType())
                  .withConfiguration(new NullConfiguration())
                  .withConfigurationNode(node)
                  .build();
  
          assertThat(plugin).isInstanceOf(BuilderBackedPlugin.class);
          final BuilderBackedPlugin builderBackedPlugin = (BuilderBackedPlugin) plugin;
          assertThat(builderBackedPlugin.name).isEqualTo("builder-value");
          assertThat(node.getAttributes()).isEmpty();
      }
  
      @Test
      void fallsBackToAnnotatedFactoryMethodWhenNoBuilderFactoryExists() {
          final Node node = nodeFor(FactoryBackedPlugin.class, "FactoryBackedPlugin");
          node.getAttributes().put("name", "factory-value");
  
          final Object plugin = new PluginBuilder(node.getType())
                  .withConfiguration(new NullConfiguration())
                  .withConfigurationNode(node)
                  .build();
  
          assertThat(plugin).isInstanceOf(FactoryBackedPlugin.class);
          final FactoryBackedPlugin factoryBackedPlugin = (FactoryBackedPlugin) plugin;
          assertThat(factoryBackedPlugin.name).isEqualTo("factory-value");
          assertThat(node.getAttributes()).isEmpty();
      }
  
      private static Node nodeFor(final Class<?> pluginClass, final String elementName) {
          final PluginEntry entry = new PluginEntry();
          entry.setKey(elementName.toLowerCase());
          entry.setName(elementName);
          entry.setClassName(pluginClass.getName());
          entry.setCategory(Node.CATEGORY);
          return new Node(null, elementName, new PluginType<>(entry, pluginClass, elementName));
      }
  
      @Plugin(name = "BuilderBackedPlugin", category = Node.CATEGORY)
      public static final class BuilderBackedPlugin {
          private final String name;
  
          private BuilderBackedPlugin(final String name) {
              this.name = name;
          }
  
          @PluginBuilderFactory
          public static BuilderBackedPluginBuilder newBuilder() {
              return new BuilderBackedPluginBuilder();
          }
      }
  
      public static final class BuilderBackedPluginBuilder implements Builder<BuilderBackedPlugin> {
          @PluginAttribute("name")
          private String name = "default-builder-value";
  
          @Override
          public BuilderBackedPlugin build() {
              return new BuilderBackedPlugin(name);
          }
      }
  
      @Plugin(name = "FactoryBackedPlugin", category = Node.CATEGORY)
      public static final class FactoryBackedPlugin {
          private final String name;
  
          private FactoryBackedPlugin(final String name) {
              this.name = name;
          }
  
          @PluginFactory
          public static FactoryBackedPlugin create(@PluginAttribute("name") final String name) {
              return new FactoryBackedPlugin(name);
          }
      }
  }
