 }\n        }\n    }\n    throw new AssertionError('Expected a non-loopback IPv4 address for legacy JmDNS')\n}\n\ntasks.withType(Test).configureEach {\n    File hostsFile = layout.buildDirectory.file('tmp/log4j-core-jmdns.hosts').get().asFile\n\n    jvmArgs += [\n        '--add-opens=java.base/java.nio=ALL-UNNAMED',\n        '--add-opens=java.base/jdk.internal.ref=ALL-UNNAMED',\n        '--add-exports=java.base/jdk.internal.ref=ALL-UNNAMED'\n    ]\n\n    inputs.files(configurations.jmdnsVersion1)\n    doFirst {\n        hostsFile.parentFile.mkdirs()\n        hostsFile.text = \"\"\"\\\n127.0.0.1 localhost\n${findNonLoopbackIpv4Address().hostAddress} ${localHostName()}\n\"\"\"\n    }\n    systemProperty 'jdk.net.hosts.file', hostsFile.absolutePath\n    systemProperty 'log4jCore.jmdnsVersion1Jar', configurations.jmdnsVersion1.singleFile.absolutePath\n}\n\ngraalvmNative {\n    agent {\n        defaultMode = \"conditional\"\n        modes {\n            conditional {\n                userCodeFilterPath = \"user-code-filter.json\"\n            }\n        }\n    }\n    binaries {\n        all {\n            buildArgs.addAll([\n                '--add-opens=java.base/java.nio=ALL-UNNAMED',\n                '--add-opens=java.base/jdk.internal.ref=ALL-UNNAMED',\n                '--add-exports=java.base/jdk.internal.ref=ALL-UNNAMED'\n            ])\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1779278019503}, {"role": "toolResult", "toolCallId": "call_RBLvxsPqNkFuIAHUSLArb2xf|fc_002cce0962b9a045016a0da0c34e0481929ca6f51790ebcb16", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_apache_logging_log4j.log4j_core;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport org.apache.logging.log4j.core.config.Node;\nimport org.apache.logging.log4j.core.config.NullConfiguration;\nimport org.apache.logging.log4j.core.config.plugins.Plugin;\nimport org.apache.logging.log4j.core.config.plugins.PluginAttribute;\nimport org.apache.logging.log4j.core.config.plugins.PluginBuilderFactory;\nimport org.apache.logging.log4j.core.config.plugins.PluginFactory;\nimport org.apache.logging.log4j.core.config.plugins.processor.PluginEntry;\nimport org.apache.logging.log4j.core.config.plugins.util.PluginBuilder;\nimport org.apache.logging.log4j.core.config.plugins.util.PluginType;\nimport org.apache.logging.log4j.core.util.Builder;\nimport org.junit.jupiter.api.Test;\n\npublic class PluginBuilderTest {\n\n    @Test\n    void buildsPluginThroughAnnotatedBuilderFactoryAndInjectsBuilderFields() {\n        final Node node = nodeFor(BuilderBackedPlugin.class, \"BuilderBackedPlugin\");\n        node.getAttributes().put(\"name\", \"builder-value\");\n\n        final Object plugin = new PluginBuilder(node.getType())\n                .withConfiguration(new NullConfiguration())\n                .withConfigurationNode(node)\n                .build();\n\n        assertThat(plugin).isInstanceOf(BuilderBackedPlugin.class);\n        final BuilderBackedPlugin builderBackedPlugin = (BuilderBackedPlugin) plugin;\n        assertThat(builderBackedPlugin.name).isEqualTo(\"builder-value\");\n        assertThat(node.getAttributes()).isEmpty();\n    }\n\n    @Test\n    void fallsBackToAnnotatedFactoryMethodWhenNoBuilderFactoryExists() {\n        final Node node = nodeFor(FactoryBackedPlugin.class, \"FactoryBackedPlugin\");\n        node.getAttributes().put(\"name\", \"factory-value\");\n\n        final Object plugin = new PluginBuilder(node.getType())\n                .withConfiguration(new NullConfiguration())\n                .withConfigurationNode(node)\n                .build();\n\n        assertThat(plugin).isInstanceOf(FactoryBackedPlugin.class);\n        final FactoryBackedPlugin factoryBackedPlugin = (FactoryBackedPlugin) plugin;\n        assertThat(factoryBackedPlugin.name).isEqualTo(\"factory-value\");\n        assertThat(node.getAttributes()).isEmpty();\n    }\n\n    private static Node nodeFor(final Class<?> pluginClass, final String elementName) {\n        final PluginEntry entry = new PluginEntry();\n        entry.setKey(elementName);\n        entry.setName(elementName);\n        entry.setClassName(pluginClass.getName());\n        entry.setCategory(Node.CATEGORY);\n        return new Node(null, elementName, new PluginType<>(entry, pluginClass, elementName));\n    }\n\n    @Plugin(name = \"BuilderBackedPlugin\", category = Node.CATEGORY)\n    public static final class BuilderBackedPlugin {\n        private final String name;\n\n        private BuilderBackedPlugin(final String name) {\n            this.name = name;\n        }\n\n        @PluginBuilderFactory\n        public static BuilderBackedPluginBuilder newBuilder() {\n            return new BuilderBackedPluginBuilder();\n        }\n    }\n\n    public static final class BuilderBackedPluginBuilder implements Builder<BuilderBackedPlugin> {\n        @PluginAttribute(\"name\")\n        private String name = \"default-builder-value\";\n\n        @Override\n        public BuilderBackedPlugin build() {\n            return new BuilderBackedPlugin(name);\n        }\n    }\n\n    @Plugin(name = \"FactoryBackedPlugin\", category = Node.CATEGORY)\n    public static final class FactoryBackedPlugin {\n        private final String name;\n\n        private FactoryBackedPlugin(final String name) {\n            this.name = name;\n        }\n\n        @PluginFactory\n        public static FactoryBackedPlugin create(@PluginAttribute(\"name\") final String name) {\n            return new FactoryBackedPlugin(name);\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1779278019503}, {"role": "toolResult", "toolCallId": "call_CdSpFS080lqypzCmP1uCQ9k2|fc_002cce0962b9a045016a0da0c34e0c81929079f070a6cc6328", "toolName": "read", "content": [{"type": "t