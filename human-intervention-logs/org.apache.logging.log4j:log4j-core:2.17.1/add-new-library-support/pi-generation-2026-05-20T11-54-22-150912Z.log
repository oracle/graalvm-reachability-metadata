[tool-call] delta {"path":"tests/src/org.apache.logging.log4j/log4j-core/2.17.1/src/test/java/org_apache_logging_log4j/log4j_core/ReflectionUtilTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_apache_logging_log4j.log4j_core;\n\nimport static org.assertj.core.api.Assertions.assertThat;\nimport static org.assertj.core.api.Assertions.assertThatExceptionOfType;\n\nimport java.lang.reflect.Field;\n\nimport org.apache.logging.log4j.core.util.ReflectionUtil;\nimport org.junit.jupiter.api.Test;\n\npublic class ReflectionUtilTest {\n\n    @Test\n    void readsAndWritesFieldValue() throws Exception {\n        final Field valueField = MutableBean.class.getDeclaredField(\"value\");\n        final MutableBean bean = new MutableBean(\"initial\");\n\n        assertThat(ReflectionUtil.getFieldValue(valueField, bean)).isEqualTo(\"initial\");\n\n        ReflectionUtil.setFieldValue(valueField, bean, \"updated\");\n\n        assertThat(bean.value).isEqualTo(\"updated\");\n        assertThat(ReflectionUtil.getFieldValue(valueField, bean)).isEqualTo(\"updated\");\n    }\n\n    @Test\n    void reportsMissingDefaultConstructor() {\n        assertThatExceptionOfType(IllegalStateException.class)\n                .isThrownBy(() -> ReflectionUtil.getDefaultConstructor(ConstructorOnlyBean.class))\n                .withCauseInstanceOf(NoSuchMethodException.class);\n    }\n\n    private static final class MutableBean {\n        private String value;\n\n        private MutableBean(final String value) {\n            this.value = value;\n        }\n    }\n\n    private static final class ConstructorOnlyBean {\n        private ConstructorOnlyBean(final String value) {\n            assertThat(value).isNotBlank();\n        }\n    }\n}\n"}
