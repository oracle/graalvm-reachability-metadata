rURLConnection) resourceUrl.openConnection();\n            return connection.getJarFileURL();\n        }\n        final String externalForm = resourceUrl.toExternalForm();\n        assertThat(externalForm).endsWith(resourceName);\n        return new URL(externalForm.substring(0, externalForm.length() - resourceName.length()));\n    }\n\n    private static URL jmdnsVersion1JarUrl() throws IOException {\n        final String jarPath = System.getProperty(JMDNS_VERSION1_JAR_PROPERTY);\n\n        assertThat(jarPath).isNotBlank();\n        return Path.of(jarPath).toUri().toURL();\n    }\n\n    public static final class Version1Action implements Callable<String> {\n        @Override\n        public String call() {\n            final MulticastDnsAdvertiser advertiser = new MulticastDnsAdvertiser();\n            final String serviceName = \"graalvm-log4j-core-version1-test-\" + Long.toUnsignedString(System.nanoTime());\n            final Map<String, String> properties = Map.of(\n                    \"name\", serviceName,\n                    \"protocol\", \"tcp\",\n                    \"port\", \"4555\");\n\n            final Object serviceInfo = advertiser.advertise(properties);\n            try {\n                if (serviceInfo == null) {\n                    throw new AssertionError(\"Expected JmDNS version 1 ServiceInfo to be created\");\n                }\n                return serviceInfo.getClass().getName();\n            } finally {\n                if (serviceInfo != null) {\n                    advertiser.unadvertise(serviceInfo);\n                }\n            }\n        }\n    }\n\n    private static final class ChildFirstClassLoader extends URLClassLoader {\n        private ChildFirstClassLoader(final URL[] urls, final ClassLoader parent) {\n            super(urls, parent);\n        }\n\n        @Override\n        protected Class<?> loadClass(final String name, final boolean resolve) throws ClassNotFoundException {\n            synchronized (getClassLoadingLock(name)) {\n                Class<?> loadedClass = findLoadedClass(name);\n                if (loadedClass == null) {\n                    if (isChildFirst(name)) {\n                        try {\n                            loadedClass = findClass(name);\n                        } catch (ClassNotFoundException ignored) {\n                            loadedClass = super.loadClass(name, false);\n                        }\n                    } else {\n                        loadedClass = super.loadClass(name, false);\n                    }\n                }\n                if (resolve) {\n                    resolveClass(loadedClass);\n                }\n                return loadedClass;\n            }\n        }\n\n        private boolean isChildFirst(final String className) {\n            return className.equals(MulticastDnsAdvertiser.class.getName())\n                    || className.equals(VERSION1_ACTION_CLASS_NAME)\n                    || className.startsWith(VERSION1_ACTION_CLASS_NAME + \"$\")\n                    || className.startsWith(\"javax.jmdns.\");\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 640, "output": 1545, "cacheRead": 35328, "cacheWrite": 0, "totalTokens": 37513, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1779272759573, "responseId": "resp_049dae7f6ec59baf016a0d8c38296481939316b0296bb92edf"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_x9Se6KgVpQRsz4pbwYfYmnm8|fc_049dae7f6ec59baf016a0d8c38d5e88193940909c3ddbf2fe8", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 6534 bytes to tests/src/org.apache.logging.log4j/log4j-core/2.17.1/src/test/java/org_apache_logging_log4j/log4j_core/MulticastDnsAdvertiserTest.java"}], "isError": false, "timestamp": 1779272769401}]}
