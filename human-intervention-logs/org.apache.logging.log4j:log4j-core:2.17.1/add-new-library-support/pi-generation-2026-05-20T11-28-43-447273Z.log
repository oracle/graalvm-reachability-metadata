 Path packageDirectory = createPackageDirectory();\n        final Path resource = Files.createFile(packageDirectory.resolve(\"resolver-util-resource.txt\"));\n        final ResolverUtil resolver = new ResolverUtil();\n        resolver.setClassLoader(new DirectoryBackedClassLoader(temporaryDirectory, packageDirectory));\n\n        resolver.find(new MatchingResourceTest(resource.toUri()), RESOLVER_PACKAGE);\n\n        assertThat(resolver.getResources()).containsExactly(resource.toUri());\n    }\n\n    @Test\n    void resolvesResourceAfterRemovingLeadingSlash() throws Exception {\n        final Path packageDirectory = createPackageDirectory();\n        final Path resource = Files.createFile(packageDirectory.resolve(\"resolver-util-resource.txt\"));\n        final ExposedResolverUtil resolver = new ExposedResolverUtil();\n        resolver.setClassLoader(new DirectoryBackedClassLoader(temporaryDirectory, packageDirectory));\n\n        resolver.addCandidate(new MatchingResourceTest(resource.toUri()), \"/\" + TEST_RESOURCE);\n\n        assertThat(resolver.getResources()).containsExactly(resource.toUri());\n    }\n\n    private Path createPackageDirectory() throws IOException {\n        final Path packageDirectory = temporaryDirectory.resolve(RESOLVER_PACKAGE_PATH);\n        Files.createDirectories(packageDirectory);\n        return packageDirectory;\n    }\n\n    private static final class MatchingClassTest implements ResolverUtil.Test {\n        private final Class<?> expectedClass;\n\n        private MatchingClassTest(final Class<?> expectedClass) {\n            this.expectedClass = expectedClass;\n        }\n\n        @Override\n        public boolean matches(final Class<?> type) {\n            return expectedClass.equals(type);\n        }\n\n        @Override\n        public boolean matches(final URI resource) {\n            return false;\n        }\n\n        @Override\n        public boolean doesMatchClass() {\n            return true;\n        }\n\n        @Override\n        public boolean doesMatchResource() {\n            return false;\n        }\n    }\n\n    private static final class MatchingResourceTest implements ResolverUtil.Test {\n        private final URI expectedResource;\n\n        private MatchingResourceTest(final URI expectedResource) {\n            this.expectedResource = expectedResource;\n        }\n\n        @Override\n        public boolean matches(final Class<?> type) {\n            return false;\n        }\n\n        @Override\n        public boolean matches(final URI resource) {\n            return expectedResource.equals(resource);\n        }\n\n        @Override\n        public boolean doesMatchClass() {\n            return false;\n        }\n\n        @Override\n        public boolean doesMatchResource() {\n            return true;\n        }\n    }\n\n    private static final class ExposedResolverUtil extends ResolverUtil {\n        private void addCandidate(final ResolverUtil.Test test, final String candidate) {\n            addIfMatching(test, candidate);\n        }\n    }\n\n    private static final class DirectoryBackedClassLoader extends ClassLoader {\n        private final Path resourceRoot;\n        private final Path packageDirectory;\n\n        private DirectoryBackedClassLoader(final Path resourceRoot, final Path packageDirectory) {\n            super(ResolverUtilTest.class.getClassLoader());\n            this.resourceRoot = resourceRoot;\n            this.packageDirectory = packageDirectory;\n        }\n\n        @Override\n        public Enumeration<URL> getResources(final String name) throws IOException {\n            if (!RESOLVER_PACKAGE_PATH.equals(name)) {\n                return Collections.emptyEnumeration();\n            }\n            return Collections.enumeration(List.of(packageDirectory.toUri().toURL()));\n        }\n\n        @Override\n        public URL getResource(final String name) {\n            if (name.startsWith(\"/\")) {\n                return null;\n            }\n            final Path resource = resourceRoot.resolve(name);\n            if (!Files.exists(resource)) {\n                return null;\n            }\n            try {\n                return resource.toUri().toURL();\n            } catch (final IOException e) {\n                throw new IllegalStateException(e);\n            }\n        }\n    }\n}\n"}
