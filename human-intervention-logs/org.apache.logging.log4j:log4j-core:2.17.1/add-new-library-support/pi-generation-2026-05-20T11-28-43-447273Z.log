      @Test
      void decodesBase64UsingLog4jConverter() {
          final byte[] expected = "log4j-core Base64 converter".getBytes(StandardCharsets.UTF_8);
          final String encoded = Base64.getEncoder().encodeToString(expected);
  
          final byte[] decoded = Base64Converter.parseBase64Binary(encoded);
  
          assertThat(decoded).isEqualTo(expected);
