  /*
   * Copyright and related rights waived via CC0
   *
   * You should have received a copy of the CC0 legalcode along with this
   * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.
   */
  package org_apache_logging_log4j.log4j_core;
  
  import static org.assertj.core.api.Assertions.assertThat;
  import static org.assertj.core.api.Assertions.assertThatExceptionOfType;
  
  import java.io.ByteArrayInputStream;
  import java.io.InputStream;
  import java.net.MalformedURLException;
  import java.net.URL;
  import java.nio.charset.StandardCharsets;
  
  import org.apache.logging.log4j.core.util.Loader;
  import org.junit.jupiter.api.Test;
  
  public class LoaderTest {
  
      private static final String RESOURCE_NAME = "log4j-loader-test-resource.txt";
      private static final String RESOURCE_CONTENT = "loaded by default test class loader";
      private static final String MISSING_RESOURCE_NAME = "log4j-loader-test-missing-resource.txt";
  
      @Test
      void searchesResourcesThroughContextLog4jDefaultAndSystemClassLoaders() throws Exception {
          final ClassLoader originalContextClassLoader = Thread.currentThread().getContextClassLoader();
          final ClassLoader emptyContextClassLoader = new EmptyResourceClassLoader();
          final ClassLoader defaultClassLoader = new ResourceClassLoader();
          try {
              Thread.currentThread().setContextClassLoader(emptyContextClassLoader);
  
              final URL resource = Loader.getResource(RESOURCE_NAME, defaultClassLoader);
              assertThat(resource).isNotNull();
              assertThat(resource.toString()).endsWith(RESOURCE_NAME);
  
              final URL missingResource = Loader.getResource(MISSING_RESOURCE_NAME, new EmptyResourceClassLoader());
              assertThat(missingResource).isNull();
          } finally {
              Thread.currentThread().setContextClassLoader(originalContextClassLoader);
          }
      }
  
      @Test
      void searchesResourceStreamsThroughContextLog4jDefaultAndSystemClassLoaders() throws Exception {
          final ClassLoader originalContextClassLoader = Thread.currentThread().getContextClassLoader();
          final ClassLoader emptyContextClassLoader = new EmptyResourceClassLoader();
          final ClassLoader defaultClassLoader = new ResourceClassLoader();
          try {
              Thread.currentThread().setContextClassLoader(emptyContextClassLoader);
  
              try (InputStream resource = Loader.getResourceAsStream(RESOURCE_NAME, defaultClassLoader)) {
                  assertThat(resource).isNotNull();
                  assertThat(new String(resource.readAllBytes(), StandardCharsets.UTF_8)).isEqualTo(RESOURCE_CONTENT);
              }
  
              final InputStream missingResource = Loader.getResourceAsStream(
                      MISSING_RESOURCE_NAME,
                      new EmptyResourceClassLoader());
              assertThat(missingResource).isNull();
          } finally {
              Thread.currentThread().setContextClassLoader(originalContextClassLoader);
          }
      }
  
      @Test
      void initializesAndLoadsClassesWithProvidedClassLoader() throws Exception {
          System.clearProperty(InitializationTarget.class.getName());
  
          final Class<?> initializedClass = Loader.initializeClass(
                  InitializationTarget.class.getName(),
                  LoaderTest.class.getClassLoader());
          assertThat(initializedClass).isSameAs(InitializationTarget.class);
          assertThat(System.getProperty(InitializationTarget.class.getName())).isEqualTo("initialized");
  
          System.clearProperty(LoadOnlyTarget.class.getName());
          final Class<?> loadedClass = Loader.loadClass(
                  LoadOnlyTarget.class.getName(),
                  LoaderTest.class.getClassLoader());
          assertThat(loadedClass).isSameAs(LoadOnlyTarget.class);
          assertThat(System.getProperty(LoadOnlyTarget.class.getName())).isNull();
      }
  
      @Test
      void loadsSystemClassesAndExercisesFallbackLookup() throws Exception {
          assertThat(Loader.loadSystemClass(String.class.getName())).isSameAs(String.class);
  
          assertThatExceptionOfType(ClassNotFoundException.class)
                  .isThrownBy(() -> Loader.loadSystemClass("not.a.RealClassForLog4jLoaderTest"));
      }
  
      @Test
      void loadSystemClassFallsBackToLog4jDefiningClassLoader() throws Exception {
          assertThat(Loader.loadSystemClass(Loader.class.getName())).isSameAs(Loader.class);
  
          final Class<?> loadedClass = Loader.loadSystemClass(FallbackTarget.class.getName());
          assertThat(loadedClass).isSameAs(FallbackTarget.class);
      }
  
      public static final class InitializationTarget {
          static {
              System.setProperty(InitializationTarget.class.getName(), "initialized");
          }
      }
  
      public static final class LoadOnlyTarget {
          static {
              System.setProperty(LoadOnlyTarget.class.getName(), "initialized");
          }
      }
  
      public static final class FallbackTarget {
      }
  
      private static final class EmptyResourceClassLoader extends ClassLoader {
          private EmptyResourceClassLoader() {
              super(null);
          }
      }
  
      private static final class ResourceClassLoader extends ClassLoader {
          private ResourceClassLoader() {
              super(null);
          }
  
          @Override
          public URL getResource(final String name) {
              if (!RESOURCE_NAME.equals(name)) {
                  return null;
              }
              try {
                  return new URL("file:/" + RESOURCE_NAME);
              } catch (final MalformedURLException e) {
                  throw new IllegalStateException(e);
              }
          }
  
          @Override
          public InputStream getResourceAsStream(final String name) {
              if (!RESOURCE_NAME.equals(name)) {
                  return null;
              }
              return new ByteArrayInputStream(RESOURCE_CONTENT.getBytes(StandardCharsets.UTF_8));
          }
      }
  }
