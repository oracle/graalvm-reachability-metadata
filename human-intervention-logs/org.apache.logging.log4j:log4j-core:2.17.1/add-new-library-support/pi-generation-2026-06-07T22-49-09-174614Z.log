          final ClassLoader previousContextClassLoader = Thread.currentThread().getContextClassLoader();
          try (LegacyJmDnsClassLoader classLoader = new LegacyJmDnsClassLoader(legacyJmDnsClasspath())) {
              preloadLegacyJmDnsClasses(classLoader);
              Thread.currentThread().setContextClassLoader(classLoader);
              final Class<?> advertiserClass = Class.forName(ADVERTISER_CLASS_NAME, true, classLoader);
              final Object advertiser = advertiserClass.getConstructor().newInstance();
              final Map<String, String> properties = new HashMap<>();
              properties.put("name", "log4j-core-legacy-test-" + UUID.randomUUID());
              properties.put("protocol", "tcp");
              properties.put("port", "4556");
              properties.put("description", "Log4j legacy multicast DNS advertiser integration test");
  
              final Method advertiseMethod = advertiserClass.getMethod("advertise", Map.class);
              final Object serviceInfo = invoke(advertiseMethod, advertiser, properties);
  
              try {
                  assertThat(advertiserClass.getClassLoader()).isSameAs(classLoader);
              } finally {
                  if (serviceInfo != null) {
                      invoke(advertiserClass.getMethod("unadvertise", Object.class), advertiser, serviceInfo);
                  }
                  closeLegacyJmDns(advertiserClass);
              }
          } finally {
              Thread.currentThread().setContextClassLoader(previousContextClassLoader);
          }
      }
  
      private static Object invoke(final Method method, final Object target, final Object... arguments) throws Exception {
          try {
              return method.invoke(target, arguments);
          } catch (InvocationTargetException exception) {
              final Throwable cause = exception.getCause();
              if (cause instanceof Exception) {
                  throw (Exception) cause;
              }
              if (cause instanceof Error) {
                  throw (Error) cause;
              }
              throw exception;
          }
      }
  
      private static void closeLegacyJmDns(final Class<?> advertiserClass) throws Exception {
          final Field jmDnsField = advertiserClass.getDeclaredField("jmDNS");
          jmDnsField.setAccessible(true);
          final Object jmDns = jmDnsField.get(null);
          if (jmDns != null) {
              invoke(jmDns.getClass().getMethod("close"), jmDns);
          }
      }
  
      private static URL[] legacyJmDnsClasspath() throws Exception {
          final String oldJmDnsJar = legacyJmDnsJarPath();
          final List<URL> urls = new ArrayList<>();
          urls.add(Path.of(oldJmDnsJar).toUri().toURL());
          for (String entry : System.getProperty("java.class.path", "").split(Pattern.quote(File.pathSeparator))) {
              if (!entry.isBlank() && !Path.of(entry).getFileName().toString().startsWith("jmdns-")) {
                  urls.add(Path.of(entry).toUri().toURL());
              }
          }
          return urls.toArray(URL[]::new);
      }
  
      private static void preloadLegacyJmDnsClasses(final ClassLoader classLoader) throws Exception {
          try (JarFile jarFile = new JarFile(legacyJmDnsJarPath())) {
              jarFile.stream()
                      .map(entry -> entry.getName())
                      .filter(name -> name.startsWith("javax/jmdns/") && name.endsWith(".class"))
                      .map(name -> name.substring(0, name.length() - ".class".length()).replace('/', '.'))
                      .forEach(className -> loadLegacyJmDnsClass(className, classLoader));
          }
      }
  
      private static void loadLegacyJmDnsClass(final String className, final ClassLoader classLoader) {
          try {
              Class.forName(className, false, classLoader);
          } catch (ClassNotFoundException exception) {
              throw new IllegalStateException("Unable to preload legacy JmDNS class: " + className, exception);
          }
      }
  
      private static String legacyJmDnsJarPath() {
          final String oldJmDnsJar = System.getProperty(OLD_JMDNS_JAR_PROPERTY);
          assertThat(oldJmDnsJar).isNotBlank();
          return oldJmDnsJar;
      }
  
      private static final class LegacyJmDnsClassLoader extends URLClassLoader {
  
