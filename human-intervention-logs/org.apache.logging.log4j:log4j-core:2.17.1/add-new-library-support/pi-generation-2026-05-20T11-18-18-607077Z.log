[tool-call] delta {"path":"tests/src/org.apache.logging.log4j/log4j-core/2.17.1/src/test/java/org_apache_logging_log4j/log4j_core/Base64ConverterTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_apache_logging_log4j.log4j_core;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.nio.charset.StandardCharsets;\nimport java.util.Base64;\n\nimport org.apache.logging.log4j.core.config.plugins.convert.Base64Converter;\nimport org.junit.jupiter.api.Test;\n\npublic class Base64ConverterTest {\n\n    @Test\n    void decodesBase64UsingLog4jConverter() {\n        final byte[] expected = \"log4j-core Base64 converter\".getBytes(StandardCharsets.UTF_8);\n        final String encoded = Base64.getEncoder().encodeToString(expected);\n\n        final byte[] decoded = Base64Converter.parseBase64Binary(encoded);\n\n        assertThat(decoded).isEqualTo(expected);\n    }\n}\n"}
