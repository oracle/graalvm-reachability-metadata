[tool-call] delta {"path":"tests/src/org.apache.logging.log4j/log4j-core/2.17.1/src/test/java/org_apache_logging_log4j/log4j_core/Base64ConverterTest.java","edits":[{"oldText":"import java.net.URL;\nimport java.net.URLClassLoader;\nimport java.nio.charset.StandardCharsets;\nimport java.security.CodeSource;\nimport java.util.Base64;\nimport java.util.concurrent.Callable;\n","newText":"import java.io.IOException;\nimport java.net.JarURLConnection;\nimport java.net.URL;\nimport java.net.URLClassLoader;\nimport java.nio.charset.StandardCharsets;\nimport java.security.CodeSource;\nimport java.util.Base64;\nimport java.util.ServiceLoader;\nimport java.util.concurrent.Callable;\n"},{"oldText":"    private static final String FALLBACK_ACTION_CLASS_NAME = FallbackAction.class.getName();\n    private static final String JAVA_UTIL_BASE64_CLASS_NAME = \"java.util.Base64\";\n","newText":"    private static final String CALLABLE_SERVICE_RESOURCE = \"META-INF/services/java.util.concurrent.Callable\";\n    private static final String FALLBACK_ACTION_CLASS_NAME = FallbackAction.class.getName();\n    private static final String JAVA_UTIL_BASE64_CLASS_NAME = \"java.util.Base64\";\n"},{"oldText":"        try (Base64BlockingClassLoader classLoader = new Base64BlockingClassLoader(new URL[] {\n                codeSourceUrl(Base64ConverterTest.class),\n                codeSourceUrl(Base64Converter.class),\n                codeSourceUrl(LoaderUtil.class),\n                codeSourceUrl(DatatypeConverter.class)\n        }, Base64ConverterTest.class.getClassLoader())) {\n","newText":"        try (Base64BlockingClassLoader classLoader = new Base64BlockingClassLoader(new URL[] {\n                codeSourceUrl(Base64ConverterTest.class),\n                resourceRootUrl(CALLABLE_SERVICE_RESOURCE),\n                codeSourceUrl(Base64Converter.class),\n                codeSourceUrl(LoaderUtil.class),\n                codeSourceUrl(DatatypeConverter.class)\n        }, Base64ConverterTest.class.getClassLoader())) {\n"},{"oldText":"                final Callable<?> action = classLoader.loadClass(FALLBACK_ACTION_CLASS_NAME)\n                        .asSubclass(Callable.class)\n                        .getConstructor()\n                        .newInstance();\n","newText":"                final Callable<?> action = ServiceLoader.load(Callable.class, classLoader).stream()\n                        .map(ServiceLoader.Provider::get)\n                        .filter(provider -> provider.getClass().getName().equals(FALLBACK_ACTION_CLASS_NAME))\n                        .findFirst()\n                        .orElseThrow(() -> new AssertionError(\"Expected an isolated Base64 fallback provider\"));\n"},{"oldText":"    private static URL codeSourceUrl(final Class<?> type) {\n        final CodeSource codeSource = type.getProtectionDomain().getCodeSource();\n\n        assertThat(codeSource).isNotNull();\n        return codeSource.getLocation();\n    }\n\n    public static final class FallbackAction implements Callable<byte[]> {\n","newText":"    private static URL codeSourceUrl(final Class<?> type) {\n        final CodeSource codeSource = type.getProtectionDomain().getCodeSource();\n\n        assertThat(codeSource).isNotNull();\n        return codeSource.getLocation();\n    }\n\n    private static URL resourceRootUrl(final String resourceName) throws IOException {\n        final URL resourceUrl = Base64ConverterTest.class.getClassLoader().getResource(resourceName);\n\n        assertThat(resourceUrl).isNotNull();\n        if (\"jar\".equals(resourceUrl.getProtocol())) {\n            final JarURLConnection connection = (JarURLConnection) resourceUrl.openConnection();\n            return connection.getJarFileURL();\n        }\n        final String externalForm = resourceUrl.toExternalForm();\n        assertThat(externalForm).endsWith(resourceName);\n        return new URL(externalForm.substring(0, externalForm.length() - resourceName.length()));\n    }\n\n    public static fin