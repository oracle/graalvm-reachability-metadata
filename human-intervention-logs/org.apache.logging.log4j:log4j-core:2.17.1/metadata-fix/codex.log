{"type":"item.completed","item":{"id":"item_181","type":"command_execution","command":"/usr/bin/bash -lc \"sed -n '1,200p' tests/src/org.apache.logging.log4j/log4j-core/2.17.1/src/test/java/org_apache_logging_log4j/log4j_core/ConsoleAppenderTest.java\"","aggregated_output":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_apache_logging_log4j.log4j_core;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.util.concurrent.TimeUnit;\n\nimport org.apache.logging.log4j.core.appender.ConsoleAppender;\nimport org.apache.logging.log4j.core.layout.PatternLayout;\nimport org.apache.logging.log4j.util.BiConsumer;\nimport org.apache.logging.log4j.util.PropertiesUtil;\nimport org.apache.logging.log4j.util.PropertySource;\nimport org.junit.jupiter.api.Test;\nimport org.junit.jupiter.api.parallel.ResourceLock;\n\npublic class ConsoleAppenderTest {\n\n    private static final String FORCE_WINDOWS_PROPERTY = ConsoleAppenderTest.class.getName() + \".forceWindows\";\n    private static final String JANSI_LIBRARY_PATH_PROPERTY = \"library.jansi.path\";\n    private static final String JANSI_STUB_DIRECTORY_PROPERTY = \"log4jCore.jansiStubDirectory\";\n    private static final String SKIP_JANSI_PROPERTY = \"log4j.skipJansi\";\n\n    @Test\n    @ResourceLock(\"log4j-properties\")\n    void buildsConsoleAppenderThroughJansiLookupWhenWindowsAnsiIsEnabled() {\n        final String originalForceWindows = System.getProperty(FORCE_WINDOWS_PROPERTY);\n        final String originalJansiLibraryPath = System.getProperty(JANSI_LIBRARY_PATH_PROPERTY);\n        final String originalSkipJansi = System.getProperty(SKIP_JANSI_PROPERTY);\n        final String jansiStubDirectory = System.getProperty(JANSI_STUB_DIRECTORY_PROPERTY);\n        final PatternLayout layout = PatternLayout.createDefaultLayout();\n        assertThat(jansiStubDirectory).isNotBlank();\n        try {\n            System.setProperty(FORCE_WINDOWS_PROPERTY, Boolean.TRUE.toString());\n            System.setProperty(JANSI_LIBRARY_PATH_PROPERTY, jansiStubDirectory);\n            System.setProperty(SKIP_JANSI_PROPERTY, Boolean.FALSE.toString());\n            PropertiesUtil.getProperties().reload();\n\n            final ConsoleAppender.Builder<?> builder = ConsoleAppender.newBuilder();\n            builder.setName(\"console-jansi-lookup\");\n            builder.setTarget(ConsoleAppender.Target.SYSTEM_OUT);\n            builder.setFollow(false);\n            builder.setDirect(false);\n            builder.setLayout(layout);\n\n            try {\n                final ConsoleAppender appender = builder.build();\n\n                assertThat(appender).isNotNull();\n                assertThat(appender.stop(1, TimeUnit.SECONDS)).isTrue();\n            } catch (final ExceptionInInitializerError error) {\n                assertExpectedJansiPlatformError(error);\n            } catch (final UnsatisfiedLinkError error) {\n                assertExpectedJansiPlatformError(error);\n            }\n        } finally {\n            restoreProperty(FORCE_WINDOWS_PROPERTY, originalForceWindows);\n            restoreProperty(JANSI_LIBRARY_PATH_PROPERTY, originalJansiLibraryPath);\n            restoreProperty(SKIP_JANSI_PROPERTY, originalSkipJansi);\n            PropertiesUtil.getProperties().reload();\n        }\n    }\n\n    private static void assertExpectedJansiPlatformError(final Error error) {\n        assertThat(error).hasStackTraceContaining(\"org.fusesource.jansi\");\n    }\n\n    private static void restoreProperty(final String name, final String originalValue) {\n        if (originalValue == null) {\n            System.clearProperty(name);\n        } else {\n            System.setProperty(name, originalValue);\n        }\n    }\n\n    public static final class WindowsOverridePropertySource implements PropertySource {\n\n        private static final String OS_NAME_PROPERTY = \"os.name\";\n        private static final String WINDOWS_OS_NAME = \"Windows 10\";\n\n        @Override\n        public int getPriority() {\n            return 300;\n        }\n\n        @Override\n        public void forEach(final BiConsumer<String, String> action) {\n            if (Boolean.getBoolean(FORCE_WINDOWS_PROPERTY)) {\n                action.accept(OS_NAME_PROPERTY, WINDOWS_OS_NAME);\n            }\n        }\n\n        @Override\n        public CharSequence getNormalForm(final Iterable<? extends CharSequence> tokens) {\n            return Util.joinAsCamelCase(tokens);\n        }\n    }\n}\n","exit_code":0,"status":"completed"}}
