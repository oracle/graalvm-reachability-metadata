{"type":"item.completed","item":{"id":"item_99","type":"command_execution","command":"/usr/bin/bash -lc \"sed -n '1,220p' tests/src/org.apache.logging.log4j/log4j-core/2.17.1/src/test/java/org_apache_logging_log4j/log4j_core/CommandLineInnerInterpreterTest.java\"","aggregated_output":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_apache_logging_log4j.log4j_core;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.util.ArrayList;\nimport java.util.LinkedHashMap;\nimport java.util.List;\n\nimport org.apache.logging.log4j.core.tools.picocli.CommandLine;\nimport org.apache.logging.log4j.core.tools.picocli.CommandLine.Command;\nimport org.apache.logging.log4j.core.tools.picocli.CommandLine.Option;\nimport org.junit.jupiter.api.Test;\n\npublic class CommandLineInnerInterpreterTest {\n\n    @Test\n    void parsesSubcommandsAndPopulatesScalarArrayCollectionAndMapFields() {\n        ChildCommand.reset();\n        final RootCommand rootCommand = new RootCommand();\n        final CommandLine commandLine = new CommandLine(rootCommand);\n\n        final List<CommandLine> parsedCommands = commandLine.parse(\n                \"-v\",\n                \"--name\", \"updated\",\n                \"--numbers\", \"2,3\",\n                \"--words\", \"red,blue\",\n                \"--entry\", \"one=1\",\n                \"--entry\", \"two=2\",\n                \"child\", \"--value\", \"7\");\n\n        assertThat(parsedCommands).hasSize(2);\n        assertThat(rootCommand.verbose).isTrue();\n        assertThat(rootCommand.name).isEqualTo(\"updated\");\n        assertThat(rootCommand.numbers).containsExactly(1, 2, 3);\n        assertThat(rootCommand.words).containsExactly(\"red\", \"blue\");\n        assertThat(rootCommand.words).isInstanceOf(StringList.class);\n        assertThat(rootCommand.entries).containsEntry(\"one\", 1).containsEntry(\"two\", 2);\n        assertThat(rootCommand.entries).isInstanceOf(StringIntegerMap.class);\n        assertThat(ChildCommand.constructedCount).isOne();\n        assertThat(ChildCommand.lastInstance.value).isEqualTo(7);\n    }\n\n    @Command(name = \"root\", subcommands = ChildCommand.class)\n    private static final class RootCommand {\n        @Option(names = \"-v\")\n        private boolean verbose;\n\n        @Option(names = \"--name\")\n        private String name = \"initial\";\n\n        @Option(names = \"--numbers\", arity = \"1..*\", split = \",\")\n        private Integer[] numbers = {1};\n\n        @Option(names = \"--words\", arity = \"1..*\", split = \",\", type = String.class)\n        private StringList words;\n\n        @Option(names = \"--entry\", arity = \"1..*\", type = {String.class, Integer.class})\n        private StringIntegerMap entries;\n    }\n\n    @Command(name = \"child\")\n    private static final class ChildCommand {\n        private static int constructedCount;\n        private static ChildCommand lastInstance;\n\n        @Option(names = \"--value\")\n        private int value;\n\n        private ChildCommand() {\n            constructedCount++;\n            lastInstance = this;\n        }\n\n        private static void reset() {\n            constructedCount = 0;\n            lastInstance = null;\n        }\n    }\n\n    public static final class StringList extends ArrayList<String> {\n    }\n\n    public static final class StringIntegerMap extends LinkedHashMap<String, Integer> {\n    }\n}\n","exit_code":0,"status":"completed"}}
