{"type":"item.completed","item":{"id":"item_64","type":"command_execution","command":"/usr/bin/bash -lc \"sed -n '1,220p' tests/src/org.apache.logging.log4j/log4j-core/2.17.1/src/test/java/org_apache_logging_log4j/log4j_core/Base64ConverterTest.java\"","aggregated_output":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_apache_logging_log4j.log4j_core;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.IOException;\nimport java.net.JarURLConnection;\nimport java.net.URL;\nimport java.net.URLClassLoader;\nimport java.nio.charset.StandardCharsets;\nimport java.security.CodeSource;\nimport java.util.Base64;\nimport java.util.ServiceLoader;\nimport java.util.concurrent.Callable;\n\nimport javax.xml.bind.DatatypeConverter;\n\nimport org.apache.logging.log4j.core.config.plugins.convert.Base64Converter;\nimport org.apache.logging.log4j.util.LoaderUtil;\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\n\npublic class Base64ConverterTest {\n\n    private static final String CALLABLE_SERVICE_RESOURCE = \"META-INF/services/java.util.concurrent.Callable\";\n    private static final String FALLBACK_ACTION_CLASS_NAME = FallbackAction.class.getName();\n    private static final String JAVA_UTIL_BASE64_CLASS_NAME = \"java.util.Base64\";\n\n    @Test\n    void decodesBase64UsingLog4jConverter() {\n        final byte[] expected = \"log4j-core Base64 converter\".getBytes(StandardCharsets.UTF_8);\n        final String encoded = Base64.getEncoder().encodeToString(expected);\n\n        final byte[] decoded = Base64Converter.parseBase64Binary(encoded);\n\n        assertThat(decoded).isEqualTo(expected);\n    }\n\n    @Test\n    void fallsBackToJaxbDatatypeConverterWhenJavaBase64IsUnavailable() throws Exception {\n        try (Base64BlockingClassLoader classLoader = new Base64BlockingClassLoader(new URL[] {\n                codeSourceUrl(Base64ConverterTest.class),\n                resourceRootUrl(CALLABLE_SERVICE_RESOURCE),\n                codeSourceUrl(Base64Converter.class),\n                codeSourceUrl(LoaderUtil.class),\n                codeSourceUrl(DatatypeConverter.class)\n        }, Base64ConverterTest.class.getClassLoader())) {\n            final Thread thread = Thread.currentThread();\n            final ClassLoader previousClassLoader = thread.getContextClassLoader();\n            thread.setContextClassLoader(classLoader);\n            try {\n                final Callable<?> action = ServiceLoader.load(Callable.class, classLoader).stream()\n                        .filter(provider -> provider.type().getName().equals(FALLBACK_ACTION_CLASS_NAME))\n                        .map(ServiceLoader.Provider::get)\n                        .findFirst()\n                        .orElseThrow(() -> new AssertionError(\"Expected an isolated Base64 fallback provider\"));\n\n                final Object decoded = action.call();\n\n                assertThat(decoded).isInstanceOf(byte[].class);\n                assertThat((byte[]) decoded).isEqualTo(\"fallback base64\".getBytes(StandardCharsets.UTF_8));\n            } finally {\n                thread.setContextClassLoader(previousClassLoader);\n            }\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    private static URL codeSourceUrl(final Class<?> type) {\n        final CodeSource codeSource = type.getProtectionDomain().getCodeSource();\n\n        assertThat(codeSource).isNotNull();\n        return codeSource.getLocation();\n    }\n\n    private static URL resourceRootUrl(final String resourceName) throws IOException {\n        final URL resourceUrl = Base64ConverterTest.class.getClassLoader().getResource(resourceName);\n\n        assertThat(resourceUrl).isNotNull();\n        if (\"jar\".equals(resourceUrl.getProtocol())) {\n            final JarURLConnection connection = (JarURLConnection) resourceUrl.openConnection();\n            return connection.getJarFileURL();\n        }\n        final String externalForm = resourceUrl.toExternalForm();\n        assertThat(externalForm).endsWith(resourceName);\n        return new URL(externalForm.substring(0, externalForm.length() - resourceName.length()));\n    }\n\n    public static final class FallbackAction implements Callable<byte[]> {\n        @Override\n        public byte[] call() {\n            return Base64Converter.parseBase64Binary(\"ZmFsbGJhY2sgYmFzZTY0\");\n        }\n    }\n\n    private static final class Base64BlockingClassLoader extends URLClassLoader {\n        private Base64BlockingClassLoader(final URL[] urls, final ClassLoader parent) {\n            super(urls, parent);\n        }\n\n        @Override\n        protected Class<?> loadClass(final String name, final boolean resolve) throws ClassNotFoundException {\n            if (JAVA_UTIL_BASE64_CLASS_NAME.equals(name)) {\n                throw new ClassNotFoundException(name);\n            }\n            synchronized (getClassLoadingLock(name)) {\n                Class<?> loadedClass = findLoadedClass(name);\n                if (loadedClass == null) {\n                    if (isChildFirst(name)) {\n                        try {\n                            loadedClass = findClass(name);\n                        } catch (ClassNotFoundException ignored) {\n                            loadedClass = super.loadClass(name, false);\n                        }\n                    } else {\n                        loadedClass = super.loadClass(name, false);\n                    }\n                }\n                if (resolve) {\n                    resolveClass(loadedClass);\n                }\n                return loadedClass;\n            }\n        }\n\n        private boolean isChildFirst