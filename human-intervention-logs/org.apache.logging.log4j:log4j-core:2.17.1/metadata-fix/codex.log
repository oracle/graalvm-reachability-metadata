IEXPORT jlong JNICALL Java_org_fusesource_jansi_internal_Kernel32_GetStdHandle(JNIEnv *env, jclass clazz, jint handle) {\n    return (jlong) handle;\n}\n\nJNIEXPORT jint JNICALL Java_org_fusesource_jansi_internal_Kernel32_GetConsoleScreenBufferInfo(JNIEnv *env, jclass clazz, jlong console, jobject info) {\n    return 1;\n}\n\nJNIEXPORT jint JNICALL Java_org_fusesource_jansi_internal_Kernel32_GetLastError(JNIEnv *env, jclass clazz) {\n    return 0;\n}\n\nJNIEXPORT jint JNICALL Java_org_fusesource_jansi_internal_Kernel32_FormatMessageW(JNIEnv *env, jclass clazz, jint flags, jlong source, jint messageId, jint languageId, jbyteArray buffer, jint size, jlongArray arguments) {\n    return 0;\n}\n\nJNIEXPORT void JNICALL Java_org_fusesource_jansi_internal_Kernel32_00024COORD_init(JNIEnv *env, jclass clazz) {\n}\n\nJNIEXPORT void JNICALL Java_org_fusesource_jansi_internal_Kernel32_00024SMALL_1RECT_init(JNIEnv *env, jclass clazz) {\n}\n\nJNIEXPORT void JNICALL Java_org_fusesource_jansi_internal_Kernel32_00024CONSOLE_1SCREEN_1BUFFER_1INFO_init(JNIEnv *env, jclass clazz) {\n}\n'''\n        List<String> command = [\n                'gcc',\n                '-shared',\n                '-fPIC',\n                '-I', includeDirectory.absolutePath,\n                '-I', linuxIncludeDirectory.absolutePath,\n                '-o', outputFile.absolutePath,\n                sourceFile.absolutePath\n        ]\n        Process process = new ProcessBuilder(command)\n                .redirectErrorStream(true)\n                .start()\n        String output = process.inputStream.getText('UTF-8')\n        int exitCode = process.waitFor()\n        if (exitCode != 0) {\n            throw new GradleException(\"Failed to compile Jansi stub with exit code ${exitCode}:\\n${output}\")\n        }\n    }\n}\n\nString localHostName() {\n    String hostName = System.getenv('HOSTNAME')\n    if (hostName != null && !hostName.isBlank()) {\n        return hostName\n    }\n    File linuxHostName = file('/p