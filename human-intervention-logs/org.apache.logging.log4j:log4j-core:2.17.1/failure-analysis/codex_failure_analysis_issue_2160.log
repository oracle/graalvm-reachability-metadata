ing.log4j.core.config.plugins.PluginFactory;\\nimport org.apache.logging.log4j.core.config.plugins.processor.PluginEntry;\\nimport org.apache.logging.log4j.core.config.plugins.util.PluginBuilder;\\nimport org.apache.logging.log4j.core.config.plugins.util.PluginType;\\nimport org.apache.logging.log4j.core.util.Builder;\\nimport org.junit.jupiter.api.Test;\\n\\npublic class PluginBuilderTest {\\n\\n    @Test\\n    void buildsPluginThroughAnnotatedBuilderFactoryAndInjectsBuilderFields() {\\n        final Node node = nodeFor(BuilderBackedPlugin.class, \\\"BuilderBackedPlugin\\\");\\n        node.getAttributes().put(\\\"name\\\", \\\"builder-value\\\");\\n\\n        final Object plugin = new PluginBuilder(node.getType())\\n                .withConfiguration(new NullConfiguration())\\n                .withConfigurationNode(node)\\n                .build();\\n\\n        assertThat(plugin).isInstanceOf(BuilderBackedPlugin.class);\\n        final BuilderBackedPlugin builderBackedPlugin = (BuilderBackedPlugin) plugin;\\n        assertThat(builderBackedPlugin.name).isEqualTo(\\\"builder-value\\\");\\n        assertThat(node.getAttributes()).isEmpty();\\n    }\\n\\n    @Test\\n    void fallsBackToAnnotatedFactoryMethodWhenNoBuilderFactoryExists() {\\n        final Node node = nodeFor(FactoryBackedPlugin.class, \\\"FactoryBackedPlugin\\\");\\n        node.getAttributes().put(\\\"name\\\", \\\"factory-value\\\");\\n\\n        final Object plugin = new PluginBuilder(node.getType())\\n                .withConfiguration(new NullConfiguration())\\n                .withConfigurationNode(node)\\n                .build();\\n\\n        assertThat(plugin).isInstanceOf(FactoryBackedPlugin.class);\\n        final FactoryBackedPlugin factoryBackedPlugin = (FactoryBackedPlugin) plugin;\\n        assertThat(factoryBackedPlugin.name).isEqualTo(\\\"factory-value\\\");\\n        assertThat(node.getAttributes()).isEmpty();\\n    }\\n\\n    private static Node nodeFor(final Class<?> pluginClass, final String elementName) {\\n        final PluginEntry entry = new PluginEntry();\\n        entry.setKey(elementName);\\n        entry.setName(elementName);\\n        entry.setClassName(pluginClass.getName());\\n        entry.setCategory(Node.CATEGORY);\\n        return new Node(null, elementName, new PluginType<>(entry, pluginClass, elementName));\\n    }\\n\\n    @Plugin(name = \\\"BuilderBackedPlugin\\\", category = Node.CATEGORY)\\n    public static final class BuilderBackedPlugin {\\n        private final String name;\\n\\n        private BuilderBackedPlugin(final String name) {\\n            this.name = name;\\n        }\\n\\n        @PluginBuilderFactory\\n        public static BuilderBackedPluginBuilder newBuilder() {\\n            return new BuilderBackedPluginBuilder();\\n        }\\n    }\\n\\n    public static final class BuilderBackedPluginBuilder implements Builder<BuilderBackedPlugin> {\\n        @PluginAttribute(\\\"name\\\")\\n        private String name = \\\"default-builder-value\\\";\\n\\n        @Override\\n        public BuilderBackedPlugin build() {\\n            return new BuilderBackedPlugin(name);\\n        }\\n    }\\n\\n    @Plugin(name = \\\"FactoryBackedPlugin\\\", category = Node.CATEGORY)\\n    public static final class FactoryBackedPlugin {\\n        private final String name;\\n\\n        private FactoryBackedPlugin(final String name) {\\n            this.name = name;\\n        }\\n\\n        @PluginFactory\\n        public static FactoryBackedPlugin create(@PluginAttribute(\\\"name\\\") final String name) {\\n            return new FactoryBackedPlugin(name);\\n        }\\n    }\\n}\\n\",\"exit_code\":0,\"status\":\"completed\"}}\n{\"type\":\"item.started\",\"item\":{\"id\":\"item_126\",\"type\":\"command_execution\",\"command\":\"/usr/bin/bash -lc 'export GRAALVM_HOME=/home/vjovanov/c/graalvm-reachability-metadata/vj/forge/ce/sdk/latest_graalvm_home JAVA_HOME=/home/vjovanov/c/graalvm-reachability-metadata/vj/forge/ce/sdk/latest_graa