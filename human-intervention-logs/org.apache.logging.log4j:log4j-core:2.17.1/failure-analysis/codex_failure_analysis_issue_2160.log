ersion1LoadedInIsolation() throws Exception {\\n        try (ChildFirstClassLoader classLoader = new ChildFirstClassLoader(new URL[] {\\n                codeSourceUrl(MulticastDnsAdvertiserTest.class),\\n                resourceRootUrl(CALLABLE_SERVICE_RESOURCE),\\n                codeSourceUrl(MulticastDnsAdvertiser.class),\\n                jmdnsVersion1JarUrl()\\n        }, MulticastDnsAdvertiserTest.class.getClassLoader())) {\\n            final Thread thread = Thread.currentThread();\\n            final ClassLoader previousClassLoader = thread.getContextClassLoader();\\n            thread.setContextClassLoader(classLoader);\\n            try {\\n                final Callable<?> action = ServiceLoader.load(Callable.class, classLoader).stream()\\n                        .map(ServiceLoader.Provider::get)\\n                        .filter(provider -> provider.getClass().getName().equals(VERSION1_ACTION_CLASS_NAME))\\n                        .findFirst()\\n                        .orElseThrow(() -> new AssertionError(\\n                                \\\"Expected an isolated JmDNS version 1 callable provider\\\"));\\n\\n                assertThat(action.call()).isEqualTo(ServiceInfo.class.getName());\\n            } finally {\\n                thread.setContextClassLoader(previousClassLoader);\\n            }\\n        } catch (Error error) {\\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\\n                throw error;\\n            }\\n        }\\n    }\\n\\n    private static URL codeSourceUrl(final Class<?> type) {\\n        final CodeSource codeSource = type.getProtectionDomain().getCodeSource();\\n\\n        assertThat(codeSource).isNotNull();\\n        return codeSource.getLocation();\\n    }\\n\\n    private static URL resourceRootUrl(final String resourceName) throws IOException {\\n        final URL resourceUrl = MulticastDnsAdvertiserTest.class.getClassLoader().getResource(resourceName);\\n\\n        assertThat(resourceUrl).isNotNull();\\n        if (\\\"jar\\\".equals(resourceUrl.getProtocol())) {\\n            final JarURLConnection connection = (JarURLConnection) resourceUrl.openConnection();\\n            return connection.getJarFileURL();\\n        }\\n        final String externalForm = resourceUrl.toExternalForm();\\n        assertThat(externalForm).endsWith(resourceName);\\n        return new URL(externalForm.substring(0, externalForm.length() - resourceName.length()));\\n    }\\n\\n    private static URL jmdnsVersion1JarUrl() throws IOException {\\n        final String jarPath = System.getProperty(JMDNS_VERSION1_JAR_PROPERTY);\\n\\n        assertThat(jarPath).isNotBlank();\\n        return Path.of(jarPath).toUri().toURL();\\n    }\\n\\n    public static final class Version1Action implements Callable<String> {\\n        @Override\\n        public String call() {\\n            final MulticastDnsAdvertiser advertiser = new MulticastDnsAdvertiser();\\n            final String serviceName = \\\"graalvm-log4j-core-version1-test-\\\" + Long.toUnsignedString(System.nanoTime());\\n            final Map<String, String> properties = Map.of(\\n                    \\\"name\\\", serviceName,\\n                    \\\"protocol\\\", \\\"tcp\\\",\\n                    \\\"port\\\", \\\"4555\\\");\\n\\n            final Object serviceInfo = advertiser.advertise(properties);\\n            try {\\n                if (serviceInfo == null) {\\n                    throw new AssertionError(\\\"Expected JmDNS version 1 ServiceInfo to be created\\\");\\n                }\\n                return serviceInfo.getClass().getName();\\n            } finally {\\n                if (serviceInfo != null) {\\n                    advertiser.unadvertise(serviceInfo);\\n                }\\n            }\\n        }\\n    }\\n\\n    private static final class ChildFirstClassLoader extends URLClassLoader {\\n        private ChildFirstClassLoader(final URL[] urls, final ClassLoader parent) {\\n            super(urls, parent);\\n        }\\n\\n        @Override\\n        protected Class<?> loadClass(final String name, final boolean resolve) throws ClassNotFoundException {\\n            synchronized (getClassLoadingLock(name)) {\\n                Class<?> loadedClass = findLoadedClass(name);\\n                if (loadedClass == null) {\\n                    if (isChildFirst(name)) {\\n                        try {\\n                            loadedClass = findClass(name);\\n                        } catch (ClassNotFoundException ignored) {\\n                            loadedClass = super.loadClass(name, false);\\n                        }\\n                    } else {\\n                        loadedClass = super.loadClass(name, false);\\n                    }\\n                }\\n                if (resolve) {\\n                    resolveClass(loadedClass);\\n                }\\n                return loadedClass;\\n            }\\n        }\\n\\n        private boolean isChildFirst(final String className) {\\n            return className.equals(MulticastDnsAdvertiser.class.getName())\\n                    || className.equals(MulticastDnsAdvertiserTest.class.getName())\\n                    || className.equals(VERSION1_ACTION_CLASS_NAME)\\n                    || className.startsWith(VERSION1_ACTION_CLASS_NAME + \\\"$\\\")\\n                    || className.startsWith(\\\"javax.jmdns.\\\");\\n        }\\n    }\\n}\\n\",\"exit_code\":0,\"status\":\"completed\"}}\n../2160-a6e96de1/human-intervention-logs/org.apache.logging.log4j:log4j-core:2.17.1/metadata-fix/codex.log:329:{\"type\":\"item.completed\",\"item\":{\"id\":\"item_158\",\"type\":\"command_execution\",\"command\":\"/usr/bin/bash -lc 'export JAVA_HOME=/home/vjovanov/c/graalvm-reachability-metadata/vj/forge/ce/sdk/latest_graalvm_home PATH=$JAVA_HOME/bin:$PATH; javap -classpath /home/vjovanov/.m2/repository/org/apache/logging/log4j/log4j-core/2.17.1/log4j-core-2.17.1.jar -p -c org.apache.logging.log4j.core.config.plugins.