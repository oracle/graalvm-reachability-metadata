ts waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage org_apache_logging_log4j.log4j_core;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\n\\nimport java.io.IOException;\\nimport java.net.JarURLConnection;\\nimport java.net.URL;\\nimport java.net.URLClassLoader;\\nimport java.nio.file.Path;\\nimport java.security.CodeSource;\\nimport java.util.Map;\\nimport java.util.ServiceLoader;\\nimport java.util.concurrent.Callable;\\n\\nimport javax.jmdns.ServiceInfo;\\n\\nimport org.apache.logging.log4j.core.net.MulticastDnsAdvertiser;\\nimport org.graalvm.internal.tck.NativeImageSupport;\\nimport org.junit.jupiter.api.Test;\\n\\npublic class MulticastDnsAdvertiserTest {\\n\\n    private static final String CALLABLE_SERVICE_RESOURCE = \\\"META-INF/services/java.util.concurrent.Callable\\\";\\n    private static final String VERSION1_ACTION_CLASS_NAME = Version1Action.class.getName();\\n    private static final String JMDNS_VERSION1_JAR_PROPERTY = \\\"log4jCore.jmdnsVersion1Jar\\\";\\n\\n    @Test\\n    void advertisesAndUnadvertisesWithJmDnsVersion3() {\\n        final MulticastDnsAdvertiser advertiser = new MulticastDnsAdvertiser();\\n        final String serviceName = \\\"graalvm-log4j-core-test-\\\" + Long.toUnsignedString(System.nanoTime());\\n        final Map<String, String> properties = Map.of(\\n                \\\"name\\\", serviceName,\\n                \\\"protocol\\\", \\\"tcp\\\",\\n                \\\"port\\\", \\\"4555\\\");\\n\\n        final Object serviceInfo = advertiser.advertise(properties);\\n        try {\\n            assertThat(serviceInfo).isInstanceOf(ServiceInfo.class);\\n        } finally {\\n            if (serviceInfo != null) {\\n                advertiser.unadvertise(serviceInfo);\\n            }\\n        }\\n    }\\n\\n    @Test\\n    void advertisesAndUnadvertisesWithJmDnsVersion1LoadedInIsolation() throws Exception {\\n        try (ChildFirstClassLoader classLoader = new ChildFirstClassLoader(new URL[] {\\n                codeSourceUrl(MulticastDnsAdvertiserTest.class),\\n                resourceRootUrl(CALLABLE_SERVICE_RESOURCE),\\n                codeSourceUrl(MulticastDnsAdvertiser.class),\\n                jmdnsVersion1JarUrl()\\n        }, MulticastDnsAdvertiserTest.class.getClassLoader())) {\\n            final Thread thread = Thread.currentThread();\\n            final ClassLoader previousClassLoader = thread.getContextClassLoader();\\n            thread.setContextClassLoader(classLoader);\\n            try {\\n                final Callable<?> action = ServiceLoader.load(Callable.class, classLoader).stream()\\n                        .map(ServiceLoader.Provider::get)\\n                        .filter(provider -> provider.getClass().getName().equals(VERSION1_ACTION_CLASS_NAME))\\n                        .findFirst()\\n                        .orElseThrow(() -> new AssertionError(\\n                                \\\"Expected an isolated JmDNS version 1 callable provider\\\"));\\n\\n                assertThat(action.call()).isEqualTo(ServiceInfo.class.getName());\\n            } finally {\\n                thread.setContextClassLoader(previousClassLoader);\\n            }\\n        } catch (Error error) {\\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\\n                throw error;\\n            }\\n        }\\n    }\\n\\n    private static URL codeSourceUrl(final Class<?> type) {\\n        final CodeSource codeSource = type.getProtectionDomain().getCodeSource();\\n\\n        assertThat(codeSource).isNotNull();\\n        return codeSource.getLocation();\\n    }\\n\\n    private static URL resourceRootUrl(final String resourceName) throws IOException {\\n        final URL resourceUrl = MulticastDnsAdvertiserTest.class.getClassLoader().getResource(resourceName);\\n\\n        assertThat(resourceUrl).isNotNull();\\n      