_JANSI_PROPERTY);\\n        final String jansiStubDirectory = System.getProperty(JANSI_STUB_DIRECTORY_PROPERTY);\\n        final PatternLayout layout = PatternLayout.createDefaultLayout();\\n        assertThat(jansiStubDirectory).isNotBlank();\\n        try {\\n            System.setProperty(FORCE_WINDOWS_PROPERTY, Boolean.TRUE.toString());\\n            System.setProperty(JANSI_LIBRARY_PATH_PROPERTY, jansiStubDirectory);\\n            System.setProperty(SKIP_JANSI_PROPERTY, Boolean.FALSE.toString());\\n            PropertiesUtil.getProperties().reload();\\n\\n            final ConsoleAppender.Builder<?> builder = ConsoleAppender.newBuilder();\\n            builder.setName(\\\"console-jansi-lookup\\\");\\n            builder.setTarget(ConsoleAppender.Target.SYSTEM_OUT);\\n            builder.setFollow(false);\\n            builder.setDirect(false);\\n            builder.setLayout(layout);\\n\\n            try {\\n                final ConsoleAppender appender = builder.build();\\n\\n                assertThat(appender).isNotNull();\\n                assertThat(appender.stop(1, TimeUnit.SECONDS)).isTrue();\\n            } catch (final ExceptionInInitializerError error) {\\n                assertExpectedJansiPlatformError(error);\\n            } catch (final UnsatisfiedLinkError error) {\\n                assertExpectedJansiPlatformError(error);\\n            }\\n        } finally {\\n            restoreProperty(FORCE_WINDOWS_PROPERTY, originalForceWindows);\\n            restoreProperty(JANSI_LIBRARY_PATH_PROPERTY, originalJansiLibraryPath);\\n            restoreProperty(SKIP_JANSI_PROPERTY, originalSkipJansi);\\n            PropertiesUtil.getProperties().reload();\\n        }\\n    }\\n\\n    private static void assertExpectedJansiPlatformError(final Error error) {\\n        assertThat(error).hasStackTraceContaining(\\\"org.fusesource.jansi\\\");\\n    }\\n\\n    private static void restoreProperty(final String name, final String originalValue) {\\n        if (originalValue == null) {\\n            System.clearProperty(name);\\n        } else {\\n            System.setProperty(name, originalValue);\\n        }\\n    }\\n\\n    public static final class WindowsOverridePropertySource implements PropertySource {\\n\\n        private static final String OS_NAME_PROPERTY = \\\"os.name\\\";\\n        private static final String WINDOWS_OS_NAME = \\\"Windows 10\\\";\\n\\n        @Override\\n        public int getPriority() {\\n            return 300;\\n        }\\n\\n        @Override\\n        public void forEach(final BiConsumer<String, String> action) {\\n            if (Boolean.getBoolean(FORCE_WINDOWS_PROPERTY)) {\\n                action.accept(OS_NAME_PROPERTY, WINDOWS_OS_NAME);\\n            }\\n        }\\n\\n        @Override\\n        public CharSequence getNormalForm(final Iterable<? extends CharSequence> tokens) {\\n            return Util.joinAsCamelCase(tokens);\\n        }\\n    }\\n}\\n\",\"exit_code\":0,\"status\":\"completed\"}}\n../2160-a6e96de1/human-intervention-logs/org.apache.logging.log4j:log4j-core:2.17.1/metadata-fix/codex.log:381:2026-05-20T12:42:39.442963Z ERROR codex_core::tools::router: error=apply_patch verification failed: Failed to find expected lines in /home/vjovanov/c/forge/forge10/graalvm-reachability-metadata/forge/local_repositories/forge_worktrees/2160-a6e96de1/metadata/org.apache.logging.log4j/log4j-core/2.17.1/reachability-metadata.json:\n../2160-a6e96de1/human-intervention-logs/org.apache.logging.log4j:log4j-core:2.17.1/metadata-fix/codex.log:395:{\"type\":\"item.completed\",\"item\":{\"id\":\"item_191\",\"type\":\"command_execution\",\"command\":\"/usr/bin/bash -lc 'export GRAALVM_HOME=/home/vjovanov/c/graalvm-reachability-metadata/vj/forge/ce/sdk/latest_graalvm_home JAVA_HOME=/home/vjovanov/c/graalvm-reachability-metadata/vj/forge/ce/sdk/latest_graalvm_home PATH=$GRAALVM_HOME/bin:$PATH; ./gradlew test -Pcoordinates=org.apache.logging.log4j:log4j-core:2.17.1 --stacktrace'\",\"aggregated_ou