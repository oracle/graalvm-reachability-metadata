leArgConstructor != null) singleArgConstructor.newInstance(baseHostConfiguration) as ScriptingHostConfiguration\\n        else scriptConfigInstance(hostConfigurationKClass)\\n            ?: throw IllegalArgumentException(\\\"${ERROR_MSG_PREFIX}Illegal argument hostConfiguration of the KotlinScript annotation: expecting an object or a class derived from ScriptingHostConfiguration constructable without arguments or from a base configuration\\\")\\n\\n    return hostConfigurationInstance.with {\\n        body()\\n    }.withDefaultsFrom(baseHostConfiguration)\\n}\\n\\nprivate fun ScriptCompilationConfiguration.Builder.propertiesFromTemplate(\\n    templateClass: KClass<*>, baseClassType: KotlinType, mainAnnotation: KotlinScript\\n) {\\n    baseClass.replaceOnlyDefault(if (templateClass == baseClassType.fromClass) baseClassType else KotlinType(templateClass))\\n    fileExtension.replaceOnlyDefault(mainAnnotation.fileExtension)\\n\\n[53 more lines in file. Use offset=159 to continue.]\"}], \"isError\": false, \"timestamp\": 1781144856780}]}\n1981:[recv] {\"type\": \"message_end\", \"message\": {\"role\": \"assistant\", \"content\": [{\"type\": \"thinking\", \"thinking\": \"\", \"thinkingSignature\": \"{\\\"id\\\":\\\"rs_07e37d872963455d016a2a1d1a62c48195bf265fd0d9d63d47\\\",\\\"type\\\":\\\"reasoning\\\",\\\"content\\\":[],\\\"encrypted_content\\\":\\\"gAAAAABqKh0g-2g5PmMy3UFe1gAbDZw6cB6tgznfm-lPt4zojdkAwJhxV3JG-j8RGu92E2A0OvUXTY0uZ6DIemQeLNxRT0NQQKVh2UyPGmDJ4TknPyvRNoOq92jgzp8rUtYiSUlCf5yEMLtZC4-W87iXvcm6bHSnO8uK8ItSxPgo_5V-zr_iRuqtxYogTzDw7-j3I-DP_69u_LdATYruEmlhieqSQ9TR0f4A5EeDdD7WAWeaR1p1sVn6ocb75-v0ukyUGe6WRSy7qVV60-B3mDmAttAyS92Q6LK-B8anxOB67ve9Bgbx43OiivvzWuPBPEF4PkZtDhb1tTDLJMDns7yJVRdCBQi9f9P5ejwESC7JHvzU7sWgKEOs1tfpqToW9ffQYYDCw5rb4j2OrXpVDPqv_Zjy49KwyiphRiVyMC6Fd_yxUlXTX3IzF9Gp1vybDvtJheSzl2Abs4Ca5hxCWzkhxq701AVzLUI-OPF5K00wdhLFu01Gsgqu09F4bwSR1IK0QHqH4GVZXMuD9rBQiVy7-vR7bLev-Aqml0SIg9LO5QnCz3HNSXd0veFjK2ZYrxGPjghoQW_wkfUWvZ3htKazjPlJ-YuV6ypbUb5nFne6B3jD9Nu3xPY