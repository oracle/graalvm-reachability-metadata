n                project\\n            ) to psiAnn\\n        }\\n    }\\n\\nprivate fun PsiElement.location(document: Document): SourceCode.Location {\\n    val start = document.offsetToPosition(startOffset)\\n    val end = if (endOffset > startOffset) document.offsetToPosition(endOffset) else null\\n    return SourceCode.Location(start, end)\\n}\\n\\nprivate fun Document.offsetToPosition(offset: Int): SourceCode.Position {\\n    val line = getLineNumber(offset)\\n    val column = offset - getLineStartOffset(line)\\n    return SourceCode.Position(line + 1, column + 1, offset)\\n}\\n\",\"exit_code\":0,\"status\":\"completed\"}}\n{\"type\":\"item.started\",\"item\":{\"id\":\"item_68\",\"type\":\"command_execution\",\"command\":\"/usr/bin/bash -lc \\\"cd /tmp/kotlin-src && sed -n '1,260p' kotlin/script/experimental/api/scriptCompilation.kt\\\"\",\"aggregated_output\":\"\",\"exit_code\":null,\"status\":\"in_progress\"}}\n{\"type\":\"item.completed\",\"item\":{\"id\":\"item_68\",\"type\":\"command_execution\",\"command\":\"/usr/bin/bash -lc \\\"cd /tmp/kotlin-src && sed -n '1,260p' kotlin/script/experimental/api/scriptCompilation.kt\\\"\",\"aggregated_output\":\"sed: can't read kotlin/script/experimental/api/scriptCompilation.kt: No such file or directory\\n\",\"exit_code\":2,\"status\":\"failed\"}}\n{\"type\":\"item.started\",\"item\":{\"id\":\"item_69\",\"type\":\"command_execution\",\"command\":\"/usr/bin/bash -lc \\\"cd /tmp/kotlin-src && (test -f kotlin-scripting-common-2.3.21-sources.jar || curl -fsSLO https://repo.maven.apache.org/maven2/org/jetbrains/kotlin/kotlin-scripting-common/2.3.21/kotlin-scripting-common-2.3.21-sources.jar) && jar xf kotlin-scripting-common-2.3.21-sources.jar kotlin/script/experimental/api/scriptCompilation.kt && rg -n 'RefineConfigurationOnAnnotationsData|onAnnotations|refineConfigurationOnAnnotations|data class KotlinType|class KotlinType' kotlin/script/experimental/api/scriptCompilation.kt -n -C 3\\\"\",\"aggregated_output\":\"\",\"exit