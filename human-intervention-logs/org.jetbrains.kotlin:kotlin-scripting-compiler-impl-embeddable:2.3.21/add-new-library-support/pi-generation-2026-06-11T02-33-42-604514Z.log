l(type.classLoader.getResourceAsStream(classResourceName)) {\n            \"Class resource $classResourceName is not available\"\n        }.use { input: InputStream ->\n            Files.copy(input, classFile)\n        }\n\n        val markersDirectory: Path = root.resolve(SCRIPT_DEFINITION_MARKERS_PATH)\n", "newText": "        val classResourceName: String = type.name.replace('.', '/') + \".class\"\n        val classFile: Path = root.resolve(classResourceName)\n        Files.createDirectories(classFile.parent)\n        Files.write(classFile, legacyTemplateClassBytes(type))\n\n        val markersDirectory: Path = root.resolve(SCRIPT_DEFINITION_MARKERS_PATH)\n"}, {"oldText": "        return root\n    }\n}\n\n@KotlinScript(\n", "newText": "        return root\n    }\n\n    private fun legacyTemplateClassBytes(type: Class<*>): ByteArray {\n        val writer = ClassWriter(0)\n        writer.visit(\n            Opcodes.V1_8,\n            Opcodes.ACC_PUBLIC or Opcodes.ACC_ABSTRACT,\n            type.name.replace('.', '/'),\n            null,\n            \"java/lang/Object\",\n            null,\n        )\n        writer.visitAnnotation(\"Lkotlin/script/templates/ScriptTemplateDefinition;\", true).visitEnd()\n        val constructor = writer.visitMethod(Opcodes.ACC_PUBLIC, \"<init>\", \"()V\", null, null)\n        constructor.visitCode()\n        constructor.visitVarInsn(Opcodes.ALOAD, 0)\n        constructor.visitMethodInsn(Opcodes.INVOKESPECIAL, \"java/lang/Object\", \"<init>\", \"()V\", false)\n        constructor.visitInsn(Opcodes.RETURN)\n        constructor.visitMaxs(1, 1)\n        constructor.visitEnd()\n        writer.visitEnd()\n        return writer.toByteArray()\n    }\n}\n\n@KotlinScript(\n"}]}, "partialJson": "{\"path\":\"tests/src/org.jetbrains.kotlin/kotlin-scripting-compiler-impl-embeddable/2.3.21/src/test/kotlin/org_jetbrains_kotlin/kotlin_scripting_compiler_impl_embeddable/ScriptiDefinitionsFromClasspathDiscoverySourceKtTest.kt\",\"edits\":[{\"oldText\"