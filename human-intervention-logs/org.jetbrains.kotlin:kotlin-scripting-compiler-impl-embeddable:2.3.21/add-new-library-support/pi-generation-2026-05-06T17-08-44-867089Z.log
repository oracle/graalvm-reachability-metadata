      30	public class RefineCompilationConfigurationKtTest {
      31	    @Test
      32	    public fun collectsAcceptedScriptAnnotationUsingContextClassLoader(): Unit {
      33	        try {
      34	            val parentDisposable: Disposable = Disposer.newDisposable("refine-compilation-configuration-test")
      35	            try {
      36	                val compilerConfiguration: CompilerConfiguration = CompilerConfiguration().apply {
      37	                    put(CLIConfigurationKeys.MESSAGE_COLLECTOR_KEY, MessageCollector.NONE)
      38	                    put(CommonConfigurationKeys.MODULE_NAME, "refine-compilation-configuration-test")
      39	                }
      40	                val environment: KotlinCoreEnvironment = KotlinCoreEnvironment.createForProduction(
      41	                    parentDisposable,
      42	                    compilerConfiguration,
      43	                    EnvironmentConfigFiles.JVM_CONFIG_FILES,
      44	                )
      45	                val scriptFile: KtFile = KtPsiFactory(environment.project).createFile(
      46	                    "annotated-refine-script.kts",
      47	                    """
      48	                    @RefineCompilationConfigurationTestAnnotation(label = "native-image")
      49	                    val answer = 42
      50	                    """.trimIndent(),
      51	                )
      52	                val compilationConfiguration: ScriptCompilationConfiguration = ScriptCompilationConfiguration {
      53	                    refineConfiguration {
      54	                        onAnnotations(RefineCompilationConfigurationTestAnnotation::class) { context ->
      55	                            context.compilationConfiguration.asSuccess()
      56	                        }
      57	                    }
      58	                }
      59	                val contextClassLoader: RecordingClassLoader = RecordingClassLoader(
      60	                    RefineCompilationConfigurationTestAnnotation::class.java.classLoader,
      61	                )
      62	
      63	                val collectedData: ScriptCollectedData = getScriptCollectedData(
      64	                    scriptFile,
      65	                    compilationConfiguration,
      66	                    environment.project,
      67	                    contextClassLoader,
      68	                )
      69	                val annotations: List<ScriptSourceAnnotation<*>> =
      70	                    collectedData[ScriptCollectedData.collectedAnnotations].orEmpty()
      71	
      72	                assertThat(contextClassLoader.loadedNames)
      73	                    .contains(RefineCompilationConfigurationTestAnnotation::class.java.name)
      74	                assertThat(annotations).hasSize(1)
      75	                assertThat(annotations.single().annotation)
      76	                    .isInstanceOf(RefineCompilationConfigurationTestAnnotation::class.java)
      77	                assertThat((annotations.single().annotation as RefineCompilationConfigurationTestAnnotation).label)
      78	                    .isEqualTo("native-image")
      79	            } finally {
      80	                Disposer.dispose(parentDisposable)
      81	            }
      82	        } catch (error: Error) {
      83	            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
      84	                throw error
      85	            }
      86	        }
