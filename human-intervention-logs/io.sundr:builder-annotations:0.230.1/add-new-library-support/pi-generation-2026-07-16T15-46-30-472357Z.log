  import org.graalvm.buildtools.gradle.tasks.NativeRunTask
  
  plugins {
      id "org.graalvm.internal.tck"
  }
  
  String libraryVersion = tck.testedLibraryVersion.get()
  String javaHome = System.getenv('JAVA_HOME') ?: System.getenv('GRAALVM_HOME')
  List<String> javacRuntimeArgs = [
          "-Djava.home=${javaHome}",
          "-Djava.class.path=${-> sourceSets.test.runtimeClasspath.asPath}"
  ]
  
  dependencies {
      testImplementation "io.sundr:transform-annotations:$libraryVersion"
      testImplementation "io.sundr:sundr-codegen-velocity-nodeps:$libraryVersion"
      testImplementation 'org.assertj:assertj-core:3.22.0'
