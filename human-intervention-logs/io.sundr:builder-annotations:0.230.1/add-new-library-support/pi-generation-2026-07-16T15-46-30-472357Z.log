  graalvmNative {
      binaries {
          test {
              runtimeArgs.addAll(javacRuntimeArgs)
          }
      }
      agent {
          defaultMode = "conditional"
          modes {
              conditional {
                  userCodeFilterPath = "user-code-filter.json"
              }
          }
      }
  }
  
  tasks.named("nativeTest", NativeRunTask) {
      runtimeArgs.addAll(javacRuntimeArgs)
  }
