        Lazy item = new LazyBuilder().addToList(new String(\"foo\")).addToSet(new String(\"bar\")).build();\n        assertNotNull(item.getList());\n        assertEquals(1, item.getList().size());\n        assertEquals(\"foo\", item.getList().get(0));\n\n        assertEquals(1, item.getSet().size());\n        assertEquals(\"bar\", item.getSet().iterator().next());\n    }\n}\n=====EagerTest\n/*\n *      Copyright 2019 The original authors.\n *\n *      Licensed under the Apache License, Version 2.0 (the \"License\");\n *      you may not use this file except in compliance with the License.\n *      You may obtain a copy of the License at\n *\n *          http://www.apache.org/licenses/LICENSE-2.0\n *\n *      Unless required by applicable law or agreed to in writing, software\n *      distributed under the License is distributed on an \"AS IS\" BASIS,\n *      WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n *      See the License for the specific language governing permissions and\n *      limitations under the License.\n */\npackage io.sundr.it;\n\nimport org.junit.Test;\nimport java.util.List;\nimport java.util.ArrayList;\nimport java.util.Set;\nimport java.util.LinkedHashSet;\n\nimport static org.junit.Assert.*;\n\npublic class EagerTest {\n\n    @Test\n    public void shouldReturnNull() {\n        Eager item = new EagerBuilder().build();\n        assertNotNull(item.getList());\n        assertTrue(item.getList().isEmpty());\n        assertNotNull(item.getSet());\n        assertTrue(item.getSet().isEmpty());\n    }\n\n    @Test\n    public void shouldRespectWithNull() {\n        Eager item = new EagerBuilder().withList((List<String>)null).withSet((Set<String>)null).build();\n        assertNull(item.getList());\n        assertNull(item.getSet());\n    }\n\n    @Test\n    public void shouldRespectWith() {\n        Eager item = new EagerBuilder().withList(new ArrayList<>()).withSet(new LinkedHashSet<>()).build();\n        assertNotNull(item.getList());\n        assertEquals(0, item.getList().size());\n        assertEquals(0, item.getSet().size());\n    }\n\n    @Test\n    public void shouldRespecAddTo() {\n        Eager item = new EagerBuilder().addToList(new String(\"foo\")).addToSet(new String(\"bar\")).build();\n        assertNotNull(item.getList());\n        assertEquals(1, item.getList().size());\n        assertEquals(\"foo\", item.getList().get(0));\n\n        assertEquals(1, item.getSet().size());\n        assertEquals(\"bar\", item.getSet().iterator().next());\n    }\n}\n====paths\n\"path\": \"annotations/builder/src/it/lazy-collections\"\n\"path\": \"annotations/builder/src/it/lazy-collections/pom.xml\"\n\"path\": \"annotations/builder/src/it/lazy-collections/src\"\n\"path\": \"annotations/builder/src/it/lazy-collections/src/main\"\n\"path\": \"annotations/builder/src/it/lazy-collections/src/main/java\"\n\"path\": \"annotations/builder/src/it/lazy-collections/src/main/java/io\"\n\"path\": \"annotations/builder/src/it/lazy-collections/src/main/java/io/sundr\"\n\"path\": \"annotations/builder/src/it/lazy-collections/src/main/java/io/sundr/it\"\n\"path\": \"annotations/builder/src/it/lazy-collections/src/main/java/io/sundr/it/Default.java\"\n\"path\": \"annotations/builder/src/it/lazy-collections/src/main/java/io/sundr/it/Eager.java\"\n\"path\": \"annotations/builder/src/it/lazy-collections/src/main/java/io/sundr/it/Lazy.java\"\n\"path\": \"annotations/builder/src/it/lazy-collections/src/test\"\n\"path\": \"annotations/builder/src/it/lazy-collections/src/test/java\"\n\"path\": \"annotations/builder/src/it/lazy-collections/src/test/java/io\"\n\"path\": \"annotations/builder/src/it/lazy-collections/src/test/java/io/sundr\"\n\"path\": \"annotations/builder/src/it/lazy-collections/src/test/java/io/sundr/it\"\n\"path\": \"annotations/builder/src/it/lazy-collections/src/test/java/io/sundr/it/DefaultTest.java\"\n\"path\": \"annotations/builder/src/it/lazy-collections/src/test/java/io/sundr/it/EagerTest.