ger(new PrintStream(new ByteArrayOutputStream()), InvokerLogger.ERROR));\n\n        InvocationResult result = invoker.execute(request);\n\n        assertThat(result.getExitCode()).isZero();\n        assertThat(result.getExecutionException()).isNull();\n        assertThat(outputLines).contains(\"PWD=\" + projectDirectory.toRealPath());\n        assertThat(outputLines).anySatisfy(line -> assertThat(line)\n                .contains(\"ARGS=\")\n                .contains(\"maven.repo.local=\" + localRepository.toRealPath())\n                .contains(\"validate\"));\n        assertThat(errorLines).contains(\"stderr-line\");\n    }\n\n    @Test\n    void defaultInvokerExecutesConfiguredMavenCommandAndCapturesResult() throws Exception {\n        Path mavenHome = createFakeMavenHome(7);\n"}]}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 544, "output": 1989, "cacheRead": 37888, "cacheWrite": 0, "totalTokens": 40421, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778588556521, "responseId": "resp_02e3884f54a6cc6a016a031b8d41c081919e637c16e191741f"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_wchfkPWqKsIChsUtw3FwmQHO|fc_02e3884f54a6cc6a016a031ba00edc81919eb2c7fadc947d5f", "toolName": "edit", "content": [{"type": "text", "text": "Successfully replaced 1 block(s) in tests/src/org.apache.maven.shared/maven-invoker/2.0.9/src/test/java/org_apache_maven_shared/maven_invoker/Maven_invokerTest.java."}], "details": {"diff": "     ...\n 273         assertThat(errorLines).isEmpty();\n 274     }\n 275 \n 276     @Test\n+277     void defaultInvokerUsesInvokerLevelWorkingDirectoryAndLocalRepositoryDefaults() throws Exception {\n+278         Path mavenHome = createFakeMavenHome(0);\n+279         Path projectDirectory = Files.createDirectory(tempDir.resolve(\"defaulted-project\"));\n+280         Path localRepository = Files.createDirectory(tempDir.resolve(\"defau