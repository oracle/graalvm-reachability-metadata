      private ScmUrlParserResult parseScmUrl( String scmSpecificUrl, char delimiter )
          throws ScmException
      {
          ScmUrlParserResult result = new ScmUrlParserResult();
  
          result.repository = new GitScmProviderRepository( scmSpecificUrl );
  
          return result;
      }
  
