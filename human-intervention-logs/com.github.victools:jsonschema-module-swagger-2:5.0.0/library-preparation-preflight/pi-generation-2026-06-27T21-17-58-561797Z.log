fka/kafka-clients/4.2.1/reachability-metadata.json:975:            \"com.fasterxml.jackson.databind.JsonNode\",\nmetadata/org.apache.kafka/kafka-clients/4.2.0/reachability-metadata.json:917:            \"com.fasterxml.jackson.databind.JsonNode\",\nmetadata/org.hibernate.validator/hibernate-validator/7.0.4.Final/reachability-metadata.json:31:      \"type\": \"com.fasterxml.jackson.databind.JsonNode\"\nmetadata/org.hibernate.orm/hibernate-core/6.1.1.Final/reachability-metadata.json:43:      \"type\": \"com.fasterxml.jackson.databind.JsonNode\"\nmetadata/tools.jackson.core/jackson-databind/index.json:5:    \"source-code-url\" : \"https://repo1.maven.org/maven2/tools/jackson/core/jackson-databind/$version$/jackson-databind-$version$-sources.jar\",\nmetadata/tools.jackson.core/jackson-databind/index.json:6:    \"repository-url\" : \"https://github.com/FasterXML/jackson-databind\",\nmetadata/tools.jackson.core/jackson-databind/index.json:7:    \"test-code-url\" : \"https://github.com/FasterXML/jackson-databind/tree/jackson-databind-$version$/src/test\",\nmetadata/tools.jackson.core/jackson-databind/index.json:8:    \"documentation-url\" : \"https://repo1.maven.org/maven2/tools/jackson/core/jackson-databind/$version$/jackson-databind-$version$-javadoc.jar\",\nmetadata/com.github.victools/jsonschema-module-swagger-2/index.json:5:    \"source-code-url\" : \"https://repo1.maven.org/maven2/com/github/victools/jsonschema-module-swagger-2/$version$/jsonschema-module-swagger-2-$version$-sources.jar\",\nmetadata/com.github.victools/jsonschema-module-swagger-2/index.json:6:    \"repository-url\" : \"https://github.com/victools/jsonschema-generator\",\nmetadata/com.github.victools/jsonschema-module-swagger-2/index.json:7:    \"test-code-url\" : \"https://github.com/victools/jsonschema-generator/tree/v$version$/jsonschema-module-swagger-2/src/test\",\nmetadata/com.github.victools/jsonschema-module-swagger-2/index.json:8:    \"documentation-url\" : \"https://repo1.maven.org/maven2/com/github/victools/jsonschema-module-swagger-2/$version$/jsonschema-module-swagger-2-$version$-javadoc.jar\",\nmetadata/com.github.victools/jsonschema-module-swagger-2/index.json:9:    \"description\" : \"jsonschema-module-swagger-2 is an extension for victools/jsonschema-generator that reads Swagger Core 2.x annotations while producing JSON Schema from Java types. It maps annotation metadata such as descriptions, titles, references, composition, required flags, nullability, defaults, access modes, formats, patterns, numeric bounds, and array constraints into generated schema attributes.\",\nmetadata/com.github.victools/jsonschema-module-swagger-2/index.json:14:      \"com.github.victools.jsonschema.module.swagger2\"\nmetadata/com.github.java-json-tools/json-patch/1.13/reachability-metadata.json:65:            \"com.fasterxml.jackson.databind.JsonNode\"\nmetadata/com.github.java-json-tools/json-patch/1.13/reachability-metadata.json:124:            \"com.fasterxml.jackson.databind.JsonNode\"\nmetadata/com.github.java-json-tools/json-patch/1.13/reachability-metadata.json:139:            \"com.fasterxml.jackson.databind.JsonNode\"\nmetadata/io.fabric8/zjsonpatch/index.json:9:    \"description\" : \"zjsonpatch is Fabric8's Java library for applying RFC 6902 JSON Patch operations and generating diffs between Jackson JsonNode trees. It supports patch application, diff generation, and JSON Pointer path handling for JSON documents in JVM applications.\",\n"}], "isError": false, "timestamp": 1782595022992}}
