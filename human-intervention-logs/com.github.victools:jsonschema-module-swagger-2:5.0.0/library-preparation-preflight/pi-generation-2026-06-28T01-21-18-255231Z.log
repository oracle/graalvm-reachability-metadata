\n            </plugin>\n            <plugin>\n                <artifactId>maven-source-plugin</artifactId>\n            </plugin>\n            <plugin>\n                <artifactId>maven-javadoc-plugin</artifactId>\n            </plugin>\n            <plugin>\n                <groupId>org.moditect</groupId>\n                <artifactId>moditect-maven-plugin</artifactId>\n            </plugin>\n        </plugins>\n    </build>\n\n</project>\n\n\n--- https://repo1.maven.org/maven2/com/github/victools/jsonschema-generator/5.0.0/jsonschema-generator-5.0.0.pom\n<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<project xmlns=\"http://maven.apache.org/POM/4.0.0\" xmlns:xsi=\"http://www.w3.org/2001/XMLSchema-instance\" xsi:schemaLocation=\"http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd\">\n    <modelVersion>4.0.0</modelVersion>\n\n    <parent>\n        <groupId>com.github.victools</groupId>\n        <artifactId>jsonschema-generator-parent</artifactId>\n        <version>5.0.0</version>\n        <relativePath>../jsonschema-generator-parent/pom.xml</relativePath>\n    </parent>\n    <artifactId>jsonschema-generator</artifactId>\n    \n    <name>Java JSON Schema Generator</name>\n    <description>Java JSON Schema Generator – creating a JSON Schema (Draft 6, Draft 7 or Draft 2019-09) from your Java classes</description>\n    <url>https://github.com/victools/jsonschema-generator</url>\n\n    <properties>\n        <java.module.name>com.github.victools.jsonschema.generator</java.module.name>\n    </properties>\n\n    <dependencies>\n        <dependency>\n            <groupId>com.fasterxml</groupId>\n            <artifactId>classmate</artifactId>\n        </dependency>\n        <dependency>\n            <groupId>tools.jackson.core</groupId>\n            <artifactId>jackson-core</artifactId>\n        </dependency>\n        <dependency>\n            <groupId>tools.jackson.core</groupId>\n            <artifactId>jackson-databind</artifactId>\n        </dependency>\n    </dependencies>\n\n    <build>\n        <plugins>\n            <plugin>\n                <artifactId>maven-compiler-plugin</artifactId>\n            </plugin>\n            <plugin>\n                <artifactId>maven-checkstyle-plugin</artifactId>\n            </plugin>\n            <plugin>\n                <artifactId>maven-source-plugin</artifactId>\n            </plugin>\n            <plugin>\n                <artifactId>maven-javadoc-plugin</artifactId>\n            </plugin>\n            <plugin>\n                <groupId>org.moditect</groupId>\n                <artifactId>moditect-maven-plugin</artifactId>\n            </plugin>\n        </plugins>\n    </build>\n\n</project>\n\n\n--- https://repo1.maven.org/maven2/com/github/victools/jsonschema-generator-bom/5.0.0/jsonschema-generator-bom-5.0.0.pom\n<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<project xmlns=\"http://maven.apache.org/POM/4.0.0\" xmlns:xsi=\"http://www.w3.org/2001/XMLSchema-instance\" xsi:schemaLocation=\"http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd\">\n    <modelVersion>4.0.0</modelVersion>\n\n    <name>Java JSON Schema Generator (BOM)</name>\n    <description>Bill of Materials for the Java JSON Schema Generator and its (standard) Modules</description>\n    <url>https://github.com/victools/jsonschema-generator</url>\n\n    <groupId>com.github.victools</groupId>\n    <artifactId>jsonschema-generator-bom</artifactId>\n    <version>5.0.0</version>\n    <packaging>pom</packaging>\n\n    <properties>\n        <signAndStage.skip>true</signAndStage.skip>\n    </properties>\n\n    <licenses>\n        <license>\n            <name>The Apache License, Version 2.0</name>\n            <url>http://www.apache.org/licenses/LICENSE-2.0.txt</url>\n        </license>\n    </licenses>\n\n    <scm>\n        <connection>scm:git:https://github.com/victools/jsonschema-generator.git</connection>\n        <developerConnection>scm:git:https://github.com/victools/jsonschema-generator.git</developerConnection>\n        <url>https://github.com/victools/jsonschema-generator</url>\n        <tag>HEAD</tag>\n    </scm>\n\n    <organization>\n        <name>VicTools</name>\n        <url>https://github.com/victools</url>\n    </organization>\n\n    <developers>\n        <developer>\n            <id>CarstenWickner</id>\n            <name>Carsten Wickner</name>\n        </developer>\n    </developers>\n\n    <distributionManagement>\n        <snapshotRepository>\n            <id>ossrh</id>\n            <url>https://oss.sonatype.org/content/repositories/snapshots</url>\n        </snapshotRepository>\n        <repository>\n            <id>ossrh</id>\n            <url>https://oss.sonatype.org/service/local/staging/deploy/maven2/</url>\n        </repository>\n    </distributionManagement>\n\n    <dependencyManagement>\n        <dependencies>\n            <dependency>\n                <groupId>com.github.victools</groupId>\n                <artifactId>jsonschema-generator</artifactId>\n                <version>${project.version}</version>\n            </dependency>\n            <dependency>\n                <groupId>com.github.victools</groupId>\n                <artifactId>jsonschema-module-jackson</artifactId>\n                <version>${project.version}</version>\n            </dependency>\n            <dependency>\n                <groupId>com.github.victools</groupId>\n                <artifactId>jsonschema-module-jakarta-validation</artifactId>\n                <version>${project.version}</version>\n            </dependency>\n            <dependency>\n                <groupId>com.github.victools</groupId>\n                <artifactId>jsonschema-module-javax-validation</artifactId>\n                <version>${project.version}</version>\n            </dependency>\n            <dependency>\n                <groupId>com.github.victools</groupId>\n                <artifactId>jsonschema-module-swagger-1.5</artifactId>\n                <version>${project.version}</version>\n            </dependency>\n            <dependency>\n                <groupId>com.github.victools</groupId>\n                <artifactId>jsonschema-module-swagger-2</artifactId>\n                <version>${project.version}</version>\n            </dependency>\n        </dependencies>\n    </dependencyManagement>\n\n    <build>\n        <plugins>\n            <plugin>\n                <groupId>org.apache.maven.plugins</groupId>\n                <artifactId>maven-gpg-plugin</artifactId>\n                <version>1.6</version>\n                <executions>\n                    <execution>\n                        <id>sign-artifacts</id>\n                        <phase>verify</phase>\n                        <goals>\n                            <goal>sign</goal>\n                        </goals>\n                    </execution>\n                </executions>\n                <configuration>\n                    <skip>${signAndStage.skip}</skip>\n                </configuration>\n            </plugin>\n            <plugin>\n                <groupId>org.sonatype.central</groupId>\n                <artifactId>central-publishing-maven-plugin</artifactId>\n                <version>0.10.0</version>\n                <extensions>true</extensions>\n                <configuration>\n                    <publishingServerId>central</publishingServerId>\n                    <autoPublish>true</autoPublish>\n                    <skipPublishing>${signAndStage.skip}</skipPublishing>\n                    <waitUntil>published</waitUntil>\n                </configuration>\n            </plugin>\n        </plugins>\n    </build>\n</project>\n\n"}], "isError": false, "timestamp": 1782609625508}]}
