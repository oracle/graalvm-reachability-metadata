[tool-call] delta {"path":"tests/src/io.ous/jtoml/2.0.0/src/test/java/io_ous/jtoml/ObjectDeserializerTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_ous.jtoml;\n\nimport io.ous.jtoml.JToml;\nimport io.ous.jtoml.Toml;\n\nimport java.util.List;\n\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ObjectDeserializerTest {\n    @Test\n    void deserializesTomlTableIntoObjectGraph() {\n        Toml toml = JToml.parseString(\"\"\"\n                title = \"payments\"\n                enabled = true\n                maxConnections = 42\n                loadFactor = 0.75\n                tags = [\"api\", \"billing\"]\n                mode = \"WRITE\"\n\n                [database]\n                host = \"localhost\"\n                port = 5432\n                \"\"\");\n\n        ApplicationConfig config = toml.asObject(ApplicationConfig.class);\n\n        assertThat(config.getTitle()).isEqualTo(\"payments\");\n        assertThat(config.getEnabled()).isTrue();\n        assertThat(config.getMaxConnections()).isEqualTo(42L);\n        assertThat(config.getLoadFactor()).isEqualTo(0.75D);\n        assertThat(config.getTags()).containsExactly(\"api\", \"billing\");\n        assertThat(config.getMode()).isEqualTo(Mode.WRITE);\n        assertThat(config.getDatabase().getHost()).isEqualTo(\"localhost\");\n        assertThat(config.getDatabase().getPort()).isEqualTo(5432L);\n    }\n\n    public enum Mode {\n        READ,\n        WRITE\n    }\n\n    public static class BaseConfig {\n        private String title;\n\n        public String getTitle() {\n            return title;\n        }\n    }\n\n    public static class ApplicationConfig extends BaseConfig {\n        private Boolean enabled;\n        private Long maxConnections;\n        private Double loadFactor;\n        private List<String> tags;\n        private Mode mode;\n        private DatabaseConfig database;\n\n        public Boolean getEnabled() {\n            return enabled;\n        }\n\n        public Long getMaxConnections() {\n            return maxConnections;\n        }\n\n        public Double getLoadFactor() {\n            return loadFactor;\n        }\n\n        public List<String> getTags() {\n            return tags;\n        }\n\n        public Mode getMode() {\n            return mode;\n        }\n\n        public DatabaseConfig getDatabase() {\n            return database;\n        }\n    }\n\n    public static class DatabaseConfig {\n        private String host;\n        private Long port;\n\n        public String getHost() {\n            return host;\n        }\n\n        public Long getPort() {\n            return port;\n        }\n    }\n}\n"}
