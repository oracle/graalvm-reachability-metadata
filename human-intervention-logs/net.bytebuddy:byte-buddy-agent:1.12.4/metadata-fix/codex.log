 throw new ClassNotFoundException(name);\n            }\n            return super.loadClass(name);\n        }\n\n        boolean failedInitialLoad() {\n            return failed;\n        }\n    }\n}\n\nclass ClassLoaderClassResolverTarget {\n}\n","exit_code":0,"status":"completed"}}
