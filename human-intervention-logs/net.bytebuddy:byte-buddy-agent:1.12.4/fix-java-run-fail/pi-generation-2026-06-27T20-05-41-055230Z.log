agent/1.12.4/src/test/java/net_bytebuddy/byte_buddy_agent/ByteBuddyAgentTest.java\n+++ w/tests/src/net.bytebuddy/byte-buddy-agent/1.12.4/src/test/java/net_bytebuddy/byte_buddy_agent/ByteBuddyAgentTest.java\n@@ -8,32 +8,48 @@ package net_bytebuddy.byte_buddy_agent;\n \n import net.bytebuddy.agent.ByteBuddyAgent;\n import net.bytebuddy.agent.Installer;\n+import org.graalvm.internal.tck.NativeImageSupport;\n import org.junit.jupiter.api.AfterAll;\n import org.junit.jupiter.api.BeforeAll;\n import org.junit.jupiter.api.BeforeEach;\n import org.junit.jupiter.api.Test;\n import org.junit.jupiter.api.io.TempDir;\n \n+import java.io.ByteArrayOutputStream;\n+import java.io.DataOutputStream;\n import java.io.File;\n import java.io.IOException;\n import java.lang.instrument.ClassDefinition;\n import java.lang.instrument.ClassFileTransformer;\n import java.lang.instrument.Instrumentation;\n import java.lang.instrument.UnmodifiableClassException;\n+import java.lang.invoke.MethodHandle;\n+import java.lang.invoke.MethodHandles;\n+import java.lang.invoke.MethodType;\n+import java.lang.module.Configuration;\n+import java.lang.module.ModuleFinder;\n+import java.lang.module.ModuleReference;\n+import java.net.URI;\n import java.nio.file.Files;\n import java.nio.file.Path;\n+import java.nio.file.Paths;\n+import java.security.CodeSource;\n import java.util.Collections;\n import java.util.List;\n import java.util.Map;\n import java.util.Set;\n+import java.util.jar.JarEntry;\n import java.util.jar.JarFile;\n+import java.util.jar.JarOutputStream;\n \n import static org.assertj.core.api.Assertions.assertThat;\n import static org.assertj.core.api.Assertions.assertThatThrownBy;\n+import static org.assertj.core.api.Assertions.fail;\n \n public class ByteBuddyAgentTest {\n     private static final String ALLOW_SELF_ATTACH = \"jdk.attach.allowAttachSelf\";\n     private static final String JAVA_HOME = \"java.home\";\n+    private static final String ISOLATED_MODULE_NAME = \"isolated.bytebuddy.agent\";\n \n     private static String originalAllowSelfAttach;\n \n@@ -69,6 +85,21 @@ public class ByteBuddyAgentTest {\n         assertThat(ByteBuddyAgent.getInstrumentation()).isSameAs(instrumentation);\n     }\n \n+    /// Loads Byte Buddy Agent as a named module while the installer remains in the system loader.\n+    @Test\n+    void getInstrumentationAddsReadEdgeToSystemInstallerModule(@TempDir Path temporaryDirectory) throws Throwable {\n+        try {\n+            getInstrumentationFromIsolatedAgentModule(temporaryDirectory);\n+            fail(\"Expected isolated Byte Buddy agent to report unavailable instrumentation\");\n+        } catch (IllegalStateException exception) {\n+            assertThat(exception).hasMessageContaining(\"not initialized\");\n+        } catch (Error error) {\n+            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n+                throw error;\n+            }\n+        }\n+    }\n+\n     @Test\n     void externalAttachmentCopiesAttacherClassResource(@TempDir Path temporaryDirectory) throws IOException {\n         Path agentJar = Files.createFile(temporaryDirectory.resolve(\"agent.jar\"));\n@@ -88,6 +119,153 @@ public class ByteBuddyAgentTest {\n         }\n     }\n \n+    private static Object getInstrumentationFromIsolatedAgentModule(Path temporaryDirectory) throws Throwable {\n+        Path agentJar = createExplicitModuleAgentJar(temporaryDirectory);\n+        ModuleFinder finder = ModuleFinder.of(agentJar);\n+        ModuleReference moduleReference = finder.find(ISOLATED_MODULE_NAME)\n+                .orElseThrow(() -> new IllegalStateException(\"Byte Buddy agent module was not found\"));\n+        String moduleName = moduleReference.descriptor().name();\n+        Configuration configuration = ModuleLayer.boot()\n+                .configuration()\n+                .resolve(finder, ModuleFinder.of(), Set.of(moduleName));\n+        ModuleLayer moduleLayer = ModuleLayer.boot()\n+                .defineModulesWithOneLoader(configuration, ClassLoader.getPlatformClassLoader());\n+        Class<?> agentType = moduleLayer.findLoader(moduleName).loadClass(ByteBuddyAgent.class.getName());\n+        Module sourceModule = agentType.getModule();\n+        Module installerModule = Installer.class.getModule();\n+        assertThat(sourceModule.canRead(installerModule)).isFalse();\n+        MethodHandle getInstrumentation = MethodHandles.lookup()\n+                .findStatic(agentType, \"getInstrumentation\", MethodType.methodType(Instrumentation.class));\n+        try {\n+            return getInstrumentation.invoke();\n+        } finally {\n+            assertThat(sourceModule.canRead(installerModule)).isTrue();\n+        }\n+    }\n+\n+    private static Path createExplicitModuleAgentJar(Path temporaryDirectory) throws Exception {\n+        Path sourceJar = resolveAgentJar();\n+        Path modularJar = temporaryDirectory.resolve(\"byte-buddy-agent-explicit-module.jar\");\n+        try (JarFile jarFile = new JarFile(sourceJar.toFile());\n+             JarOutputStream output = new JarOutputStream(Files.newOutputStream(modularJar))) {\n+            jarFile.stream().forEach(entry -> copyJarEntry(jarFile, output, entry));\n+            JarEntry moduleInfo = new JarEntry(\"module-info.class\");\n+            output.putNextEntry(moduleInfo);\n+            output.write(moduleInfoClass());\n+            output.closeEntry();\n+        }\n+        return modularJar;\n+    }\n+\n+    private static void copyJarEntry(JarFile jarFile, JarOutputStream output, JarEntry entry) {\n+        if (entry.getName().equals(\"module-info.class\")) {\n+            return;\n+        }\n+        try {\n+            JarEntry copy = new JarEntry(entry.getName());\n+            output.putNextEntry(copy);\n+            jarFile.getInputStream(entry).transferTo(output);\n+            output.closeEntry();\n+        } catch (IOException exception) {\n+            throw new IllegalStateException(\"Cannot copy Byte Buddy agent JAR entry \" + entry.getName(), exception);\n+        }\n+    }\n+\n+    private static byte[] moduleInfoClass() throws IOException {\n+        ByteArrayOutputStream output = new ByteArrayOutputStream();\n+        try (DataOutputStream data = new DataOutputStream(output)) {\n+            data.writeInt(0xCAFEBABE);\n+            data.writeShort(0);\n+            data.writeShort(53);\n+            data.writeShort(14);\n+            writeUtf8(data, \"module-info\");\n+            writeClass(data, 1);\n+            writeUtf8(data, \"Module\");\n+            writeUtf8(data, ISOLATED_MODULE_NAME);\n+            writeModule(data, 4);\n+            writeUtf8(data, \"java.base\");\n+            writeModule(data, 6);\n+            writeUtf8(data, \"java.instrument\");\n+            writeModule(data, 8);\n+            writeUtf8(data, \"net/bytebuddy/agent\");\n+            writePackage(data, 10);\n+            writeUtf8(data, \"SourceFile\");\n+            writeUtf8(data, \"module-info.java\");\n+            data.writeShort(0x8000);\n+            data.writeShort(2);\n+            data.writeShort(0);\n+            data.writeShort(0);\n+            data.writeShort(0);\n+            data.writeShort(0);\n+            data.writeShort(0);\n+            data.writeShort(2);\n+            writeModuleAttribute(data);\n+            writeSourceFileAttribute(data);\n+        }\n+        return output.toByteArray();\n+    }\n+\n+    private static void writeModuleAttribute(DataOutputStream data) throws IOException {\n+        data.writeShort(3);\n+        data.writeInt(34);\n+        data.writeShort(5);\n+        data.writeShort(0);\n+        data.writeShort(0);\n+        data.writeShort(2);\n+        data.writeShort(7);\n+        data.writeShort(0x8000);\n+        data.writeShort(0);\n+        data.writeShort(9);\n+        data.writeShort(0);\n+        data.writeShort(0);\n+        data.writeShort(1);\n+        data.writeShort(11);\n+        data.writeShort(0);\n+        data.writeShort(0);\n+        data.writeShort(0);\n+        data.writeShort(0);\n+        data.writeShort(0);\n+    }\n+\n+    private static void writeSourceFileAttribute(DataOutputStream data) throws IOException {\n+        data.writeShort(12);\n+        data.writeInt(2);\n+        data.writeShort(13);\n+    }\n+\n+    private static void writeUtf8(DataOutputStream data, String value) throws IOException {\n+        data.writeByte(1);\n+        data.writeUTF(value);\n+    }\n+\n+    private static void writeClass(DataOutputStream data, int nameIndex) throws IOException {\n+        data.writeByte(7);\n+        data.writeShort(nameIndex);\n+    }\n+\n+    private static void writeModule(DataOutputStream data, int nameIndex) throws IOException {\n+        data.writeByte(19);\n+        data.writeShort(nameIndex);\n+    }\n+\n+    private static void writePackage(DataOutputStream data, int nameIndex) throws IOException {\n+        data.writeByte(20);\n+        data.writeShort(nameIndex);\n+    }\n+\n+    private static Path resolveAgentJar() throws Exception {\n+        CodeSource codeSource = ByteBuddyAgent.class.getProtectionDomain().getCodeSource();\n+        if (codeSource == null) {\n+            throw new IllegalStateException(\"Byte Buddy agent code source is not available\");\n+        }\n+        URI location = codeSource.getLocation().toURI();\n+        Path agentJar = Paths.get(location);\n+        if (!Files.isRegularFile(agentJar)) {\n+            throw new IllegalStateException(\"Byte Buddy agent code source is not a file: \" + agentJar);\n+        }\n+        return agentJar;\n+    }\n+\n     private static void restoreProperty(String name, String value) {\n         if (value == null) {\n             System.clearProperty(name);\n"}], "isError": false, "timestamp": 1782590926817}]}
