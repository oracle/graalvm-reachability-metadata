[tool-call] delta {"path":"tests/src/net.bytebuddy/byte-buddy-agent/1.12.4/src/test/java/net_bytebuddy/byte_buddy_agent/ByteBuddyAgentTest.java","edits":[{"oldText":"import net.bytebuddy.agent.ByteBuddyAgent;\nimport net.bytebuddy.agent.Installer;\nimport org.junit.jupiter.api.AfterAll;\n","newText":"import net.bytebuddy.agent.ByteBuddyAgent;\nimport net.bytebuddy.agent.Installer;\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.AfterAll;\n"},{"oldText":"import java.io.File;\nimport java.io.IOException;\nimport java.lang.instrument.ClassDefinition;\n","newText":"import java.io.File;\nimport java.io.IOException;\nimport java.lang.instrument.ClassDefinition;\n"},{"oldText":"import java.lang.instrument.ClassFileTransformer;\nimport java.lang.instrument.Instrumentation;\nimport java.lang.instrument.UnmodifiableClassException;\nimport java.nio.file.Files;\nimport java.nio.file.Path;\nimport java.util.Collections;\n","newText":"import java.lang.instrument.ClassFileTransformer;\nimport java.lang.instrument.Instrumentation;\nimport java.lang.instrument.UnmodifiableClassException;\nimport java.lang.invoke.MethodHandle;\nimport java.lang.invoke.MethodHandles;\nimport java.lang.invoke.MethodType;\nimport java.lang.module.Configuration;\nimport java.lang.module.ModuleFinder;\nimport java.lang.module.ModuleReference;\nimport java.net.URI;\nimport java.nio.file.Files;\nimport java.nio.file.Path;\nimport java.nio.file.Paths;\nimport java.security.CodeSource;\nimport java.util.Collections;\n"},{"oldText":"import static org.assertj.core.api.Assertions.assertThat;\nimport static org.assertj.core.api.Assertions.assertThatThrownBy;\n","newText":"import static org.assertj.core.api.Assertions.assertThat;\nimport static org.assertj.core.api.Assertions.assertThatThrownBy;\nimport static org.assertj.core.api.Assertions.fail;\n"},{"oldText":"    @Test\n    void getInstrumentationInvokesInstallerMethodSuccessfully() {\n        Instrumentation instrumentation = new RecordingInstrumentation();\n\n        Installer.premain(null, instrumentation);\n\n        assertThat(ByteBuddyAgent.getInstrumentation()).isSameAs(instrumentation);\n    }\n\n    @Test\n    void externalAttachmentCopiesAttacherClassResource(@TempDir Path temporaryDirectory) throws IOException {\n","newText":"    @Test\n    void getInstrumentationInvokesInstallerMethodSuccessfully() {\n        Instrumentation instrumentation = new RecordingInstrumentation();\n\n        Installer.premain(null, instrumentation);\n\n        assertThat(ByteBuddyAgent.getInstrumentation()).isSameAs(instrumentation);\n    }\n\n    @Test\n    void getInstrumentationAddsReadEdgeToSystemInstallerModule() throws Throwable {\n        try {\n            getInstrumentationFromIsolatedAgentModule();\n            fail(\"Expected isolated Byte Buddy agent to report unavailable instrumentation\");\n        } catch (IllegalStateException exception) {\n            assertThat(exception).hasMessageContaining(\"not initialized\");\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    @Test\n    void externalAttachmentCopiesAttacherClassResource(@TempDir Path temporaryDirectory) throws IOException {\n"},{"oldText":"    private static void restoreProperty(String name, String value) {\n        if (value == null) {\n            System.clearProperty(name);\n        } else {\n            System.setProperty(name, value);\n        }\n    }\n\n    private static final class AlwaysExternalAttachmentProvider implements ByteBuddyAgent.AttachmentProvider {\n","newText":"    private static Object getInstrumentationFromIsolatedAgentModule() throws Throwable {\n        Path agentJar = resolveAgentJar();\n        ModuleFinder finder = ModuleFinder.of(agentJar);\n        ModuleReference moduleReference = finder.findAll().stream()\n                .findFirst()\n                .orElseThrow(() -> new IllegalStateException(\"Byte Buddy agent module was not found\"));\n        String moduleName = moduleReference.descriptor().name();\n        Configuration configuration = ModuleLayer.boot()\n                .configuration()\n                .resolve(finder, ModuleFinder.of(), Set.of(moduleName));\n        ModuleLayer moduleLayer = ModuleLayer.boot()\n                .defineModulesWithOneLoader(configuration, ClassLoader.getPlatformClassLoader());\n        Class<?> agentType = moduleLayer.findLoader(moduleName).loadClass(ByteBuddyAgent.class.getName());\n        MethodHandle getInstrumentation = MethodHandles.publicLookup()\n                .findStatic(agentType, \"getInstrumentation\", MethodType.methodType(Instrumentation.class));\n        return getInstrumentation.invoke();\n    }\n\n    private static Path resolveAgentJar() throws Exception {\n        CodeSource codeSource = ByteBuddyAgent.class.getProtectionDomain().getCodeSource();\n        if (codeSource == null) {\n            throw new IllegalStateException(\"Byte Buddy agent code source is not available\");\n        }\n        URI location = codeSource.getLocation().toURI();\n        Path agentJar = Paths.get(location);\n        if (!Files.isRegularFile(agentJar)) {\n            throw new IllegalStateException(\"Byte Buddy agent code source is not a file: \" + agentJar);\n        }\n        return agentJar;\n    }\n\n    private static void restoreProperty(String name, String value) {\n        if (value == null) {\n            System.clearProperty(name);\n        } else {\n            System.setProperty(name, value);\n        }\n    }\n\n    private static final class AlwaysExternalAttachmentProvider implements ByteBuddyAgent.AttachmentProvider {\n"}]}
