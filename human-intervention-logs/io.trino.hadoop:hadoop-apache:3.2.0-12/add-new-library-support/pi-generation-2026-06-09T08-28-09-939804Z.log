h = fileSystem.getFileStatus(file).getLen();\n            try (FSDataInputStream inputStream = fileSystem.open(file);\n                    SequenceFile.Reader reader = new SequenceFile.Reader(\n                            conf,\n                            SequenceFile.Reader.stream(inputStream),\n                            SequenceFile.Reader.length(fileLength))) {\n                Text key = new Text();\n                IntWritable value = new IntWritable();\n\n                reader.sync(syncPosition);\n\n                assertThat(reader.next(key, value)).isTrue();\n                assertThat(key.toString()).isEqualTo(\"after-sync\");\n                assertThat(value.get()).isEqualTo(2);\n                assertThat(reader.next(key, value)).isFalse();\n            }\n        }\n    }\n\n"}]}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 1221, "output": 1083, "cacheRead": 34304, "cacheWrite": 0, "totalTokens": 36608, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780993733139, "responseId": "resp_0a507e0d22a3646a016a27cec5ae348197a2fddac54361af94"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_qa0G7KFh61ZAX0FFbBeMTuij|fc_0a507e0d22a3646a016a27cecb90608197a7197a016e064460", "toolName": "edit", "content": [{"type": "text", "text": "Successfully replaced 2 block(s) in tests/src/io.trino.hadoop/hadoop-apache/3.2.0-12/src/test/java/io_trino_hadoop/hadoop_apache/SequenceFileTest.java."}], "details": {"diff": "     ...\n   8 \n   9 import static org.assertj.core.api.Assertions.assertThat;\n  10 \n  11 import java.net.URI;\n- 12 import java.util.ArrayList;\n- 13 import java.util.List;\n  14 \n  15 import org.apache.hadoop.conf.Configuration;\n  16 import org.apache.hadoop.fs.FSDataInputStream;\n  17 import org.apache.hadoop.fs.FSDataOutputStream;\n     ...\n  27     @TempDir\n  28     java.nio.file.Path tempDir;\n  29 \n  30     @Test\n- 3