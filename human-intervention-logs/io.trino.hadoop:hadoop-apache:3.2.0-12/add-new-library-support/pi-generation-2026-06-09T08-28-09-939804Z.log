[tool-call] delta {"path":"tests/src/io.trino.hadoop/hadoop-apache/3.2.0-12/src/test/java/io_trino_hadoop/hadoop_apache/SequenceFileTest.java","edits":[{"oldText":"import java.net.URI;\nimport java.util.ArrayList;\nimport java.util.List;\n\nimport org.apache.hadoop.conf.Configuration;","newText":"import java.net.URI;\n\nimport org.apache.hadoop.conf.Configuration;"},{"oldText":"    @Test\n    void sorterOrdersWritableComparableKeys() throws Exception {\n        Configuration conf = new Configuration(false);\n        Path input = new Path(tempDir.resolve(\"unsorted-records.seq\").toUri());\n        Path sorted = new Path(tempDir.resolve(\"sorted-records.seq\").toUri());\n\n        try (RawLocalFileSystem fileSystem = createRawLocalFileSystem(conf)) {\n            try (FSDataOutputStream outputStream = fileSystem.create(input, true);\n                    SequenceFile.Writer writer = SequenceFile.createWriter(\n                            conf,\n                            SequenceFile.Writer.stream(outputStream),\n                            SequenceFile.Writer.keyClass(Text.class),\n                            SequenceFile.Writer.valueClass(IntWritable.class),\n                            SequenceFile.Writer.compression(SequenceFile.CompressionType.NONE))) {\n                writer.append(new Text(\"charlie\"), new IntWritable(3));\n                writer.append(new Text(\"alpha\"), new IntWritable(1));\n                writer.append(new Text(\"bravo\"), new IntWritable(2));\n            }\n\n            SequenceFile.Sorter sorter = new SequenceFile.Sorter(\n                    fileSystem,\n                    Text.class,\n                    IntWritable.class,\n                    conf);\n            sorter.sort(input, sorted);\n\n            List<String> records = new ArrayList<>();\n            long fileLength = fileSystem.getFileStatus(sorted).getLen();\n            try (FSDataInputStream inputStream = fileSystem.open(sorted);\n                    SequenceFile.Re