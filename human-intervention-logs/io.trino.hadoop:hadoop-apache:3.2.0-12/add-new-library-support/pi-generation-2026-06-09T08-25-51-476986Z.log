                  assertThat(value.get()).isEqualTo(1);
  
                  assertThat(reader.next(key, value)).isTrue();
                  assertThat(key.toString()).isEqualTo("two");
                  assertThat(value.get()).isEqualTo(2);
  
                  assertThat(reader.next(key, value)).isFalse();
              }
