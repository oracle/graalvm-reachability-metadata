          assertThat(aclEntries).hasSize(4);
          assertThat(AclEntry.aclSpecToString(aclEntries)).contains("user:analytics:r--");
  
          Text text = new Text("hello");
          byte[] suffix = " π".getBytes(StandardCharsets.UTF_8);
  
