nseProto.class);\n\n        Object result = ObjectWritable.readObject(\n                new DataInputStream(new ByteArrayInputStream(serialized)),\n                null);\n\n        assertThat(result).isEqualTo(message);\n    }\n\n    private static byte[] serialize(Object instance, Class<?> declaredClass) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        DataOutputStream output = new DataOutputStream(bytes);\n        ObjectWritable.writeObject(output, instance, declaredClass, null);\n        output.flush();\n        return bytes.toByteArray();\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 860, "output": 666, "cacheRead": 73728, "cacheWrite": 0, "totalTokens": 75254, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780993110534, "responseId": "resp_0e7f1898e0bf9500016a27cc57333c81939dfd40689ed57994"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_ApJcey9RXE3lHbQclf9juZSD|fc_0e7f1898e0bf9500016a27cc5c612481939013703d12c00a0e", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2007 bytes to tests/src/io.trino.hadoop/hadoop-apache/3.2.0-12/src/test/java/io_trino_hadoop/hadoop_apache/ObjectWritableTest.java"}], "isError": false, "timestamp": 1780993122983}]}
