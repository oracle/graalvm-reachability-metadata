 metadata.set(new Text(\"source\"), new Text(\"unit-test\"));\n\n        try (SequenceFile.Writer writer = SequenceFile.createWriter(\n                conf,\n                SequenceFile.Writer.file(file),\n                SequenceFile.Writer.keyClass(Text.class),\n                SequenceFile.Writer.valueClass(IntWritable.class),\n                SequenceFile.Writer.metadata(metadata),\n                SequenceFile.Writer.compression(SequenceFile.CompressionType.NONE))) {\n            writer.append(new Text(\"one\"), new IntWritable(1));\n            writer.append(new Text(\"two\"), new IntWritable(2));\n        }\n\n        try (SequenceFile.Reader reader = new SequenceFile.Reader(conf, SequenceFile.Reader.file(file))) {\n            Text key = new Text();\n            IntWritable value = new IntWritable();\n\n            assertThat(reader.getKeyClass()).isEqualTo(Text.class);\n            assertThat(reader.getValueClass()).isEqualTo(IntWritable.class);\n            assertThat(reader.getMetadata().get(new Text(\"source\"))).isEqualTo(new Text(\"unit-test\"));\n\n            assertThat(reader.next(key, value)).isTrue();\n            assertThat(key.toString()).isEqualTo(\"one\");\n            assertThat(value.get()).isEqualTo(1);\n\n            assertThat(reader.next(key, value)).isTrue();\n            assertThat(key.toString()).isEqualTo(\"two\");\n            assertThat(value.get()).isEqualTo(2);\n\n            assertThat(reader.next(key, value)).isFalse();\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 834, "output": 705, "cacheRead": 49152, "cacheWrite": 0, "totalTokens": 50691, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780992883768, "responseId": "resp_0e7f1898e0bf9500016a27cb745e9c81939b6d5d1addcf8ccb"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_RDp8UiwAeVa4KIfoVphrNWDf|fc_0e7f1898e0bf9500016a27cb7