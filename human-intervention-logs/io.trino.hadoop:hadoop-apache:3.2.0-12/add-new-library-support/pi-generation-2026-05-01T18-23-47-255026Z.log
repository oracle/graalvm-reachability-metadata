n\n            Text closestValue = new Text();\n            assertThat(reader.getClosest(new IntWritable(25), closestValue)).isEqualTo(new IntWritable(30));\n            assertThat(closestValue.toString()).isEqualTo(\"thirty\");\n            assertThat(reader.getClosest(new IntWritable(25), closestValue, true)).isEqualTo(new IntWritable(20));\n            assertThat(closestValue.toString()).isEqualTo(\"twenty\");\n\n            IntWritable key = new IntWritable();\n            Text scannedValue = new Text();\n            assertThat(reader.seek(new IntWritable(30))).isTrue();\n            assertThat(reader.next(key, scannedValue)).isTrue();\n            assertThat(key).isEqualTo(new IntWritable(30));\n            assertThat(scannedValue.toString()).isEqualTo(\"thirty\");\n\n            IntWritable finalKey = new IntWritable();\n            reader.finalKey(finalKey);\n            assertThat(finalKey).isEqualTo(new IntWritable(40));\n        }\n    }\n\n    @Test\n    void tFileStoresSortedRecordsAndNamedMetaBlocks() throws Exception {"}]}
