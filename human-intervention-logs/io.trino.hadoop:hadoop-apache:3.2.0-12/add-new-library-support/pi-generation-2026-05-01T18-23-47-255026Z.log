[tool-call] delta {"path":"tests/src/io.trino.hadoop/hadoop-apache/3.2.0-12/src/test/java/io_trino_hadoop/hadoop_apache/Hadoop_apacheTest.java","edits":[{"oldText":"import org.apache.hadoop.io.IntWritable;\nimport org.apache.hadoop.io.SequenceFile;","newText":"import org.apache.hadoop.io.IntWritable;\nimport org.apache.hadoop.io.MapFile;\nimport org.apache.hadoop.io.SequenceFile;"},{"oldText":"    @Test\n    void tFileStoresSortedRecordsAndNamedMetaBlocks() throws Exception {","newText":"    @Test\n    void mapFileSupportsIndexedSortedLookupAndForwardScanning() throws Exception {\n        Configuration configuration = hadoopConfiguration();\n        Path directory = new Path(new File(temporaryDirectory, \"records.map\").toURI());\n\n        try (MapFile.Writer writer = new MapFile.Writer(\n                configuration,\n                directory,\n                MapFile.Writer.keyClass(IntWritable.class),\n                MapFile.Writer.valueClass(Text.class),\n                MapFile.Writer.compression(SequenceFile.CompressionType.NONE))) {\n            writer.setIndexInterval(1);\n            writer.append(new IntWritable(10), new Text(\"ten\"));\n            writer.append(new IntWritable(20), new Text(\"twenty\"));\n            writer.append(new IntWritable(30), new Text(\"thirty\"));\n            writer.append(new IntWritable(40), new Text(\"forty\"));\n        }\n\n        try (MapFile.Reader reader = new MapFile.Reader(directory, configuration)) {\n            Text value = new Text();\n            assertThat(reader.getKeyClass()).isEqualTo(IntWritable.class);\n            assertThat(reader.getValueClass()).isEqualTo(Text.class);\n            assertThat(reader.get(new IntWritable(20), value)).isSameAs(value);\n            assertThat(value.toString()).isEqualTo(\"twenty\");\n            assertThat(reader.get(new IntWritable(25), new Text())).isNull();\n\n            Text closestValue = new Text();\n            assertThat(reader.getClosest(new IntWritable(25), closestValue)).isEqualTo(new IntWritable(30));\n            assertThat(closestValue.toString()).isEqualTo(\"thirty\");\n            assertThat(reader.getClosest(new IntWritable(25), closestValue, true)).isEqualTo(new IntWritable(20));\n            assertThat(closestValue.toString()).isEqualTo(\"twenty\");\n\n            IntWritable key = new IntWritable();\n            Text scannedValue = new Text();\n            assertThat(reader.seek(new IntWritable(30))).isTrue();\n            assertThat(reader.next(key, scannedValue)).isTrue();\n            assertThat(key).isEqualTo(new IntWritable(30));\n            assertThat(scannedValue.toString()).isEqualTo(\"thirty\");\n\n            IntWritable finalKey = new IntWritable();\n            reader.finalKey(finalKey);\n            assertThat(finalKey).isEqualTo(new IntWritable(40));\n        }\n    }\n\n    @Test\n    void tFileStoresSortedRecordsAndNamedMetaBlocks() throws Exception {"}]}
