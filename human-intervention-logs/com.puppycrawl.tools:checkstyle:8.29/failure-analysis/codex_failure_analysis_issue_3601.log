g file is an array of entries\\n    private List<Map<String, Object>> getConfigEntries(File file) {\\n        return ((List<Object>) new JsonSlurper()\\n                .parse(file))\\n                .stream()\\n                .map(e -> (Map<String, Object>) e)\\n                .collect(Collectors.toList());\\n    }\\n\\n    private boolean containsDuplicatedEntries(JsonNode entries, String sectionName, File file) {\\n        if (!entries.isArray() || entries.isEmpty()) {\\n            return false;\\n        }\\n\\n        Map<JsonNode, Integer> duplicates = new LinkedHashMap<>();\\n        entries.forEach(entry -> duplicates.merge(entry, 1, Integer::sum));\\n\\n        boolean containsDuplicates = false;\\n\",\"exit_code\":0,\"status\":\"completed\"}}\n{\"type\":\"item.completed\",\"item\":{\"id\":\"item_26\",\"type\":\"agent_message\",\"text\":\"I want to know whether this is an isolated omission or a broader invariant break in the repository. If it’s just this one artifact, the right fix is to restore its metadata-version directory and verify the gate.\"}}\n{\"type\":\"item.started\",\"item\":{\"id\":\"item_27\",\"type\":\"command_execution\",\"command\":\"/usr/bin/bash -lc 'git ls-files metadata/com.typesafe.akka/akka-serialization-jackson_3 tests/src/com.typesafe.akka/akka-serialization-jackson_3'\",\"aggregated_output\":\"\",\"exit_code\":null,\"status\":\"in_progress\"}}\n{\"type\":\"item.completed\",\"item\":{\"id\":\"item_27\",\"type\":\"command_execution\",\"command\":\"/usr/bin/bash -lc 'git ls-files metadata/com.typesafe.akka/akka-serialization-jackson_3 tests/src/com.typesafe.akka/akka-serialization-jackson_3'\",\"aggregated_output\":\"metadata/com.typesafe.akka/akka-serialization-jackson_3/index.json\\ntests/src/com.typesafe.akka/akka-serialization-jackson_3/2.6.21/.gitignore\\ntests/src/com.typesafe.akka/akka-serialization-jackson_3/2.6.21/build.gradle\\ntests/src/com.typesafe.akka/akka-serialization-jackson_3/2.6.21/gradle.properties\\ntests/src/