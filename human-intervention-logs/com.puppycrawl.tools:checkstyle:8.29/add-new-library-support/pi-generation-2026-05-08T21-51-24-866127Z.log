      private ResourceBundle getBundle(String bundleName) {
          return BUNDLE_CACHE.computeIfAbsent(bundleName, name -> {
              return ResourceBundle.getBundle(
                  name, sLocale, sourceClass.getClassLoader(), new Utf8Control());
          });
      }
  
