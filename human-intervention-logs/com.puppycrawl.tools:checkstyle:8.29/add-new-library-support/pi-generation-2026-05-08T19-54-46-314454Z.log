[tool-call] delta {"path":"tests/src/com.puppycrawl.tools/checkstyle/8.29/src/test/java/com_puppycrawl_tools/checkstyle/CommonUtilTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_puppycrawl_tools.checkstyle;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.lang.reflect.Constructor;\nimport java.net.URI;\n\nimport com.puppycrawl.tools.checkstyle.utils.CommonUtil;\nimport org.junit.jupiter.api.Test;\n\npublic class CommonUtilTest {\n    private static final String RESOURCE_NAME = \"com_puppycrawl_tools/checkstyle/common-util-resource.txt\";\n\n    @Test\n    void constructorHelpersCreateNewInstance() {\n        Constructor<StringBuilder> constructor = CommonUtil.getConstructor(StringBuilder.class, String.class);\n\n        StringBuilder builder = CommonUtil.invokeConstructor(constructor, \"created by CommonUtil\");\n\n        assertThat(builder).hasToString(\"created by CommonUtil\");\n    }\n\n    @Test\n    void resolvesAbsoluteClasspathResourceName() throws Exception {\n        URI uri = CommonUtil.getUriByFilename('/' + RESOURCE_NAME);\n\n        assertThat(uri.toString()).contains(\"common-util-resource.txt\");\n    }\n\n    @Test\n    void resolvesRelativeClasspathResourceName() throws Exception {\n        URI uri = CommonUtil.getUriByFilename(RESOURCE_NAME);\n\n        assertThat(uri.toString()).contains(\"common-util-resource.txt\");\n    }\n}\n"}
