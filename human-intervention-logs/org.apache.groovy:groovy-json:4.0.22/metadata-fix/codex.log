eContaining(\"NaN\");\n   187\t\n   188\t        Map<Object, Object> nullKeyMap = new LinkedHashMap<>();\n   189\t        nullKeyMap.put(null, \"value\");\n   190\t        assertThatThrownBy(() -> JsonOutput.toJson(nullKeyMap))\n   191\t                .isInstanceOf(IllegalArgumentException.class)\n   192\t                .hasMessageContaining(\"null keys\");\n   193\t    }\n   194\t\n   195\t    @Test\n   196\t    void customJsonGeneratorHonorsConvertersExclusionsDatesAndUnicode() throws Exception {\n   197\t        UUID uuid = UUID.fromString(\"123e4567-e89b-12d3-a456-426614174000\");\n   198\t        JsonGenerator generator = new JsonGenerator.Options()\n   199\t                .excludeNulls()\n   200\t                .disableUnicodeEscaping()\n   201\t                .dateFormat(\"yyyy-MM-dd\", Locale.US)\n   202\t                .timezone(\"GMT\")\n   203\t                .excludeFieldsByName(\"secret\")\n   204\t                .excludeFieldsByType(URL.class)\n   205\t                .addConverter(UUID.class, new Closure<String>(null) {\n   206\t                    public String doCall(UUID value, String key) {\n   207\t                        return key + \":\" + value.toString().substring(0, 8);\n   208\t                    }\n   209\t                })\n   210\t                .build();\n   211\t\n   212\t        Map<String, Object> nested = new LinkedHashMap<>();\n   213\t        nested.put(\"skip\", null);\n   214\t        nested.put(\"ok\", 1);\n   215\t\n   216\t        List<Object> list = new ArrayList<>();\n   217\t        list.add(null);\n   218\t        list.add(URI.create(\"https://example.org\").toURL());\n   219\t        list.add(\"ok\");\n   220\t\n   221\t        Map<String, Object> input = new LinkedHashMap<>();\n   222\t        input.put(\"keep\", \"žluťoučký kůň\");\n   223\t        input.put(\"missing\", null);\n   224\t        input.put(\"secret\", \"hidden\");\n   225\t        input.put(\"site\", URI.create(\"https://example.com\").toURL(