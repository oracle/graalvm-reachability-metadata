   259\t\n   260\t        JsonBuilder builder = new JsonBuilder();\n   285\t        assertThat(asMap(parsedCatalog.get(\"metadata\")).get(\"version\")).isEqualTo(4);\n   286\t    }\n   287\t\n   288\t    @Test\n   289\t    void streamsJsonDocumentsWithStreamingJsonBuilder() throws Exception {\n   290\t        StringWriter writer = new StringWriter();\n   291\t        StreamingJsonBuilder builder = new StreamingJsonBuilder(writer);\n   292\t\n   293\t        List<Map<String, String>> peopleRows = List.of(\n   294\t                Map.of(\"name\", \"Ada\", \"language\", \"Groovy\"),\n   295\t                Map.of(\"name\", \"Grace\", \"language\", \"COBOL\"));\n   296\t\n   297\t        Map<String, Object> payload = new LinkedHashMap<>();\n   298\t        payload.put(\"message\", \"streamed\");\n   299\t        payload.put(\"answer\", 42);\n   300\t        payload.put(\"raw\", JsonOutput.unescaped(\"{\\\"trusted\\\":true}\"));\n   301\t        payload.put(\"people\", peopleRows);\n   302\t        payload.put(\"values\", List.of(1, 2, 3));\n   303\t\n   304\t        builder.call(payload);\n   305\t\n   306\t        Map<String, Object> parsed = asMap(new JsonSlurper().parseText(writer.toString()));\n   307\t\n   308\t        assertThat(parsed.get(\"message\")).isEqualTo(\"streamed\");\n   309\t        assertThat(((Number) parsed.get(\"answer\")).intValue()).isEqualTo(42);\n   310\t        assertThat(asMap(parsed.get(\"raw\")).get(\"trusted\")).isEqualTo(true);\n   311\t        assertThat(asList(parsed.get(\"people\")))\n   312\t                .extracting(entry -> asMap(entry).get(\"name\"))\n   313\t                .containsExactly(\"Ada\", \"Grace\");\n   314\t        assertThat(asList(parsed.get(\"people\")))\n   315\t                .extracting(entry -> asMap(entry).get(\"language\"))\n   316\t                .containsExactly(\"Groovy\", \"COBOL\");\n   317\t        assertThat(asList(parsed.get(\"values\"))).extracting(Object::toString).containsExactly(\"1\", \"2\", \"3\");\n   318\t    }\n   319\t\n   320\t    @Test\n   321\t    void prettyPrintsLexesAndUnescapesJson() {\n   322\t        String compactJson = \"{\\\"message\\\":\\\"Привет\\\",\\\"items\\\":[1,{\\\"x\\\":true}]}\";\n   323\t\n   324\t        String prettyJson = JsonOutput.prettyPrint(compactJson, true);\n   325\t        JsonLexer lexer = new JsonLexer(new StringReader(compactJson));\n   326\t        List<JsonToken> tokens = new ArrayList<>();\n   327\t        while (lexer.hasNext()) {\n   328\t            tokens.add(lexer.next());\n   329\t        }\n   330\t\n   331\t        assertThat(prettyJson).contains(\"\\\"message\\\": \\\"Привет\\\"\");\n   332\t        assertThat(prettyJson).contains(\"\\n    \\\"items\\\": [\");\n   333\t        assertThat(tokens).extracting(JsonToken::getType).contains(\n   334\t                JsonTokenType.OPEN_CURLY,\n   335\t                JsonTokenType.STRING,\n   336\t                JsonTokenType.COLON,\n   337\t                JsonTokenType.OPEN_BRACKET,\n   338\t                JsonTokenType.TRUE,\n   339\t                JsonTokenType.CLOSE_CURLY);\n   340\t        assertThat(tokens.stream()\n   341\t                .filter(token -> token.getType() == JsonTokenType.STRING)\n   342\t                .findFirst()\n   343\t                .orElseThrow()\n   344\t                .getValue()).isEqualTo(\"message\");\n   345\t        assertThat(JsonLexer.unescape(\"line\\\\nvalue\\\\u0021\")).isEqualTo(\"line\\nvalue!\");\n   346\t    }\n   347\t\n   348\t    @Test\n   349\t    void indexOverlaySlurperConvertsIsoDateStringsWhenDateCheckingIsEnabled() {\n   350\t        String json = \"\"\"\n   351\t                {\n   352\t                    \"utc\":\"1994-11-05T08:15:30Z\",\n   353\t                    \"offset\":\"1994-11-05T08:15:30-05:00\",\n   354\t                    \"millis\":\"2013-12-14T01:55:33.412Z\",\n   355\t                    \"plain\":\"1994-11-05\"\n   356\t                }\n   357\t                \"\"\";\