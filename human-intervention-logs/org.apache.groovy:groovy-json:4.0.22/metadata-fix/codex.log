line\\n unicode ☕\");\n   153\t        payload.put(\"truth\", true);\n   154\t        payload.put(\"count\", 7);\n   155\t        payload.put(\"decimal\", 2.75D);\n   156\t        payload.put(\"uuid\", uuid);\n   157\t        payload.put(\"url\", url);\n   158\t        payload.put(\"raw\", JsonOutput.unescaped(\"{\\\"trusted\\\":true}\"));\n   159\t        payload.put(\"expando\", expando);\n   160\t        payload.put(\"state\", Thread.State.RUNNABLE);\n   161\t        payload.put(\"intArray\", new int[]{1, 2, 3});\n   162\t        payload.put(\"charArray\", new char[]{'a', '\\n'});\n   163\t        payload.put(\"enumeration\", Collections.enumeration(List.of(\"first\", \"second\")));\n   164\t\n   165\t        String json = JsonOutput.toJson(payload);\n   166\t        Map<String, Object> parsed = asMap(new JsonSlurper().parseText(json));\n   167\t\n   168\t        assertThat(parsed.get(\"text\")).isEqualTo(\"quote \\\" slash \\\\ newline\\n unicode ☕\");\n   169\t        assertThat(parsed.get(\"truth\")).isEqualTo(true);\n   170\t        assertThat(((Number) parsed.get(\"count\")).intValue()).isEqualTo(7);\n   171\t        assertThat(parsed.get(\"decimal\").toString()).isEqualTo(\"2.75\");\n   172\t        assertThat(parsed.get(\"uuid\")).isEqualTo(uuid.toString());\n   173\t        assertThat(parsed.get(\"url\")).isEqualTo(url.toString());\n   174\t        assertThat(asMap(parsed.get(\"raw\")).get(\"trusted\")).isEqualTo(true);\n   175\t        assertThat(asMap(parsed.get(\"expando\")).get(\"name\")).isEqualTo(\"dynamic\");\n   176\t        assertThat(asMap(parsed.get(\"expando\")).get(\"active\")).isEqualTo(true);\n   177\t        assertThat(parsed.get(\"state\")).isEqualTo(\"RUNNABLE\");\n   178\t        assertThat(asList(parsed.get(\"intArray\"))).extracting(Object::toString).containsExactly(\"1\", \"2\", \"3\");\n   179\t        assertThat(asList(parsed.get(\"charArray\"))).containsExactly(\"a\", \"\\n\");\n   180\t        assertThat(asList(parsed.get(\"enume