{"type":"item.started","item":{"id":"item_88","type":"command_execution","command":"/usr/bin/bash -lc \"python - <<'PY'\nimport struct, zipfile\nfrom pathlib import Path\njar = Path('/tmp/metadata-forge-gradle/2ee8a0b5be6f7818/caches/modules-2/files-2.1/org.apache.groovy/groovy/4.0.22/a04df669ad2778678072315bc92f10f03362e7d7/groovy-4.0.22.jar')\n\ndef read_utf(data, off):\n    utflen = struct.unpack('>H', data[off:off+2])[0]\n    off += 2\n    b = data[off:off+utflen]\n    off += utflen\n    out = []\n    i = 0\n    while i < utflen:\n        c = b[i]\n        if c >> 7 == 0:\n            out.append(chr(c))\n            i += 1\n        elif (c >> 5) == 0b110:\n            c2 = b[i+1]\n            ch = ((c & 0x1F) << 6) | (c2 & 0x3F)\n            out.append(chr(ch))\n            i += 2\n        else:\n            c2 = b[i+1]\n            c3 = b[i+2]\n            ch = ((c & 0x0F) << 12) | ((c2 & 0x3F) << 6) | (c3 & 0x3F)\n            out.append(chr(ch))\n            i += 3\n    return ''.join(out), off\n\nwith zipfile.ZipFile(jar) as zf:\n    data = zf.read('META-INF/dgminfo')\n\noff = 0\nnames = []\nwhile True:\n    s, off = read_utf(data, off)\n    if s == '':\n        break\n    idx = struct.unpack('>i', data[off:off+4])[0]\n    off += 4\n    names.append((idx, s))\n\nprint('count', len(names))\nfor idx, s in names[:200]:\n    print(f'{idx}\\\\t{s}')\nPY\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
