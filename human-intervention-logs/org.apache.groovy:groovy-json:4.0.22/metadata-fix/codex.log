5\t\n    46\tpublic final class Groovy_jsonTest {\n    47\t    @Test\n    48\t    void parsesStrictJsonWithEachSlurperParserType() {\n    49\t        String json = \"\"\"\n    50\t                {\n    51\t                    \"name\":\"Groovy\",\n    52\t                    \"numbers\":[1,2.5,-3],\n    53\t                    \"enabled\":true,\n    54\t                    \"missing\":null,\n    55\t                    \"nested\":{\"escaped\":\"line\\\\nbreak\",\"unicode\":\"☕\"}\n    56\t                }\n    57\t                \"\"\";\n    58\t\n    59\t        for (JsonParserType parserType : JsonParserType.values()) {\n    60\t            JsonSlurper slurper = new JsonSlurper()\n    61\t                    .setType(parserType)\n    62\t                    .setChop(true)\n    63\t                    .setLazyChop(false)\n    64\t                    .setCheckDates(false);\n    65\t            Map<String, Object> parsed = asMap(slurper.parseText(json));\n    66\t            Map<String, Object> nested = asMap(parsed.get(\"nested\"));\n    67\t            List<?> numbers = asList(parsed.get(\"numbers\"));\n    68\t\n    69\t            assertThat(slurper.getType()).isEqualTo(parserType);\n    70\t            assertThat(slurper.isChop()).isTrue();\n    71\t            assertThat(slurper.isLazyChop()).isFalse();\n    72\t            assertThat(slurper.isCheckDates()).isFalse();\n    73\t            assertThat(parsed.get(\"name\")).isEqualTo(\"Groovy\");\n    74\t            assertThat(((Number) numbers.get(0)).intValue()).isEqualTo(1);\n    75\t            assertThat(numbers.get(1).toString()).isEqualTo(\"2.5\");\n    76\t            assertThat(((Number) numbers.get(2)).intValue()).isEqualTo(-3);\n    77\t            assertThat(parsed.get(\"enabled\")).isEqualTo(true);\n    78\t            assertThat(parsed.get(\"missing\")).isNull();\n    79\t            assertThat(nested.get(\"escaped\")).isEqualTo(\"line\\nbreak\");\n    80\t            assertThat(nested.get(\"unicode\")).isEqualTo(\"☕\");\n    81\t        }\n    82\t    }\n    83\t\n    84\t    @Test\n    85\t    void laxSlurperParsesRelaxedJsonSyntax() {\n    86\t        String relaxedJson = \"\"\"\n    87\t                // LAX mode accepts comments, unquoted object keys, and single-quoted strings.\n    88\t                {\n    89\t                    name: 'Groovy',\n    90\t                    enabled: true,\n    91\t                    nested: {\n    92\t                        description: 'relaxed syntax',\n    93\t                        count: 3\n    94\t                    },\n    95\t                    tags: [\n    96\t                        'json',\n    97\t                        'lax'\n    98\t                    ]\n    99\t                }\n   100\t                \"\"\";\n   101\t\n   102\t        Map<String, Object> parsed = asMap(new JsonSlurper()\n   103\t                .setType(JsonParserType.LAX)\n   104\t                .parseText(relaxedJson));\n   105\t\n   106\t        assertThat(parsed.get(\"name\")).isEqualTo(\"Groovy\");\n   107\t        assertThat(parsed.get(\"enabled\")).isEqualTo(true);\n   108\t        assertThat(asMap(parsed.get(\"nested\")).get(\"description\")).isEqualTo(\"relaxed syntax\");\n   109\t        assertThat(((Number) asMap(parsed.get(\"nested\")).get(\"count\")).intValue()).isEqualTo(3);\n   110\t        assertThat(asList(parsed.get(\"tags\"))).containsExactly(\"json\", \"lax\");\n   111\t    }\n   112\t\n   113\t    @Test\n   114\t    void parsesJsonFromReadersStreamsArraysFilesPathsAndUrls() throws Exception {\n   115\t        String json = \"{\\\"greeting\\\":\\\"héllo\\\",\\\"values\\\":[1,2,3],\\\"nested\\\":{\\\"ok\\\":true}}\";\n   116\t        JsonSlurper slurper = new JsonSlurper();\n   117\t        Path tempFile = Files.createTempFile(\"groovy-json-\", \".json\");\n   118\t\n   119\t        try {\n   120\t            Files.writeString(tempFile, json, StandardCharsets.UTF_8);\n   121\t\n   122\t            asser