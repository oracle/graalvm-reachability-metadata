7\t\n   218\t        Map<String, Object> nested = new LinkedHashMap<>();\n   219\t        nested.put(\"skip\", null);\n   220\t        nested.put(\"ok\", 1);\n   221\t\n   222\t        List<Object> list = new ArrayList<>();\n   223\t        list.add(null);\n   224\t        list.add(URI.create(\"file:/example.org\").toURL());\n   225\t        list.add(\"ok\");\n   226\t\n   227\t        Map<String, Object> input = new LinkedHashMap<>();\n   228\t        input.put(\"keep\", \"žluťoučký kůň\");\n   229\t        input.put(\"missing\", null);\n   230\t        input.put(\"secret\", \"hidden\");\n   231\t        input.put(\"site\", URI.create(\"file:/example.com\").toURL());\n   232\t        input.put(\"id\", uuid);\n   233\t        input.put(\"date\", new Date(0L));\n   234\t        input.put(\"nested\", nested);\n   235\t        input.put(\"list\", list);\n   236\t\n   237\t        String json = generator.toJson(input);\n   238\t        Map<String, Object> parsed = asMap(new JsonSlurper().parseText(json));\n   239\t\n   240\t        assertThat(generator.isExcludingFieldsNamed(\"secret\")).isTrue();\n   241\t        assertThat(generator.isExcludingValues(null)).isTrue();\n   242\t        assertThat(generator.isExcludingValues(URI.create(\"file:/example.net\").toURL())).isTrue();\n   243\t        assertThat(json).contains(\"žluťoučký kůň\");\n   244\t        assertThat(parsed.get(\"keep\")).isEqualTo(\"žluťoučký kůň\");\n   245\t        assertThat(parsed).doesNotContainKeys(\"missing\", \"secret\", \"site\");\n   246\t        assertThat(parsed.get(\"id\")).isEqualTo(\"id:123e4567\");\n   247\t        assertThat(parsed.get(\"date\")).isEqualTo(\"1970-01-01\");\n   248\t        assertThat(asMap(parsed.get(\"nested\"))).doesNotContainKey(\"skip\");\n   249\t        assertThat(asMap(parsed.get(\"nested\")).get(\"ok\")).isEqualTo(1);\n   250\t        assertThat(asList(parsed.get(\"list\"))).containsExactly(\"ok\");\n   251\t    }\n   252\t\n   253\t    @Test\n   254\t    void buildsJsonDocumentsWithJsonBuilder() throws Exception {\n   255\t        List<Map<String, Object>> books = List.of(\n   256\t                Map.of(\"identifier\", 1, \"available\", true),\n   257\t                Map.of(\"identifier\", 2, \"available\", false));\n   258\t\n   259\t        Map<String, Object> catalog = new LinkedHashMap<>();\n   260\t        catalog.put(\"title\", \"Groovy JSON\");\n","exit_code":0,"status":"completed"}}
