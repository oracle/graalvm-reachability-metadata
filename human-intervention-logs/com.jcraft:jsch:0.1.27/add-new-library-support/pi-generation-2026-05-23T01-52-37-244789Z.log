, "isError": false, "timestamp": 1779500988169}, {"role": "toolResult", "toolCallId": "call_LZBChZuwBXGbwvkv2jsuucZl|fc_0009f1ba6b51f0be016a1107bbd1ec8192841d49d6b031f020", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_jcraft.jsch;\n\nimport static org.assertj.core.api.Assertions.assertThatCode;\n\nimport com.jcraft.jsch.JSch;\nimport com.jcraft.jsch.KeyPair;\nimport com.jcraft.jsch.Session;\nimport java.io.ByteArrayOutputStream;\nimport java.io.Closeable;\nimport java.io.DataInputStream;\nimport java.io.IOException;\nimport java.io.OutputStream;\nimport java.math.BigInteger;\nimport java.net.InetAddress;\nimport java.net.ServerSocket;\nimport java.net.Socket;\nimport java.nio.charset.StandardCharsets;\nimport java.nio.file.Files;\nimport java.nio.file.Path;\nimport java.security.KeyPairGenerator;\nimport java.security.MessageDigest;\nimport java.security.PrivateKey;\nimport java.security.SecureRandom;\nimport java.security.Signature;\nimport java.security.interfaces.RSAPublicKey;\nimport java.util.Arrays;\nimport java.util.Properties;\nimport java.util.concurrent.ExecutorService;\nimport java.util.concurrent.Executors;\nimport java.util.concurrent.Future;\nimport java.util.concurrent.TimeUnit;\nimport javax.crypto.Cipher;\nimport javax.crypto.Mac;\nimport javax.crypto.spec.IvParameterSpec;\nimport javax.crypto.spec.SecretKeySpec;\nimport org.junit.jupiter.api.Test;\nimport org.junit.jupiter.api.io.TempDir;\n\npublic class IdentityFileTest {\n    private static final byte[] USER = \"coverage\".getBytes(StandardCharsets.UTF_8);\n    private static final BigInteger GROUP1_P = new BigInteger(\"\"\"\n            FFFFFFFFFFFFFFFFC90FDAA22168C234C4C6628B80DC1CD129024E08\n            8A67CC74020BBEA63B139B22514A08798E3404DDEF9519B3CD3A431B\n            302B0A6DF25F14374FE1356D6D51C245E485B576625E7EC6F44C42E9\n            A637ED6B0BFF5CB6F406B7EDEE386BFB5A899FA5AE9F24117C4B1FE6\n            49286651ECE65381FFFFFFFFFFFFFFFF\n            \"\"\".replaceAll(\"\\\\s\", \"\"), 16);\n    private static final BigInteger GROUP1_G = BigInteger.valueOf(2L);\n\n    @TempDir\n    Path temporaryDirectory;\n\n    @Test\n    void authenticatesWithRsaIdentityFile() throws Exception {\n        authenticateWithIdentity(KeyPair.RSA, \"rsa_identity\");\n    }\n\n    @Test\n    void authenticatesWithDsaIdentityFile() throws Exception {\n        authenticateWithIdentity(KeyPair.DSA, \"dsa_identity\");\n    }\n\n    private void authenticateWithIdentity(int keyType, String fileName) throws Exception {\n        Path identity = temporaryDirectory.resolve(fileName);\n        writeIdentityFile(keyType, identity);\n\n        String expectedAlgorithm = keyType == KeyPair.RSA ? \"ssh-rsa\" : \"ssh-dss\";\n        try (MinimalSshServer server = new MinimalSshServer(expectedAlgorithm)) {\n            JSch jsch = new JSch();\n            jsch.addIdentity(identity.toString());\n\n            Session session = jsch.getSession(new String(USER, StandardCharsets.UTF_8), \"127.0.0.1\", server.port());\n            Properties sessionConfig = new Properties();\n            sessionConfig.setProperty(\"StrictHostKeyChecking\", \"no\");\n            session.setConfig(sessionConfig);\n\n            assertThatCode(() -> session.connect(10_000)).doesNotThrowAnyException();\n            session.disconnect();\n        }\n    }\n\n    private static void writeIdentityFile(int keyType, Path identity) throws Exception {\n        JSch jsch = new JSch();\n        KeyPair keyPair = KeyPair.genKeyPair(jsch, keyType, 1024);\n        try (OutputStream outputStream = Files.newOutputStream(identity)) {\n            keyPair.writePrivateKey(outputStream);\n        }\n        try (OutputStream outputStream = Files.newOutputStream(Path.of(identity + \".pub\"))) {\n            keyPair.writePublicKey(outputStream, \"coverage\");\n        }\n    }\n\n    private static final class MinimalSshServer implements AutoCloseable {\n        private static final byte SSH_MSG_KEXINIT = 20;\n        private static final byte SSH_MSG_NEWKEYS = 21;\n        private static final byte SSH_MSG_KEXDH_INIT = 30;\n        private static final byte SSH_MSG_KEXDH_REPLY = 31;\n        private static final byte SSH_MSG_SERVICE_REQUEST = 5;\n        private static final byte SSH_MSG_SERVICE_ACCEPT = 6;\n        private static final byte SSH_MSG_USERAUTH_REQUEST = 50;\n        private static final byte SSH_MSG_USERAUTH_FAILURE = 51;\n        private static final byte SSH_MSG_USERAUTH_SUCCESS = 52;\n        private static final byte SSH_MSG_USERAUTH_PK_OK = 60;\n\n        private final ServerSocket serverSocket;\n        private final ExecutorService executorService;\n        private final Future<?> serverTask;\n        private final byte[] expectedAlgorithm;\n\n        private Socket socket;\n        private DataInputStream inputStream;\n        private OutputStream outputStream;\n        private Cipher decryptCipher;\n        private Cipher encryptCipher;\n        private byte[] clientMacKey;\n        private byte[] serverMacKey;\n        private int inboundSequence;\n        private int outboundSequence;\n\n        MinimalSshServer(String expectedAlgorithm) throws IOException {\n            this.expectedAlgorithm = expectedAlgorithm.getBytes(StandardCharsets.UTF_8);\n            serverSocket = new ServerSocket(0, 1, InetAddress.getLoopbackAddress());\n            executorService = Executors.newSingleThreadExecutor();\n            serverTask = executorService.submit(this::run);\n        }\n\n        int port() {\n            return serverSocket.getLocalPort();\n        }\n\n        @Override\n        public void close() throws Exception {\n            closeQuietly(socket);\n            closeQuietly(serverSocket);\n            executorService.shutdownNow();\