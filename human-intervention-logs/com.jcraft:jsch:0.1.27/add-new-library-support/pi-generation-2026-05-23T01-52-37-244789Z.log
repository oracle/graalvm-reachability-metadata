                          .filter(name -> name.endsWith(".class"))
                          .anyMatch(name -> !name.equals("module-info.class"));
                  if (found) {
                      return true;
                  }
              } catch (IOException e) {
                  throw new GradleException("Failed to read library JAR " + jarPath, e);
              }
  
