          private void authenticatePublicKey() throws Exception {
              PacketReader serviceRequest = new PacketReader(receiveEncrypted(SSH_MSG_SERVICE_REQUEST), 1);
              byte[] serviceName = serviceRequest.readString();
              PacketBuilder serviceAccept = new PacketBuilder();
              serviceAccept.putByte(SSH_MSG_SERVICE_ACCEPT);
              serviceAccept.putString(serviceName);
              sendEncrypted(serviceAccept.toByteArray());
  
              receiveEncrypted(SSH_MSG_USERAUTH_REQUEST);
              PacketBuilder noneRejected = new PacketBuilder();
              noneRejected.putByte(SSH_MSG_USERAUTH_FAILURE);
              noneRejected.putString("publickey".getBytes(StandardCharsets.UTF_8));
              noneRejected.putByte((byte) 0);
              sendEncrypted(noneRejected.toByteArray());
  
              PacketReader probe = new PacketReader(receiveEncrypted(SSH_MSG_USERAUTH_REQUEST), 1);
              probe.readString();
              probe.readString();
              probe.readString();
              probe.readByte();
              byte[] algorithm = probe.readString();
              byte[] publicKey = probe.readString();
              if (!Arrays.equals(expectedAlgorithm, algorithm)) {
                  throw new IOException("Unexpected public-key algorithm in probe request");
