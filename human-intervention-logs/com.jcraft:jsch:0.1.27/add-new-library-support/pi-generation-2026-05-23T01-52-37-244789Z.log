obe.readByte();\n            byte[] algorithm = probe.readString();\n            byte[] publicKey = probe.readString();\n            if (!Arrays.equals(expectedAlgorithm, algorithm)) {\n                throw new IOException(\"Unexpected public-key algorithm in probe request\");\n            }\n\n            PacketBuilder publicKeyAccepted = new PacketBuilder();\n            publicKeyAccepted.putByte(SSH_MSG_USERAUTH_PK_OK);\n            publicKeyAccepted.putString(algorithm);\n            publicKeyAccepted.putString(publicKey);\n            sendEncrypted(publicKeyAccepted.toByteArray());\n\n            PacketReader signedRequest = new PacketReader(receiveEncrypted(SSH_MSG_USERAUTH_REQUEST), 1);\n            signedRequest.readString();\n            signedRequest.readString();\n            signedRequest.readString();\n            byte signedFlag = signedRequest.readByte();\n            byte[] signedAlgorithm = signedRequest.readString();\n            signedRequest.readString();\n            byte[] signature = signedRequest.readString();\n            PacketReader signatureReader = new PacketReader(signature, 0);\n            byte[] signatureAlgorithm = signatureReader.readString();\n            byte[] signatureBytes = signatureReader.readString();\n            if (signedFlag != 1\n                    || !Arrays.equals(expectedAlgorithm, signedAlgorithm)\n                    || !Arrays.equals(expectedAlgorithm, signatureAlgorithm)\n                    || signatureBytes.length == 0) {\n                throw new IOException(\"Expected a signed public-key authentication request\");\n            }\n            sendEncrypted(new byte[] {SSH_MSG_USERAUTH_SUCCESS});\n        }\n\n        private byte[] kexInit() {\n            PacketBuilder builder = new PacketBuilder();\n            builder.putByte(SSH_MSG_KEXINIT);\n            builder.putBytes(new byte[16]);\n            builder.putString(\"diffie-hellman-group1-sha1\".getBytes(StandardCharsets.UTF_8));\n            builder