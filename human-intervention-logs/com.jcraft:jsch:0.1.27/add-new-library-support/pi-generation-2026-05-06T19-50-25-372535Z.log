C245\n            E485B576625E7EC6F44C42E9A637ED6B0BFF5CB6F406B7ED\n            EE386BFB5A899FA5AE9F24117C4B1FE649286651ECE65381\n            FFFFFFFFFFFFFFFF\n            \"\"\".replaceAll(\"\\\\s\", \"\"), 16);\n    private static final String SERVER_VERSION = \"SSH-2.0-IdentityFileCoverageTest\";\n\n    @TempDir\n    Path temporaryDirectory;\n\n    @Test\n    void rsaIdentitySignsPublicKeyAuthenticationRequest() throws Exception {\n        authenticateWithGeneratedIdentity(KeyPair.RSA, \"id_rsa\");\n    }\n\n    @Test\n    void dsaIdentitySignsPublicKeyAuthenticationRequest() throws Exception {\n        authenticateWithGeneratedIdentity(KeyPair.DSA, \"id_dsa\");\n    }\n\n    private void authenticateWithGeneratedIdentity(int keyType, String fileName) throws Exception {\n        configureJschForDeterministicLocalServer();\n        Path privateKey = temporaryDirectory.resolve(fileName);\n        writeIdentityFile(keyType, privateKey);\n\n        try (MinimalPublicKeySshServer server = new MinimalPublicKeySshServer()) {\n            JSch jsch = new JSch();\n            jsch.addIdentity(privateKey.toString());\n\n            Session session = jsch.getSession(\"user\", \"127.0.0.1\", server.getPort());\n            session.setConfig(\"StrictHostKeyChecking\", \"no\");\n            session.connect((int) Duration.ofSeconds(10).toMillis());\n            session.disconnect();\n\n            assertThat(server.awaitSignedPublicKeyRequest()).isTrue();\n            assertThat(server.getFailure()).isNull();\n        }\n    }\n\n    private static void configureJschForDeterministicLocalServer() {\n        Hashtable<String, String> config = new Hashtable<>();\n        config.put(\"kex\", \"diffie-hellman-group1-sha1\");\n        config.put(\"server_host_key\", \"ssh-rsa\");\n        config.put(\"cipher.c2s\", \"none\");\n        config.put(\"cipher.s2c\", \"none\");\n        config.put(\"mac.c2s\", \"none\");\n        config.put(\"mac.s2c\", \"none\");\n        JSch.setConfig(config);\n    }\n\n    private static void writeIdentityFile(int keyType, Path privateKey) throws Exception {\n        JSch jsch = new JSch();\n        KeyPair keyPair = KeyPair.genKeyPair(jsch, keyType, 1024);\n        keyPair.writePrivateKey(privateKey.toString());\n    }\n\n    private static final class MinimalPublicKeySshServer implements AutoCloseable {\n        private final ServerSocket serverSocket;\n        private final Thread serverThread;\n        private final CountDownLatch finished = new CountDownLatch(1);\n        private final AtomicBoolean signedPublicKeyRequest = new AtomicBoolean();\n        private final AtomicReference<Throwable> failure = new AtomicReference<>();\n\n        MinimalPublicKeySshServer() throws IOException {\n            serverSocket = new ServerSocket(0, 1, InetAddress.getLoopbackAddress());\n            serverSocket.setSoTimeout((int) Duration.ofSeconds(10).toMillis());\n            serverThread = new Thread(this::serve, \"minimal-jsch-public-key-server\");\n            serverThread.start();\n        }\n\n        int getPort() {\n            return serverSocket.getLocalPort();\n        }\n\n        boolean awaitSignedPublicKeyRequest() throws InterruptedException {\n            finished.await(10, TimeUnit.SECONDS);\n            return signedPublicKeyRequest.get();\n        }\n\n        Throwable getFailure() {\n            return failure.get();\n        }\n\n        @Override\n        public void close() throws Exception {\n            serverSocket.close();\n            serverThread.join(Duration.ofSeconds(10).toMillis());\n        }\n\n        private void serve() {\n            try (Socket socket = serverSocket.accept()) {\n                socket.setSoTimeout((int) Duration.ofSeconds(10).toMillis());\n                performHandshakeAndAuthentication(socket.getInputStream(), socket.getOutputStream());\n            } catch (EOFException ignored) {\n                // The client may disconnect immediately after authentication succeeds.\n            } catch (Throwable throwable) {\n                failure.set(throwable);\n            } finally {\n                finished.countDown();\n            }\n        }\n\n        private void performHandshakeAndAuthentication(InputStream inputStream, OutputStream outputStream) throws Exception {\n            writeLine(outputStream, SERVER_VERSION);\n            String clientVersion = readLine(inputStream);\n\n            byte[] clientKexInit = readPacket(inputStream);\n            byte[] serverKexInit = kexInitPayload();\n            writePacket(outputStream, serverKexInit);\n\n            PacketReader kexInit = new PacketReader(readPacket(inputStream));\n            assertThat(kexInit.readByte()).isEqualTo(30);\n            byte[] clientDhValue = kexInit.readMpint();\n            DhExchange exchange = createDhExchange(clientDhValue);\n            byte[] hostKey = createRsaHostKeyBlob(exchange.hostPublicKey());\n            byte[] exchangeHash = calculateExchangeHash(\n                    clientVersion.getBytes(StandardCharsets.UTF_8),\n                    SERVER_VERSION.getBytes(StandardCharsets.UTF_8),\n                    clientKexInit,\n                    serverKexInit,\n                    hostKey,\n                    clientDhValue,\n                    exchange.serverDhValue(),\n                    exchange.sharedSecret());\n            byte[] signature = signRsaExchangeHash(exchange.hostPrivateKey(), exchangeHash);\n            writePacket(outputStream, kexReplyPayload(hostKey, exchange.serverDhValue(), signature));\n\n            assertThat(readPacket(inputStream)[0]).isEqualTo((byte) 21);\n            writePacket(outputStream, new byte[] {21});\n\n            assertThat(readPacket(inputStream)[0]).isEqualTo((byte) 5);\n            writePacket(outputStream, serviceAcceptPayload());\n\n            assertThat(readPacket(inputStream)[0]).isEqualTo((byte) 50);\n            writePacket(outputStream, userAuthFailurePayload());\n\n            PublicKeyProbe probe = readPublicKeyProbe(readPacket(inputStream));\n            writePacket(outputStream, publicKeyOkPayload(probe.algorithm(), probe.publicKeyBlob()));\n\n            PublicKeyProbe signedProbe = readPublicKeyProbe(readPacket(inputStream));\n            assertThat(signedProbe.hasSignature()).isTrue();\n            signedPublicKeyRequest.set(true);\n            writePacket(outputStream, new byte[] {52});\n        }\n\n        private static DhExchange createDhExchange(byte[] clientDhValue) throws Exception {\n            java.security.KeyPair hostKeyPair = generateRsaHostKeyPair();\n            BigInteger serverSecret = new BigInteger(1024, new SecureRandom())\n                    .mod(DH_GROUP1_PRIME.subtract(BigInteger.TWO))\n                    .add(BigInteger.TWO);\n            BigInteger serverDhValue = DH_GROUP1_GENERATOR.modPow(serverSecret, DH_GROUP1_PRIME);\n            BigInteger sharedSecret = new BigInteger(1, clientDhValue).modPow(serverSecret, DH_GROUP1_PRIME);\n            return new DhExchange(\n                    (RSAPublicKey) hostKeyPair.getPublic(),\n                    hostKeyPair.getPrivate(),\n                    positiveBytes(serverDhValue),\n                    fixedLengthBytes(sharedSecret, 128));\n        }\n\n        private static java.security.KeyPair generateRsaHostKeyPair() throws Exception {\n            KeyPairGenerator generator = KeyPairGenerator.getInstance(\"RSA\");\n            generator.initialize(1024);\n            return generator.generateKeyPair();\n        }\n\n        private static byte[] kexInitPayload() throws IOException {\n            ByteArrayOutputStream payload = new ByteArrayOutputStream();\n            payload.write(20);\n            payload.write(new byte[16]);\n            writeString(payload, \"diffie-hellman-group1-sha1\".getBytes(StandardCharsets.UTF_8));\n            writeString(payload, \"ssh-rsa\".getBytes(StandardCharsets.UTF_8));\n            writeString(payload, \"none\".getBytes(StandardCharsets.UTF_8));\n            writeString(payload, \"none\".getBytes(StandardCharsets.UTF_8));\n            writeString(payload, \"none\".getBytes(StandardCharsets.UTF_8));\n            writeString(payload, \"none\".getBytes(StandardCharsets.UTF_8));\n            writeString(payload, \"none\".getBytes(StandardCharsets.UTF_8));\n            writeString(payload, \"none\".getBytes(StandardCharsets.UTF_8));\n            writeString(payload, new byte[0]);\n            writeString(payload, new byte[0]);\n            payload.write(0);\n            writeUInt32(payload, 0);\n            return payload.toByteArray();\n        }\n\n        private static byte[] kexReplyPayload(byte[] hostKey, byte[] serverDhValue, byte[] signature) throws IOException {\n            ByteArrayOutputStream payload = new ByteArrayOutputStream();\n            payload.write(31);\n            writeString(payload, hostKey);\n            writeMpint(payload, serverDhValue);\n            writeString(payload, signature);\n            return payload.toByteArray();\n        }\n\n        private static byte[] createRsaHostKeyBlob(RSAPublicKey publicKey) throws Exception {\n            RSAPublicKeySpec spec = KeyFactory.getInstance(\"RSA\").getKeySpec(publicKey, RSAPublicKeySpec.class);\n            ByteArrayOutputStream blob = new ByteArrayOutputStream();\n            writeString(blob, \"ssh-rsa\".getBytes(StandardCharsets.UTF_8));\n            writeString(blob, positiveBytes(spec.getPublicExponent()));\n            writeString(blob, positiveBytes(spec.getModulus()));\n            return blob.toByteArray();\n        }\n\n        private static byte[] calculateExchangeHash(\n                byte[] clientVersion,\n                byte[] serverVersion,\n                byte[] clientKexInit,\n                byte[] serverKexInit,\n                byte[] hostKey,\n                byte[] clientDhValue,\n                byte[] serverDhValue,\n                byte[] sharedSecret) throws Exception {\n            ByteArrayOutputStream data = new ByteArrayOutputStream();\n            writeString(data, clientVersion);\n\n[196 more lines in file. Use offset=261 to continue.]"}], "isError": false, "timestamp": 1778096909641}}
