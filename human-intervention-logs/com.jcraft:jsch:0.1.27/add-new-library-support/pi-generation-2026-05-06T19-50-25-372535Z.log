fig);\n    }\n\n    private static void writeIdentityFile(int keyType, Path privateKey) throws Exception {\n        JSch jsch = new JSch();\n        KeyPair keyPair = KeyPair.genKeyPair(jsch, keyType, 1024);\n        keyPair.writePrivateKey(privateKey.toString());\n    }\n\n    private static final class MinimalPublicKeySshServer implements AutoCloseable {\n        private final ServerSocket serverSocket;\n        private final Thread serverThread;\n        private final CountDownLatch finished = new CountDownLatch(1);\n        private final AtomicBoolean signedPublicKeyRequest = new AtomicBoolean();\n        private final AtomicReference<Throwable> failure = new AtomicReference<>();\n\n        MinimalPublicKeySshServer() throws IOException {\n            serverSocket = new ServerSocket(0, 1, InetAddress.getLoopbackAddress());\n            serverSocket.setSoTimeout((int) Duration.ofSeconds(10).toMillis());\n            serverThread = new Thread(this::serve, \"minimal-jsch-public-key-server\");\n            serverThread.start();\n        }\n\n        int getPort() {\n            return serverSocket.getLocalPort();\n        }\n\n        boolean awaitSignedPublicKeyRequest() throws InterruptedException {\n            finished.await(10, TimeUnit.SECONDS);\n            return signedPublicKeyRequest.get();\n        }\n\n        Throwable getFailure() {\n            return failure.get();\n        }\n\n        @Override\n        public void close() throws Exception {\n            serverSocket.close();\n            serverThread.join(Duration.ofSeconds(10).toMillis());\n        }\n\n        private void serve() {\n            try (Socket socket = serverSocket.accept()) {\n                socket.setSoTimeout((int) Duration.ofSeconds(10).toMillis());\n                performHandshakeAndAuthentication(socket.getInputStream(), socket.getOutputStream());\n            } catch (EOFException ignored) {\n                // The client may disconnect immediately after authentication suc