\n                .contains(\"-----END RSA PRIVATE KEY-----\");\n\n        Path privateKeyPath = temporaryDirectory.resolve(\"encrypted-rsa-key\");\n        Files.write(privateKeyPath, privateKeyBytes);\n        KeyPair loadedKeyPair = KeyPair.load(new JSch(), privateKeyPath.toString());\n\n        assertThat(loadedKeyPair.isEncrypted()).isTrue();\n        assertThat(loadedKeyPair.decrypt(PASSPHRASE)).isTrue();\n        assertThat(loadedKeyPair.isEncrypted()).isFalse();\n        assertThat(loadedKeyPair.getFingerPrint()).startsWith(\"1024 \");\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 401, "output": 858, "cacheRead": 28160, "cacheWrite": 0, "totalTokens": 29419, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1779500598022, "responseId": "resp_0b7c0e5b4bf7f843016a1106369d148196b3b355ba4a5d6bdc"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_0Ms1JOCAArnMdbIW7ynuxdhB|fc_0b7c0e5b4bf7f843016a11063ebea881969600898e3edc4f0e", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1966 bytes to tests/src/com.jcraft/jsch/0.1.27/src/test/java/com_jcraft/jsch/KeyPairTest.java"}], "isError": false, "timestamp": 1779500607738}]}
