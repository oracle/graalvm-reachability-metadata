        index++; // INTEGER
        length=plain[index++]&0xff;
        if((length&0x80)!=0){
          int foo=length&0x7f; length=0;
          while(foo-->0){ length=(length<<8)+(plain[index++]&0xff); }
        }
        index+=length;
  
  //System.out.println("int: len="+length);
  //System.out.print(Integer.toHexString(plain[index-1]&0xff)+":");
  //System.out.println("");
  
