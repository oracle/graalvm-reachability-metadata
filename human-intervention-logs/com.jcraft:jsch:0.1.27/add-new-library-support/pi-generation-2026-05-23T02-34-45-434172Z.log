      tmp[2]=(byte)(val >>> 8);
      tmp[3]=(byte)(val);
      System.arraycopy(tmp, 0, buffer, index+4, 4);
      index+=8;
    }
    void skip(int n) {
      index+=n;
    }
    void putPad(int n) {
      while(n>0){
        buffer[index++]=(byte)0;
        n--;
