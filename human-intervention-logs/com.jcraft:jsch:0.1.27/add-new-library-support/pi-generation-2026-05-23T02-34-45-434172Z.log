      private static final int SSH_MSG_NEWKEYS = 21;
  
      @Test
      void formatsHostKeyFingerprintDuringSessionKeyExchange() throws Exception {
          keepConfiguredImplementationsReachable();
          JSch.setConfig(globalConfig());
          try (MiniSshServer server = new MiniSshServer()) {
              Session session = new JSch().getSession("fingerprint-coverage", "127.0.0.1", server.port());
              session.setConfig(strictHostKeyCheckingConfig());
  
              assertThatThrownBy(() -> session.connect(10_000))
                      .isInstanceOf(JSchException.class);
              session.disconnect();
  
              assertThat(server.awaitClientNewKeys()).isTrue();
          }
      }
  
      private static void keepConfiguredImplementationsReachable() {
          assertThat(new DHG1()).isNotNull();
          assertThat(new MD5()).isNotNull();
          assertThat(new SHA1()).isNotNull();
          assertThat(new DH()).isNotNull();
          assertThat(new SignatureRSA()).isNotNull();
          assertThat(new Random()).isNotNull();
          assertThat(new TripleDESCBC()).isNotNull();
      }
  
      private static Hashtable<String, String> globalConfig() {
          Hashtable<String, String> config = new Hashtable<>();
          config.put("kex", "diffie-hellman-group1-sha1");
          config.put("diffie-hellman-group1-sha1", DHG1.class.getName());
          config.put("md5", MD5.class.getName());
          config.put("sha-1", SHA1.class.getName());
          config.put("dh", DH.class.getName());
          config.put("signature.rsa", SignatureRSA.class.getName());
          config.put("random", Random.class.getName());
          config.put("3des-cbc", TripleDESCBC.class.getName());
          config.put("cipher.c2s", "3des-cbc");
          config.put("cipher.s2c", "3des-cbc");
          return config;
      }
  
      private static Hashtable<String, String> strictHostKeyCheckingConfig() {
          Hashtable<String, String> config = new Hashtable<>();
          config.put("StrictHostKeyChecking", "no");
          return config;
      }
  
      private static byte[] kexInitPayload() {
          PacketBuilder builder = new PacketBuilder();
          builder.putByte((byte) 20);
