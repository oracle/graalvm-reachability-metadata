DEF9519B3CD3A431B\n            302B0A6DF25F14374FE1356D6D51C245E485B576625E7EC6F44C42E9\n            A637ED6B0BFF5CB6F406B7EDEE386BFB5A899FA5AE9F24117C4B1FE6\n            49286651ECE65381FFFFFFFFFFFFFFFF\n            \"\"\".replaceAll(\"\\\\s\", \"\"), 16);\n    private static final BigInteger GROUP1_G = BigInteger.TWO;\n    private static final int GROUP1_SHARED_SECRET_BYTES = 128;\n    private static final int SSH_MSG_KEXDH_INIT = 30;\n    private static final int SSH_MSG_KEXDH_REPLY = 31;\n    private static final int SSH_MSG_NEWKEYS = 21;\n\n    @Test\n    void formatsHostKeyFingerprintDuringSessionKeyExchange() throws Exception {\n        keepConfiguredImplementationsReachable();\n        try (MiniSshServer server = new MiniSshServer()) {\n            Session session = new JSch().getSession(\"fingerprint-coverage\", \"127.0.0.1\", server.port());\n            session.setConfig(sessionConfig());\n\n            assertThatThrownBy(() -> session.connect(10_000))\n                    .isInstanceOf(JSchException.class);\n            session.disconnect();\n\n            assertThat(server.awaitClientNewKeys()).isTrue();\n        }\n    }\n\n    private static void keepConfiguredImplementationsReachable() {\n        assertThat(new MD5()).isNotNull();\n        assertThat(new SHA1()).isNotNull();\n        assertThat(new DH()).isNotNull();\n        assertThat(new SignatureRSA()).isNotNull();\n        assertThat(new Random()).isNotNull();\n        assertThat(new TripleDESCBC()).isNotNull();\n    }\n\n    private static Properties sessionConfig() {\n        Properties config = new Properties();\n        config.setProperty(\"StrictHostKeyChecking\", \"no\");\n        config.setProperty(\"md5\", MD5.class.getName());\n        config.setProperty(\"sha-1\", SHA1.class.getName());\n        config.setProperty(\"dh\", DH.class.getName());\n        config.setProperty(\"signature.rsa\", SignatureRSA.class.getName());\n        config.setProperty(\"random\", Random.class.getName());\n        config.setProperty(\"3des-cbc\", TripleDESCBC.class.getName());\n        return config;\n    }\n\n    private static byte[] kexInitPayload() {\n        PacketBuilder builder = new PacketBuilder();\n        builder.putByte((byte) 20);\n        builder.putBytes(new byte[16]);\n        builder.putString(\"diffie-hellman-group1-sha1\".getBytes(StandardCharsets.UTF_8));\n        builder.putString(\"ssh-rsa\".getBytes(StandardCharsets.UTF_8));\n        builder.putString(\"3des-cbc\".getBytes(StandardCharsets.UTF_8));\n        builder.putString(\"3des-cbc\".getBytes(StandardCharsets.UTF_8));\n        builder.putString(\"hmac-md5\".getBytes(StandardCharsets.UTF_8));\n        builder.putString(\"hmac-md5\".getBytes(StandardCharsets.UTF_8));\n        builder.putString(\"none\".getBytes(StandardCharsets.UTF_8));\n        builder.putString(\"none\".getBytes(StandardCharsets.UTF_8));\n        builder.putString(new byte[0]);\n        builder.putString(new byte[0]);\n        builder.putByte((byte) 0);\n        builder.putInt(0);\n        return builder.toByteArray();\n    }\n\n    private static byte[] signedGroup1Reply(byte[] clientVersion, byte[] clientKexInit, byte[] serverKexInit,\n            byte[] clientDhPublic, KeyPair hostKeyPair) throws Exception {\n        BigInteger serverPrivate = new BigInteger(1024, new SecureRandom())\n                .mod(GROUP1_P.subtract(BigInteger.valueOf(3L)))\n                .add(BigInteger.TWO);\n        BigInteger clientPublic = new BigInteger(clientDhPublic);\n        BigInteger serverPublic = GROUP1_G.modPow(serverPrivate, GROUP1_P);\n        byte[] serverDhPublic = serverPublic.toByteArray();\n        byte[] sharedSecret = unsignedFixedLength(clientPublic.modPow(serverPrivate, GROUP1_P),\n                GROUP1_SHARED_SECRET_BYTES);\n        byte[] hostKeyBlob = hostKeyBlob((RSAPublicKey) hostKeyPair.getPublic());\n        byte[] exchangeHash = exchangeHash(clientVersion, clientKexInit, serverKexInit, hostKeyBlob, clientDhPublic,\n                serverDhPublic, sharedSecret);\n\n        PacketBuilder payload = new PacketBuilder();\n        payload.putByte((byte) SSH_MSG_KEXDH_REPLY);\n        payload.putString(hostKeyBlob);\n        payload.putMpInt(serverDhPublic);\n        payload.putString(rsaSignatureBlob(exchangeHash, hostKeyPair));\n        return payload.toByteArray();\n    }\n\n    private static byte[] exchangeHash(byte[] clientVersion, byte[] clientKexInit, byte[] serverKexInit,\n            byte[] hostKeyBlob, byte[] clientDhPublic, byte[] serverDhPublic, byte[] sharedSecret) throws Exception {\n        PacketBuilder builder = new PacketBuilder();\n        builder.putString(clientVersion);\n        builder.putString(SERVER_VERSION);\n        builder.putString(clientKexInit);\n        builder.putString(serverKexInit);\n        builder.putString(hostKeyBlob);\n        builder.putMpInt(clientDhPublic);\n        builder.putMpInt(serverDhPublic);\n        builder.putMpInt(sharedSecret);\n        return MessageDigest.getInstance(\"SHA-1\").digest(builder.toByteArray());\n    }\n\n    private static byte[] hostKeyBlob(RSAPublicKey key) {\n        PacketBuilder builder = new PacketBuilder();\n        builder.putString(\"ssh-rsa\".getBytes(StandardCharsets.UTF_8));\n        builder.putMpInt(key.getPublicExponent().toByteArray());\n        builder.putMpInt(key.getModulus().toByteArray());\n        return builder.toByteArray();\n    }\n\n    private static byte[] rsaSignatureBlob(byte[] exchangeHash, KeyPair keyPair) throws Exception {\n        Signature signature = Signature.getInstance(\"SHA1withRSA\");\n        signature.initSign(keyPair.getPrivate());\n        signature.update(exchangeHash);\n\n        PacketBuilder builder = new PacketBuilder();\n        builder.putString(\"ssh-rsa\".getBytes(StandardCharsets.UTF_8));\n        builder.putString(signature.sign());\n        return builder.toByteArray();\n    }\n\n    private static byte[] unsignedFixedLength(BigInteger value, int length) {\n        byte[] bytes = value.toByteArray();\n        if (bytes.length == length) {\n            return bytes;\n        }\n        byte[] unsignedBytes = bytes;\n        if (bytes.length > 1 && bytes[0] == 0) {\n            unsignedBytes = new byte[bytes.length - 1];\n            System.arraycopy(bytes, 1, unsignedBytes, 0, unsignedBytes.length);\n        }\n        byte[] paddedBytes = new byte[length];\n        System.arraycopy(unsignedBytes, 0, paddedBytes, length - unsignedBytes.length, unsignedBytes.length);\n        return paddedBytes;\n    }\n\n    private static byte[] readPayload(InputStream inputStream) throws IOException {\n        DataInputStream input = new DataInputStream(inputStream);\n        int packetLength = input.readInt();\n        byte[] packet = new byte[packetLength];\n        input.readFully(packet);\n        int paddingLength = packet[0] & 0xff;\n        int payloadLength = packetLength - paddingLength - 1;\n        byte[] payload = new byte[payloadLength];\n        System.arraycopy(packet, 1, payload, 0, payload.length);\n        return payload;\n    }\n\n    private static void writePacket(OutputStream outputStream, byte[] payload) throws IOException {\n        outputStream.write(wrapPacket(payload));\n        outputStream.flush();\n    }\n\n    private static byte[] wrapPacket(byte[] payload) {\n        int paddingLength = 8 - ((payload.length + 5) % 8);\n        if (paddingLength < 4) {\n            paddingLength += 8;\n        }\n        PacketBuilder builder = new PacketBuilder();\n        builder.putInt(payload.length + paddingLength + 1);\n        builder.putByte((byte) paddingLength);\n        builder.putBytes(payload);\n        builder.putBytes(new byte[paddingLength]);\n        return builder.toByteArray();\n    }\n\n    private static byte[] readVersionLine(InputStream inputStream) throws IOException {\n        ByteArrayOutputStream line = new ByteArrayOutputStream();\n        int value;\n        while ((value = inputStream.read()) >= 0) {\n            if (value == '\\n') {\n                break;\n            }\n            if (value != '\\r') {\n                line.write(value);\n            }\n        }\n        return line.toByteArray();\n    }\n\n    private static KeyPair rsaKeyPair() throws Exception {\n        KeyPairGenerator keyPairGenerator = KeyPairGenerator.getInstance(\"RSA\");\n        keyPairGenerator.initialize(1024);\n        return keyPairGenerator.generateKeyPair();\n    }\n\n    private static final class MiniSshServer implements AutoCloseable {\n        private final ServerSocket serverSocket;\n        private final ExecutorService executorService;\n        private final Future<Boolean> serverTask;\n\n        MiniSshServer() throws IOException {\n            serverSocket = new ServerSocket(0, 1, InetAddress.getLoopbackAddress());\n            executorService = Executors.newSingleThreadExecutor();\n            serverTask = executorService.submit(this::serveOneKeyExchange);\n        }\n\n        int port() {\n            return serverSocket.getLocalPort();\n        }\n\n        boolean awaitClientNewKeys() throws Exception {\n            return serverTask.get(10, TimeUnit.SECONDS);\n        }\n\n        @Override\n        public void close() throws Exception {\n            closeQuietly(serverSocket);\n            executorService.shutdownNow();\n            if (!executorService.awaitTermination(5, TimeUnit.SECONDS)) {\n                throw new AssertionError(\"SSH test server did not stop\");\n            }\n            try {\n                serverTask.get(5, TimeUnit.SECONDS);\n            } catch (ExecutionException exception) {\n                throw exception;\n            }\n        }\n\n        private Boolean serveOneKeyExchange() throws Exception {\n            try (Socket socket = serverSocket.accept()) {\n                socket.setSoTimeout(10_000);\n                InputStream inputStream = socket.getInputStream();\n                OutputStream outputStream = socket.getOutputStream();\n                outputStream.write(SERVER_VERSION);\n                outputStream.write('\\r');\n                outputStream.write('\\n');\n                outputStream.flush();\n\n                byte[] clientVersion = readVersionLine(inputStream);\n                byte[] serverKexInit = kexInitPayload();\n                writePacket(outputStream, serverKexInit);\n                byte[] clientKexInit = readPayload(inputStream);\n                byte[] clientDhInit = readPayload(inputStream);\n                PacketReader dhInitReader = new PacketReader(clientDhInit);\n                assertThat(dhInitReader.getByte()).isEqualTo(SSH_MSG_KEXDH_INIT);\n\n                byte[] reply = signedGroup1Reply(clientVersion, clientKexInit, serverKexInit, dhInitReader.getMpInt(),\n                        rsaKeyPair());\n                writePacket(outputStream, reply);\n                byte[] clientNewKeys = readPayload(inputStream);\n                return clientNewKeys.length == 1 && (clientNewKeys[0] & 0xff) == SSH_MSG_NEWKEYS;\n            }\n        }\n\n        private static void closeQuietly(Closeable closeable) {\n            try {\n                closeable.close();\n            } catch (IOException ignored) {\n                // Best-effort cleanup after bounded SSH handshake exercise.\n            }\n        }\n    }\n\n    private static final class PacketReader {\n        private final byte[] bytes;\n        private int offset;\n\n        PacketReader(byte[] bytes) {\n            this.bytes = bytes;\n        }\n\n        int getByte() {\n            return bytes[offset++] & 0xff;\n        }\n\n        byte[] getMpInt() {\n            int length = getInt();\n            byte[] value = new byte[length];\n            System.arraycopy(bytes, offset, value, 0, value.length);\n            offset += length;\n            return value;\n        }\n\n        private int getInt() {\n            int value = ((bytes[offset] << 24) & 0xff000000)\n                    | ((bytes[offset + 1] << 16) & 0x00ff0000)\n                    | ((bytes[offset + 2] << 8) & 0x0000ff00)\n                    | (bytes[offset + 3] & 0x000000ff);\n            offset += 4;\n            return value;\n        }\n    }\n\n    private static final class PacketBuilder {\n        private final ByteArrayOutputStream outputStream = new ByteArrayOutputStream();\n\n        void putByte(byte value) {\n            outputStream.write(value);\n        }\n\n        void putBytes(byte[] value) {\n            outputStream.writeBytes(value);\n        }\n\n        void putInt(int value) {\n            outputStream.write((value >>> 24) & 0xff);\n            outputStream.write((value >>> 16) & 0xff);\n            outputStream.write((value >>> 8) & 0xff);\n            outputStream.write(value & 0xff);\n        }\n\n        void putString(byte[] value) {\n            putInt(value.length);\n            putBytes(value);\n        }\n\n        void putMpInt(byte[] value) {\n            if ((value[0] & 0x80) != 0) {\n                putInt(value.length + 1);\n                putByte((byte) 0);\n                putBytes(value);\n            } else {\n                putString(value);\n            }\n        }\n\n        byte[] toByteArray() {\n            return outputStream.toByteArray();\n        }\n    }\n}\n"}
