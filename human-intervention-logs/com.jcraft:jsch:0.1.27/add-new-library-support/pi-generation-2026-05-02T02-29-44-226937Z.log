  	  String message=null;
  	  try{ message=new String(_message, "UTF-8"); }
  	  catch(java.io.UnsupportedEncodingException e){
  	    message=new String(_message);
  	  }
  	  if(userinfo!=null){
  	    userinfo.showMessage(message);
  	  }
  	  continue loop2;
  	}
  	else if(buf.buffer[5]==Session.SSH_MSG_USERAUTH_FAILURE){
