        buf.putByte((byte)1);
        buf.putString(identity.getAlgName().getBytes());
        buf.putString(pubkeyblob);
  
  //      byte[] tmp=new byte[buf.index-5];
  //      System.arraycopy(buf.buffer, 5, tmp, 0, tmp.length);
  //      buf.putString(signature);
  
        byte[] sid=session.getSessionId();
