  plugins {
      id "org.graalvm.internal.tck"
  }
  
  String libraryVersion = tck.testedLibraryVersion.get()
  
  configurations {
      jschSources
  }
  
  Provider<Directory> generatedJschSources = layout.buildDirectory.dir("generated-jsch-sources")
  
  TaskProvider<Sync> unpackJschSources = tasks.register("unpackJschSources", Sync) {
      from({ zipTree(configurations.jschSources.singleFile) }) {
          exclude "META-INF/**"
          exclude "com/jcraft/jsch/jcraft/Compression.java"
      }
      into generatedJschSources
  }
  
  // Compile the tested sources with line numbers because the published classes do not expose them to JaCoCo.
  sourceSets {
      main {
          java.srcDir unpackJschSources.map { it.destinationDir }
      }
  }
  
  dependencies {
      jschSources "com.jcraft:jsch:$libraryVersion:sources"
      testImplementation "com.jcraft:jsch:$libraryVersion"
      testImplementation 'org.assertj:assertj-core:3.22.0'
  }
  
  graalvmNative {
      agent {
          defaultMode = "conditional"
          modes {
              conditional {
                  userCodeFilterPath = "user-code-filter.json"
              }
          }
