[tool-call] delta {"path":"tests/src/com.jcraft/jsch/0.1.27/src/test/java/com_jcraft/jsch/KeyPairRSATest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_jcraft.jsch;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport com.jcraft.jsch.JSch;\nimport com.jcraft.jsch.KeyPair;\nimport com.jcraft.jsch.KeyPairGenRSA;\nimport java.io.ByteArrayOutputStream;\nimport java.nio.charset.StandardCharsets;\nimport java.security.KeyPairGenerator;\nimport java.security.PrivateKey;\nimport java.security.PublicKey;\nimport java.security.SecureRandom;\nimport java.security.interfaces.RSAPrivateCrtKey;\nimport java.security.interfaces.RSAPublicKey;\nimport java.util.Hashtable;\nimport org.junit.jupiter.api.Test;\n\npublic class KeyPairRSATest {\n    @Test\n    void generatesAndWritesRsaKeyPair() throws Exception {\n        keepConfiguredRsaKeyPairGeneratorReachable();\n        configureRsaKeyPairGenerator(ConfiguredKeyPairGenRSA.class.getName());\n        try {\n            KeyPair keyPair = KeyPair.genKeyPair(new JSch(), KeyPair.RSA, 1024);\n\n            assertThat(keyPair.getKeyType()).isEqualTo(KeyPair.RSA);\n\n            ByteArrayOutputStream privateKeyOutputStream = new ByteArrayOutputStream();\n            keyPair.writePrivateKey(privateKeyOutputStream);\n            String privateKey = privateKeyOutputStream.toString(StandardCharsets.US_ASCII);\n            assertThat(privateKey)\n                    .contains(\"-----BEGIN RSA PRIVATE KEY-----\")\n                    .contains(\"-----END RSA PRIVATE KEY-----\");\n\n            ByteArrayOutputStream publicKeyOutputStream = new ByteArrayOutputStream();\n            keyPair.writePublicKey(publicKeyOutputStream, \"coverage\");\n            String publicKey = publicKeyOutputStream.toString(StandardCharsets.US_ASCII);\n            assertThat(publicKey).startsWith(\"ssh-rsa \").endsWith(\" coverage\\n\");\n        } finally {\n            configureRsaKeyPairGenerator(\"com.jcraft.jsch.jce.KeyPairGenRSA\");\n        }\n    }\n\n    private static void configureRsaKeyPairGenerator(String keyPairGenerator) {\n        Hashtable<String, String> config = new Hashtable<>();\n        config.put(\"keypairgen.rsa\", keyPairGenerator);\n        JSch.setConfig(config);\n    }\n\n    private static void keepConfiguredRsaKeyPairGeneratorReachable() {\n        assertThat(new ConfiguredKeyPairGenRSA()).isNotNull();\n    }\n\n    public static final class ConfiguredKeyPairGenRSA implements KeyPairGenRSA {\n        private byte[] privateExponent;\n        private byte[] publicExponent;\n        private byte[] modulus;\n        private byte[] coefficient;\n        private byte[] primeExponentP;\n        private byte[] primeExponentQ;\n        private byte[] primeP;\n        private byte[] primeQ;\n\n        @Override\n        public void init(int keySize) throws Exception {\n            KeyPairGenerator keyPairGenerator = KeyPairGenerator.getInstance(\"RSA\");\n            keyPairGenerator.initialize(keySize, new SecureRandom());\n            java.security.KeyPair generatedKeyPair = keyPairGenerator.generateKeyPair();\n            PublicKey generatedPublicKey = generatedKeyPair.getPublic();\n            PrivateKey generatedPrivateKey = generatedKeyPair.getPrivate();\n\n            RSAPublicKey rsaPublicKey = (RSAPublicKey) generatedPublicKey;\n            RSAPrivateCrtKey rsaPrivateKey = (RSAPrivateCrtKey) generatedPrivateKey;\n\n            privateExponent = rsaPrivateKey.getPrivateExponent().toByteArray();\n            publicExponent = rsaPublicKey.getPublicExponent().toByteArray();\n            modulus = rsaPublicKey.getModulus().toByteArray();\n            coefficient = rsaPrivateKey.getCrtCoefficient().toByteArray();\n            primeExponentP = rsaPrivateKey.getPrimeExponentP().toByteArray();\n            primeExponentQ = rsaPrivateKey.getPrimeExponentQ().toByteArray();\n            primeP = rsaPrivateKey.getPrimeP().toByteArray();\n            primeQ = rsaPrivateKey.getPrimeQ().toByteArray();\n        }\n\n        @Override\n        public byte[] getD() {\n            return privateExponent;\n        }\n\n        @Override\n        public byte[] getE() {\n            return publicExponent;\n        }\n\n        @Override\n        public byte[] getN() {\n            return modulus;\n        }\n\n        @Override\n        public byte[] getC() {\n            return coefficient;\n        }\n\n        @Override\n        public byte[] getEP() {\n            return primeExponentP;\n        }\n\n        @Override\n        public byte[] getEQ() {\n            return primeExponentQ;\n        }\n\n        @Override\n        public byte[] getP() {\n            return primeP;\n        }\n\n        @Override\n        public byte[] getQ() {\n            return primeQ;\n        }\n    }\n}\n"}
