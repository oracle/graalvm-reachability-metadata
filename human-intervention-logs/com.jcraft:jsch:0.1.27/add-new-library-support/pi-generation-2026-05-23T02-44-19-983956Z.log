c void keepConfiguredDsaKeyPairGeneratorReachable() {\n+ 57         assertThat(new ConfiguredKeyPairGenDSA()).isNotNull();\n  50     }\n+ 59 \n+ 60     public static final class ConfiguredKeyPairGenDSA implements KeyPairGenDSA {\n+ 61         private byte[] privateKey;\n+ 62         private byte[] publicKey;\n+ 63         private byte[] p;\n+ 64         private byte[] q;\n+ 65         private byte[] g;\n+ 66 \n+ 67         @Override\n+ 68         public void init(int keySize) throws Exception {\n+ 69             KeyPairGenerator keyPairGenerator = KeyPairGenerator.getInstance(\"DSA\");\n+ 70             keyPairGenerator.initialize(keySize, new SecureRandom());\n+ 71             java.security.KeyPair generatedKeyPair = keyPairGenerator.generateKeyPair();\n+ 72             PublicKey generatedPublicKey = generatedKeyPair.getPublic();\n+ 73             PrivateKey generatedPrivateKey = generatedKeyPair.getPrivate();\n+ 74 \n+ 75             privateKey = ((DSAPrivateKey) generatedPrivateKey).getX().toByteArray();\n+ 76             publicKey = ((DSAPublicKey) generatedPublicKey).getY().toByteArray();\n+ 77 \n+ 78             DSAParams parameters = ((DSAKey) generatedPrivateKey).getParams();\n+ 79             p = parameters.getP().toByteArray();\n+ 80             q = parameters.getQ().toByteArray();\n+ 81             g = parameters.getG().toByteArray();\n+ 82         }\n+ 83 \n+ 84         @Override\n+ 85         public byte[] getX() {\n+ 86             return privateKey;\n+ 87         }\n+ 88 \n+ 89         @Override\n+ 90         public byte[] getY() {\n+ 91             return publicKey;\n+ 92         }\n+ 93 \n+ 94         @Override\n+ 95         public byte[] getP() {\n+ 96             return p;\n+ 97         }\n+ 98 \n+ 99         @Override\n+100         public byte[] getQ() {\n+101             return q;\n+102         }\n+103 \n+104         @Override\n+105         public byte[] getG() {\n+106             return g;\n+107         }\n+108     }\n  51 }", "firstChangedLine