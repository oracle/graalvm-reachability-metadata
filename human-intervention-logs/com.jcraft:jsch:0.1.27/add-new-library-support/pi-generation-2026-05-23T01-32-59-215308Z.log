  package com_jcraft.jsch;
  
  import static org.assertj.core.api.Assertions.assertThatCode;
  
  import com.jcraft.jsch.JSch;
  import com.jcraft.jsch.KeyPair;
  import com.jcraft.jsch.Session;
  import java.io.ByteArrayOutputStream;
  import java.io.Closeable;
  import java.io.DataInputStream;
  import java.io.IOException;
  import java.io.OutputStream;
  import java.math.BigInteger;
  import java.net.InetAddress;
  import java.net.ServerSocket;
  import java.net.Socket;
  import java.nio.charset.StandardCharsets;
  import java.nio.file.Files;
  import java.nio.file.Path;
  import java.security.KeyPairGenerator;
  import java.security.MessageDigest;
  import java.security.PrivateKey;
  import java.security.SecureRandom;
  import java.security.Signature;
  import java.security.interfaces.RSAPublicKey;
  import java.util.Arrays;
  import java.util.Properties;
  import java.util.concurrent.ExecutorService;
  import java.util.concurrent.Executors;
  import java.util.concurrent.Future;
  import java.util.concurrent.TimeUnit;
  import javax.crypto.Cipher;
  import javax.crypto.Mac;
  import javax.crypto.spec.IvParameterSpec;
  import javax.crypto.spec.SecretKeySpec;
  import org.junit.jupiter.api.Test;
  import org.junit.jupiter.api.io.TempDir;
  
  public class IdentityFileTest {
      private static final byte[] USER = "coverage".getBytes(StandardCharsets.UTF_8);
      private static final BigInteger GROUP1_P = new BigInteger("""
              FFFFFFFFFFFFFFFFC90FDAA22168C234C4C6628B80DC1CD129024E08
              8A67CC74020BBEA63B139B22514A08798E3404DDEF9519B3CD3A431B
              302B0A6DF25F14374FE1356D6D51C245E485B576625E7EC6F44C42E9
              A637ED6B0BFF5CB6F406B7EDEE386BFB5A899FA5AE9F24117C4B1FE6
              49286651ECE65381FFFFFFFFFFFFFFFF
              """.replaceAll("\\s", ""), 16);
      private static final BigInteger GROUP1_G = BigInteger.valueOf(2L);
  
      @TempDir
      Path temporaryDirectory;
  
      @Test
      void authenticatesWithRsaIdentityFile() throws Exception {
          authenticateWithIdentity(KeyPair.RSA, "rsa_identity");
      }
  
      @Test
      void authenticatesWithDsaIdentityFile() throws Exception {
          authenticateWithIdentity(KeyPair.DSA, "dsa_identity");
      }
  
      private void authenticateWithIdentity(int keyType, String fileName) throws Exception {
          Path identity = temporaryDirectory.resolve(fileName);
          writeIdentityFile(keyType, identity);
  
          try (MinimalSshServer server = new MinimalSshServer()) {
              JSch jsch = new JSch();
              jsch.addIdentity(identity.toString());
  
              Session session = jsch.getSession(new String(USER, StandardCharsets.UTF_8), "127.0.0.1", server.port());
              Properties sessionConfig = new Properties();
              sessionConfig.setProperty("StrictHostKeyChecking", "no");
              session.setConfig(sessionConfig);
  
              assertThatCode(() -> session.connect(10_000)).doesNotThrowAnyException();
              session.disconnect();
          }
      }
  
      private static void writeIdentityFile(int keyType, Path identity) throws Exception {
          JSch jsch = new JSch();
          KeyPair keyPair = KeyPair.genKeyPair(jsch, keyType, 1024);
          try (OutputStream outputStream = Files.newOutputStream(identity)) {
              keyPair.writePrivateKey(outputStream);
          }
          try (OutputStream outputStream = Files.newOutputStream(Path.of(identity + ".pub"))) {
              keyPair.writePublicKey(outputStream, "coverage");
          }
      }
  
      private static final class MinimalSshServer implements AutoCloseable {
          private static final byte SSH_MSG_KEXINIT = 20;
          private static final byte SSH_MSG_NEWKEYS = 21;
          private static final byte SSH_MSG_KEXDH_INIT = 30;
          private static final byte SSH_MSG_KEXDH_REPLY = 31;
          private static final byte SSH_MSG_SERVICE_REQUEST = 5;
          private static final byte SSH_MSG_SERVICE_ACCEPT = 6;
          private static final byte SSH_MSG_USERAUTH_REQUEST = 50;
          private static final byte SSH_MSG_USERAUTH_FAILURE = 51;
          private static final byte SSH_MSG_USERAUTH_SUCCESS = 52;
          private static final byte SSH_MSG_USERAUTH_PK_OK = 60;
  
          private final ServerSocket serverSocket;
          private final ExecutorService executorService;
          private final Future<?> serverTask;
  
          private Socket socket;
          private DataInputStream inputStream;
          private OutputStream outputStream;
          private Cipher decryptCipher;
          private Cipher encryptCipher;
          private byte[] clientMacKey;
          private byte[] serverMacKey;
          private int inboundSequence;
          private int outboundSequence;
  
          MinimalSshServer() throws IOException {
              serverSocket = new ServerSocket(0, 1, InetAddress.getLoopbackAddress());
              executorService = Executors.newSingleThreadExecutor();
              serverTask = executorService.submit(this::run);
          }
  
          int port() {
              return serverSocket.getLocalPort();
          }
  
          @Override
          public void close() throws Exception {
              closeQuietly(socket);
              closeQuietly(serverSocket);
              executorService.shutdownNow();
              if (!executorService.awaitTermination(5, TimeUnit.SECONDS)) {
                  throw new AssertionError("SSH test server did not stop");
              }
              serverTask.get(5, TimeUnit.SECONDS);
          }
  
          private void run() {
              try {
                  socket = serverSocket.accept();
                  socket.setSoTimeout(10_000);
                  inputStream = new DataInputStream(socket.getInputStream());
                  outputStream = socket.getOutputStream();
                  exchangeKeys();
                  authenticatePublicKey();
              } catch (IOException exception) {
                  if (!serverSocket.isClosed()) {
                      throw new AssertionError(exception);
                  }
              } catch (Exception exception) {
                  throw new AssertionError(exception);
              }
          }
  
          private void exchangeKeys() throws Exception {
              byte[] serverVersion = "SSH-2.0-coverage-test".getBytes(StandardCharsets.UTF_8);
