/netty-codec-mqtt/index.json:5:    \"source-code-url\" : \"https://repo.maven.apache.org/maven2/io/netty/netty-codec-mqtt/4.1.74.Final/netty-codec-mqtt-4.1.74.Final-sources.jar\",\nmetadata/io.netty/netty-codec-mqtt/index.json:6:    \"repository-url\" : \"https://github.com/netty/netty\",\nmetadata/io.netty/netty-codec-mqtt/index.json:7:    \"test-code-url\" : \"https://repo.maven.apache.org/maven2/io/netty/netty-codec-mqtt/4.1.74.Final/netty-codec-mqtt-4.1.74.Final-tests.jar\",\nmetadata/io.netty/netty-codec-mqtt/index.json:8:    \"documentation-url\" : \"https://repo.maven.apache.org/maven2/io/netty/netty-codec-mqtt/4.1.74.Final/netty-codec-mqtt-4.1.74.Final-javadoc.jar\",\nmetadata/io.netty/netty-codec-mqtt/index.json:9:    \"description\" : \"Netty Codec MQTT provides MQTT protocol encoder, decoder, and message model classes for Netty pipelines. It lets Java applications implement MQTT clients or servers on top of Netty by translating MQTT wire frames to and from Netty message objects.\",\nmetadata/io.netty/netty-codec/index.json:5:    \"source-code-url\" : \"https://repo.maven.apache.org/maven2/io/netty/netty-codec/$version$/netty-codec-$version$-sources.jar\",\nmetadata/io.netty/netty-codec/index.json:6:    \"repository-url\" : \"https://github.com/netty/netty\",\nmetadata/io.netty/netty-codec/index.json:7:    \"test-code-url\" : \"https://github.com/netty/netty/tree/netty-$version$/codec/src/test/java\",\nmetadata/io.netty/netty-codec/index.json:8:    \"documentation-url\" : \"https://repo.maven.apache.org/maven2/io/netty/netty-codec/$version$/netty-codec-$version$-javadoc.jar\",\nmetadata/io.netty/netty-codec/index.json:9:    \"description\" : \"Netty Codec provides encoders and decoders for transforming byte streams and messages within Netty channel pipelines. It includes reusable frame decoders, compression handlers, serialization codecs, and protocol-building primitives used by Netty-based network applications.\",\nmetadata/io.netty/netty-transport-native-epoll/index.json:5:    \"source-code-url\" : \"https://repo.maven.apache.org/maven2/io/netty/netty-transport-native-epoll/4.1.42.Final/netty-transport-native-epoll-4.1.42.Final-sources.jar\",\nmetadata/io.netty/netty-transport-native-epoll/index.json:6:    \"repository-url\" : \"https://github.com/netty/netty\",\nmetadata/io.netty/netty-transport-native-epoll/index.json:7:    \"test-code-url\" : \"https://github.com/netty/netty/tree/netty-4.1.42.Final/transport-native-epoll/src/test\",\nmetadata/io.netty/netty-transport-native-epoll/index.json:8:    \"documentation-url\" : \"https://repo.maven.apache.org/maven2/io/netty/netty-transport-native-epoll/4.1.42.Final/netty-transport-native-epoll-4.1.42.Final-javadoc.jar\",\nmetadata/io.netty/netty-transport-native-epoll/index.json:9:    \"description\" : \"Netty Transport Native Epoll provides Linux epoll-based native transport support for Netty. It gives Netty applications high-performance event loops, channels, and JNI-backed native socket features on Linux.\",\nmetadata/io.netty/netty-codec-smtp/index.json:5:    \"source-code-url\" : \"https://repo.maven.apache.org/maven2/io/netty/netty-codec-smtp/$version$/netty-codec-smtp-$version$-sources.jar\",\nmetadata/io.netty/netty-codec-smtp/index.json:6:    \"repository-url\" : \"https://github.com/netty/netty\",\nmetadata/io.netty/netty-codec-smtp/index.json:7:    \"test-code-url\" : \"https://repo.maven.apache.org/maven2/io/netty/netty-codec-smtp/$version$/netty-codec-smtp-$version$-test-sources.jar\",\nmetadata/io.netty/netty-codec-smtp/index.json:8:    \"documentation-url\" : \"https://repo.maven.apache.org/maven2/io/netty/netty-codec-smtp/$version$/netty-codec-smtp-$version$-javadoc.jar\",\nmetadata/io.netty/netty-codec-smtp/index.json:9:    \"description\" : \"Netty Codec SMTP provides SMTP protocol support for Netty by modeling SMTP commands, requests, responses, and message content. It includes an SMTP request encoder and response decoder for implementing asynchronous SMTP clients on Netty's channel pipeline.\",\nmetadata/io.netty/netty-tcnative-classes/index.json:5:    \"source-code-url\" : \"https://repo.maven.apache.org/maven2/io/netty/netty-tcnative-classes/$version$/netty-tcnative-classes-$version$-sources.jar\",\nmetadata/io.netty/netty-tcnative-classes/index.json:6:    \"repository-url\" : \"https://github.com/netty/netty-tcnative\",\nmetadata/io.netty/netty-tcnative-classes/index.json:7:    \"test-code-url\" : \"https://github.com/netty/netty-tcnative/tree/netty-tcnative-parent-$version$/openssl-dynamic/src/test\",\nmetadata/io.netty/netty-tcnative-classes/index.json:8:    \"documentation-url\" : \"https://repo.maven.apache.org/maven2/io/netty/netty-tcnative-classes/$version$/netty-tcnative-classes-$version$-javadoc.jar\",\nmetadata/io.netty/netty-tcnative-classes/index.json:9:    \"description\" : \"Netty tcnative classes provide Java bindings for Netty's fork of Tomcat Native, exposing native TLS and SSL functionality to Netty-based applications. The artifact supplies the shared class definitions that Netty's platform-specific tcnative libraries use to access OpenSSL and Apache APR capabilities.\",\nmetadata/io.netty/netty-codec-haproxy/index.json:5:    \"source-code-url\": \"https://repo.maven.apache.org/maven2/io/netty/netty-codec-haproxy/$version$/netty-codec-haproxy-$version$-sources.jar\",\nmetadata/io.netty/netty-codec-haproxy/index.json:6:    \"repository-url\": \"https://github.com/netty/netty\",\nmetadata/io.netty/netty-codec-haproxy/index.json:7:    \"test-code-url\": \"https://repo.maven.apache.org/maven2/io/netty/netty-codec-haproxy/$version$/netty-codec-haproxy-$version$-test-sources.jar\",\nmetadata/io.netty/netty-codec-haproxy/index.json:8:    \"documentation-url\": \"https://repo.maven.apache.org/maven2/io/netty/netty-codec-haproxy/$version$/netty-codec-haproxy-$version$-javadoc.jar\",\nmetadata/io.netty/netty-codec-haproxy/index.json:9:    \"description\": \"Netty Codec HAProxy provides encoders, decoders, and message model classes for the HAProxy PROXY protocol in Netty pipelines. It lets Netty-based servers and clients parse and emit proxy protocol headers so original client connection metadata can be preserved through load balancers and proxies.\",\nmetadata/io.netty/netty-codec-haproxy/index.json:21:    \"source-code-url\": \"https://repo.maven.apache.org/maven2/io/netty/netty-codec-haproxy/$version$/netty-codec-haproxy-$version$-sources.jar\",\nmetadata/io.netty/netty-codec-haproxy/index.json:22:    \"repository-url\": \"https://github.com/netty/netty\",\nmetadata/io.netty/netty-codec-haproxy/index.json:23:    \"test-code-url\": \"https://repo.maven.apache.org/maven2/io/netty/netty-codec-haproxy/$version$/netty-codec-haproxy-$version$-test-sources.jar\",\nmetadata/io.netty/netty-codec-haproxy/index.json:24:    \"documentation-url\": \"https://repo.maven.apache.org/maven2/io/netty/netty-codec-haproxy/$version$/netty-codec-haproxy-$version$-javadoc.jar\",\nmetadata/io.netty/netty-codec-haproxy/index.json:25:    \"description\": \"Netty Codec HAProxy provides encoders, decoders, and message model classes for the HAProxy PROXY protocol in Netty pipelines. It lets Netty-based servers and clients parse and emit proxy protocol headers so original client connection metadata can be preserved through load balancers and proxies.\",\nmetadata/io.netty/netty-codec-dns/index.json:6:    \"source-code-url\": \"https://repo.maven.apache.org/maven2/io/netty/netty-codec-dns/$version$/netty-codec-dns-$version$-sources.jar\",\nmetadata/io.netty/netty-codec-dns/index.json:7:    \"repository-url\": \"https://github.com/netty/netty\",\nmetadata/io.netty/netty-codec-dns/index.json:8:    \"test-code-url\": \"https://repo.maven.apache.org/maven2/io/netty/netty-codec-dns/$version$/netty-codec-dns-$version$-test-sources.jar\",\nmetadata/io.netty/netty-codec-dns/index.json:9:    \"documentation-url\": \"https://repo.maven.apache.org/maven2/io/netty/netty-codec-dns/$version$/netty-codec-dns-$version$-javadoc.jar\",\nmetadata/io.netty/netty-codec-dns/index.json:10:    \"description\": \"Netty Codec DNS provides DNS protocol message types, encoders, and decoders for Netty's asynchronous networking framework. It supports building and parsing DNS queries and responses for resolver and DNS-related network components.\",\nmetadata/io.netty/netty-codec-dns/index.json:21:    \"source-code-url\": \"https://repo.maven.apache.org/maven2/io/netty/netty-codec-dns/$version$/netty-codec-dns-$version$-sources.jar\",\nmetadata/io.netty/netty-codec-dns/index.json:22:    \"repository-url\": \"https://github.com/netty/netty\",\nmetadata/io.netty/netty-codec-dns/index.json:23:    \"test-code-url\": \"https://repo.maven.apache.org/maven2/io/netty/netty-codec-dns/$version$/netty-codec-dns-$version$-test-sources.jar\",\nmetadata/io.netty/netty-codec-dns/index.json:24:    \"documentation-url\": \"https://repo.maven.apache.org/maven2/io/netty/netty-codec-dns/$version$/netty-codec-dns-$version$-javadoc.jar\",\nmetadata/io.netty/netty-codec-dns/index.json:25:    \"description\": \"Netty Codec DNS provides DNS protocol message types, encoders, and decoders for Netty's asynchronous networking framework. It supports building and parsing DNS queries and responses for resolver and DNS-related network components.\",\nmetadata/io.netty/netty-handler-proxy/index.json:5:    \"source-code-url\" : \"https://repo.maven.apache.org/maven2/io/netty/netty-handler-proxy/4.1.60.Final/netty-handler-proxy-4.1.60.Final-sources.jar\",\nmetadata/io.netty/netty-handler-proxy/index.json:6:    \"repository-url\" : \"https://github.com/netty/netty\",\nmetadata/io.netty/netty-handler-proxy/index.json:7:    \"test-code-url\" : \"https://repo.maven.apache.org/maven2/io/netty/netty-handler-proxy/4.1.60.Final/netty-handler-proxy-4.1.60.Final-test-sources.jar\",\nmetadata/io.netty/netty-handler-proxy/index.json:8:    \"documentation-url\" : \"https://repo.maven.apache.org/maven2/io/netty/netty-handler-proxy/4.1.60.Final/netty-handler-proxy-4.1.60.Final-javadoc.jar\",\nmetadata/io.netty/netty-handler-proxy/index.json:9:    \"description\" : \"Netty Handler Proxy adds client-side support for connecting through proxy protocols such as SOCKS and HTTP CONNECT tunneling. It provides proxy channel handlers and connection events that integrate with Netty's asynchronous networking pipeline.\",\nmetadata/io.netty/netty-transport-udt/index.json:5:    \"source-code-url\" : \"https://repo1.maven.org/maven2/io/netty/netty-transport-udt/4.1.74.Final/netty-transport-udt-4.1.74.Final-sources.jar\",\nmetadata/io.netty/netty-transport-udt/index.json:6:    \"repository-url\" : \"https://github.com/netty/netty\",\nmetadata/io.netty/netty-transport-udt/index.json:7:    \"test-code-url\" : \"https://repo1.maven.org/maven2/io/netty/netty-transport-udt/4.1.74.Final/netty-transport-udt-4.1.74.Final-test-sources.jar\",\nmetadata/io.netty/netty-transport-udt/index.json:8:    \"documentation-url\" : \"https://repo1.maven.org/maven2/io/netty/netty-transport-udt/4.1.74.Final/netty-transport-udt-4.1.74.Final-javadoc.jar\",\nmetadata/io.netty/netty-transport-udt/index.json:9:    \"description\" : \"Netty Transport UDT provides Netty channel implementations and configuration types for the UDT transport over NIO. It integrates Netty's asynchronous event-driven networking model with the Barchart UDT bundle, although the UDT transport was deprecated as no longer maintained in this release.\",\nmetadata/io.netty/netty-transport-native-unix-common/index.json:5:    \"source-code-url\" : \"https://repo.maven.apache.org/maven2/io/netty/netty-transport-native-unix-common/$version$/netty-transport-native-unix-common-$version$-sources.jar\",\nmetadata/io.netty/netty-transport-native-unix-common/index.json:6:    \"repository-url\" : \"https://github.com/netty/netty\",\nmetadata/io.netty/netty-transport-native-unix-common/index.json:7:    \"test-code-url\" : \"https://repo.maven.apache.org/maven2/io/netty/netty-transport-native-unix-common-tests/$version$/netty-transport-native-unix-common-tests-$version$-sources.jar\",\nmetadata/io.netty/netty-transport-native-unix-common/index.json:8:    \"documentation-url\" : \"https://repo.maven.apache.org/maven2/io/netty/netty-transport-native-unix-common/$version$/netty-transport-native-unix-common-$version$-javadoc.jar\",\nmetadata/io.netty/netty-transport-native-unix-common/index.json:9:    \"description\" : \"Netty Transport Native Unix Common provides shared JNI-backed Unix utility classes and native support used by Netty's Unix-based transport modules. It supplies common Unix socket address, file descriptor, and native library plumbing that higher-level Netty transports build on for asynchronous network clients and servers.\",\nmetadata/io.netty/netty-transport-classes-epoll/index.json:5:    \"source-code-url\" : \"https://repo.maven.apache.org/maven2/io/netty/netty-transport-classes-epoll/$version$/netty-transport-classes-epoll-$version$-sources.jar\",\nmetadata/io.netty/netty-transport-classes-epoll/index.json:6:    \"repository-url\" : \"https://github.com/netty/netty\",\nmetadata/io.netty/netty-transport-classes-epoll/index.json:7:    \"test-code-url\" : \"https://repo.maven.apache.org/maven2/io/netty/netty-transport-classes-epoll/$version$/netty-transport-classes-epoll-$version$-tests.jar\",\nmetadata/io.netty/netty-transport-classes-epoll/index.json:8:    \"documentation-url\" : \"https://repo.maven.apache.org/maven2/io/netty/netty-transport-classes-epoll/$version$/netty-transport-classes-epoll-$version$-javadoc.jar\",\nmetadata/io.netty/netty-transport-classes-epoll/index.json:9:    \"description\" : \"Provides the Java classes for Netty's Linux epoll transport, integrating epoll-based channels and event loops with Netty's transport APIs. It is used to build high-performance non-blocking network clients and servers on Linux when paired with the corresponding native epoll artifacts.\",\nmetadata/io.netty/netty-resolver-dns-c