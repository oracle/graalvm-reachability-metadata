o.netty/netty-transport-classes-kqueue/index.json:5:    \"source-code-url\" : \"https://repo.maven.apache.org/maven2/io/netty/netty-transport-classes-kqueue/$version$/netty-transport-classes-kqueue-$version$-sources.jar\",\nmetadata/io.netty/netty-transport-classes-kqueue/index.json:6:    \"repository-url\" : \"https://github.com/netty/netty\",\nmetadata/io.netty/netty-transport-classes-kqueue/index.json:7:    \"test-code-url\" : \"https://github.com/netty/netty/tree/netty-$version$/transport-native-kqueue/src/test/java/io/netty/channel/kqueue\",\nmetadata/io.netty/netty-transport-classes-kqueue/index.json:8:    \"documentation-url\" : \"https://repo.maven.apache.org/maven2/io/netty/netty-transport-classes-kqueue/$version$/netty-transport-classes-kqueue-$version$-javadoc.jar\",\nmetadata/io.netty/netty-transport-classes-kqueue/index.json:9:    \"description\" : \"Netty Transport Classes KQueue provides the Java classes that implement Netty's kqueue-based transport integration on BSD-derived operating systems such as macOS. It enables Netty applications to use the native kqueue event notification mechanism for high-performance asynchronous network I/O when paired with the matching native transport artifacts.\",\nmetadata/io.netty/netty-resolver-dns-classes-macos/index.json:5:    \"source-code-url\" : \"https://repo.maven.apache.org/maven2/io/netty/netty-resolver-dns-classes-macos/4.1.74.Final/netty-resolver-dns-classes-macos-4.1.74.Final-sources.jar\",\nmetadata/io.netty/netty-resolver-dns-classes-macos/index.json:6:    \"repository-url\" : \"https://github.com/netty/netty\",\nmetadata/io.netty/netty-resolver-dns-classes-macos/index.json:7:    \"test-code-url\" : \"https://repo.maven.apache.org/maven2/io/netty/netty-resolver-dns-classes-macos/4.1.74.Final/netty-resolver-dns-classes-macos-4.1.74.Final-tests.jar\",\nmetadata/io.netty/netty-resolver-dns-classes-macos/index.json:8:    \"documentation-url\" : \"https://repo.maven.apache.org/maven2/io/netty/netty-resolver-dns-classes-macos/4.1.74.Final/netty-resolver-dns-classes-macos-4.1.74.Final-javadoc.jar\",\nmetadata/io.netty/netty-resolver-dns-classes-macos/index.json:9:    \"description\" : \"Netty Resolver DNS Classes for macOS provides the Java-side classes used by Netty's macOS DNS resolver integration. It exposes a DNS server address stream provider that loads Netty's native macOS resolver library and reads the system nameserver configuration for DNS resolution.\",\nmetadata/io.netty/netty-transport-classes-epoll/index.json:5:    \"source-code-url\" : \"https://repo.maven.apache.org/maven2/io/netty/netty-transport-classes-epoll/$version$/netty-transport-classes-epoll-$version$-sources.jar\",\nmetadata/io.netty/netty-transport-classes-epoll/index.json:6:    \"repository-url\" : \"https://github.com/netty/netty\",\nmetadata/io.netty/netty-transport-classes-epoll/index.json:7:    \"test-code-url\" : \"https://repo.maven.apache.org/maven2/io/netty/netty-transport-classes-epoll/$version$/netty-transport-classes-epoll-$version$-tests.jar\",\nmetadata/io.netty/netty-transport-classes-epoll/index.json:8:    \"documentation-url\" : \"https://repo.maven.apache.org/maven2/io/netty/netty-transport-classes-epoll/$version$/netty-transport-classes-epoll-$version$-javadoc.jar\",\nmetadata/io.netty/netty-transport-classes-epoll/index.json:9:    \"description\" : \"Provides the Java classes for Netty's Linux epoll transport, integrating epoll-based channels and event loops with Netty's transport APIs. It is used to build high-performance non-blocking network clients and servers on Linux when paired with the corresponding native epoll artifacts.\",\nmetadata/io.netty/netty-transport-native-unix-common/index.json:5:    \"source-code-url\" : \"https://repo.maven.apache.org/maven2/io/netty/netty-transport-native-unix-common/$version$/netty-transport-native-unix-common-$version$-sources.jar\",\nmetadata/io.netty/netty-transport-native-unix-common/index.json:6:    \"repository-url\" : \"https://github.com/netty/netty\",\nmetadata/io.netty/netty-transport-native-unix-common/index.json:7:    \"test-code-url\" : \"https://repo.maven.apache.org/maven2/io/netty/netty-transport-native-unix-common-tests/$version$/netty-transport-native-unix-common-tests-$version$-sources.jar\",\nmetadata/io.netty/netty-transport-native-unix-common/index.json:8:    \"documentation-url\" : \"https://repo.maven.apache.org/maven2/io/netty/netty-transport-native-unix-common/$version$/netty-transport-native-unix-common-$version$-javadoc.jar\",\nmetadata/io.netty/netty-transport-native-unix-common/index.json:9:    \"description\" : \"Netty Transport Native Unix Common provides shared JNI-backed Unix utility classes and native support used by Netty's Unix-based transport modules. It supplies common Unix socket address, file descriptor, and native library plumbing that higher-level Netty transports build on for asynchronous network clients and servers.\",\n","exit_code":0,"status":"completed"}}
