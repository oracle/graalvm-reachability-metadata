void quartzEndpointReportsGroupsJobDetailsAndSanitizedJobData() {\\n        SanitizingFunction secretSanitizer = SanitizingFunction.sanitizeValue().ifKeyContains(\\\"secret\\\");\\n\\n        this.contextRunner.withPropertyValues(\\\"spring.quartz.auto-startup=false\\\")\\n                .withBean(\\\"endpointJobDetail\\\", JobDetail.class, Spring_boot_quartzTest::endpointJobDetail)\\n                .withBean(\\\"endpointTrigger\\\", Trigger.class, Spring_boot_quartzTest::endpointTrigger)\\n                .run((context) -> {\\n                    QuartzEndpoint endpoint = new QuartzEndpoint(context.getBean(Scheduler.class),\\n                            List.of(secretSanitizer));\\n\\n                    QuartzDescriptor report = endpoint.quartzReport();\\n                    assertThat(report.getJobs().getGroups()).contains(ENDPOINT_JOB_KEY.getGroup());\\n                    assertThat(report.getTriggers().getGroups()).contains(ENDPOINT_TRIGGER_KEY.getGroup());\\n\\n                    QuartzGroupsDescriptor jobGroups = endpoint.quartzJobGroups();\\n                    assertThat(jobGroups.getGroups()).containsEntry(ENDPOINT_JOB_KEY.getGroup(),\\n                            Map.of(\\\"jobs\\\", List.of(ENDPOINT_JOB_KEY.getName())));\\n\\n                    QuartzJobGroupSummaryDescriptor jobGroup = endpoint.quartzJobGroupSummary(ENDPOINT_JOB_KEY.getGroup());\\n                    assertThat(jobGroup.getGroup()).isEqualTo(ENDPOINT_JOB_KEY.getGroup());\\n                    assertThat(jobGroup.getJobs()).containsKey(ENDPOINT_JOB_KEY.getName());\\n                    assertThat(jobGroup.getJobs().get(ENDPOINT_JOB_KEY.getName()).getClassName())\\n                            .isEqualTo(SampleQuartzJob.class.getName());\\n\\n                    QuartzTriggerGroupSummaryDescriptor triggerGroup = endpoint.quartzTriggerGroupSummary(\\n                            ENDPOINT_TRIGGER_KEY.getGroup());\\n                    assertThat(triggerGroup.getGroup()).isEqualTo(ENDPOINT_TRIGGER_KEY.getGroup());\\n                    assertThat(triggerGroup.isPaused()).isFalse();\\n                    assertThat(triggerGroup.getTriggers().getSimple()).containsKey(ENDPOINT_TRIGGER_KEY.getName());\\n\\n                    QuartzJobDetailsDescriptor sanitizedJob = endpoint.quartzJob(ENDPOINT_JOB_KEY.getGroup(),\\n                            ENDPOINT_JOB_KEY.getName(), false);\\n                    assertThat(sanitizedJob.getData()).containsEntry(\\\"visible\\\", \\\"orders\\\")\\n                            .containsEntry(\\\"apiSecret\\\", SanitizableData.SANITIZED_VALUE);\\n                    assertThat(sanitizedJob.getTriggers()).singleElement().satisfies((trigger) -> assertThat(trigger)\\n                            .containsEntry(\\\"group\\\", ENDPOINT_TRIGGER_KEY.getGroup())\\n                            .containsEntry(\\\"name\\\", ENDPOINT_TRIGGER_KEY.getName()));\\n\\n                    QuartzJobDetailsDescriptor unsanitizedJob = endpoint.quartzJob(ENDPOINT_JOB_KEY.getGroup(),\\n                            ENDPOINT_JOB_KEY.getName(), true);\\n                    assertThat(unsanitizedJob.getData()).containsEntry(\\\"apiSecret\\\", \\\"keep-private\\\");\\n                });\\n    }\\n\\n    private static JobDetail sampleJobDetail() {\\n\"}, {\"oldText\": \"    private static Trigger sampleTrigger() {\\n        JobDataMap data = new JobDataMap();\\n        data.put(\\\"trigger\\\", \\\"boot-auto-configuration\\\");\\n        return TriggerBuilder.newTrigger()\\n                .withIdentity(TRIGGER_KEY)\\n                .forJob(JOB_KEY)\\n                .usingJobData(data)\\n                .startAt(Date.from(Instant.now().plus(Duration.ofHours(1))))\\n                .withSchedule(SimpleScheduleBuilder.simpleSchedule().withIntervalInHours(1).withRepeatCount(0))\\n                .build();\\n    }\\n\\n    public static class SampleQuartzJob implements Job {\\n\", \"newText\": \"    private static Trigger sampleTrigger() {\\n        JobDataMap data = new JobDataMap();\\n        data.put(\\\"trigger\\\", \\\"boot-auto-configuration\\\");\\n        return TriggerBuilder.newTrigger()\\n                .withIdentity(TRIGGER_KEY)\\n                .forJob(JOB_KEY)\\n                .usingJobData(data)\\n                .startAt(Date.from(Instant.now().plus(Duration.ofHours(1))))\\n                .withSchedule(SimpleScheduleBuilder.simpleSchedule().withIntervalInHours(1).withRepeatCount(0))\\n                .build();\\n    }\\n\\n    private static JobDetail endpointJobDetail() {\\n        JobDataMap data = new JobDataMap();\\n        data.put(\\\"visible\\\", \\\"orders\\\");\\n        data.put(\\\"apiSecret\\\", \\\"keep-private\\\");\\n        return JobBuilder.newJob(SampleQuartzJob.class)\\n                .withIdentity(ENDPOINT_JOB_KEY)\\n                .usingJobData(data)\\n                .storeDurably()\\n                .build();\\n    }\\n\\n    private static Trigger endpointTrigger() {\\n        return TriggerBuilder.newTrigger()\\n                .withIdentity(ENDPOINT_TRIGGER_KEY)\\n                .forJob(ENDPOINT_JOB_KEY)\\n                .startAt(Date.from(Instant.now().plus(Duration.ofHours(2))))\\n                .withSchedule(SimpleScheduleBuilder.simpleSchedule().withIntervalInMinutes(30).withRepeatCount(1))\\n                .build();\\n    }\\n\\n    public static class SampleQuartzJob implements Job {\\n\"}]}}], \"api\": \"openai-responses\", \"provider\": \"OCA\", \"model\": \"oca/gpt-5.5\", \"usage\": {\"input\": 3156, \"output\": 3283, \"cacheRead\": 54784, \"cacheWrite\": 0, \"totalTokens\": 61223, \"cost\": {\"input\": 0, \"output\": 0, \"cacheRead\": 0, \"cacheWrite\": 0, \"total\": 0}}, \"stopReason\": \"toolUse\", \"timestamp\": 1782573031652, \"responseId\": \"resp_085067120dea2f11016a3fe7e84800819693d75e5102639477\"}, \"toolResults\": [{\"role\": \"toolResult\", \"toolCallId\": \"call_1zYju80Aam8MJqOzbkE8pEx9|fc_085067120dea2f11016a3fe7fdb5d081968ad04f9efb3b9b40\"