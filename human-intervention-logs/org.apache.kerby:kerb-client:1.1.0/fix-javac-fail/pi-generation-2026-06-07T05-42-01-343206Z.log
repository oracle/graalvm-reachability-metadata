       */
      public String getRenewLifetime() {
          try {
              return Long.toString(getLong(KrbConfigKey.RENEW_LIFETIME, true, LIBDEFAULT));
          } catch (Exception e) {
              return getString(KrbConfigKey.RENEW_LIFETIME, true, LIBDEFAULT);
          }
      }
  
