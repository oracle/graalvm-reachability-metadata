ed for `{claimed_issue.issue_coordinates}`, but dynamic-access coverage remains \"\nforge/forge_metadata.py:2708:        \"This suggests the generated tests are not exercising the required dynamic-access paths well enough.\\n\\n\"\nforge/forge_metadata.py:2710:        \"- Inspect the generated tests and compare them with the dynamic-access report to find uncovered call sites.\\n\"\nforge/forge_metadata.py:2821:    coverage_details = \"- Dynamic-access coverage: unavailable\"\nforge/forge_metadata.py:2825:            f\"- Dynamic-access coverage: {candidate.coverage.covered_calls}/\"\nforge/forge_metadata.py:2844:        f\"- Human-intervention reason: {candidate.reason}\\n\"\nforge/forge_metadata.py:3012:    if candidate.reason in {\"test_generation_failed\", \"job_failed\"}:\nforge/forge_metadata.py:3027:    if not claimed_issue_worktree_is_valid(claimed_issue, \"human-intervention analysis\"):\nforge/forge_metadata.py:3044:            f\"ERROR: Human-intervention analysis failed for issue #{claimed_issue.issue['number']}: {exc!r}\",\nforge/forge_metadata.py:3183:        f\"ai/{authenticated_login}/human-intervention/\"\nforge/forge_metadata.py:3291:    \"\"\"Refresh library logs on an already pushed human-intervention branch.\"\"\"\nforge/forge_metadata.py:3339:    \"\"\"Post the human-intervention comment and always attempt to apply the label.\"\"\"\nforge/forge_metadata.py:3348:                f\"ERROR: Failed to post human-intervention comment to issue #{issue_number}: {exc!r}\",\nforge/forge_metadata.py:3369:    \"\"\"Post a human-intervention comment and label when an issue run needs follow-up.\"\"\"\nforge/forge_metadata.py:3387:            f\"ERROR: Failed to apply human-intervention follow-up to issue #{claimed_issue.issue['number']}: {exc!r}\",\nforge/forge_metadata.py:3413:            reason=\"job_failed\",\nforge/forge_metadata.py:3477:            pipeline_argv.append(\"--keep-tests-without-dynamic-access\")\nforge/forge_metadata.py:3493:            f\"