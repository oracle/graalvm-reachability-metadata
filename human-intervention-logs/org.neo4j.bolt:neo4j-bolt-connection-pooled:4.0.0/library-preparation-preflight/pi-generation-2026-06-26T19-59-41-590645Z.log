              await(connection.beginTransaction(
                      DATABASE_NAME,
                      AccessMode.READ,
                      "neo4j-user",
                      Set.of("bookmark-2"),
                      TransactionType.UNCONSTRAINED,
                      Duration.ofSeconds(2),
                      metadata,
                      "tx-2",
  
