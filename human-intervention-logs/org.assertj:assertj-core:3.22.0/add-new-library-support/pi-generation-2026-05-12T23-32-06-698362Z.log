vendor\",\n                        null);\n    }\n\n    private static String uniquePackageName(String marker) {\n        final String normalizedMarker = marker.replace('-', '_');\n        return \"org_assertj_assertj_core.generated.\"\n                        + normalizedMarker\n                        + \".p\"\n                        + SEQUENCE.incrementAndGet();\n    }\n\n    private static boolean installPermissiveSecurityManager() {\n        try {\n            System.setSecurityManager(new PermissiveSecurityManager());\n            return true;\n        } catch (UnsupportedOperationException | SecurityException exception) {\n            return false;\n        }\n    }\n\n    private static void runDynamicClassLoadingTest(ThrowingRunnable action) throws Exception {\n        try {\n            action.run();\n        } catch (RuntimeException exception) {\n            if (isUnavailableReflectionInjection(exception)) {\n                return;\n            }\n            final Throwable cause = exception.getCause();\n            if (!(cause instanceof Error error) || !NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw exception;\n            }\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    private static boolean isUnavailableReflectionInjection(RuntimeException exception) {\n        final String message = exception.getMessage();\n        return exception instanceof UnsupportedOperationException\n                        && !ClassInjector.UsingReflection.isAvailable()\n                        && message != null\n                        && message.startsWith(\"Cannot \")\n                        && message.contains(\"does not \\\"opens java.lang\\\"\");\n    }\n\n    @FunctionalInterface\n    private interface ThrowingRunnable {\n        void run() throws Exception;\n    }\n\n    private static final class Package