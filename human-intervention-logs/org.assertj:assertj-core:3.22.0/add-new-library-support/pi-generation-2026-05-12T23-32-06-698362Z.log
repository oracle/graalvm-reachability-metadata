  package org_assertj.assertj_core;
  
  import static org.junit.jupiter.api.Assertions.assertEquals;
  import static org.junit.jupiter.api.Assertions.assertNotNull;
  import static org.junit.jupiter.api.Assertions.assertSame;
  
  import java.net.URL;
  import java.net.URLClassLoader;
  import java.security.Permission;
  import java.util.Collections;
  import java.util.Map;
  import java.util.concurrent.atomic.AtomicInteger;
  
  import org.assertj.core.internal.bytebuddy.ByteBuddy;
  import org.assertj.core.internal.bytebuddy.dynamic.loading.ClassInjector;
  import org.assertj.core.internal.bytebuddy.dynamic.loading.PackageDefinitionStrategy;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  
  public class ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeInjectionTest {
      private static final AtomicInteger SEQUENCE = new AtomicInteger();
  
      @Test
      void injectsClassAndDefinesPackageWhileSecurityManagerIsPresent() throws Exception {
          runDynamicClassLoadingTest(() -> {
              final SecurityManager previousSecurityManager = System.getSecurityManager();
              final boolean securityManagerInstalled = installPermissiveSecurityManager();
              try {
                  final String marker = securityManagerInstalled ? "security-manager" : "no-security-manager";
                  injectClassAndAssertPackage(new URLClassLoader(new URL[0], null), marker);
              } finally {
                  if (securityManagerInstalled) {
                      System.setSecurityManager(previousSecurityManager);
                  }
              }
          });
      }
  
      @Test
      void fallsBackToGetPackageWhenPackageDefinitionRaces() throws Exception {
          runDynamicClassLoadingTest(() -> {
              try (PackageRaceClassLoader classLoader = new PackageRaceClassLoader()) {
                  final String packageName = uniquePackageName("package-race");
                  final String className = packageName + ".Generated";
                  final Class<?> injected = inject(classLoader, className, packageDefinitionStrategy("package-race"));
  
                  assertSame(classLoader, injected.getClassLoader());
                  assertEquals(className, injected.getName());
                  assertNotNull(injected.getPackage());
                  assertEquals("package-race implementation", injected.getPackage().getImplementationTitle());
              }
          });
      }
  
      private static void injectClassAndAssertPackage(URLClassLoader classLoader, String marker) throws Exception {
          try (classLoader) {
              final String packageName = uniquePackageName(marker);
              final String className = packageName + ".Generated";
              final Class<?> injected = inject(classLoader, className, packageDefinitionStrategy(marker));
  
              assertSame(classLoader, injected.getClassLoader());
              assertEquals(className, injected.getName());
              assertNotNull(injected.getPackage());
              assertEquals(marker + " specification", injected.getPackage().getSpecificationTitle());
              assertEquals(marker + " implementation", injected.getPackage().getImplementationTitle());
          }
      }
  
      private static Class<?> inject(
                      ClassLoader classLoader,
                      String className,
                      PackageDefinitionStrategy packageDefinitionStrategy) {
          final byte[] classBytes = new ByteBuddy()
                          .subclass(Object.class)
                          .name(className)
                          .make()
                          .getBytes();
          final ClassInjector classInjector = new ClassInjector.UsingReflection(
                          classLoader,
                          null,
                          packageDefinitionStrategy,
                          true);
          final Map<String, Class<?>> injected = classInjector.injectRaw(Collections.singletonMap(className, classBytes));
          return injected.get(className);
      }
  
      private static PackageDefinitionStrategy packageDefinitionStrategy(String marker) {
          return (classLoader, packageName, typeName) -> new PackageDefinitionStrategy.Definition.Simple(
                          marker + " specification",
                          "1.0",
                          marker + " specification vendor",
                          marker + " implementation",
                          "1.0",
                          marker + " implementation vendor",
                          null);
      }
  
      private static String uniquePackageName(String marker) {
          final String normalizedMarker = marker.replace('-', '_');
          return "org_assertj_assertj_core.generated."
                          + normalizedMarker
                          + ".p"
                          + SEQUENCE.incrementAndGet();
      }
  
      private static boolean installPermissiveSecurityManager() {
          try {
              System.setSecurityManager(new PermissiveSecurityManager());
              return true;
          } catch (UnsupportedOperationException | SecurityException exception) {
              return false;
          }
      }
  
      private static void runDynamicClassLoadingTest(ThrowingRunnable action) throws Exception {
          try {
              action.run();
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
      }
  
      @FunctionalInterface
      private interface ThrowingRunnable {
          void run() throws Exception;
      }
  
      private static final class PackageRaceClassLoader extends URLClassLoader {
          private boolean packageDefinitionRace = true;
  
          private PackageRaceClassLoader() {
              super(new URL[0], null);
          }
  
          @Override
          protected Package definePackage(
                          String name,
                          String specTitle,
                          String specVersion,
                          String specVendor,
                          String implTitle,
                          String implVersion,
                          String implVendor,
                          URL sealBase) {
              final Package definedPackage = super.definePackage(
                              name,
                              specTitle,
                              specVersion,
                              specVendor,
                              implTitle,
                              implVersion,
                              implVendor,
                              sealBase);
              if (packageDefinitionRace) {
                  packageDefinitionRace = false;
                  throw new IllegalStateException("Package was defined concurrently: " + definedPackage.getName());
              }
              return definedPackage;
          }
      }
  
      private static final class PermissiveSecurityManager extends SecurityManager {
          @Override
          public void checkPermission(Permission permission) {
              // Permit all actions so the test only exercises Byte Buddy's security-manager branch.
          }
      }
  }
