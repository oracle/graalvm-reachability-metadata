  package org_assertj.assertj_core;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.util.AbstractMap;
  import java.util.LinkedHashMap;
  import java.util.Set;
  import java.util.concurrent.ConcurrentHashMap;
  
  import org.junit.jupiter.api.Test;
  
  public class MapsTest {
      @Test
      void containsOnlyKeysUsesCloneMethodForCloneableMaps() {
          Map<String, Integer> actual = new LinkedHashMap<>();
          actual.put("one", 1);
          actual.put("two", 2);
  
          assertThat(actual).containsOnlyKeys("one", "two");
      }
  
      @Test
      void containsOnlyKeysUsesCopyConstructorForNonCloneableMaps() {
          ConcurrentHashMap<String, Integer> actual = new ConcurrentHashMap<>();
          actual.put("one", 1);
          actual.put("two", 2);
  
          assertThat(actual).containsOnlyKeys("one", "two");
      }
  
      @Test
      void containsOnlyKeysUsesDefaultConstructorForNonCloneableMapsWithoutCopyConstructor() {
          DefaultConstructorMap<String, Integer> actual = new DefaultConstructorMap<>();
          actual.put("one", 1);
          actual.put("two", 2);
  
          assertThat(actual).containsOnlyKeys("one", "two");
      }
  
      public static class DefaultConstructorMap<K, V> extends AbstractMap<K, V> {
          private final LinkedHashMap<K, V> entries = new LinkedHashMap<>();
  
          public DefaultConstructorMap() {
          }
  
          @Override
          public V put(K key, V value) {
              return entries.put(key, value);
          }
  
          @Override
          public Set<Entry<K, V>> entrySet() {
              return entries.entrySet();
          }
      }
  }
