[tool-call] delta {"path":"tests/src/org.assertj/assertj-core/3.22.0/src/test/java/org_assertj/assertj_core/MapsTest.java","edits":[{"oldText":"import java.util.Map;\nimport java.util.Set;\n","newText":"import java.util.Set;\nimport java.util.concurrent.ConcurrentHashMap;\n"},{"oldText":"    void containsOnlyKeysUsesCopyConstructorForNonCloneableMaps() {\n        CopyConstructorMap<String, Integer> actual = new CopyConstructorMap<>();\n        actual.put(\"one\", 1);\n        actual.put(\"two\", 2);\n\n        assertThat(actual).containsOnlyKeys(\"one\", \"two\");\n    }\n\n","newText":"    void containsOnlyKeysUsesCopyConstructorForNonCloneableMaps() {\n        ConcurrentHashMap<String, Integer> actual = new ConcurrentHashMap<>();\n        actual.put(\"one\", 1);\n        actual.put(\"two\", 2);\n\n        assertThat(actual).containsOnlyKeys(\"one\", \"two\");\n    }\n\n"},{"oldText":"    public static class CopyConstructorMap<K, V> extends AbstractMap<K, V> {\n        private final LinkedHashMap<K, V> entries;\n\n        public CopyConstructorMap() {\n            this.entries = new LinkedHashMap<>();\n        }\n\n        public CopyConstructorMap(Map<K, V> source) {\n            this.entries = new LinkedHashMap<>(source);\n        }\n\n        @Override\n        public V put(K key, V value) {\n            return entries.put(key, value);\n        }\n\n        @Override\n        public Set<Entry<K, V>> entrySet() {\n            return entries.entrySet();\n        }\n    }\n\n","newText":""}]}
