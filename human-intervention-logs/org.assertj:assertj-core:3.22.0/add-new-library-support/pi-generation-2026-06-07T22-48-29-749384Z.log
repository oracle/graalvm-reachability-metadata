       String agentClassResource = AssertjModuleOpenerAgent.class.getName().replace('.', '/') + \".class\";\n            jarOutputStream.putNextEntry(new JarEntry(agentClassResource));\n            ClassLoader classLoader = AssertjModuleOpenerAgent.class.getClassLoader();"}, {"oldText": "    public static final class ExternalAttacher {\n        public static void main(String[] arguments) throws Exception {\n            VirtualMachine virtualMachine = VirtualMachine.attach(arguments[0]);\n            try {\n                virtualMachine.loadAgent(arguments[1]);\n            } finally {\n                virtualMachine.detach();\n            }\n        }\n    }\n\n    public static final class ModuleOpenerAgent {\n        public static void agentmain(String arguments, Instrumentation instrumentation) throws Exception {\n            Set<Module> targetModules = new HashSet<>();\n            for (Class<?> loadedClass : instrumentation.getAllLoadedClasses()) {\n                Module module = loadedClass.getModule();\n                if (!module.isNamed()) {\n                    targetModules.add(module);\n                }\n            }\n            if (targetModules.isEmpty()) {\n                targetModules.add(ModuleOpenerAgent.class.getModule());\n            }\n            instrumentation.redefineModule(Object.class.getModule(),\n                    Set.of(),\n                    Map.of(),\n                    Map.of(\"java.lang\", targetModules,\n                            \"java.lang.reflect\", targetModules,\n                            \"jdk.internal.misc\", targetModules),\n                    Set.of(),\n                    Map.of());\n            instrumentation.redefineModule(Class.forName(\"sun.misc.Unsafe\").getModule(),\n                    Set.of(),\n                    Map.of(),\n                    Map.of(\"sun.misc\", targetModules),\n                    Set.of(),\n                    Map.of());\n        }\n    }\n\n", "newText": ""}]}}], "api": "op