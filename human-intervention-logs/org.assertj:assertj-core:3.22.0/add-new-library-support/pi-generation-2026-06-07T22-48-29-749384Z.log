ceAsStream(agentClassResource)) {\n                if (inputStream == null) {\n                    throw new IOException(\"Cannot find module opener agent class resource\");\n                }\n                inputStream.transferTo(jarOutputStream);\n            }\n            jarOutputStream.closeEntry();\n        }\n        return agentJar;\n    }\n\n    private static void runByteCodeGeneratingTest(ThrowingRunnable runnable) throws Exception {\n        try {\n            runnable.run();\n        } catch (UnsupportedOperationException exception) {\n            if (!isLegacyInjectionUnavailable(exception)) {\n                throw exception;\n            }\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    private static boolean isLegacyInjectionUnavailable(UnsupportedOperationException exception) {\n        String message = exception.getMessage();\n        return message != null\n                && (message.startsWith(\"Cannot get defined package using reflection:\")\n                        || message.startsWith(\"Cannot get package using reflection:\")\n                        || message.startsWith(\"Cannot define package using injection:\")\n                        || message.startsWith(\"Cannot define class using reflection:\"));\n    }\n\n    @FunctionalInterface\n    private interface ThrowingRunnable {\n        void run() throws Exception;\n    }\n\n    public static final class ExternalAttacher {\n        public static void main(String[] arguments) throws Exception {\n            VirtualMachine virtualMachine = VirtualMachine.attach(arguments[0]);\n            try {\n                virtualMachine.loadAgent(arguments[1]);\n            } finally {\n                virtualMachine.detach();\n            }\n        }\n    }\n\n    public static final class ModuleOpenerAgent {\n        public static void agentmain(String arguments, Instrumentation instrumentation) throws Exception {\n            Set<Module> targetModules = new HashSet<>();\n            for (Class<?> loadedClass : instrumentation.getAllLoadedClasses()) {\n                Module module = loadedClass.getModule();\n                if (!module.isNamed()) {\n                    targetModules.add(module);\n                }\n            }\n            if (targetModules.isEmpty()) {\n                targetModules.add(ModuleOpenerAgent.class.getModule());\n            }\n            instrumentation.redefineModule(Object.class.getModule(),\n                    Set.of(),\n                    Map.of(),\n                    Map.of(\"java.lang\", targetModules,\n                            \"java.lang.reflect\", targetModules,\n                            \"jdk.internal.misc\", targetModules),\n                    Set.of(),\n                    Map.of());\n            instrumentation.redefineModule(Class.forName(\"sun.misc.Unsafe\").getModule(),\n                    Set.of(),\n                    Map.of(),\n                    Map.of(\"sun.misc\", targetModules),\n                    Set.of(),\n                    Map.of());\n        }\n    }\n\n    private static final class ExposedPackageClassLoader extends ClassLoader {\n        ExposedPackageClassLoader() {\n            super(ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeInjectionTest.class.getClassLoader());\n        }\n\n        boolean isPackageDefined(String packageName) {\n            return getDefinedPackage(packageName) != null;\n        }\n\n        Package defineGeneratedPackage(String packageName) {\n            return definePackage(packageName, null, null, null, null, null, null, null);\n        }\n    }\n\n    private static final class DefinePackageDuringMetadataLookup implements PackageDefinitionStrategy, Definition {\n        private final ExposedPackageClassLoader classLoader;\n        private final String packageName;\n        private boolean packageDefined