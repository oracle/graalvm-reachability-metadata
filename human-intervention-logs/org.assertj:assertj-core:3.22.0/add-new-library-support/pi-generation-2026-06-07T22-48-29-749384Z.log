        .isEqualTo(new Person(\"Ada\", 37));\n            }\n        });\n    }\n\n    private static void runByteCodeGeneratingTest(ThrowingRunnable runnable) throws Exception {\n        try {\n            runnable.run();\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    @FunctionalInterface\n    private interface ThrowingRunnable {\n        void run() throws Exception;\n    }\n\n    private static final class Person {\n        private final String name;\n        private final int age;\n\n        private Person(String name, int age) {\n            this.name = name;\n            this.age = age;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 2107, "output": 1369, "cacheRead": 64512, "cacheWrite": 0, "totalTokens": 67988, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780872536458, "responseId": "resp_079fc6a7bc1ecf8e016a25f5593a248190af2c3b5235f03ae2"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_fokVnE7cZJuhX5jnzFKhgB0c|fc_079fc6a7bc1ecf8e016a25f56f608881908120db78d8b0b1ac", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2222 bytes to tests/src/org.assertj/assertj-core/3.22.0/src/test/java/org_assertj/assertj_core/ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeInjectionTest.java"}], "isError": false, "timestamp": 1780872564105}]}
