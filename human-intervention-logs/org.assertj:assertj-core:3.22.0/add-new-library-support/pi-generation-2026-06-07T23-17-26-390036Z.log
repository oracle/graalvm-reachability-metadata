= nextPackageName(\"defined\");\n                Class<?> generatedType = injectObjectSubclass(definedPackageName + \".GeneratedType\", classLoader,\n                        PackageDefinitionStrategy.Trivial.INSTANCE);\n                assertSame(classLoader, generatedType.getClassLoader());\n                assertTrue(classLoader.isPackageDefined(definedPackageName));\n\n                String fallbackPackageName = nextPackageName(\"fallback\");\n                Class<?> fallbackType = injectObjectSubclass(fallbackPackageName + \".GeneratedType\", classLoader,\n                        new DefinePackageDuringMetadataLookup(classLoader, fallbackPackageName));\n                assertSame(classLoader, fallbackType.getClassLoader());\n                assertTrue(classLoader.isPackageDefined(fallbackPackageName));\n            } finally {\n                if (securityManagerChanged) {\n                    System.setSecurityManager(previousSecurityManager);\n                }\n                restoreSafeProperty(previousSafeProperty);\n            }\n        } catch (UnsupportedOperationException exception) {\n            if (!isLegacyInjectionUnavailable(exception)) {\n                throw exception;\n            }\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    private static void initializeUnsafeInjectorAsUnavailable(String previousSafeProperty) {\n        System.setProperty(BYTE_BUDDY_SAFE_PROPERTY, Boolean.TRUE.toString());\n        ClassInjector.UsingUnsafe.isAvailable();\n        restoreSafeProperty(previousSafeProperty);\n    }\n\n    private static Class<?> injectObjectSubclass(String name, ClassLoader classLoader,\n            PackageDefinitionStrategy packageDefinitionStrategy) {\n        byte[] classFile = new ByteBuddy()\n                .subclass(Object.class)\n                .name(name)\n                .make()\n                .getBytes();\n        ClassInjector classInjector = new ClassInjector.UsingReflection(classLoader,\n                ClassLoadingStrategy.NO_PROTECTION_DOMAIN,\n                packageDefinitionStrategy,\n                false);\n        return classInjector.injectRaw(Map.of(name, classFile)).get(name);\n    }\n\n    private static String nextPackageName(String label) {\n        return ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeOverrideTest.class.getPackageName()\n                + \".generated.\" + label + CLASS_COUNTER.incrementAndGet();\n    }\n\n    private static boolean installPermissiveSecurityManagerIfPossible() {\n        try {\n            System.setSecurityManager(new SecurityManager() {\n                @Override\n                public void checkPermission(Permission permission) {\n                }\n            });\n            return true;\n        } catch (SecurityException | UnsupportedOperationException ignored) {\n            return false;\n        }\n    }\n\n    private static void restoreSafeProperty(String previousSafeProperty) {\n        if (previousSafeProperty == null) {\n            System.clearProperty(BYTE_BUDDY_SAFE_PROPERTY);\n        } else {\n            System.setProperty(BYTE_BUDDY_SAFE_PROPERTY, previousSafeProperty);\n        }\n    }\n\n    private static boolean isLegacyInjectionUnavailable(UnsupportedOperationException exception) {\n        String message = exception.getMessage();\n        return message != null\n                && (message.startsWith(\"Cannot get defined package using reflection:\")\n                        || message.startsWith(\"Cannot get package using reflection:\")\n                        || message.startsWith(\"Cannot define package using injection:\")\n                        || message.startsWith(\"Cannot define class using reflection:\"));\n    }\n\n    private static final class ExposedPackageClassLoader extends ClassLoader {\n        private ExposedPackageClassLoader() {\n       