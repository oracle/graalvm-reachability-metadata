  package org_assertj.assertj_core;
  
  import static org.junit.jupiter.api.Assertions.assertArrayEquals;
  import static org.junit.jupiter.api.Assertions.assertEquals;
  import static org.junit.jupiter.api.Assertions.assertFalse;
  import static org.junit.jupiter.api.Assertions.assertSame;
  import static org.junit.jupiter.api.Assertions.assertTrue;
  
  import java.io.IOException;
  import java.io.InputStream;
  import java.lang.instrument.ClassFileTransformer;
  import java.nio.file.Files;
  import java.nio.file.Path;
  import java.security.ProtectionDomain;
  import java.lang.reflect.Method;
  import java.util.Collection;
  import java.util.LinkedHashMap;
  import java.util.List;
  import java.util.Map;
  import java.util.concurrent.TimeUnit;
  import java.util.jar.Attributes;
  import java.util.jar.JarEntry;
  import java.util.jar.JarOutputStream;
  import java.util.jar.Manifest;
  
  import org.assertj.core.internal.bytebuddy.agent.builder.LambdaFactory;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  
  public class LambdaFactoryTest {
      private static final Object CALLER = new Object();
      private static final Object INVOKED_TYPE = new Object();
      private static final Object SAM_METHOD_TYPE = new Object();
      private static final Object IMPLEMENTATION_METHOD = new Object();
      private static final Object INSTANTIATED_METHOD_TYPE = new Object();
  
      @Test
      void registeredFactoryCreatesLambdaClassBytesAndCanBeReleased() throws Exception {
          runLambdaFactoryTest(() -> {
              openJavaBasePackagesForLegacyByteBuddyInjectionIfPossible();
              byte[] expectedBytes = new byte[] {1, 2, 3, 5, 8};
              RecordingLambdaClassFileFactory classFileFactory = new RecordingLambdaClassFileFactory(expectedBytes);
              ClassFileTransformer transformer = new NoOpClassFileTransformer();
  
              try {
                  assertTrue(LambdaFactory.register(transformer, classFileFactory));
                  assertTrue(LambdaFactory.release(transformer));
              } finally {
                  LambdaFactory.release(transformer);
              }
              assertFalse(LambdaFactory.CLASS_FILE_TRANSFORMERS.containsKey(transformer));
          });
      }
  
      @Test
      void makeDispatchesToRegisteredFactory() throws Exception {
          byte[] expectedBytes = new byte[] {1, 2, 3, 5, 8};
          RecordingLambdaClassFileFactory classFileFactory = new RecordingLambdaClassFileFactory(expectedBytes);
          ClassFileTransformer transformer = new NoOpClassFileTransformer();
          LambdaFactory lambdaFactory = new LambdaFactory(classFileFactory, dispatcherMethod());
          Map<ClassFileTransformer, LambdaFactory> registeredFactories = LambdaFactory.CLASS_FILE_TRANSFORMERS;
          Map<ClassFileTransformer, LambdaFactory> previousFactories = new LinkedHashMap<>(registeredFactories);
  
          synchronized (registeredFactories) {
              registeredFactories.clear();
              registeredFactories.put(transformer, lambdaFactory);
              try {
                  byte[] generatedBytes = LambdaFactory.make(CALLER,
                          "apply",
                          INVOKED_TYPE,
                          SAM_METHOD_TYPE,
                          IMPLEMENTATION_METHOD,
                          INSTANTIATED_METHOD_TYPE,
                          true,
                          List.of(Runnable.class),
                          List.of());
  
                  assertArrayEquals(expectedBytes, generatedBytes);
                  assertEquals(1, classFileFactory.invocationCount);
                  assertSame(CALLER, classFileFactory.caller);
                  assertEquals("apply", classFileFactory.invokedName);
                  assertSame(INVOKED_TYPE, classFileFactory.invokedType);
                  assertSame(SAM_METHOD_TYPE, classFileFactory.samMethodType);
                  assertSame(IMPLEMENTATION_METHOD, classFileFactory.implementationMethod);
                  assertSame(INSTANTIATED_METHOD_TYPE, classFileFactory.instantiatedMethodType);
                  assertTrue(classFileFactory.serializable);
                  assertEquals(List.of(Runnable.class), classFileFactory.markerInterfaces);
                  assertEquals(List.of(), classFileFactory.additionalBridges);
                  assertTrue(classFileFactory.classFileTransformers.contains(transformer));
              } finally {
                  registeredFactories.clear();
                  registeredFactories.putAll(previousFactories);
              }
          }
      }
  
      private static Method dispatcherMethod() throws NoSuchMethodException {
          return RecordingLambdaClassFileFactory.class.getMethod("make",
                  Object.class,
                  String.class,
                  Object.class,
                  Object.class,
                  Object.class,
                  Object.class,
                  boolean.class,
                  List.class,
                  List.class,
                  Collection.class);
      }
  
      private static void runLambdaFactoryTest(ThrowingRunnable runnable) throws Exception {
          try {
              runnable.run();
          } catch (UnsupportedOperationException exception) {
              if (!isLegacyInjectionUnavailable(exception)) {
                  throw exception;
              }
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
      }
  
      private static void openJavaBasePackagesForLegacyByteBuddyInjectionIfPossible() {
          try {
              Path agentJar = createModuleOpenerAgentJar();
              try {
                  attachAgentFromExternalProcess(agentJar);
              } finally {
                  Files.deleteIfExists(agentJar);
              }
          } catch (Exception | LinkageError ignored) {
              // AssertJ can use an already available dispatcher when reflective injection cannot be opened.
          }
      }
  
      private static void attachAgentFromExternalProcess(Path agentJar) throws IOException, InterruptedException {
          String javaExecutable = Path.of(System.getProperty("java.home"), "bin", "java").toString();
          String helperClasspath = System.getProperty("java.class.path");
          Process process = new ProcessBuilder(javaExecutable,
                  "--add-modules", "jdk.attach",
                  "-cp", helperClasspath,
                  AssertjExternalAttacher.class.getName(),
                  Long.toString(ProcessHandle.current().pid()),
                  agentJar.toString())
                  .redirectOutput(ProcessBuilder.Redirect.DISCARD)
                  .redirectError(ProcessBuilder.Redirect.DISCARD)
                  .start();
          if (!process.waitFor(20, TimeUnit.SECONDS)) {
              process.destroyForcibly();
          }
      }
  
      private static Path createModuleOpenerAgentJar() throws IOException {
          Path agentJar = Files.createTempFile("assertj-lambda-factory-module-opener", ".jar");
          Manifest manifest = new Manifest();
          Attributes attributes = manifest.getMainAttributes();
          attributes.put(Attributes.Name.MANIFEST_VERSION, "1.0");
          attributes.put(new Attributes.Name("Agent-Class"), AssertjModuleOpenerAgent.class.getName());
  
          try (JarOutputStream jarOutputStream = new JarOutputStream(Files.newOutputStream(agentJar), manifest)) {
              String agentClassResource = AssertjModuleOpenerAgent.class.getName().replace('.', '/') + ".class";
              jarOutputStream.putNextEntry(new JarEntry(agentClassResource));
              ClassLoader classLoader = AssertjModuleOpenerAgent.class.getClassLoader();
              try (InputStream inputStream = classLoader.getResourceAsStream(agentClassResource)) {
                  if (inputStream == null) {
                      throw new IOException("Cannot find module opener agent class resource");
                  }
                  inputStream.transferTo(jarOutputStream);
              }
              jarOutputStream.closeEntry();
          }
          return agentJar;
  
