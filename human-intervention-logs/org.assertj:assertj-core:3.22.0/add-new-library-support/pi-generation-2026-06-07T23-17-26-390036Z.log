  import org.junit.jupiter.api.Test;
  
  public class ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeInjectionTest {
      private static final AtomicInteger CLASS_COUNTER = new AtomicInteger();
  
      @Test
      void softAssertionsCreateGeneratedAssertionProxies() throws Exception {
          runByteCodeGeneratingTest(() -> {
              openJavaBasePackagesForLegacyByteBuddyInjectionIfPossible();
              try (AutoCloseableSoftAssertions softly = new AutoCloseableSoftAssertions()) {
                  softly.assertThat("assertj byte buddy proxy").startsWith("assertj").contains("buddy");
                  softly.assertThat(42).isPositive().isGreaterThan(10);
                  softly.assertThat(List.of("alpha", "beta", "gamma"))
                          .hasSize(3)
                          .contains("beta")
                          .allSatisfy(value -> assertEquals(value, value.toLowerCase()));
                  softly.assertThat(Map.of("answer", 42, "count", 2))
                          .containsEntry("answer", 42)
                          .containsKey("count");
                  softly.assertThat(new Person("Ada", 37))
                          .usingRecursiveComparison()
                          .isEqualTo(new Person("Ada", 37));
              }
          });
      }
  
      @Test
      void classInjectionDefinesGeneratedTypeAndPackage() throws Exception {
          runByteCodeGeneratingTest(() -> {
              openJavaBasePackagesForLegacyByteBuddyInjectionIfPossible();
              ExposedPackageClassLoader classLoader = new ExposedPackageClassLoader();
              String packageName = nextPackageName("defined");
              Class<?> generatedType = generateObjectSubclass(packageName + ".GeneratedType", classLoader,
                      PackageDefinitionStrategy.Trivial.INSTANCE);
  
              assertSame(classLoader, generatedType.getClassLoader());
              assertTrue(generatedType.getName().startsWith(packageName));
              assertTrue(classLoader.isPackageDefined(packageName));
          });
      }
  
      @Test
      void classInjectionFallsBackToVisiblePackageAfterConcurrentDefinition() throws Exception {
          runByteCodeGeneratingTest(() -> {
              openJavaBasePackagesForLegacyByteBuddyInjectionIfPossible();
              ExposedPackageClassLoader classLoader = new ExposedPackageClassLoader();
              String packageName = nextPackageName("fallback");
              Class<?> generatedType = generateObjectSubclass(packageName + ".GeneratedType", classLoader,
                      new DefinePackageDuringMetadataLookup(classLoader, packageName));
  
              assertSame(classLoader, generatedType.getClassLoader());
              assertTrue(classLoader.isPackageDefined(packageName));
          });
      }
  
      private static Class<?> generateObjectSubclass(String name, ClassLoader classLoader,
              PackageDefinitionStrategy packageDefinitionStrategy) {
          return new ByteBuddy()
                  .subclass(Object.class)
                  .name(name)
                  .make()
                  .load(classLoader, ClassLoadingStrategy.Default.INJECTION.with(packageDefinitionStrategy))
                  .getLoaded();
      }
  
      private static String nextPackageName(String label) {
          return ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeInjectionTest.class.getPackageName()
                  + ".generated." + label + CLASS_COUNTER.incrementAndGet();
      }
  
      private static void openJavaBasePackagesForLegacyByteBuddyInjectionIfPossible() {
          try {
              Class<?> testClass = ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeInjectionTest.class;
              Class.forName(AutoCloseableSoftAssertions.class.getName(), false, testClass.getClassLoader());
              Path agentJar = createModuleOpenerAgentJar();
              try {
                  attachAgentFromExternalProcess(agentJar);
              } finally {
                  Files.deleteIfExists(agentJar);
              }
          } catch (Exception | LinkageError ignored) {
              // AssertJ falls back to its MethodHandles-based proxy strategy when legacy injection is unavailable.
          }
      }
  
      private static void attachAgentFromExternalProcess(Path agentJar) throws IOException, InterruptedException {
          String javaExecutable = Path.of(System.getProperty("java.home"), "bin", "java").toString();
          String helperClasspath = System.getProperty("java.class.path");
          Process process = new ProcessBuilder(javaExecutable,
                  "--add-modules", "jdk.attach",
                  "-cp", helperClasspath,
                  AssertjExternalAttacher.class.getName(),
                  Long.toString(ProcessHandle.current().pid()),
                  agentJar.toString())
                  .redirectOutput(ProcessBuilder.Redirect.DISCARD)
                  .redirectError(ProcessBuilder.Redirect.DISCARD)
                  .start();
          if (!process.waitFor(20, TimeUnit.SECONDS)) {
              process.destroyForcibly();
          }
      }
  
      private static Path createModuleOpenerAgentJar() throws IOException {
          Path agentJar = Files.createTempFile("assertj-bytebuddy-module-opener", ".jar");
          Manifest manifest = new Manifest();
          Attributes attributes = manifest.getMainAttributes();
          attributes.put(Attributes.Name.MANIFEST_VERSION, "1.0");
          attributes.put(new Attributes.Name("Agent-Class"), AssertjModuleOpenerAgent.class.getName());
  
          try (JarOutputStream jarOutputStream = new JarOutputStream(Files.newOutputStream(agentJar), manifest)) {
              String agentClassResource = AssertjModuleOpenerAgent.class.getName().replace('.', '/') + ".class";
              jarOutputStream.putNextEntry(new JarEntry(agentClassResource));
              ClassLoader classLoader = AssertjModuleOpenerAgent.class.getClassLoader();
              try (InputStream inputStream = classLoader.getResourceAsStream(agentClassResource)) {
                  if (inputStream == null) {
                      throw new IOException("Cannot find module opener agent class resource");
                  }
                  inputStream.transferTo(jarOutputStream);
              }
              jarOutputStream.closeEntry();
          }
          return agentJar;
      }
  
      private static void runByteCodeGeneratingTest(ThrowingRunnable runnable) throws Exception {
          try {
              runnable.run();
          } catch (UnsupportedOperationException exception) {
              if (!isLegacyInjectionUnavailable(exception)) {
                  throw exception;
              }
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
      }
  
      private static boolean isLegacyInjectionUnavailable(UnsupportedOperationException exception) {
          String message = exception.getMessage();
          return message != null
                  && (message.startsWith("Cannot get defined package using reflection:")
                          || message.startsWith("Cannot get package using reflection:")
                          || message.startsWith("Cannot define package using injection:")
                          || message.startsWith("Cannot define class using reflection:"));
      }
  
      @FunctionalInterface
      private interface ThrowingRunnable {
          void run() throws Exception;
      }
  
      private static final class ExposedPackageClassLoader extends ClassLoader {
          ExposedPackageClassLoader() {
              super(ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeInjectionTest.class.getClassLoader());
          }
  
          boolean isPackageDefined(String packageName) {
