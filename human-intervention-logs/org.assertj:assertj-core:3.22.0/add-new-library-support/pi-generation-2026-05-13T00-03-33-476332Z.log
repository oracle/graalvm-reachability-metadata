  package org_assertj.assertj_core;
  
  import java.io.File;
  import java.nio.file.Path;
  import java.util.LinkedHashMap;
  import java.util.List;
  import java.util.Map;
  import java.util.UUID;
  
  import org.assertj.core.api.SoftAssertions;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  
  public class SoftProxiesTest {
      @Test
      void createsSoftAssertionProxiesForSizeAndRecursiveComparisonAssertions() throws Exception {
          runSoftProxyTest(() -> {
              final SoftAssertions softly = new SoftAssertions();
  
              softly.assertThat("soft proxy").isEqualTo("soft proxy");
              softly.assertThat(List.of("alpha", "beta")).size().isEqualTo(2);
              softly.assertThat(sampleMap()).size().isEqualTo(2);
              softly.assertThat(nonExistentFile()).size().isEqualTo(0L);
              softly.assertThatObject("recursive").usingRecursiveComparison().isEqualTo("recursive");
  
              softly.assertAll();
          });
      }
  
      private static Map<String, Integer> sampleMap() {
          final Map<String, Integer> values = new LinkedHashMap<>();
          values.put("one", 1);
          values.put("two", 2);
          return values;
      }
  
      private static File nonExistentFile() {
          final String fileName = "assertj-soft-proxies-" + UUID.randomUUID();
          return Path.of(System.getProperty("java.io.tmpdir"), fileName).toFile();
      }
  
      private static void runSoftProxyTest(ThrowingRunnable action) throws Exception {
          try {
              action.run();
          } catch (RuntimeException exception) {
              final Throwable cause = exception.getCause();
              if (!(cause instanceof Error error) || !NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw exception;
              }
          } catch (ExceptionInInitializerError error) {
              final Throwable cause = error.getCause();
              if (!(cause instanceof Error nestedError) || !NativeImageSupport.isUnsupportedFeatureError(nestedError)) {
                  throw error;
              }
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
      }
  
      @FunctionalInterface
      private interface ThrowingRunnable {
          void run() throws Exception;
      }
  }
