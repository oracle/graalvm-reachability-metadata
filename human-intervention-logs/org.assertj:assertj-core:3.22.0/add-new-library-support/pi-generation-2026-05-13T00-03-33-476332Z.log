  @SuppressWarnings("removal")
  public class ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeOverrideTest {
      private static final AtomicInteger SEQUENCE = new AtomicInteger();
  
      @Test
      void unsafeOverrideDispatcherDefinesPackagesAndClassesThroughClassLoaderMethods() throws Exception {
          runDynamicClassLoadingTest(() -> {
              final String previousExperimental = System.getProperty("net.bytebuddy.experimental");
              System.setProperty("net.bytebuddy.experimental", "true");
              final SecurityManager previousSecurityManager = System.getSecurityManager();
              final boolean securityManagerInstalled = installPermissiveSecurityManager();
              try (URLClassLoader classLoader = new URLClassLoader(new URL[0], null)) {
                  final String packageName = uniquePackageName();
                  final String className = packageName + ".Generated";
                  UnsafeOverrideHarness.exercise(classLoader, packageName, className, makeMinimalClass(className));
              } finally {
                  if (securityManagerInstalled) {
                      System.setSecurityManager(previousSecurityManager);
                  }
                  restoreExperimentalProperty(previousExperimental);
              }
          });
      }
  
      private static byte[] makeMinimalClass(String className) {
          try {
              final ByteArrayOutputStream bytes = new ByteArrayOutputStream();
              final DataOutputStream output = new DataOutputStream(bytes);
              output.writeInt(0xCAFEBABE);
              output.writeShort(0);
              output.writeShort(52);
              output.writeShort(10);
              writeUtf8(output, className.replace('.', '/'));
              writeClass(output, 1);
              writeUtf8(output, "java/lang/Object");
              writeClass(output, 3);
              writeUtf8(output, "<init>");
              writeUtf8(output, "()V");
              writeUtf8(output, "Code");
              writeNameAndType(output, 5, 6);
              writeMethodRef(output, 4, 8);
              output.writeShort(0x0021);
              output.writeShort(2);
              output.writeShort(4);
              output.writeShort(0);
              output.writeShort(0);
              output.writeShort(1);
              output.writeShort(0x0001);
              output.writeShort(5);
              output.writeShort(6);
              output.writeShort(1);
              output.writeShort(7);
              output.writeInt(17);
              output.writeShort(1);
              output.writeShort(1);
              output.writeInt(5);
              output.writeByte(0x2A);
              output.writeByte(0xB7);
              output.writeShort(9);
              output.writeByte(0xB1);
              output.writeShort(0);
              output.writeShort(0);
              output.writeShort(0);
              output.flush();
              return bytes.toByteArray();
          } catch (IOException exception) {
              throw new IllegalStateException(exception);
          }
      }
  
      private static void writeUtf8(DataOutputStream output, String value) throws IOException {
          output.writeByte(1);
          output.writeUTF(value);
      }
  
      private static void writeClass(DataOutputStream output, int nameIndex) throws IOException {
          output.writeByte(7);
          output.writeShort(nameIndex);
      }
  
      private static void writeNameAndType(
                      DataOutputStream output,
                      int nameIndex,
                      int descriptorIndex) throws IOException {
          output.writeByte(12);
          output.writeShort(nameIndex);
          output.writeShort(descriptorIndex);
      }
  
      private static void writeMethodRef(
                      DataOutputStream output,
                      int classIndex,
                      int nameAndTypeIndex) throws IOException {
          output.writeByte(10);
          output.writeShort(classIndex);
          output.writeShort(nameAndTypeIndex);
      }
  
      private static String uniquePackageName() {
          return "org_assertj_assertj_core.generated.unsafe_override.p" + SEQUENCE.incrementAndGet();
      }
  
      private static void restoreExperimentalProperty(String previousExperimental) {
          if (previousExperimental == null) {
              System.clearProperty("net.bytebuddy.experimental");
          } else {
              System.setProperty("net.bytebuddy.experimental", previousExperimental);
          }
      }
  
      private static boolean installPermissiveSecurityManager() {
          try {
              System.setSecurityManager(new PermissiveSecurityManager());
              return true;
          } catch (UnsupportedOperationException | SecurityException exception) {
              return false;
          }
      }
  
      private static void runDynamicClassLoadingTest(ThrowingRunnable action) throws Exception {
          try {
              action.run();
          } catch (RuntimeException exception) {
              final Throwable cause = exception.getCause();
              if (!(cause instanceof Error error) || !NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw exception;
              }
          } catch (ExceptionInInitializerError error) {
              final Throwable cause = error.getCause();
              if (!(cause instanceof Error nestedError) || !NativeImageSupport.isUnsupportedFeatureError(nestedError)) {
                  throw error;
              }
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
      }
  
      @FunctionalInterface
      private interface ThrowingRunnable {
          void run() throws Exception;
      }
  
      private static final class PermissiveSecurityManager extends SecurityManager {
          @Override
          public void checkPermission(Permission permission) {
              // Permit all actions so the test only exercises Byte Buddy's security-manager branch.
          }
      }
  }
  
  final class UnsafeOverrideHarness extends ClassInjector.UsingReflection {
      private UnsafeOverrideHarness() {
          super(ClassLoader.getSystemClassLoader());
      }
  
      static void exercise(
                      URLClassLoader classLoader,
                      String packageName,
                      String className,
                      byte[] classBytes) throws Exception {
          final Dispatcher.Initializable initializable = UnsafeOverrideAccessor.create();
          final Dispatcher dispatcher = initializable.initialize();
  
          assertNull(dispatcher.findClass(classLoader, className));
          assertNull(dispatcher.getDefinedPackage(classLoader, packageName));
  
          final Package definedPackage = dispatcher.definePackage(
                          classLoader,
                          packageName,
                          "unsafe override specification",
                          "1.0",
                          "unsafe override specification vendor",
                          "unsafe override implementation",
                          "1.0",
                          "unsafe override implementation vendor",
                          null);
          assertNotNull(definedPackage);
          assertSame(definedPackage, dispatcher.getDefinedPackage(classLoader, packageName));
          assertSame(definedPackage, dispatcher.getPackage(classLoader, packageName));
  
          final Class<?> definedClass = dispatcher.defineClass(classLoader, className, classBytes, null);
  
          assertSame(classLoader, definedClass.getClassLoader());
          assertEquals(className, definedClass.getName());
          assertSame(definedClass, dispatcher.findClass(classLoader, className));
      }
  
      private abstract static class UnsafeOverrideAccessor extends Dispatcher.UsingUnsafeOverride {
          private UnsafeOverrideAccessor() {
              super(null, null, null, null, null);
          }
  
          private static Dispatcher.Initializable create() throws Exception {
              return make();
          }
      }
  }
