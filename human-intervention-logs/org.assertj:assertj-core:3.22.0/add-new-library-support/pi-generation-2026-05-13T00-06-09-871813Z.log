w LinkedHashMap<>();\n\n        public CopyConstructorMap(Map<? extends K, ? extends V> source) {\n            entries.putAll(source);\n        }\n\n        @Override\n        public Set<Entry<K, V>> entrySet() {\n            return entries.entrySet();\n        }\n    }\n\n    public static class DefaultConstructorMap<K, V> extends AbstractMap<K, V> {\n        private final Map<K, V> entries = new LinkedHashMap<>();\n\n        public DefaultConstructorMap() {\n        }\n\n        @Override\n        public V put(K key, V value) {\n            return entries.put(key, value);\n        }\n\n        @Override\n        public Set<Entry<K, V>> entrySet() {\n            return entries.entrySet();\n        }\n    }\n}\n"}
