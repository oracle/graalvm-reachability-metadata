\n */\npackage org_assertj.assertj_core;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.util.AbstractMap;\nimport java.util.LinkedHashMap;\nimport java.util.Map;\nimport java.util.Set;\n\nimport org.junit.jupiter.api.Test;\n\npublic class MapsTest {\n    @Test\n    void containsOnlyKeysClonesCloneableMaps() {\n        final CloneableMap<String, Integer> actual = new CloneableMap<>();\n        actual.put(\"one\", 1);\n        actual.put(\"two\", 2);\n\n        assertThat(actual).containsOnlyKeys(\"one\", \"two\");\n    }\n\n    @Test\n    void containsOnlyKeysClonesMapsWithCopyConstructor() {\n        final CopyConstructorMap<String, Integer> actual = new CopyConstructorMap<>(Map.of(\"one\", 1, \"two\", 2));\n\n        assertThat(actual).containsOnlyKeys(\"one\", \"two\");\n    }\n\n    @Test\n    void containsOnlyKeysClonesMapsWithDefaultConstructor() {\n        final DefaultConstructorMap<String, Integer> actual = new DefaultConstructorMap<>();\n        actual.put(\"one\", 1);\n        actual.put(\"two\", 2);\n\n        assertThat(actual).containsOnlyKeys(\"one\", \"two\");\n    }\n\n    public static class CloneableMap<K, V> extends LinkedHashMap<K, V> implements Cloneable {\n        @Override\n        public CloneableMap<K, V> clone() {\n            final CloneableMap<K, V> clone = new CloneableMap<>();\n            clone.putAll(this);\n            return clone;\n        }\n    }\n\n    public static class CopyConstructorMap<K, V> extends AbstractMap<K, V> {\n        private final Map<K, V> entries = new LinkedHashMap<>();\n\n        public CopyConstructorMap(Map<? extends K, ? extends V> source) {\n            entries.putAll(source);\n        }\n\n        @Override\n        public Set<Entry<K, V>> entrySet() {\n            return entries.entrySet();\n        }\n    }\n\n    public static class DefaultConstructorMap<K, V> extends AbstractMap<K, V> {\n        private final Map<K, V> entries = new LinkedHashMap<>();\n\n        public DefaultConstructorMap() {\n        }\n\n        @Override\n        public V put(K key, V value) {\n            return entries.put(key, value);\n        }\n\n        @Override\n        public Set<Entry<K, V>> entrySet() {\n            return entries.entrySet();\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1964, "output": 1607, "cacheRead": 9728, "cacheWrite": 0, "totalTokens": 13299, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778630729093, "responseId": "resp_0e924b331431d6f0016a03c049b9848192adca783afed5b4d6"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_2yo24GAAh52uFTbuqf66yZ8g|fc_0e924b331431d6f0016a03c058cda081929150c2480054c7a5", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2377 bytes to tests/src/org.assertj/assertj-core/3.22.0/src/test/java/org_assertj/assertj_core/MapsTest.java"}], "isError": false, "timestamp": 1778630748453}]}
