[] generatedClass = LambdaFactory.make(lambdaFactory, \"lambda$assertj$0\", factoryType,\n                                implementationHandle, dynamicMethodType, interceptedMethodType, true,\n                                markerInterfaces, additionalBridges);\n\n                assertArrayEquals(target.generatedClass, generatedClass);\n                assertSame(lambdaFactory, target.lambdaFactory);\n                assertEquals(\"lambda$assertj$0\", target.lambdaName);\n                assertSame(factoryType, target.factoryType);\n                assertSame(implementationHandle, target.implementationHandle);\n                assertSame(dynamicMethodType, target.dynamicMethodType);\n                assertSame(interceptedMethodType, target.interceptedMethodType);\n                assertTrue(target.serializable);\n                assertSame(markerInterfaces, target.markerInterfaces);\n                assertSame(additionalBridges, target.additionalBridges);\n                assertTrue(target.transformers.contains(transformer));\n            } finally {\n                LambdaFactory.release(transformer);\n            }\n\n            assertFalse(LambdaFactory.release(transformer));\n        });\n    }\n\n    public static class RecordingLambdaTarget {\n        private final byte[] generatedClass = new byte[] { 1, 2, 3 };\n        private Object lambdaFactory;\n        private String lambdaName;\n        private Object factoryType;\n        private Object implementationHandle;\n        private Object dynamicMethodType;\n        private Object interceptedMethodType;\n        private boolean serializable;\n        private List<Class<?>> markerInterfaces;\n        private List<?> additionalBridges;\n        private Collection<ClassFileTransformer> transformers;\n\n        public byte[] make(Object lambdaFactory, String lambdaName, Object factoryType, Object implementationHandle,\n                        Object dynamicMethodType, Object interceptedMethodType, boolean serializable,\n                        List<Class<?>> markerInterfaces, List<?> additionalBridges,\n                        Collection<ClassFileTransformer> transformers) {\n            this.lambdaFactory = lambdaFactory;\n            this.lambdaName = lambdaName;\n            this.factoryType = factoryType;\n            this.implementationHandle = implementationHandle;\n            this.dynamicMethodType = dynamicMethodType;\n            this.interceptedMethodType = interceptedMethodType;\n            this.serializable = serializable;\n            this.markerInterfaces = markerInterfaces;\n            this.additionalBridges = additionalBridges;\n            this.transformers = transformers;\n            return generatedClass;\n        }\n    }\n\n    private static final class NoOpClassFileTransformer implements ClassFileTransformer {\n        @Override\n        public byte[] transform(ClassLoader loader, String className, Class<?> classBeingRedefined,\n                        ProtectionDomain protectionDomain, byte[] classfileBuffer) throws IllegalClassFormatException {\n            return null;\n        }\n    }\n\n    private static void runLambdaFactoryTest(ThrowingRunnable action) throws Exception {\n        try {\n            action.run();\n        } catch (RuntimeException exception) {\n            final Throwable cause = exception.getCause();\n            if (!(cause instanceof Error error) || !NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw exception;\n            }\n        } catch (ExceptionInInitializerError error) {\n            final Throwable cause = error.getCause();\n            if (!(cause instanceof Error nestedError) || !NativeImageSupport.isUnsupportedFeatureError(nestedError)) {\n                throw error;\n            }\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    @FunctionalInterface\n    private interface ThrowingRunnable {\n        void run() throws Exception;\n    }\n}\n"}
