() throws Exception {\n        runLambdaFactoryTest(() -> {\n            final RecordingLambdaTarget target = new RecordingLambdaTarget();\n            final ClassFileTransformer transformer = new NoOpClassFileTransformer();\n            final Object lambdaFactory = new Object();\n            final Object factoryType = \"factoryType\";\n            final Object implementationHandle = \"implementationHandle\";\n            final Object dynamicMethodType = \"dynamicMethodType\";\n            final Object interceptedMethodType = \"interceptedMethodType\";\n            final List<Class<?>> markerInterfaces = List.of(Runnable.class);\n            final List<?> additionalBridges = List.of(\"bridge\");\n            final Map<ClassFileTransformer, LambdaFactory> previousFactories = new LinkedHashMap<>(\n                            LambdaFactory.CLASS_FILE_TRANSFORMERS);\n            boolean registered = false;\n\n            LambdaFactory.CLASS_FILE_TRANSFORMERS.clear();\n            try {\n                LambdaFactory.register(transformer, target);\n                registered = true;\n                LambdaFactory.release(transformer);\n                assertFalse(LambdaFactory.release(transformer));\n\n                final Method dispatcher = RecordingLambdaTarget.class.getMethod(\"make\", Object.class, String.class,\n                                Object.class, Object.class, Object.class, Object.class, boolean.class, List.class,\n                                List.class, Collection.class);\n                LambdaFactory.CLASS_FILE_TRANSFORMERS.put(transformer, new LambdaFactory(target, dispatcher));\n\n                final byte[] generatedClass = LambdaFactory.make(lambdaFactory, \"lambda$assertj$0\", factoryType,\n                                implementationHandle, dynamicMethodType, interceptedMethodType, true,\n                                markerInterfaces, additionalBridges);\n\n                assertArrayEquals(target.generatedClass, generatedClass);\n                assertSame(lambdaFactory, target.lambdaFactory);\n                assertEquals(\"lambda$assertj$0\", target.lambdaName);\n                assertSame(factoryType, target.factoryType);\n                assertSame(implementationHandle, target.implementationHandle);\n                assertSame(dynamicMethodType, target.dynamicMethodType);\n                assertSame(interceptedMethodType, target.interceptedMethodType);\n                assertTrue(target.serializable);\n                assertSame(markerInterfaces, target.markerInterfaces);\n                assertSame(additionalBridges, target.additionalBridges);\n                assertTrue(target.transformers.contains(transformer));\n            } finally {\n                if (registered) {\n                    LambdaFactory.release(transformer);\n                }\n                LambdaFactory.CLASS_FILE_TRANSFORMERS.clear();\n                LambdaFactory.CLASS_FILE_TRANSFORMERS.putAll(previousFactories);\n            }\n        });\n    }\n\n[66 more lines in file. Use offset=81 to continue.]"}], "isError": false, "timestamp": 1778630266010}]}
