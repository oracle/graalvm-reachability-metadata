  package org_assertj.assertj_core;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import org.junit.jupiter.api.Test;
  
  public class ClassesTest {
      @Test
      void classAssertionsDiscoverPublicFields() {
          final String[] publicFields = { "publicField", "secondPublicField" };
  
          assertThat(PublicFieldFixture.class)
                          .hasPublicFields(publicFields)
                          .hasOnlyPublicFields(publicFields);
      }
  
      @Test
      void classAssertionsDiscoverDeclaredFields() {
          final String[] declaredFields = {
              "publicField", "protectedField", "packageField", "privateField"
          };
  
          assertThat(DeclaredFieldFixture.class)
                          .hasDeclaredFields(declaredFields)
                          .hasOnlyDeclaredFields(declaredFields);
      }
  
      @Test
      void classAssertionsDiscoverDeclaredInheritedAndPublicMethods() {
          final String[] declaredMethods = {
              "publicMethod", "protectedMethod", "packageMethod", "privateMethod"
          };
          final String[] allMethods = {
              "publicMethod", "protectedMethod", "packageMethod", "privateMethod",
              "inheritedMethod", "interfaceMethod"
          };
          final String[] publicMethods = { "publicMethod", "interfaceMethod" };
  
          assertThat(MethodFixture.class)
                          .hasDeclaredMethods(declaredMethods)
                          .hasMethods(allMethods)
                          .hasPublicMethods(publicMethods);
      }
  
      public static class PublicFieldFixture {
          public String publicField;
          public int secondPublicField;
          protected long protectedField;
          String packageField;
          private boolean privateField;
      }
  
      public static class DeclaredFieldFixture {
          public String publicField;
          protected long protectedField;
          String packageField;
          private boolean privateField;
      }
  
      interface MethodInterface {
          void interfaceMethod();
      }
  
      public static class MethodSuperClass {
          public void inheritedMethod() {
          }
      }
  
      public static class MethodFixture extends MethodSuperClass implements MethodInterface {
          @Override
          public void interfaceMethod() {
          }
  
          public void publicMethod() {
          }
  
          protected void protectedMethod() {
          }
  
          void packageMethod() {
          }
  
          private void privateMethod() {
          }
      }
  }
