her.getDefinedPackage(classLoader, packageName));\n        assertSame(definedPackage, dispatcher.getPackage(classLoader, packageName));\n\n        final Class<?> definedClass = dispatcher.defineClass(classLoader, className, classBytes, null);\n\n        assertSame(classLoader, definedClass.getClassLoader());\n        assertEquals(className, definedClass.getName());\n        assertSame(definedClass, dispatcher.findClass(classLoader, className));\n    }\n\n    private abstract static class UnsafeOverrideAccessor extends Dispatcher.UsingUnsafeOverride {\n        private UnsafeOverrideAccessor() {\n            super(null, null, null, null, null);\n        }\n\n        private static Dispatcher.Initializable create() throws Exception {\n            return make();\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778629805427}]}
