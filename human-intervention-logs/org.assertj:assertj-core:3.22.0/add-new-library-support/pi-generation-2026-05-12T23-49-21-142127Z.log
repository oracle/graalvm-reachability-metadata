[tool-call] delta {"path":"tests/src/org.assertj/assertj-core/3.22.0/src/test/java/org_assertj/assertj_core/SoftProxiesTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_assertj.assertj_core;\n\nimport java.io.File;\nimport java.nio.file.Path;\nimport java.util.LinkedHashMap;\nimport java.util.List;\nimport java.util.Map;\nimport java.util.UUID;\n\nimport org.assertj.core.api.SoftAssertions;\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\n\npublic class SoftProxiesTest {\n    @Test\n    void createsSoftAssertionProxiesForSizeAndRecursiveComparisonAssertions() throws Exception {\n        runSoftProxyTest(() -> {\n            final SoftAssertions softly = new SoftAssertions();\n\n            softly.assertThat(\"soft proxy\").isEqualTo(\"soft proxy\");\n            softly.assertThat(List.of(\"alpha\", \"beta\")).size().isEqualTo(2);\n            softly.assertThat(sampleMap()).size().isEqualTo(2);\n            softly.assertThat(nonExistentFile()).size().isEqualTo(0L);\n            softly.assertThat(\"recursive\").usingRecursiveComparison().isEqualTo(\"recursive\");\n\n            softly.assertAll();\n        });\n    }\n\n    private static Map<String, Integer> sampleMap() {\n        final Map<String, Integer> values = new LinkedHashMap<>();\n        values.put(\"one\", 1);\n        values.put(\"two\", 2);\n        return values;\n    }\n\n    private static File nonExistentFile() {\n        final String fileName = \"assertj-soft-proxies-\" + UUID.randomUUID();\n        return Path.of(System.getProperty(\"java.io.tmpdir\"), fileName).toFile();\n    }\n\n    private static void runSoftProxyTest(ThrowingRunnable action) throws Exception {\n        try {\n            action.run();\n        } catch (RuntimeException exception) {\n            final Throwable cause = exception.getCause();\n            if (!(cause instanceof Error error) || !NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw exception;\n            }\n        } catch (ExceptionInInitializerError error) {\n            final Throwable cause = error.getCause();\n            if (!(cause instanceof Error nestedError) || !NativeImageSupport.isUnsupportedFeatureError(nestedError)) {\n                throw error;\n            }\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    @FunctionalInterface\n    private interface ThrowingRunnable {\n        void run() throws Exception;\n    }\n}\n"}
