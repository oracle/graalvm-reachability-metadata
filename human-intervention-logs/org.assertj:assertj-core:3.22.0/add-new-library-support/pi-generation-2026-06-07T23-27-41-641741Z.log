  package org_assertj.assertj_core;
  
  import static org.junit.jupiter.api.Assertions.assertEquals;
  import static org.junit.jupiter.api.Assertions.assertNotNull;
  import static org.junit.jupiter.api.Assertions.assertNull;
  import static org.junit.jupiter.api.Assertions.assertSame;
  import static org.junit.jupiter.api.Assertions.assertTrue;
  
  import java.io.IOException;
  import java.io.InputStream;
  import java.lang.instrument.Instrumentation;
  import java.net.URL;
  import java.net.URLClassLoader;
  import java.nio.file.Files;
  import java.nio.file.Path;
  import java.util.Enumeration;
  import java.util.HashSet;
  import java.util.LinkedHashMap;
  import java.util.Map;
  import java.util.Set;
  import java.util.concurrent.TimeUnit;
  import java.util.concurrent.atomic.AtomicInteger;
  import java.util.jar.Attributes;
  import java.util.jar.JarEntry;
  import java.util.jar.JarOutputStream;
  import java.util.jar.Manifest;
  
  import com.sun.tools.attach.VirtualMachine;
  import org.assertj.core.internal.bytebuddy.ByteBuddy;
  import org.assertj.core.internal.bytebuddy.description.type.TypeDescription;
  import org.assertj.core.internal.bytebuddy.dynamic.DynamicType;
  import org.assertj.core.internal.bytebuddy.dynamic.loading.ByteArrayClassLoader;
  import org.assertj.core.internal.bytebuddy.dynamic.loading.ClassLoadingStrategy;
  import org.assertj.core.internal.bytebuddy.dynamic.loading.PackageDefinitionStrategy;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  import org.junit.jupiter.api.io.TempDir;
  
  public class ByteArrayClassLoaderInnerChildFirstTest {
      private static final AtomicInteger CLASS_COUNTER = new AtomicInteger();
      private static final String CLASS_FILE_SUFFIX = ".class";
  
      @TempDir
      Path temporaryDirectory;
  
      @Test
      void staticLoadDefinesGeneratedTypesThroughChildFirstLoader() throws Exception {
          runDynamicClassLoadingTest(() -> {
              openJavaLangForParallelCapableRegistrationIfPossible();
              DynamicType.Unloaded<?> unloadedType = makeObjectSubclass(nextGeneratedName("StaticLoaded"));
              Map<TypeDescription, byte[]> types = new LinkedHashMap<>();
              types.put(unloadedType.getTypeDescription(), unloadedType.getBytes());
  
              Map<TypeDescription, Class<?>> loadedTypes = ByteArrayClassLoader.ChildFirst.load(
                      ByteArrayClassLoaderInnerChildFirstTest.class.getClassLoader(),
                      types,
                      ClassLoadingStrategy.NO_PROTECTION_DOMAIN,
                      ByteArrayClassLoader.PersistenceHandler.MANIFEST,
                      PackageDefinitionStrategy.Trivial.INSTANCE,
                      false,
                      true);
  
              Class<?> loadedType = loadedTypes.get(unloadedType.getTypeDescription());
              assertNotNull(loadedType);
              assertEquals(unloadedType.getTypeDescription().getName(), loadedType.getName());
              assertTrue(loadedType.getClassLoader() instanceof ByteArrayClassLoader.ChildFirst);
          });
      }
  
      @Test
      void childFirstLoadClassReturnsAlreadyLoadedGeneratedType() throws Exception {
          runDynamicClassLoadingTest(() -> {
              openJavaLangForParallelCapableRegistrationIfPossible();
              DynamicType.Unloaded<?> unloadedType = makeObjectSubclass(nextGeneratedName("DirectLoaded"));
              ByteArrayClassLoader.ChildFirst classLoader = new ByteArrayClassLoader.ChildFirst(
                      ByteArrayClassLoaderInnerChildFirstTest.class.getClassLoader(),
                      Map.of(unloadedType.getTypeDescription().getName(), unloadedType.getBytes()),
                      ByteArrayClassLoader.PersistenceHandler.MANIFEST);
  
              Class<?> firstLoad = classLoader.loadClass(unloadedType.getTypeDescription().getName());
              Class<?> secondLoad = classLoader.loadClass(unloadedType.getTypeDescription().getName());
  
              assertSame(firstLoad, secondLoad);
              assertSame(classLoader, firstLoad.getClassLoader());
          });
      }
  
      @Test
      void childFirstResourceLookupDelegatesAndPrependsPersistentClassResources() throws Exception {
          runDynamicClassLoadingTest(() -> {
              openJavaLangForParallelCapableRegistrationIfPossible();
              DynamicType.Unloaded<?> unloadedType = makeObjectSubclass(nextGeneratedName("ResourceLoaded"));
              String classResourceName = unloadedType.getTypeDescription().getName().replace('.', '/')
                      + CLASS_FILE_SUFFIX;
              String parentResourceName = "parent-only-resource.txt";
              writeParentResource(parentResourceName, "parent resource");
              writeParentResource(classResourceName, "parent class resource");
  
              try (URLClassLoader parentClassLoader = new URLClassLoader(
                      new URL[] {temporaryDirectory.toUri().toURL()}, null)) {
                  ByteArrayClassLoader.ChildFirst classLoader = new ByteArrayClassLoader.ChildFirst(
                          parentClassLoader,
                          Map.of(unloadedType.getTypeDescription().getName(), unloadedType.getBytes()),
                          ByteArrayClassLoader.PersistenceHandler.MANIFEST);
  
                  URL delegatedResource = classLoader.getResource(parentResourceName);
                  assertNotNull(delegatedResource);
                  assertEquals("parent resource", readResource(delegatedResource));
  
                  Enumeration<URL> delegatedResources = classLoader.getResources(parentResourceName);
                  assertTrue(delegatedResources.hasMoreElements());
                  assertEquals("parent resource", readResource(delegatedResources.nextElement()));
  
                  Enumeration<URL> prependedResources = classLoader.getResources(classResourceName);
                  assertTrue(prependedResources.hasMoreElements());
                  URL childResource = prependedResources.nextElement();
                  assertEquals("bytebuddy", childResource.getProtocol());
              }
          });
      }
  
      @Test
      void latentChildFirstLoaderShadowsResourcesForLoadedClasses() throws Exception {
          runDynamicClassLoadingTest(() -> {
              openJavaLangForParallelCapableRegistrationIfPossible();
              DynamicType.Unloaded<?> unloadedType = makeObjectSubclass(nextGeneratedName("Shadowed"));
              String typeName = unloadedType.getTypeDescription().getName();
              String classResourceName = typeName.replace('.', '/') + CLASS_FILE_SUFFIX;
              writeParentResource(classResourceName, "parent class resource");
  
              try (URLClassLoader parentClassLoader = new URLClassLoader(
                      new URL[] {temporaryDirectory.toUri().toURL()}, null)) {
                  ByteArrayClassLoader.ChildFirst classLoader = new ByteArrayClassLoader.ChildFirst(
                          parentClassLoader,
                          Map.of(typeName, unloadedType.getBytes()),
                          ByteArrayClassLoader.PersistenceHandler.LATENT);
  
                  Class<?> loadedType = classLoader.loadClass(typeName);
                  assertSame(classLoader, loadedType.getClassLoader());
                  assertNull(classLoader.getResource(classResourceName));
              }
          });
      }
  
      private static DynamicType.Unloaded<?> makeObjectSubclass(String name) {
          return new ByteBuddy()
                  .subclass(Object.class)
                  .name(name)
                  .make();
      }
  
      private static String nextGeneratedName(String label) {
          return ByteArrayClassLoaderInnerChildFirstTest.class.getPackageName()
                  + ".generated." + label + CLASS_COUNTER.incrementAndGet();
      }
  
      private void writeParentResource(String resourceName, String content) throws IOException {
          Path resource = temporaryDirectory.resolve(resourceName);
          Files.createDirectories(resource.getParent());
          Files.writeString(resource, content);
      }
  
      private static String readResource(URL resource) throws IOException {
          try (InputStream inputStream = resource.openStream()) {
              return new String(inputStream.readAllBytes());
          }
      }
  
      private static void runDynamicClassLoadingTest(ThrowingRunnable runnable) throws Exception {
          try {
              runnable.run();
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
      }
  
      private static void openJavaLangForParallelCapableRegistrationIfPossible() {
          try {
              Path agentJar = createModuleOpenerAgentJar();
              try {
                  attachAgentFromExternalProcess(agentJar);
              } finally {
                  Files.deleteIfExists(agentJar);
              }
          } catch (Exception | LinkageError ignored) {
              // The child-first loader still works when the JVM rejects reflective parallel-capable registration.
          }
      }
  
      private static void attachAgentFromExternalProcess(Path agentJar) throws IOException, InterruptedException {
          String javaExecutable = Path.of(System.getProperty("java.home"), "bin", "java").toString();
          String helperClasspath = System.getProperty("java.class.path");
          Process process = new ProcessBuilder(javaExecutable,
                  "--add-modules", "jdk.attach",
                  "-cp", helperClasspath,
                  ByteArrayClassLoaderInnerChildFirstExternalAttacher.class.getName(),
                  Long.toString(ProcessHandle.current().pid()),
                  agentJar.toString())
                  .redirectOutput(ProcessBuilder.Redirect.DISCARD)
                  .redirectError(ProcessBuilder.Redirect.DISCARD)
                  .start();
          if (!process.waitFor(20, TimeUnit.SECONDS)) {
              process.destroyForcibly();
          }
      }
  
      private static Path createModuleOpenerAgentJar() throws IOException {
          Path agentJar = Files.createTempFile("assertj-child-first-module-opener", ".jar");
          Manifest manifest = new Manifest();
