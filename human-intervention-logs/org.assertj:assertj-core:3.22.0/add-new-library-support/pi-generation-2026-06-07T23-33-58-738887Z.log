.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\n\npublic class ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeInjectionTest {\n    private static final AtomicInteger CLASS_COUNTER = new AtomicInteger();\n\n    @Test\n    void softAssertionsCreateGeneratedAssertionProxies() throws Exception {\n        runByteCodeGeneratingTest(() -> {\n            openJavaBasePackagesForLegacyByteBuddyInjectionIfPossible();\n            try (AutoCloseableSoftAssertions softly = new AutoCloseableSoftAssertions()) {\n                softly.assertThat(\"assertj byte buddy proxy\").startsWith(\"assertj\").contains(\"buddy\");\n                softly.assertThat(42).isPositive().isGreaterThan(10);\n                softly.assertThat(List.of(\"alpha\", \"beta\", \"gamma\"))\n                        .hasSize(3)\n                        .contains(\"beta\")\n                        .allSatisfy(value -> assertEquals(value, value.toLowerCase()));\n                softly.assertThat(Map.of(\"answer\", 42, \"count\", 2))\n                        .containsEntry(\"answer\", 42)\n                        .containsKey(\"count\");\n                softly.assertThat(new Person(\"Ada\", 37))\n                        .usingRecursiveComparison()\n                        .isEqualTo(new Person(\"Ada\", 37));\n            }\n        });\n    }\n\n    @Test\n    void classInjectionDefinesGeneratedTypeAndPackage() throws Exception {\n        runByteCodeGeneratingTest(() -> {\n            openJavaBasePackagesForLegacyByteBuddyInjectionIfPossible();\n            ExposedPackageClassLoader classLoader = new ExposedPackageClassLoader();\n            String packageName = nextPackageName(\"defined\");\n            Class<?> generatedType = generateObjectSubclass(packageName + \".GeneratedType\", classLoader,\n                    PackageDefinitionStrategy.Trivial.INSTANCE);\n\n            assertSame(classLoader, generatedType.getClassLoader());\n            assertTrue(generatedType.getName().