 codeSourceUrl(ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeOverrideTest.class);\n        URL assertjCoreUrl = codeSourceUrl(Assertions.class);\n        try (ChildFirstUrlClassLoader classLoader = new ChildFirstUrlClassLoader(\n                new URL[] { testClassesUrl, assertjCoreUrl })) {\n            Class<?> exerciseClass = classLoader.loadClass(IsolatedUsingUnsafeOverrideExercise.class.getName());\n            Runnable exercise = (Runnable) exerciseClass.getConstructor().newInstance();\n            exercise.run();\n        } catch (InvocationTargetException exception) {\n            Throwable target = exception.getTargetException();\n            if (target instanceof Exception) {\n                throw (Exception) target;\n            }\n            if (target instanceof Error) {\n                throw (Error) target;\n            }\n            throw exception;\n        }\n    }\n\n    private static URL codeSourceUrl(Class<?> type) {\n        CodeSource codeSource = type.getProtectionDomain().getCodeSource();\n        if (codeSource == null) {\n            throw new IllegalStateException(\"Cannot locate code source for \" + type.getName());\n        }\n        return codeSource.getLocation();\n    }\n\n    private static boolean isLegacyInjectionUnavailable(UnsupportedOperationException exception) {\n        String message = exception.getMessage();\n        return message != null && message.startsWith(LEGACY_INJECTION_UNAVAILABLE_PREFIX);\n    }\n\n    private static final class ChildFirstUrlClassLoader extends URLClassLoader {\n        private static final String TEST_CLASS_PREFIX =\n                \"org_assertj.assertj_core.ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeOverrideTest\";\n        private static final String BYTE_BUDDY_PREFIX = \"org.assertj.core.internal.bytebuddy.\";\n\n        private ChildFirstUrlClassLoader(URL[] urls) {\n            super(urls, ClassLoader.getPlatformClassLoader());\n        }\n\n        @Override\n        protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {\n            synchronized (getClassLoadingLock(name)) {\n                Class<?> loadedClass = findLoadedClass(name);\n                if (loadedClass == null && shouldLoadChildFirst(name)) {\n                    try {\n                        loadedClass = findClass(name);\n                    } catch (ClassNotFoundException ignored) {\n                        loadedClass = super.loadClass(name, false);\n                    }\n                }\n                if (loadedClass == null) {\n                    loadedClass = super.loadClass(name, false);\n                }\n                if (resolve) {\n                    resolveClass(loadedClass);\n                }\n                return loadedClass;\n            }\n        }\n\n        private static boolean shouldLoadChildFirst(String name) {\n            return name.startsWith(TEST_CLASS_PREFIX) || name.startsWith(BYTE_BUDDY_PREFIX);\n        }\n    }\n\n    public static final class IsolatedUsingUnsafeOverrideExercise implements Runnable {\n        private static final AtomicInteger CLASS_COUNTER = new AtomicInteger();\n        private static final String BYTE_BUDDY_SAFE_PROPERTY = \"org.assertj.core.internal.bytebuddy.safe\";\n        private static final String GENERATED_PACKAGE = \"org_assertj.assertj_core.generated.unsafeoverride\";\n\n        public IsolatedUsingUnsafeOverrideExercise() {\n        }\n\n        @Override\n        public void run() {\n            String previousSafeProperty = System.getProperty(BYTE_BUDDY_SAFE_PROPERTY);\n            SecurityManager previousSecurityManager = System.getSecurityManager();\n            boolean securityManagerChanged = false;\n            try {\n                System.setProperty(BYTE_BUDDY_SAFE_PROPERTY, Boolean.TRUE.toString());\n                if (ClassInjector.UsingUnsafe.isAvailable()) {\n                    throw new AssertionError(\"Unsafe injector should be initialized as unavailable\");\n                }\n                restoreSafeProperty(previousSafeProperty);\n                securityManagerChanged = installPermissiveSecurityManagerIfPossible();\n\n                ExposedPackageClassLoader classLoader = new ExposedPackageClassLoader();\n                String definedPackageName = nextPackageName(\"defined\");\n                Class<?> generatedType = generateObjectSubclass(definedPackageName + \".GeneratedType\", classLoader,\n                        PackageDefinitionStrategy.Trivial.INSTANCE);\n                assertLoadedBy(generatedType, classLoader);\n                assertPackageDefined(classLoader, definedPackageName);\n\n                String fallbackPackageName = nextPackageName(\"fallback\");\n                Class<?> fallbackType = generateObjectSubclass(fallbackPackageName + \".GeneratedType\", classLoader,\n                        new DefinePackageDuringMetadataLookup(classLoader, fallbackPackageName));\n                assertLoadedBy(fallbackType, classLoader);\n                assertPackageDefined(classLoader, fallbackPackageName);\n            } finally {\n                if (securityManagerChanged) {\n                    System.setSecurityManager(previousSecurityManager);\n                }\n                restoreSafeProperty(previousSafeProperty);\n            }\n        }\n\n        private static Class<?> generateObjectSubclass(String name, ClassLoader classLoader,\n                PackageDefinitionStrategy packageDefinitionStrategy) {\n            return new ByteBuddy()\n                    .subclass(Object.class)\n                    .name(name)\n                    .make()\n                    .load(classLoader, ClassLoadingStrategy.Default.INJECTION.with(packageDefinitionStrategy))\n                    .getLoaded();\n        }\n\n        private static String nextPackageName(String label) {\n            return GENERATED_PACKAGE + \".\" + label + CLASS_COUNTER.incrementAndGet();\n        }\n\n        private static boolean installPermissiveSecurityManagerIfPossible() {\n            try {\n                System.setSecurityManager(new SecurityManager() {\n                    @Override\n                    public void checkPermission(Permission permission) {\n                    }\n                });\n                return true;\n            } catch (SecurityException | UnsupportedOperationException ignored) {\n                return false;\n            }\n        }\n\n        private static void restoreSafeProperty(String previousSafeProperty) {\n            if (previousSafeProperty == null) {\n                System.clearProperty(BYTE_BUDDY_SAFE_PROPERTY);\n            } else {\n                System.setProperty(BYTE_BUDDY_SAFE_PROPERTY, previousSafeProperty);\n            }\n        }\n\n        private static void assertLoadedBy(Class<?> generatedType, ClassLoader expectedClassLoader) {\n            if (generatedType.getClassLoader() != expectedClassLoader) {\n                throw new AssertionError(\"Generated type was not loaded by the target class loader\");\n            }\n        }\n\n        private static void assertPackageDefined(ExposedPackageClassLoader classLoader, String packageName) {\n            if (!classLoader.isPackageDefined(packageName)) {\n                throw new AssertionError(\"Generated package was not defined\");\n            }\n        }\n\n        private static final class ExposedPackageClassLoader extends ClassLoader {\n            private ExposedPackageClassLoader() {\n                super(IsolatedUsingUnsafeOverrideExercise.class.getClassLoader());\n            }\n\n            private boolean isPackageDefined(String packageName) {\n                return getDefinedPackage(packageName) != null;\n            }\n\n            private Package defineGeneratedPackage(String packageName) {\n                return definePackage(packageName, null, null, null, null, null, null, null);\n            }\n        }\n\n        private static final class DefinePackageDuringMetadataLookup implements PackageDefinitionStrategy, Definition {\n            private final ExposedPackageClassLoader classLoader;\n            private final String packageName;\n            private boolean packageDefined;\n\n            private DefinePackageDuringMetadataLookup(ExposedPackageClassLoader classLoader, String packageName) {\n                this.classLoader = classLoader;\n                this.packageName = packageName;\n            }\n\n            @Override\n            public Definition define(ClassLoader ignored, String ignoredPackageName, String ignoredTypeName) {\n                return this;\n            }\n\n            @Override\n            public boolean isDefined() {\n                return true;\n            }\n\n            @Override\n            public String getSpecificationTitle() {\n                definePackageOnce();\n                return null;\n            }\n\n            @Override\n            public String getSpecificationVersion() {\n                return null;\n            }\n\n            @Override\n            public String getSpecificationVendor() {\n                return null;\n            }\n\n            @Override\n            public String getImplementationTitle() {\n                return null;\n            }\n\n            @Override\n            public String getImplementationVersion() {\n                return null;\n            }\n\n            @Override\n            public String getImplementationVendor() {\n                return null;\n            }\n\n            @Override\n            public URL getSealBase() {\n                return null;\n            }\n\n            @Override\n            public boolean isCompatibleTo(Package definedPackage) {\n                return packageName.equals(definedPackage.getName());\n            }\n\n            private void definePackageOnce() {\n                if (!packageDefined) {\n                    classLoader.defineGeneratedPackage(packageName);\n                    packageDefined = true;\n                }\n            }\n        }\n    }\n}\n"}
