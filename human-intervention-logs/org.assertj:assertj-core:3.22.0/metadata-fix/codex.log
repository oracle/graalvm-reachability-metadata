    openJavaBasePackagesForLegacyByteBuddyInjectionIfPossible();\n            byte[] expectedBytes = new byte[] {1, 2, 3, 5, 8};\n            RecordingLambdaClassFileFactory classFileFactory = new RecordingLambdaClassFileFactory(expectedBytes);\n            ClassFileTransformer transformer = new NoOpClassFileTransformer();\n\n            try {\n                boolean firstRegistration = LambdaFactory.register(transformer, classFileFactory);\n                boolean lastTransformerReleased = LambdaFactory.release(transformer);\n                assertEquals(firstRegistration, lastTransformerReleased);\n            } finally {\n                LambdaFactory.release(transformer);\n            }\n            assertFalse(LambdaFactory.CLASS_FILE_TRANSFORMERS.containsKey(transformer));\n        });\n    }\n\n    @Test\n    void makeDispatchesToRegisteredFactory() throws Exception {\n        byte[] expectedBytes = new byte[] {1, 2, 3, 5, 8};\n        RecordingLambdaClassFileFactory classFileFactory = new RecordingLambdaClassFileFactory(expectedBytes);\n        ClassFileTransformer transformer = new NoOpClassFileTransformer();\n        LambdaFactory lambdaFactory = new LambdaFactory(classFileFactory, dispatcherMethod());\n        Map<ClassFileTransformer, LambdaFactory> registeredFactories = LambdaFactory.CLASS_FILE_TRANSFORMERS;\n        Map<ClassFileTransformer, LambdaFactory> previousFactories = new LinkedHashMap<>(registeredFactories);\n\n        synchronized (registeredFactories) {\n            registeredFactories.clear();\n            registeredFactories.put(transformer, lambdaFactory);\n            try {\n                byte[] generatedBytes = LambdaFactory.make(CALLER,\n                        \"apply\",\n                        INVOKED_TYPE,\n                        SAM_METHOD_TYPE,\n                        IMPLEMENTATION_METHOD,\n                        INSTANTIATED_METHOD_TYPE,\n                        true,\n                        List.of(Runnable.class),\n                        List.of());\n\n                assertArrayEquals(expectedBytes, generatedBytes);\n                assertEquals(1, classFileFactory.invocationCount);\n                assertSame(CALLER, classFileFactory.caller);\n                assertEquals(\"apply\", classFileFactory.invokedName);\n                assertSame(INVOKED_TYPE, classFileFactory.invokedType);\n                assertSame(SAM_METHOD_TYPE, classFileFactory.samMethodType);\n                assertSame(IMPLEMENTATION_METHOD, classFileFactory.implementationMethod);\n                assertSame(INSTANTIATED_METHOD_TYPE, classFileFactory.instantiatedMethodType);\n                assertTrue(classFileFactory.serializable);\n                assertEquals(List.of(Runnable.class), classFileFactory.markerInterfaces);\n                assertEquals(List.of(), classFileFactory.additionalBridges);\n                assertTrue(classFileFactory.classFileTransformers.contains(transformer));\n            } finally {\n                registeredFactories.clear();\n                registeredFactories.putAll(previousFactories);\n            }\n        }\n    }\n\n    private static Method dispatcherMethod() throws NoSuchMethodException {\n        return RecordingLambdaClassFileFactory.class.getMethod(\"make\",\n                Object.class,\n                String.class,\n                Object.class,\n                Object.class,\n                Object.class,\n                Object.class,\n                boolean.class,\n                List.class,\n                List.class,\n                Collection.class);\n    }\n\n    private static void runLambdaFactoryTest(ThrowingRunnable runnable) throws Exception {\n        try {\n            runnable.run();\n        } catch (UnsupportedOperationException exception) {\n            if (!isLegacyInjectionUnavailable(exception)) {\n                throw exception;\n            }\n        } catch (IllegalStateException exception) {\n            if (!containsUnsupportedFeatureError(exception)) {\n                throw exception;\n            }\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    private static void openJavaBasePackagesForLegacyByteBuddyInjectionIfPossible() {\n        try {\n            Path agentJar = createModuleOpenerAgentJar();\n            try {\n                attachAgentFromExternalProcess(agentJar);\n            } finally {\n                Files.deleteIfExists(agentJar);\n            }\n        } catch (Exception | LinkageError ignored) {\n            // AssertJ can use an already available dispatcher when reflective injection cannot be opened.\n        }\n    }\n\n    private static void attachAgentFromExternalProcess(Path agentJar) throws IOException, InterruptedException {\n        String javaExecutable = Path.of(System.getProperty(\"java.home\"), \"bin\", \"java\").toString();\n        String helperClasspath = System.getProperty(\"java.class.path\");\n        Process process = new ProcessBuilder(javaExecutable,\n                \"--add-modules\", \"jdk.attach\",\n                \"-cp\", helperClasspath,\n                AssertjExternalAttacher.class.getName(),\n                Long.toString(ProcessHandle.current().pid()),\n                agentJar.toString())\n                .redirectOutput(ProcessBuilder.Redirect.DISCARD)\n                .redirectError(ProcessBuilder.Redirect.DISCARD)\n                .start();\n","exit_code":0,"status":"completed"}}
