_workflows/workflow_strategies/optimistic_dynamic_access_strategy.py:26:    \"\"\"Bulk dynamic-access coverage strategy that shows the full report to the agent.\"\"\"\n./forge/ai_workflows/workflow_strategies/optimistic_dynamic_access_strategy.py:28:    REQUIRED_PROMPTS = [\"optimistic-dynamic-access-iteration\"]\n./forge/ai_workflows/workflow_strategies/optimistic_dynamic_access_strategy.py:52:            \"dynamic-access\",\n./forge/ai_workflows/workflow_strategies/optimistic_dynamic_access_strategy.py:53:            \"dynamic-access-coverage.json\",\n./forge/ai_workflows/workflow_strategies/optimistic_dynamic_access_strategy.py:93:                \"optimistic-dynamic-access-iteration\",\n./forge/ai_workflows/workflow_strategies/optimistic_dynamic_access_strategy.py:151:                self._print_detail(\"result: dynamic-access report unavailable after test run\")\n./forge/ai_workflows/workflow_strategies/optimistic_dynamic_access_strategy.py:155:                \"Optimistic dynamic-access coverage ({covered}/{total})\".format(\n./stats/com.google.api.grpc/grpc-google-cloud-spanner-admin-instance-v1/6.116.1/execution-metrics.json:53:      \"metadata_file\": \"metadata/com.google.api.grpc/grpc-google-cloud-spanner-admin-instance-v1/6.116.1/reachability-metadata.json\"\n./stats/dev.profunktor/redis4cats-core_3/1.7.2/execution-metrics.json:53:      \"metadata_file\": \"metadata/dev.profunktor/redis4cats-core_3/1.7.2/reachability-metadata.json\"\n./forge/ai_workflows/workflow_strategies/dynamic_access_iterative_strategy.py:39:    \"\"\"Iterative add-new-library workflow guided by dynamic-access coverage.\"\"\"\n./forge/ai_workflows/workflow_strategies/dynamic_access_iterative_strategy.py:43:    REQUIRED_PROMPTS = [\"dynamic-access-iteration\"]\n./forge/ai_workflows/workflow_strategies/dynamic_access_iterative_strategy.py:93:            \"dynamic-access\",\n./forge/ai_workflows/workflow_strategies/dynamic_access_iterative_strategy.py:94:            \"dynamic-access-coverage.json\",\n./forge/ai_workflows/workflow_strategies/dynamic_access_iterative_strategy.py:228:                    \"dynamic-access-iteration\",\n./forge/ai_workflows/workflow_strategies/dynamic_access_iterative_strategy.py:234:                self._print_dynamic_access_detail(\"agent: running dynamic-access prompt\", indent_level=2)\n./forge/ai_workflows/workflow_strategies/dynamic_access_iterative_strategy.py:297:                        \"result: dynamic-access report unavailable after test run\",\n./forge/ai_workflows/workflow_strategies/dynamic_access_iterative_strategy.py:370:                        f\"Partial dynamic-access coverage for {class_name} \"\n./forge/ai_workflows/workflow_strategies/dynamic_access_iterative_strategy.py:556:        \"\"\"Regenerate the dynamic-access report after the gate to reflect new coverage.\"\"\"\n./forge/ai_workflows/workflow_strategies/dynamic_access_iterative_strategy.py:576:        \"\"\"Start resumable chunking when the first dynamic-access report is too large.\"\"\"\n./forge/ai_workflows/workflow_strategies/dynamic_access_iterative_strategy.py:598:            \"Large dynamic-access report detected; starting large-library series \"\n./forge/ai_workflows/workflow_strategies/dynamic_access_iterative_strategy.py:856:                \"Coverage report loaded but contains no usable dynamic-access guidance:\",\n./forge/ai_workflows/workflow_strategies/dynamic_access_iterative_strategy.py:932:        log_stage(\"dynamic-access\", message)\n./forge/ai_workflows/workflow_strategies/dynamic_access_iterative_strategy.py:936:        log_stage(\"dynamic-access\", message, indent_level=indent_level)\n./forge/ai_workflows/workflow_strategies/basic_iterative_strategy.py:16:    │   https://github.com/oracle/graalvm-reachability-metadata/blob/master/docs/CONTRIBUTING.md#generate-metadata-and-test   │\n./stats/com.google.api.grpc/proto-google-cloud-spanner-admin-database-v1/6.116.1/execution-metrics.json:53:      \"metadata_file\": \"metadata/com.google.api.grpc/proto-google-cloud-spanner-admin-database-v1/6.116.1/reachability-metadata.json\"\n./forge/ai_workflows/fix_javac_fail.py:14:    [--reachability-metadata-path /path/to/graalvm-reachability-metadata] \\\n./forge/ai_workflows/fix_metadata_codex.py:23:    Requires the ``fix-missing-reachability-metadata`` skill. The skill definition lives at:\n./forge/ai_workflows/fix_metadata_codex.py:24:    https://github.com/oracle/graalvm-reachability-metadata/blob/master/skills/fix-missing-reachability-metadata/SKILL.md\n./stats/org.apache.jackrabbit/jackrabbit-jcr-commons/1.5.0/execution-metrics.json:59:      \"metadata_file\": \"metadata/org.apache.jackrabbit/jackrabbit-jcr-commons/1.5.0/reachability-metadata.json\"\n./stats/com.google.api.grpc/grpc-google-cloud-spanner-executor-v1/6.116.1/execution-metrics.json:53:      \"metadata_file\": \"metadata/com.google.api.grpc/grpc-google-cloud-spanner-executor-v1/6.116.1/reachability-metadata.json\"\n./forge/ai_workflows/add_new_library_support.py:10:    [--reachability-metadata-path /path/to/graalvm-reachability-metadata] \\\n./forge/ai_workflows/add_new_library_support.py:88:            \"  --reachability-metadata-path /path/to/reachability-metadata \\\\\\n\"\n./forge/ai_workflows/add_new_library_support.py:101:        \"--reachability-metadata-path\",\n./forge/ai_workflows/add_new_library_support.py:103:            \"Path to the graalvm-reachability-metadata repository to operate on. \"\n./forge/ai_workflows/add_new_library_support.py:142:        \"--keep-tests-without-dynamic-access\",\n./forge/ai_workflows/add_new_library_support.py:145:            \"When using dynamic-access strategies, keep generated tests even when they do not improve \"\n./forge/ai_workflows/add_new_library_support.py:146:            \"dynamic-access coverage.\"\n./forge/ai_workflows/add_new_library_support.py:152:        help=\"Enable resumable large-library chunking for dynamic-access workflows.\",\n./forge/ai_workflows/add_new_library_support.py:220:    \"\"\"Resolve paths for reachability-metadata and metrics-metadata-forge repositories.\"\"\"\n./stats/com.google.api.grpc/proto-google-iam-v1/1.40.1/execution-metrics.json:53:      \"metadata_file\": \"metadata/com.google.api.grpc/proto-google-iam-v1/1.40.1/reachability-metadata.json\"\n./stats/com.google.re2j/re2j/1.1/execution-metrics.json:53:      \"metadata_file\": \"metadata/com.google.re2j/re2j/1.1/reachability-metadata.json\"\n./stats/com.google.api.grpc/proto-google-cloud-bigquerystorage-v1alpha/3.14.1/execution-metrics.json:53:      \"metadata_file\": \"metadata/com.google.api.grpc/proto-google-cloud-bigquerystorage-v1alpha/3.14.1/reachability-metadata.json\"\n./forge/ai_workflows/improve_library_coverage.py:6:\"\"\"Workflow entry point for improving dynamic-access coverage on an existing library.\n./forge/ai_workflows/improve_library_coverage.py:9:focuses solely on generating new tests to improve dynamic-access coverage.\n./forge/ai_workflows/improve_library_coverage.py:14:    [--reachability-metadata-path /path/to/graalvm-reachability-metadata] \\\n./forge/ai_workflows/improve_library_coverage.py:74:        description=\"Improve dynamic-access coverage for an existing library version.\",\n./forge/ai_workflows/improve_library_coverage.py:83:        \"--reachability-metadata-path\",\n./forge/ai_workflows/improve_library_coverage.py:85:            \"Path to the graalvm-reachability-metadata repository. \"\n./forge/ai_workflows/improve_library_coverage.py:112:        help=\"Enable resumable large-library chunking for dynamic-access workflows.\",\n./forge/ai_workflows/fix_java_fails.py:13:    [--strategy-name NAME] [--reachability-metadata-path PATH] \\\n./forge/ai_workflows/fix_java_fails.py:19:    [--strategy-name NAME] [--reachability-metadata-path PATH] \\\n./forge/ai_workflows/fix_java_fails.py:60:        \"--reachability-metadata-path\",\n./forge/ai_workflows/fix_java_fails.py:62:            \"Path to the graalvm-reachability-metadata repository. \"\n./forge/ai_workflows/fix_java_fails.py:96:        workflow_argv.extend([\"--reachability-metadata-path\", flags.reachability_metadata_path])\n./stats/org.wildfly.openssl/wildfly-openssl-java/2.1.1.Final/execution-metrics.json:106:      \"metadata_file\": \"metadata/org.wildfly.openssl/wildfly-openssl-java/2.1.1.Final/reachability-metadata.json\"\n./stats/com.google.api.grpc/proto-google-cloud-spanner-admin-instance-v1/6.116.1/execution-metrics.json:53:      \"metadata_file\": \"metadata/com.google.api.grpc/proto-google-cloud-spanner-admin-instance-v1/6.116.1/reachability-metadata.json\"\n./stats/org.wildfly.openssl/wildfly-openssl-java/1.0.7.Final/execution-metrics.json:64:      \"metadata_file\": \"metadata/org.wildfly.openssl/wildfly-openssl-java/1.0.7.Final/reachability-metadata.json\"\n./docs/CONTRIBUTING.md:16:git clone git@github.com:oracle/graalvm-reachability-metadata.git\n./docs/CONTRIBUTING.md:224:Only Docker images that are listed in the [`allowed-docker-images` directory](https://github.com/oracle/graalvm-reachability-metadata/blob/master/tests/tck-build-logic/src/main/resources/allowed-docker-images) can be used for testing.\n./docs/CONTRIBUTING.md:226:That pull request should add a new file in the [`allowed-docker-images` directory](https://github.com/oracle/graalvm-reachability-metadata/blob/master/tests/tck-build-logic/src/main/resources/allowed-docker-images)\n./docs/CONTRIBUTING.md:237:   * If your test uses Docker image that is not listed in [allowed docker images list](https://github.com/oracle/graalvm-reachability-metadata/blob/master/tests/tck-build-logic/src/main/resources/AllowedDockerImages.txt),\n./docs/CONTRIBUTING.md:243:See an [example](https://github.com/oracle/graalvm-reachability-metadata/blob/master/tests/tck-build-logic/src/main/resources/allowed-docker-images/Dockerfile-mysql_mysql-server).\n./docs/CONTRIBUTING.md:247:If your library or framework is tested with GraalVM Native Image, consider adding it to [this list](https://github.com/oracle/graalvm-reachability-metadata/blob/master/metadata/library-and-framework-list.json).\n./docs/CONTRIBUTING.md:274:   * community-tested (the library is partially tested through some project, e.g. [Reachability Metadata Repository](https://github.com/oracle/graalvm-reachability-metadata/tree/master/tests/src))\n./docs/CONTRIBUTING.md:279:**Note:** The entries you add will be validated against [library-and-framework-list-schema-v1.0.0.json](https://github.com/oracle/graalvm-reachability-metadata/blob/master/schemas/library-and-framework-list-schema-v1.0.0.json)\n./stats/org.wildfly.openssl/wildfly-openssl-java/2.0.0.Alpha1/execution-metrics.json:106:      \"metadata_file\": \"metadata/org.wildfly.openssl/wildfly-openssl-java/2.0.0.Alpha1/reachability-metadata.json\"\n./docs/support/index.html:415:        <a class=\"brand\" id=\"repositoryBrand\" href=\"https://github.com/oracle/graalvm-reachability-metadata\">\n./docs/support/index.html:419:            <span class=\"brand-subtitle\" id=\"repositoryName\">oracle/graalvm-reachability-metadata</span>\n./docs/support/index.html:422:        <a class=\"toplink\" id=\"readmeLink\" href=\"https://github.com/oracle/graalvm-reachability-metadata#readme\">View README</a>\n./docs/support/index.html:430:            <a id=\"newLibraryLink\" href=\"https://github.com/oracle/graalvm-reachability-metadata/issues/new?template=01_support_new_library.yml\">\n./docs/support/index.html:434:            <a id=\"updateLibraryLink\" href=\"https://github.com/oracle/graalvm-reachability-metadata/issues/new?template=02_update_existing_library.yml\">\n./docs/support/index.html:438:            <a id=\"contributeLink\" href=\"https://github.com/oracle/graalvm-reachability-metadata/issues/new?template=02_update_existing_library.yml\">\n./docs/support/index.html:472:            <code id=\"commandSnippet\">curl -sSL https://raw.githubusercontent.com/oracle/graalvm-reachability-metadata/master/check-library-support.sh | bash -s \"&lt;groupId&gt;:&lt;artifactId&gt;:&lt;version&gt;\"</code>\n./docs/support/index.html:485:        repo: \"graalvm-reachability-metadata\",\n./docs/FUNCTIONAL_SPEC.md:22:| **Repository automation (Metadata Forge)** | Generate or repair metadata using LLM-driven pipelines. | Per coordinate, the toolkit can: (1) **add support for a new library** — generate a JUnit / Kotlin / Scala test suite, scaffold metadata, and iterate until JVM-mode tests pass and dynamic-access is collected ([`add_new_library_support.py`](../forge/ai_workflows/add_new_library_support.py)); (2) **fix a Java compilation (`javac`) failure** raised by a library version bump ([`fix_javac_fail.py`](../forge/ai_workflows/fix_javac_fail.py)); (3) **fix a JVM-mode (`javaTest`) runtime failure** raised by a version bump ([`fix_java_run_fail.py`](../forge/ai_workflows/fix_java_run_fail.py)); (4) **fix a `native-image` runtime failure** raised by a version bump ([`fix_ni_run.py`](../forge/ai_workflows/fix_ni_run.py)); (5) **improve dynamic-access coverage** of already-supported libraries by targeting uncovered call sites; (6) **post-generation repair** of the metadata produced by a previous run ([`fix_post_generation_pi.py`](../forge/ai_workflows/fix_post_generation_pi.py), [`fix_metadata_codex.py`](../forge/ai_workflows/fix_metadata_codex.py)). Each task runs Gradle tasks against a worktree of this repo, appends a schema-validated metrics record, and — when invoked through [`forge/git_scripts/make_pr_*.py`](../forge/git_scripts/) — opens a PR for human review. See [forge/docs/architecture.md](../forge/docs/architecture.md). |\n./docs/FUNCTIONAL_SPEC.md:30:Two properties make this achievable: the reachability-metadata schema is itself additive (every entry is gated on `typeReachable`, FR-M-2), and `native-image` defaults to runtime initialization when no build-time directives are supplied. The hard constraints below preserve that additivity — they are not editorial scope choices but direct consequences of the invariant.\n./docs/FUNCTIONAL_SPEC.md:46:- A `stats/<groupId>/<artifactId>/<metadata-version>/stats.json` mirror of per-version metrics (dynamic-access call sites, coverage, lines of code, dependency information).\n./docs/FUNCTIONAL_SPEC.md:55:- Coverage collection (JaCoCo) and dynamic-access reporting per coordinate.\n./docs/FUNCTIONAL_SPEC.md:74:- `latest/badges.json` — badges shown in the README (libraries supported, tested versions, dynamic-access coverage, tested LOC).\n./docs/FUNCTIONAL_SPEC.md:84:1. **Add new library support** — generate a JUnit test suite, scaffold metadata, iterate until JVM-mode tests pass and dynamic-access metadata is collected.\n./docs/FUNCTIONAL_SPEC.md:87:4. **Improve coverage** of already-supported libraries by targeting uncovered dynamic-access call sites.\n./docs/FUNCTIONAL_SPEC.md:124:    participant Repo as graalvm-reachability-metadata\n./docs/FUNCTIONAL_SPEC.md:146:**1. Distribution artifact.** The `package` Gradle task produces `graalvm-reachability-metadata-<repo-version>.zip`, which the scheduled release workflow attaches as a GitHub Release asset on a `<repo-version>` tag every two weeks. The ZIP is a verbatim copy of the repository's `metadata/` tree — there is no separate top-level manifest. Its contents at the ZIP root are exactly:\n./docs/FUNCTIONAL_SPEC.md:153:    reachability-metadata-schema-vX.Y.Z.json\n./docs/FUNCTIONAL_SPEC.md:156:    reachability-metadata.json                           # the only file native-image loads (element 3)\n./docs/FUNCTIONAL_SPEC.md:159:Plugin-relevant content is `<groupId>/<artifactId>/index.json` and the per-version `reachability-metadata.json` files; the plugin discovers libraries by directory walk. `library-and-framework-list.json` and `schemas/` are present for downstream tooling (the libraries-and-frameworks page and offline validators) and are not consumed by native-build-tools at native-image time.\n./docs/FUNCTIONAL_SPEC.md:165:**3. `<groupId>/<artifactId>/<metadata-version>/reachability-metadata.json`** — the only file the plugin loads at native-image time. Schema [reachability-metadata-schema-v1.2.0.json](../metadata/schemas/reachability-metadata-schema-v1.2.0.json) (a vendored copy of the upstream GraalVM schema), with top-level keys `reflection`, `jni`, `resources`, `bundles`, `serialization`, and `foreignCalls`. Every entry must carry a `condition.typeReachable` clause (FR-M-2) so the plugin can rely on conditional registration. The legacy split-config layout (`reflect-config.json`, `jni-config.json`, …) is no longer present.\n./stats/io.prometheus/simpleclient_caffeine/0.16.0/execution-metrics.json:53:      \"metadata_file\": \"metadata/io.prometheus/simpleclient_caffeine/0.16.0/reachability-metadata.json\"\n./stats/com.google.api.grpc/proto-google-cloud-bigquerystorage-v1beta/3.14.1/execution-metrics.json:53:      \"metadata_file\": \"metadata/com.google.api.grpc/proto-google-cloud-bigquerystorage-v1beta/3.14.1/reachability-metadata.json\"\n./stats/io.prometheus/simpleclient/0.16.0/execution-metrics.json:53:      \"metadata_file\": \"metadata/io.prometheus/simpleclient/0.16.0/reachability-metadata.json\"\n./stats/io.prometheus/simpleclient_tracer_otel_agent/0.16.0/execution-metrics.json:53:      \"metadata_file\": \"metadata/io.prometheus/simpleclient_tracer_otel_agent/0.16.0/reachability-metadata.json\"\n./docs/DEVELOPING.md:206:These tasks use Native Image runtime metadata tracing. They require a GraalVM build that supports `-H:+MetadataTracingSupport`, `-XX:TraceMetadata`, and `-XX:TraceMetadataConditionPackages`.\n./docs/DEVELOPING.md:211:./gradlew nativeTraceImage -Pcoordinates=<group:artifact:version>\n./docs/DEVELOPING.md:214:Run the trace-enabled binary once and write runtime trace metadata. The trace binary is built with `-H:+MetadataTracingSupport`, `--exact-reachability-metadata`, and `-H:MissingRegistrationReportingMode=Exit`, so it exits with `ExitStatus.MISSING_METADATA` (172) when an access misses the supplied metadata. The Gradle Exec ignores the binary's exit code so the trace output can still be inspected or merged after a 172 exit; pass `-PtraceBinaryExitFile=<absolute-path>` to capture the exit code in a sentinel file (used by automated callers like the verification gate).\n./docs/DEVELOPING.md:217:./gradlew runNativeTraceImage \\\n./docs/DEVELOPING.md:234:./gradlew nativeTraceImage \\\n./docs/DEVELOPING.md:241:Moves test-only entries from library `reachability-metadata.json` in `metadata/`, into the corresponding test resources metadata file.\n./docs/DEVELOPING.md:310:- Build trace-enabled native image: `./gradlew nativeTraceImage -Pcoordinates=group:artifact:version`\n./docs/DEVELOPING.md:311:- Run trace-enabled native image: `./gradlew runNativeTraceImage -Pcoordinates=group:artifact:version -PtraceMetadataPath=<absolute-trace-output-dir> -PtraceMetadataConditionPackages=<package1,package2,...>`\n./docs/DEVELOPING.md:319:  Output: `metadata/<group>/<artifact>/<version>/test/build/reports/dynamic-access/dynamic-access-coverage.json`\n./stats/io.prometheus/simpleclient_tracer_common/0.16.0/execution-metrics.json:33:      \"metadata_file\": \"metadata/io.prometheus/simpleclient_tracer_common/0.16.0/reachability-metadata.json\"\n./stats/io.prometheus/simpleclient_tracer_otel/0.16.0/execution-metrics.json:53:      \"metadata_file\": \"metadata/io.prometheus/simpleclient_tracer_otel/0.16.0/reachability-metadata.json\"\n./stats/net.postgis/postgis-geometry/2.5.0/execution-metrics.json:53:      \"metadata_file\": \"metadata/net.postgis/postgis-geometry/2.5.0/reachability-metadata.json\"\n./stats/net.postgis/postgis-jdbc/2.5.0/execution-metrics.json:64:      \"metadata_file\": \"metadata/net.postgis/postgis-jdbc/2.5.0/reachability-metadata.json\"\n./stats/com.fasterxml.jackson.dataformat/jackson-dataformat-cbor/2.14.3/execution-metrics.json:53:      \"metadata_file\": \"metadata/com.fasterxml.jackson.dataformat/jackson-dataformat-cbor/2.14.3/reachability-metadata.json\"\