[tool-call] delta {"path":"tests/src/com.diffplug.durian/durian-core/1.2.0/src/test/java/com_diffplug_durian/durian_core/ErrorsInnerPluginsTest.java","edits":[{"oldText":"import java.awt.AWTEvent;\nimport java.awt.EventQueue;\nimport java.awt.Toolkit;\n","newText":"import java.awt.Window;\n"},{"oldText":"import java.util.concurrent.TimeUnit;\nimport java.util.concurrent.atomic.AtomicInteger;\n","newText":"import java.util.concurrent.atomic.AtomicInteger;\n\nimport javax.swing.SwingUtilities;\nimport javax.swing.Timer;\n"},{"oldText":"        System.setProperty(\"java.awt.headless\", \"true\");\n        DispatchingEventQueue eventQueue = new DispatchingEventQueue();\n        Toolkit.getDefaultToolkit().getSystemEventQueue().push(eventQueue);\n\n        try (PrintStream replacementErr = new PrintStream(capturedErr, true, StandardCharsets.UTF_8)) {\n            System.setErr(replacementErr);\n\n            Errors.Plugins.defaultDialog(error);\n            int messageReadsAfterScheduling = error.messageReads();\n\n            eventQueue.dispatchUntilMessageReadIncreases(error, messageReadsAfterScheduling);\n\n            assertThat(error.messageReads()).isGreaterThan(messageReadsAfterScheduling);\n        } finally {\n            System.setErr(originalErr);\n            eventQueue.popQueue();\n            restoreSystemProperty(\"java.awt.headless\", previousHeadless);\n        }\n","newText":"        Timer closeDialogs = new Timer(50, event -> disposeShowingWindows());\n        closeDialogs.setRepeats(true);\n\n        try (PrintStream replacementErr = new PrintStream(capturedErr, true, StandardCharsets.UTF_8)) {\n            enableAwtWhenDisplayIsAvailable();\n            System.setErr(replacementErr);\n            closeDialogs.start();\n\n            Errors.Plugins.defaultDialog(error);\n            int messageReadsAfterScheduling = error.messageReads();\n\n            SwingUtilities.invokeAndWait(() -> assertThat(SwingUtilities.isEventDispatchThread()).isTrue());\n\n            assertThat(error.messageReads()).isGreaterThan(messageReadsAfterScheduling);\n        } finally {\n            closeDialogs.stop();\n            disposeShowingWindows();\n            System.setErr(originalErr);\n            restoreSystemProperty(\"java.awt.headless\", previousHeadless);\n        }\n"},{"oldText":"    private static final class DispatchingEventQueue extends EventQueue {\n        private void dispatchUntilMessageReadIncreases(DialogTestException error, int previousReads)\n                throws InterruptedException {\n            long deadline = System.nanoTime() + TimeUnit.SECONDS.toNanos(5);\n            while (error.messageReads() <= previousReads && System.nanoTime() < deadline) {\n                AWTEvent event = peekEvent();\n                if (event == null) {\n                    Thread.sleep(10);\n                } else {\n                    dispatchEvent(getNextEvent());\n                }\n            }\n        }\n\n        private void popQueue() {\n            pop();\n        }\n    }\n\n    private static void restoreSystemProperty(String propertyName, String previousValue) {\n","newText":"    private static void enableAwtWhenDisplayIsAvailable() {\n        if (System.getenv(\"DISPLAY\") != null || System.getenv(\"WAYLAND_DISPLAY\") != null) {\n            System.setProperty(\"java.awt.headless\", \"false\");\n        }\n    }\n\n    private static void disposeShowingWindows() {\n        for (Window window : Window.getWindows()) {\n            if (window.isShowing()) {\n                window.dispose();\n            }\n        }\n    }\n\n    private static void restoreSystemProperty(String propertyName, String previousValue) {\n"}]}
