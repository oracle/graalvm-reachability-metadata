[tool-call] delta {"path":"tests/src/com.diffplug.durian/durian-core/1.2.0/src/test/java/com_diffplug_durian/durian_core/FinalizerTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_diffplug_durian.durian_core;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.lang.ref.PhantomReference;\nimport java.lang.ref.ReferenceQueue;\nimport java.util.concurrent.CountDownLatch;\nimport java.util.concurrent.TimeUnit;\n\nimport org.junit.jupiter.api.Test;\n\nimport com.diffplug.common.base.FinalizableReference;\nimport com.diffplug.common.base.internal.Finalizer;\n\npublic class FinalizerTest {\n    @Test\n    void startedFinalizerInvokesFinalizeReferentForQueuedReference() throws InterruptedException {\n        ReferenceQueue<Object> queue = new ReferenceQueue<>();\n        Object stopReferent = new Object();\n        PhantomReference<Object> stopReference = new PhantomReference<>(stopReferent, queue);\n        CountDownLatch finalizeReferentWasCalled = new CountDownLatch(1);\n        FinalizingPhantomReference reference = new FinalizingPhantomReference(\n                new Object(),\n                queue,\n                finalizeReferentWasCalled);\n\n        Finalizer.startFinalizer(FinalizableReference.class, queue, stopReference);\n        boolean referenceWasEnqueued = reference.enqueue();\n        boolean finalized;\n        try {\n            finalized = finalizeReferentWasCalled.await(5, TimeUnit.SECONDS);\n        } finally {\n            stopReference.enqueue();\n        }\n\n        assertThat(referenceWasEnqueued).isTrue();\n        assertThat(finalized).isTrue();\n        assertThat(stopReferent).isNotNull();\n    }\n\n    private static final class FinalizingPhantomReference extends PhantomReference<Object>\n            implements FinalizableRefer