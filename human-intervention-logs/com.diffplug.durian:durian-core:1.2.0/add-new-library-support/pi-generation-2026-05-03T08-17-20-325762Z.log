ject> queue = new ReferenceQueue<>();\n        Object stopReferent = new Object();\n        PhantomReference<Object> stopReference = new PhantomReference<>(stopReferent, queue);\n        CountDownLatch finalizeReferentWasCalled = new CountDownLatch(1);\n        FinalizingPhantomReference reference = new FinalizingPhantomReference(\n                new Object(),\n                queue,\n                finalizeReferentWasCalled);\n\n        Finalizer.startFinalizer(FinalizableReference.class, queue, stopReference);\n        boolean referenceWasEnqueued = reference.enqueue();\n        boolean finalized;\n        try {\n            finalized = finalizeReferentWasCalled.await(5, TimeUnit.SECONDS);\n        } finally {\n            stopReference.enqueue();\n        }\n\n        assertThat(referenceWasEnqueued).isTrue();\n        assertThat(finalized).isTrue();\n        assertThat(stopReferent).isNotNull();\n    }\n\n    private static final class FinalizingPhantomReference extends PhantomReference<Object>\n            implements FinalizableReference {\n        private final CountDownLatch finalizeReferentWasCalled;\n\n        private FinalizingPhantomReference(\n                Object referent,\n                ReferenceQueue<? super Object> queue,\n                CountDownLatch finalizeReferentWasCalled) {\n            super(referent, queue);\n            this.finalizeReferentWasCalled = finalizeReferentWasCalled;\n        }\n\n        @Override\n        public void finalizeReferent() {\n            finalizeReferentWasCalled.countDown();\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 7335, "output": 1787, "cacheRead": 13824, "cacheWrite": 0, "totalTokens": 22946, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777796165476, "responseId": "resp_01df897cf78f724f0169f70445ec6081a1a5b33114c7a65244"}}
