  @@ -0,0 +1,44 @@
  +/*
  + * Copyright and related rights waived via CC0
  + *
  + * You should have received a copy of the CC0 legalcode along with this
  + * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.
  + */
  +package org_hibernate_common.hibernate_commons_annotations;
  +
  +import static org.assertj.core.api.Assertions.assertThat;
  +
  +import java.util.List;
  +
  +import org.hibernate.annotations.common.reflection.XClass;
  +import org.hibernate.annotations.common.reflection.XProperty;
  +import org.hibernate.annotations.common.reflection.java.JavaReflectionManager;
  +import org.junit.jupiter.api.Test;
  +
  +public class ApproximatingTypeEnvironmentAnonymous1Test {
  +    @Test
  +    public void approximatesGenericArrayComponentToSingleUpperBound() {
  +        JavaReflectionManager reflectionManager = new JavaReflectionManager();
  +        XClass targetClass = reflectionManager.toXClass(GenericArrayProperties.class);
  +        XProperty valuesProperty = declaredFieldProperty(targetClass, "values");
  +
  +        assertThat(valuesProperty.isArray()).isTrue();
  +        assertThat(reflectionManager.toClass(valuesProperty.getElementClass())).isEqualTo(CharSequence.class);
  +        assertThat(reflectionManager.toClass(valuesProperty.getClassOrElementClass())).isEqualTo(CharSequence.class);
  +        assertThat(reflectionManager.toClass(valuesProperty.getType())).isEqualTo(CharSequence[].class);
  +    }
  +
  +    private static XProperty declaredFieldProperty(XClass targetClass, String name) {
  +        List<XProperty> properties = targetClass.getDeclaredProperties(XClass.ACCESS_FIELD);
  +        for (XProperty property : properties) {
  +            if (property.getName().equals(name)) {
  +                return property;
  +            }
  +        }
  +        throw new AssertionError("Missing field property: " + name);
  +    }
  +
  +    public static class GenericArrayProperties<T extends CharSequence> {
  +        public T[] values;
  +    }
  +}
