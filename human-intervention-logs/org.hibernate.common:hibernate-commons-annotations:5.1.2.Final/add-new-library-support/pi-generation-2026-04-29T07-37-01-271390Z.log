read().setContextClassLoader(originalClassLoader);\n        }\n    }\n\n    @Test\n    public void fallsBackToHibernateClassLoaderWhenContextClassLoaderIsMissing() {\n        ClassLoader originalClassLoader = Thread.currentThread().getContextClassLoader();\n\n        try {\n            Thread.currentThread().setContextClassLoader(null);\n\n            Class<?> resolvedClass = StandardClassLoaderDelegateImpl.INSTANCE.classForName(Integer.class.getName());\n\n            assertThat(resolvedClass).isSameAs(Integer.class);\n        } finally {\n            Thread.currentThread().setContextClassLoader(originalClassLoader);\n        }\n    }\n\n    private static final class DelegatingClassLoader extends ClassLoader {\n        private DelegatingClassLoader(ClassLoader parent) {\n            super(parent);\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 783, "output": 542, "cacheRead": 19968, "cacheWrite": 0, "totalTokens": 21293, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777448192560, "responseId": "resp_08b82483661584400169f1b500fe0c819184936b5a9c699013"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_zJgBMSRZd7Dlx0hpCurVabqA|fc_08b82483661584400169f1b5042b4481919c4bb0c6d12ebf90", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1940 bytes to tests/src/org.hibernate.common/hibernate-commons-annotations/5.1.2.Final/src/test/java/org_hibernate_common/hibernate_commons_annotations/StandardClassLoaderDelegateImplTest.java"}], "isError": false, "timestamp": 1777448197919}]}
