\t\treturn TypeUtils.isResolved( boundType );\r\n\t}\r\n\r\n\tprotected Type approximate() {\r\n\t\treturn approximatedType;\r\n\t}\r\n\r\n\tprotected XClass toXClass(Type type) {\r\n\t\treturn factory.toXClass( type, context );\r\n\t}\r\n}\r\n"}], "isError": false, "timestamp": 1777448288637}}
