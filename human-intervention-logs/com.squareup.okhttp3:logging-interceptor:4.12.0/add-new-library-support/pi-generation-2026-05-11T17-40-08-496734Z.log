              level = HttpLoggingInterceptor.Level.NONE
          }
          val client = httpClient {
              addInterceptor(interceptor)
          }
          val responseBody = "network still executed"
  
          OneShotHttpServer(
              body = responseBody.toByteArray(StandardCharsets.UTF_8),
          ).use { server ->
              server.start()
