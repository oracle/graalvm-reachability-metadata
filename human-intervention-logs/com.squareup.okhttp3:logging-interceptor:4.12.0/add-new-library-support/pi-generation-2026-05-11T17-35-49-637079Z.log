      private fun httpClient(configure: OkHttpClient.Builder.() -> Unit): OkHttpClient =
          OkHttpClient.Builder()
              .callTimeout(10, TimeUnit.SECONDS)
              .connectTimeout(5, TimeUnit.SECONDS)
