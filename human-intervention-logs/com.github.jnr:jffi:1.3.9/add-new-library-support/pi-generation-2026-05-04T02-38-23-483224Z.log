          Path emptyLibraryDirectory = Files.createDirectory(temporaryDirectory.resolve("empty-libraries"));
          Path invalidExtractDirectory = Files.createFile(temporaryDirectory.resolve("not-a-directory"));
          SystemPropertySnapshot systemProperties = new SystemPropertySnapshot(
                  "jffi.boot.library.path",
                  "java.library.path",
                  "jffi.extract.dir");
  
          try {
              System.setProperty("jffi.boot.library.path", emptyLibraryDirectory.toString());
