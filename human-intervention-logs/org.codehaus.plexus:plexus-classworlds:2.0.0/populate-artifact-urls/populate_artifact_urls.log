  <name>Plexus Classworlds</name>
  <description>A class loader framework</description>
  <inceptionYear>2002</inceptionYear>

  <scm>
    <connection>scm:svn:http://svn.codehaus.org/plexus/plexus-classworlds/tags/plexus-classworlds-2.0.0</connection>
