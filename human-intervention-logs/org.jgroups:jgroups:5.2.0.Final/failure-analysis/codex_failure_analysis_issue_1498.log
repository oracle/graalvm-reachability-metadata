;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\n\\npublic class ConfiguratorTest {\\n    @Test\\n    public void createsProtocolLayerFromConfiguration() throws Exception {\\n        ProtocolStack stack=new ProtocolStack();\\n\\n        Protocol protocol=Configurator.createProtocol(DISCARD.class.getName(), stack, false);\\n\\n        assertThat(protocol).isInstanceOf(DISCARD.class);\\n        assertThat(protocol.getProtocolStack()).isSameAs(stack);\\n    }\\n\\n    @Test\\n    public void initializesAnnotatedFieldsAndMethodsInDependencyOrder() throws Exception {\\n        DependentPropertiesTarget target=new DependentPropertiesTarget();\\n        Map<String,String> properties=new HashMap<>();\\n        properties.put(\\\"base_value\\\", \\\"base\\\");\\n        properties.put(\\\"dependent_value\\\", \\\"dependent\\\");\\n\\n        Configurator.initializeAttrs(target, properties, StackType.IPv4);\\n\\n        assertThat(target.baseValue()).isEqualTo(\\\"base\\\");\\n        assertThat(target.dependentValue()).isEqualTo(\\\"base:dependent\\\");\\n        assertThat(properties).isEmpty();\\n    }\\n\\n    @Test\\n    public void invokesAnnotatedPropertyMethodsFromPublicMethodScan() throws Exception {\\n        MethodPropertiesTarget target=new MethodPropertiesTarget();\\n        Map<String,String> properties=new HashMap<>();\\n        properties.put(\\\"method_value\\\", \\\"configured-by-method\\\");\\n\\n        Configurator.resolveAndInvokePropertyMethods(target, properties, StackType.IPv4);\\n\\n        assertThat(target.methodValue()).isEqualTo(\\\"configured-by-method\\\");\\n        assertThat(properties).isEmpty();\\n    }\\n\\n    @Test\\n    public void assignsAnnotatedFieldsFromDeclaredFieldScan() throws Exception {\\n        FieldPropertiesTarget target=new FieldPropertiesTarget();\\n        Map<String,String> properties=new HashMap<>();\\n        properties.put(\\\"field_value\\\", \\\"configured-by-field\\\");\\n\\n        Configurator.resolveAndAssignFields(target, properties, StackType.IPv4);\\n\\n        assertThat(target.fieldValue()).isEqualTo(\\\"configured-by-field\\\");\\n        assertThat(properties).isEmpty();\\n    }\\n\\n    @Test\\n    public void discoversInetAddressFieldsOnProtocols() throws Exception {\\n        InetAddress loopback=InetAddress.getLoopbackAddress();\\n        AddressFieldProtocol protocol=new AddressFieldProtocol(loopback);\\n\\n        List<InetAddress> addresses=Configurator.getInetAddresses(Collections.singletonList(protocol));\\n\\n        assertThat(addresses).contains(loopback);\\n    }\\n\\n    @Test\\n    public void appliesDefaultInetAddressThroughAnnotatedSetter() throws Exception {\\n        DefaultAddressMethodTarget target=new DefaultAddressMethodTarget();\\n\\n        Configurator.setDefaultAddressValues(target, StackType.IPv4);\\n\\n        assertThat(target.bindAddr()).isEqualTo(InetAddress.getByName(\\\"127.0.0.1\\\"));\\n    }\\n\\n    @Test\\n    public void createsProtocolsAndInitializesAttributesFromConfigurations() throws Exception {\\n        ProtocolConfiguration configuration=new ProtocolConfiguration(DISCARD.class.getName() + \\\"(discard_all=true)\\\");\\n\\n        List<Protocol> protocols=Configurator.createProtocolsAndInitializeAttrs(\\n          Collections.singletonList(configuration), new ProtocolStack());\\n\\n        assertThat(protocols).hasSize(1);\\n        assertThat(protocols.get(0)).isInstanceOf(DISCARD.class);\\n        assertThat(((DISCARD)protocols.get(0)).discardAll()).isTrue();\\n    }\\n\\n    public static class DependentPropertiesTarget {\\n        @Property\\n        private String base_value;\\n\\n        private String dependent_value;\\n\\n        public String baseValue() {\\n            return base_value;\\n        }\\n\\n        public String dependentValue() {\\n            return dependent_value;\\n        }\\n\\n        @Property(name=\\\"dependent_value\\\", dependsUpon=\\\"base_value\\\")\\n        public void setDependentValue(String dependentValue) {\\n            dependent_value=base_value + \\\":\\\" + dependentValue;\\n        }\\n    }\\n\\n    public static class MethodPropertiesTarget {\\n        private String method_value;\\n\\n        public String methodValue() {\\n            return method_value;\\n        }\\n\\n        @Property(name=\\\"method_value\\\")\\n        public void setMethodValue(String methodValue) {\\n            method_value=methodValue;\\n        }\\n    }\\n\\n    public static class FieldPropertiesTarget {\\n        @Property\\n        private String field_value;\\n\\n        public String fieldValue() {\\n            return field_value;\\n        }\\n    }\\n\\n    public static class AddressFieldProtocol extends Protocol {\\n        @Property\\n        private InetAddress bind_addr;\\n\\n        public AddressFieldProtocol(InetAddress bindAddr) {\\n            bind_addr=bindAddr;\\n        }\\n    }\\n\\n    public static class DefaultAddressMethodTarget {\\n        private InetAddress bind_addr;\\n\\n        public InetAddress bindAddr() {\\n            return bind_addr;\\n        }\\n\\n        @Property(name=\\\"bind_addr\\\", defaultValueIPv4=\\\"127.0.0.1\\\")\\n        public void setBindAddr(InetAddress bindAddr) {\\n            bind_addr=bindAddr;\\n        }\\n    }\\n}\\n\"}], \"isError\": false, \"timestamp\": 1778105944222}}\n3549:[recv] {\"type\": \"message_end\", \"message\": {\"role\": \"toolResult\", \"toolCallId\": \"call_yjVyUvEF2StbR4PsAVR2AbDo|fc_09057be2467e98090169fbbe57454c81a08f6b2a8f56fc9360\", \"toolName\": \"read\", \"content\": [{\"type\": \"text\", \"text\": \"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage org_jgroups.jgroups;\\n\\nimport org.jgroups.annotations.Property;\\nimport org.jgroups.conf.ProtocolConfiguration;\\nimport