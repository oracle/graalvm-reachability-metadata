d(\"bravo\", 7);\n\n        String encoded = Base64.encodeObject(payload, Base64.GZIP | Base64.DO_BREAK_LINES);\n        Object decoded = Base64.decodeToObject(encoded, Base64.GZIP, Base64Test.class.getClassLoader());\n\n        assertThat(decoded).isEqualTo(payload);\n    }\n\n    public static class SerializablePayload implements Serializable {\n        private static final long serialVersionUID = 1L;\n\n        private final String name;\n        private final int value;\n\n        public SerializablePayload(String name, int value) {\n            this.name = name;\n            this.value = value;\n        }\n\n        @Override\n        public boolean equals(Object other) {\n            if(this == other) {\n                return true;\n            }\n            if(!(other instanceof SerializablePayload)) {\n                return false;\n            }\n            SerializablePayload that = (SerializablePayload)other;\n            return value == that.value && Objects.equals(name, that.name);\n        }\n\n        @Override\n        public int hashCode() {\n            return Objects.hash(name, value);\n        }\n    }\n}\n"}, "partialJson": "{\"path\":\"tests/src/org.jgroups/jgroups/5.2.0.Final/src/test/java/org_jgroups/jgroups/Base64Test.java\",\"content\":\"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage org_jgroups.jgroups;\\n\\nimport org.jgroups.util.Base64;\\nimport org.junit.jupiter.api.Test;\\n\\nimport java.io.Serializable;\\nimport java.util.Objects;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\n\\npublic class Base64Test {\\n    @Test\\n    void serializesAndDeserializesObjectsThroughBase64() throws Exception {\\n        SerializablePayload payload = new SerializablePayload(\\\"alpha\\\", 42);\\n\\n        String encoded = Base64.encodeObject(payload);\\n   