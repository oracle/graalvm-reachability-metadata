blePayload)) {\n                return false;\n            }\n            SerializablePayload that = (SerializablePayload)other;\n            return value == that.value && Objects.equals(name, that.name);\n        }\n\n        @Override\n        public int hashCode() {\n            return Objects.hash(name, value);\n        }\n    }\n}\n"}
