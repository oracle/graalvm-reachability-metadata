              try {
                  if(ex.isSet())
                      return;
                  Map<String,String> m=new HashMap<>();
                  String key=prefix + ".";
                  props.entrySet().stream().filter(e -> e.getKey().startsWith(key))
                    .forEach(e -> m.put(e.getKey().substring(prefix.length() + 1), e.getValue()));
