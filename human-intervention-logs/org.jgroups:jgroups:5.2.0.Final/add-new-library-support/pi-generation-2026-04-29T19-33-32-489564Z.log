                  Map<String,String> tmp=getProps(prot);
                  for(Map.Entry<String,String> entry: tmp.entrySet()) {
                      sb.append("    ").append(entry.getKey()).append("=").append(entry.getValue()).append("\n");
                  }
              }
          }
          return sb.toString();
      }
  
