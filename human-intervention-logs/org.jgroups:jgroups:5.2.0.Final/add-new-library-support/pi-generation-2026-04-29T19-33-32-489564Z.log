          Util.forAllComponentTypes(p.getClass(), (cl, prefix) -> {
              if(ex.isSet())
                  return;
              if(prefix == null || prefix.trim().isEmpty()) {
                  ex.set(new IllegalArgumentException(String.format("component (class=%s) in %s must have a prefix",
                                                                    cl.getSimpleName(), p.getName())));
