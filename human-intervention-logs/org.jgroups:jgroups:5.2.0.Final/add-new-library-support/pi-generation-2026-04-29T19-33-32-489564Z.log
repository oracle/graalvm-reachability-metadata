                              PropertyConverter conv=null;
                              try {
                                  conv=(PropertyConverter)conv_class.getDeclaredConstructor().newInstance();
                              }
                              catch(Exception e) {
                              }
                              String tmp=conv != null? conv.toString(value) : value.toString();
                              retval.put(field.getName(), tmp);
                          }
                      }
                  }
              }
          }
          return retval;
      }
  
  
