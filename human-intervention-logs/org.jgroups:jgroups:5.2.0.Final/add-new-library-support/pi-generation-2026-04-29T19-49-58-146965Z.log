              boolean external=tuple.getVal3();
              if(external) {
                  if(magicMap[m] != null)
                      alreadyInMagicMap(m, tuple.getVal2());
                  continue;
              }
              Class<?> clazz=Util.loadClass(tuple.getVal2(), ClassConfigurator.class);
              if(magicMap[m] != null)
