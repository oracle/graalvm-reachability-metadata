  package org_jgroups.jgroups;
  
  import org.jgroups.annotations.Component;
  import org.jgroups.annotations.ManagedAttribute;
  import org.jgroups.annotations.ManagedOperation;
  import org.jgroups.jmx.ResourceDMBean;
  import org.junit.jupiter.api.Test;
  
  import javax.management.Attribute;
  import javax.management.AttributeList;
  import javax.management.MBeanAttributeInfo;
  import javax.management.MBeanInfo;
  import java.util.LinkedHashMap;
  import java.util.Map;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ResourceDMBeanTest {
      @Test
      public void exposesAnnotatedAttributesAndInvokesPrimaryAndComponentOperations() throws Exception {
          ManagedResource target=new ManagedResource();
          ResourceDMBean bean=new ResourceDMBean(target);
  
          assertThat(bean.getAttribute("fieldOnly")).isEqualTo("initial");
          bean.setAttribute(new Attribute("fieldOnly", "changed"));
          assertThat(bean.getAttribute("fieldOnly")).isEqualTo("changed");
  
          AttributeList attributes=bean.getAttributes(new String[] {"fieldOnly", "computed"});
          assertThat(attributes.asList()).extracting(Attribute::getName).contains("fieldOnly", "computed");
  
          AttributeList updates=new AttributeList();
          updates.add(new Attribute("fieldOnly", "updated"));
          assertThat(bean.setAttributes(updates).asList()).extracting(Attribute::getName).containsExactly("fieldOnly");
          assertThat(bean.getAttribute("fieldOnly")).isEqualTo("updated");
  
          Object componentResult=bean.invoke("componentEcho", new Object[] {"payload"},
            new String[] {String.class.getName()});
          Object primaryResult=bean.invoke("primaryEcho", new Object[] {"payload", 3},
            new String[] {String.class.getName(), int.class.getName()});
  
          assertThat(componentResult).isEqualTo("component:payload");
          assertThat(primaryResult).isEqualTo("primary:payload:3");
  
          MBeanInfo info=bean.getMBeanInfo();
          assertThat(info.getAttributes()).extracting(MBeanAttributeInfo::getName).contains("fieldOnly", "computed");
      }
  
      @Test
      public void dumpsAnnotatedFieldAndGetterStatistics() {
          ManagedResource target=new ManagedResource();
          Map<String,Object> stats=new LinkedHashMap<>();
  
          ResourceDMBean.dumpStats(target, "resource", stats);
  
          assertThat(stats).containsEntry("resource.fieldOnly", "initial")
            .containsEntry("resource.computed", "computed-initial");
      }
  
      public static class ManagedResource {
          @ManagedAttribute(writable=true)
          private String fieldOnly="initial";
  
          @Component(name="component")
          private final ManagedComponent component=new ManagedComponent();
  
          @ManagedAttribute(name="computed")
          public String getComputed() {
              return "computed-" + fieldOnly;
          }
  
          @ManagedOperation
          public String primaryEcho(String value, int count) {
              return "primary:" + value + ":" + count;
          }
      }
  
      public static class ManagedComponent {
          @ManagedAttribute(name="componentValue")
          private String componentValue="component-state";
  
          @ManagedOperation
          public String componentEcho(String value) {
              return "component:" + value;
          }
      }
  }
