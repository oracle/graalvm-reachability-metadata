            UtilTest.class.getClassLoader());
          CustomSerializable fromByteBuffer=Util.objectFromByteBuffer(ByteBuffer.wrap(byteBuffer),
            UtilTest.class.getClassLoader());
  
          ByteArrayDataOutputStream output=new ByteArrayDataOutputStream(128, true);
          Util.objectToStream(payload, output);
          CustomSerializable fromStream=Util.objectFromStream(new ByteArrayDataInputStream(output.buffer(), 0,
            output.position()), UtilTest.class.getClassLoader());
  
          assertThat(fromArray).isEqualTo(payload);
          assertThat(fromByteBuffer).isEqualTo(payload);
          assertThat(fromStream).isEqualTo(payload);
      }
  
      @Test
      public void createsStreamablesAndStreamableArraysFromSerializedData() throws Exception {
          TestStreamable value=new TestStreamable("streamable", 7);
  
          byte[] genericBuffer=Util.objectToByteBuffer(value);
          TestStreamable fromGenericBuffer=Util.objectFromByteBuffer(genericBuffer, 0, genericBuffer.length,
            UtilTest.class.getClassLoader());
  
          ByteArrayDataOutputStream singleOutput=new ByteArrayDataOutputStream(64, true);
          value.writeTo(singleOutput);
          TestStreamable fromArray=Util.streamableFromByteBuffer(TestStreamable.class, singleOutput.buffer(), 0,
            singleOutput.position());
          TestStreamable fromByteBuffer=Util.streamableFromByteBuffer(TestStreamable.class,
            ByteBuffer.wrap(singleOutput.buffer(), 0, singleOutput.position()));
  
          TestStreamable[] values={new TestStreamable("one", 1), new TestStreamable("two", 2)};
          ByteArrayDataOutputStream arrayOutput=new ByteArrayDataOutputStream(128, true);
          Util.write(values, arrayOutput);
          TestStreamable[] restored=Util.read(TestStreamable.class, new ByteArrayDataInputStream(arrayOutput.buffer(), 0,
            arrayOutput.position()));
  
          assertThat(fromGenericBuffer).isEqualTo(value);
          assertThat(fromArray).isEqualTo(value);
          assertThat(fromByteBuffer).isEqualTo(value);
          assertThat(restored).containsExactly(values);
      }
  
      @Test
      public void recreatesExceptionsUsingAvailableConstructors() throws Exception {
          ByteArray withMessageBuffer=Util.exceptionToBuffer(new MessageException("boom"));
          Throwable withMessage=Util.exceptionFromBuffer(withMessageBuffer.getArray(), withMessageBuffer.getOffset(),
            withMessageBuffer.getLength());
  
          ByteArray noMessageBuffer=Util.exceptionToBuffer(new NoMessageException());
          Throwable noMessage=Util.exceptionFromBuffer(noMessageBuffer.getArray(), noMessageBuffer.getOffset(),
            noMessageBuffer.getLength());
  
          assertThat(withMessage).isInstanceOf(MessageException.class).hasMessage("boom");
          assertThat(noMessage).isInstanceOf(NoMessageException.class);
      }
  
      @Test
      public void accessesFieldsMethodsArraysClassesAndCustomAddressSuppliers() throws Exception {
          ReflectiveTarget target=new ReflectiveTarget();
  
          Field secret=Util.getField(ReflectiveTarget.class, "secret", true);
          Util.setField(secret, target, "changed");
          Field discovered=Util.findField(target, Arrays.asList("missing", "secret"));
          Method setter=Util.findMethod(target, Arrays.asList("missing", "setValue"), String.class);
          Method computed=Util.findMethod(ReflectiveTarget.class, "computed");
          Method primitiveMethod=Util.findMethod(ReflectiveTarget.class, "setNumber", new Object[] {"5"});
          Method[] allMethods=Util.getAllMethods(ReflectiveTarget.class);
          Field[] propertyFields=Util.getAllDeclaredFieldsWithAnnotations(ReflectiveTarget.class, Property.class);
          Method[] propertyMethods=Util.getAllDeclaredMethodsWithAnnotations(ReflectiveTarget.class, Property.class);
          String[] combined=Util.combine(new String[] {"a"}, new String[] {"b", "c"});
          Class<?> loaded=Util.loadClass(CustomSerializable.class.getName(), UtilTest.class.getClassLoader());
          InetAddress supplied=Util.getAddressByCustomCode(AddressSupplier.class.getName());
  
          assertThat(Util.getField(secret, target)).isEqualTo("changed");
          assertThat(discovered).isEqualTo(secret);
          assertThat(setter.getName()).isEqualTo("setValue");
          assertThat(computed.getName()).isEqualTo("computed");
          assertThat(primitiveMethod.getName()).isEqualTo("setNumber");
          assertThat(allMethods).extracting(Method::getName).contains("computed", "inheritedMethod");
          assertThat(propertyFields).extracting(Field::getName).contains("secret", "parentProperty");
          assertThat(propertyMethods).extracting(Method::getName).contains("setValue");
          assertThat(combined).containsExactly("a", "b", "c");
          assertThat(loaded).isEqualTo(CustomSerializable.class);
          assertThat(supplied).isEqualTo(InetAddress.getLoopbackAddress());
          Util.fibersAvailable();
      }
  
      @Test
      public void discoversClassesAndResourcesThroughClassLoaders() throws Exception {
          ClassLoader originalContextLoader=Thread.currentThread().getContextClassLoader();
          ClassLoader resourceLoader=originalContextLoader != null? originalContextLoader : UtilTest.class.getClassLoader();
  
          Set<Class<?>> assignableClasses=Util.findClassesAssignableFromPath("org_jgroups/jgroups", Runnable.class,
            resourceLoader);
          List<Class<?>> annotatedClasses=Util.findClassesAnnotatedWith("org_jgroups.jgroups", Deprecated.class);
  
          try(InputStream ignored=Util.getResourceAsStream("jg-messages.properties", Util.class)) {
              assertThat(ignored).isNotNull();
          }
          try(InputStream ignored=Util.getResourceAsStream("jg-messages.properties", (ClassLoader)null)) {
              assertThat(ignored).isNotNull();
          }
          try {
              Thread.currentThread().setContextClassLoader(new EmptyClassLoader());
              InputStream systemResource=Util.getResourceAsStream("jg-messages.properties", (ClassLoader)null);
              Util.close(systemResource);
          }
          finally {
              Thread.currentThread().setContextClassLoader(originalContextLoader);
          }
  
          assertThat(assignableClasses).isNotNull();
          assertThat(annotatedClasses).isNotNull();
      }
  
      public static class CustomSerializable implements Serializable {
          private static final long serialVersionUID=1L;
  
          private String name;
          private int value;
  
          public CustomSerializable(String name, int value) {
              this.name=name;
              this.value=value;
          }
  
          @Override
          public boolean equals(Object other) {
              if(this == other)
                  return true;
              if(!(other instanceof CustomSerializable))
                  return false;
              CustomSerializable that=(CustomSerializable)other;
              return value == that.value && name.equals(that.name);
          }
  
          @Override
          public int hashCode() {
              int result=name.hashCode();
              result=31 * result + value;
              return result;
          }
      }
  
      public static class TestStreamable implements Streamable {
          private String name;
          private int value;
  
          public TestStreamable() {
          }
  
          public TestStreamable(String name, int value) {
              this.name=name;
              this.value=value;
          }
  
          @Override
          public void writeTo(DataOutput out) throws IOException {
              out.writeUTF(name);
              out.writeInt(value);
          }
  
          @Override
          public void readFrom(DataInput in) throws IOException {
              name=in.readUTF();
              value=in.readInt();
          }
  
          @Override
          public boolean equals(Object other) {
              if(this == other)
                  return true;
              if(!(other instanceof TestStreamable))
                  return false;
              TestStreamable that=(TestStreamable)other;
              return value == that.value && name.equals(that.name);
          }
  
          @Override
          public int hashCode() {
              int result=name.hashCode();
              result=31 * result + value;
              return result;
          }
      }
  
      public static class MessageException extends Exception {
          public MessageException(String message) {
              super(message);
          }
      }
  
      public static class NoMessageException extends Exception {
          public NoMessageException() {
          }
      }
  
      public static class AddressSupplier implements Supplier<InetAddress> {
          public AddressSupplier() {
          }
  
          @Override
          public InetAddress get() {
              return InetAddress.getLoopbackAddress();
          }
      }
  
      public static class ReflectiveParent {
          @Property
          private String parentProperty="parent";
  
          public String inheritedMethod() {
              return parentProperty;
          }
      }
  
      public static class ReflectiveTarget extends ReflectiveParent {
          @Property
          private String secret="initial";
  
          @Property
          public void setValue(String value) {
              secret=value;
          }
  
          public void setNumber(int ignored) {
          }
  
          public String computed() {
              return secret;
          }
      }
  
      public static class EmptyClassLoader extends ClassLoader {
          public EmptyClassLoader() {
              super(null);
          }
      }
  
      public static class RunnableCandidate implements Runnable {
          @Override
          public void run() {
          }
      }
  
      @Deprecated
      public static class AnnotatedResourceCandidate {
      }
  }
