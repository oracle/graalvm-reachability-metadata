[tool-call] delta {"path":"tests/src/org.jgroups/jgroups/5.2.0.Final/src/test/java/org_jgroups/jgroups/ProtocolStackTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_jgroups.jgroups;\n\nimport org.jgroups.JChannel;\nimport org.jgroups.annotations.Property;\nimport org.jgroups.conf.PropertyConverter;\nimport org.jgroups.stack.Protocol;\nimport org.jgroups.stack.ProtocolHook;\nimport org.jgroups.stack.ProtocolStack;\nimport org.jgroups.util.StackType;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ProtocolStackTest {\n    @Test\n    public void constructsWithChannelAndCreatesProtocolsByClassName() throws Exception {\n        ProtocolStack stack=new ProtocolStack((JChannel)null);\n        ExposedProtocolStack exposedStack=new ExposedProtocolStack();\n\n        Protocol created=exposedStack.newProtocol(CreatedProtocol.class);\n\n        assertThat(stack.getChannel()).isNull();\n        assertThat(created).isInstanceOf(CreatedProtocol.class);\n        assertThat(created.getProtocolStack()).isSameAs(exposedStack);\n    }\n\n    @Test\n    public void printsProtocolPropertiesFromAnnotatedFieldsAndSetters() {\n        PropertyPrintingProtocol protocol=new PropertyPrintingProtocol();\n        ProtocolStack stack=new ProtocolStack().addProtocol(protocol);\n\n        String spec=stack.printProtocolSpec(true);\n\n        assertThat(spec).contains(\"fieldProperty=converted:field-value\")\n          .contains(\"setterValue=converted:setter-value\");\n        assertThat(PropertyPrintingConverter.instancesCreated()).isGreaterThanOrEqualTo(2);\n    }\n\n    @Test\n    public void invokesConfiguredAfterCreationHookDuringInitialization() throws Exception {\n        HookedProtocolHook.reset();\n        HookedProtocol protocol=new HookedProtocol();\n        ProtocolStack stack=new ProtocolStack().addProtocol(protocol);\n\n        stack.initProtocolStack();\n\n        assertThat(HookedProtocolHook.invokedWith()).isSameAs(protocol);\n    }\n\n    public static class ExposedProtocolStack extends ProtocolStack {\n        public Protocol newProtocol(Class<? extends Protocol> protocolClass) throws Exception {\n            return createProtocol(protocolClass.getName());\n        }\n    }\n\n    public static class CreatedProtocol extends Protocol {\n        public CreatedProtocol() {\n        }\n    }\n\n    public static class PropertyPrintingProtocol extends Protocol {\n        @Property(converter=PropertyPrintingConverter.class)\n        private String fieldProperty=\"field-value\";\n\n        private String setterValue=\"setter-value\";\n\n        public PropertyPrintingProtocol() {\n        }\n\n        @Property(converter=PropertyPrintingConverter.class)\n        public void setSetterValue(String setterValue) {\n            this.setterValue=setterValue;\n        }\n    }\n\n    public static class PropertyPrintingConverter implements PropertyConverter {\n        private static int instancesCreated;\n\n        public PropertyPrintingConverter() {\n            instancesCreated++;\n        }\n\n        public static int instancesCreated() {\n            return instancesCreated;\n        }\n\n        @Override\n        public Object convert(Object obj, Class<?> propertyFieldType, String propertyName, String propertyValue,\n                              boolean checkScope, StackType ipVersion) {\n            return propertyValue;\n        }\n\n        @Override\n        public String toString(Object value) {\n            return \"converted:\" + value;\n        }\n    }\n\n    public static class HookedProtocol extends Protocol {\n        public HookedProtocol() {\n        }\n\n        @Override\n        public String afterCreationHook() {\n            return HookedProtocolHook.class.getName();\n        }\n    }\n\n    public static class HookedProtocolHook implements ProtocolHook {\n        private static Protocol invokedWith;\n\n        public HookedProtocolHook() {\n        }\n\n        public static void reset() {\n            invokedWith=null;\n        }\n\n        public static Protocol invokedWith() {\n            return invokedWith;\n        }\n\n        @Override\n        public void afterCreation(Protocol prot) {\n            invokedWith=prot;\n        }\n    }\n}\n"}
