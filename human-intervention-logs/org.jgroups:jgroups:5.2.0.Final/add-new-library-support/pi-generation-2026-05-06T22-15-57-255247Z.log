  package org_jgroups.jgroups;
  
  import org.jgroups.JChannel;
  import org.jgroups.annotations.Property;
  import org.jgroups.conf.PropertyConverter;
  import org.jgroups.protocols.DISCARD;
  import org.jgroups.stack.Protocol;
  import org.jgroups.stack.ProtocolHook;
  import org.jgroups.stack.ProtocolStack;
  import org.jgroups.util.StackType;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ProtocolStackTest {
      @Test
      public void constructsWithChannelAndCreatesProtocolsByClassName() throws Exception {
          ProtocolStack stack=new ProtocolStack((JChannel)null);
          ExposedProtocolStack exposedStack=new ExposedProtocolStack();
  
          Protocol created=exposedStack.newProtocol(DISCARD.class);
  
          assertThat(stack.getChannel()).isNull();
          assertThat(created).isInstanceOf(DISCARD.class);
          assertThat(created.getProtocolStack()).isSameAs(exposedStack);
      }
  
      @Test
      public void printsProtocolPropertiesFromAnnotatedFieldsAndSetters() {
          PropertyPrintingProtocol protocol=new PropertyPrintingProtocol();
          ProtocolStack stack=new ProtocolStack().addProtocol(protocol);
  
          String spec=stack.printProtocolSpec(true);
  
          assertThat(spec).contains("fieldProperty=converted:field-value")
            .contains("setter_value=converted:setter-value");
          assertThat(PropertyPrintingConverter.instancesCreated()).isGreaterThanOrEqualTo(2);
      }
  
      @Test
      public void invokesConfiguredAfterCreationHookDuringInitialization() throws Exception {
          HookedProtocolHook.reset();
          HookedProtocol protocol=new HookedProtocol();
          ProtocolStack stack=new ProtocolStack().addProtocol(protocol);
  
          stack.initProtocolStack();
  
          assertThat(HookedProtocolHook.invokedWith()).isSameAs(protocol);
      }
  
      public static class ExposedProtocolStack extends ProtocolStack {
          public Protocol newProtocol(Class<? extends Protocol> protocolClass) throws Exception {
              return createProtocol(protocolClass.getName());
          }
      }
  
      public static class PropertyPrintingProtocol extends Protocol {
          @Property(converter=PropertyPrintingConverter.class)
          private String fieldProperty="field-value";
  
          private String setter_value="setter-value";
  
          public PropertyPrintingProtocol() {
          }
  
          @Property(converter=PropertyPrintingConverter.class)
          public void setSetterValue(String setterValue) {
              this.setter_value=setterValue;
          }
      }
  
      public static class PropertyPrintingConverter implements PropertyConverter {
          private static int instancesCreated;
  
          public PropertyPrintingConverter() {
              instancesCreated++;
          }
  
          public static int instancesCreated() {
              return instancesCreated;
          }
  
          @Override
          public Object convert(Object obj, Class<?> propertyFieldType, String propertyName, String propertyValue,
                                boolean checkScope, StackType ipVersion) {
              return propertyValue;
          }
  
          @Override
          public String toString(Object value) {
              return "converted:" + value;
          }
      }
  
      public static class HookedProtocol extends Protocol {
          public HookedProtocol() {
          }
  
          @Override
          public String afterCreationHook() {
              return HookedProtocolHook.class.getName();
          }
      }
  
      public static class HookedProtocolHook implements ProtocolHook {
          private static Protocol invokedWith;
  
          public HookedProtocolHook() {
          }
  
          public static void reset() {
              invokedWith=null;
          }
  
          public static Protocol invokedWith() {
              return invokedWith;
          }
  
          @Override
          public void afterCreation(Protocol prot) {
              invokedWith=prot;
          }
      }
  }
