[tool-call] delta {"path":"tests/src/org.jgroups/jgroups/5.2.0.Final/src/test/java/org_jgroups/jgroups/TPTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_jgroups.jgroups;\n\nimport org.jgroups.Address;\nimport org.jgroups.Message;\nimport org.jgroups.MessageFactory;\nimport org.jgroups.PhysicalAddress;\nimport org.jgroups.View;\nimport org.jgroups.protocols.Bundler;\nimport org.jgroups.protocols.LocalTransport;\nimport org.jgroups.protocols.TP;\nimport org.jgroups.stack.MessageProcessingPolicy;\nimport org.jgroups.util.MessageBatch;\nimport org.junit.jupiter.api.Test;\n\nimport java.util.function.Supplier;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class TPTest {\n    @Test\n    public void initializesCustomComponentsConfiguredByClassName() throws Exception {\n        RecordingLocalTransport.resetState();\n        RecordingMessageProcessingPolicy.resetState();\n        RecordingMessageFactory.resetState();\n        RecordingBundler.resetState();\n        TestTransport transport=new TestTransport();\n        transport.setValue(\"local_transport_class\", RecordingLocalTransport.class.getName());\n        transport.setValue(\"message_processing_policy\", RecordingMessageProcessingPolicy.class.getName());\n        transport.setMsgFactoryClass(RecordingMessageFactory.class.getName());\n        transport.setBundlerType(RecordingBundler.class.getName());\n\n        try {\n            transport.init();\n\n            assertThat(transport.getLocalTransport()).isInstanceOf(RecordingLocalTransport.class);\n            assertThat(transport.getMessageFactory()).isInstanceOf(RecordingMessageFactory.class);\n            assertThat(transport.getBundler()).isInstanceOf(RecordingBundler.class);\n            assertThat(RecordingLocalTransport.instancesCreated()).isEqualTo(1);\n            assertThat(RecordingLocalTransport.initializedWith()).isSameAs(transport);\n            assertThat(RecordingMessageProcessingPolicy.instancesCreated()).isEqualTo(1);\n            assertThat(RecordingMessageProcessingPolicy.initializedWith()).isSameAs(transport);\n            assertThat(RecordingMessageFactory.instancesCreated()).isEqualTo(1);\n            assertThat(RecordingBundler.instancesCreated()).isEqualTo(1);\n            assertThat(RecordingBundler.initializedWith()).isSameAs(transport);\n        }\n        finally {\n            transport.destroy();\n        }\n    }\n\n    @Test\n    public void setsLocalTransportByClassName() throws Exception {\n        RecordingLocalTransport.resetState();\n        TestTransport transport=new TestTransport();\n\n        try {\n            transport.setLocalTransport(RecordingLocalTransport.class.getName());\n\n            assertThat(transport.getLocalTransport()).isInstanceOf(RecordingLocalTransport.class);\n            assertThat(RecordingLocalTransport.instancesCreated()).isEqualTo(1);\n            assertThat(RecordingLocalTransport.initializedWith()).isSameAs(transport);\n            assertThat(RecordingLocalTransport.starts()).isEqualTo(1);\n\n            transport.setLocalTransport(\"null\");\n\n            assertThat(transport.getLocalTransport()).isNull();\n            assertThat(RecordingLocalTransport.stops()).isEqualTo(1);\n            assertThat(RecordingLocalTransport.destroys()).isEqualTo(1);\n        }\n        finally {\n            transport.destroy();\n        }\n    }\n\n    public static class TestTransport extends TP {\n        public TestTransport() {\n            setTimeServiceInterval(0);\n            setLogicalAddrCacheReaperInterval(0);\n        }\n\n        @Override\n        public boolean supportsMulticasting() {\n            return false;\n        }\n\n        @Override\n        public void sendUnicast(PhysicalAddress dest, byte[] data, int offset, int length) {\n        }\n\n        @Override\n        public String getInfo() {\n            return \"test transport\";\n        }\n\n        @Override\n        protected PhysicalAddress getPhysicalAddress() {\n            return null;\n        }\n    }\n\n    public static class RecordingLocalTransport implements LocalTransport {\n        private static int instancesCreated;\n        private static int starts;\n        private static int stops;\n        private static int destroys;\n        private static TP initializedWith;\n\n        public RecordingLocalTransport() {\n            instancesCreated++;\n        }\n\n        public static void resetState() {\n            instancesCreated=0;\n            starts=0;\n            stops=0;\n            destroys=0;\n            initializedWith=null;\n        }\n\n        public static int instancesCreated() {\n            return instancesCreated;\n        }\n\n        public static int starts() {\n            return starts;\n        }\n\n        public static int stops() {\n            return stops;\n        }\n\n        public static int destroys() {\n            return destroys;\n        }\n\n        public static TP initializedWith() {\n            return initializedWith;\n        }\n\n        @Override\n        public LocalTransport init(TP transport) {\n            initializedWith=transport;\n            return this;\n        }\n\n        @Override\n        public LocalTransport start() {\n            starts++;\n            return this;\n        }\n\n        @Override\n        public LocalTransport stop() {\n            stops++;\n            return this;\n        }\n\n        @Override\n        public LocalTransport destroy() {\n            destroys++;\n            return this;\n        }\n\n        @Override\n        public LocalTransport resetStats() {\n            return this;\n        }\n\n        @Override\n        public LocalTransport viewChange(View view) {\n            return this;\n        }\n\n        @Override\n        public boolean isLocalMember(Address addr) {\n            return false;\n        }\n\n        @Override\n        public void sendTo(Address dest, byte[] buf, int offset, int length) {\n        }\n\n        @Override\n        public void sendToAll(byte[] buf, int offset, int length) {\n        }\n    }\n\n    public static class RecordingMessageProcessingPolicy implements MessageProcessingPolicy {\n        private static int instancesCreated;\n        private static TP initializedWith;\n\n        public RecordingMessageProcessingPolicy() {\n            instancesCreated++;\n        }\n\n        public static void resetState() {\n            instancesCreated=0;\n            initializedWith=null;\n        }\n\n        public static int instancesCreated() {\n            return instancesCreated;\n        }\n\n        public static TP initializedWith() {\n            return initializedWith;\n        }\n\n        @Override\n        public void init(TP transport) {\n            initializedWith=transport;\n        }\n\n        @Override\n        public boolean loopback(Message msg, boolean oob) {\n            return false;\n        }\n\n        @Override\n        public boolean process(Message msg, boolean oob) {\n            return false;\n        }\n\n        @Override\n        public boolean process(MessageBatch batch, boolean oob) {\n            return false;\n        }\n    }\n\n    public static class RecordingMessageFactory implements MessageFactory {\n        private static int instancesCreated;\n\n        public RecordingMessageFactory() {\n            instancesCreated++;\n        }\n\n        public static void resetState() {\n            instancesCreated=0;\n        }\n\n        public static int instancesCreated() {\n            return instancesCreated;\n        }\n\n        @Override\n        public <T extends Message> T create(short id) {\n            return null;\n        }\n\n        @Override\n        @SuppressWarnings(\"unchecked\")\n        public <M extends MessageFactory> M register(short type, Supplier<? extends Message> generator) {\n            return (M)this;\n        }\n    }\n\n    public static class RecordingBundler implements Bundler {\n        private static int instancesCreated;\n        private static int starts;\n        private static int stops;\n        private static TP initializedWith;\n\n        public RecordingBundler() {\n            instancesCreated++;\n        }\n\n        public static void resetState() {\n            instancesCreated=0;\n            starts=0;\n            stops=0;\n            initializedWith=null;\n        }\n\n        public static int instancesCreated() {\n            return instancesCreated;\n        }\n\n        public static TP initializedWith() {\n            return initializedWith;\n        }\n\n        @Override\n        public void init(TP transport) {\n            initializedWith=transport;\n        }\n\n        @Override\n        public void start() {\n            starts++;\n        }\n\n        @Override\n        public void stop() {\n            stops++;\n        }\n\n        @Override\n        public void send(Message msg) {\n        }\n\n        @Override\n        public int size() {\n            return 0;\n        }\n\n        @Override\n        public int getQueueSize() {\n            return -1;\n        }\n\n        @Override\n        public int getMaxSize() {\n            return 0;\n        }\n    }\n}\n"}
