 }\n\n    public static class CustomSerializable implements Serializable {\n        private static final long serialVersionUID=1L;\n\n        private String name;\n        private int value;\n\n        public CustomSerializable(String name, int value) {\n            this.name=name;\n            this.value=value;\n        }\n\n        @Override\n        public boolean equals(Object other) {\n            if(this == other)\n                return true;\n            if(!(other instanceof CustomSerializable))\n                return false;\n            CustomSerializable that=(CustomSerializable)other;\n            return value == that.value && name.equals(that.name);\n        }\n\n        @Override\n        public int hashCode() {\n            int result=name.hashCode();\n            result=31 * result + value;\n            return result;\n        }\n    }\n\n    public static class TestStreamable implements Streamable {\n        private String name;\n        private int value;\n\n        public TestStreamable() {\n        }\n\n        public TestStreamable(String name, int value) {\n            this.name=name;\n            this.value=value;\n        }\n\n        @Override\n        public void writeTo(DataOutput out) throws IOException {\n            out.writeUTF(name);\n            out.writeInt(value);\n        }\n\n        @Override\n        public void readFrom(DataInput in) throws IOException {\n            name=in.readUTF();\n            value=in.readInt();\n        }\n\n        @Override\n        public boolean equals(Object other) {\n            if(this == other)\n                return true;\n            if(!(other instanceof TestStreamable))\n                return false;\n            TestStreamable that=(TestStreamable)other;\n            return value == that.value && name.equals(that.name);\n        }\n\n        @Override\n        public int hashCode() {\n            int result=name.hashCode();\n            result=31 * result + value;\n            return result;\n        }\n    }\n\n    public static class MessageException extends Exception {\n        public MessageException(String message) {\n            super(message);\n        }\n    }\n\n    public static class NoMessageException extends Exception {\n        public NoMessageException() {\n        }\n    }\n\n    public static class AddressSupplier implements Supplier<InetAddress> {\n        public AddressSupplier() {\n        }\n\n        @Override\n        public InetAddress get() {\n            return InetAddress.getLoopbackAddress();\n        }\n    }\n\n    public static class ReflectiveParent {\n        @Property\n        private String parentProperty=\"parent\";\n\n        public String inheritedMethod() {\n            return parentProperty;\n        }\n    }\n\n    public static class ReflectiveTarget extends ReflectiveParent {\n        @Property\n        private String secret=\"initial\";\n\n        @Property\n        public void setValue(String value) {\n\n[28 more lines in file. Use offset=261 to continue.]"}], "isError": false, "timestamp": 1778104780296}}
