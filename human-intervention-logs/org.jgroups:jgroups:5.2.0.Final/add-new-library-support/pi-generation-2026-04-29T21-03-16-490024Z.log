          if(time_service_interval > 0)
              time_service=new TimeService(timer, time_service_interval);
  
          Map<String, Object> m=new HashMap<>(2);
          if(bind_addr != null)
              m.put("bind_addr", bind_addr);
          if(external_addr != null)
              m.put("external_addr", external_addr);
          if(external_port > 0)
