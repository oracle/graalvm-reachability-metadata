isEmpty();\n    }\n\n    @Test\n    public void invokesAnnotatedPropertyMethodsFromPublicMethodScan() throws Exception {\n        MethodPropertiesTarget target=new MethodPropertiesTarget();\n        Map<String,String> properties=new HashMap<>();\n        properties.put(\"method_value\", \"configured-by-method\");\n\n        Configurator.resolveAndInvokePropertyMethods(target, properties, StackType.IPv4);\n\n        assertThat(target.methodValue()).isEqualTo(\"configured-by-method\");\n        assertThat(properties).isEmpty();\n    }\n\n    @Test\n    public void assignsAnnotatedFieldsFromDeclaredFieldScan() throws Exception {\n        FieldPropertiesTarget target=new FieldPropertiesTarget();\n        Map<String,String> properties=new HashMap<>();\n        properties.put(\"field_value\", \"configured-by-field\");\n\n        Configurator.resolveAndAssignFields(target, properties, StackType.IPv4);\n\n        assertThat(target.fieldValue()).isEqualTo(\"configured-by-field\");\n        assertThat(properties).isEmpty();\n    }\n\n    @Test\n    public void discoversInetAddressFieldsOnProtocols() throws Exception {\n        InetAddress loopback=InetAddress.getLoopbackAddress();\n        AddressFieldProtocol protocol=new AddressFieldProtocol(loopback);\n\n        List<InetAddress> addresses=Configurator.getInetAddresses(Collections.singletonList(protocol));\n\n        assertThat(addresses).contains(loopback);\n    }\n\n    @Test\n    public void appliesDefaultInetAddressThroughAnnotatedSetter() throws Exception {\n        DefaultAddressMethodTarget target=new DefaultAddressMethodTarget();\n\n        Configurator.setDefaultAddressValues(target, StackType.IPv4);\n\n        assertThat(target.bindAddr()).isEqualTo(InetAddress.getByName(\"127.0.0.1\"));\n    }\n\n    @Test\n    public void createsProtocolsAndInitializesAttributesFromConfigurations() throws Exception {\n        ProtocolConfiguration configuration=new ProtocolConfiguration(DISCARD.class.getName() + \"(discard_all=true)\");\n\n        List<Protocol> protocols=Configurator.createProtocolsAndInitializeAttrs(\n          Collections.singletonList(configuration), new ProtocolStack());\n\n        assertThat(protocols).hasSize(1);\n        assertThat(protocols.get(0)).isInstanceOf(DISCARD.class);\n        assertThat(((DISCARD)protocols.get(0)).discardAll()).isTrue();\n    }\n\n    public static class DependentPropertiesTarget {\n        @Property\n        private String base_value;\n\n        private String dependent_value;\n\n        public String baseValue() {\n            return base_value;\n        }\n\n        public String dependentValue() {\n            return dependent_value;\n        }\n\n        @Property(name=\"dependent_value\", dependsUpon=\"base_value\")\n        public void setDependentValue(String dependentValue) {\n            dependent_value=base_value + \":\" + dependentValue;\n        }\n    }\n\n    public static class MethodPropertiesTarget {\n        private String method_value;\n\n        public String methodValue() {\n            return method_value;\n        }\n\n        @Property(name=\"method_value\")\n        public void setMethodValue(String methodValue) {\n            method_value=methodValue;\n        }\n    }\n\n    public static class FieldPropertiesTarget {\n        @Property\n        private String field_value;\n\n        public String fieldValue() {\n            return field_value;\n        }\n    }\n\n    public static class AddressFieldProtocol extends Protocol {\n        @Property\n        private InetAddress bind_addr;\n\n        public AddressFieldProtocol(InetAddress bindAddr) {\n            bind_addr=bindAddr;\n        }\n    }\n\n    public static class DefaultAddressMethodTarget {\n        private InetAddress bind_addr;\n\n        public InetAddress bindAddr() {\n            return bind_addr;\n        }\n\n        @Property(name=\"bind_addr\", defaultValueIPv4=\"127.0.0.1\")\n        public void setBindAddr(InetAddress bindAddr) {\n            bind_addr=bindAddr;\n        }\n    }\n}\n","exit_code":0,"status":"completed"}}
