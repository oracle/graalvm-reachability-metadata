      private synchronized T computeValue() {
          final Supplier<? extends T> s = supplier;
          if (s != null) {
              value = s.get();
              supplier = null;
          }
          return value;
      }
  
      @Override
      public boolean isEmpty() {
          return false;
      }
  
      /**
