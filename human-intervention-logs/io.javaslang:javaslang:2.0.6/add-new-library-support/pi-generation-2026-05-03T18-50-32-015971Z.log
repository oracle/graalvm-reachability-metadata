  package io_javaslang.javaslang;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.IOException;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.io.Serializable;
  
  import org.junit.jupiter.api.Test;
  
  import javaslang.collection.HashSet;
  
  public class HashSetInnerSerializationProxyTest {
      @Test
      public void serializesAndDeserializesNonEmptyHashSetThroughSerializationProxy() throws Exception {
          final HashSet<String> hashSet = HashSet.of("alpha", "beta", "gamma", "alpha");
  
          final Object restored = deserialize(serialize(hashSet));
  
          assertThat(restored).isInstanceOf(HashSet.class);
          assertThat(restored).isEqualTo(HashSet.of("alpha", "beta", "gamma"));
          @SuppressWarnings("unchecked")
          final HashSet<String> restoredHashSet = (HashSet<String>) restored;
          assertThat(restoredHashSet.size()).isEqualTo(3);
          assertThat(restoredHashSet.contains("alpha")).isTrue();
          assertThat(restoredHashSet.contains("beta")).isTrue();
          assertThat(restoredHashSet.contains("gamma")).isTrue();
      }
  
