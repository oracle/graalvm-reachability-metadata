    * @param providers provider classes used during request processing.\n     */\n    public DefaultClientConfig(Class<?>... providers) {\n        Collections.addAll(this.providers, providers);\n    }\n\n    /**\n     * Create a new DefaultClientConfig instance\n     *\n     * @param providers set of provider classes used during request processing.\n     */\n    public DefaultClientConfig(Set<Class<?>> providers) {\n       this.providers.addAll(providers);\n    }\n\n    /**\n     * {@inheritDoc}\n     */\n    @Override\n    public Set<Class<?>> getClasses() {\n        return providers;\n    }\n\n    /**\n     * {@inheritDoc}\n     */\n    @Override\n    public Set<Object> getSingletons() {\n        return providerInstances;\n    }\n\n    /**\n     * {@inheritDoc}\n     */\n    @Override\n    public Map<String, Boolean> getFeatures() {\n        return features;\n    }\n\n    /**\n     * {@inheritDoc}\n     */\n    @Override\n    public boolean getFeature(String featureName) {\n        final Boolean v = features.get(featureName);\n        return (v != null) ? v : false;\n    }\n    \n    /**\n     * {@inheritDoc}\n     */\n    @Override\n    public Map<String, Object> getProperties() {\n        return properties;\n    }\n\n    /**\n     * {@inheritDoc}\n     */\n    @Override\n    public Object getProperty(String propertyName) {\n        return properties.get(propertyName);\n    }\n\n    /**\n     * {@inheritDoc}\n     */\n    @Override\n    public boolean getPropertyAsFeature(String name) {\n        Boolean v = (Boolean)getProperties().get(name);\n        return (v != null) ? v : false;\n    }\n}"}], "isError": false, "timestamp": 1782659671857}, {"role": "toolResult", "toolCallId": "call_WagsBV6SaLNTAa2LYB3hXS6y|fc_0808f0dbf58bcdd6016a413a5776a881939145c417da4258eb", "toolName": "bash", "content": [{"type": "text", "text": "/home/vjovanov/c/forge/forge4/graalvm-reachability-metadata/forge/local_repositories/source_context/com.sun.jersey/jersey-client/1.9/main/extrac