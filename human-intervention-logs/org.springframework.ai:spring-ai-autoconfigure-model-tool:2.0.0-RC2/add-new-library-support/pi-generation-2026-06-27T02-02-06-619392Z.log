  			List<Media> media) {
  		super(MessageType.ASSISTANT, content, properties);
  		Assert.notNull(toolCalls, "Tool calls must not be null");
  		Assert.notNull(media, "Media must not be null");
  		this.toolCalls = toolCalls;
  		this.media = media;
