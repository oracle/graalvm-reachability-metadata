c/org.eclipse.jdt.core.compiler/ecj/4.4.2/src/test/java/org_eclipse_jdt_core_compiler/ecj/BatchAnnotationProcessorManagerTest.java\n./tests/src/org.eclipse.jdt.core.compiler/ecj/4.4.2/src/test/java/org_eclipse_jdt_core_compiler/ecj/ScannerHelperTest.java\n./tests/src/org.eclipse.jdt.core.compiler/ecj/4.4.2/src/test/java/org_eclipse_jdt_core_compiler/ecj/ProblemReferenceBindingTest.java\n./tests/src/com.beust/jcommander/1.81/src/test/resources/com_beust/jcommander/parameter_descriptions.properties\n./tests/src/com.beust/jcommander/1.75/src/test/java/com_beust/jcommander/defaultprovider/PropertyFileDefaultProviderTest.java\n./tests/src/com.beust/jcommander/1.81/src/test/java/com_beust/jcommander/defaultprovider/PropertyFileDefaultProviderTest.java\n./tests/src/com.beust/jcommander/1.75/src/test/resources/com_beust/jcommander/parameter_descriptions.properties\n","exit_code":0,"status":"completed"}}
