urrentKeyVersion(keyName);\n\n            assertThat(keyProvider.getKind()).isSameAs(KeyProviderKind.HADOOP);\n            assertThat(keyProvider.getKeyNames()).contains(keyName);\n            assertThat(currentKey.getKeyName()).isEqualTo(keyName);\n            assertThat(currentKey.getVersion()).isZero();\n            assertThat(currentKey.getAlgorithm()).isSameAs(EncryptionAlgorithm.AES_CTR_128);\n        } finally {\n            hadoopProvider.deleteKey(keyName);\n            hadoopProvider.close();\n        }\n    }\n\n    @Test\n    void shimsExposeCompressionTypesAndEndBlockSupport() throws Exception {"}]}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 774, "output": 1441, "cacheRead": 26112, "cacheWrite": 0, "totalTokens": 28327, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778277291254, "responseId": "resp_023c2f98684b946e0169fe5babbef88194a03463e8234def27"}}
