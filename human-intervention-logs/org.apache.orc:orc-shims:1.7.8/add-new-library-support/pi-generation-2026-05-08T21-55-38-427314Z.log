[tool-call] delta {"path":"tests/src/org.apache.orc/orc-shims/1.7.8/src/test/java/org_apache_orc/orc_shims/Orc_shimsTest.java","edits":[{"oldText":"import static org.assertj.core.api.Assertions.assertThatIllegalArgumentException;\n\nimport java.io.ByteArrayOutputStream;","newText":"import static org.assertj.core.api.Assertions.assertThatIllegalArgumentException;\nimport static org.apache.hadoop.crypto.key.KeyProvider.DEFAULT_CIPHER;\n\nimport java.io.ByteArrayOutputStream;"},{"oldText":"import java.util.Arrays;\nimport java.util.Random;","newText":"import java.util.Arrays;\nimport java.util.Random;\nimport java.util.UUID;"},{"oldText":"import javax.crypto.spec.SecretKeySpec;\nimport org.apache.orc.EncryptionAlgorithm;","newText":"import javax.crypto.spec.SecretKeySpec;\nimport org.apache.hadoop.conf.Configuration;\nimport org.apache.hadoop.crypto.key.KeyProvider.Options;\nimport org.apache.hadoop.crypto.key.KeyProviderFactory;\nimport org.apache.orc.EncryptionAlgorithm;"},{"oldText":"    @Test\n    void shimsExposeCompressionTypesAndEndBlockSupport() throws Exception {","newText":"    @Test\n    void hadoopShimReadsKeyMetadataFromConfiguredKeyProvider() throws Exception {\n        Configuration configuration = new Configuration(false);\n        configuration.set(KeyProviderFactory.KEY_PROVIDER_PATH, \"user:///\");\n        org.apache.hadoop.crypto.key.KeyProvider hadoopProvider = KeyProviderFactory.get(configuration);\n        String keyName = \"orc-shims-test-key-\" + UUID.randomUUID();\n\n        try {\n            Options options = org.apache.hadoop.crypto.key.KeyProvider.options(configuration)\n                    .setCipher(DEFAULT_CIPHER)\n                    .setBitLength(EncryptionAlgorithm.AES_CTR_128.keyLength() * Byte.SIZE);\n            hadoopProvider.createKey(\n                    keyName,\n                    repeatByte(EncryptionAlgorithm.AES_CTR_128.keyLength(), (byte) 5),\n                    options);\n            hadoopProvider.flush();\n\n            KeyProvider keyProvider = new HadoopShimsPre2_7().getHadoopKeyProvider(configuration, new Random(0));\n            KeyMetadata currentKey = keyProvider.getCurrentKeyVersion(keyName);\n\n            assertThat(keyProvider.getKind()).isSameAs(KeyProviderKind.HADOOP);\n            assertThat(keyProvider.getKeyNames()).contains(keyName);\n            assertThat(currentKey.getKeyName()).isEqualTo(keyName);\n            assertThat(currentKey.getVersion()).isZero();\n            assertThat(currentKey.getAlgorithm()).isSameAs(EncryptionAlgorithm.AES_CTR_128);\n        } finally {\n            hadoopProvider.deleteKey(keyName);\n            hadoopProvider.close();\n        }\n    }\n\n    @Test\n    void shimsExposeCompressionTypesAndEndBlockSupport() throws Exception {"}]}
