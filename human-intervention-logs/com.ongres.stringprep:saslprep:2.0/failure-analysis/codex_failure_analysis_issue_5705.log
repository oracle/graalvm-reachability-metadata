ep, C.9]\\n        Option.CHECK_BIDI); // Bidirectional Characters\\n  }\\n\\n  /**\\n   * {@inheritDoc}\\n   */\\n  @Override\\n  public String prepareQuery(String string) {\\n    return Profile.super.prepareQuery(string);\\n  }\\n\\n  /**\\n   * {@inheritDoc}\\n   */\\n  @Override\\n  public String prepareStored(String string) {\\n    return Profile.super.prepareStored(string);\\n  }\\n\\n  /**\\n   * Non-ASCII space characters that can be mapped to SPACE (U+0020).\\n   */\\n  @Override\\n  public int[] additionalMappingTable(int codePoint) {\\n    // - non-ASCII space characters [StringPrep, C.1.2] that can be\\n    // mapped to SPACE (U+0020)\\n    return Tables.prohibitionNonAsciiSpace(codePoint)\\n        ? new int[] {0x0020}\\n        : new int[] {codePoint};\\n  }\\n\\n}\\n\"}], \"isError\": false, \"timestamp\": 1777892539274}]}\n765:[tool-call] delta {\"path\":\"tests/src/com.ongres.stringprep/saslprep/2.0/src/test/java/com_ongres_stringprep/saslprep/SaslprepTest.java\",\"edits\":[{\"oldText\":\"import com.ongres.saslprep.SaslPrep;\\n\",\"newText\":\"import com.ongres.saslprep.SASLprep;\\n\"},{\"oldText\":\"public class SaslprepTest {\\n\",\"newText\":\"public class SaslprepTest {\\n    private static final SASLprep SASL_PREP = new SASLprep();\\n\\n\"},{\"oldText\":\"SaslPrep.saslPrep(\\\"I\\\\u00ADX\\\", true)\",\"newText\":\"prepareStored(\\\"I\\\\u00ADX\\\")\"},{\"oldText\":\"SaslPrep.saslPrep(\\\"user\\\", true)\",\"newText\":\"prepareStored(\\\"user\\\")\"},{\"oldText\":\"SaslPrep.saslPrep(\\\"USER\\\", true)\",\"newText\":\"prepareStored(\\\"USER\\\")\"},{\"oldText\":\"SaslPrep.saslPrep(\\\"\\\\u00AA\\\", true)\",\"newText\":\"prepareStored(\\\"\\\\u00AA\\\")\"},{\"oldText\":\"SaslPrep.saslPrep(\\\"\\\\u2168\\\", true)\",\"newText\":\"prepareStored(\\\"\\\\u2168\\\")\"},{\"oldText\":\"SaslPrep.saslPrep(\\\"\\\\uD840\\\\uDC00\\\", true)\",\"newText\":\"prepareStored(\\\"\\\\uD840\\\\uDC00\\\")\"},{\"oldText\":\"SaslPrep.saslPrep(\\\"pass\\\\u00AD\\\\u