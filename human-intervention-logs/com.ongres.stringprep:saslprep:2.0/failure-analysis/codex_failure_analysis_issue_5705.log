tringPrep, C.5]\\n        Option.FORBID_INAPPROPRIATE_FOR_PLAIN_TEXT, // [StringPrep, C.6]\\n        Option.FORBID_INAPPROPRIATE_FOR_CANON_REP, // [StringPrep, C.7]\\n        Option.FORBID_CHANGE_DISPLAY_AND_DEPRECATED, // [StringPrep, C.8]\\n        Option.FORBID_TAGGING, // [StringPrep, C.9]\\n        Option.CHECK_BIDI); // Bidirectional Characters\\n  }\\n\\n  /**\\n   * {@inheritDoc}\\n   */\\n  @Override\\n  public String prepareQuery(String string) {\\n    return Profile.super.prepareQuery(string);\\n  }\\n\\n  /**\\n   * {@inheritDoc}\\n   */\\n  @Override\\n  public String prepareStored(String string) {\\n    return Profile.super.prepareStored(string);\\n  }\\n\\n  /**\\n   * Non-ASCII space characters that can be mapped to SPACE (U+0020).\\n   */\\n  @Override\\n  public int[] additionalMappingTable(int codePoint) {\\n    // - non-ASCII space characters [StringPrep, C.1.2] that can be\\n    // mapped to SPACE (U+0020)\\n    return Tables.prohibitionNonAsciiSpace(codePoint)\\n        ? new int[] {0x0020}\\n        : new int[] {codePoint};\\n  }\\n\\n}\\n\"}], \"isError\": false, \"timestamp\": 1777891593754}}\n794:[recv] {\"type\": \"turn_end\", \"message\": {\"role\": \"assistant\", \"content\": [{\"type\": \"thinking\", \"thinking\": \"\", \"thinkingSignature\": \"{\\\"id\\\":\\\"rs_0c55b89e53cf71350169f8790890e081a0af9cbc40d2389318\\\",\\\"type\\\":\\\"reasoning\\\",\\\"encrypted_content\\\":\\\"gAAAAABp-HkJHQDP1sb9EIQEgxTgo7Y15g4RBJNWo23XMZqnHg5M7YxWegGRr_Bew2pptelTlqGk2bPTJHG36Wvd0DIy6LnbsGJU_4298Fuzt0HfXgCs6bSXXkmy8vkQtz-uZEM1Bj89bZJhssW7swcIknMBynAOo4LkNQO-4hvkqrLfZxdIALm70XtNLJNRdF1IhvK3T5A6PBVaBX0pkqLXDXxnEeQxHgxW5ENOSej-s-V14Cpjc3Drth8BCpGEDSI6UwoOq1ehtr-tZL-ZYkbxJV7qSTSAboEa8DZCKP-JHysJonO2lS3_WZ3iMOt1gUubz3T2iaARChZA7uB1aJstCse9bgBYiHDgQD0WqseymtaU24dbxvM4cFzv2WhoUAzfTANQyfJzXWDmBB85YtxlSYgr89az503Zdoy8_ODcSvnNCrgMr__hL8vZ7byrqf84zvk_UZwUMsc933wxhNHlyCpRAT_H5L01ljtYVmYV3SWvTeGnmoGXTVPuDFjdKrEpblCSH5I5A_tsZbtPPAxG-me6u6PK-t-Y5maEbwEU9lzB38K0MGSmuM