0627\\\", true))\\n                .isInstanceOf(IllegalArgumentException.class)\\n                .hasMessageContaining(\\\"RandALCat character is not the first and the last characters\\\");\\n    }\\n\\n    @Test\\n    void appliesBidirectionalRuleAfterCompatibilityNormalization() {\\n        assertThat(saslPrep(\\\"\\\\u0627\\\\uFF11\\\\u0628\\\", true)).isEqualTo(\\\"\\\\u06271\\\\u0628\\\");\\n\\n        assertThatThrownBy(() -> saslPrep(\\\"\\\\u0627\\\\uFF21\\\\u0628\\\", true))\\n                .isInstanceOf(IllegalArgumentException.class)\\n                .hasMessageContaining(\\\"RandALCat and LCat\\\");\\n    }\\n\\n    @Test\\n    void rejectsNullInput() {\\n        assertThatNullPointerException().isThrownBy(() -> saslPrep(null, true));\\n    }\\n\\n    private static void assertProhibited(String description, String value) {\\n        assertThatThrownBy(() -> saslPrep(value, true))\\n                .as(description)\\n                .isInstanceOf(IllegalArgumentException.class)\\n                .hasMessageContaining(\\\"Prohibited character\\\");\\n    }\\n\\n    private static String saslPrep(String value, boolean storedString) {\\n        return storedString ? SASL_PREP.prepareStored(value) : SASL_PREP.prepareQuery(value);\\n    }\\n}\\n\"}], \"isError\": false, \"timestamp\": 1777950860100}]}\n1444:[tool-call] delta {\"path\":\"tests/src/com.ongres.stringprep/saslprep/2.0/src/test/java/com_ongres_stringprep/saslprep/SaslprepTest.java\",\"edits\":[{\"oldText\":\"        assertThatThrownBy(() -> saslPrep(stringWithUnassignedCodePoint, true))\\n                .isInstanceOf(IllegalArgumentException.class)\\n                .hasMessageContaining(\\\"Prohibited character\\\")\\n                .hasMessageContaining(\\\"\\\\u0221\\\");\",\"newText\":\"        assertThatThrownBy(() -> saslPrep(stringWithUnassignedCodePoint, true))\\n                .isInstanceOf(IllegalArgumentException.class)\\n                .hasMessageContaining(\\\"Unassigned code 