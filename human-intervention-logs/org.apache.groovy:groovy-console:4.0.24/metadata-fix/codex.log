{"type":"item.completed","item":{"id":"item_152","type":"command_execution","command":"/usr/bin/bash -lc \"nl -ba tests/src/org.apache.groovy/groovy-console/4.0.24/src/test/groovy/org_apache_groovy/groovy_console/Groovy_consoleTest.groovy | sed -n '1,340p'\"","aggregated_output":"     1\t/*\n     2\t * Copyright and related rights waived via CC0\n     3\t *\n     4\t * You should have received a copy of the CC0 legalcode along with this\n     5\t * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n     6\t */\n     7\tpackage org_apache_groovy.groovy_console\n     8\t\n     9\timport groovy.console.TextNode\n    10\timport groovy.console.TextTreeNodeMaker\n    11\timport groovy.console.ui.AstNodeToScriptAdapter\n    12\timport groovy.console.ui.CompilePhaseAdapter\n    13\timport groovy.console.ui.HistoryRecord\n    14\timport groovy.console.ui.OutputTransforms\n    15\timport groovy.console.ui.ScriptToTreeNodeAdapter\n    16\timport groovy.console.ui.SystemOutputInterceptor\n    17\timport groovy.console.ui.TreeNodeWithProperties\n    18\timport groovy.console.ui.text.GroovyFilter\n    19\timport groovy.console.ui.text.MatchingHighlighter\n    20\timport groovy.console.ui.text.SmartDocumentFilter\n    21\timport groovy.console.ui.text.TextEditor\n    22\timport org.codehaus.groovy.control.CompilePhase\n    23\timport org.graalvm.internal.tck.NativeImageSupport\n    24\timport org.junit.jupiter.api.Test\n    25\t\n    26\timport javax.swing.ImageIcon\n    27\timport javax.swing.JTextPane\n    28\timport javax.swing.SwingUtilities\n    29\timport javax.swing.text.AbstractDocument\n    30\timport javax.swing.text.AttributeSet\n    31\timport javax.swing.text.DefaultStyledDocument\n    32\timport javax.swing.text.StyleConstants\n    33\timport java.awt.Color\n    34\timport java.awt.image.BufferedImage\n    35\timport java.nio.file.Files\n    36\timport java.nio.file.Path\n    37\timport java.util.concurrent.CountDownLatch\n    38\timport java.util.concurrent.TimeUnit\n    39\timport static org.assertj.core.api.Assertions.assertThat\n    40\t\n    41\tpublic class Groovy_consoleTest {\n    42\t    @Test\n    43\t    void createsPlainTextNodesHistoryRecordsAndCompilePhaseNavigation() {\n    44\t        TextTreeNodeMaker maker = new TextTreeNodeMaker()\n    45\t        TextNode root = maker.makeNode('root')\n    46\t        List<List<?>> propertyTable = [['name', 'demo', 'String', 'demo']]\n    47\t        TextNode child = maker.makeNodeWithProperties(null, propertyTable)\n    48\t\n    49\t        child.parent = root\n    50\t        root.add(child)\n    51\t\n    52\t        assertThat(root.toString()).isEqualTo('root')\n    53\t        assertThat(child.toString()).isEqualTo('null')\n    54\t        assertThat(child.parent).isSameAs(root)\n    55\t        assertThat(root.children).containsExactly(child)\n    56\t        assertThat(child.properties).containsExactlyElementsOf(propertyTable)\n    57\t\n    58\t        TreeNodeWithProperties astNode = new TreeNodeWithProperties('ClassNode - Demo', [\n    59\t                ['class', 'class org.codehaus.groovy.ast.ClassNode', 'Class', Object],\n    60\t                ['name', 'Demo', 'String', 'Demo']\n    61\t        ])\n    62\t        assertThat(astNode.getPropertyValue('name')).isEqualTo('Demo')\n    63\t        assertThat(astNode.getPropertyValue('missing')).isNull()\n    64\t        assertThat(astNode.classNode).isTrue()\n    65\t        assertThat(astNode.methodNode).isFalse()\n    66\t\n    67\t        String script = '''import java.time.LocalDate\n    68\t\n    69\tprintln 'before'\n    70\tprintln LocalDate.now()\n    71\tprintln 'after'\n    72\t'''\n    73\t        int selectionStart = script.indexOf(\"println LocalDate\")\n    74\t        int selectionEnd = selectionStart + \"println LocalDate.now()\".length()\n    75\t        HistoryRecord selectedRecord = new HistoryRecord(\n    76\t                allText: script,\n    77\t                selectionStart: selectionStart,\n    78\t                selectionEnd: selectionEnd,\n    79\t                result: 42)\n    80\t\n    81\t        assertThat(selectedRecord.getTextToRun(true))\n    82\t                .isEqualTo('import java.time.LocalDate\\nprintln LocalDate.now()')\n    83\t        assertThat(selectedRecord.getTextToRun(false)).isEqualTo(script)\n    84\t        assertThat(selectedRecord.value).isEqualTo(42)\n    85\t\n    86\t        IllegalStateException failure = new IllegalStateException('boom')\n    87\t        HistoryRecord failedRecord = new HistoryRecord(allText: '1 / 0', result: 'ignored', exception: failure)\n    88\t        assertThat(failedRecord.value).isSameAs(failure)\n    89\t\n    90\t        assertThat(CompilePhaseAdapter.PARSING.next()).isEqualTo(CompilePhaseAdapter.CONVERSION)\n    91\t        assertThat(CompilePhaseAdapter.CONVERSION.previous()).isEqualTo(CompilePhaseAdapter.PARSING)\n    92\t        assertThat(CompilePhaseAdapter.PARSING.phaseId).isEqualTo(CompilePhase.PARSING.phaseNumber)\n    93\t        assertThat(CompilePhaseAdapter.PARSING.toString()).containsIgnoringCase('parsing')\n    94\t    }\n    95\t\n    96\t    @Test\n    97\t    void buildsTextTreeForGroovySourceAst() {\n    98\t        try {\n    99\t            TextTreeNodeMaker maker = new TextTreeNodeMaker()\n   100\t            ScriptToTreeNodeAdapter adapter = new ScriptToTreeNodeAdapter(\n   101\t                    new GroovyClassLoader(getClass().classLoader),\n   102\t                    true,\n   103\t                    true,\n   104\t                    true,\n   105\t                    maker)\n   106\t            String source = '''import java.util.concurrent.atomic.AtomicInteger\n   107\t\n   108\tclass Greeter {\n   109\t    String prefix = 'Hello'\n   110\t\n   111\t    String greet(String name) {\n   112\t        return \"${prefix}, ${name}\"\n   113\t    }\n   114\t}\n   115\t\n   116\tdef counter = new AtomicInteger(1)\n   117\tdef doubled = [1, 2, 3].collect { value -> value * 2 }\n   118\tassert doubled.sum() == 12\n   119\tcounter.incrementAndGet()\n   120\t'''\n   121\t\n   122\t            TextNode root = adapter.compile(source, CompilePhase.SEMANTIC_ANALYSIS.phaseNumber) as TextNode\n   123\t            List<TextNode> nodes = flatten(root)\n   124\t            String renderedTree = nodes.collect { it.toString() }.join('\\n')\n   125\t\n   126\t            assertThat(root.toString()).isEqualTo('root')\n   127\t            assertThat(renderedTree)\n   128\t                    .contains('BlockStatement')\n   129\t                    .contains('Greeter')\n   130\t                    .contains('Methods')\n   131\t                    .contains('greet')\n   132\t                    .contains('Fields')\n   133\t                    .contains('Properties')\n   134\t            List<TextNode> nodesWithProperties = nodes.findAll { it.properties }\n   135\t            assertThat(nodesWithProperties).isNotEmpty()\n   136\t            boolean namedAstNodeFound = nodesWithProperties.any { TextNode node ->\n   137\t                node.properties.any { List<?> property ->\n   138\t                    property[0] == 'name' && property[1].toString().contains('Greeter')\n   139\t                }\n   140\t            }\n   141\t            assertThat(namedAstNodeFound).isTrue()\n   142\t        } catch (Error e) {\n   143\t            verifyUnsupportedDynamicCompilation(e)\n   144\t        }\n   145\t    }\n   146\t\n   147\t    @Test\n   148\t    void decompilesAstToScriptAndReportsCompilationFailures() {\n   149\t        try {\n   150\t            AstNodeToScriptAdapter adapter = new AstNodeToScriptAdapter()\n   151\t            String source = '''package sample\n   152\t\n   153\timport static java.lang.Math.max\n   154\t\n   155\tclass Calculator<T extends Number> {\n   156\t    int twice(int value) {\n   157\t        return max(value, value) * 2\n   158\t    }\n   159\t}\n   160\t\n   161\tassert new Calculator<Integer>().twice(21) == 42\n   162\t'''\n   163\t\n   164\t            String decompiled = adapter.compileToScript(\n   165\t                    source,\n   166\t                    CompilePhase.CONVERSION.phaseNumber,\n   167\t                    new GroovyClassLoader(getClass().classLoader),\n   168\t                    true,\n   169\t                    true)\n   170\t\n   171\t            assertThat(decompiled)\n   172\t                    .contains('package sample')\n   173\t                    .contains('import static java.lang.Math.max')\n   174\t                    .contains('Calculator')\n   175\t                    .contains('twice')\n   176\t                    .contains('return')\n   177\t                    .contains('max')\n   178\t\n   179\t            String failed = adapter.compileToScript('def broken = ', CompilePhase.SEMANTIC_ANALYSIS.phaseNumber)\n   180\t            assertThat(failed)\n   181\t                    .contains('Unable to produce AST for this phase due to earlier compilation error')\n   182\t                    .contains('Fix the above error(s) and then press Refresh')\n   183\t        } catch (Error e) {\n   184\t            verifyUnsupportedDynamicCompilation(e)\n   185\t        }\n   186\t    }\n   187\t\n   188\t    @Test\n   189\t    void highlightsGroovySyntaxAndInstallsAutoIndentAction() {\n   190\t        DefaultStyledDocument document = new DefaultStyledDocument()\n   191\t        GroovyFilter filter = new GroovyFilter(document)\n   192\t        ((AbstractDocument) document).documentFilter = filter\n   193\t\n   194\t        String source = '''class Demo {\n   195\t    // comment\n   196\t    def answer = 42\n   197\t    String text = 'ok'\n   198\t}\n   199\t'''\n   200\t        document.insertString(0, source, null)\n   201\t\n   202\t        assertThat(StyleConstants.isBold(attributesAt(document, source.indexOf('class')))).isTrue()\n   203\t        assertThat(StyleConstants.isItalic(attributesAt(document, source.indexOf('// comment') + 1))).isTrue()\n   204\t        assertThat(StyleConstants.getForeground(attributesAt(document, source.indexOf('42')))).isNotNull()\n   205\t        assertThat(StyleConstants.getForeground(attributesAt(document, source.indexOf(\"'ok'\") + 1))).isNotNull()\n   206\t\n   207\t        document.remove(source.indexOf('42'), 2)\n   208\t        document.insertString(source.indexOf('42'), '0x2A', null)\n   209\t        assertThat(document.getText(0, document.length)).contains('0x2A')\n   210\t\n   211\t        JTextPane pane = new JTextPane(document)\n   212\t        GroovyFilter.installAutoTabAction(pane)\n   213\t        assertThat(pane.actionMap.get('GroovyFilter-autoTab')).isNotNull()\n   214\t        boolean enterKeyBound = pane.inputMap.allKeys().any { it.toString().contains('ENTER') }\n   215\t        assertThat(enterKeyBound).isTrue()\n   216\t    }\n   217\t\n   218\t    @Test\n   219\t    void highlightsMatchingDelimitersAndClearsStaleHighlights() {\n   220\t        DefaultStyledDocument document = new DefaultStyledDocument()\n   221\t        SmartDocumentFilter filter = new SmartDocumentFilter(document)\n   222\t        ((AbstractDocument) document).documentFilter = filter\n   223\t        String source = 'def values = [1, (2 + 3)]\\n'\n   224\t        document.insertString(0, source, null)\n   225\t        JTextPane pane = new JTextPane(document)\n   226\t        MatchingHighlighter highlighter = new MatchingHighlighter(filter, pane)\n   227\t\n   228\t        int openParen = source.indexOf('(')\n   229\t        int closeParen = source.indexOf(')')\n   230\t        pane.caretPosition = openParen + 1\n   231\t        highlighter.highlight()\n   232\t        waitForPendingSwingEvents()\n   233\t\n   234\t        assertHighlightedDelimiter(document, openParen)\n   235\t        assertHighlightedDelimiter(document, closeParen)\n   236\t\n   237\t        pane.caretPosition = source.length()\n   238\t        highlighter.highlight()\n   239\t        waitForPendingSwingEvents()\n   240\t\n   241\t        assertPlainDelimiter(document, openParen)\n   242\t        assertPlainDelimiter(document, closeParen)\n   243\t    }\n   244\t\n   245\t    @Test\n   246\t    void editsTextWithTextEditorPublicApi() {\n   247\t        TextEditor editor = new TextEditor(true, true, true)\n   248\t        editor.text = 'alpha\\nbeta'\n   249\t\n   250\t        editor.caretPosition = 0\n   251\t        editor.setOvertypeMode(true)\n   252\t        editor.replaceSelection('Z')\n   253\t        assertThat(editor.text).isEqualTo('Zlpha\\nbeta')\n   254\t\n   255\t        editor.setOvertypeMode(false)\n   256\t        editor.caretPosition = editor.text.length()\n   257\t        editor.replaceSelection('\\nnext')\n   258\t        assertThat(editor.text).endsWith('beta\\nnext')\n   259\t\n   260\t        editor.setUnwrapped(false)\n   261\t        editor.isTabsAsSpaces(false)\n   262\t        editor.isMultiLineTabbed(false)\n   263\t\n   264\t        assertThat(editor.tabsAsSpaces).isFalse()\n   265\t        assertThat(editor.multiLineTabbed).isFalse()\n   266\t        assertThat(editor.unwrapped).isFalse()\n   267\t        assertThat(editor.actionMap.get('TextEditor-tabAction')).isNotNull()\n   268\t        assertThat(editor.actionMap.get('TextEditor-shiftTabAction')).isNotNull()\n   269\t        assertThat(editor.getPageFormat(0)).isNotNull()\n   270\t        assertThat(editor.getPrintable(0)).isSameAs(editor)\n   271\t    }\n   272\t\n   273\t    @Test\n   274\t    void transformsConsoleResultsIntoDisplayableValues() {\n   275\t        String originalUserHome = System.getProperty('user.home')\n   276\t        Path tempHome = Files.createTempDirectory('groovy-console-output-transforms')\n   277\t\n   278\t        try {\n   279\t            System.setProperty('user.home', tempHome.toString())\n   280\t            List<Closure> transforms = OutputTransforms.loadOutputTransforms()\n   281\t\n   282\t            BufferedImage image = new BufferedImage(2, 3, BufferedImage.TYPE_INT_ARGB)\n   283\t            ImageIcon icon = OutputTransforms.transformResult(image, transforms) as ImageIcon\n   284\t            assertThat(icon.iconWidth).isEqualTo(2)\n   285\t            assertThat(icon.iconHeight).isEqualTo(3)\n   286\t\n   287\t            String inspected = OutputTransforms.transformResult([answer: 42], transforms) as String\n   288\t            assertThat(inspected).contains('answer', '42')\n   289\t            assertThat(OutputTransforms.transformResult(null, transforms)).isNull()\n   290\t\n   291\t            List<Closure> customTransforms = [\n   292\t                    { Object value -> value instanceof Number ? null : 'not-a-number' },\n   293\t                    { Object value -> value instanceof Number ? value * 2 : null }\n   294\t            ]\n   295\t            assertThat(OutputTransforms.transformResult(21, customTransforms)).isEqualTo(42)\n   296\t        } finally {\n   297\t            if (originalUserHome == null) {\n   298\t                System.clearProperty('user.home')\n   299\t            } else {\n   300\t                System.setProperty('user.home', originalUserHome)\n   301\t            }\n   302\t            Files.deleteIfExists(tempHome)\n   303\t        }\n   304\t    }\n   305\t\n   306\t    @Test\n   307\t    void interceptsSystemOutputAndRestoresOriginalPrintStreams() {\n   308\t        PrintStream originalOut = System.out\n   309\t        PrintStream originalErr = System.err\n   310\t        List<List<Object>> capturedOut = []\n   311\t        List<List<Object>> capturedErr = []\n   312\t        SystemOutputInterceptor outInterceptor = new SystemOutputInterceptor({ Integer consoleId, String text ->\n   313\t            capturedOut << [consoleId, text]\n   314\t            false\n   315\t        })\n   316\t        SystemOutputInterceptor errInterceptor = new SystemOutputInterceptor({ Integer consoleId, String text ->\n   317\t            capturedErr << [consoleId, text]\