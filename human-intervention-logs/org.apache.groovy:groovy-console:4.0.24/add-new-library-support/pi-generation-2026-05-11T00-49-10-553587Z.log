ter-autoTab')).isNotNull()\n        assertThat(pane.inputMap.allKeys()*.toString()).anyMatch { String key -> key.contains('ENTER') }\n    }\n\n    @Test\n    void editsTextWithConsoleTextEditorActions() {\n        TextEditor editor = new TextEditor(true, true, true)\n        editor.text = 'alpha\\nbeta'\n        editor.select(0, editor.text.length())\n\n        editor.actionMap.get('TextEditor-tabAction').actionPerformed(new ActionEvent(editor, ActionEvent.ACTION_PERFORMED, 'tab'))\n        assertThat(editor.text).isEqualTo('    alpha\\n    beta')\n\n        editor.actionMap.get('TextEditor-shiftTabAction').actionPerformed(new ActionEvent(editor, ActionEvent.ACTION_PERFORMED, 'shiftTab'))\n        assertThat(editor.text).isEqualTo('alpha\\nbeta')\n\n        editor.caretPosition = 0\n        editor.setOvertypeMode(true)\n        editor.replaceSelection('Z')\n        assertThat(editor.text).isEqualTo('Zlpha\\nbeta')\n        editor.setOvertypeMode(false)\n        editor.setUnwrapped(false)\n        editor.isTabsAsSpaces(false)\n        editor.isMultiLineTabbed(false)\n\n        assertThat(editor.tabsAsSpaces).isFalse()\n        assertThat(editor.multiLineTabbed).isFalse()\n        assertThat(editor.unwrapped).isFalse()\n        assertThat(editor.getPageFormat(0)).isNotNull()\n        assertThat(editor.getPrintable(0)).isSameAs(editor)\n\n        ConsoleTextEditor consoleEditor = new ConsoleTextEditor()\n        consoleEditor.showLineNumbers = true\n        consoleEditor.editable = false\n        consoleEditor.enableHighLighter(GroovyFilter)\n        consoleEditor.textEditor.document.insertString(0, 'def value = 123', null)\n\n        assertThat(consoleEditor.textEditor.text).isEqualTo('def value = 123')\n        assertThat(consoleEditor.undoAction).isNotNull()\n        assertThat(consoleEditor.redoAction).isNotNull()\n        assertThat(consoleEditor.printAction).isNotNull()\n        assertThat(consoleEditor.defaultFamily).isNotBlank()\n    }\n\n    @Test\n    void interceptsSystemOutputAndRestoresOriginalPrintStream() {\n        PrintStream originalOut = System.out\n        List<List<Object>> captured = []\n        SystemOutputInterceptor interceptor = new SystemOutputInterceptor({ Integer consoleId, String text ->\n            captured << [consoleId, text]\n            false\n        })\n\n        try {\n            interceptor.setConsoleId(7)\n            interceptor.start()\n            System.out.print('hello')\n            System.out.write((int) '!')\n            System.out.flush()\n        } finally {\n            interceptor.stop()\n            interceptor.removeConsoleId()\n        }\n\n        assertThat(System.out).isSameAs(originalOut)\n        assertThat(captured).contains([7, 'hello'], [7, '!'])\n    }\n\n    private static List<TextNode> flatten(TextNode root) {\n        List<TextNode> result = []\n        Deque<TextNode> remaining = new ArrayDeque<>()\n        remaining.add(root)\n        while (!remaining.isEmpty()) {\n            TextNode current = remaining.removeFirst()\n            result << current\n            current.children.findAll { it instanceof TextNode }.reverseEach { TextNode child ->\n                remaining.addFirst(child)\n            }\n        }\n        result\n    }\n\n    private static javax.swing.text.AttributeSet attributesAt(DefaultStyledDocument document, int offset) {\n        document.getCharacterElement(offset).attributes\n    }\n\n    private static void verifyUnsupportedDynamicCompilation(Error e) {\n        if (!NativeImageSupport.isUnsupportedFeatureError(e)) {\n            throw e\n        }\n    }\n}\n"}
