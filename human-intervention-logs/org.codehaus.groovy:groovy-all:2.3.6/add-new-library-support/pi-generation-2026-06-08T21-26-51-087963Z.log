  package org_codehaus_groovy.groovy_all
  
  import groovy.swing.LookAndFeelHelper
  import groovy.transform.CompileStatic
  import org.junit.jupiter.api.Test
  
  import javax.swing.LookAndFeel
  import javax.swing.UIManager
  import java.lang.invoke.MethodHandle
  import java.lang.invoke.MethodHandles
  import java.lang.invoke.MethodType
  
  import static org.assertj.core.api.Assertions.assertThat
  
  public class LookAndFeelHelperTest {
      @Test
      void discoversOptionalLookAndFeelClassNames() {
          List<String> nimbusNames = [
                  'com.sun.java.swing.plaf.nimbus.NimbusLookAndFeel',
                  'sun.swing.plaf.nimbus.NimbusLookAndFeel',
                  'org.jdesktop.swingx.plaf.nimbus.NimbusLookAndFeel'
          ]
          List<String> aquaNames = [
                  'com.apple.laf.AquaLookAndFeel',
                  'apple.laf.AquaLookAndFeel'
          ]
          List<String> substanceNames = [
                  'org.pushingpixels.substance.api.SubstanceLookAndFeel',
                  'org.jvnet.substance.SubstanceLookAndFeel'
          ]
  
          assertThatOptionalClassNameIsSupported(LookAndFeelHelper.getNimbusLAFName(), nimbusNames)
          assertThatOptionalClassNameIsSupported(LookAndFeelHelper.getAquaLAFName(), aquaNames)
          assertThatOptionalClassNameIsSupported(LookAndFeelHelper.getSubstanceLAFName(), substanceNames)
      }
  
      @Test
      void createsLookAndFeelFromStandardAlias() {
          LookAndFeelHelper helper = LookAndFeelHelper.getInstance()
          LookAndFeel originalLookAndFeel = UIManager.getLookAndFeel()
  
          try {
              LookAndFeel lookAndFeel = helper.lookAndFeel('metal', [:], null)
  
              assertThat(helper.isLeaf()).isTrue()
              assertThat(lookAndFeel.class.name).isEqualTo('javax.swing.plaf.metal.MetalLookAndFeel')
              assertThat(UIManager.getLookAndFeel()).isSameAs(lookAndFeel)
          } finally {
              if (originalLookAndFeel != null) {
                  UIManager.setLookAndFeel(originalLookAndFeel)
              }
          }
      }
  
      @Test
      @CompileStatic
      void resolvesGeneratedClassReferenceHelper() {
          MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(LookAndFeelHelper.class, MethodHandles.lookup())
          MethodHandle helper = lookup.findStatic(
                  LookAndFeelHelper.class,
                  'class$',
                  MethodType.methodType(Class.class, String.class))
  
          Class<?> loadedClass = helper.invokeWithArguments(LookAndFeelHelper.name) as Class<?>
  
          assertThat(loadedClass).isSameAs(LookAndFeelHelper.class)
      }
  
      private static void assertThatOptionalClassNameIsSupported(String className, List<String> supportedClassNames) {
          assertThat(className == null || supportedClassNames.contains(className)).isTrue()
      }
  }
