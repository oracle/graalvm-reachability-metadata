ll", "id": "call_iTa2PqisLiLq1Z8FYt4X2Mxe|fc_0359bec474ff1a75016a273340fc4c8193988c993c3b7174cb", "name": "write", "arguments": {"path": "tests/src/org.codehaus.groovy/groovy-all/2.3.6/src/test/groovy/org_codehaus_groovy/groovy_all/LexerFrameTest.groovy", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_codehaus_groovy.groovy_all\n\nimport org.codehaus.groovy.antlr.LexerFrame\nimport org.codehaus.groovy.antlr.parser.GroovyLexer\nimport org.codehaus.groovy.antlr.parser.GroovyTokenTypes\nimport org.junit.jupiter.api.Test\n\nimport javax.swing.AbstractButton\nimport javax.swing.JButton\nimport javax.swing.JFileChooser\nimport javax.swing.JMenuItem\nimport javax.swing.JPopupMenu\nimport javax.swing.JToggleButton\nimport javax.swing.JTextArea\nimport javax.swing.SwingUtilities\nimport javax.swing.WindowConstants\nimport java.awt.Component\nimport java.awt.Container\nimport java.awt.Window\nimport java.awt.event.MouseEvent\nimport java.awt.event.MouseListener\nimport java.nio.charset.StandardCharsets\nimport java.nio.file.Files\nimport java.nio.file.Path\nimport java.time.Duration\nimport java.util.concurrent.Callable\nimport java.util.concurrent.CompletableFuture\nimport java.util.concurrent.TimeUnit\nimport java.util.concurrent.atomic.AtomicReference\n\nimport static org.assertj.core.api.Assertions.assertThat\n\npublic class LexerFrameTest {\n    @Test\n    void tokenViewerScansGroovyScriptSelectedFromFileChooser() {\n        String script = 'def answer = 42\\nprintln answer\\n'\n        Path scriptPath = Files.createTempFile('lexer-frame-script', '.groovy')\n        Files.write(scriptPath, script.getBytes(StandardCharsets.UTF_8))\n        AtomicReference<LexerFrame> frameReference = new AtomicReference<>()\n\n        try {\n            AtomicReference<JButton> openButtonReference = new AtomicReference<>()\n            onEventDispatchThreadAndWait {\n                LexerFrame frame = new LexerFrame(GroovyLexer, GroovyTokenTypes)\n                frame.setDefaultCloseOperation(WindowConstants.DISPOSE_ON_CLOSE)\n                frame.setVisible(true)\n                frameReference.set(frame)\n                openButtonReference.set(findDescendant(frame, JButton) { JButton button -> button.text == 'open' })\n            }\n\n            CompletableFuture<Void> chooserApproval = CompletableFuture.runAsync {\n                JFileChooser chooser = waitFor('file chooser', Duration.ofSeconds(10)) {\n                    AtomicReference<JFileChooser> chooserReference = new AtomicReference<>()\n                    onEventDispatchThreadAndWait {\n                        chooserReference.set(findShowingComponent(JFileChooser))\n                    }\n                    chooserReference.get()\n                }\n                onEventDispatchThreadAndWait {\n                    chooser.setSelectedFile(scriptPath.toFile())\n                    chooser.approveSelection()\n                }\n            }\n\n            CompletableFuture<Void> openAction = new CompletableFuture<>()\n            SwingUtilities.invokeLater {\n                try {\n                    showOpenPopupAndChooseFile(openButtonReference.get())\n                    openAction.complete(null)\n                } catch (Throwable throwable) {\n                    openAction.completeExceptionally(throwable)\n                }\n            }\n\n            chooserApproval.get(10, TimeUnit.SECONDS)\n            openAction.get(10, TimeUnit.SECONDS)\n\n            AtomicReference<JTextArea> scriptAreaReference = new AtomicReference<>()\n            AtomicReference<List<JToggleButton>> tokenButtonsReference = new AtomicReference<>()\n            onEventDispatchThreadAndWait {\n                LexerFrame frame = frameReference.get()\n                scriptAreaReference.set(findDescendant(frame, JTextArea) { JTextArea ignored -> true })\n                tokenButtonsReference.set(findDescendants(frame, JToggleButton))\n            }\n\n            assertThat(scriptAreaReference.get().text).isEqualTo(script)\n            assertThat(tokenButtonsReference.get().collect { JToggleButton button -> button.toolTipText })\n                    .contains('def', 'answer', '42', 'println')\n        } finally {\n            onEventDispatchThreadAndWait {\n                Window.getWindows().each { Window window -> window.dispose() }\n            }\n            Files.deleteIfExists(scriptPath)\n        }\n    }\n\n    private static void showOpenPopupAndChooseFile(JButton openButton) {\n        assertThat(openButton).isNotNull()\n        MouseEvent releaseEvent = new MouseEvent(\n                openButton,\n                MouseEvent.MOUSE_RELEASED,\n                System.currentTimeMillis(),\n                0,\n                5,\n                5,\n                1,\n                false)\n        openButton.mouseListeners.each { MouseListener listener -> listener.mouseReleased(releaseEvent) }\n\n        JMenuItem openMenuItem = findSelectedPopupMenuItem('Open File...')\n        assertThat(openMenuItem).isNotNull()\n        openMenuItem.doClick()\n    }\n\n    private static JMenuItem findSelectedPopupMenuItem(String text) {\n        Component[] selectedPath = javax.swing.MenuSelectionManager.defaultManager().selectedPath\n                .findAll { Object element -> element instanceof Component } as Component[]\n        for (Component component : selectedPath) {\n            JMenuItem menuItem = findDescendant(component, JMenuItem) { JMenuItem candidate -> candidate.text == text }\n            if (menuItem != null) {\n                return menuItem\n            }\n        }\n        for (Window window : Window.getWindows()) {\n            JMenuItem menuItem = findDescendant(window, JMenuItem) { JMenuItem candidate -> candidate.text == text }\n            if (menuItem != null) {\n                return menuItem\n            }\n        }\n        return null\n    }\n\n    private static <T extends Component> T findShowingComponent(Class<T> type) {\n        for (Window window : Window.getWindows()) {\n            if (window.showing) {\n                T component = findDescendant(window, type) { T ignored -> true }\n                if (component != null) {\n                    return component\n                }\n            }\n        }\n        return null\n    }\n\n    private static <T extends Component> T findDescendant(Component component, Class<T> type, Closure<Boolean> predicate) {\n        if (type.isInstance(component) && predicate.call(type.cast(component))) {\n            return type.cast(component)\n        }\n        if (component instanceof JPopupMenu) {\n            for (Component child : ((JPopupMenu) component).components) {\n                T match = findDescendant(child, type, predicate)\n                if (match != null) {\n                    return match\n                }\n            }\n        }\n        if (component instanceof Container) {\n            for (Component child : ((Container) component).components) {\n                T match = findDescendant(child, type, predicate)\n                if (match != null) {\n                    return match\n                }\n            }\n        }\n        return null\n    }\n\n    private static <T extends Component> List<T> findDescendants(Component component, Class<T> type) {\n        List<T> matches = []\n        collectDescendants(component, type, matches)\n        return matches\n    }\n\n    private static <T extends Component> void collectDescendants(Component component, Class<T> type, List<T> matches) {\n        if (type.isInstance(component)) {\n            matches.add(type.cast(component))\n        }\n        if (component instanceof Container) {\n            for (Component child : ((Container) component).components) {\n                collectDescendants(child, type, matches)\n            }\n        }\n    }\n\n    private static <T> T waitFor(String description, Duration timeout, Callable<T> supplier) {\n        long deadline = System.nanoTime() + timeout.toNanos()\n        while (System.nanoTime() < deadline) {\n            T result = supplier.call()\n            if (result != null) {\n                return result\n            }\n            Thread.sleep(50)\n        }\n        throw new AssertionError(\"Timed out waiting for ${description}\")\n    }\n\n    private static void onEventDispatchThreadAndWait(Closure<?> action) {\n        if (SwingUtilities.eventDispatchThread) {\n            action.call()\n        } else {\n            SwingUtilities.invokeAndWait({ action.call() } as Runnable)\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 367, "output": 3868, "cacheRead": 53760, "cacheWrite": 0, "totalTokens": 57995, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780953878352, "responseId": "resp_0359bec474ff1a75016a273317074c81939e3037a325065a3a"}}
