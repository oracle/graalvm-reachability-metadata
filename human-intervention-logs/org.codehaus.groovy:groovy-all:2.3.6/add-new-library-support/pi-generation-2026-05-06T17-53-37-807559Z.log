  package org_codehaus_groovy.groovy_all
  
  import groovy.inspect.swingui.GeneratedBytecodeAwareGroovyClassLoader
  import groovy.lang.GroovyClassLoader
  import groovy.transform.CompileStatic
  import java.net.URL
  import java.util.Enumeration
  import org.junit.jupiter.api.Test
  
  public class GeneratedBytecodeAwareGroovyClassLoaderTest {
      @Test
      void resolvesKnownClassThroughGeneratedClassHelper() {
          Class<?> resolvedClass = GeneratedBytecodeAwareGroovyClassLoader.'class$'('java.lang.String')
  
          assert resolvedClass == String
      }
  
      @Test
      @CompileStatic
      void delegatesGeneratedSuperclassAccessorsToClassLoader() {
          GroovyClassLoader parentLoader = new GroovyClassLoader(getClass().classLoader)
          GeneratedBytecodeAwareGroovyClassLoader loader = new GeneratedBytecodeAwareGroovyClassLoader(parentLoader)
  
          try {
              Class<?> loadedClass = loader.super$2$findLoadedClass('java.lang.String')
              Class<?> systemClass = loader.super$2$findSystemClass('java.lang.String')
              URL resource = loader.super$2$getResource('java/lang/String.class')
              Enumeration<URL> resources = loader.super$2$getResources('java/lang/String.class')
  
              assert loadedClass == null || loadedClass == String
              assert systemClass == String
              assert resource == null || resource.toString().length() > 0
              assert resources != null
          } finally {
              loader.close()
              parentLoader.close()
          }
      }
  }
