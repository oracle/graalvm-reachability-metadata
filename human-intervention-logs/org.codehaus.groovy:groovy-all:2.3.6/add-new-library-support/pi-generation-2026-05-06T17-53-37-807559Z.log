ions.emptyMap())\n        RecordingTarget target = new RecordingTarget()\n        triggerBinding.setClosure(sourceExpression)\n\n        FullBinding binding = triggerBinding.createBinding(triggerBinding, target)\n\n        try {\n            assert binding.targetBinding.is(target)\n            assert triggerBinding.sourceValue == 'Ada'\n\n            binding.bind()\n            person.name = 'Grace'\n\n            assert target.values == ['Grace']\n        } finally {\n            binding.unbind()\n        }\n    }\n\n    static class ObservableHolder {\n        private final PropertyChangeSupport propertyChangeSupport = new PropertyChangeSupport(this)\n        private ObservablePerson personValue\n\n        ObservableHolder(ObservablePerson person) {\n            this.personValue = person\n        }\n\n        ObservablePerson getPerson() {\n            return personValue\n        }\n\n        void setPerson(ObservablePerson person) {\n            ObservablePerson oldPerson = personValue\n            personValue = person\n            propertyChangeSupport.firePropertyChange('person', oldPerson, person)\n        }\n\n        void addPropertyChangeListener(String propertyName, java.beans.PropertyChangeListener listener) {\n            propertyChangeSupport.addPropertyChangeListener(propertyName, listener)\n        }\n\n        void removePropertyChangeListener(String propertyName, java.beans.PropertyChangeListener listener) {\n            propertyChangeSupport.removePropertyChangeListener(propertyName, listener)\n        }\n    }\n\n    static class ObservablePerson {\n        private final PropertyChangeSupport propertyChangeSupport = new PropertyChangeSupport(this)\n        private String nameValue\n\n        ObservablePerson(String name) {\n            this.nameValue = name\n        }\n\n        String getName() {\n            return nameValue\n        }\n\n        void setName(String name) {\n            String oldName = nameValue\n            nameValue = name\n            propertyChangeSupport.firePropertyChange('name', oldName, name)\n        }\n\n        void addPropertyChangeListener(String propertyName, java.beans.PropertyChangeListener listener) {\n            propertyChangeSupport.addPropertyChangeListener(propertyName, listener)\n        }\n\n        void removePropertyChangeListener(String propertyName, java.beans.PropertyChangeListener listener) {\n            propertyChangeSupport.removePropertyChangeListener(propertyName, listener)\n        }\n    }\n\n    static class RecordingTarget implements TargetBinding {\n        final List<Object> values = []\n\n        void updateTargetValue(Object value) {\n            values.add(value)\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1621, "output": 1033, "cacheRead": 21504, "cacheWrite": 0, "totalTokens": 24158, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778089949008, "responseId": "resp_069e4a1fc4bc21b30169fb7fddae4081a1a1457702a16c16d0"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_XANqZLBWs23AU1HfstZAIC0e|fc_069e4a1fc4bc21b30169fb7fe2394081a1ae4a34d77cc42cb4", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 3533 bytes to tests/src/org.codehaus.groovy/groovy-all/2.3.6/src/test/groovy/org_codehaus_groovy/groovy_all/ClosureTriggerBindingAnonymous1Test.groovy"}], "isError": false, "timestamp": 1778089958931}]}
