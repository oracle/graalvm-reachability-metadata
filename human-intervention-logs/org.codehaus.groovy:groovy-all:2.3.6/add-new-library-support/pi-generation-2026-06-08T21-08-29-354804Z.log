  package org_codehaus_groovy.groovy_all
  
  import groovy.inspect.swingui.GeneratedBytecodeAwareGroovyClassLoader
  import groovy.lang.GroovyClassLoader
  import groovy.transform.CompileStatic
  import org.codehaus.groovy.runtime.InvokerHelper
  import org.junit.jupiter.api.Test
  
  import java.net.URL
  import java.util.Collections
  import java.util.Enumeration
  
  import static org.assertj.core.api.Assertions.assertThat
  
  public class GeneratedBytecodeAwareGroovyClassLoaderTest {
      @Test
      @CompileStatic
      void delegatesCoreClassLoaderOperations() {
          GeneratedBytecodeAwareGroovyClassLoader loader = new GeneratedBytecodeAwareGroovyClassLoader(
                  new GroovyClassLoader())
  
          Class<?> systemClass = loader.super$2$findSystemClass('java.lang.String') as Class<?>
          assertThat(systemClass).isSameAs(String.class)
  
          Class<?> notLoadedClass = loader.super$2$findLoadedClass('org.example.DoesNotExist') as Class<?>
          assertThat(notLoadedClass).isNull()
  
          URL missingResource = loader.super$2$getResource('org/example/does-not-exist.txt') as URL
          assertThat(missingResource).isNull()
  
          Enumeration<URL> missingResources = loader.super$2$getResources(
                  'org/example/does-not-exist.txt') as Enumeration<URL>
          assertThat(Collections.list(missingResources)).isEmpty()
      }
  
      @Test
      void resolvesClassNamesThroughGroovyGeneratedClassLookup() {
          Class<?> loadedClass = InvokerHelper.invokeStaticMethod(
                  GeneratedBytecodeAwareGroovyClassLoader,
                  'class$',
                  'java.lang.String') as Class<?>
  
          assertThat(loadedClass).isSameAs(String.class)
      }
  }
