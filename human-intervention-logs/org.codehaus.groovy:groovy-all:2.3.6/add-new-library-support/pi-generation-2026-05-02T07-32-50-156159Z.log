  package org_codehaus_groovy.groovy_all
  
  import groovy.inspect.swingui.GeneratedBytecodeAwareGroovyClassLoader
  import groovy.lang.GroovyClassLoader
  import groovy.transform.CompileStatic
  import org.graalvm.internal.tck.NativeImageSupport
  import org.junit.jupiter.api.Test
  
  import java.net.URL
  import java.util.Enumeration
  
  import static org.assertj.core.api.Assertions.assertThat
  
  public class GeneratedBytecodeAwareGroovyClassLoaderTest {
      @Test
      void generatedClassHelperUsesClassForName() {
          try {
              Class<?> classFromGeneratedHelper = GeneratedBytecodeAwareGroovyClassLoader.'class$'(GeneratedBytecodeAwareGroovyClassLoader.name)
  
              assertThat(classFromGeneratedHelper).isSameAs(GeneratedBytecodeAwareGroovyClassLoader)
          } catch (Error e) {
              if (!NativeImageSupport.isUnsupportedFeatureError(e)) {
                  throw e
              }
          }
      }
  
      @Test
      @CompileStatic
      void generatedClassLoadingBridgeMethodsDelegateToSuperclassImplementations() {
          try {
              GeneratedBytecodeAwareGroovyClassLoader loader = new GeneratedBytecodeAwareGroovyClassLoader(new GroovyClassLoader())
  
              Class<?> systemClass = loader.super$2$findSystemClass('java.lang.String')
  
              assertThat(systemClass).isSameAs(String)
          } catch (Error e) {
              if (!NativeImageSupport.isUnsupportedFeatureError(e)) {
                  throw e
              }
          }
      }
  
      @Test
      @CompileStatic
      void generatedLookupBridgeMethodsDelegateToSuperclassImplementations() {
          GeneratedBytecodeAwareGroovyClassLoader loader = new GeneratedBytecodeAwareGroovyClassLoader(new GroovyClassLoader())
          String missingResourceName = 'org/codehaus/groovy/groovy-all/generated-bytecode-aware-loader-test-resource.txt'
  
          Class<?> missingLoadedClass = loader.super$2$findLoadedClass('org.codehaus.groovy.groovy_all.NotLoadedByThisClassLoader')
          URL missingResource = loader.super$2$getResource(missingResourceName)
          Enumeration<URL> missingResources = loader.super$2$getResources(missingResourceName)
  
          assertThat(missingLoadedClass).isNull()
          assertThat(missingResource).isNull()
          assertThat(missingResources).isNotNull()
          assertThat(missingResources.hasMoreElements()).isFalse()
      }
  }
