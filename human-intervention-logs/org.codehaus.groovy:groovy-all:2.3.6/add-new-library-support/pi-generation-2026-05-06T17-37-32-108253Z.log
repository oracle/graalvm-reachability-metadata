[tool-call] delta {"path":"tests/src/org.codehaus.groovy/groovy-all/2.3.6/src/test/groovy/org_codehaus_groovy/groovy_all/ASTFactoryTest.groovy","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_codehaus_groovy.groovy_all\n\nimport groovyjarjarantlr.ASTFactory\nimport groovyjarjarantlr.CommonAST\nimport groovyjarjarantlr.CommonToken\nimport groovyjarjarantlr.collections.AST\nimport org.junit.jupiter.api.Test\n\npublic class ASTFactoryTest {\n    @Test\n    void createsDefaultCommonAstNodesByClassLookupAndDefaultConstructor() {\n        ASTFactory factory = new ASTFactory()\n\n        AST ast = factory.create(123, 'default-node')\n\n        assert ast instanceof CommonAST\n        assert ast.type == 123\n        assert ast.text == 'default-node'\n    }\n\n    @Test\n    void createsAstNodesUsingPublicTokenConstructor() {\n        ASTFactory factory = new ASTFactory()\n        CommonToken token = new CommonToken(321, 'from-token')\n\n        AST ast = factory.create(token, CommonAST.name)\n\n        assert ast instanceof CommonAST\n        assert ast.type == 321\n        assert ast.text == 'from-token'\n    }\n}\n"}
