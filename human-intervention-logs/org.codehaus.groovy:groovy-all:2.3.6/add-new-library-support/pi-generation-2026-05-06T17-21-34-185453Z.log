s.find { FieldNode field ->\n            field.name == 'declaredValue'\n        }\n        MethodNode methodNode = classNode.methods.find { MethodNode method ->\n            method.name == 'annotatedMethod'\n        }\n        AnnotationNode classAnnotation = classNode.annotations.find { AnnotationNode annotation ->\n            annotation.classNode.name.endsWith('Java5FixtureAnnotation')\n        }\n\n        assert fieldNode != null\n        assert methodNode != null\n        assert classNode.declaredConstructors.size() >= 2\n        assert classAnnotation != null\n        assert classAnnotation.getMember('name') instanceof ConstantExpression\n        assert classAnnotation.getMember('number') instanceof ConstantExpression\n        assert classAnnotation.getMember('type') instanceof ClassExpression\n        assert classAnnotation.getMember('tags') instanceof ListExpression\n        assert methodNode.annotations.any { AnnotationNode annotation ->\n            annotation.classNode.name.endsWith('Java5FixtureAnnotation')\n        }\n    }\n\n    @Retention(RetentionPolicy.RUNTIME)\n    @Target([\n        ElementType.TYPE,\n        ElementType.FIELD,\n        ElementType.METHOD,\n        ElementType.CONSTRUCTOR,\n        ElementType.PARAMETER\n    ])\n    public @interface Java5FixtureAnnotation {\n        String name()\n\n        int number() default 7\n\n        Class type() default String\n\n        String[] tags() default []\n    }\n\n    @Java5FixtureAnnotation(name = 'fixture', number = 42, type = Integer, tags = ['class', 'annotation'])\n    public static class Java5ConfiguredFixture {\n        @Java5FixtureAnnotation(name = 'field', tags = ['field'])\n        private String declaredValue\n\n        public Java5ConfiguredFixture() {\n            this('default')\n        }\n\n        @Java5FixtureAnnotation(name = 'constructor', tags = ['constructor'])\n        public Java5ConfiguredFixture(String declaredValue) {\n            this.declaredValue = declaredValue\n        }\n\n        @Java5FixtureAnnotation(name = 'method', tags = ['method'])\n        public String annotatedMethod(@Java5FixtureAnnotation(name = 'parameter') String suffix) throws IOException {\n            if (suffix == null) {\n                throw new IOException('suffix is required')\n            }\n            return declaredValue + suffix\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 964, "output": 1345, "cacheRead": 23552, "cacheWrite": 0, "totalTokens": 25861, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778088035807, "responseId": "resp_0d08e1d9dbd24f400169fb7864a850819fa6113f978ebdc8cf"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_0p9HBfWXeobHDT7ln5HGl9na|fc_0d08e1d9dbd24f400169fb786cccc8819f9fd505112c360f41", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 3456 bytes to tests/src/org.codehaus.groovy/groovy-all/2.3.6/src/test/groovy/org_codehaus_groovy/groovy_all/Java5Test.groovy"}], "isError": false, "timestamp": 1778088049786}]}
