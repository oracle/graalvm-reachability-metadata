      public PropertyNode addProperty(String name,
                                      int modifiers,
                                      ClassNode type,
                                      Expression initialValueExpression,
                                      Statement getterBlock,
                                      Statement setterBlock) {
          for (PropertyNode pn : getProperties()) {
