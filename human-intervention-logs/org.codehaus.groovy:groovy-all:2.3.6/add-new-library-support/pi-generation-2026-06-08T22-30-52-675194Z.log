assLoader()\n\n        try {\n            Thread.currentThread().setContextClassLoader(new RejectingClassLoader())\n            assertThrows(ClassNotFoundException) {\n                Sql.loadDriver('org.example.jdbc.MissingDriver')\n            }\n        } finally {\n            Thread.currentThread().setContextClassLoader(originalContextClassLoader)\n        }\n    }\n\n    public static final class ContextOnlyDriverClassLoader extends ClassLoader {\n        public static final String CONTEXT_DRIVER_NAME = 'org.example.jdbc.ContextOnlyDriver'\n\n        private final Class<?> driverClass\n        public final List<String> requestedNames = []\n\n        ContextOnlyDriverClassLoader(Class<?> driverClass) {\n            super(null)\n            this.driverClass = driverClass\n        }\n\n        @Override\n        Class<?> loadClass(String name) throws ClassNotFoundException {\n            requestedNames.add(name)\n            if (CONTEXT_DRIVER_NAME == name) {\n                return driverClass\n            }\n            throw new ClassNotFoundException(name)\n        }\n    }\n\n    public static final class RejectingClassLoader extends ClassLoader {\n        RejectingClassLoader() {\n            super(null)\n        }\n\n        @Override\n        Class<?> loadClass(String name) throws ClassNotFoundException {\n            throw new ClassNotFoundException(name)\n        }\n    }\n\n    public static final class VisibleDriver implements Driver {\n        @Override\n        Connection connect(String url, Properties info) throws SQLException {\n            return null\n        }\n\n        @Override\n        boolean acceptsURL(String url) throws SQLException {\n            return false\n        }\n\n        @Override\n        DriverPropertyInfo[] getPropertyInfo(String url, Properties info) throws SQLException {\n            return new DriverPropertyInfo[0]\n        }\n\n        @Override\n        int getMajorVersion() {\n            return 1\n        }\n\n        @Override\n        int getMinorVersion() {\n            return 0\n        }\n\n        @Override\n        boolean jdbcCompliant() {\n            return false\n        }\n\n        @Override\n        Logger getParentLogger() throws SQLFeatureNotSupportedException {\n            return Logger.getLogger(VisibleDriver.name)\n        }\n    }\n}\n"}
