  package groovy.inspect.swingui
  
  import groovy.swing.SwingBuilder
  
  import java.awt.Cursor
  import java.awt.Font
  import java.awt.event.KeyEvent
  import java.util.prefs.Preferences
  import javax.swing.JSplitPane
