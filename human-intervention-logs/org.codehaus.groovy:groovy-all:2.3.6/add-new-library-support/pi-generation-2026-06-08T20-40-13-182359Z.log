[tool-call] delta {"path":"tests/src/org.codehaus.groovy/groovy-all/2.3.6/src/test/groovy/org_codehaus_groovy/groovy_all/GeneratedBytecodeAwareGroovyClassLoaderTest.groovy","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_codehaus_groovy.groovy_all\n\nimport groovy.inspect.swingui.GeneratedBytecodeAwareGroovyClassLoader\nimport groovy.lang.GroovyClassLoader\nimport org.junit.jupiter.api.Test\n\nimport java.net.URL\n\nimport static org.assertj.core.api.Assertions.assertThat\n\npublic class GeneratedBytecodeAwareGroovyClassLoaderTest {\n    @Test\n    void delegatesCoreClassLoaderOperations() {\n        GeneratedBytecodeAwareGroovyClassLoader loader = new GeneratedBytecodeAwareGroovyClassLoader(new GroovyClassLoader())\n\n        Class<?> systemClass = loader.'super$2$findSystemClass'('java.lang.String') as Class<?>\n        assertThat(systemClass).isSameAs(String.class)\n\n        Class<?> notLoadedClass = loader.'super$2$findLoadedClass'('org.example.DoesNotExist') as Class<?>\n        assertThat(notLoadedClass).isNull()\n\n        URL missingResource = loader.'super$2$getResource'('org/example/does-not-exist.txt') as URL\n        assertThat(missingResource).isNull()\n\n        Enumeration<URL> missingResources = loader.'super$2$getResources'('org/example/does-not-exist.txt') as Enumeration<URL>\n        assertThat(Collections.list(missingResources)).isEmpty()\n    }\n\n    @Test\n    void resolvesClassNamesThroughGroovyGeneratedClassLookup() {\n        Class<?> loadedClass = GeneratedBytecodeAwareGroovyClassLoader.'class$'('java.lang.String') as Class<?>\n\n        assertThat(loadedClass).isSameAs(String.class)\n    }\n}\n"}
