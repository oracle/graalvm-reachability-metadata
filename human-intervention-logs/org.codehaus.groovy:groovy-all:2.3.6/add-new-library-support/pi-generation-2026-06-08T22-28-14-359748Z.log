  package org_codehaus_groovy.groovy_all
  
  import org.codehaus.groovy.jsr223.GroovyScriptEngineImpl
  import org.graalvm.internal.tck.NativeImageSupport
  import org.junit.jupiter.api.Test
  
  import static org.assertj.core.api.Assertions.assertThat
  
  interface GreetingScript {
      String greet(String name)
  
      int add(int left, int right)
  }
  
  public class GroovyScriptEngineImplTest {
      @Test
      void evaluatesScriptAndAdaptsGlobalMethodsToInterface() {
          try {
              GroovyScriptEngineImpl engine = new GroovyScriptEngineImpl()
  
              Object result = engine.eval('''
                  def greet(name) {
                      'Hello, ' + name
                  }
  
                  def add(left, right) {
                      left + right
                  }
  
                  'ready'
              '''.stripIndent())
  
              GreetingScript script = engine.getInterface(GreetingScript)
  
              assertThat(result).isEqualTo('ready')
              assertThat(script.greet('Groovy')).isEqualTo('Hello, Groovy')
              assertThat(script.add(2, 5)).isEqualTo(7)
          } catch (Error error) {
              verifyUnsupportedDynamicClassLoading(error)
          }
      }
  
      private static void verifyUnsupportedDynamicClassLoading(Error error) {
          if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
              throw error
          }
      }
