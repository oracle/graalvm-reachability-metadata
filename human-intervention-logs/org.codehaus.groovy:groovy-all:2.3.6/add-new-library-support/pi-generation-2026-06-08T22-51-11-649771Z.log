r.build.Tool\nimport org.junit.jupiter.api.Test\nimport org.junit.jupiter.api.io.TempDir\n\nimport java.nio.charset.StandardCharsets\nimport java.nio.file.Files\nimport java.nio.file.Path\n\nimport static org.assertj.core.api.Assertions.assertThat\n\npublic class GroovyjarjarantlrBuildToolTest {\n    @TempDir\n    Path temporaryDirectory\n\n    @Test\n    void printsUsageWhenNoBuildActionIsProvided() {\n        ByteArrayOutputStream errorOutput = captureStandardError {\n            Tool.main(new String[0])\n        }\n\n        assertThat(errorOutput.toString(StandardCharsets.UTF_8.name()))\n                .contains('usage: java antlr.build.Tool action')\n    }\n\n    @Test\n    void reportsMissingApplicationOrAction() {\n        Tool tool = new Tool()\n\n        ByteArrayOutputStream errorOutput = captureStandardError {\n            tool.perform(null, 'build')\n            tool.perform('groovyjarjarantlr.build.ANTLR', null)\n        }\n\n        assertThat(errorOutput.toString(StandardCharsets.UTF_8.name()))\n                .contains('antlr.build.Tool: missing app or action')\n    }\n\n    @Test\n    void generatesParserSourcesForGrammarFile() {\n        Path grammarFile = temporaryDirectory.resolve('Sample.g')\n        Files.write(grammarFile, sampleGrammar().getBytes(StandardCharsets.UTF_8))\n\n        captureStandardOutput {\n            new Tool().antlr(grammarFile.toString())\n        }\n\n        assertThat(temporaryDirectory.resolve('SampleParser.java')).exists()\n        assertThat(temporaryDirectory.resolve('SampleLexer.java')).exists()\n        assertThat(temporaryDirectory.resolve('SampleParserTokenTypes.java')).exists()\n    }\n\n    private static String sampleGrammar() {\n        return '''class SampleParser extends Parser;\n\nstartRule\n    : WORD EOF\n    ;\n\nclass SampleLexer extends Lexer;\n\nWORD\n    : ('a'..'z')+\n    ;\n\nWS\n    : (' ' | '\\t' | '\\n' | '\\r')+ { _ttype = Token.SKIP; }\n    ;\n'''\n    }\n\n    private static ByteArrayOutputStream captureStandardError(Closure<?> action) {\n        PrintStream originalError = System.err\n        ByteArrayOutputStream output = new ByteArrayOutputStream()\n        System.err = new PrintStream(output, true, StandardCharsets.UTF_8.name())\n        try {\n            action.call()\n        } finally {\n            System.err = originalError\n        }\n        return output\n    }\n\n    private static ByteArrayOutputStream captureStandardOutput(Closure<?> action) {\n        PrintStream originalOutput = System.out\n        ByteArrayOutputStream output = new ByteArrayOutputStream()\n        System.out = new PrintStream(output, true, StandardCharsets.UTF_8.name())\n        try {\n            action.call()\n        } finally {\n            System.out = originalOutput\n        }\n        return output\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 952, "output": 2059, "cacheRead": 30720, "cacheWrite": 0, "totalTokens": 33731, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780958983956, "responseId": "resp_06727ba9988174b4016a2747087be88193a270fa33beca3f03"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_kZux2hOmGH6aw2J2gJrg1NBa|fc_06727ba9988174b4016a27472c6b7c819385f439e9dd50b10f", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2999 bytes to tests/src/org.codehaus.groovy/groovy-all/2.3.6/src/test/groovy/org_codehaus_groovy/groovy_all/GroovyjarjarantlrBuildToolTest.groovy"}], "isError": false, "timestamp": 1780959028800}]}
