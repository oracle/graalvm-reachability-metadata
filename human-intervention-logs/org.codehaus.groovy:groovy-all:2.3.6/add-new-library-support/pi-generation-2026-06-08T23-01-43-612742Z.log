  package org_codehaus_groovy.groovy_all
  
  import org.codehaus.groovy.antlr.LexerFrame
  import org.codehaus.groovy.antlr.parser.GroovyLexer
  import org.codehaus.groovy.antlr.parser.GroovyTokenTypes
  import org.junit.jupiter.api.Test
  
  import javax.swing.JButton
  import javax.swing.JFileChooser
  import javax.swing.JMenuItem
  import javax.swing.JPopupMenu
  import javax.swing.JToggleButton
  import javax.swing.JTextArea
  import javax.swing.MenuSelectionManager
  import javax.swing.SwingUtilities
  import javax.swing.WindowConstants
  import java.awt.Component
  import java.awt.Container
  import java.awt.Window
  import java.awt.event.MouseEvent
  import java.awt.event.MouseListener
  import java.nio.charset.StandardCharsets
  import java.nio.file.Files
  import java.nio.file.Path
  import java.time.Duration
  import java.util.concurrent.Callable
  import java.util.concurrent.CompletableFuture
  import java.util.concurrent.TimeUnit
  import java.util.concurrent.atomic.AtomicReference
  
  import static org.assertj.core.api.Assertions.assertThat
  
  public class LexerFrameTest {
      @Test
      void tokenViewerScansGroovyScriptSelectedFromFileChooser() {
          String script = 'def answer = 42\nprintln answer\n'
          Path scriptPath = Files.createTempFile('lexer-frame-script', '.groovy')
          Files.write(scriptPath, script.getBytes(StandardCharsets.UTF_8))
          AtomicReference<LexerFrame> frameReference = new AtomicReference<LexerFrame>()
  
          try {
              AtomicReference<JButton> openButtonReference = new AtomicReference<JButton>()
              onEventDispatchThreadAndWait {
                  LexerFrame frame = new LexerFrame(GroovyLexer.class, GroovyTokenTypes.class)
                  frame.setDefaultCloseOperation(WindowConstants.DISPOSE_ON_CLOSE)
                  frame.setVisible(true)
                  frameReference.set(frame)
                  openButtonReference.set(findDescendant(frame, JButton) { JButton button -> button.text == 'open' })
              }
  
              CompletableFuture<Void> chooserApproval = CompletableFuture.runAsync {
                  JFileChooser chooser = waitFor('file chooser', Duration.ofSeconds(10)) {
                      AtomicReference<JFileChooser> chooserReference = new AtomicReference<JFileChooser>()
                      onEventDispatchThreadAndWait {
                          chooserReference.set(findShowingComponent(JFileChooser))
                      }
                      chooserReference.get()
                  }
                  onEventDispatchThreadAndWait {
                      chooser.setSelectedFile(scriptPath.toFile())
                      chooser.approveSelection()
                  }
              }
  
              CompletableFuture<Void> openAction = new CompletableFuture<Void>()
              SwingUtilities.invokeLater {
                  try {
                      showOpenPopupAndChooseFile(openButtonReference.get())
                      openAction.complete(null)
                  } catch (Throwable throwable) {
                      openAction.completeExceptionally(throwable)
                  }
              }
  
              chooserApproval.get(10, TimeUnit.SECONDS)
              openAction.get(10, TimeUnit.SECONDS)
  
              AtomicReference<JTextArea> scriptAreaReference = new AtomicReference<JTextArea>()
              AtomicReference<List<JToggleButton>> tokenButtonsReference = new AtomicReference<List<JToggleButton>>()
              onEventDispatchThreadAndWait {
                  LexerFrame frame = frameReference.get()
                  scriptAreaReference.set(findDescendant(frame, JTextArea) { JTextArea ignored -> true })
                  tokenButtonsReference.set(findDescendants(frame, JToggleButton))
              }
  
              assertThat(scriptAreaReference.get().text).isEqualTo(script)
              assertThat(tokenButtonsReference.get().collect { JToggleButton button -> button.toolTipText })
                      .contains('def', 'answer', '42', 'println')
          } finally {
              onEventDispatchThreadAndWait {
                  Window.getWindows().each { Window window -> window.dispose() }
              }
              Files.deleteIfExists(scriptPath)
          }
      }
  
      private static void showOpenPopupAndChooseFile(JButton openButton) {
          assertThat(openButton).isNotNull()
          MouseEvent releaseEvent = new MouseEvent(
                  openButton,
                  MouseEvent.MOUSE_RELEASED,
                  System.currentTimeMillis(),
                  0,
                  5,
                  5,
                  1,
                  false)
          openButton.mouseListeners.each { MouseListener listener -> listener.mouseReleased(releaseEvent) }
  
          JMenuItem openMenuItem = findSelectedPopupMenuItem('Open File...')
          assertThat(openMenuItem).isNotNull()
          openMenuItem.doClick()
      }
  
      private static JMenuItem findSelectedPopupMenuItem(String text) {
          Component[] selectedPath = MenuSelectionManager.defaultManager().selectedPath
                  .findAll { Object element -> element instanceof Component } as Component[]
          for (Component component : selectedPath) {
              JMenuItem menuItem = findDescendant(component, JMenuItem) { JMenuItem candidate -> candidate.text == text }
              if (menuItem != null) {
                  return menuItem
              }
          }
          for (Window window : Window.getWindows()) {
              JMenuItem menuItem = findDescendant(window, JMenuItem) { JMenuItem candidate -> candidate.text == text }
              if (menuItem != null) {
                  return menuItem
              }
          }
          return null
      }
  
      private static <T extends Component> T findShowingComponent(Class<T> type) {
          for (Window window : Window.getWindows()) {
              if (window.showing) {
                  T component = findDescendant(window, type) { Component ignored -> true }
                  if (component != null) {
                      return component
                  }
              }
          }
          return null
      }
  
      private static <T extends Component> T findDescendant(Component component, Class<T> type, Closure<Boolean> predicate) {
          if (type.isInstance(component) && predicate.call(type.cast(component))) {
              return type.cast(component)
          }
          if (component instanceof JPopupMenu) {
              for (Component child : ((JPopupMenu) component).components) {
                  T match = findDescendant(child, type, predicate)
                  if (match != null) {
                      return match
                  }
              }
          }
          if (component instanceof Container) {
              for (Component child : ((Container) component).components) {
                  T match = findDescendant(child, type, predicate)
                  if (match != null) {
                      return match
                  }
              }
          }
          return null
      }
  
      private static <T extends Component> List<T> findDescendants(Component component, Class<T> type) {
          List<T> matches = []
          collectDescendants(component, type, matches)
          return matches
      }
  
      private static <T extends Component> void collectDescendants(Component component, Class<T> type, List<T> matches) {
          if (type.isInstance(component)) {
              matches.add(type.cast(component))
          }
          if (component instanceof Container) {
              for (Component child : ((Container) component).components) {
                  collectDescendants(child, type, matches)
              }
          }
      }
  
      private static <T> T waitFor(String description, Duration timeout, Callable<T> supplier) {
          long deadline = System.nanoTime() + timeout.toNanos()
          while (System.nanoTime() < deadline) {
              T result = supplier.call()
              if (result != null) {
                  return result
              }
              Thread.sleep(50)
          }
          throw new AssertionError("Timed out waiting for ${description}")
      }
  
      private static void onEventDispatchThreadAndWait(Closure<?> action) {
          if (SwingUtilities.isEventDispatchThread()) {
              action.call()
          } else {
              SwingUtilities.invokeAndWait({ action.call() } as Runnable)
          }
      }
  }
