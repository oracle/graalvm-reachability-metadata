   if (SWING_BUTTON_CLASS_NAME == name) {\n                return Object\n            }\n            return super.loadClass(name)\n        }\n    }\n\n    private static final class EndOfFileTokenStream implements TokenStream {\n        @Override\n        Token nextToken() throws TokenStreamException {\n            return new Token(Token.EOF_TYPE, '<EOF>')\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 1979, "output": 1563, "cacheRead": 28160, "cacheWrite": 0, "totalTokens": 31702, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780959640688, "responseId": "resp_0dbb4ce0de75e3f7016a27499c8c6481909a76b1f59edf2392"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_YSlhootEnJGPpG8wRFs16Gxq|fc_0dbb4ce0de75e3f7016a2749b0ee648190b0cf0ccbbb080b0f", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 3280 bytes to tests/src/org.codehaus.groovy/groovy-all/2.3.6/src/test/groovy/org_codehaus_groovy/groovy_all/LLkDebuggingParserTest.groovy"}], "isError": false, "timestamp": 1780959671571}]}
