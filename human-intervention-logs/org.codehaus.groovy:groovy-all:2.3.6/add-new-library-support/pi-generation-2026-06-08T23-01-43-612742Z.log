rence.set(findDescendant(frame, JTextArea) { JTextArea ignored -> true })\n                tokenButtonsReference.set(findDescendants(frame, JToggleButton))\n            }\n\n            assertThat(scriptAreaReference.get().text).isEqualTo(script)\n            assertThat(tokenButtonsReference.get().collect { JToggleButton button -> button.toolTipText })\n                    .contains('def', 'answer', '42', 'println')\n        } finally {\n            onEventDispatchThreadAndWait {\n                Window.getWindows().each { Window window -> window.dispose() }\n            }\n            Files.deleteIfExists(scriptPath)\n        }\n    }\n\n    private static void showOpenPopupAndChooseFile(JButton openButton) {\n        assertThat(openButton).isNotNull()\n        MouseEvent releaseEvent = new MouseEvent(\n                openButton,\n                MouseEvent.MOUSE_RELEASED,\n                System.currentTimeMillis(),\n                0,\n                5,\n                5,\n                1,\n                false)\n        openButton.mouseListeners.each { MouseListener listener -> listener.mouseReleased(releaseEvent) }\n\n        JMenuItem openMenuItem = findSelectedPopupMenuItem('Open File...')\n        assertThat(openMenuItem).isNotNull()\n        openMenuItem.doClick()\n    }\n\n    private static JMenuItem findSelectedPopupMenuItem(String text) {\n        Component[] selectedPath = MenuSelectionManager.defaultManager().selectedPath\n                .findAll { Object element -> element instanceof Component } as Component[]\n        for (Component component : selectedPath) {\n            JMenuItem menuItem = findDescendant(component, JMenuItem) { JMenuItem candidate -> candidate.text == text }\n            if (menuItem != null) {\n                return menuItem\n            }\n        }\n        for (Window window : Window.getWindows()) {\n            JMenuItem menuItem = findDescendant(window, JMenuItem) { JMenuItem candidate -> candidate.text == text }\n            if (menuItem != null) {\n                return menuItem\n            }\n        }\n        return null\n    }\n\n    private static <T extends Component> T findShowingComponent(Class<T> type) {\n        for (Window window : Window.getWindows()) {\n            if (window.showing) {\n                T component = findDescendant(window, type) { Component ignored -> true }\n                if (component != null) {\n                    return component\n                }\n            }\n        }\n        return null\n    }\n\n    private static <T extends Component> T findDescendant(Component component, Class<T> type, Closure<Boolean> predicate) {\n        if (type.isInstance(component) && predicate.call(type.cast(component))) {\n            return type.cast(component)\n        }\n        if (component instanceof JPopupMenu) {\n            for (Component child : ((JPopupMenu) component).components) {\n                T match = findDescendant(child, type, predicate)\n                if (match != null) {\n                    return match\n                }\n            }\n        }\n        if (component instanceof Container) {\n            for (Component child : ((Container) component).components) {\n                T match = findDescendant(child, type, predicate)\n                if (match != null) {\n                    return match\n                }\n            }\n        }\n        return null\n    }\n\n    private static <T extends Component> List<T> findDescendants(Component component, Class<T> type) {\n        List<T> matches = []\n        collectDescendants(component, type, matches)\n        return matches\n    }\n\n    private static <T extends Component> void collectDescendants(Component component, Class<T> type, List<T> matches) {\n        if (type.isInstance(component)) {\n            matches.add(type.cast(component))\n        }\n        if (component instanceof Container) {\n            for (Component child : ((Container) component).components) {\n                collectDescendants(child, type, matches)\n            }\n        }\n    }\n\n    private static <T> T waitFor(String description, Duration timeout, Callable<T> supplier) {\n        long deadline = System.nanoTime() + timeout.toNanos()\n        while (System.nanoTime() < deadline) {\n            T result = supplier.call()\n            if (result != null) {\n                return result\n            }\n            Thread.sleep(50)\n        }\n        throw new AssertionError(\"Timed out waiting for ${description}\")\n    }\n\n    private static void onEventDispatchThreadAndWait(Closure<?> action) {\n        if (SwingUtilities.isEventDispatchThread()) {\n            action.call()\n        } else {\n            SwingUtilities.invokeAndWait({ action.call() } as Runnable)\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1780959583340}}
