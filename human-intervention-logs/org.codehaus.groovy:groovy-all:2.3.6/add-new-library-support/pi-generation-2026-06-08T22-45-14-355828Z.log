lass RejectingClassLoader extends ClassLoader {\n        RejectingClassLoader(ClassLoader parent) {\n            super(parent)\n        }\n\n        @Override\n        Class loadClass(String name) throws ClassNotFoundException {\n            throw new ClassNotFoundException(name)\n        }\n    }\n}\n"}
