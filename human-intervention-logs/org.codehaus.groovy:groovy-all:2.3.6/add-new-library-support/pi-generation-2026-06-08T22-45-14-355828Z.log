  package org_codehaus_groovy.groovy_all
  
  import groovyjarjarantlr.ASTFactory
  import groovyjarjarantlr.CommonAST
  import groovyjarjarantlr.CommonToken
  import groovyjarjarantlr.Token
  import groovyjarjarantlr.collections.AST
  import org.junit.jupiter.api.Test
  
  import static org.assertj.core.api.Assertions.assertThat
  
  public class ASTFactoryTest {
      @Test
      void createsDefaultAstNodeForTokenType() {
          ASTFactory factory = new ASTFactory()
  
          AST ast = factory.create(Token.MIN_USER_TYPE, 'identifier')
  
          assertThat(ast).isInstanceOf(CommonAST)
          assertThat(ast.type).isEqualTo(Token.MIN_USER_TYPE)
          assertThat(ast.text).isEqualTo('identifier')
      }
  
      @Test
      void createsAstNodeUsingTokenConstructorWhenAvailable() {
          ASTFactory factory = new ASTFactory()
          CommonToken token = new CommonToken(Token.MIN_USER_TYPE + 1, 'literal')
  
          AST ast = factory.create(token, CommonAST.name)
  
          assertThat(ast).isInstanceOf(CommonAST)
          assertThat(ast.type).isEqualTo(Token.MIN_USER_TYPE + 1)
          assertThat(ast.text).isEqualTo('literal')
      }
  }
