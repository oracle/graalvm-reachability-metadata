  package org_codehaus_groovy.groovy_all
  
  import groovyjarjarantlr.Utils
  import org.junit.jupiter.api.Test
  
  import java.net.URL
  import java.net.URLClassLoader
  
  import static org.assertj.core.api.Assertions.assertThat
  
  public class UtilsTest {
      @Test
      void loadsClassDirectlyWhenContextClassLoaderIsUnavailable() {
          Thread currentThread = Thread.currentThread()
          ClassLoader originalLoader = currentThread.contextClassLoader
          Class loadedClass
          try {
              currentThread.contextClassLoader = null
              loadedClass = Utils.loadClass('java.lang.String')
          } finally {
              currentThread.contextClassLoader = originalLoader
          }
  
          assertThat(loadedClass).isSameAs(String.class)
      }
  
      @Test
      void fallsBackToDirectClassLoadingWhenContextClassLoaderCannotLoadClass() {
          Thread currentThread = Thread.currentThread()
          ClassLoader originalLoader = currentThread.contextClassLoader
          Class loadedClass
          URLClassLoader isolatedLoader = new URLClassLoader(new URL[0], null)
          try {
              currentThread.contextClassLoader = isolatedLoader
              loadedClass = Utils.loadClass('groovy.lang.GroovyObject')
          } finally {
              currentThread.contextClassLoader = originalLoader
              isolatedLoader.close()
          }
  
          assertThat(loadedClass).isSameAs(GroovyObject.class)
      }
  
      @Test
      void createsInstanceFromClassName() {
          Object instance = Utils.createInstanceOf('java.lang.StringBuffer')
  
          assertThat(instance).isInstanceOf(StringBuffer.class)
          assertThat(instance.toString()).isEmpty()
      }
  
  }
