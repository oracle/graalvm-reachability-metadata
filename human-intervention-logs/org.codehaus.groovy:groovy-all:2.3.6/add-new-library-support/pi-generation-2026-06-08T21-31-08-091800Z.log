  package org_codehaus_groovy.groovy_all
  
  import groovy.util.Expando
  import org.codehaus.groovy.binding.ClosureTriggerBinding
  import org.codehaus.groovy.binding.FullBinding
  import org.codehaus.groovy.binding.TargetBinding
  import org.codehaus.groovy.binding.TriggerBinding
  import org.junit.jupiter.api.Test
  
  import java.util.LinkedHashMap
  import java.util.Map
  
  import static org.assertj.core.api.Assertions.assertThat
  
  public class ClosureTriggerBindingAnonymous1Test {
      @Test
      void createsBindingFromClosureThatReadsCapturedPropertyPath() {
          Map<String, TriggerBinding> syntheticBindings = new LinkedHashMap<String, TriggerBinding>()
          ClosureTriggerBinding triggerBinding = new ClosureTriggerBinding(syntheticBindings)
          def person = new Expando(name: 'Ada')
          triggerBinding.closure = { person.name }
          RecordingTargetBinding targetBinding = new RecordingTargetBinding()
  
          FullBinding binding = triggerBinding.createBinding(triggerBinding, targetBinding)
  
          assertThat(binding.targetBinding).isSameAs(targetBinding)
          binding.update()
          assertThat(targetBinding.value).isEqualTo('Ada')
  
          person.name = 'Grace'
          binding.update()
          assertThat(targetBinding.value).isEqualTo('Grace')
      }
  }
  
  class RecordingTargetBinding implements TargetBinding {
      Object value
  
      @Override
      void updateTargetValue(Object value) {
          this.value = value
      }
  }
