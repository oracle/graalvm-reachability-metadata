ort org.codehaus.groovy.binding.TargetBinding\nimport org.codehaus.groovy.binding.TriggerBinding\nimport org.junit.jupiter.api.Test\n\nimport static org.assertj.core.api.Assertions.assertThat\n\npublic class ClosureTriggerBindingAnonymous1Test {\n    @Test\n    void createsBindingFromClosureThatReadsCapturedPropertyPath() {\n        Map<String, TriggerBinding> syntheticBindings = new LinkedHashMap<>()\n        ClosureTriggerBinding triggerBinding = new ClosureTriggerBinding(syntheticBindings)\n        def person = new Expando(name: 'Ada')\n        triggerBinding.closure = { person.name }\n        RecordingTargetBinding targetBinding = new RecordingTargetBinding()\n\n        FullBinding binding = triggerBinding.createBinding(triggerBinding, targetBinding)\n\n        assertThat(binding.targetBinding).isSameAs(targetBinding)\n        binding.update()\n        assertThat(targetBinding.value).isEqualTo('Ada')\n\n        person.name = 'Grace'\n        binding.update()\n        assertThat(targetBinding.value).isEqualTo('Grace')\n    }\n}\n\nclass RecordingTargetBinding implements TargetBinding {\n    Object value\n\n    @Override\n    void updateTargetValue(Object value) {\n        this.value = value\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 894, "output": 911, "cacheRead": 29184, "cacheWrite": 0, "totalTokens": 30989, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780954189677, "responseId": "resp_0f4d73f10a916cff016a27344f9c6481939c1659124b26ce45"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_PLfXiuB72VWgDHLc66rRddAd|fc_0f4d73f10a916cff016a27345bc2a48193995918ec240f66e4", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1539 bytes to tests/src/org.codehaus.groovy/groovy-all/2.3.6/src/test/groovy/org_codehaus_groovy/groovy_all/ClosureTriggerBindingAnonymous1Test.groovy"}], "isError": false, "ti