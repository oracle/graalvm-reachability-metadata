  package org_codehaus_groovy.groovy_all
  
  import groovy.swing.LookAndFeelHelper
  import java.lang.invoke.MethodHandle
  import java.lang.invoke.MethodHandles
  import java.lang.invoke.MethodType
  import org.junit.jupiter.api.Test
  
  import static org.junit.jupiter.api.Assertions.assertThrows
  
  public class LookAndFeelHelperTest {
      @Test
      void resolvesOptionalLookAndFeelClassNames() {
          String nimbusLookAndFeel = LookAndFeelHelper.getNimbusLAFName()
          String aquaLookAndFeel = LookAndFeelHelper.getAquaLAFName()
          String substanceLookAndFeel = LookAndFeelHelper.getSubstanceLAFName()
  
          assert nimbusLookAndFeel == null || nimbusLookAndFeel.contains('NimbusLookAndFeel')
          assert aquaLookAndFeel == null || aquaLookAndFeel.contains('AquaLookAndFeel')
          assert substanceLookAndFeel == null || substanceLookAndFeel.contains('SubstanceLookAndFeel')
      }
  
      @Test
      void resolvesKnownClassThroughGeneratedClassHelper() {
          Class<?> resolvedClass = invokeGeneratedClassHelper('groovy.swing.LookAndFeelHelper')
  
          assert resolvedClass.name == 'groovy.swing.LookAndFeelHelper'
      }
  
      @Test
      void wrapsMissingClassLookupThroughGeneratedClassHelper() {
          NoClassDefFoundError error = assertThrows(NoClassDefFoundError) {
              invokeGeneratedClassHelper('groovy.swing.DoesNotExistLookAndFeel')
          }
  
          assert error.message == 'groovy.swing.DoesNotExistLookAndFeel'
      }
  
      private static Class<?> invokeGeneratedClassHelper(String className) {
          MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(LookAndFeelHelper, MethodHandles.lookup())
          MethodType methodType = MethodType.methodType(Class, String)
          MethodHandle classHelper = lookup.findStatic(LookAndFeelHelper, 'class$', methodType)
  
          return classHelper.invokeWithArguments(className) as Class<?>
      }
  }
