  public class Java5Test {
      @Test
      void configuresClassNodeUsingDeclaredMembersAndRuntimeAnnotations() {
          Java5 java5 = new Java5()
          ClassNode classNode = new ClassNode(Java5ConfiguredFixture)
  
          java5.configureClassNode(null, classNode)
  
          FieldNode fieldNode = classNode.fields.find { FieldNode field ->
              field.name == 'declaredValue'
          }
          MethodNode methodNode = classNode.methods.find { MethodNode method ->
              method.name == 'annotatedMethod'
          }
          AnnotationNode classAnnotation = classNode.annotations.find { AnnotationNode annotation ->
              annotation.classNode.name.endsWith('Java5FixtureAnnotation')
          }
  
          assert fieldNode != null
          assert methodNode != null
          assert classNode.declaredConstructors.size() >= 2
          assert classAnnotation != null
          assert classAnnotation.getMember('name') instanceof ConstantExpression
          assert classAnnotation.getMember('number') instanceof ConstantExpression
          assert classAnnotation.getMember('type') instanceof ClassExpression
          assert classAnnotation.getMember('tags') instanceof ListExpression
          assert methodNode.annotations.any { AnnotationNode annotation ->
              annotation.classNode.name.endsWith('Java5FixtureAnnotation')
          }
      }
  
      @Retention(RetentionPolicy.RUNTIME)
      @Target([
          ElementType.TYPE,
          ElementType.FIELD,
          ElementType.METHOD,
          ElementType.CONSTRUCTOR,
          ElementType.PARAMETER
      ])
      public @interface Java5FixtureAnnotation {
          String name()
  
          int number() default 7
  
          Class type() default String
  
          String[] tags() default []
      }
  
      @Java5FixtureAnnotation(name = 'fixture', number = 42, type = Integer, tags = ['class', 'annotation'])
      public static class Java5ConfiguredFixture {
          @Java5FixtureAnnotation(name = 'field', tags = ['field'])
          private String declaredValue
  
          public Java5ConfiguredFixture() {
              this('default')
          }
  
          @Java5FixtureAnnotation(name = 'constructor', tags = ['constructor'])
          public Java5ConfiguredFixture(String declaredValue) {
              this.declaredValue = declaredValue
          }
  
          @Java5FixtureAnnotation(name = 'method', tags = ['method'])
          public String annotatedMethod(@Java5FixtureAnnotation(name = 'parameter') String suffix) throws IOException {
              if (suffix == null) {
                  throw new IOException('suffix is required')
              }
              return declaredValue + suffix
          }
      }
  }
