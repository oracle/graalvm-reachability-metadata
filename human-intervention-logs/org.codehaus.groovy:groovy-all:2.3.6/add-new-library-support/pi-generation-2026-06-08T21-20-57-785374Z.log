  /*
   * Copyright and related rights waived via CC0
   *
   * You should have received a copy of the CC0 legalcode along with this
   * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.
   */
  package org_codehaus_groovy.groovy_all
  
  import groovy.lang.GroovyClassLoader
  import groovy.transform.ToString
  import org.codehaus.groovy.ast.AnnotationNode
  import org.codehaus.groovy.ast.ClassNode
  import org.codehaus.groovy.ast.CompileUnit
  import org.codehaus.groovy.ast.expr.ConstantExpression
  import org.codehaus.groovy.ast.expr.ListExpression
  import org.codehaus.groovy.control.CompilerConfiguration
  import org.codehaus.groovy.runtime.InvokerHelper
  import org.codehaus.groovy.transform.GroovyASTTransformationClass
  import org.codehaus.groovy.vmplugin.v5.Java5
  import org.junit.jupiter.api.Test
  
  import static org.assertj.core.api.Assertions.assertThat
  
  public class Java5Test {
      @Test
      void configuresDeclaredMembersFromLibraryClass() {
          Java5 java5 = new Java5()
          CompileUnit compileUnit = new CompileUnit(new GroovyClassLoader(), new CompilerConfiguration())
          ClassNode classNode = new ClassNode(InvokerHelper.class)
  
          java5.configureClassNode(compileUnit, classNode)
  
          assertThat(classNode.fields.collect { it.name }).contains('EMPTY_ARGS', 'metaRegistry')
          assertThat(classNode.methods.collect { it.name }).contains('invokeMethod', 'invokeConstructorOf')
          assertThat(classNode.declaredConstructors).isNotEmpty()
      }
  
      @Test
      void configuresRuntimeAnnotationMembersFromLibraryAnnotation() {
          Java5 java5 = new Java5()
          CompileUnit compileUnit = new CompileUnit(new GroovyClassLoader(), new CompilerConfiguration())
          ClassNode classNode = new ClassNode(ToString.class)
  
          java5.configureClassNode(compileUnit, classNode)
  
          AnnotationNode transformAnnotation = classNode.annotations.find {
              it.classNode.name == GroovyASTTransformationClass.name
          }
          assertThat(transformAnnotation).isNotNull()
  
          ListExpression value = transformAnnotation.getMember('value') as ListExpression
          assertThat(value.expressions.collect { ((ConstantExpression) it).value })
                  .containsExactly('org.codehaus.groovy.transform.ToStringASTTransformation')
  
          ListExpression classes = transformAnnotation.getMember('classes') as ListExpression
          assertThat(classes.expressions).isEmpty()
      }
  }
