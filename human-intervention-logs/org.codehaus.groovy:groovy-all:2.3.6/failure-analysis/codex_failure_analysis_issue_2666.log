oid configuresClassNodeMembersAndRuntimeAnnotationValues() {\\n        ClassNode classNode = new ClassNode(Java5CoverageSubject)\\n\\n        new Java5().configureClassNode(null, classNode)\\n\\n        FieldNode fieldNode = classNode.getField('items')\\n        MethodNode methodNode = classNode.getMethods('combine').find { MethodNode node ->\\n            node.parameters.length == 2\\n        }\\n        ConstructorNode constructorNode = classNode.declaredConstructors.find { ConstructorNode node ->\\n            node.parameters.length == 1\\n        }\\n        AnnotationNode classAnnotation = classNode.annotations.find { AnnotationNode annotationNode ->\\n            annotationNode.classNode.name == Java5CoverageMarker.name\\n        }\\n\\n        assertThat(fieldNode).isNotNull()\\n        assertThat(fieldNode.type.name).isEqualTo(List.name)\\n        assertThat(methodNode).isNotNull()\\n        assertThat(methodNode.returnType.name).isEqualTo(String.name)\\n        assertThat(methodNode.parameters*.type*.name).containsExactly(String.name, Integer.name)\\n        assertThat(methodNode.exceptions*.name).contains(IllegalStateException.name)\\n        assertThat(constructorNode).isNotNull()\\n        assertThat(constructorNode.parameters*.type*.name).containsExactly(String.name)\\n\\n        assertThat(classAnnotation).isNotNull()\\n        assertConstantExpression(classAnnotation.getMember('name'), 'coverage-subject')\\n        assertConstantExpression(classAnnotation.getMember('priority'), 7)\\n        assertClassExpression(classAnnotation.getMember('type'), Map)\\n        assertListExpression(classAnnotation.getMember('tags'), ['class', 'runtime'])\\n    }\\n\\n    private static void assertConstantExpression(Expression expression, Object expectedValue) {\\n        assertThat(expression).isInstanceOf(ConstantExpression)\\n        assertThat(((ConstantExpression) expression).value).isEqualTo(expectedValue)\\n    }\\n\\n    private static void assertClassExpression(Expression expression, Class<?> expectedType) {\\n        assertThat(expression).isInstanceOf(ClassExpression)\\n        assertThat(((ClassExpression) expression).type.name).isEqualTo(expectedType.name)\\n    }\\n\\n    private static void assertListExpression(Expression expression, List<?> expectedValues) {\\n        assertThat(expression).isInstanceOf(ListExpression)\\n        ListExpression listExpression = (ListExpression) expression\\n        assertThat(listExpression.expressions).hasSize(expectedValues.size())\\n        listExpression.expressions.eachWithIndex { Expression elementExpression, int index ->\\n            assertConstantExpression(elementExpression, expectedValues[index])\\n        }\\n    }\\n}\\n\\n@Retention(RetentionPolicy.RUNTIME)\\n@Target([ElementType.TYPE, ElementType.FIELD, ElementType.METHOD, ElementType.PARAMETER, ElementType.CONSTRUCTOR])\\n@interface Java5CoverageMarker {\\n    String name()\\n\\n    int priority() default 1\\n\\n    Class<?> type() default String.class\\n\\n    String[] tags() default []\\n}\\n\\n@Java5CoverageMarker(name = 'coverage-subject', priority = 7, type = Map.class, tags = ['class', 'runtime'])\\nclass Java5CoverageSubject {\\n    @Java5CoverageMarker(name = 'field', tags = ['field'])\\n    private List<String> items = []\\n\\n    @Java5CoverageMarker(name = 'constructor', tags = ['constructor'])\\n    Java5CoverageSubject(@Java5CoverageMarker(name = 'constructor-parameter') String initialItem) {\\n        items.add(initialItem)\\n    }\\n\\n    @Java5CoverageMarker(name = 'method', tags = ['method'])\\n    String combine(@Java5CoverageMarker(name = 'method-parameter') String prefix, Integer count) throws IllegalStateException {\\n        if (count < 0) {\\n            throw new IllegalStateException('count must not be negative')\\n        }\\n        return \\\"${prefix}:${items.take(count).join(',')}\\\"\\n    }\\n}\\n\"}], \"isError\": false, \"timestamp\": 1777707147878}}\nhuman-intervention-logs/org.co