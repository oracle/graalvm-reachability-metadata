qlClassLoaderFallback() {\n        try {\n            ClassLoader originalContextClassLoader = Thread.currentThread().getContextClassLoader()\n            SqlFallbackClassLoader sqlLoader = new SqlFallbackClassLoader(\n                    Sql.class.getClassLoader(),\n                    readSqlClassBytes())\n            Class<?> isolatedSqlClass = sqlLoader.loadClass(Sql.name)\n\n            try {\n                Thread.currentThread().setContextClassLoader(new RejectingClassLoader(\n                        originalContextClassLoader,\n                        VisibleDriver.name))\n                InvokerHelper.invokeStaticMethod(isolatedSqlClass, 'loadDriver', VisibleDriver.name)\n            } finally {\n                Thread.currentThread().setContextClassLoader(originalContextClassLoader)\n            }\n\n            assertThat(sqlLoader.rejectedClassForNameAttempt).isTrue()\n            assertThat(sqlLoader.loadedDriverFromSqlLoaderFallback).isTrue()\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error\n            }\n        }\n    }\n\n    @Test\n    void reportsClassNotFoundWhenDriverCannotBeResolved() {\n        ClassLoader originalContextClassLoader = Thread.currentThread().getContextClassLoader()\n\n        try {\n            Thread.currentThread().setContextClassLoader(new RejectingClassLoader(\n                    originalContextClassLoader,\n                    'org.example.jdbc.MissingDriver'))\n            assertThrows(ClassNotFoundException) {\n                Sql.loadDriver('org.example.jdbc.MissingDriver')\n            }\n        } finally {\n            Thread.currentThread().setContextClassLoader(originalContextClassLoader)\n        }\n    }\n\n    public static final class ContextOnlyDriverClassLoader extends ClassLoader {\n        public static final String CONTEXT_DRIVER_NAME = 'org.example.jdbc.ContextOnlyDriver'\n\n        private final Class<?> driverClass\n        public final List<String> requestedNames = []\n\n        ContextOnlyDriverClassLoader(Class<?> driverClass, ClassLoader parent) {\n            super(parent)\n            this.driverClass = driverClass\n        }\n\n        @Override\n        Class<?> loadClass(String name) throws ClassNotFoundException {\n            if (CONTEXT_DRIVER_NAME == name) {\n                requestedNames.add(name)\n                return driverClass\n            }\n            return super.loadClass(name)\n        }\n    }\n\n    private static byte[] readSqlClassBytes() throws IOException {\n        return readClassBytes(Sql.name)\n    }\n\n    private static byte[] readClassBytes(String className) throws IOException {\n        String resourceName = className.replace('.', '/') + '.class'\n        InputStream input = Sql.class.getClassLoader().getResourceAsStream(resourceName)\n        assertThat(input).isNotNull()\n        try {\n            return input.readAllBytes()\n        } finally {\n            input.close()\n        }\n    }\n\n    public static final class SqlFallbackClassLoader extends ClassLoader {\n        private final byte[] sqlClassBytes\n        public boolean rejectedClassForNameAttempt\n        public boolean loadedDriverFromSqlLoaderFallback\n\n        SqlFallbackClassLoader(ClassLoader parent, byte[] sqlClassBytes) {\n            super(parent)\n            this.sqlClassBytes = sqlClassBytes\n        }\n\n        @Override\n        Class<?> loadClass(String name) throws ClassNotFoundException {\n            if (Sql.name == name || name.startsWith(Sql.name + '$')) {\n                Class<?> loadedClass = findLoadedClass(name)\n                if (loadedClass != null) {\n                    return loadedClass\n                }\n                try {\n                    byte[] classBytes = Sql.name == name ? sqlClassBytes : readClassBytes(name)\n                    return defineClass(name, classBytes, 0, classBytes.length)\n                } catch (IOException exception) {\n                    throw new ClassNotFoundException(name, exception)\n                }\n            }\n            if (VisibleDriver.name == name && !rejectedClassForNameAttempt) {\n                rejectedClassForNameAttempt = true\n                throw new ClassNotFoundException(name)\n            }\n            if (VisibleDriver.name == name) {\n                loadedDriverFromSqlLoaderFallback = true\n            }\n            return super.loadClass(name)\n        }\n    }\n\n    public static final class RejectingClassLoader extends ClassLoader {\n        private final String rejectedName\n\n        RejectingClassLoader(ClassLoader parent, String rejectedName) {\n            super(parent)\n            this.rejectedName = rejectedName\n        }\n\n        @Override\n        Class<?> loadClass(String name) throws ClassNotFoundException {\n            if (rejectedName == name) {\n                throw new ClassNotFoundException(name)\n            }\n            return super.loadClass(name)\n        }\n    }\n\n    public static final class VisibleDriver implements Driver {\n        @Override\n        Connection connect(String url, Properties info) throws SQLException {\n            return null\n        }\n\n        @Override\n        boolean acceptsURL(String url) throws SQLException {\n            return false\n        }\n\n        @Override\n        DriverPropertyInfo[] getPropertyInfo(String url, Properties info) throws SQLException {\n            return new DriverPropertyInfo[0]\n        }\n\n        @Override\n        int getMajorVersion() {\n            return 1\n        }\n\n        @Override\n        int getMinorVersion() {\n            return 0\n        }\n\n        @Override\n        boolean jdbcCompliant() {\n            return false\n        }\n\n        @Override\n        Logger getParentLogger() throws SQLFeatureNotSupportedException {\n            return Logger.getLogger(VisibleDriver.name)\n        }\n    }\n}\n","exit_code":0