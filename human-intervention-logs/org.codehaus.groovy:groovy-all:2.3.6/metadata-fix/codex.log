{"type":"item.completed","item":{"id":"item_14","type":"command_execution","command":"/usr/bin/bash -lc \"sed -n '1,220p' tests/src/org.codehaus.groovy/groovy-all/2.3.6/src/test/groovy/org_codehaus_groovy/groovy_all/LexerFrameTest.groovy\"","aggregated_output":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_codehaus_groovy.groovy_all\n\nimport groovyjarjarantlr.Token\nimport java.awt.Component\nimport java.awt.Container\nimport java.lang.invoke.MethodHandle\nimport java.lang.invoke.MethodHandles\nimport java.lang.invoke.MethodType\nimport java.nio.file.Path\nimport java.util.Hashtable\nimport javax.swing.JToggleButton\nimport javax.swing.JTextArea\nimport javax.swing.JTextPane\nimport org.codehaus.groovy.antlr.LexerFrame\nimport org.codehaus.groovy.antlr.parser.GroovyLexer\nimport org.codehaus.groovy.antlr.parser.GroovyTokenTypes\nimport org.junit.jupiter.api.Test\nimport org.junit.jupiter.api.io.TempDir\nimport sun.misc.Unsafe\n\npublic class LexerFrameTest {\n    @TempDir\n    Path tempDir\n\n    @Test\n    void scansGroovyScriptIntoInteractiveTokenButtons() {\n        File script = tempDir.resolve('sample-script.groovy').toFile()\n        script.text = '''\\\ndef answer = 40 + 2\nprintln answer\n'''\n        HeadlessLexerFrame fixture = newHeadlessLexerFrame()\n\n        invokeListTokens(fixture.frame, GroovyTokenTypes.class)\n        invokeScanScript(fixture.frame, script)\n\n        List<JToggleButton> tokenButtons = descendants(fixture.tokenPane, JToggleButton.class)\n        List<String> tokenTexts = tokenButtons.collect { JToggleButton button ->\n            button.toolTipText\n        }\n        List<Token> tokens = tokenButtons.collect { JToggleButton button ->\n            button.getClientProperty('token') as Token\n        }\n\n        assert fixture.scriptPane.text == script.text\n        assert tokenTexts.contains('def')\n        assert tokenTexts.contains('answer')\n        assert tokenTexts.contains('println')\n        assert tokens.every { Token token -> token != null }\n        assert tokens.any { Token token -> token.type == Token.EOF_TYPE }\n    }\n\n    private static HeadlessLexerFrame newHeadlessLexerFrame() {\n        LexerFrame frame = unsafe().allocateInstance(LexerFrame) as LexerFrame\n        JTextPane tokenPane = new JTextPane()\n        JTextArea scriptPane = new JTextArea()\n        MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(LexerFrame.class, MethodHandles.lookup())\n\n        setField(lookup, frame, 'lexerClass', Class.class, GroovyLexer.class)\n        setField(lookup, frame, 'tokens', Hashtable.class, new Hashtable<Integer, String>())\n        setField(lookup, frame, 'tokenPane', JTextPane.class, tokenPane)\n        setField(lookup, frame, 'scriptPane', JTextArea.class, scriptPane)\n\n        return new HeadlessLexerFrame(frame, tokenPane, scriptPane)\n    }\n\n    private static void setField(MethodHandles.Lookup lookup, LexerFrame frame, String name, Class<?> type, Object value) throws Throwable {\n        MethodHandle setter = lookup.findSetter(LexerFrame.class, name, type)\n        setter.invokeWithArguments(frame, value)\n    }\n\n    private static Unsafe unsafe() throws Throwable {\n        MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(Unsafe.class, MethodHandles.lookup())\n        MethodHandle theUnsafe = lookup.findStaticGetter(Unsafe.class, 'theUnsafe', Unsafe.class)\n\n        return theUnsafe.invokeWithArguments() as Unsafe\n    }\n\n    private static void invokeListTokens(LexerFrame frame, Class<?> tokenTypes) throws Throwable {\n        MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(LexerFrame.class, MethodHandles.lookup())\n        MethodType methodType = MethodType.methodType(Void.TYPE, Class.class)\n        MethodHandle listTokens = lookup.findVirtual(LexerFrame.class, 'listTokens', methodType)\n\n        listTokens.invokeWithArguments(frame, tokenTypes)\n    }\n\n    private static void invokeScanScript(LexerFrame frame, File script) throws Throwable {\n        MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(LexerFrame.class, MethodHandles.lookup())\n        MethodType methodType = MethodType.methodType(Void.TYPE, File.class)\n        MethodHandle scanScript = lookup.findVirtual(LexerFrame.class, 'scanScript', methodType)\n\n        scanScript.invokeWithArguments(frame, script)\n    }\n\n    private static <T extends Component> List<T> descendants(Container container, Class<T> type) {\n        List<T> matches = []\n        for (Component component : container.components) {\n            if (type.isInstance(component)) {\n                matches.add(type.cast(component))\n            }\n            if (component instanceof Container) {\n                matches.addAll(descendants(component as Container, type))\n            }\n        }\n        return matches\n    }\n\n    private static class HeadlessLexerFrame {\n        final LexerFrame frame\n        final JTextPane tokenPane\n        final JTextArea scriptPane\n\n        HeadlessLexerFrame(LexerFrame frame, JTextPane tokenPane, JTextArea scriptPane) {\n            this.frame = frame\n            this.tokenPane = tokenPane\n            this.scriptPane = scriptPane\n        }\n    }\n}\n","exit_code":0,"status":"completed"}}
