ssertThat(restored).hasSize(original.size());\n        assertThat(restored.removeFirst()).isEqualTo(\"alpha\");\n        assertThat(restored.removeFirst()).isEqualTo(\"beta\");\n        assertThat(restored.removeFirst()).isEqualTo(\"gamma\");\n        assertThat(restored).isEmpty();\n    }\n\n    private static LinkedList createList() {\n        LinkedList list = new LinkedList();\n        list.addLast(\"alpha\");\n        list.addLast(\"beta\");\n        list.addLast(\"gamma\");\n        return list;\n    }\n\n    private static byte[] serialize(LinkedList list) throws IOException {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(list);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static LinkedList deserialize(byte[] bytes) throws IOException, ClassNotFoundException {\n        try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(bytes))) {\n            return (LinkedList) input.readObject();\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 446, "output": 811, "cacheRead": 13312, "cacheWrite": 0, "totalTokens": 14569, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777328980014, "responseId": "resp_059ff2c4127f96cc0169efe3547e98819fa4dbcc0fea509d99"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_6uO7OC4aJBZNmXdieqLsWrpq|fc_059ff2c4127f96cc0169efe3585d60819f81bffc1c866b95af", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2207 bytes to tests/src/backport-util-concurrent/backport-util-concurrent/3.1/src/test/java/backport_util_concurrent/backport_util_concurrent/LinkedListTest.java"}], "isError": false, "timestamp": 1777328988149}]}
