rt org.junit.jupiter.api.Test;\n\nimport java.util.LinkedHashMap;\nimport java.util.Map;\n\nimport static org.assertj.core.api.Assertions.assertThat;\nimport static org.assertj.core.api.Assertions.assertThatThrownBy;\n\npublic class CollectionsTest {\n    @Test\n    @SuppressWarnings({\"rawtypes\", \"unchecked\"})\n    void checkedMapEntrySetToArrayReturnsCheckedEntryViews() {\n        Map backingMap = new LinkedHashMap();\n        backingMap.put(\"name\", \"value\");\n        Map checkedMap = Collections.checkedMap(backingMap, String.class, String.class);\n\n        Object[] entries = checkedMap.entrySet().toArray();\n\n        assertThat(entries).hasSize(1);\n        assertThat(entries[0]).isInstanceOf(Map.Entry.class);\n\n        Map.Entry entry = (Map.Entry) entries[0];\n        assertThat(entry.getKey()).isEqualTo(\"name\");\n        assertThat(entry.getValue()).isEqualTo(\"value\");\n        assertThat(entry.setValue(\"updated\")).isEqualTo(\"value\");\n        assertThat(backingMap).containsEntry(\"name\", \"updated\");\n        assertThatThrownBy(() -> entry.setValue(1))\n                .isInstanceOf(ClassCastException.class);\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1119, "output": 781, "cacheRead": 25088, "cacheWrite": 0, "totalTokens": 26988, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777330106201, "responseId": "resp_09d65ffd15e47cd70169efe7baa33081a3a3a40fef2eb6dc31"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_EHxtQIbeVfuPVDG4Du6rYHjt|fc_09d65ffd15e47cd70169efe7bfab0881a39c08a9e99d09482b", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1438 bytes to tests/src/backport-util-concurrent/backport-util-concurrent/3.1/src/test/java/backport_util_concurrent/backport_util_concurrent/CollectionsTest.java"}], "isError": false, "timestamp": 1777330113409}]}
