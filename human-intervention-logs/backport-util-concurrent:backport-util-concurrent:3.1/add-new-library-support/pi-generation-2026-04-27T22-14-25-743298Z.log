.isEqualTo(\"alpha\");\n        assertThat(restored.get(\"secondary\")).isEqualTo(\"beta\");\n        assertThat(restored.get(Integer.valueOf(42))).isEqualTo(Long.valueOf(123456789L));\n    }\n\n    private static byte[] serialize(ConcurrentHashMap map) throws IOException {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(map);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static ConcurrentHashMap deserialize(byte[] bytes) throws IOException, ClassNotFoundException {\n        try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(bytes))) {\n            return (ConcurrentHashMap) input.readObject();\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1083, "output": 1047, "cacheRead": 17920, "cacheWrite": 0, "totalTokens": 20050, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777328022905, "responseId": "resp_081196e9fbb7c7960169efdf97410c81978543b67ef2ea26d4"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_ZSgWbbAjcqHLvTzPIVAMqiFg|fc_081196e9fbb7c7960169efdfa1067881978ba0fb50edcf5855", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1930 bytes to tests/src/backport-util-concurrent/backport-util-concurrent/3.1/src/test/java/backport_util_concurrent/backport_util_concurrent/ConcurrentHashMapTest.java"}], "isError": false, "timestamp": 1777328035115}]}
