esAndDeserializesElementsInFifoOrder() throws Exception {\n        ConcurrentLinkedQueue original = new ConcurrentLinkedQueue();\n        original.offer(\"first\");\n        original.offer(\"second\");\n        original.offer(\"third\");\n\n        ConcurrentLinkedQueue restored = deserialize(serialize(original));\n\n        assertThat(restored).isNotSameAs(original);\n        assertThat(restored).hasSize(3);\n        assertThat(restored.poll()).isEqualTo(\"first\");\n        assertThat(restored.poll()).isEqualTo(\"second\");\n        assertThat(restored.poll()).isEqualTo(\"third\");\n        assertThat(restored.poll()).isNull();\n        assertThat(restored).isEmpty();\n    }\n\n    private static byte[] serialize(ConcurrentLinkedQueue queue) throws IOException {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(queue);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static ConcurrentLinkedQueue deserialize(byte[] bytes) throws IOException, ClassNotFoundException {\n        try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(bytes))) {\n            return (ConcurrentLinkedQueue) input.readObject();\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 739, "output": 884, "cacheRead": 21504, "cacheWrite": 0, "totalTokens": 23127, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777329384592, "responseId": "resp_0e239e40b406e05d0169efe4e90b78819291fa4732388984bd"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_9rOpaWSuq5iXmLdYg27xa0BJ|fc_0e239e40b406e05d0169efe4f2669c81928ef3c711d340ee19", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1945 bytes to tests/src/backport-util-concurrent/backport-util-concurrent/3.1/src/test/java/