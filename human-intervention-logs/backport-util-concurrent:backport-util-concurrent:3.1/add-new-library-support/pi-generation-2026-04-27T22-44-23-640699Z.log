          int remaining;
          IOIterator(java.io.ObjectInputStream ois, int remaining) {
              this.ois = ois;
              this.remaining = remaining;
          }
          public boolean hasNext() {
              return remaining > 0;
          }
          public Object next() {
              if (remaining <= 0) throw new NoSuchElementException();
              remaining--;
