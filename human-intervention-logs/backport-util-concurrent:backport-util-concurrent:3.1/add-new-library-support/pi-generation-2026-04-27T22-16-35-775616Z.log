*/\n        public SimpleEntry(Object key, Object value) {\n            this.key   = key;\n            this.value = value;\n        }\n\n        /**\n         * Creates an entry representing the same mapping as the\n         * specified entry.\n         *\n         * @param entry the entry to copy\n\n[159 more lines in file. Use offset=81 to continue.]"}], "isError": false, "timestamp": 1777328171475}]}
