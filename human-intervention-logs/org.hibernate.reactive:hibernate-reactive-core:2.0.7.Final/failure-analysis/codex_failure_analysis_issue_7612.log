s/postgis-java\",\nmetadata/net.postgis/postgis-jdbc/index.json:7:    \"test-code-url\" : \"https://github.com/postgis/postgis-java/tree/postgis-java-aggregator-$version$/jdbc/src/test\",\nmetadata/net.postgis/postgis-jdbc/index.json:8:    \"documentation-url\" : \"https://repo.maven.apache.org/maven2/net/postgis/postgis-jdbc/$version$/postgis-jdbc-$version$-javadoc.jar\",\nmetadata/net.postgis/postgis-jdbc/index.json:9:    \"description\" : \"PostGIS JDBC provides PostgreSQL JDBC driver extensions that register PostGIS geometry and geography data types with Java JDBC connections. It builds on postgis-geometry and the PostgreSQL JDBC driver so applications can read, write, parse, and serialize spatial values in PostGIS databases.\",\nmetadata/io.prometheus/simpleclient_tracer_common/index.json:5:    \"source-code-url\" : \"https://repo1.maven.org/maven2/io/prometheus/simpleclient_tracer_common/$version$/simpleclient_tracer_common-$version$-sources.jar\",\nmetadata/io.prometheus/simpleclient_tracer_common/index.json:6:    \"repository-url\" : \"https://github.com/prometheus/client_java\",\n","exit_code":0,"status":"completed"}}
