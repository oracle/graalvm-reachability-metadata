etadata/com.fasterxml.jackson.dataformat/jackson-dataformat-cbor/index.json:6:    \"repository-url\" : \"https://github.com/FasterXML/jackson-dataformats-binary\",\nmetadata/com.fasterxml.jackson.dataformat/jackson-dataformat-cbor/index.json:7:    \"test-code-url\" : \"https://github.com/FasterXML/jackson-dataformats-binary/tree/jackson-dataformats-binary-$version$/cbor/src/test\",\nmetadata/com.fasterxml.jackson.dataformat/jackson-dataformat-cbor/index.json:8:    \"documentation-url\" : \"https://repo1.maven.org/maven2/com/fasterxml/jackson/dataformat/jackson-dataformat-cbor/$version$/jackson-dataformat-cbor-$version$-javadoc.jar\",\nmetadata/com.fasterxml.jackson.dataformat/jackson-dataformat-cbor/index.json:9:    \"description\" : \"Jackson Dataformat CBOR adds support for reading and writing Concise Binary Object Representation (CBOR) data through Jackson's streaming, data binding, and tree model APIs. It provides CBOR-specific parser, generator, factory, and mapper implementations so Java applications can serialize and deserialize objects and JSON-like structures in a compact binary format.\",\nmetadata/jakarta.authentication/jakarta.authentication-api/index.json:5:    \"source-code-url\" : \"https://repo.maven.apache.org/maven2/jakarta/authentication/jakarta.authentication-api/$version$/jakarta.authentication-api-$version$-sources.jar\",\nmetadata/jakarta.authentication/jakarta.authentication-api/index.json:6:    \"repository-url\" : \"https://github.com/jakartaee/authentication\",\nmetadata/jakarta.authentication/jakarta.authentication-api/index.json:7:    \"test-code-url\" : \"https://download.eclipse.org/jakartaee/authentication/3.0/jakarta-authentication-tck-$version$.zip\",\nmetadata/jakarta.authentication/jakarta.authentication-api/index.json:8:    \"documentation-url\" : \"https://repo.maven.apache.org/maven2/jakarta/authentication/jakarta.authentication-api/$version$/jakarta.authentication-api-$version$-javadoc.jar\",\nmetadata/jakarta.authentication/jakarta.authentication-api/index.json:9:    \"description\" : \"Jakarta Authentication defines a low-level SPI for authentication mechanisms that interact with callers and container environments to obtain credentials, validate them, and pass authenticated identities to the container. It also defines integration profiles that describe how containers such as Jakarta Servlet adapt to and use that SPI.\",\nmetadata/biz.aQute.bnd/biz.aQute.bnd.annotation/index.json:5:    \"source-code-url\" : \"https://repo1.maven.org/maven2/biz/aQute/bnd/biz.aQute.bnd.annotation/$version$/biz.aQute.bnd.annotation-$version$-sources.jar\",\nmetadata/biz.aQute.bnd/biz.aQute.bnd.annotation/index.json:6:    \"repository-url\" : \"https://github.com/bndtools/bnd\",\nmetadata/biz.aQute.bnd/biz.aQute.bnd.annotation/index.json:7:    \"test-code-url\" : \"https://github.com/bndtools/bnd/tree/$version$/biz.aQute.bndlib.tests/test/test\",\nmetadata/biz.aQute.bnd/biz.aQute.bnd.annotation/index.json:8:    \"documentation-url\" : \"https://repo1.maven.org/maven2/biz/aQute/bnd/biz.aQute.bnd.annotation/$version$/biz.aQute.bnd.annotation-$version$-javadoc.jar\",\nmetadata/biz.aQute.bnd/biz.aQute.bnd.annotation/index.json:9:    \"description\" : \"The biz.aQute.bnd.annotation artifact provides bnd-specific Java annotations for OSGi bundle metadata, package versioning, capabilities, service metadata, JPMS hints, licenses, and plugin declarations. These annotations are consumed by bnd and related tooling to generate or validate bundle headers and metadata without hard-coding that information in build instructions.\",\nmetadata/io.prometheus/simpleclient_tracer_otel_agent/index.json:5:    \"source-code-url\" : \"https://repo1.maven.org/maven2/io/prometheus/simpleclient_tracer_otel_agent/$version$/simpleclient_tracer_otel_agent-$version$-sources.jar\",\nmetadata/io.prometheus/simpleclient_tracer_otel_agent/index.json:6:    \"repository-url\" : \"https://github.com/prometheus/client_java\",\nmetadata/io.prometheus/simpleclient_tracer_otel_agent/index.json:7:    \"test-code-url\" : \"https://github.com/prometheus/client_java/tree/parent-$version$/integration_tests/it_exemplars_otel_agent\",\nmetadata/io.prometheus/simpleclient_tracer_otel_agent/index.json:8:    \"documentation-url\" : \"https://repo1.maven.org/maven2/io/prometheus/simpleclient_tracer_otel_agent/$version$/simpleclient_tracer_otel_agent-$version$-javadoc.jar\",\nmetadata/io.prometheus/simpleclient_tracer_otel_agent/index.json:9:    \"description\" : \"This artifact provides the Prometheus Java client SpanContextSupplier implementation for applications using the OpenTelemetry Java agent. It reads the current OpenTelemetry span context from the agent-shaded OpenTelemetry API so Prometheus exemplars can include valid trace and span IDs and sampled state.\",\nmetadata/com.fasterxml.jackson.dataformat/jackson-dataformat-toml/index.json:5:    \"source-code-url\" : \"https://repo1.maven.org/maven2/com/fasterxml/jackson/dataformat/jackson-dataformat-toml/$version$/jackson-dataformat-toml-$version$-sources.jar\",\nmetadata/com.fasterxml.jackson.dataformat/jackson-dataformat-toml/index.json:6:    \"repository-url\" : \"https://github.com/FasterXML/jackson-dataformats-text\",\nmetadata/com.fasterxml.jackson.dataformat/jackson-dataformat-toml/index.json:7:    \"test-code-url\" : \"https://github.com/FasterXML/jackson-dataformats-text/tree/jackson-dataformats-text-$version$/toml/src/test\",\nmetadata/com.fasterxml.jackson.dataformat/jackson-dataformat-toml/index.json:8:    \"documentation-url\" : \"https://repo1.maven.org/maven2/com/fasterxml/jackson/dataformat/jackson-dataformat-toml/$version$/jackson-dataformat-toml-$version$-javadoc.jar\",\nmetadata/com.fasterxml.jackson.dataformat/jackson-dataformat-toml/index.json:9:    \"description\" : \"Jackson Dataformat TOML adds Jackson support for reading and writing TOML documents. It provides TOML parsing and generation through Jackson's streaming and databinding APIs.\",\nmetadata/io.getquill/quill-engine_3/index.json:5:    \"source-code-url\" : \"https://repo.maven.apache.org/maven2/io/getquill/quill-engine_3/$version$/quill-engine_3-$version$-sources.jar\",\nmetadata/io.getquill/quill-engine_3/index.json:6:    \"repository-url\" : \"https://github.com/zio/zio-quill\",\nmetadata/io.getquill/quill-engine_3/index.json:7:    \"test-code-url\" : \"N/A\",\nmetadata/io.getquill/quill-engine_3/index.json:8:    \"documentation-url\" : \"https://repo.maven.apache.org/maven2/io/getquill/quill-engine_3/$version$/quill-engine_3-$version$-javadoc.jar\",\nmetadata/io.getquill/quill-engine_3/index.json:9:    \"description\" : \"ZIO Quill is a Scala library that provides a quoted DSL for expressing database queries and translating them to target languages such as SQL and CQL. The quill-engine module contains the shared query AST, normalization, idiom, dialect, and rendering infrastructure used by Quill contexts.\",\nmetadata/io.getquill/quill-engine_3/index.json:10:    \"language\" : {\nmetadata/io.prometheus/simpleclient_tracer_otel/index.json:5:    \"source-code-url\" : \"https://repo.maven.apache.org/maven2/io/prometheus/simpleclient_tracer_otel/$version$/simpleclient_tracer_otel-$version$-sources.jar\",\nmetadata/io.prometheus/simpleclient_tracer_otel/index.json:6:    \"repository-url\" : \"https://github.com/prometheus/client_java\",\nmetadata/io.prometheus/simpleclient_tracer_otel/index.json:7:    \"test-code-url\" : \"https://github.com/prometheus/client_java/tree/parent-$version$/integration_tests/it_exemplars_otel_sdk/src/test\",\nmetadata/io.prometheus/simpleclient_tracer_otel/index.json:8:    \"documentation-url\" : \"https://repo.maven.apache.org/maven2/io/prometheus/simpleclient_tracer_otel/$version$/simpleclient_tracer_otel-$version$-javadoc.jar\",\nmetadata/io.prometheus/simpleclient_tracer_otel/index.json:9:    \"description\" : \"simpleclient_tracer_otel connects the Prometheus Java simpleclient exemplar support to OpenTelemetry by reading the current trace and span context from the OpenTelemetry API. It lets Prometheus metrics include exemplars correlated with OpenTelemetry traces while remaining optional when OpenTelemetry is not available.\",\nmetadata/io.getquill/quill-engine_2.13/index.json:5:    \"source-code-url\" : \"https://repo.maven.apache.org/maven2/io/getquill/quill-engine_2.13/$version$/quill-engine_2.13-$version$-sources.jar\",\nmetadata/io.getquill/quill-engine_2.13/index.json:6:    \"repository-url\" : \"https://github.com/zio/zio-quill\",\nmetadata/io.getquill/quill-engine_2.13/index.json:7:    \"test-code-url\" : \"N/A\",\nmetadata/io.getquill/quill-engine_2.13/index.json:8:    \"documentation-url\" : \"https://repo.maven.apache.org/maven2/io/getquill/quill-engine_2.13/$version$/quill-engine_2.13-$version$-javadoc.jar\",\nmetadata/io.getquill/quill-engine_2.13/index.json:9:    \"description\" : \"ZIO Quill is a Scala library that provides a quoted DSL for expressing database queries and translating them to target languages such as SQL and CQL. The quill-engine module contains the shared query AST, normalization, idiom, dialect, and rendering infrastructure used by Quill contexts.\",\nmetadata/io.getquill/quill-engine_2.13/index.json:10:    \"language\" : {\nmetadata/com.fasterxml.jackson.dataformat/jackson-dataformat-yaml/index.json:5:    \"source-code-url\" : \"https://repo1.maven.org/maven2/com/fasterxml/jackson/dataformat/jackson-dataformat-yaml/$version$/jackson-dataformat-yaml-$version$-sources.jar\",\nmetadata/com.fasterxml.jackson.dataformat/jackson-dataformat-yaml/index.json:6:    \"repository-url\" : \"https://github.com/FasterXML/jackson-dataformats-text\",\nmetadata/com.fasterxml.jackson.dataformat/jackson-dataformat-yaml/index.json:7:    \"test-code-url\" : \"https://github.com/FasterXML/jackson-dataformats-text/tree/jackson-dataformats-text-$version$/yaml/src/test\",\nmetadata/com.fasterxml.jackson.dataformat/jackson-dataformat-yaml/index.json:8:    \"documentation-url\" : \"https://repo1.maven.org/maven2/com/fasterxml/jackson/dataformat/jackson-dataformat-yaml/$version$/jackson-dataformat-yaml-$version$-javadoc.jar\",\nmetadata/com.fasterxml.jackson.dataformat/jackson-dataformat-yaml/index.json:9:    \"description\" : \"Jackson Dataformat YAML provides Jackson-backed reading and writing of YAML data through the standard streaming and data-binding APIs. It integrates SnakeYAML as the underlying YAML parser and generator so Java applications can serialize and deserialize YAML alongside other Jackson data formats.\",\nmetadata/io.getquill/quill-util_3/index.json:5:    \"source-code-url\" : \"https://repo.maven.apache.org/maven2/io/getquill/quill-util_3/$version$/quill-util_3-$version$-sources.jar\",\nmetadata/io.getquill/quill-util_3/index.json:6:    \"repository-url\" : \"https://github.com/zio/zio-quill\",\nmetadata/io.getquill/quill-util_3/index.json:7:    \"test-code-url\" : \"N/A\",\nmetadata/io.getquill/quill-util_3/index.json:8:    \"documentation-url\" : \"https://repo.maven.apache.org/maven2/io/getquill/quill-util_3/$version$/quill-util_3-$version$-javadoc.jar\",\nmetadata/io.getquill/quill-util_3/index.json:9:    \"description\" : \"Quill is a Scala library for compile-time language-integrated database queries that translates quoted Scala code into query ASTs and target SQL or CQL. The quill-util module provides shared utility helpers used by the Quill runtime, including throwable extension helpers and Scalafmt-based formatting support.\",\nmetadata/io.getquill/quill-util_3/index.json:10:    \"language\" : {\nmetadata/net.postgis/postgis-geometry/index.json:5:    \"source-code-url\" : \"https://repo.maven.apache.org/maven2/net/postgis/postgis-geometry/$version$/postgis-geometry-$version$-sources.jar\",\nmetadata/net.postgis/postgis-geometry/index.json:6:    \"repository-url\" : \"https://github.com/postgis/postgis-java\",\nmetadata/net.postgis/postgis-geometry/index.json:7:    \"test-code-url\" : \"https://github.