);\n                    SessionFactoryImplementor sessionFactory = reactiveSession.getFactory();\n                    EntityMappingType entityMapping = sessionFactory.getRuntimeMetamodels()\n                            .getMappingMetamodel()\n                            .getEntityDescriptor(BatchAuthor.class);\n                    TestableReactiveEntityBatchLoaderArrayParam loader =\n                            new TestableReactiveEntityBatchLoaderArrayParam(entityMapping, sessionFactory);\n                    loader.prepare();\n                    return CompletableFuture.completedFuture(loader.resolveIds(1L, reactiveSession));\n                })\n                .toCompletableFuture()\n                .join();\n\n        assertThat(idsToInitialize).hasSize(4);\n        assertThat(idsToInitialize.getClass().getComponentType()).isEqualTo(Long.class);\n    }\n\n    private static void waitUntil(Callable<Boolean> conditionEvaluator, int timeoutSeconds, int sleepTimeSeconds) {\n        Exception lastException = null;\n        long end = System.currentTimeMillis() + TimeUnit.SECONDS.toMillis(timeoutSeconds);\n        while (System.currentTimeMillis() < end) {\n            try {\n                if (conditionEvaluator.call()) {\n                    return;\n                }\n            } catch (Exception e) {\n                lastException = e;\n            }\n            try {\n                Thread.sleep(TimeUnit.SECONDS.toMillis(sleepTimeSeconds));\n            } catch (InterruptedException e) {\n                Thread.currentThread().interrupt();\n                throw new IllegalStateException(\"Interrupted while waiting for PostgreSQL\", e);\n            }\n        }\n        String errorMessage = \"Condition was not fulfilled within \" + timeoutSeconds + \" seconds\";\n        if (lastException == null) {\n            throw new IllegalStateException(errorMessage);\n        }\n        throw new IllegalStateException(errorMessage, lastException);\n    }\n\n    private boolean isPostgresReady() throws IOException, InterruptedException {\n        Process pgReady = new ProcessBuilder(\n                \"docker\", \"exec\", CONTAINER_NAME, \"pg_isready\", \"-U\", USERNAME, \"-d\", DATABASE)\n                .redirectOutput(new File(\"postgres-entity-array-param-ready-stdout.txt\"))\n                .redirectError(new File(\"postgres-entity-array-param-ready-stderr.txt\"))\n                .start();\n        return pgReady.waitFor(5, TimeUnit.SECONDS) && pgReady.exitValue() == 0;\n    }\n\n    private static void stopStaleContainer() {\n        try {\n            new ProcessBuilder(\"docker\", \"rm\", \"-f\", CONTAINER_NAME).start().waitFor(10, TimeUnit.SECONDS);\n        } catch (IOException e) {\n            logger.debug(\"Could not remove PostgreSQL test container\", e);\n        } catch (InterruptedException e) {\n            Thread.currentThread().interrupt();\n            throw new IllegalStateException(\"Interrupted while removing PostgreSQL test container\", e);\n        }\n    }\n\n    private static final class TestableReactiveEntityBatchLoaderArrayParam\n            extends ReactiveEntityBatchLoaderArrayParam<BatchAuthor> {\n\n        private TestableReactiveEntityBatchLoaderArrayParam(\n                EntityMappingType entityDescriptor,\n                SessionFactoryImplementor sessionFactory) {\n            super(4, entityDescriptor, sessionFactory);\n        }\n\n        private Object[] resolveIds(Object pkValue, SharedSessionContractImplementor session) {\n            return resolveIdsToInitialize(pkValue, session);\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1779819894015}}
