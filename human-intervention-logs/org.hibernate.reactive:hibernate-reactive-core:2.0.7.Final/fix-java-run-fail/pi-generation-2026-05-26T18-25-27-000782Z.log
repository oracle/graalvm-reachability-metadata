  		}
  
  		return ids;
  	}
  
  	private <X> X[] createTypedArray(@SuppressWarnings("SameParameterValue") int length) {
  		//noinspection unchecked
  		return (X[]) Array.newInstance( getIdentifierMapping().getJavaType().getJavaTypeClass(), length );
  	}
  
  	@Override
  	public void prepare() {
  		super.prepare();
  
