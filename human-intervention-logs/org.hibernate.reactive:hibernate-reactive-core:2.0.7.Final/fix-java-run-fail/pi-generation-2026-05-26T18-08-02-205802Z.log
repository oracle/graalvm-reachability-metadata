  import jakarta.persistence.Id;
  import jakarta.persistence.ManyToOne;
  
  @Entity
  public class BatchEmployee {
  
      @Id
      @GeneratedValue
      private Long id;
  
      private String name;
  
      @ManyToOne
      private BatchDepartment department;
  
      public BatchEmployee() {
      }
  
      public BatchEmployee(String name) {
          this.name = name;
      }
  
      public Long getId() {
          return id;
      }
  
      public String getName() {
          return name;
      }
  
      public BatchDepartment getDepartment() {
          return department;
