  package org_hibernate_reactive.hibernate_reactive_core.entity;
  
  import jakarta.persistence.CascadeType;
  import jakarta.persistence.Entity;
  import jakarta.persistence.GeneratedValue;
  import jakarta.persistence.Id;
  import jakarta.persistence.OneToMany;
  import org.hibernate.annotations.BatchSize;
  
  import java.util.ArrayList;
  import java.util.List;
  
  @Entity
  public class BatchDepartment {
  
      @Id
      @GeneratedValue
      private Long id;
  
      private String name;
  
      @OneToMany(mappedBy = "department", cascade = CascadeType.ALL)
      @BatchSize(size = 4)
      private List<BatchEmployee> employees = new ArrayList<>();
  
      public BatchDepartment() {
      }
  
      public BatchDepartment(String name) {
          this.name = name;
      }
  
      public Long getId() {
          return id;
      }
  
      public String getName() {
          return name;
      }
  
      public List<BatchEmployee> getEmployees() {
          return employees;
      }
  
      public void addEmployee(BatchEmployee employee) {
          employees.add(employee);
          employee.setDepartment(this);
      }
  }
