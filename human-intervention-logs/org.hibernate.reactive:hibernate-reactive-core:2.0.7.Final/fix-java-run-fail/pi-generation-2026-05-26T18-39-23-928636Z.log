          Map<String, String> properties = new HashMap<>();
          properties.put("jakarta.persistence.jdbc.url", "jdbc:postgresql://localhost:5433/test");
          properties.put("hibernate.dialect", "org.hibernate.dialect.PostgreSQLDialect");
