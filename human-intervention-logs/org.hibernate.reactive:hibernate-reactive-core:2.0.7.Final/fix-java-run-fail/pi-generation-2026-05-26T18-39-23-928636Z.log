nBuilderImpl(sessionFactory);\n        return connectionPool.getConnection()\n                .thenApply(connection -> new ReactiveSessionImpl(sessionFactory, options, connection));\n    }\n\n    private <T> T awaitInReactiveContext(Supplier<CompletionStage<T>> work) {\n        CompletableFuture<T> future = new CompletableFuture<>();\n        ((Implementor) factory).getContext().execute(() -> {\n            try {\n                work.get().whenComplete((value, failure) -> {\n                    if (failure != null) {\n                        future.completeExceptionally(failure);\n                    }\n                    else {\n                        future.complete(value);\n                    }\n                });\n            }\n            catch (Throwable throwable) {\n                future.completeExceptionally(throwable);\n            }\n        });\n        return future.join();\n    }\n"}]}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 2805, "output": 1357, "cacheRead": 54784, "cacheWrite": 0, "totalTokens": 58946, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1779820817762, "responseId": "resp_08478571cc423ec1016a15e91275e881a3a7b7752f3eb440aa"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_SrlDxhMp5INPwmb2l8clJMuJ|fc_08478571cc423ec1016a15e918c84c81a394e6af4aa952ee9a", "toolName": "edit", "content": [{"type": "text", "text": "Successfully replaced 4 block(s) in tests/src/org.hibernate.reactive/hibernate-reactive-core/2.0.7.Final/src/test/java/org_hibernate_reactive/hibernate_reactive_core/ReactiveMultiIdEntityLoaderStandardTest.java."}], "details": {"diff": "     ...\n  14 import org.hibernate.internal.SessionCreationOptions;\n  15 import org.hibernate.internal.SessionFactoryImpl;\n  16 import org.hibernate.loader.ast.spi.MultiIdLoadOptions;\n  17 import org.hibernate.persister.entity.EntityPersister;\n+ 18 import org.hib