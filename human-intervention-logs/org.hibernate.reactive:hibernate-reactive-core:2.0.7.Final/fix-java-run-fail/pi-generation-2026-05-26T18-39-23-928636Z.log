ibernate.reactive.persister.entity.impl.ReactiveEntityPersister;\n"}, {"oldText": "import java.util.concurrent.Callable;\n", "newText": "import java.util.concurrent.Callable;\nimport java.util.concurrent.CompletableFuture;\nimport java.util.concurrent.CompletionException;\nimport java.util.concurrent.CompletionStage;\nimport java.util.function.Supplier;\n"}, {"oldText": "        ReactiveSessionImpl session = openReactiveSession();\n        try {\n            BatchAuthor cachedAuthor = session.reactiveFind(BatchAuthor.class, alreadyManaged.getId(), null, null)\n                    .toCompletableFuture()\n                    .join();\n            assertThat(cachedAuthor.getName()).isEqualTo(alreadyManaged.getName());\n\n            List<?> authors = reactivePersister().reactiveMultiLoad(\n                            new Long[] { alreadyManaged.getId(), loadedFromDatabase.getId() },\n                            session,\n                            new UnorderedSessionCheckingOptions())\n                    .toCompletableFuture()\n                    .join();\n\n            assertThat(authors)\n                    .hasSize(2)\n                    .extracting(\"name\")\n                    .containsExactlyInAnyOrder(alreadyManaged.getName(), loadedFromDatabase.getName());\n        }\n        finally {\n            session.reactiveClose().toCompletableFuture().join();\n        }\n", "newText": "        List<?> authors = awaitInReactiveContext(() -> openReactiveSession()\n                .thenCompose(session -> session.reactiveFind(BatchAuthor.class, alreadyManaged.getId(), null, null)\n                        .thenCompose(cachedAuthor -> {\n                            assertThat(cachedAuthor.getName()).isEqualTo(alreadyManaged.getName());\n                            return reactivePersister().reactiveMultiLoad(\n                                    new Long[] { alreadyManaged.getId(), loadedFromDatabase.getId() },\n                                    session,\n          