  		@SuppressWarnings("unchecked")
  		public CompletionStage<List<T>> multiLoad(Object... ids) {
  			Object[] sids = new Object[ids.length];
  			System.arraycopy( ids, 0, sids, 0, ids.length );
  
  			return perform( () -> (CompletionStage)
