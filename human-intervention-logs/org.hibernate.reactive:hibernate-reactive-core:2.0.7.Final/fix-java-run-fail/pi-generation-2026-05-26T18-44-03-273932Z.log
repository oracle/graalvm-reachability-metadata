  		}
  	}
  
  	public static URI parse(String url) {
  		if ( url == null || url.isBlank() ) {
  			throw LOG.blankConnectionString( Settings.URL );
  		}
  
  		if ( url.startsWith( "jdbc:" ) ) {
  			return URI.create( url.substring( 5 ) );
  		}
  
  		return URI.create( url );
  	}
  }
