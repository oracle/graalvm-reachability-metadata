ion> getConnection() {\n        return unsupportedConnectionRequest();\n    }\n\n    @Override\n    public CompletionStage<ReactiveConnection> getConnection(SqlExceptionHelper sqlExceptionHelper) {\n        return unsupportedConnectionRequest();\n    }\n\n    @Override\n    public CompletionStage<ReactiveConnection> getConnection(String tenantId) {\n        return unsupportedConnectionRequest();\n    }\n\n    @Override\n    public CompletionStage<ReactiveConnection> getConnection(String tenantId, SqlExceptionHelper sqlExceptionHelper) {\n        return unsupportedConnectionRequest();\n    }\n\n    @Override\n    public CompletionStage<Void> getCloseFuture() {\n        return CompletableFuture.completedFuture(null);\n    }\n\n    private static CompletionStage<ReactiveConnection> unsupportedConnectionRequest() {\n        return CompletableFuture.failedFuture(new UnsupportedOperationException(\"connection acquisition is not used in this test\"));\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 2112, "output": 1486, "cacheRead": 25088, "cacheWrite": 0, "totalTokens": 28686, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1779820949110, "responseId": "resp_0f88f54e0e978645016a15e99596b8819eabfd8c890f313cbe"}}
