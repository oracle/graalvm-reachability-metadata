[tool-call] delta {"path":"tests/src/org.hibernate.reactive/hibernate-reactive-core/2.0.7.Final/src/test/java/org_hibernate_reactive/hibernate_reactive_core/ReactiveEntityBatchLoaderArrayParamTest.java","edits":[{"oldText":"import org_hibernate_reactive.hibernate_reactive_core.entity.BatchArticle;\nimport org_hibernate_reactive.hibernate_reactive_core.entity.BatchAuthor;\n","newText":"import org_hibernate_reactive.hibernate_reactive_core.entity.BatchAuthor;\n"},{"oldText":"    void fetchesLazyManyToOneEntitiesUsingSqlArrayBatchLoader() {\n        BatchAuthor ada = new BatchAuthor(\"Ada Lovelace\");\n        BatchAuthor grace = new BatchAuthor(\"Grace Hopper\");\n        BatchAuthor katherine = new BatchAuthor(\"Katherine Johnson\");\n\n        factory.withTransaction((session, tx) -> session.persist(ada, grace, katherine)\n                        .thenCompose(v -> session.persist(\n                                new BatchArticle(\"Analytical engine notes\", ada),\n                                new BatchArticle(\"Compiler notes\", grace),\n                                new BatchArticle(\"Orbital mechanics\", katherine))))\n                .toCompletableFuture()\n                .join();\n\n        List<String> names = factory.withSession(session -> session\n                        .createQuery(\"from BatchArticle order by title\", BatchArticle.class)\n                        .getResultList()\n                        .thenCompose(articles -> {\n                            assertThat(articles).hasSize(3);\n                            return session.fetch(articles.get(0).getAuthor())\n                                    .thenCompose(firstAuthor -> session.fetch(articles.get(1).getAuthor())\n                                            .thenApply(secondAuthor -> List.of(\n                                                    firstAuthor.getName(),\n                                                    secondAuthor.getName())));\n                        }))\n                .toCompletableFuture()\n                .join();\n\n        assertThat(names).containsExactly(\"Ada Lovelace\", \"Grace Hopper\");\n    }\n","newText":"    void findsBatchSizedEntityUsingSqlArrayBatchLoader() {\n        BatchAuthor ada = new BatchAuthor(\"Ada Lovelace\");\n        BatchAuthor grace = new BatchAuthor(\"Grace Hopper\");\n        BatchAuthor katherine = new BatchAuthor(\"Katherine Johnson\");\n\n        factory.withTransaction((session, tx) -> session.persist(ada, grace, katherine))\n                .toCompletableFuture()\n                .join();\n\n        BatchAuthor author = factory.withSession(session -> session.find(BatchAuthor.class, ada.getId()))\n                .toCompletableFuture()\n                .join();\n\n        assertThat(author.getName()).isEqualTo(\"Ada Lovelace\");\n    }\n"}]}
[tool-call] end id=call_DHsegEsmsLzkcdI8NFpI363c|fc_04a8a56e44fb2ef1016a15e3aaeda881a1b518c92f54a60397 name=edit args={"path": "tests/src/org.hibernate.reactive/hibernate-reactive-core/2.0.7.Final/src/test/java/org_hibernate_reactive/hibernate_reactive_core/ReactiveEntityBatchLoaderArrayParamTest.java", "edits": [{"oldText": "import org_hibernate_reactive.hibernate_reactive_core.entity.BatchArticle;\nimport org_hibernate_reactive.hibernate_reactive_core.entity.BatchAuthor;\n", "newText": "import org_hibernate_reactive.hibernate_reactive_core.entity.BatchAuthor;\n"}, {"oldText": "    void fetchesLazyManyToOneEntitiesUsingSqlArrayBatchLoader() {\n        BatchAuthor ada = new BatchAuthor(\"Ada Lovelace\");\n        BatchAuthor grace = new BatchAuthor(\"Grace Hopper\");\n        BatchAuthor katherine = new BatchAuthor(\"Katherine Johnson\");\n\n        factory.withTransaction((session, tx) -> session.persist(ada, grace, katherine)\n                        .thenCompose(v -> session.persist(\n                                new BatchArticle(\"Analytical engine notes\", ada),\n                                new BatchArticle(\"Compiler notes\", grace),\n                                new BatchArticle(\"Orbital mechanics\", katherine))))\n                .toCompletableFuture()\n                .join();\n\n        List<String> names = factory.withSession(session -> session\n                        .createQuery(\"from BatchArticle order by title\", BatchArticle.class)\n                        .getResultList()\n                        .thenCompose(articles -> {\n                            assertThat(articles).hasSize(3);\n                            return session.fetch(articles.get(0).getAuthor())\n                                    .thenCompose(firstAuthor -> session.fetch(articles.get(1).getAuthor())\n                                            .thenApply(secondAuthor -> List.of(\n                                                    firstAuthor.getName(),\n                                                    secondAuthor.getName())));\n                        }))\n                .toCompletableFuture()\n                .join();\n\n        assertThat(names).containsExactly(\"Ada Lovelace\", \"Grace Hopper\");\n    }\n", "newText": "    void findsBatchSizedEntityUsingSqlArrayBatchLoader() {\n        BatchAuthor ada = new BatchAuthor(\"Ada Lovelace\");\n        BatchAuthor grace = new BatchAuthor(\"Grace Hopper\");\n        BatchAuthor katherine = new BatchAuthor(\"Katherine Johnson\");\n\n        factory.withTransaction((session, tx) -> session.persist(ada, grace, katherine))\n                .toCompletableFuture()\n                .join();\n\n        BatchAuthor author = factory.withSession(session -> session.find(BatchAuthor.class, ada.getId()))\n                .toCompletableFuture()\n                .join();\n\n        assertThat(author.getName()).isEqualTo(\"Ada Lovelace\");\n    }\n"}]}
