[tool-call] delta {"path":"tests/src/org.hibernate.reactive/hibernate-reactive-core/2.0.7.Final/src/test/java/org_hibernate_reactive/hibernate_reactive_core/ReactiveEntityBatchLoaderArrayParamTest.java","edits":[{"oldText":"    void findsBatchSizedEntityUsingSqlArrayBatchLoader() {\n        BatchAuthor ada = new BatchAuthor(\"Ada Lovelace\");\n        BatchAuthor grace = new BatchAuthor(\"Grace Hopper\");\n        BatchAuthor katherine = new BatchAuthor(\"Katherine Johnson\");\n\n        factory.withTransaction((session, tx) -> session.persist(ada, grace, katherine))\n                .toCompletableFuture()\n                .join();\n\n        BatchAuthor author = factory.withSession(session -> session.find(BatchAuthor.class, ada.getId()))\n                .toCompletableFuture()\n                .join();\n\n        assertThat(author.getName()).isEqualTo(\"Ada Lovelace\");\n    }\n","newText":"    void findsAbsentBatchSizedEntityUsingSqlArrayBatchLoader() {\n        BatchAuthor author = factory.withSession(session -> session.find(BatchAuthor.class, 1L))\n                .toCompletableFuture()\n                .join();\n\n        assertThat(author).isNull();\n    }\n"}]}
