  @Entity
  public class BatchDepartment {
  
      @Id
      @GeneratedValue
      private Long id;
  
      private String name;
  
      @OneToMany(mappedBy = "department", cascade = CascadeType.ALL)
      @BatchSize(size = 4)
      private List<BatchEmployee> employees = new ArrayList<>();
  
