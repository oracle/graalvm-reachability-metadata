[tool-call] delta {"path":"tests/src/org.hibernate.reactive/hibernate-reactive-core/2.0.7.Final/src/test/java/org_hibernate_reactive/hibernate_reactive_core/ReactiveEntityBatchLoaderArrayParamTest.java","edits":[{"oldText":"import jakarta.persistence.Persistence;\nimport org.hibernate.reactive.stage.Stage.SessionFactory;\n","newText":"import jakarta.persistence.Persistence;\nimport org.hibernate.engine.spi.SessionFactoryImplementor;\nimport org.hibernate.engine.spi.SharedSessionContractImplementor;\nimport org.hibernate.metamodel.mapping.EntityMappingType;\nimport org.hibernate.reactive.loader.ast.internal.ReactiveEntityBatchLoaderArrayParam;\nimport org.hibernate.reactive.session.ReactiveSharedSessionContractImplementor;\nimport org.hibernate.reactive.stage.Stage.SessionFactory;\n"},{"oldText":"import java.util.concurrent.Callable;\nimport java.util.concurrent.TimeUnit;\n","newText":"import java.util.concurrent.Callable;\nimport java.util.concurrent.CompletableFuture;\nimport java.util.concurrent.TimeUnit;\n"},{"oldText":"    void findsAbsentBatchSizedEntityUsingSqlArrayBatchLoader() {\n        BatchAuthor author = factory.withSession(session -> session.find(BatchAuthor.class, 1L))\n                .toCompletableFuture()\n                .join();\n\n        assertThat(author).isNull();\n    }\n","newText":"    void preparesAndResolvesIdsUsingSqlArrayBatchLoader() {\n        Object[] idsToInitialize = factory.withSession(session -> {\n                    ReactiveSharedSessionContractImplementor reactiveSession = session.unwrap(\n                            ReactiveSharedSessionContractImplementor.class);\n                    SessionFactoryImplementor sessionFactory = reactiveSession.getFactory();\n                    EntityMappingType entityMapping = sessionFactory.getRuntimeMetamodels()\n                            .getMappingMetamodel()\n                            .getEntityDescriptor(BatchAuthor.class);\n                    TestableReactiveEntityBatchLoaderArrayParam loader =\n                            new TestableReactiveEntityBatchLoaderArrayParam(entityMapping, sessionFactory);\n                    loader.prepare();\n                    return CompletableFuture.completedFuture(loader.resolveIds(1L, reactiveSession));\n                })\n                .toCompletableFuture()\n                .join();\n\n        assertThat(idsToInitialize).hasSize(4);\n        assertThat(idsToInitialize.getClass().getComponentType()).isEqualTo(Long.class);\n    }\n"}]}
