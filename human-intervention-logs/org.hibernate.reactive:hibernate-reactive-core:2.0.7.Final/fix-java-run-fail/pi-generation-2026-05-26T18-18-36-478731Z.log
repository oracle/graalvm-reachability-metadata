  	@Override
  	public <T> CompletionStage<T> find(EntityGraph<T> entityGraph, Object id) {
  		Class<T> entityClass = ( (RootGraph<T>) entityGraph ).getGraphedType().getJavaType();
  		return delegate.reactiveFind( entityClass, id, null, entityGraph );
  	}
  
