private static final String DATABASE = \"test\";\n\n    private static final String CONTAINER_NAME = \"hibernate-reactive-entity-array-param-postgres\";\n\n    private static final String JDBC_URL = \"jdbc:postgresql://localhost:5433/\" + DATABASE;\n\n    private static Process process;\n\n    private SessionFactory factory;\n\n    @BeforeAll\n    public void init() throws IOException {\n        logger.info(\"Starting PostgreSQL ...\");\n        stopStaleContainer();\n        process = new ProcessBuilder(\n                \"docker\", \"run\", \"--rm\", \"--name\", CONTAINER_NAME, \"-p\", \"5433:5432\", \"-e\", \"POSTGRES_DB=\" + DATABASE,\n                \"-e\", \"POSTGRES_USER=\" + USERNAME, \"-e\", \"POSTGRES_PASSWORD=\" + PASSWORD, \"postgres:18-alpine\")\n                .redirectOutput(new File(\"postgres-entity-array-param-stdout.txt\"))\n                .redirectError(new File(\"postgres-entity-array-param-stderr.txt\"))\n                .start();\n\n        waitUntil(this::isPostgresReady, 60, 1);\n        logger.info(\"PostgreSQL started\");\n\n        Map<String, String> properties = new HashMap<>();\n        properties.put(\"jakarta.persistence.jdbc.url\", JDBC_URL);\n        properties.put(\"jakarta.persistence.jdbc.user\", USERNAME);\n        properties.put(\"jakarta.persistence.jdbc.password\", PASSWORD);\n        factory = Persistence.createEntityManagerFactory(\"postgres-entity-array-param-batch\", properties)\n                .unwrap(SessionFactory.class);\n    }\n\n    @AfterAll\n    public void close() {\n        if (factory != null) {\n            factory.close();\n        }\n        if (process != null && process.isAlive()) {\n            logger.info(\"Shutting down PostgreSQL\");\n            process.destroy();\n        }\n        stopStaleContainer();\n    }\n\n    @Test\n    void fetchesLazyManyToOneEntitiesUsingSqlArrayBatchLoader() {\n        BatchAuthor ada = new BatchAuthor(\"Ada Lovelace\");\n        BatchAuthor grace = new BatchAuthor(\"Grace Hopper\");\n        BatchAuthor katherine = new BatchAuthor(\"Katherine Johnson\");\n\n        factory.withTransaction((session, tx) -> session.persist(\n                        new BatchArticle(\"Analytical engine notes\", ada),\n                        new BatchArticle(\"Compiler notes\", grace),\n                        new BatchArticle(\"Orbital mechanics\", katherine)))\n                .toCompletableFuture()\n                .join();\n\n        List<String> names = factory.withSession(session -> session\n                        .createQuery(\"from BatchArticle order by title\", BatchArticle.class)\n                        .getResultList()\n                        .thenCompose(articles -> {\n                            assertThat(articles).hasSize(3);\n                            return session.fetch(articles.get(0).getAuthor())\n                                    .thenCompose(firstAuthor -> session.fetch(articles.get(1).getAuthor())\n                                            .thenApply(secondAuthor -> List.of(firstAuthor.getName(), secondAuthor.getName())));\n                        }))\n                .toCompletableFuture()\n                .join();\n\n        assertThat(names).containsExactly(\"Ada Lovelace\", \"Grace Hopper\");\n    }\n\n    private static void waitUntil(Callable<Boolean> conditionEvaluator, int timeoutSeconds, int sleepTimeSeconds) {\n        Exception lastException = null;\n        long end = System.currentTimeMillis() + TimeUnit.SECONDS.toMillis(timeoutSeconds);\n        while (System.currentTimeMillis() < end) {\n            try {\n                if (conditionEvaluator.call()) {\n                    return;\n                }\n            } catch (Exception e) {\n                lastException = e;\n            }\n            try {\n                Thread.sleep(TimeUnit.SECONDS.toMillis(sleepTimeSeconds));\n            } catch (InterruptedException e) {\n                Thread.currentThread().interrupt();\n                throw new IllegalStateException(\"Interrupted while waiting for PostgreSQL\", e);\n            }\n        }\n        String errorMessage = \"Condition was not fulfilled within \" + timeoutSeconds + \" seconds\";\n        throw lastException == null ? new IllegalStateException(errorMessage) : new IllegalStateException(errorMessage, lastException);\n    }\n\n    private boolean isPostgresReady() throws IOException, InterruptedException {\n        Process pgReady = new ProcessBuilder(\"docker\", \"exec\", CONTAINER_NAME, \"pg_isready\", \"-U\", USERNAME, \"-d\", DATABASE)\n                .redirectOutput(new File(\"postgres-entity-array-param-ready-stdout.txt\"))\n                .redirectError(new File(\"postgres-entity-array-param-ready-stderr.txt\"))\n                .start();\n        return pgReady.waitFor(5, TimeUnit.SECONDS) && pgReady.exitValue() == 0;\n    }\n\n    private static void stopStaleContainer() {\n        try {\n            new ProcessBuilder(\"docker\", \"rm\", \"-f\", CONTAINER_NAME).start().waitFor(10, TimeUnit.SECONDS);\n        } catch (IOException e) {\n            logger.debug(\"Could not remove PostgreSQL test container\", e);\n        } catch (InterruptedException e) {\n            Thread.currentThread().interrupt();\n            throw new IllegalStateException(\"Interrupted while removing PostgreSQL test container\", e);\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 756, "output": 2052, "cacheRead": 40448, "cacheWrite": 0, "totalTokens": 43256, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1779819327344, "responseId": "resp_04a8a56e44fb2ef1016a15e340619881a1aa570334c1c8f950"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_sHbw1Q0kfxmXJr7vGyU6kVaS|fc_04a8a56e44fb2ef1016a15e349c11c81a1be057b6c9492aa58", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 6481 bytes to