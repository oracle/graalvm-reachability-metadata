     Process pgReady = new ProcessBuilder(\n+                \"docker\", \"exec\", CONTAINER_NAME, \"pg_isready\", \"-U\", USERNAME, \"-d\", DATABASE)\n+                .redirectOutput(new File(\"postgres-multi-id-array-param-ready-stdout.txt\"))\n+                .redirectError(new File(\"postgres-multi-id-array-param-ready-stderr.txt\"))\n+                .start();\n+        return pgReady.waitFor(5, TimeUnit.SECONDS) && pgReady.exitValue() == 0;\n+    }\n+\n+    private static void stopStaleContainer() {\n+        try {\n+            new ProcessBuilder(\"docker\", \"rm\", \"-f\", CONTAINER_NAME).start().waitFor(10, TimeUnit.SECONDS);\n+        } catch (IOException e) {\n+            logger.debug(\"Could not remove PostgreSQL test container\", e);\n+        } catch (InterruptedException e) {\n+            Thread.currentThread().interrupt();\n+            throw new IllegalStateException(\"Interrupted while removing PostgreSQL test container\", e);\n+        }\n+    }\n+}\n"}], "isError": false, "timestamp": 1779820208826}]}
