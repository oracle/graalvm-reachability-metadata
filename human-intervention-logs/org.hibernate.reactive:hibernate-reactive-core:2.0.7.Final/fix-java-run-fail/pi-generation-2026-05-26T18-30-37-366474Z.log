loader =\n                            new ReactiveMultiIdEntityLoaderArrayParam<>(entityMapping, sessionFactory);\n                    loader.prepare();\n\n                    return CompletableFuture.completedFuture(loader.getLoadable().getEntityName());\n                })\n                .toCompletableFuture()\n                .join();\n\n        assertThat(entityName).isEqualTo(BatchAuthor.class.getName());\n    }\n\n    private static void waitUntil(Callable<Boolean> conditionEvaluator, int timeoutSeconds, int sleepTimeSeconds) {\n        Exception lastException = null;\n        long end = System.currentTimeMillis() + TimeUnit.SECONDS.toMillis(timeoutSeconds);\n        while (System.currentTimeMillis() < end) {\n            try {\n                if (conditionEvaluator.call()) {\n                    return;\n                }\n            } catch (Exception e) {\n                lastException = e;\n            }\n            try {\n                Thread.sleep(TimeUnit.SECONDS.toMillis(sleepTimeSeconds));\n            } catch (InterruptedException e) {\n                Thread.currentThread().interrupt();\n                throw new IllegalStateException(\"Interrupted while waiting for PostgreSQL\", e);\n            }\n        }\n        String errorMessage = \"Condition was not fulfilled within \" + timeoutSeconds + \" seconds\";\n        if (lastException == null) {\n            throw new IllegalStateException(errorMessage);\n        }\n        throw new IllegalStateException(errorMessage, lastException);\n    }\n\n    private boolean isPostgresReady() throws IOException, InterruptedException {\n        Process pgReady = new ProcessBuilder(\n                \"docker\", \"exec\", CONTAINER_NAME, \"pg_isready\", \"-U\", USERNAME, \"-d\", DATABASE)\n                .redirectOutput(new File(\"postgres-multi-id-array-param-ready-stdout.txt\"))\n                .redirectError(new File(\"postgres-multi-id-array-param-ready-stderr.txt\"))\n                .start();\n        return pgReady.waitFor(5, TimeUnit.SECONDS) && pgReady.exitValue() == 0;\n    }\n\n    private static void stopStaleContainer() {\n        try {\n            new ProcessBuilder(\"docker\", \"rm\", \"-f\", CONTAINER_NAME).start().waitFor(10, TimeUnit.SECONDS);\n        } catch (IOException e) {\n            logger.debug(\"Could not remove PostgreSQL test container\", e);\n        } catch (InterruptedException e) {\n            Thread.currentThread().interrupt();\n            throw new IllegalStateException(\"Interrupted while removing PostgreSQL test container\", e);\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 665, "output": 2104, "cacheRead": 31744, "cacheWrite": 0, "totalTokens": 34513, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1779820107521, "responseId": "resp_0e678c877676a4ab016a15e64c4308819ebbcaca8e2bad0cb9"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_iZr9F5xqSUSINqggi4md27fW|fc_0e678c877676a4ab016a15e65609e4819e9732c5368b538fc7", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 6638 bytes to tests/src/org.hibernate.reactive/hibernate-reactive-core/2.0.7.Final/src/test/java/org_hibernate_reactive/hibernate_reactive_core/ReactiveMultiIdEntityLoaderArrayParamTest.java"}], "isError": false, "timestamp": 1779820126968}]}
