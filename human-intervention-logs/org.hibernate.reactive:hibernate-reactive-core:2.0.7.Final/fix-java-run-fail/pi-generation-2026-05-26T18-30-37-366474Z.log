[tool-call] delta {"path":"tests/src/org.hibernate.reactive/hibernate-reactive-core/2.0.7.Final/src/test/java/org_hibernate_reactive/hibernate_reactive_core/ReactiveMultiIdEntityLoaderArrayParamTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_hibernate_reactive.hibernate_reactive_core;\n\nimport jakarta.persistence.Persistence;\nimport org.hibernate.engine.spi.SessionFactoryImplementor;\nimport org.hibernate.engine.spi.SharedSessionContractImplementor;\nimport org.hibernate.metamodel.mapping.EntityMappingType;\nimport org.hibernate.reactive.loader.ast.internal.ReactiveMultiIdEntityLoaderArrayParam;\nimport org.hibernate.reactive.session.ReactiveSession;\nimport org.hibernate.reactive.stage.Stage.SessionFactory;\nimport org.hibernate.reactive.stage.impl.StageSessionImpl;\nimport org.junit.jupiter.api.AfterAll;\nimport org.junit.jupiter.api.BeforeAll;\nimport org.junit.jupiter.api.Test;\nimport org.junit.jupiter.api.TestInstance;\nimport org.slf4j.Logger;\nimport org.slf4j.LoggerFactory;\nimport org_hibernate_reactive.hibernate_reactive_core.entity.BatchAuthor;\n\nimport java.io.File;\nimport java.io.IOException;\nimport java.util.HashMap;\nimport java.util.Map;\nimport java.util.concurrent.Callable;\nimport java.util.concurrent.CompletableFuture;\nimport java.util.concurrent.TimeUnit;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\n@TestInstance(TestInstance.Lifecycle.PER_CLASS)\npublic class ReactiveMultiIdEntityLoaderArrayParamTest {\n\n    private static final Logger logger = LoggerFactory.getLogger(\"ReactiveMultiIdEntityLoaderArrayParamTest\");\n\n    private static final String USERNAME = \"fred\";\n\n    private static final String PASSWORD = \"secret\";\n\n    private static final String DATABASE = \"test\";\n\n    private static final String CONTAINER_NAME = \"hibernate-reactive-multi-id-array-param-postgres\";\n\n    private static final String JDBC_URL = \"jdbc:postgresql://localhost:5434/\" + DATABASE;\n\n    private static Process process;\n\n    private SessionFactory factory;\n\n    @BeforeAll\n    public void init() throws IOException {\n        logger.info(\"Starting PostgreSQL ...\");\n        stopStaleContainer();\n        process = new ProcessBuilder(\n                \"docker\", \"run\", \"--rm\", \"--name\", CONTAINER_NAME, \"-p\", \"5434:5432\", \"-e\", \"POSTGRES_DB=\" + DATABASE,\n                \"-e\", \"POSTGRES_USER=\" + USERNAME, \"-e\", \"POSTGRES_PASSWORD=\" + PASSWORD, \"postgres:18-alpine\")\n                .redirectOutput(new File(\"postgres-multi-id-array-param-stdout.txt\"))\n                .redirectError(new File(\"postgres-multi-id-array-param-stderr.txt\"))\n                .start();\n\n        waitUntil(this::isPostgresReady, 60, 1);\n        logger.info(\"PostgreSQL started\");\n\n        Map<String, String> properties = new HashMap<>();\n        properties.put(\"jakarta.persistence.jdbc.url\", JDBC_URL);\n        properties.put(\"jakarta.persistence.jdbc.user\", USERNAME);\n        properties.put(\"jakarta.persistence.jdbc.password\", PASSWORD);\n        factory = Persistence.createEntityManagerFactory(\"postgres-array-param-batch\", properties)\n                .unwrap(SessionFactory.class);\n    }\n\n    @AfterAll\n    public void close() {\n        if (factory != null) {\n            factory.close();\n        }\n        if (process != null && process.isAlive()) {\n            logger.info(\"Shutting down PostgreSQL\");\n            process.destroy();\n        }\n        stopStaleContainer();\n    }\n\n    @Test\n    void preparesSqlArrayMultiIdLoaderForEntityIdentifierType() {\n        String entityName = factory.<String>withSession(session -> {\n                    ReactiveSession reactiveSession = ((StageSessionImpl) session).unwrap(ReactiveSession.class);\n                    SharedSessionContractImplementor hibernateSession = (SharedSessionContractImplementor) reactiveSession;\n                    SessionFactoryImplementor sessionFactory = hibernateSession.getFactory();\n                    EntityMappingType entityMapping = sessionFactory.getRuntimeMetamodels()\n                            .getMappingMetamodel()\n                            .getEntityDescriptor(BatchAuthor.class);\n\n                    ReactiveMultiIdEntityLoaderArrayParam<BatchAuthor> loader =\n                            new ReactiveMultiIdEntityLoaderArrayParam<>(entityMapping, sessionFactory);\n                    loader.prepare();\n\n                    return CompletableFuture.completedFuture(loader.getLoadable().getEntityName());\n                })\n                .toCompletableFuture()\n                .join();\n\n        assertThat(entityName).isEqualTo(BatchAuthor.class.getName());\n    }\n\n    private static void waitUntil(Callable<Boolean> conditionEvaluator, int timeoutSeconds, int sleepTimeSeconds) {\n        Exception lastException = null;\n        long end = System.currentTimeMillis() + TimeUnit.SECONDS.toMillis(timeoutSeconds);\n        while (System.currentTimeMillis() < end) {\n            try {\n                if (conditionEvaluator.call()) {\n                    return;\n                }\n            } catch (Exception e) {\n                lastException = e;\n            }\n            try {\n                Thread.sleep(TimeUnit.SECONDS.toMillis(sleepTimeSeconds));\n            } catch (InterruptedException e) {\n                Thread.currentThread().interrupt();\n                throw new IllegalStateException(\"Interrupted while waiting for PostgreSQL\", e);\n            }\n        }\n        String errorMessage = \"Condition was not fulfilled within \" + timeoutSeconds + \" seconds\";\n        if (lastException == null) {\n            throw new IllegalStateException(errorMessage);\n        }\n        throw new IllegalStateException(errorMessage, lastException);\n    }\n\n    private boolean isPostgresReady() throws IOException, InterruptedException {\n        Process pgReady = new ProcessBuilder(\n                \"docker\", \"exec\", CONTAINER_NAME, \"pg_isready\", \"-U\", USERNAME, \"-d\", DATABASE)\n                .redirectOutput(new File(\"postgres-multi-id-array-param-ready-stdout.txt\"))\n                .redirectError(new File(\"postgres-multi-id-array-param-ready-stderr.txt\"))\n                .start();\n        return pgReady.waitFor(5, TimeUnit.SECONDS) && pgReady.exitValue() == 0;\n    }\n\n    private static void stopStaleContainer() {\n        try {\n            new ProcessBuilder(\"docker\", \"rm\", \"-f\", CONTAINER_NAME).start().waitFor(10, TimeUnit.SECONDS);\n        } catch (IOException e) {\n            logger.debug(\"Could not remove PostgreSQL test container\", e);\n        } catch (InterruptedException e) {\n            Thread.currentThread().interrupt();\n            throw new IllegalStateException(\"Interrupted while removing PostgreSQL test container\", e);\n        }\n    }\n}\n"}
