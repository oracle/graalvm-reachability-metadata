  	@Override
  	public ServiceRegistry getServiceRegistry() {
  		return delegate.getServiceRegistry();
  	}
  
  	@Override
  	public Context getContext() {
  		return context;
  	}
  
  	@Override
  	public CompletionStage<Stage.Session> openSession() {
  		SessionCreationOptions options = options();
