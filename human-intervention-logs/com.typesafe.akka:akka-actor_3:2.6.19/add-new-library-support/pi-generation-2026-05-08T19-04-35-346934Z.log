 * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_typesafe_akka.akka_actor_3\n\nimport akka.actor.Actor\nimport akka.actor.ActorRef\nimport akka.actor.ActorSystem\nimport akka.actor.OneForOneStrategy\nimport akka.actor.PoisonPill\nimport akka.actor.Props\nimport akka.actor.Status\nimport akka.actor.SupervisorStrategy\nimport akka.actor.Terminated\nimport akka.pattern.Patterns\nimport akka.util.Timeout\nimport com.typesafe.config.ConfigFactory\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\n\nimport java.time.Duration\nimport java.util.Locale\nimport java.util.concurrent.CompletableFuture\nimport java.util.concurrent.ExecutionException\nimport java.util.concurrent.TimeUnit\nimport java.util.concurrent.atomic.AtomicInteger\nimport scala.concurrent.Await\nimport scala.concurrent.Future\nimport scala.concurrent.duration.DurationInt\n\nclass Akka_actor_3Test {\n  @Test\n  def actorsCanChangeBehaviorResolvePathsAndObserveTermination(): Unit = {\n    withActorSystem(\"behavior\") { system =>\n      val worker: ActorRef = system.actorOf(Props(new StatefulActor(\"akka-\")), \"worker\")\n\n      val firstReply: CompletableFuture[String] = new CompletableFuture[String]()\n      worker ! Append(\"actor\", firstReply)\n      assertThat(awaitFuture(firstReply)).isEqualTo(\"akka-actor\")\n\n      val behaviorChanged: CompletableFuture[Unit] = new CompletableFuture[Unit]()\n      worker ! UseUppercase(behaviorChanged)\n      awaitFuture(behaviorChanged)\n\n      val secondReply: CompletableFuture[String] = new CompletableFuture[String]()\n      worker ! Append(\"actor\", secondReply)\n      assertThat(awaitFuture(secondReply)).isEqualTo(\"AKKA-ACTOR\")\n\n      val resolved: ActorRef = awaitScala(system.actorSelection(worker.path).resolveOne(Timeout(3.seconds)))\n      assertThat(resolved.path).isEqualTo(worker.path)\n\n      val stoppedActor: ActorRef = system.actorOf(Props.empty, \"watched-stop-target\")\n      val stoppedReply: CompletableFuture[String] = new CompletableFuture[String]()\n      worker ! WatchAndStop(stoppedActor, stoppedReply)\n      assertThat(awaitFuture(stoppedReply)).isEqualTo(\"watched-stop-target\")\n    }\n  }\n\n  @Test\n  def eventStreamAndSchedulerDeliverMessages(): Unit = {\n    withActorSystem(\"events\") { system =>\n      val delivered: CompletableFuture[List[String]] = new CompletableFuture[List[String]]()\n      val collector: ActorRef = system.actorOf(Props(new EventCollector(2, delivered)), \"collector\")\n\n      assertThat(system.eventStream.subscribe(collector, classOf[LibraryEvent])).isTrue()\n      system.eventStream.publish(LibraryEvent(\"immediate\"))\n\n      val scheduled = system.scheduler.scheduleOnce(25.millis) {\n        system.eventStream.publish(LibraryEvent(\"scheduled\"))\n      }(system.dispatcher)\n\n      assertThat(awaitFuture(delivered)).containsExactly(\"immediate\", \"scheduled\")\n      assertThat(system.eventStream.unsubscribe(collector, classOf[LibraryEvent])).isTrue()\n      scheduled.cancel()\n    }\n  }\n\n  @Test\n  def askPatternCompletesWithRepliesAndStatusFailures(): Unit = {\n    withActorSystem(\"ask\") { system =>\n      val calculator: ActorRef = system.actorOf(Props(new CalculatorActor), \"calculator\")\n\n      val sum: AnyRef = Patterns\n        .ask(calculator, Add(2, 3), Duration.ofSeconds(3))\n        .toCompletableFuture\n        .get(3, TimeUnit.SECONDS)\n        .asInstanceOf[AnyRef]\n      assertThat(sum).isEqualTo(Sum(5))\n\n      val failed = Patterns\n        .ask(calculator, Divide(7, 0), Duration.ofSeconds(3))\n        .toCompletableFuture\n\n      val exception: ExecutionException = try {\n        failed.get(3, TimeUnit.SECONDS)\n        throw new AssertionError(\"Expected division by zero to fail the ask future\")\n      } catch {\n        case failure: ExecutionException => failure\n      }\n      assertThat(exception.getCause).isInstanceOf(classOf[ArithmeticException])\n      assertThat(exception.getCause).hasMessage(\"division by zero\")\n    }\n  }\n\n  @Test\n  def supervisionRestartsFailedChildrenAndResetsState(): Unit = {\n    withActorSystem(\"supervision\") { system =>\n      val supervisor: ActorRef = system.actorOf(Props(new SupervisorActor), \"supervisor\")\n\n      supervisor ! Increment(2)\n      supervisor ! Increment(3)\n      val beforeRestart: CompletableFuture[Int] = new CompletableFuture[Int]()\n      supervisor ! GetCount(beforeRestart)\n      assertThat(awaitFuture(beforeRestart)).isEqualTo(5)\n\n      supervisor ! ResetByCrashing\n\n      val afterRestart: CompletableFuture[Int] = new CompletableFuture[Int]()\n      supervisor ! GetCount(afterRestart)\n      assertThat(awaitFuture(afterRestart)).isZero()\n    }\n  }\n\n  private def withActorSystem[A](testName: String)(body: ActorSystem => A): A = {\n    val systemName: String = s\"akka-actor-${testName}-${Akka_actor_3Test.nextSystemId.incrementAndGet()}\"\n    val system: ActorSystem = ActorSystem(systemName, Akka_actor_3Test.config)\n    try {\n      body(system)\n    } finally {\n      Await.result(system.terminate(), 10.seconds)\n    }\n  }\n\n  private def awaitFuture[A](future: CompletableFuture[A]): A = {\n    future.get(5, TimeUnit.SECONDS)\n  }\n\n  private def awaitScala[A](future: Future[A]): A = {\n    Await.result(future, 5.seconds)\n  }\n}\n\nobject Akka_actor_3Test {\n  val nextSystemId: AtomicInteger = new AtomicInteger(0)\n\n  val config = ConfigFactory.parseString(\n    \"\"\"\n      akka {\n        loglevel = \"OFF\"\n        stdout-loglevel = \"OFF\"\n        actor {\n          provider = \"local\"\n          default-dispatcher {\n            fork-join-executor {\n              parallelism-min = 1\n              parallelism-factor = 1.0\n              parallelism-max = 4\n            }\n          }\n        }\n      }\