  <description>Checks that we can use the generated artifacts</description>
  <name>Apache Hadoop Client Packaging Integration Tests</name>

  <properties>
    <failsafe.timeout>400</failsafe.timeout>
  </properties>

  <dependencies>
    <dependency>
      <groupId>log4j</groupId>
