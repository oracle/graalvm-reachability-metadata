    }\\n\\n        // If the version already exists, no update needed\\n        String newVersion = newCoords.version();\\n        for (MetadataVersionsIndexEntry entry : entries) {\\n            if (newVersion.equals(entry.metadataVersion())) {\\n                return;\\n            }\\n            List<String> tv = entry.testedVersions();\\n            if (tv != null && tv.contains(newVersion)) {\\n                return;\\n            }\\n        }\\n\\n        List<String> latestAllowedPackages = null;\\n        List<String> latestRequires = null;\\n        LibraryLanguage latestLanguage = null;\\n        // Copy default metadata properties from the current latest entry.\\n        for (int i = 0; i < entries.size(); i++) {\\n            MetadataVersionsIndexEntry entry = entries.get(i);\\n            if (Boolean.TRUE.equals(entry.latest())) {\\n                latestAllowedPackages = entry.allowedPackages();\\n                latestRequires = entry.requires();\\n                latestLanguage = entry.language();\\n\",\"exit_code\":0,\"status\":\"completed\"}}\n{\"type\":\"item.started\",\"item\":{\"id\":\"item_94\",\"type\":\"command_execution\",\"command\":\"/usr/bin/bash -lc \\\"rg -n 'class GenerateMetadataTask|agentAllowedPackages|generateMetadata' tests/tck-build-logic/src/main -S\\\"\",\"aggregated_output\":\"\",\"exit_code\":null,\"status\":\"in_progress\"}}\n{\"type\":\"item.completed\",\"item\":{\"id\":\"item_94\",\"type\":\"command_execution\",\"command\":\"/usr/bin/bash -lc \\\"rg -n 'class GenerateMetadataTask|agentAllowedPackages|generateMetadata' tests/tck-build-logic/src/main -S\\\"\",\"aggregated_output\":\"tests/tck-build-logic/src/main/java/org/graalvm/internal/tck/GenerateMetadataTask.java:29:public abstract class GenerateMetadataTask extends DefaultTask {\\ntests/tck-build-logic/src/main/java/org/graalvm/internal/tck/GenerateMetadataTask.java:34:    private String agentAllowedPackages;\\ntests/tck-build-logic/src/main/java/org/graalvm/intern