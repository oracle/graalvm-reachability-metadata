rk.boot.webmvc.autoconfigure.WebMvcProperties;\nimport org.springframework.boot.webmvc.autoconfigure.WebMvcProperties.MatchingStrategy;\nimport org.springframework.boot.webmvc.autoconfigure.WebMvcRegistrations;\nimport org.springframework.boot.webmvc.autoconfigure.error.BasicErrorController;\nimport org.springframework.boot.webmvc.error.DefaultErrorAttributes;"}, {"oldText": "import org.springframework.http.HttpStatus;\nimport org.springframework.http.MediaType;", "newText": "import org.springframework.http.HttpStatus;\nimport org.springframework.http.MediaType;\nimport org.springframework.http.ResponseEntity;"}, {"oldText": "    void jspTemplateAvailabilityProviderRequiresJasperAndJspResource() {\n        JspTemplateAvailabilityProvider provider = new JspTemplateAvailabilityProvider();\n        Environment environment = new StandardEnvironment();\n        ClassLoader classLoader = getClass().getClassLoader();\n\n        boolean available = provider.isTemplateAvailable(\"home\", environment, classLoader, new DefaultResourceLoader());\n\n        assertThat(available).isFalse();\n    }\n\n    @Configuration(proxyBeanMethods = false)", "newText": "    void jspTemplateAvailabilityProviderRequiresJasperAndJspResource() {\n        JspTemplateAvailabilityProvider provider = new JspTemplateAvailabilityProvider();\n        Environment environment = new StandardEnvironment();\n        ClassLoader classLoader = getClass().getClassLoader();\n\n        boolean available = provider.isTemplateAvailable(\"home\", environment, classLoader, new DefaultResourceLoader());\n\n        assertThat(available).isFalse();\n    }\n\n    @Test\n    void basicErrorControllerBuildsJsonResponseUsingErrorPropertiesAndRequestParameters() {\n        ErrorProperties errorProperties = new ErrorProperties();\n        errorProperties.setIncludeException(true);\n        errorProperties.setIncludeMessage(IncludeAttribute.ON_PARAM);\n        errorProperties.setIncludeStacktrace(IncludeAttribute.ON_PARAM);\n        errorProperties.setIncludePath(IncludeAttribute.ON_PARAM);\n        BasicErrorController controller = new BasicErrorController(new DefaultErrorAttributes(), errorProperties);\n        SimpleHttpServletRequest request = new SimpleHttpServletRequest(\"/orders/42\");\n        IllegalArgumentException failure = new IllegalArgumentException(\"order is invalid\");\n        request.setAttribute(\"jakarta.servlet.error.status_code\", HttpStatus.CONFLICT.value());\n        request.setAttribute(\"jakarta.servlet.error.request_uri\", \"/orders/42\");\n        request.setAttribute(\"jakarta.servlet.error.exception\", failure);\n        request.setParameter(\"message\", \"true\");\n        request.setParameter(\"trace\", \"true\");\n        request.setParameter(\"path\", \"true\");\n\n        ResponseEntity<Map<String, Object>> response = controller.error(request);\n\n        assertThat(response.getStatusCode()).isEqualTo(HttpStatus.CONFLICT);\n        assertThat(response.getBody()).containsEntry(\"status\", 409)\n                .containsEntry(\"error\", \"Conflict\")\n                .containsEntry(\"message\", \"order is invalid\")\n                .containsEntry(\"path\", \"/orders/42\")\n                .containsEntry(\"exception\", IllegalArgumentException.class.getName());\n        assertThat(response.getBody().get(\"trace\")).asString().contains(IllegalArgumentException.class.getName());\n    }\n\n    @Configuration(proxyBeanMethods = false)"}, {"oldText": "    static final class RegistrationForm {\n\n    }\n\n    private static final class SimpleWebRequest implements WebRequest {", "newText": "    static final class RegistrationForm {\n\n    }\n\n    private static final class SimpleHttpServletRequest implements HttpServletRequest {\n\n        private final Map<String, Object> attributes = new HashMap<>();\n\n        private final Map<String, String[]> parameters = new HashMap<>();\n\n        private final String requestUri;\n\n        SimpleHttpServletRequest(S