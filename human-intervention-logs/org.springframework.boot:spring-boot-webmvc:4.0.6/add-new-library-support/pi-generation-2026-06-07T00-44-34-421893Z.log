[tool-call] delta {"path":"tests/src/org.springframework.boot/spring-boot-webmvc/4.0.6/src/test/java/org_springframework_boot/spring_boot_webmvc/Spring_boot_webmvcTest.java","edits":[{"oldText":"import org.springframework.boot.webmvc.autoconfigure.error.BasicErrorController;\nimport org.springframework.boot.webmvc.error.DefaultErrorAttributes;","newText":"import org.springframework.boot.webmvc.autoconfigure.error.BasicErrorController;\nimport org.springframework.boot.webmvc.error.DefaultErrorAttributes;\nimport org.springframework.boot.webmvc.error.ErrorAttributes;"},{"oldText":"    void basicErrorControllerBuildsJsonResponseUsingErrorPropertiesAndRequestParameters() {\n        ErrorProperties errorProperties = new ErrorProperties();\n        errorProperties.setIncludeException(true);\n        errorProperties.setIncludeMessage(IncludeAttribute.ON_PARAM);\n        errorProperties.setIncludeStacktrace(IncludeAttribute.ON_PARAM);\n        errorProperties.setIncludePath(IncludeAttribute.ON_PARAM);\n        BasicErrorController controller = new BasicErrorController(new DefaultErrorAttributes(), errorProperties);\n        SimpleHttpServletRequest request = new SimpleHttpServletRequest(\"/orders/42\");\n        IllegalArgumentException failure = new IllegalArgumentException(\"order is invalid\");\n        request.setAttribute(\"jakarta.servlet.error.status_code\", HttpStatus.CONFLICT.value());\n        request.setAttribute(\"jakarta.servlet.error.request_uri\", \"/orders/42\");\n        request.setAttribute(\"jakarta.servlet.error.exception\", failure);\n        request.setParameter(\"message\", \"true\");\n        request.setParameter(\"trace\", \"true\");\n        request.setParameter(\"path\", \"true\");\n\n        ResponseEntity<Map<String, Object>> response = controller.error(request);\n\n        assertThat(response.getStatusCode()).isEqualTo(HttpStatus.CONFLICT);\n        assertThat(response.getBody()).containsEntry(\"status\", 409)\n                .containsEntry(\"error\", \"Conflict\")\n                .containsEntry(\"message\", \"order is invalid\")\n                .containsEntry(\"path\", \"/orders/42\")\n                .containsEntry(\"exception\", IllegalArgumentException.class.getName());\n        assertThat(response.getBody().get(\"trace\")).asString().contains(IllegalArgumentException.class.getName());\n    }","newText":"    void basicErrorControllerBuildsJsonResponseUsingErrorPropertiesAndRequestParameters() {\n        ErrorProperties errorProperties = new ErrorProperties();\n        errorProperties.setIncludeException(true);\n        errorProperties.setIncludeMessage(IncludeAttribute.ON_PARAM);\n        errorProperties.setIncludeStacktrace(IncludeAttribute.ON_PARAM);\n        errorProperties.setIncludePath(IncludeAttribute.ON_PARAM);\n        BasicErrorController controller = new BasicErrorController(new CapturingErrorAttributes(), errorProperties);\n        SimpleHttpServletRequest request = new SimpleHttpServletRequest(\"/orders/42\");\n        request.setAttribute(\"jakarta.servlet.error.status_code\", HttpStatus.CONFLICT.value());\n        request.setParameter(\"message\", \"true\");\n        request.setParameter(\"trace\", \"true\");\n        request.setParameter(\"path\", \"true\");\n\n        ResponseEntity<Map<String, Object>> response = controller.error(request);\n\n        assertThat(response.getStatusCode()).isEqualTo(HttpStatus.CONFLICT);\n        assertThat(response.getBody()).containsEntry(\"exceptionIncluded\", true)\n                .containsEntry(\"messageIncluded\", true)\n                .containsEntry(\"stackTraceIncluded\", true)\n                .containsEntry(\"pathIncluded\", true)\n                .containsEntry(\"bindingErrorsIncluded\", false);\n    }"},{"oldText":"    static final class RegistrationForm {\n\n    }\n\n    private static final class SimpleHttpServletRequest implements HttpServletRequest {","newText":"    static final class RegistrationForm {\n\n    }\n\n    private static final class CapturingErrorAttributes implements ErrorAttributes {\n\n        @Override\n        public Map<String, Object> getErrorAttributes(WebRequest webRequest, ErrorAttributeOptions options) {\n            Map<String, Object> result = new HashMap<>();\n            result.put(\"exceptionIncluded\", options.isIncluded(Include.EXCEPTION));\n            result.put(\"messageIncluded\", options.isIncluded(Include.MESSAGE));\n            result.put(\"stackTraceIncluded\", options.isIncluded(Include.STACK_TRACE));\n            result.put(\"pathIncluded\", options.isIncluded(Include.PATH));\n            result.put(\"bindingErrorsIncluded\", options.isIncluded(Include.BINDING_ERRORS));\n            return result;\n        }\n\n        @Override\n        public Throwable getError(WebRequest webRequest) {\n            return null;\n        }\n\n    }\n\n    private static final class SimpleHttpServletRequest implements HttpServletRequest {"}]}
