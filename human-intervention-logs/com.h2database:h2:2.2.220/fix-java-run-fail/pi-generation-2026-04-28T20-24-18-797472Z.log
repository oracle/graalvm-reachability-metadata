[tool-call] delta {"path":"tests/src/com.h2database/h2/2.2.220/src/test/java/h2/SourceCompilerAnonymous1Test.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage h2;\n\nimport org.h2.util.SourceCompiler;\nimport org.junit.jupiter.api.Test;\n\nimport java.lang.reflect.Method;\n\nimport static org.assertj.core.api.Assertions.assertThat;\nimport static org.assertj.core.api.Assertions.fail;\n\npublic class SourceCompilerAnonymous1Test {\n    private static final String INVOKER_CLASS_NAME = \"org.h2.util.SourceCompilerSystemFallbackInvoker\";\n    private static final String TARGET_CLASS_NAME = \"h2.generated.SourceCompilerSystemFallbackTarget\";\n    private static final String INVOKER_SOURCE = \"\"\"\n            package org.h2.util;\n\n            public class SourceCompilerSystemFallbackInvoker {\n                public static void exerciseFindSystemClassFallback() throws Exception {\n                    NullBytecodeCompiler compiler = new NullBytecodeCompiler();\n                    compiler.setJavaSystemCompiler(false);\n                    compiler.setSource(\"h2.generated.SourceCompilerSystemFallbackTarget\", \"Object value() { return null; }\");\n                    try {\n                        compiler.getClass(\"h2.generated.SourceCompilerSystemFallbackTarget\");\n                        throw new AssertionError(\"Expected system class lookup to fail for generated target\");\n                    } catch (ClassNotFoundException expected) {\n                        if (!expected.getMessage().contains(\"h2.generated.SourceCompilerSystemFallbackTarget\")) {\n                            throw expected;\n                        }\n                    }\n                }\n\n                static final class NullBytecodeCompiler extends SourceCompiler {\n                    @Override\n                    byte[] javacCompile(String packageName, String className, String source) {\n                        return null;\n                    }\n                }\n            }\n            \"\"\";\n\n    @Test\n    void fallsBackToSystemClassLookupWhenLegacyCompilerProducesNoBytecode() throws Exception {\n        SourceCompiler compiler = new SourceCompiler();\n        compiler.setSource(INVOKER_CLASS_NAME, INVOKER_SOURCE);\n\n        assertRuntimeCompilationOutcome(() -> {\n            Method method = compiler.getMethod(INVOKER_CLASS_NAME);\n\n            assertThat(method).isNotNull();\n            assertThat(method.getName()).isEqualTo(\"exerciseFindSystemClassFallback\");\n            method.invoke(null);\n        });\n    }\n\n    private static void assertRuntimeCompilationOutcome(CompilationAction action) throws Exception {\n        try {\n            action.run();\n        } catch (UnsupportedOperationException ex) {\n            assertThat(ex).hasMessageContaining(\"Defining new classes at runtime is not supported\");\n        } catch (RuntimeException ex) {\n            if (!hasUnsupportedRuntimeClassDefinitionCause(ex)) {\n                fail(\"Runtime source compilation failed before class definition\", ex);\n            }\n        }\n    }\n\n    private static boolean hasUnsupportedRuntimeClassDefinitionCause(Throwable throwable) {\n        Throwable current = throwable;\n        while (current != null) {\n            if (current instanceof UnsupportedOperationException\n                    && current.getMessage() != null\n                    && current.getMessage().contains(\"Defining new classes at runtime is not supported\")) {\n                return true;\n            }\n            current = current.getCause();\n        }\n        return false;\n    }\n\n    private interface CompilationAction {\n        void run() throws Exception;\n    }\n}\n"}
