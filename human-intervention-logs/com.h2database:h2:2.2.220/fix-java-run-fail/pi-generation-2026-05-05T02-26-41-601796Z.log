      /**
       * Close an AutoCloseable without throwing an exception.
       *
       * @param out the AutoCloseable or null
       */
      public static void closeSilently(AutoCloseable out) {
          if (out != null) {
              try {
                  trace("closeSilently", null, out);
                  out.close();
              } catch (Exception e) {
                  // ignore
