  plugins {
      id "org.graalvm.internal.tck"
  }
  
  String libraryVersion = tck.testedLibraryVersion.get()
  
  Provider<Directory> explodedH2Runtime = layout.buildDirectory.dir("exploded-h2-runtime")
  
  TaskProvider<Task> prepareExplodedH2Runtime = tasks.register("prepareExplodedH2Runtime") { task ->
      task.inputs.files(configurations.testRuntimeClasspath)
      task.outputs.dir(explodedH2Runtime)
      task.doLast {
          File h2Jar = configurations.testRuntimeClasspath.files.find { file ->
              file.name == "h2-${libraryVersion}.jar"
          }
          if (h2Jar == null) {
              throw new GradleException("Unable to locate h2-${libraryVersion}.jar on the test runtime classpath")
          }
          File outputDir = explodedH2Runtime.get().asFile
          delete(outputDir)
          copy {
              from(zipTree(h2Jar)) {
                  exclude "org/h2/util/data.zip"
              }
              into(outputDir)
          }
          copy {
              from(zipTree(h2Jar)) {
                  include "org/h2/util/data.zip"
              }
              into(task.temporaryDir)
          }
          copy {
              from(zipTree(new File(task.temporaryDir, "org/h2/util/data.zip")))
              into(outputDir)
          }
      }
  }
  
  dependencies {
  	testImplementation("com.h2database:h2:$libraryVersion")
  	testImplementation("org.assertj:assertj-core:3.22.0")
  	testRuntimeOnly("com.ibm.icu:icu4j:73.2")
  	testRuntimeOnly("org.slf4j:slf4j-simple:2.0.9")
  }
  
  test {
      systemProperty 'h2.javaObjectSerializer', 'h2.JdbcUtilsTest$PassThroughJavaObjectSerializer'
      systemProperty 'h2.useThreadContextClassLoader', 'true'
      systemProperty 'h2.nioCleanerHack', 'true'
      dependsOn prepareExplodedH2Runtime
      classpath = files(explodedH2Runtime).builtBy(prepareExplodedH2Runtime) + classpath.filter { file ->
          file.name != "h2-${libraryVersion}.jar"
      }
  }
  
  graalvmNative {
      binaries {
          test {
              buildArgs.add('-Dh2.javaObjectSerializer=h2.JdbcUtilsTest$PassThroughJavaObjectSerializer')
              buildArgs.add('-Dh2.useThreadContextClassLoader=true')
              buildArgs.add('-Dh2.nioCleanerHack=true')
              buildArgs.add('--initialize-at-run-time=org.h2.util.MemoryUnmapper')
              runtimeArgs('-Dh2.javaObjectSerializer=h2.JdbcUtilsTest$PassThroughJavaObjectSerializer')
              runtimeArgs('-Dh2.useThreadContextClassLoader=true')
              runtimeArgs('-Dh2.nioCleanerHack=true')
          }
      }
      agent {
          defaultMode = "conditional"
          modes {
              conditional {
                  userCodeFilterPath = "user-code-filter.json"
              }
          }
          metadataCopy {
              mergeWithExisting = true
              inputTaskNames.add("test")
              outputDirectories.add("src/test/resources/META-INF/native-image/com.h2database/h2")
          }
      }
  }
