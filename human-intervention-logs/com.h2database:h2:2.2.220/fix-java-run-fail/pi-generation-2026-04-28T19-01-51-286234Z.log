_STATES\", Collator.PRIMARY);\n\n        assertThat(compareMode).hasToString(\"ENGLISH_UNITED_STATES\");\n        assertThat(compareMode.getClass().getName()).isEqualTo(\"org.h2.value.CompareModeIcu4J\");\n        assertThat(compareMode.compareString(\"resume\", \"résumé\", false)).isZero();\n        assertThat(compareMode.compareString(\"alpha\", \"omega\", false)).isNegative();\n    }\n}\n"}
