 "arguments": {"path": "tests/src/com.h2database/h2/2.2.220/src/test/java/h2/UtilsTest.java", "edits": [{"oldText": "import java.io.IOException;\nimport java.io.InputStream;\nimport java.nio.charset.StandardCharsets;", "newText": "import java.nio.charset.StandardCharsets;"}, {"oldText": "    @Test\n    void attemptsDirectResourceLookupWhenBundledResourceArchiveIsUnavailable() throws Exception {\n        ClassLoader filteringLoader = new DataArchiveFilteringClassLoader();\n        Class<?> isolatedUtils = filteringLoader.loadClass(Utils.class.getName());\n\n        Object resource = isolatedUtils.getMethod(\"getResource\", String.class)\n                .invoke(null, \"/h2/absent-resource.txt\");\n\n        assertThat(isolatedUtils.getClassLoader()).isSameAs(filteringLoader);\n        assertThat(resource).isNull();\n    }\n\n    @Test\n    void scalesValueForAvailableMemory() {", "newText": "    @Test\n    void scalesValueForAvailableMemory() {"}, {"oldText": "    private static final class DataArchiveFilteringClassLoader extends ClassLoader {\n        private static final String UTILS_CLASS_NAME = \"org.h2.util.Utils\";\n        private static final String UTILS_CLASS_RESOURCE = \"Utils.class\";\n        private static final String DATA_ARCHIVE_RESOURCE = \"org/h2/util/data.zip\";\n\n        private DataArchiveFilteringClassLoader() {\n            super(UtilsTest.class.getClassLoader());\n        }\n\n        @Override\n        protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {\n            if (!UTILS_CLASS_NAME.equals(name)) {\n                return super.loadClass(name, resolve);\n            }\n            Class<?> loadedClass = findLoadedClass(name);\n            if (loadedClass == null) {\n                loadedClass = findClass(name);\n            }\n            if (resolve) {\n                resolveClass(loadedClass);\n            }\n            return loadedClass;\n        }\n\n        @Override\n        protected Class<?> findClass(String name) throws ClassNotFoundException {\n            if (!UTILS_CLASS_NAME.equals(name)) {\n                return super.findClass(name);\n            }\n            try (InputStream input = Utils.class.getResourceAsStream(UTILS_CLASS_RESOURCE)) {\n                if (input == null) {\n                    throw new ClassNotFoundException(name);\n                }\n                byte[] bytes = input.readAllBytes();\n                return defineClass(name, bytes, 0, bytes.length);\n            } catch (IOException exception) {\n                throw new ClassNotFoundException(name, exception);\n            }\n        }\n\n        @Override\n        public InputStream getResourceAsStream(String name) {\n            if (DATA_ARCHIVE_RESOURCE.equals(name)) {\n                return null;\n            }\n            return super.getResourceAsStream(name);\n        }\n    }\n\n    public static class UtilityFixture {", "newText": "    public static class UtilityFixture {"}]}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 531, "output": 1670, "cacheRead": 70656, "cacheWrite": 0, "totalTokens": 72857, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777402567315, "responseId": "resp_01ec786bdc7a64a00169f102c88c0c81a1b1d46e9f28d1d041"}}
