       * we are using using a ConcurrentHashMap as a set, as there is no
       * ConcurrentHashSet.
       */
      private final ConcurrentHashMap<SessionLocal, SessionLocal> lockSharedSessions = new ConcurrentHashMap<>();
  
      private Column rowIdColumn;
  
