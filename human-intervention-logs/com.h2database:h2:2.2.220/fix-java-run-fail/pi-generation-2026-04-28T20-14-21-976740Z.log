                  add("DROP TABLE IF EXISTS SYSTEM_LOB_STREAM", true);
                  add("DROP ALIAS IF EXISTS SYSTEM_COMBINE_CLOB", true);
                  add("DROP ALIAS IF EXISTS SYSTEM_COMBINE_BLOB", true);
