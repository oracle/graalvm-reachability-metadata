                  for (int j = 0; indexes != null && j < indexes.size(); j++) {
                      Index index = indexes.get(j);
                      if (!index.getIndexType().getBelongsToConstraint()) {
                          add(index.getCreateSQL(), false);
                      }
                  }
              }
