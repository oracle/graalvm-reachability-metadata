              String output = Utils10.byteArrayOutputStreamToString(buff, StandardCharsets.UTF_8);
              handleSyntaxError(output, status);
          } catch (Exception e) {
              throw DbException.convert(e);
          } finally {
              System.setErr(old);
          }
      }
  
