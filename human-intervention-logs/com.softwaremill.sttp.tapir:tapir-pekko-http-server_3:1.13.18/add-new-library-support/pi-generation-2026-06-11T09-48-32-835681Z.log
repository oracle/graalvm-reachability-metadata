    ): ServerEndpoint.Full[SECURITY_INPUT, PRINCIPAL, INPUT, ERROR_OUTPUT, OUTPUT, R, F] =
      ServerEndpoint(endpoint.info(info), securityLogic, logic)
  
    override protected def showType: String = "ServerEndpoint"
  
