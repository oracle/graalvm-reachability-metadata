[tool-call] delta {"path":"tests/src/org.apache.maven/maven-xml/4.0.0-rc-3/src/test/java/org_apache_maven/maven_xml/Maven_xmlTest.java","edits":[{"oldText":"import org.apache.maven.internal.xml.XmlNodeStaxBuilder;\nimport org.apache.maven.internal.xml.XmlNodeWriter;\nimport org.junit.jupiter.api.Test;\n","newText":"import org.apache.maven.internal.xml.XmlNodeStaxBuilder;\nimport org.apache.maven.internal.xml.XmlNodeWriter;\nimport org.apache.maven.internal.xml.XmlPlexusConfiguration;\nimport org.codehaus.plexus.configuration.PlexusConfiguration;\nimport org.junit.jupiter.api.Test;\n"},{"oldText":"    @Test\n    void mergeCombinesAttributesAndChildrenWhileKeepingDominantValues() {\n","newText":"    @Test\n    void plexusConfigurationAdapterPreservesAttributesValuesAndRepeatedChildren() {\n        XmlNode pluginConfiguration = node(\n                \"configuration\",\n                null,\n                linkedMap(\"combine.children\", \"append\"),\n                node(\"source\", \"21\"),\n                node(\"compilerArgs\", null,\n                        node(\"arg\", \"-Xlint:all\"),\n                        node(\"arg\", \"-Werror\")),\n                node(\"profiles\", null,\n                        node(\"profile\", \"fast\", linkedMap(\"id\", \"dev\")),\n                        node(\"profile\", \"strict\", linkedMap(\"id\", \"ci\"))));\n\n        PlexusConfiguration configuration = XmlPlexusConfiguration.toPlexusConfiguration(pluginConfiguration);\n\n        assertThat(configuration.getName()).isEqualTo(\"configuration\");\n        assertThat(configuration.getValue()).isNull();\n        assertThat(configuration.getAttributeNames()).containsExactly(\"combine.children\");\n        assertThat(configuration.getAttribute(\"combine.children\")).isEqualTo(\"append\");\n        assertThat(configuration.getChildCount()).isEqualTo(3);\n        assertThat(configuration.getChild(\"source\").getValue()).isEqualTo(\"21\");\n\n        PlexusConfiguration compilerArgs = configuration.getChild(\"compilerArgs\");\n        assertThat(compilerArgs.getChildren(\"arg\")).extracting(PlexusConfiguration::getValue)\n                .containsExactly(\"-Xlint:all\", \"-Werror\");\n\n        PlexusConfiguration profiles = configuration.getChild(\"profiles\");\n        assertThat(profiles.getChildren(\"profile\")).extracting(PlexusConfiguration::getValue)\n                .containsExactly(\"fast\", \"strict\");\n        assertThat(profiles.getChild(1).getAttribute(\"id\")).isEqualTo(\"ci\");\n        assertThat(configuration.toString()).contains(\"<configuration combine.children=\\\"append\\\">\")\n                .contains(\"<source>21</source>\")\n                .contains(\"<arg>-Werror</arg>\");\n    }\n\n    @Test\n    void mergeCombinesAttributesAndChildrenWhileKeepingDominantValues() {\n"}]}
