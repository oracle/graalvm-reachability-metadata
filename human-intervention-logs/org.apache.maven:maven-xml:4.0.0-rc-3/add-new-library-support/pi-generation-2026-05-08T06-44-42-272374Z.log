(configuration.getChild(\"source\").getValue()).isEqualTo(\"21\");\n\n        PlexusConfiguration compilerArgs = configuration.getChild(\"compilerArgs\");\n        assertThat(compilerArgs.getChildren(\"arg\")).extracting(PlexusConfiguration::getValue)\n                .containsExactly(\"-Xlint:all\", \"-Werror\");\n\n        PlexusConfiguration profiles = configuration.getChild(\"profiles\");\n        assertThat(profiles.getChildren(\"profile\")).extracting(PlexusConfiguration::getValue)\n                .containsExactly(\"fast\", \"strict\");\n        assertThat(profiles.getChild(1).getAttribute(\"id\")).isEqualTo(\"ci\");\n        assertThat(configuration.toString()).contains(\"<configuration combine.children=\\\"append\\\">\")\n                .contains(\"<source>21</source>\")\n                .contains(\"<arg>-Werror</arg>\");\n    }\n\n    @Test\n    void mergeCombinesAttributesAndChildrenWhileKeepingDominantValues() {\n"}]}
