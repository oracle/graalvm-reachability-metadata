      @Test
      void mergeRemovesDominantChildrenMarkedWithRemoveCombinationMode() {
          XmlNode dominant = node(
                  "configuration",
                  null,
                  node("inherited", null,
                          linkedMap(XmlNode.SELF_COMBINATION_MODE_ATTRIBUTE, XmlNode.SELF_COMBINATION_REMOVE)),
