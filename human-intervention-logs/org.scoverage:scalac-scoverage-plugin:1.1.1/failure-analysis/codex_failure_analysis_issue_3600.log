\": true,\\nmetadata/org.jboss.weld/weld-build-config/index.json:3:    \\\"not-for-native-image\\\": true,\\nmetadata/org.jetbrains.compose.ui/ui/index.json:3:    \\\"not-for-native-image\\\": true,\\nmetadata/schemas/metadata-library-index-schema-v2.0.1.json:136:        \\\"not-for-native-image\\\",\\nmetadata/schemas/metadata-library-index-schema-v2.0.1.json:140:        \\\"not-for-native-image\\\": {\\nmetadata/schemas/metadata-library-index-schema-v2.0.1.json:249:        \\\"not-for-native-image\\\": true,\\n\\nweb search: \\nweb search: \\nweb search: \\nweb search: Maven Central org.scoverage scalac-scoverage-plugin 1.1.1\\nexec\\n/usr/bin/bash -lc 'curl -fsSL https://repo.maven.apache.org/maven2/org/scoverage/scalac-scoverage-plugin_2.11/1.1.1/scalac-scoverage-plugin_2.11-1.1.1.pom' in /home/vjovanov/c/forge/forge8/graalvm-reachability-metadata/forge/local_repositories/forge_worktrees/3600-b15ffd2a\\n succeeded in 0ms:\\n<?xml version='1.0' encoding='UTF-8'?>\\n<project xsi:schemaLocation=\\\"http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd\\\" xmlns:xsi=\\\"http://www.w3.org/2001/XMLSchema-instance\\\" xmlns=\\\"http://maven.apache.org/POM/4.0.0\\\">\\n    <modelVersion>4.0.0</modelVersion>\\n    <groupId>org.scoverage</groupId>\\n    <artifactId>scalac-scoverage-plugin_2.11</artifactId>\\n    <packaging>jar</packaging>\\n    <description>scalac-scoverage-plugin</description>\\n    <version>1.1.1</version>\\n    <name>scalac-scoverage-plugin</name>\\n    <organization>\\n        <name>org.scoverage</name>\\n    </organization>\\n    <url>https://github.com/scoverage/scalac-scoverage-plugin</url>\\n    <licenses>\\n        <license>\\n            <name>Apache 2</name>\\n            <url>http://www.apache.org/licenses/LICENSE-2.0</url>\\n            <distribution>repo</distribution>\\n        </license>\\n    </licenses>\\n    <scm>\\n        <url>git@github.com:scoverage/scalac-scoverage-plugin.git</url>\\n        <connection>scm: