{"type":"item.completed","item":{"id":"item_111","type":"command_execution","command":"/usr/bin/bash -lc \"nl -ba tests/src/org.apache.groovy/groovy-templates/4.0.24/src/test/groovy/org_apache_groovy/groovy_templates/Groovy_templatesTest.groovy | sed -n '1,320p'\"","aggregated_output":"     1\t/*\n     2\t * Copyright and related rights waived via CC0\n     3\t *\n     4\t * You should have received a copy of the CC0 legalcode along with this\n     5\t * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n     6\t */\n     7\tpackage org_apache_groovy.groovy_templates\n     8\t\n     9\timport groovy.text.GStringTemplateEngine\n    10\timport groovy.text.SimpleTemplateEngine\n    11\timport groovy.text.StreamingTemplateEngine\n    12\timport groovy.text.Template\n    13\timport groovy.text.XmlTemplateEngine\n    14\timport groovy.text.markup.MarkupTemplateEngine\n    15\timport groovy.text.markup.TemplateConfiguration\n    16\timport org.graalvm.internal.tck.NativeImageSupport\n    17\timport org.junit.jupiter.api.Test\n    18\t\n    19\timport java.nio.charset.StandardCharsets\n    20\timport java.nio.file.Files\n    21\timport java.nio.file.Path\n    22\t\n    23\timport static org.assertj.core.api.Assertions.assertThat\n    24\t\n    25\tpublic class Groovy_templatesTest {\n    26\t    @Test\n    27\t    void simpleTemplateEngineEvaluatesBindingsExpressionsAndScriptlets() {\n    28\t        String rendered = executeTemplateOperation {\n    29\t            SimpleTemplateEngine engine = new SimpleTemplateEngine()\n    30\t            Template template = engine.createTemplate('''Dear $customer.name,\n    31\t<% items.eachWithIndex { item, index -> %>\n    32\t${index + 1}. ${item.toUpperCase()}\n    33\t<% } %>\n    34\tTotal: ${items.size()}\n    35\t''')\n    36\t            template.make([\n    37\t                    customer: [name: 'Ada'],\n    38\t                    items   : ['tea', 'cake']\n    39\t            ]).toString()\n    40\t        }\n    41\t\n    42\t        if (rendered == null) {\n    43\t            return\n    44\t        }\n    45\t\n    46\t        assertThat(rendered)\n    47\t                .contains('Dear Ada')\n    48\t                .contains('1. TEA')\n    49\t                .contains('2. CAKE')\n    50\t                .contains('Total: 2')\n    51\t    }\n    52\t\n    53\t    @Test\n    54\t    void simpleTemplateEngineCreatesTemplatesFromCharsetEncodedFiles() {\n    55\t        Path tempDir = Files.createTempDirectory('groovy-templates')\n    56\t        Path templatePath = tempDir.resolve('summary.tpl')\n    57\t        try {\n    58\t            Files.writeString(templatePath, '''Résumé for $person\n    59\t<% achievements.each { achievement -> %>\n    60\t- ${achievement}\n    61\t<% } %>''', StandardCharsets.UTF_16)\n    62\t\n    63\t            String rendered = executeTemplateOperation {\n    64\t                SimpleTemplateEngine engine = new SimpleTemplateEngine()\n    65\t                Template template = engine.createTemplate(templatePath.toFile(), StandardCharsets.UTF_16)\n    66\t                template.make([\n    67\t                        person      : 'Zoë',\n    68\t                        achievements: ['naïve parser fixed', 'café menu rendered']\n    69\t                ]).toString()\n    70\t            }\n    71\t\n    72\t            if (rendered == null) {\n    73\t                return\n    74\t            }\n    75\t\n    76\t            assertThat(rendered)\n    77\t                    .contains('Résumé for Zoë')\n    78\t                    .contains('- naïve parser fixed')\n    79\t                    .contains('- café menu rendered')\n    80\t        } finally {\n    81\t            Files.deleteIfExists(templatePath)\n    82\t            Files.deleteIfExists(tempDir)\n    83\t        }\n    84\t    }\n    85\t\n    86\t    @Test\n    87\t    void streamingTemplateEngineWritesTemplatesCreatedFromReaders() {\n    88\t        String rendered = executeTemplateOperation {\n    89\t            StreamingTemplateEngine engine = new StreamingTemplateEngine()\n    90\t            String templateSource = '''Records:\n    91\t<% records.each { record -> %>${record.id}:${record.name.padRight(5)}:${record.enabled ? 'on' : 'off'}\n    92\t<% } %>'''\n    93\t            Template template = engine.createTemplate(new StringReader(templateSource))\n    94\t            StringWriter writer = new StringWriter()\n    95\t            template.make([\n    96\t                    records: [\n    97\t                            [id: 1, name: 'alpha', enabled: true],\n    98\t                            [id: 2, name: 'beta', enabled: false]\n    99\t                    ]\n   100\t            ]).writeTo(writer)\n   101\t            writer.toString()\n   102\t        }\n   103\t\n   104\t        if (rendered == null) {\n   105\t            return\n   106\t        }\n   107\t\n   108\t        assertThat(rendered)\n   109\t                .contains('Records:')\n   110\t                .contains('1:alpha:on')\n   111\t                .contains('2:beta :off')\n   112\t    }\n   113\t\n   114\t    @Test\n   115\t    void gStringTemplateEngineUsesModelValuesAndOutputWriter() {\n   116\t        String rendered = executeTemplateOperation {\n   117\t            GStringTemplateEngine engine = new GStringTemplateEngine()\n   118\t            Template template = engine.createTemplate('''Hello ${person.first} ${person.last}\n   119\t<% out << \"Roles: \" << roles.collect { it.toUpperCase() }.join(', ') %>\n   120\tMonth: ${month}\n   121\t''')\n   122\t            StringWriter writer = new StringWriter()\n   123\t            template.make([\n   124\t                    person: [first: 'Grace', last: 'Hopper'],\n   125\t                    roles : ['compiler', 'navy'],\n   126\t                    month : 'December'\n   127\t            ]).writeTo(writer)\n   128\t            writer.toString()\n   129\t        }\n   130\t\n   131\t        if (rendered == null) {\n   132\t            return\n   133\t        }\n   134\t\n   135\t        assertThat(rendered)\n   136\t                .contains('Hello Grace Hopper')\n   137\t                .contains('Roles: COMPILER, NAVY')\n   138\t                .contains('Month: December')\n   139\t    }\n   140\t\n   141\t    @Test\n   142\t    void xmlTemplateEngineEvaluatesGspScriptletsAndExpressions() {\n   143\t        String rendered = executeTemplateOperation {\n   144\t            XmlTemplateEngine engine = new XmlTemplateEngine()\n   145\t            Template template = engine.createTemplate('''<document xmlns:gsp=\"http://groovy.codehaus.org/2005/gsp\">\n   146\t  <body>\n   147\t    <gsp:scriptlet>def selected = users.findAll { it.active }</gsp:scriptlet>\n   148\t    <p>Hello, <gsp:expression>name</gsp:expression>!</p>\n   149\t    <p>Active users: <gsp:expression>selected.collect { it.name }.join(', ')</gsp:expression></p>\n   150\t  </body>\n   151\t</document>''')\n   152\t            template.make([\n   153\t                    name : 'Jean',\n   154\t                    users: [\n   155\t                            [name: 'Ada', active: true],\n   156\t                            [name: 'Alan', active: false],\n   157\t                            [name: 'Grace', active: true]\n   158\t                    ]\n   159\t            ]).toString()\n   160\t        }\n   161\t\n   162\t        if (rendered == null) {\n   163\t            return\n   164\t        }\n   165\t\n   166\t        assertThat(rendered)\n   167\t                .contains('<document>')\n   168\t                .contains('<body>')\n   169\t                .contains('<p>')\n   170\t                .contains('Hello,')\n   171\t                .contains('Jean')\n   172\t                .contains('Active users:')\n   173\t                .contains('Ada, Grace')\n   174\t                .doesNotContain('Alan')\n   175\t    }\n   176\t\n   177\t    @Test\n   178\t    void markupTemplateEngineBuildsEscapedMarkupWithConfiguration() {\n   179\t        String rendered = executeTemplateOperation {\n   180\t            TemplateConfiguration configuration = new TemplateConfiguration()\n   181\t            configuration.setAutoEscape(true)\n   182\t            configuration.setAutoIndent(true)\n   183\t            configuration.setAutoNewLine(true)\n   184\t            configuration.setUseDoubleQuotes(true)\n   185\t\n   186\t            MarkupTemplateEngine engine = new MarkupTemplateEngine(configuration)\n   187\t            Template template = engine.createTemplate('''yieldUnescaped '<!DOCTYPE html>'\n   188\thtml {\n   189\t    head {\n   190\t        title(pageTitle)\n   191\t    }\n   192\t    body {\n   193\t        h1(\"Welcome $user\")\n   194\t        ul {\n   195\t            items.each { item ->\n   196\t                li(item)\n   197\t            }\n   198\t        }\n   199\t    }\n   200\t}\n   201\t''')\n   202\t            template.make([\n   203\t                    pageTitle: 'Shopping & tasks',\n   204\t                    user     : '<Ada>',\n   205\t                    items    : ['tea', 'cake']\n   206\t            ]).toString()\n   207\t        }\n   208\t\n   209\t        if (rendered == null) {\n   210\t            return\n   211\t        }\n   212\t\n   213\t        assertThat(rendered)\n   214\t                .contains('<!DOCTYPE html>')\n   215\t                .contains('<html>')\n   216\t                .contains('<title>Shopping &amp; tasks</title>')\n   217\t                .contains('<h1>Welcome &lt;Ada&gt;</h1>')\n   218\t                .contains('<li>tea</li>')\n   219\t                .contains('<li>cake</li>')\n   220\t    }\n   221\t\n   222\t    @Test\n   223\t    void markupTemplateEngineComposesLayoutsFragmentsAndIncludedText() {\n   224\t        Path tempDir = Files.createTempDirectory('groovy-templates-layout')\n   225\t        Path layoutPath = tempDir.resolve('layout.tpl')\n   226\t        Path footerPath = tempDir.resolve('footer.txt')\n   227\t        try {\n   228\t            Files.writeString(layoutPath, '''html {\n   229\t    body {\n   230\t        section(id: sectionId) {\n   231\t            h1(pageTitle)\n   232\t            mainContents()\n   233\t        }\n   234\t        footer {\n   235\t            includeEscaped 'footer.txt'\n   236\t        }\n   237\t    }\n   238\t}\n   239\t''', StandardCharsets.UTF_8)\n   240\t            Files.writeString(footerPath, 'Generated by <Groovy & Templates>', StandardCharsets.UTF_8)\n   241\t\n   242\t            String rendered = executeTemplateOperation {\n   243\t                TemplateConfiguration configuration = new TemplateConfiguration()\n   244\t                configuration.setAutoEscape(true)\n   245\t                configuration.setUseDoubleQuotes(true)\n   246\t\n   247\t                MarkupTemplateEngine engine = new MarkupTemplateEngine(\n   248\t                        getClass().getClassLoader(),\n   249\t                        tempDir.toFile(),\n   250\t                        configuration)\n   251\t                Template template = engine.createTemplate('''layout([\n   252\t    sectionId: 'dashboard',\n   253\t    mainContents: contents({\n   254\t        p(\"Hello $visitor\")\n   255\t        fragment([items: items], 'ul { items.each { item -> li(item) } }')\n   256\t    })\n   257\t], 'layout.tpl', true)\n   258\t''')\n   259\t                template.make([\n   260\t                        pageTitle: 'Reports & metrics',\n   261\t                        visitor  : '<Ada>',\n   262\t                        items    : ['tea', 'cake']\n   263\t                ]).toString()\n   264\t            }\n   265\t\n   266\t            if (rendered == null) {\n   267\t                return\n   268\t            }\n   269\t\n   270\t            assertThat(rendered)\n   271\t                    .contains('<html>')\n   272\t                    .contains('<body>')\n   273\t                    .contains('<section id=\"dashboard\">')\n   274\t                    .contains('<h1>Reports &amp; metrics</h1>')\n   275\t                    .contains('<p>Hello &lt;Ada&gt;</p>')\n   276\t                    .contains('<ul>')\n   277\t                    .contains('<li>tea</li>')\n   278\t                    .contains('<li>cake</li>')\n   279\t                    .contains('<footer>Generated by &lt;Groovy &amp; Templates&gt;</footer>')\n   280\t        } finally {\n   281\t            Files.deleteIfExists(footerPath)\n   282\t            Files.deleteIfExists(layoutPath)\n   283\t            Files.deleteIfExists(tempDir)\n   284\t        }\n   285\t    }\n   286\t\n   287\t    private static <T> T executeTemplateOperation(Closure<T> operation) {\n   288\t        try {\n   289\t            return operation.call()\n   290\t        } catch (Error error) {\n   291\t            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n   292\t                throw error\n   293\t            }\n   294\t            return null\n   295\t        }\n   296\t    }\n   297\t}\n","exit_code":0,"status":"completed"}}
