true)\n\n            MarkupTemplateEngine engine = new MarkupTemplateEngine(configuration)\n            Template template = engine.createTemplate('''yieldUnescaped '<!DOCTYPE html>'\nhtml {\n    head {\n        title(pageTitle)\n    }\n    body {\n        h1(\"Welcome $user\")\n        ul {\n            items.each { item ->\n                li(item)\n            }\n        }\n    }\n}\n''')\n            template.make([\n                    pageTitle: 'Shopping & tasks',\n                    user     : '<Ada>',\n                    items    : ['tea', 'cake']\n            ]).toString()\n        }\n\n        if (rendered == null) {\n            return\n        }\n\n        assertThat(rendered)\n                .contains('<!DOCTYPE html>')\n                .contains('<html>')\n                .contains('<title>Shopping &amp; tasks</title>')\n                .contains('<h1>Welcome &lt;Ada&gt;</h1>')\n                .contains('<li>tea</li>')\n                .contains('<li>cake</li>')\n    }\n\n    @Test\n    void markupTemplateEngineComposesLayoutsFragmentsAndIncludedText() {\n        Path tempDir = Files.createTempDirectory('groovy-templates-layout')\n        Path layoutPath = tempDir.resolve('layout.tpl')\n        Path footerPath = tempDir.resolve('footer.txt')\n        try {\n            Files.writeString(layoutPath, '''html {\n    body {\n        section(id: sectionId) {\n            h1(pageTitle)\n            mainContents()\n        }\n        footer {\n            includeEscaped 'footer.txt'\n        }\n    }\n}\n''', StandardCharsets.UTF_8)\n            Files.writeString(footerPath, 'Generated by <Groovy & Templates>', StandardCharsets.UTF_8)\n\n            String rendered = executeTemplateOperation {\n                TemplateConfiguration configuration = new TemplateConfiguration()\n                configuration.setAutoEscape(true)\n                configuration.setUseDoubleQuotes(true)\n\n                MarkupTemplateEngine engine = new MarkupTemplateEngine(getClass().getClassLoader(), tempDir.toFile(), configuration)\n                Template template = engine.createTemplate('''layout([\n    sectionId: 'dashboard',\n    mainContents: contents {\n        p(\"Hello $visitor\")\n        fragment([items: items], 'ul { items.each { item -> li(item) } }')\n    }\n], 'layout.tpl', true)\n''')\n                template.make([\n                        pageTitle: 'Reports & metrics',\n                        visitor  : '<Ada>',\n                        items    : ['tea', 'cake']\n                ]).toString()\n            }\n\n            if (rendered == null) {\n                return\n            }\n\n            assertThat(rendered)\n                    .contains('<html>')\n                    .contains('<body>')\n                    .contains('<section id=\"dashboard\">')\n                    .contains('<h1>Reports &amp; metrics</h1>')\n                    .contains('<p>Hello &lt;Ada&gt;</p>')\n                    .contains('<ul>')\n                    .contains('<li>tea</li>')\n                    .contains('<li>cake</li>')\n                    .contains('<footer>Generated by &lt;Groovy &amp; Templates&gt;</footer>')\n        } finally {\n            Files.deleteIfExists(footerPath)\n            Files.deleteIfExists(layoutPath)\n            Files.deleteIfExists(tempDir)\n        }\n    }\n"}]}
