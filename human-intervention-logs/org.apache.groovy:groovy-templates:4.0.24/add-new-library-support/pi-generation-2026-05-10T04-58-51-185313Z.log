              doWriteIndent = false;
          }
      }
  
      private String escapeQuotes(String str) {
          String quote = configuration.isUseDoubleQuotes() ? "\"" : "'";
          String escape = configuration.isUseDoubleQuotes() ? "&quot;" : "&apos;";
          return str.replace(quote, escape);
