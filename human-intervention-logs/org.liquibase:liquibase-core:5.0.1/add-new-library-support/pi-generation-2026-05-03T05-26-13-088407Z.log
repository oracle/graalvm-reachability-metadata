  package org_liquibase.liquibase_core;
  
  import liquibase.parser.core.ParsedNode;
  import liquibase.parser.core.ParsedNodeException;
  import liquibase.resource.ResourceAccessor;
  import liquibase.serializer.AbstractLiquibaseSerializable;
  import liquibase.serializer.LiquibaseSerializable.SerializationType;
  import org.junit.jupiter.api.Test;
  
  import java.lang.reflect.Type;
  import java.sql.Date;
  import java.util.ArrayList;
  import java.util.Arrays;
  import java.util.Collection;
  import java.util.Collections;
  import java.util.LinkedHashSet;
  import java.util.List;
  import java.util.Set;
  
  import static org.junit.jupiter.api.Assertions.assertEquals;
  import static org.junit.jupiter.api.Assertions.assertInstanceOf;
  import static org.junit.jupiter.api.Assertions.assertNotNull;
  
  public class AbstractLiquibaseSerializableTest {
  
      @Test
      void loadInstantiatesSerializableCollectionElementsAndNestedObjects() throws Exception {
          ParentSerializable parent = new ParentSerializable();
          ParsedNode root = new ParsedNode(null, "parent");
          root.addChild(collectionNode("children", "from-wrapper"));
          root.addChild(childNode("nested", "from-nested-field"));
  
          parent.load(root, null);
  
          assertEquals(1, parent.children.size());
          assertEquals("child", parent.children.get(0).loadedNodeName);
          assertEquals("from-wrapper", parent.children.get(0).payload);
          assertNotNull(parent.nested);
          assertEquals("nested", parent.nested.loadedNodeName);
          assertEquals("from-nested-field", parent.nested.payload);
      }
  
      @Test
      void loadInstantiatesSerializableCollectionElementsFromElementNodes() throws Exception {
          ParentSerializable parent = new ParentSerializable();
          ParsedNode root = new ParsedNode(null, "parent");
          root.addChild(childNode("child", "from-direct-element"));
  
          parent.load(root, null);
  
          assertEquals(1, parent.children.size());
          assertEquals("child", parent.children.get(0).loadedNodeName);
          assertEquals("from-direct-element", parent.children.get(0).payload);
      }
  
      @Test
      void convertEscapedCreatesDateAndStringConstructedValues() {
          EscapedValueSerializable serializable = new EscapedValueSerializable();
  
          Object dateValue = serializable.convert("2024-01-02!{java.sql.Date}");
          Object stringConstructedValue = serializable.convert("custom-value!{java.lang.StringBuilder}");
  
          assertInstanceOf(Date.class, dateValue);
          assertEquals("2024-01-02", dateValue.toString());
          assertInstanceOf(StringBuilder.class, stringConstructedValue);
          assertEquals("custom-value", stringConstructedValue.toString());
      }
  
      private static ParsedNode collectionNode(String fieldName, String payload) throws ParsedNodeException {
          ParsedNode collection = new ParsedNode(null, fieldName);
          collection.addChild(childNode("child", payload));
          return collection;
      }
  
      private static ParsedNode childNode(String nodeName, String payload) throws ParsedNodeException {
          ParsedNode child = new ParsedNode(null, nodeName);
          child.addChild(null, "payload", payload);
          return child;
      }
  
      public static class ParentSerializable extends AbstractLiquibaseSerializable {
          private final List<ChildSerializable> children = new ArrayList<>();
          private ChildSerializable nested;
  
          @Override
          public String getSerializedObjectName() {
              return "parent";
          }
  
          @Override
          public Set<String> getSerializableFields() {
              return new LinkedHashSet<>(Arrays.asList("children", "nested"));
          }
  
          @Override
          public Object getSerializableFieldValue(String field) {
              if ("children".equals(field)) {
                  return children;
              }
              if ("nested".equals(field)) {
                  return nested;
              }
              throw new IllegalArgumentException(field);
          }
  
          @Override
          public SerializationType getSerializableFieldType(String field) {
              return SerializationType.NAMED_FIELD;
          }
  
          @Override
          public String getSerializedObjectNamespace() {
              return STANDARD_CHANGELOG_NAMESPACE;
          }
  
          @Override
          protected Class getSerializableFieldDataTypeClass(String field) {
              if ("children".equals(field)) {
                  return Collection.class;
              }
              if ("nested".equals(field)) {
                  return ChildSerializable.class;
              }
              throw new IllegalArgumentException(field);
          }
  
          @Override
          protected Type[] getSerializableFieldDataTypeClassParameters(String field) {
              if ("children".equals(field)) {
                  return new Type[] {ChildSerializable.class};
              }
              return new Type[0];
          }
  
          @Override
          protected void setSerializableFieldValue(String field, Object value) {
              if ("nested".equals(field)) {
                  nested = (ChildSerializable) value;
                  return;
              }
              throw new IllegalArgumentException(field);
          }
      }
  
      public static class ChildSerializable extends AbstractLiquibaseSerializable {
          private String loadedNodeName;
          private Object payload;
  
          public ChildSerializable() {
          }
  
          @Override
          public String getSerializedObjectName() {
              return "child";
          }
  
          @Override
          public void load(ParsedNode parsedNode, ResourceAccessor resourceAccessor) throws ParsedNodeException {
              loadedNodeName = parsedNode.getName();
              payload = parsedNode.getChildValue(null, "payload", Object.class);
          }
  
          @Override
          public Set<String> getSerializableFields() {
              return Collections.emptySet();
          }
  
          @Override
          public Object getSerializableFieldValue(String field) {
              throw new IllegalArgumentException(field);
          }
  
          @Override
          public SerializationType getSerializableFieldType(String field) {
              return SerializationType.NAMED_FIELD;
          }
  
          @Override
          public String getSerializedObjectNamespace() {
              return STANDARD_CHANGELOG_NAMESPACE;
          }
      }
  
      public static class EscapedValueSerializable extends AbstractLiquibaseSerializable {
          Object convert(Object value) {
              return convertEscaped(value);
          }
  
          @Override
          public String getSerializedObjectName() {
              return "escapedValue";
          }
  
          @Override
          public Set<String> getSerializableFields() {
              return Collections.emptySet();
          }
  
          @Override
          public Object getSerializableFieldValue(String field) {
              throw new IllegalArgumentException(field);
          }
  
          @Override
          public SerializationType getSerializableFieldType(String field) {
              return SerializationType.NAMED_FIELD;
          }
  
          @Override
          public String getSerializedObjectNamespace() {
              return STANDARD_CHANGELOG_NAMESPACE;
          }
      }
  }
