zable {\n        private final List<SerializableChild> children = new ArrayList<>();\n\n        @Override\n        public String getSerializedObjectName() {\n            return \"parent\";\n        }\n\n        public List<SerializableChild> getChildren() {\n            return children;\n        }\n    }\n\n    public static class SerializableChild extends TestSerializable {\n        private String value;\n\n        @Override\n        public String getSerializedObjectName() {\n            return \"child\";\n        }\n\n        public String getValue() {\n            return value;\n        }\n\n        public void setValue(String value) {\n            this.value = value;\n        }\n    }\n\n    public static class EscapedValuesSerializable extends TestSerializable {\n        private Date timestamp;\n        private StringBuilder builder;\n\n        @Override\n        public String getSerializedObjectName() {\n            return \"escapedValues\";\n        }\n\n        @Override\n        public SerializationType getSerializableFieldType(String field) {\n            return SerializationType.NAMED_FIELD;\n        }\n\n        public Date getTimestamp() {\n            return timestamp;\n        }\n\n        public void setTimestamp(Date timestamp) {\n            this.timestamp = timestamp;\n        }\n\n        public StringBuilder getBuilder() {\n            return builder;\n        }\n\n        public void setBuilder(StringBuilder builder) {\n            this.builder = builder;\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777742839745}}
