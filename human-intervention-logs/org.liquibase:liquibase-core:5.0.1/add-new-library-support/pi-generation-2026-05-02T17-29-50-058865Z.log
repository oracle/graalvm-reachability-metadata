k. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_liquibase.liquibase_core;\n\nimport liquibase.changelog.ChangeLogProperty;\nimport liquibase.parser.core.ParsedNode;\nimport liquibase.resource.ClassLoaderResourceAccessor;\nimport liquibase.serializer.AbstractLiquibaseSerializable;\nimport liquibase.serializer.LiquibaseSerializable.SerializationType;\nimport liquibase.util.ISODateFormat;\nimport org.junit.jupiter.api.Test;\n\nimport java.util.ArrayList;\nimport java.util.Date;\nimport java.util.List;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class AbstractLiquibaseSerializableTest {\n\n    @Test\n    void loadsExplicitCollectionAndNestedSerializableFields() throws Exception {\n        ParentSerializable serializable = new ParentSerializable();\n        ParsedNode parsedNode = new ParsedNode(null, \"parent\");\n        parsedNode.addChild(new ParsedNode(null, \"properties\")\n                .addChild(propertyNode(\"collection-name\", \"collection-value\")));\n        parsedNode.addChild(propertyNode(\"nested-name\", \"nested-value\"));\n\n        serializable.load(parsedNode, new ClassLoaderResourceAccessor());\n\n        assertThat(serializable.getProperties())\n                .extracting(ChangeLogProperty::getName)\n                .containsExactly(\"collection-name\");\n        assertThat(serializable.getProperty().getValue()).isEqualTo(\"nested-value\");\n    }\n\n    @Test\n    void loadsCollectionWhenParsedNodeUsesElementName() throws Exception {\n        ImplicitCollectionSerializable serializable = new ImplicitCollectionSerializable();\n        ParsedNode parsedNode = new ParsedNode(null, \"parent\");\n        parsedNode.addChild(propertyNode(\"implicit-name\", \"implicit-collection-value\"));\n\n        serializable.load(parsedNode, new ClassLoaderResourceAccessor());\n\n        assertThat(serializable.getProperties())\n                .extracting(ChangeLogProperty::getValue)\n                .containsExactly(\"implicit-collection-value\");\n    }\n\n    @Test\n    void loadsEscapedValuesRequiringConstructors() throws Exception {\n        EscapedValuesSerializable serializable = new EscapedValuesSerializable();\n        ParsedNode parsedNode = new ParsedNode(null, \"escapedValues\");\n        parsedNode.addChild(null, \"timestamp\", \"2024-01-02T03:04:05!{java.util.Date}\");\n        parsedNode.addChild(null, \"builder\", \"liquibase!{java.lang.StringBuilder}\");\n\n        serializable.load(parsedNode, new ClassLoaderResourceAccessor());\n\n        assertThat(new ISODateFormat().format(serializable.getTimestamp())).isEqualTo(\"2024-01-02T03:04:05\");\n        assertThat(serializable.getBuilder().toString()).isEqualTo(\"liquibase\");\n    }\n\n    private static ParsedNode propertyNode(String name, String value) throws Exception {\n        return new ParsedNode(null, \"property\")\n                .addChild(null, \"name\", name)\n                .addChild(null, \"value\", value);\n    }\n\n    public abstract static class TestSerializable extends AbstractLiquibaseSerializable {\n        @Override\n        public String getSerializedObjectNamespace() {\n            return null;\n        }\n    }\n\n    public static class ParentSerializable extends TestSerializable {\n        private final List<ChangeLogProperty> properties = new ArrayList<>();\n        private ChangeLogProperty property;\n\n        @Override\n        public String getSerializedObjectName() {\n            return \"parent\";\n        }\n\n        public List<ChangeLogProperty> getProperties() {\n            return properties;\n        }\n\n        public ChangeLogProperty getProperty() {\n            return property;\n        }\n    }\n\n    public static class ImplicitCollectionSerializable extends TestSerializable {\n        private final List<ChangeLogProperty> properties = new ArrayList<>();\n\n        @Override\n        public String getSerializedObjectName() {\n            return \"parent\";\n        }\n\n        public List<ChangeLogProperty> getProperties() {\n            return properties;\n        }\n    }\n\n    public static class EscapedValuesSerializable extends TestSerializable {\n        private Date timestamp;\n        private StringBuilder builder;\n\n        @Override\n        public String getSerializedObjectName() {\n            return \"escapedValues\";\n        }\n\n        @Override\n        public SerializationType getSerializableFieldType(String field) {\n            return SerializationType.NAMED_FIELD;\n        }\n\n        public Date getTimestamp() {\n            return timestamp;\n        }\n\n        public void setTimestamp(Date timestamp) {\n            this.timestamp = timestamp;\n        }\n\n        public StringBuilder getBuilder() {\n            return builder;\n        }\n\n        public void setBuilder(StringBuilder builder) {\n            this.builder = builder;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 788, "output": 1693, "cacheRead": 44032, "cacheWrite": 0, "totalTokens": 46513, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777742879707, "responseId": "resp_0257d767d56de5ab0169f6342043e0819cafe0ee447020950e"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_LrkgA3GmHiCaM7dI4OMCRlmk|fc_0257d767d56de5ab0169f634298794819cb8d5545adf85b8f7", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 4901 bytes to tests/src/org.liquibase/liquibase-core/5.0.1/src/test/java/org_liquibase/liquibase_core/AbstractLiquibaseSerializableTest.java"}], "isError": false, "timestamp": 1777742893744}]}
