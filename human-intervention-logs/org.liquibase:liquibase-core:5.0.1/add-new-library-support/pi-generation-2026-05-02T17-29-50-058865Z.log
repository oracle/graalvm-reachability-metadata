   ImplicitCollectionSerializable serializable = new ImplicitCollectionSerializable();\n        ParsedNode parsedNode = new ParsedNode(null, \"parent\");\n        parsedNode.addChild(new ParsedNode(null, \"child\")\n                .addChild(null, \"value\", \"implicit-collection-value\"));\n\n        serializable.load(parsedNode, new ClassLoaderResourceAccessor());\n\n        assertThat(serializable.getChildren())\n                .extracting(SerializableChild::getValue)\n                .containsExactly(\"implicit-collection-value\");\n    }\n\n    @Test\n    void loadsEscapedValuesRequiringConstructors() throws Exception {\n        EscapedValuesSerializable serializable = new EscapedValuesSerializable();\n        ParsedNode parsedNode = new ParsedNode(null, \"escapedValues\");\n        parsedNode.addChild(null, \"timestamp\", \"2024-01-02T03:04:05!{java.util.Date}\");\n        parsedNode.addChild(null, \"builder\", \"liquibase!{java.lang.StringBuilder}\");\n\n        serializable.load(parsedNode, new ClassLoaderResourceAccessor());\n\n        assertThat(new ISODateFormat().format(serializable.getTimestamp())).isEqualTo(\"2024-01-02T03:04:05\");\n        assertThat(serializable.getBuilder().toString()).isEqualTo(\"liquibase\");\n    }\n\n    public abstract static class TestSerializable extends AbstractLiquibaseSerializable {\n        @Override\n        public String getSerializedObjectNamespace() {\n            return null;\n        }\n    }\n\n    public static class ParentSerializable extends TestSerializable {\n        private final List<SerializableChild> children = new ArrayList<>();\n        private SerializableChild child;\n\n        @Override\n        public String getSerializedObjectName() {\n            return \"parent\";\n        }\n\n        public List<SerializableChild> getChildren() {\n            return children;\n        }\n\n        public SerializableChild getChild() {\n            return child;\n        }\n    }\n\n    public static class ImplicitCollectionSerializable extends TestSerializable {\n        private final List<SerializableChild> children = new ArrayList<>();\n\n        @Override\n        public String getSerializedObjectName() {\n            return \"parent\";\n        }\n\n        public List<SerializableChild> getChildren() {\n            return children;\n        }\n    }\n\n    public static class SerializableChild extends TestSerializable {\n        private String value;\n\n        @Override\n        public String getSerializedObjectName() {\n            return \"child\";\n        }\n\n        public String getValue() {\n            return value;\n        }\n\n        public void setValue(String value) {\n            this.value = value;\n        }\n    }\n\n    public static class EscapedValuesSerializable extends TestSerializable {\n        private Date timestamp;\n        private StringBuilder builder;\n\n        @Override\n        public String getSerializedObjectName() {\n            return \"escapedValues\";\n        }\n\n        @Override\n        public SerializationType getSerializableFieldType(String field) {\n            return SerializationType.NAMED_FIELD;\n        }\n\n        public Date getTimestamp() {\n            return timestamp;\n        }\n\n        public void setTimestamp(Date timestamp) {\n            this.timestamp = timestamp;\n        }\n\n        public StringBuilder getBuilder() {\n            return builder;\n        }\n\n        public void setBuilder(StringBuilder builder) {\n            this.builder = builder;\n        }\n    }\n}\n"}
