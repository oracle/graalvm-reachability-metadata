[tool-call] delta {"path":"tests/src/org.liquibase/liquibase-core/5.0.1/src/test/java/org_liquibase/liquibase_core/DatabaseFactoryTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_liquibase.liquibase_core;\n\nimport liquibase.database.Database;\nimport liquibase.database.DatabaseConnection;\nimport liquibase.database.DatabaseFactory;\nimport liquibase.database.core.H2Database;\nimport liquibase.resource.ClassLoaderResourceAccessor;\nimport org.junit.jupiter.api.AfterEach;\nimport org.junit.jupiter.api.Test;\n\nimport java.util.Properties;\nimport java.util.UUID;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class DatabaseFactoryTest {\n    private static final String H2_DRIVER = \"org.h2.Driver\";\n\n    @AfterEach\n    void resetDatabaseFactory() {\n        DatabaseFactory.reset();\n        DriverProperties.reset();\n    }\n\n    @Test\n    void opensExplicitDatabaseWithCustomDriverProperties() throws Exception {\n        DriverProperties.reset();\n        String jdbcUrl = \"jdbc:h2:mem:\" + UUID.randomUUID() + \";DB_CLOSE_DELAY=0\";\n\n        try (Database database = DatabaseFactory.getInstance().openDatabase(\n                jdbcUrl,\n                \"sa\",\n                \"password\",\n                H2_DRIVER,\n                H2Database.class.getName(),\n                null,\n                DriverProperties.class.getName(),\n                new ClassLoaderResourceAccessor())) {\n            DatabaseConnection connection = database.getConnection();\n\n            assertThat(database).isInstanceOf(H2Database.class);\n            assertThat(connection).isNotNull();\n            assertThat(connection.isClosed()).isFalse();\n            assertThat(DriverProperties.wasConstructed()).isTrue();\n        }\n    }\n\n    public static final class DriverProperties extends Properties {\n        private static boolean constructed;\n\n        public DriverProperties() {\n            constructed = true;\n        }\n\n        static boolean wasConstructed() {\n            return constructed;\n        }\n\n        static void reset() {\n            constructed = false;\n        }\n    }\n}\n"}
