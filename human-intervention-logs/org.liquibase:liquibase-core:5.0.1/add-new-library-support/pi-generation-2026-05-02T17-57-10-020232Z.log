sertThat(DriverProperties.wasConstructed()).isTrue();\n        }\n    }\n\n    public static final class DriverProperties extends Properties {\n        private static boolean constructed;\n\n        public DriverProperties() {\n            constructed = true;\n        }\n\n        static boolean wasConstructed() {\n            return constructed;\n        }\n\n        static void reset() {\n            constructed = false;\n        }\n    }\n}\n"}
