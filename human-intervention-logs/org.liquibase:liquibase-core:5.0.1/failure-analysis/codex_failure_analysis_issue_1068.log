edNode(null, \\\"parent\\\");\\n        parsedNode.addChild(propertyNode(\\\"implicit-name\\\", \\\"implicit-collection-value\\\"));\\n\\n        serializable.load(parsedNode, null);\\n\\n        assertThat(serializable.getProperties())\\n                .extracting(ChangeLogProperty::getValue)\\n                .containsExactly(\\\"implicit-collection-value\\\");\\n    }\\n\\n    @Test\\n    void loadsEscapedValuesRequiringConstructors() throws Exception {\\n        EscapedValuesSerializable serializable = new EscapedValuesSerializable();\\n        ParsedNode parsedNode = new ParsedNode(null, \\\"escapedValues\\\");\\n        parsedNode.addChild(null, \\\"timestamp\\\", \\\"2024-01-02T03:04:05!{java.util.Date}\\\");\\n        parsedNode.addChild(null, \\\"databaseFunction\\\", \\\"liquibase!{liquibase.statement.DatabaseFunction}\\\");\\n\\n        serializable.load(parsedNode, null);\\n\\n        assertThat(new ISODateFormat().format(serializable.getTimestamp())).isEqualTo(\\\"2024-01-02T03:04:05\\\");\\n        assertThat(serializable.getDatabaseFunction().getValue()).isEqualTo(\\\"liquibase\\\");\\n    }\\n\\n    private static ParsedNode propertyNode(String name, String value) throws Exception {\\n        return new ParsedNode(null, \\\"property\\\")\\n                .addChild(null, \\\"name\\\", name)\\n                .addChild(null, \\\"value\\\", value);\\n    }\\n\\n    public abstract static class TestSerializable extends AbstractLiquibaseSerializable {\\n        @Override\\n        public String getSerializedObjectNamespace() {\\n            return null;\\n        }\\n    }\\n\\n    public static class ParentSerializable extends TestSerializable {\\n        private final List<ChangeLogProperty> properties = new ArrayList<>();\\n        private ChangeLogProperty property;\\n\\n        @Override\\n        public String getSerializedObjectName() {\\n            return \\\"parent\\\";\\n        }\\n\\n        public List<ChangeLogProperty> getProperties() {\