pe;\\nimport org.junit.jupiter.api.Test;\\n\\nimport java.lang.reflect.Type;\\nimport java.sql.Date;\\nimport java.util.ArrayList;\\nimport java.util.Arrays;\\nimport java.util.Collection;\\nimport java.util.Collections;\\nimport java.util.LinkedHashSet;\\nimport java.util.List;\\nimport java.util.Set;\\n\\nimport static org.junit.jupiter.api.Assertions.assertEquals;\\nimport static org.junit.jupiter.api.Assertions.assertInstanceOf;\\nimport static org.junit.jupiter.api.Assertions.assertNotNull;\\n\\npublic class AbstractLiquibaseSerializableTest {\\n\\n    @Test\\n    void loadInstantiatesSerializableCollectionElementsAndNestedObjects() throws Exception {\\n        ParentSerializable parent = new ParentSerializable();\\n        ParsedNode root = new ParsedNode(null, \\\"parent\\\");\\n        root.addChild(collectionNode(\\\"children\\\", \\\"from-wrapper\\\"));\\n        root.addChild(childNode(\\\"nested\\\", \\\"from-nested-field\\\"));\\n\\n        parent.load(root, null);\\n\\n        assertEquals(1, parent.children.size());\\n        assertEquals(\\\"child\\\", parent.children.get(0).loadedNodeName);\\n        assertEquals(\\\"from-wrapper\\\", parent.children.get(0).payload);\\n        assertNotNull(parent.nested);\\n        assertEquals(\\\"nested\\\", parent.nested.loadedNodeName);\\n        assertEquals(\\\"from-nested-field\\\", parent.nested.payload);\\n    }\\n\\n    @Test\\n    void loadInstantiatesSerializableCollectionElementsFromElementNodes() throws Exception {\\n        ParentSerializable parent = new ParentSerializable();\\n        ParsedNode root = new ParsedNode(null, \\\"parent\\\");\\n        root.addChild(childNode(\\\"child\\\", \\\"from-direct-element\\\"));\\n\\n        parent.load(root, null);\\n\\n        assertEquals(1, parent.children.size());\\n        assertEquals(\\\"child\\\", parent.children.get(0).loadedNodeName);\\n        assertEquals(\\\"from-direct-element\\\", parent.children.get(0).payload);\\n    }\\n\\n    @Test\\n    void convertEscapedCreatesDateAndStringConstructedValues() {\\n        EscapedValueSerializable serializable = new EscapedValueSerializable();\\n\\n        Object dateValue = serializable.convert(\\\"2024-01-02!{java.sql.Date}\\\");\\n        Object stringConstructedValue = serializable.convert(\\\"custom-value!{java.lang.StringBuilder}\\\");\\n\\n        assertInstanceOf(Date.class, dateValue);\\n        assertEquals(\\\"2024-01-02\\\", dateValue.toString());\\n        assertInstanceOf(StringBuilder.class, stringConstructedValue);\\n        assertEquals(\\\"custom-value\\\", stringConstructedValue.toString());\\n    }\\n\\n    private static ParsedNode collectionNode(String fieldName, String payload) throws ParsedNodeException {\\n        ParsedNode collection = new ParsedNode(null, fieldName);\\n        collection.addChild(childNode(\\\"child\\\", payload));\\n        return collection;\\n    }\\n\\n    private static ParsedNode childNode(String nodeName, String payload) throws ParsedNodeException {\\n        ParsedNode child = new ParsedNode(null, nodeName);\\n        child.addChild(null, \\\"payload\\\", payload);\\n        return child;\\n    }\\n\\n    public static class ParentSerializable extends AbstractLiquibaseSerializable {\\n        private final List<ChildSerializable> children = new ArrayList<>();\\n        private ChildSerializable nested;\\n\\n        @Override\\n        public String getSerializedObjectName() {\\n            return \\\"parent\\\";\\n        }\\n\\n        @Override\\n        public Set<String> getSerializableFields() {\\n            return new LinkedHashSet<>(Arrays.asList(\\\"children\\\", \\\"nested\\\"));\\n        }\\n\\n        @Override\\n        public Object getSerializableFieldValue(String field) {\\n            if (\\\"children\\\".equals(field)) {\\n                return children;\\n            }\\n            if (\\\"nested\\\".equals(field)) {\\n                return nested;\\n            }\\n            throw new IllegalArgumentException(field);\\n        }\\n\\n        @Override\\n        public SerializationType getSerializableFieldType(String field) {\\n            return SerializationType.NAMED_FIELD;\\n        }\\n\\n        @Override\\n        public String getSerializedObjectNamespace() {\\n            return STANDARD_CHANGELOG_NAMESPACE;\\n        }\\n\\n        @Override\\n        protected Class getSerializableFieldDataTypeClass(String field) {\\n            if (\\\"children\\\".equals(field)) {\\n                return Collection.class;\\n            }\\n            if (\\\"nested\\\".equals(field)) {\\n                return ChildSerializable.class;\\n            }\\n            throw new IllegalArgumentException(field);\\n        }\\n\\n        @Override\\n        protected Type[] getSerializableFieldDataTypeClassParameters(String field) {\\n            if (\\\"children\\\".equals(field)) {\\n                return new Type[] {ChildSerializable.class};\\n            }\\n            return new Type[0];\\n        }\\n\\n        @Override\\n        protected void setSerializableFieldValue(String field, Object value) {\\n            if (\\\"nested\\\".equals(field)) {\\n                nested = (ChildSerializable) value;\\n                return;\\n            }\\n            throw new IllegalArgumentException(field);\\n        }\\n    }\\n\\n    public static class ChildSerializable extends AbstractLiquibaseSerializable {\\n        private String loadedNodeName;\\n        private Object payload;\\n\\n        public ChildSerializable() {\\n        }\\n\\n        @Override\\n        public String getSerializedObjectName() {\\n            return \\\"child\\\";\\n        }\\n\\n        @Override\\n        public void load(ParsedNode parsedNode, ResourceAccessor resourceAccessor) throws ParsedNodeException {\\n            loadedNodeName = parsedNode.getName();\\n            payload = parsedNode.getChildValue(null, \\\"payload\\\", Object.class);\\n        }\\n\\n        @Override\\n        public Set<String> getSerializableFields() {\\n            return Collections.emptySet();\\n        }\\n\\n        @Override\\n        public Object getSerializableFieldValue(String field) {\\n            throw new IllegalArgumentException(field);\\n        }\\n\\n        @Override\\n        public SerializationType getSerializableFieldType(String field) {\\n            return SerializationType.NAMED_FIELD;\\n        }\\n\\n        @Override\\n        public String getSerializedObjectNamespace() {\\n            return STANDARD_CHANGELOG_NAMESPACE;\\n        }\\n    }\\n\\n    public static class EscapedValueSerializable extends AbstractLiquibaseSerializable {\\n        Object convert(Object value) {\\n            return convertEscaped(value);\\n        }\\n\\n        @Override\\n        public String getSerializedObjectName() {\\n            return \\\"escapedValue\\\";\\n        }\\n\\n        @Override\\n        public Set<String> getSerializableFields() {\\n            return Collections.emptySet();\\n        }\\n\\n        @Override\\n        public Object getSerializableFieldValue(String field) {\\n            throw new IllegalArgumentException(field);\\n        }\\n\\n        @Override\\n        public SerializationType getSerializableFieldType(String field) {\\n            return SerializationType.NAMED_FIELD;\\n        }\\n\\n        @Override\\n        public String getSerializedObjectNamespace() {\\n            return STANDARD_CHANGELOG_NAMESPACE;\\n        }\\n    }\\n}\\n\"}}], \"api\": \"openai-responses\", \"provider\": \"OCA\", \"model\": \"gpt-5.5\", \"usage\": {\"input\": 2279, \"output\": 2690, \"cacheRead\": 17408, \"cacheWrite\": 0, \"totalTokens\": 22377, \"cost\": {\"input\": 0, \"output\": 0, \"cacheRead\": 0, \"cacheWrite\": 0, \"total\": 0}}, \"stopReason\": \"toolUse\", \"timestamp\": 1777785904839, \"responseId\": \"resp_013fbec7b215339c0169f6dc314738819d8bc3a054a211859b\"}}\n1650:[tool-exec] start id=call_Ks4o6SNsHjtNFqy