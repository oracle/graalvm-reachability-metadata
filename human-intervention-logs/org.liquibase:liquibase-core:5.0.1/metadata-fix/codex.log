{"type":"item.completed","item":{"id":"item_23","type":"command_execution","command":"/usr/bin/bash -lc \"sed -n '1,260p' tests/src/org.liquibase/liquibase-core/5.0.1/src/test/java/org_liquibase/liquibase_core/AbstractLiquibaseSerializableTest.java\"","aggregated_output":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_liquibase.liquibase_core;\n\nimport liquibase.changelog.ChangeLogProperty;\nimport liquibase.parser.core.ParsedNode;\nimport liquibase.serializer.AbstractLiquibaseSerializable;\nimport liquibase.serializer.LiquibaseSerializable.SerializationType;\nimport liquibase.statement.DatabaseFunction;\nimport liquibase.util.ISODateFormat;\nimport org.junit.jupiter.api.Test;\n\nimport java.util.ArrayList;\nimport java.util.Date;\nimport java.util.List;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class AbstractLiquibaseSerializableTest {\n\n    @Test\n    void loadsExplicitCollectionAndNestedSerializableFields() throws Exception {\n        ParentSerializable serializable = new ParentSerializable();\n        ParsedNode parsedNode = new ParsedNode(null, \"parent\");\n        parsedNode.addChild(new ParsedNode(null, \"properties\")\n                .addChild(propertyNode(\"collection-name\", \"collection-value\")));\n        parsedNode.addChild(propertyNode(\"nested-name\", \"nested-value\"));\n\n        serializable.load(parsedNode, null);\n\n        assertThat(serializable.getProperties())\n                .extracting(ChangeLogProperty::getName)\n                .containsExactly(\"collection-name\");\n        assertThat(serializable.getProperty().getValue()).isEqualTo(\"nested-value\");\n    }\n\n    @Test\n    void loadsCollectionWhenParsedNodeUsesElementName() throws Exception {\n        ImplicitCollectionSerializable serializable = new ImplicitCollectionSerializable();\n        ParsedNode parsedNode = new ParsedNode(null, \"parent\");\n        parsedNode.addChild(propertyNode(\"implicit-name\", \"implicit-collection-value\"));\n\n        serializable.load(parsedNode, null);\n\n        assertThat(serializable.getProperties())\n                .extracting(ChangeLogProperty::getValue)\n                .containsExactly(\"implicit-collection-value\");\n    }\n\n    @Test\n    void loadsEscapedValuesRequiringConstructors() throws Exception {\n        EscapedValuesSerializable serializable = new EscapedValuesSerializable();\n        ParsedNode parsedNode = new ParsedNode(null, \"escapedValues\");\n        parsedNode.addChild(null, \"timestamp\", \"2024-01-02T03:04:05!{java.util.Date}\");\n        parsedNode.addChild(null, \"databaseFunction\", \"liquibase!{liquibase.statement.DatabaseFunction}\");\n\n        serializable.load(parsedNode, null);\n\n        assertThat(new ISODateFormat().format(serializable.getTimestamp())).isEqualTo(\"2024-01-02T03:04:05\");\n        assertThat(serializable.getDatabaseFunction().getValue()).isEqualTo(\"liquibase\");\n    }\n\n    private static ParsedNode propertyNode(String name, String value) throws Exception {\n        return new ParsedNode(null, \"property\")\n                .addChild(null, \"name\", name)\n                .addChild(null, \"value\", value);\n    }\n\n    public abstract static class TestSerializable extends AbstractLiquibaseSerializable {\n        @Override\n        public String getSerializedObjectNamespace() {\n            return null;\n        }\n    }\n\n    public static class ParentSerializable extends TestSerializable {\n        private final List<ChangeLogProperty> properties = new ArrayList<>();\n        private ChangeLogProperty property;\n\n        @Override\n        public String getSerializedObjectName() {\n            return \"parent\";\n        }\n\n        public List<ChangeLogProperty> getProperties() {\n            return properties;\n        }\n\n        public ChangeLogProperty getProperty() {\n            return property;\n        }\n    }\n\n    public static class ImplicitCollectionSerializable extends TestSerializable {\n        private final List<ChangeLogProperty> properties = new ArrayList<>();\n\n        @Override\n        public String getSerializedObjectName() {\n            return \"parent\";\n        }\n\n        public List<ChangeLogProperty> getProperties() {\n            return properties;\n        }\n    }\n\n    public static class EscapedValuesSerializable extends TestSerializable {\n        private Date timestamp;\n        private DatabaseFunction databaseFunction;\n\n        @Override\n        public String getSerializedObjectName() {\n            return \"escapedValues\";\n        }\n\n        @Override\n        public SerializationType getSerializableFieldType(String field) {\n            return SerializationType.NAMED_FIELD;\n        }\n\n        public Date getTimestamp() {\n            return timestamp;\n        }\n\n        public void setTimestamp(Date timestamp) {\n            this.timestamp = timestamp;\n        }\n\n        public DatabaseFunction getDatabaseFunction() {\n            return databaseFunction;\n        }\n\n        public void setDatabaseFunction(DatabaseFunction databaseFunction) {\n            this.databaseFunction = databaseFunction;\n        }\n    }\n}\n","exit_code":0,"status":"completed"}}
