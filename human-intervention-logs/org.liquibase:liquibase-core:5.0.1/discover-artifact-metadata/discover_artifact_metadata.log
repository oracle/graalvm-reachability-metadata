            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-source-plugin</artifactId>
                <version>3.3.1</version>
                <configuration>
                    <!-- sources.jar from this module is the shaded sources of others  -->
                    <skipSource>true</skipSource>
