[tool-call] delta {"path":"tests/src/org.bouncycastle/bcutil-jdk18on/1.77/src/test/java/org_bouncycastle/bcutil_jdk18on/ItsUtilsAnonymous1Test.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcutil_jdk18on;\n\nimport java.math.BigInteger;\nimport java.util.List;\n\nimport org.bouncycastle.asn1.ASN1Integer;\nimport org.bouncycastle.asn1.ASN1Sequence;\nimport org.bouncycastle.oer.its.ItsUtils;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ItsUtilsAnonymous1Test {\n    private BigInteger value;\n\n    public ItsUtilsAnonymous1Test() {\n    }\n\n    private ItsUtilsAnonymous1Test(BigInteger value) {\n        this.value = value;\n    }\n\n    public static ItsUtilsAnonymous1Test getInstance(Object source) {\n        ASN1Integer integer = ASN1Integer.getInstance(source);\n        return new ItsUtilsAnonymous1Test(integer.getValue());\n    }\n\n    @Test\n    @SuppressWarnings(\"deprecation\")\n    void fillsListByCallingSuppliedTypeFactoryForEachSequenceItem() {\n        ASN1Sequence sequence = ItsUtils.toSequence(new ASN1Integer(7), new ASN1Integer(255));\n\n        List<ItsUtilsAnonymous1Test> values = ItsUtils.fillList(ItsUtilsAnonymous1Test.class, sequence);\n\n        assertThat(values).hasSize(2);\n        assertThat(values.get(0).value).isEqualTo(BigInteger.valueOf(7));\n        assertThat(values.get(1).value).isEqualTo(BigInteger.valueOf(255));\n    }\n}\n"}
[tool-call] end id=call_HyZTdXAN5cIWEvVhCELdPzl3|fc_0fdae1f3b7cf2e3e016a25dc725530819792549d1e0b096253 name=write args={"path": "tests/src/org.bouncycastle/bcutil-jdk18on/1.77/src/test/java/org_bouncycastle/bcutil_jdk18on/ItsUtilsAnonymous1Test.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcutil_jdk18on;\n\nimport java.math.BigInteger;\nimport java.util.List;\n\nimport org.bouncycastle.asn1.ASN1Integer;\nimport org.bouncycastle.asn1.ASN1Sequence;\nimport org.bouncycastle.oer.its.ItsUtils;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ItsUtilsAnonymous1Test {\n    private BigInteger value;\n\n    public ItsUtilsAnonymous1Test() {\n    }\n\n    private ItsUtilsAnonymous1Test(BigInteger value) {\n        this.value = value;\n    }\n\n    public static ItsUtilsAnonymous1Test getInstance(Object source) {\n        ASN1Integer integer = ASN1Integer.getInstance(source);\n        return new ItsUtilsAnonymous1Test(integer.getValue());\n    }\n\n    @Test\n    @SuppressWarnings(\"deprecation\")\n    void fillsListByCallingSuppliedTypeFactoryForEachSequenceItem() {\n        ASN1Sequence sequence = ItsUtils.toSequence(new ASN1Integer(7), new ASN1Integer(255));\n\n        List<ItsUtilsAnonymous1Test> values = ItsUtils.fillList(ItsUtilsAnonymous1Test.class, sequence);\n\n        assertThat(values).hasSize(2);\n        assertThat(values.get(0).value).isEqualTo(BigInteger.valueOf(7));\n        assertThat(values.get(1).value).isEqualTo(BigInteger.valueOf(255));\n    }\n}\n"}
