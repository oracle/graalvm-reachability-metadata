  package org_bouncycastle.bcutil_jdk18on;
  
  import java.math.BigInteger;
  import java.util.List;
  
  import org.bouncycastle.asn1.ASN1Integer;
  import org.bouncycastle.asn1.ASN1Sequence;
  import org.bouncycastle.oer.its.ItsUtils;
  import org.bouncycastle.oer.its.ieee1609dot2.basetypes.UINT16;
  import org.bouncycastle.oer.its.ieee1609dot2.basetypes.UINT8;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ItsUtilsAnonymous1Test {
      @Test
      @SuppressWarnings("deprecation")
      void fillsListByCallingElementTypeFactoryForEachSequenceItem() {
          ASN1Sequence sequence = ItsUtils.toSequence(new ASN1Integer(7), new ASN1Integer(255));
  
          UINT8 directlyDecoded = UINT8.getInstance(new ASN1Integer(1));
          List<UINT8> values = ItsUtils.fillList(UINT8.class, sequence);
  
          assertThat(directlyDecoded.getValue()).isEqualTo(BigInteger.ONE);
          assertThat(values).hasSize(2);
          assertThat(values.get(0).getValue()).isEqualTo(BigInteger.valueOf(7));
          assertThat(values.get(1).getValue()).isEqualTo(BigInteger.valueOf(255));
      }
  
      @Test
      @SuppressWarnings("deprecation")
      void fillsListForAnotherUnsignedIntegerFactory() {
          ASN1Sequence sequence = ItsUtils.toSequence(new ASN1Integer(1024), new ASN1Integer(4096));
  
          UINT16 directlyDecoded = UINT16.getInstance(new ASN1Integer(16));
          List<UINT16> values = ItsUtils.fillList(UINT16.class, sequence);
  
          assertThat(directlyDecoded.getValue()).isEqualTo(BigInteger.valueOf(16));
          assertThat(values).hasSize(2);
          assertThat(values.get(0).getValue()).isEqualTo(BigInteger.valueOf(1024));
          assertThat(values.get(1).getValue()).isEqualTo(BigInteger.valueOf(4096));
      }
  }
