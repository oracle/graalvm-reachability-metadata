stle/bcutil-jdk18on/1.77/src/test/java/org_bouncycastle/bcutil_jdk18on/OEROptionalAnonymous1Test.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcutil_jdk18on;\n\nimport java.math.BigInteger;\n\nimport org.bouncycastle.asn1.ASN1Integer;\nimport org.bouncycastle.oer.OEROptional;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class OEROptionalAnonymous1Test {\n    private BigInteger value;\n\n    public OEROptionalAnonymous1Test() {\n    }\n\n    private OEROptionalAnonymous1Test(BigInteger value) {\n        this.value = value;\n    }\n\n    public static OEROptionalAnonymous1Test getInstance(Object source) {\n        ASN1Integer integer = ASN1Integer.getInstance(source);\n        return new OEROptionalAnonymous1Test(integer.getValue());\n    }\n\n    @Test\n    void returnsOptionalValueThroughTargetTypeFactory() {\n        ASN1Integer encodedValue = new ASN1Integer(42);\n        OEROptional optionalValue = OEROptional.getInstance(encodedValue);\n\n        OEROptionalAnonymous1Test decodedValue = optionalValue.getObject(OEROptionalAnonymous1Test.class);\n\n        assertThat(optionalValue.isDefined()).isTrue();\n        assertThat(decodedValue).isNotNull();\n        assertThat(decodedValue.value).isEqualTo(BigInteger.valueOf(42));\n    }\n}\n"}, "partialJson": "{\"path\":\"tests/src/org.bouncycastle/bcutil-jdk18on/1.77/src/test/java/org_bouncycastle/bcutil_jdk18on/OEROptionalAnonymous1Test.java\",\"content\":\"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage org_bouncycastle.bcutil_jdk18on;\\n\\nimport java.math.BigInteger;\\n\\nimport org.bouncycastle.asn1.ASN1Integer;\\nimport org.bouncycastle.oer.OEROptional;\\nimport org.junit.jupiter.api.Test;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\n\\npublic class OEROptionalAnonymous1Test {\\n    private BigInteger value;\\n\\n    public OEROptionalAnonymous1Test() {\\n    }\\n\\n    private OEROptionalAnonymous1Test(BigInteger value) {\\n        this.value = value;\\n    }\\n\\n    public static OEROptionalAnonymous1Test getInstance(Object source) {\\n        ASN1Integer integer = ASN1Integer.getInstance(source);\\n        return new OEROptionalAnonymous1Test(integer.getValue());\\n    }\\n\\n    @Test\\n    void returnsOptionalValueThroughTargetTypeFactory() {\\n        ASN1Integer encodedValue = new ASN1Integer(42);\\n        OEROptional optionalValue = OEROptional.getInstance(encodedValue);\\n\\n        OEROptionalAnonymous1Test decodedValue = optionalValue.getObject(OEROptionalAnonymous1Test.class);\\n\\n        assertThat(optionalValue.isDefined()).isTrue();\\n        assertThat(decodedValue).isNotNull();\\n        assertThat(decodedValue.value).isEqualTo(BigInteger.valueOf(42));\\n    }\\n}\\n\"}"}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1929, "output": 2134, "cacheRead": 41472, "cacheWrite": 0, "totalTokens": 45535, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780866165613, "responseId": "resp_0fdae1f3b7cf2e3e016a25dc7694e08197bbcfcfce37bbe03d"}}
