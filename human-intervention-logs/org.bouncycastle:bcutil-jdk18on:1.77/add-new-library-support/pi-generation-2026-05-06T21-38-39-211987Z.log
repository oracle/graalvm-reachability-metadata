  import groovy.json.JsonSlurper
  import org.graalvm.internal.tck.utils.DynamicAccessUtils
  import org.graalvm.internal.tck.utils.NativeImageConfigUtils
  
  import org.graalvm.buildtools.gradle.tasks.BuildNativeImageTask
  import org.graalvm.buildtools.gradle.tasks.NativeRunTask
  import org.gradle.api.tasks.PathSensitivity
  
  import java.util.jar.JarFile
  
  plugins {
      id 'org.graalvm.internal.tck-base'
      id 'checkstyle'
      id 'java-library'
      id 'org.graalvm.buildtools.native'
      id 'jacoco'
  }
  
  repositories {
      mavenLocal()
      mavenCentral()
  }
  
  tasks.withType(JavaCompile).configureEach {
      options.release = 21
  }
  
  tasks.withType(org.graalvm.buildtools.gradle.tasks.BuildNativeImageTask).configureEach { task ->
      if (task.name == "nativeTestCompile") {
          // Restrict cacheability to the dynamic-access reporting lane.
          task.outputs.cacheIf("Enabled only when generating dynamic-access reports") {
              boolean propertyEnabled = providers.gradleProperty('tck.generateDynamicAccessReport')
                      .map { value -> value.toBoolean() }
                      .getOrElse(false)
              boolean taskRequested = gradle.startParameter.taskNames.any { taskName ->
                  taskName == "generateDynamicAccessReport" || taskName.endsWith(":generateDynamicAccessReport")
              }
              propertyEnabled || taskRequested
          }
      }
  }
  
  checkstyle {
      configFile tck.repoRoot.file("gradle/checkstyle.xml").get().asFile
  }
  
  tasks.register("checkstyle") {
      description = "Runs all checkstyle tasks"
      group = JavaBasePlugin.VERIFICATION_GROUP
      dependsOn tasks.withType(Checkstyle)
  }
  
  tasks.withType(Checkstyle).configureEach {
      exclude {
          it.file.absolutePath.contains('generated')
      }
  }
  
  int maxJUnitTestTimeoutSeconds = 60
  List<String> junitTimeoutRuntimeArgs = [
          "-Djunit.jupiter.execution.timeout.default=${maxJUnitTestTimeoutSeconds} s",
          "-Djunit.jupiter.execution.timeout.mode=enabled",
          "-Djunit.jupiter.execution.timeout.thread.mode.default=separate_thread"
  ]
  
  def timeoutAnnotationWithinLimit = { String annotationBody ->
      def valueMatcher = annotationBody =~ /\b(?:value\s*=\s*)?([0-9]+)\b/
      if (!valueMatcher.find()) {
          return true
      }
      long value = Long.parseLong(valueMatcher.group(1))
      def unitMatcher = annotationBody =~ /\bunit\s*=\s*(?:[A-Za-z_][A-Za-z0-9_]*\s*\.\s*)*([A-Z_]+)\b/
      String unit = unitMatcher.find() ? unitMatcher.group(1) : "SECONDS"
      switch (unit) {
          case "NANOSECONDS":
              return value <= maxJUnitTestTimeoutSeconds * 1000L * 1000L * 1000L
          case "MICROSECONDS":
              return value <= maxJUnitTestTimeoutSeconds * 1000L * 1000L
          case "MILLISECONDS":
              return value <= maxJUnitTestTimeoutSeconds * 1000L
          case "SECONDS":
              return value <= maxJUnitTestTimeoutSeconds
          case "MINUTES":
              return value <= 1L
          default:
              return false
      }
  }
  
  tasks.register("checkTestTimeoutAnnotations") {
      description = "Rejects JUnit @Timeout annotations above ${maxJUnitTestTimeoutSeconds} seconds."
      group = JavaBasePlugin.VERIFICATION_GROUP
      def testSources = fileTree("src/test") {
          include "**/*.java", "**/*.kt", "**/*.groovy", "**/*.scala"
      }
      inputs.files(testSources)
      doLast {
          List<String> violations = []
          testSources.files.each { File sourceFile ->
              String content = sourceFile.getText("UTF-8")
              def matcher = content =~ /(?s)@Timeout\s*\((.*?)\)/
              while (matcher.find()) {
                  String annotationBody = matcher.group(1)
                  if (!timeoutAnnotationWithinLimit(annotationBody)) {
                      int lineNumber = content.substring(0, matcher.start()).count("\n") + 1
                      violations.add("${sourceFile}:${lineNumber}: @Timeout(${annotationBody}) exceeds ${maxJUnitTestTimeoutSeconds} seconds")
                  }
              }
          }
          if (!violations.isEmpty()) {
              throw new GradleException("JUnit test timeouts must not exceed ${maxJUnitTestTimeoutSeconds} seconds:\n" + violations.join("\n"))
          }
      }
  }
  
  String metadataPath = Objects.requireNonNullElse(
  		System.getenv("GVM_TCK_MD"),
  		providers.gradleProperty('metadata.dir').get()
  )
  
  String libraryVersion = System.getenv("GVM_TCK_LV") ?: providers.gradleProperty('library.version').get()
  
  String libraryGAV = System.getenv("GVM_TCK_LC") ?: providers.gradleProperty('library.coordinates').getOrElse(null)
  libraryGAV = libraryGAV ?: ""
  
