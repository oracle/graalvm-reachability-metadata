[tool-call] delta {"path":"tests/src/org.bouncycastle/bcutil-jdk18on/1.77/src/test/java/org_bouncycastle/bcutil_jdk18on/OEROptionalAnonymous1Test.java","edits":[{"oldText":"import org.bouncycastle.asn1.ASN1Encodable;\nimport org.bouncycastle.asn1.ASN1Object;\nimport org.bouncycastle.asn1.ASN1Primitive;\nimport org.bouncycastle.asn1.DEROctetString;\nimport org.bouncycastle.oer.OEROptional;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class OEROptionalAnonymous1Test {\n    @Test\n    void getObjectReflectivelyInvokesPublicGetInstanceOnRequestedType() {\n        DEROctetString encodedValue = new DEROctetString(new byte[]{42});\n        OEROptional optional = OEROptional.getInstance(encodedValue);\n        ReflectiveOptionalValue.reset();\n\n        ReflectiveOptionalValue decodedValue = decodeOptional(optional, ReflectiveOptionalValue.class);\n\n        assertThat(decodedValue.getWrapped()).isSameAs(encodedValue);\n        assertThat(ReflectiveOptionalValue.getInvocationCount()).isEqualTo(1);\n        assertThat(ReflectiveOptionalValue.getLastInput()).isSameAs(encodedValue);\n    }\n\n    private static <T> T decodeOptional(OEROptional optional, Class<T> type) {\n        return optional.getObject(type);\n    }\n\n    public static final class ReflectiveOptionalValue extends ASN1Object {\n        private static int invocationCount;\n        private static ASN1Encodable lastInput;\n        private final ASN1Encodable wrapped;\n\n        private ReflectiveOptionalValue(ASN1Encodable wrapped) {\n            this.wrapped = wrapped;\n        }\n\n        public static ReflectiveOptionalValue getInstance(Object value) {\n            invocationCount++;\n            lastInput = (ASN1Encodable) value;\n            return new ReflectiveOptionalValue(lastInput);\n        }\n\n        static void reset() {\n            invocationCount = 0;\n            lastInput = null;\n        }\n\n        static int getInvocationCount() {\n            return invocationCount;\n        }\n\n        static ASN1Encodable getLastInput() {\n            return lastInput;\n        }\n\n        ASN1Encodable getWrapped() {\n            return wrapped;\n        }\n\n        @Override\n        public ASN1Primitive toASN1Primitive() {\n            return wrapped.toASN1Primitive();\n        }\n    }\n}\n","newText":"import java.math.BigInteger;\n\nimport org.bouncycastle.asn1.ASN1Integer;\nimport org.bouncycastle.oer.OEROptional;\nimport org.bouncycastle.oer.its.ieee1609dot2.basetypes.UINT8;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class OEROptionalAnonymous1Test {\n    @Test\n    void getObjectInvokesPublicGetInstanceOnRequestedType() {\n        ASN1Integer encodedValue = new ASN1Integer(BigInteger.valueOf(42));\n        OEROptional optional = OEROptional.getInstance(encodedValue);\n\n        UINT8 decodedValue = decodeOptional(optional, uint8Type());\n\n        assertThat(decodedValue.getValue()).isEqualTo(BigInteger.valueOf(42));\n    }\n\n    @Test\n    void getValueInvokesPublicGetInstanceOnRequestedType() {\n        ASN1Integer encodedValue = new ASN1Integer(BigInteger.valueOf(7));\n\n        UINT8 decodedValue = OEROptional.getValue(uint8Type(), encodedValue);\n\n        assertThat(decodedValue.getValue()).isEqualTo(BigInteger.valueOf(7));\n    }\n\n    private static <T> T decodeOptional(OEROptional optional, Class<T> type) {\n        return optional.getObject(type);\n    }\n\n    private static Class<UINT8> uint8Type() {\n        return UINT8.class;\n    }\n}\n"}]}
