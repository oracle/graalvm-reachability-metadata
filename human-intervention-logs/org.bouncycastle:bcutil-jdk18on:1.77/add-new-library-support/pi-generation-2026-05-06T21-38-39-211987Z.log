t\n    void getObjectInvokesPublicGetInstanceOnRequestedType() {\n        ASN1Integer encodedValue = new ASN1Integer(BigInteger.valueOf(42));\n        OEROptional optional = OEROptional.getInstance(encodedValue);\n\n        UINT8 decodedValue = decodeOptional(optional, uint8Type());\n\n        assertThat(decodedValue.getValue()).isEqualTo(BigInteger.valueOf(42));\n    }\n\n    @Test\n    void getValueInvokesPublicGetInstanceOnRequestedType() {\n        ASN1Integer encodedValue = new ASN1Integer(BigInteger.valueOf(7));\n\n        UINT8 decodedValue = OEROptional.getValue(uint8Type(), encodedValue);\n\n        assertThat(decodedValue.getValue()).isEqualTo(BigInteger.valueOf(7));\n    }\n\n    private static <T> T decodeOptional(OEROptional optional, Class<T> type) {\n        return optional.getObject(type);\n    }\n\n    private static Class<UINT8> uint8Type() {\n        return UINT8.class;\n    }\n}\n"}]}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 731, "output": 1550, "cacheRead": 39424, "cacheWrite": 0, "totalTokens": 41705, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778103727249, "responseId": "resp_02bbd92d4b7f31a30169fbb5b0210881a1a2cafc52a7114c0c"}}
