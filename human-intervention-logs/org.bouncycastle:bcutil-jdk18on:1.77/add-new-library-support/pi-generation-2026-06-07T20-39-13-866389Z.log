[tool-call] delta {"path":"tests/src/org.bouncycastle/bcutil-jdk18on/1.77/src/test/java/org_bouncycastle/bcutil_jdk18on/OEROptionalAnonymous1Test.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcutil_jdk18on;\n\nimport org.bouncycastle.asn1.ASN1OctetString;\nimport org.bouncycastle.asn1.DEROctetString;\nimport org.bouncycastle.oer.OEROptional;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class OEROptionalAnonymous1Test {\n    @Test\n    void returnsOptionalValueThroughTargetTypeFactory() {\n        DEROctetString encodedValue = new DEROctetString(new byte[] { 1, 2, 3, 4 });\n\n        ASN1OctetString decodedValue = OEROptional.getValue(ASN1OctetString.class, encodedValue);\n\n        assertThat(decodedValue).isNotNull();\n        assertThat(decodedValue.getOctets()).containsExactly(1, 2, 3, 4);\n    }\n}\n"}
