              return emptyLibraryStats();
          }
  
          NavigableMap<String, LibraryStatsModels.ArtifactStats> entries = new TreeMap<>();
          for (Map.Entry<String, LibraryStatsModels.ArtifactStats> entry : libraryStats.entries().entrySet()) {
