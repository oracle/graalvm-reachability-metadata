er.OERDefinition;\nimport org.bouncycastle.oer.OEROutputStream;\nimport org.bouncycastle.oer.its.ieee1609dot2.Opaque;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class OpaqueAnonymous1Test {\n    @Test\n    void getValueParsesOpaqueContentAndInvokesGetInstanceOnRequestedType() throws Exception {\n        Element definition = OERDefinition.integer(0, 255).build();\n        ASN1Integer encodedValue = new ASN1Integer(BigInteger.valueOf(42));\n        Opaque opaque = new Opaque(encode(encodedValue, definition));\n        CapturingValue.reset();\n\n        CapturingValue value = Opaque.getValue(CapturingValue.class, definition, opaque);\n\n        assertThat(value.getParsedValue()).isInstanceOf(ASN1Integer.class);\n        assertThat(((ASN1Integer)value.getParsedValue()).getValue()).isEqualTo(BigInteger.valueOf(42));\n        assertThat(CapturingValue.getInvocationCount()).isEqualTo(1);\n        assertThat(CapturingValue.getLastInput()).isSameAs(value.getParsedValue());\n    }\n\n    private static byte[] encode(ASN1Integer value, Element definition) throws Exception {\n        ByteArrayOutputStream output = new ByteArrayOutputStream();\n        OEROutputStream oerOutput = new OEROutputStream(output);\n        oerOutput.write(value, definition);\n        return output.toByteArray();\n    }\n\n    public static final class CapturingValue {\n        private static int invocationCount;\n        private static Object lastInput;\n        private final Object parsedValue;\n\n        private CapturingValue(Object parsedValue) {\n            this.parsedValue = parsedValue;\n        }\n\n        public static CapturingValue getInstance(Object value) {\n            invocationCount++;\n            lastInput = value;\n            return new CapturingValue(value);\n        }\n\n        static void reset() {\n            invocationCount = 0;\n            lastInput = null;\n        }\n\n        static int getInvocationCount() {\n            return invocationCount;\n        }\n\n        static Object getLastInput() {\n            return lastInput;\n        }\n\n        Object getParsedValue() {\n            return parsedValue;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 881, "output": 708, "cacheRead": 20992, "cacheWrite": 0, "totalTokens": 22581, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778104603749, "responseId": "resp_0ecf577e0df83e1c0169fbb91c92b0819280661c6d2b5f0026"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_pjdciI4qIaLpVFiqhYNl58mS|fc_0ecf577e0df83e1c0169fbb91df5348192bd4fc864baedf332", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2583 bytes to tests/src/org.bouncycastle/bcutil-jdk18on/1.77/src/test/java/org_bouncycastle/bcutil_jdk18on/OpaqueAnonymous1Test.java"}], "isError": false, "timestamp": 1778104609973}]}
