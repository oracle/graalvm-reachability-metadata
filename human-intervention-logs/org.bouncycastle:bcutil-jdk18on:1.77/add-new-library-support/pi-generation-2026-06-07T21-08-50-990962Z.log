[tool-call] delta {"path":"tests/src/org.bouncycastle/bcutil-jdk18on/1.77/src/test/java/org_bouncycastle/bcutil_jdk18on/OpaqueAnonymous1Test.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcutil_jdk18on;\n\nimport java.math.BigInteger;\n\nimport org.bouncycastle.asn1.ASN1Integer;\nimport org.bouncycastle.oer.Element;\nimport org.bouncycastle.oer.OERDefinition;\nimport org.bouncycastle.oer.OEREncoder;\nimport org.bouncycastle.oer.its.ieee1609dot2.Opaque;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class OpaqueAnonymous1Test {\n    @Test\n    void decodesOpaqueContentThroughTargetTypeFactory() {\n        Element definition = OERDefinition.integer(0, 255).build();\n        ASN1Integer expectedValue = new ASN1Integer(73);\n        Opaque opaque = new Opaque(OEREncoder.toByteArray(expectedValue, definition));\n\n        ASN1Integer decodedValue = Opaque.getValue(ASN1Integer.class, definition, opaque);\n\n        assertThat(decodedValue.getValue()).isEqualTo(BigInteger.valueOf(73));\n    }\n}\n"}
