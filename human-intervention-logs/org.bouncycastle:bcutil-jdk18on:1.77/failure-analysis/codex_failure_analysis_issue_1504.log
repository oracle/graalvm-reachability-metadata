yDecoded = UINT8.getInstance(new ASN1Integer(1));\\n        List<UINT8> values = ItsUtils.fillList(UINT8.class, sequence);\\n\\n        assertThat(directlyDecoded.getValue()).isEqualTo(BigInteger.ONE);\\n        assertThat(values).hasSize(2);\\n        assertThat(values.get(0).getValue()).isEqualTo(BigInteger.valueOf(7));\\n        assertThat(values.get(1).getValue()).isEqualTo(BigInteger.valueOf(255));\\n    }\\n\\n    @Test\\n    @SuppressWarnings(\\\"deprecation\\\")\\n    void fillsListForAnotherUnsignedIntegerFactory() {\\n        ASN1Sequence sequence = ItsUtils.toSequence(new ASN1Integer(1024), new ASN1Integer(4096));\\n\\n        UINT16 directlyDecoded = UINT16.getInstance(new ASN1Integer(16));\\n        List<UINT16> values = ItsUtils.fillList(UINT16.class, sequence);\\n\\n        assertThat(directlyDecoded.getValue()).isEqualTo(BigInteger.valueOf(16));\\n        assertThat(values).hasSize(2);\\n        assertThat(values.get(0).getValue()).isEqualTo(BigInteger.valueOf(1024));\\n        assertThat(values.get(1).getValue()).isEqualTo(BigInteger.valueOf(4096));\\n    }\"}]}, \"partialJson\": \"{\\\"path\\\":\\\"tests/src/org.bouncycastle/bcutil-jdk18on/1.77/src/test/java/org_bouncycastle/bcutil_jdk18on/ItsUtilsAnonymous1Test.java\\\",\\\"edits\\\":[{\\\"oldText\\\":\\\"import org.bouncycastle.oer.its.ieee1609dot2.basetypes.UINT8;\\\\nimport org.junit.jupiter.api.Test;\\\",\\\"newText\\\":\\\"import org.bouncycastle.oer.its.ieee1609dot2.basetypes.UINT16;\\\\nimport org.bouncycastle.oer.its.ieee1609dot2.basetypes.UINT8;\\\\nimport org.junit.jupiter.api.Test;\\\"},{\\\"oldText\\\":\\\"    void fillsListByCallingElementTypeFactoryForEachSequenceItem() {\\\\n        ASN1Sequence sequence = ItsUtils.toSequence(new ASN1Integer(7), new ASN1Integer(255));\\\\n\\\\n        List<UINT8> values = ItsUtils.fillList(UINT8.class, sequence);\\\\n\\\\n        assertThat(values).hasSize(2);\\\\n        assertThat(values.get(0).getValue()).isEqualTo(BigInteger.valueOf(7));\\\\n   