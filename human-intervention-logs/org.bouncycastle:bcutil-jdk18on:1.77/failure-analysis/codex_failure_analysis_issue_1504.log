pt_run_metrics\n../2719-1a2e0f44/tests/src/io.dropwizard.metrics\n../2719-1a2e0f44/tests/src/com.codahale.metrics\n../2719-1a2e0f44/tests/src/io.dropwizard.metrics5\n../1504-41bd5e72\n../1504-41bd5e72/AGENTS.md\n../1504-41bd5e72/stats\n../1504-41bd5e72/stats/org.eclipse.jetty\n../1504-41bd5e72/stats/org.eclipse.jetty/jetty-alpn-server\n../1504-41bd5e72/stats/org.eclipse.jetty/jetty-ee\n../1504-41bd5e72/stats/org.eclipse.jetty/jetty-server\n../1504-41bd5e72/stats/org.eclipse.jetty/jetty-client\n../1504-41bd5e72/stats/org.eclipse.jetty/jetty-util\n../1504-41bd5e72/stats/org.eclipse.jetty/jetty-http\n../1504-41bd5e72/stats/org.eclipse.jetty/jetty-io\n../1504-41bd5e72/stats/org.eclipse.jetty/jetty-session\n../1504-41bd5e72/stats/org.eclipse.jetty/jetty-util-ajax\n../1504-41bd5e72/stats/org.eclipse.jetty/jetty-alpn-java-server\n../1504-41bd5e72/stats/org.scalatest\n../1504-41bd5e72/stats/org.scalatest/scalatest-compatible\n../1504-41bd5e72/stats/org.scalatest/scalatest-shouldmatchers_2.13\n../1504-41bd5e72/stats/org.scalatest/scalatest-mustmatchers_2.13\n../1504-41bd5e72/stats/org.scalatest/scalatest-wordspec_2.13\n../1504-41bd5e72/stats/org.awaitility\n../1504-41bd5e72/stats/org.awaitility/awaitility\n../1504-41bd5e72/stats/com.typesafe.slick\n../1504-41bd5e72/stats/com.typesafe.slick/slick-hikaricp_2.13\n../1504-41bd5e72/stats/com.typesafe.slick/slick_2.13\n../1504-41bd5e72/stats/org.junit.jupiter\n../1504-41bd5e72/stats/org.junit.jupiter/junit-jupiter-params\n../1504-41bd5e72/stats/org.junit.jupiter/junit-jupiter-engine\n../1504-41bd5e72/stats/org.apache.thrift\n../1504-41bd5e72/stats/org.apache.thrift/libthrift\n../1504-41bd5e72/stats/jakarta.authentication\n../1504-41bd5e72/stats/jakarta.authentication/jakarta.authentication-api\n../1504-41bd5e72/stats/org.springframework\n../1504-41bd5e72/stats/org.springframework/spring-jcl\n../1504-41bd5e72/stats/org.springframework/spring-aspects\n../1504-41bd5e72/stats/org.springframework/spring-instrument\n../1504-41bd5e72/sta