dedValue);\\n        ReflectiveOptionalValue.reset();\\n\\n        ReflectiveOptionalValue decodedValue = decodeOptional(optional, ReflectiveOptionalValue.class);\\n\\n        assertThat(decodedValue.getWrapped()).isSameAs(encodedValue);\\n        assertThat(ReflectiveOptionalValue.getInvocationCount()).isOne();\\n        assertThat(ReflectiveOptionalValue.getLastInput()).isSameAs(encodedValue);\\n    }\\n\\n    private static <T> T decodeOptional(OEROptional optional, Class<T> type) {\\n        return optional.getObject(type);\\n    }\\n\\n    public static final class ReflectiveOptionalValue extends ASN1Object {\\n        private static int invocationCount;\\n        private static ASN1Encodable lastInput;\\n        private final ASN1Encodable wrapped;\\n\\n        private ReflectiveOptionalValue(ASN1Encodable wrapped) {\\n            this.wrapped = wrapped;\\n        }\\n\\n        public static ReflectiveOptionalValue getInstance(Object value) {\\n            invocationCount++;\\n            lastInput = (ASN1Encodable) value;\\n            return new ReflectiveOptionalValue(lastInput);\\n        }\\n\\n        static void reset() {\\n            invocationCount = 0;\\n            lastInput = null;\\n        }\\n\\n        static int getInvocationCount() {\\n            return invocationCount;\\n        }\\n\\n        static ASN1Encodable getLastInput() {\\n            return lastInput;\\n        }\\n\\n        ASN1Encodable getWrapped() {\\n            return wrapped;\\n        }\\n\\n        @Override\\n        public ASN1Primitive toASN1Primitive() {\\n            return wrapped.toASN1Primitive();\\n        }\\n    }\\n}\\n\"}]}}], \"api\": \"openai-responses\", \"provider\": \"OCA\", \"model\": \"gpt-5.5\", \"usage\": {\"input\": 1000, \"output\": 2345, \"cacheRead\": 35840, \"cacheWrite\": 0, \"totalTokens\": 39185, \"cost\": {\"input\": 0, \"output\": 0, \"cacheRead\": 0, \"cacheWrite\": 0, \"total\": 0}}, \"stopReason\": \"toolUse\", \"timestamp\": 1778103