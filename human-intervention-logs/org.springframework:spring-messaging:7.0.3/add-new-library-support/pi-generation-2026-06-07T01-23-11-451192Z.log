  	}
  
  	public @Nullable Object getErrorChannel() {
  		return get(ERROR_CHANNEL);
  	}
  
  
  	@SuppressWarnings("unchecked")
  	public <T> @Nullable T get(Object key, Class<T> type) {
  		Object value = this.headers.get(key);
