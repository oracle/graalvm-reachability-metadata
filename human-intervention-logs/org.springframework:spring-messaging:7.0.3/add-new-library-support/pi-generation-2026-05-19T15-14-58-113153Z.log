rs(rawHeaders);\n\n        MessageHeaders deserialized = deserialize(serialize(headers));\n\n        assertThat(deserialized.get(\"serializableHeader\")).isEqualTo(\"kept\");\n        assertThat(deserialized.get(\"numericHeader\")).isEqualTo(42);\n        assertThat(deserialized.containsKey(\"nonSerializableHeader\")).isFalse();\n        assertThat(deserialized.getId()).isEqualTo(headers.getId());\n        assertThat(deserialized.getTimestamp()).isEqualTo(headers.getTimestamp());\n    }\n\n    private static byte[] serialize(Object object) throws IOException {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(object);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static MessageHeaders deserialize(byte[] bytes) throws IOException, ClassNotFoundException {\n        try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(bytes))) {\n            return (MessageHeaders) input.readObject();\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 12945, "output": 2230, "cacheRead": 12800, "cacheWrite": 0, "totalTokens": 27975, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1779203643494, "responseId": "resp_0d683fbe756e9d5a016a0c7e3bf8608191b55a5993b3adfdf1"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_CRyWQfzzutYGKxke9hpkkZ67|fc_0d683fbe756e9d5a016a0c7e5474488191935e1a79db96db25", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2064 bytes to tests/src/org.springframework/spring-messaging/7.0.3/src/test/java/org_springframework/spring_messaging/MessageHeadersTest.java"}], "isError": false, "timestamp": 1779203672675}]}
