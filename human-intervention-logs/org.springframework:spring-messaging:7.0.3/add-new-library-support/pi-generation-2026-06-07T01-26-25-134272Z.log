  		@Nullable Object[] args = getMethodArgumentValues(message, providedArgs);
  		if (logger.isTraceEnabled()) {
  			logger.trace("Arguments: " + Arrays.toString(args));
  		}
  		return doInvoke(args);
  	}
  
