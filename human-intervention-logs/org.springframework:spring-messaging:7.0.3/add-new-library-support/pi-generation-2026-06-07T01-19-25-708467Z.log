          String ligatureAndRomanNumeral = "\uFB01-\u2168";
  
          assertThat(SaslPrep.saslPrep(fullwidthUserWithDigits, true)).isEqualTo("User123");
          assertThat(SaslPrep.saslPrep(ligatureAndRomanNumeral, true)).isEqualTo("fi-IX");
      }
  
