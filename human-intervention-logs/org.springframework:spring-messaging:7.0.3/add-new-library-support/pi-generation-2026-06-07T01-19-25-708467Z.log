  package com_sun_xml_bind_external.relaxng_datatype;
  
  import com.sun.tools.rngdatatype.Datatype;
  import com.sun.tools.rngdatatype.DatatypeException;
  import com.sun.tools.rngdatatype.DatatypeLibrary;
