                  0x0234,
                  0x024F,
                  0x0370,
                  0x0373,
                  0xE0002,
                  0xE0080,
                  0xEFFFD);
  
          assertRejected(StringPrep::unassignedCodePoints,
                  0x0020,
                  0x0220,
                  0x0222,
                  0x0233,
                  0x0250,
                  0xD7A3,
                  0xE000,
                  0xF0000,
