ith Jakarta or javax appengine-web.xml\u003c/p\u003e\n\u003cdiv class=\"snippet-clipboard-content notranslate position-relative overflow-auto\" data-snippet-clipboard-copy-content=\"\u0026lt;?xml version=\u0026quot;1.0\u0026quot; encoding=\u0026quot;utf-8\u0026quot;?\u0026gt;\n\u0026lt;appengine-web-app xmlns=\u0026quot;http://appengine.google.com/ns/1.0\u0026quot;\u0026gt;\n  \u0026lt;runtime\u0026gt;java21\u0026lt;/runtime\u0026gt;\n  \u0026lt;app-engine-apis\u0026gt;true\u0026lt;/app-engine-apis\u0026gt;\n\n  \u0026lt;!-- Add optionally:\n  \u0026lt;system-properties\u0026gt;\n    \u0026lt;property name=\u0026quot;appengine.use.EE8\u0026quot; value=\u0026quot;true\u0026quot;/\u0026gt;\n\u0026lt;/system-properties\u0026gt;\nIf you want to keep javax.servlet APIs and not jarkata.servlet by default\n--\u0026gt;\n\u0026lt;/appengine-web-app\u0026gt;\"\u003e\u003cpre class=\"notranslate\"\u003e\u003ccode\u003e\u0026lt;?xml version=\"1.0\" encoding=\"utf-8\"?\u0026gt;\n\u0026lt;appengine-web-app xmlns=\"http://appengine.google.com/ns/1.0\"\u0026gt;\n  \u0026lt;runtime\u0026gt;java21\u0026lt;/runtime\u0026gt;\n  \u0026lt;app-engine-apis\u0026gt;true\u0026lt;/app-engine-apis\u0026gt;\n\n  \u0026lt;!-- Add optionally:\n  \u0026lt;system-properties\u0026gt;\n    \u0026lt;property name=\"appengine.use.EE8\" value=\"true\"/\u0026gt;\n\u0026lt;/system-properties\u0026gt;\nIf you want to keep javax.servlet APIs and not jarkata.servlet by default\n--\u0026gt;\n\u0026lt;/appengine-web-app\u0026gt;\n\u003c/code\u003e\u003c/pre\u003e\u003c/div\u003e\n\u003c/li\u003e\n\u003c/ul\u003e\n\u003cul dir=\"auto\"\u003e\n\u003cli\u003e\u003ca href=\"https://cloud.google.com/appengine/docs/standard/java-gen2/runtime\" rel=\"nofollow\"\u003ePublic Java 21 Documentation\u003c/a\u003e\u003c/li\u003e\n\u003cli\u003e\u003ca href=\"https://cloud.google.com/appengine/docs/standard/java-gen2/upgrade-java-runtime\" rel=\"nofollow\"\u003eHow to upgrade to Java21\u003c/a\u003e\u003c/li\u003e\n\u003c/u