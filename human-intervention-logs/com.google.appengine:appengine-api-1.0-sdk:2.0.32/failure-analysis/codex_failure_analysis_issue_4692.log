).containsExactly(\\\"language\\\");\\n        assertThat(document.getOnlyField(\\\"title\\\").getText()).isEqualTo(\\\"Native image metadata\\\");\\n        assertThat(document.getOnlyField(\\\"score\\\").getNumber()).isEqualTo(9.5);\\n        assertThat(document.getOnlyField(\\\"location\\\").getGeoPoint().getLongitude()).isEqualTo(-122.3);\\n        assertThat(document.getOnlyFacet(\\\"language\\\")).isEqualTo(language);\\n        assertThat(queryOptions.getLimit()).isEqualTo(20);\\n        assertThat(queryOptions.getOffset()).isEqualTo(3);\\n        assertThat(queryOptions.getCursor().toWebSafeString()).isEqualTo(\\\"cursor-token\\\");\\n        assertThat(queryOptions.getCursor().isPerResult()).isTrue();\\n        assertThat(queryOptions.getFieldsToReturn()).containsExactly(\\\"title\\\", \\\"score\\\");\\n        assertThat(queryOptions.getFieldsToSnippet()).containsExactly(\\\"body\\\");\\n        assertThat(queryOptions.getExpressionsToReturn()).containsExactly(snippet);\\n        assertThat(queryOptions.getSortOptions().getSortExpressions()).containsExactly(sortExpression);\\n    }\\n\\n    private static final class TestEnvironment implements ApiProxy.Environment {\\n        private final Map<String, Object> attributes = new HashMap<>();\\n\\n        @Override\\n        public String getAppId() {\\n            return \\\"s~metadata-test\\\";\\n        }\\n\\n        @Override\\n        public String getModuleId() {\\n            return \\\"default\\\";\\n        }\\n\\n        @Override\\n        public String getVersionId() {\\n            return \\\"v1\\\";\\n        }\\n\\n        @Override\\n        public String getEmail() {\\n            return \\\"admin@example.com\\\";\\n        }\\n\\n        @Override\\n        public boolean isLoggedIn() {\\n            return true;\\n        }\\n\\n        @Override\\n        public boolean isAdmin() {\\n            return true;\\n        }\\n\\n        @Override\\n        public String getAuthDomain() {\\n            return \\\"example.com\\\";\\n        }\\n\\n        @Override\\n        public String getRequestNamespace() {\\n            return \\\"request-namespace\\\";\\n        }\\n\\n        @Override\\n        public Map<String, Object> getAttributes() {\\n            return attributes;\\n        }\\n\\n        @Override\\n        public long getRemainingMillis() {\\n            return TimeUnit.SECONDS.toMillis(30);\\n        }\\n    }\\n}\\n\"}\nhuman-intervention-logs/com.google.appengine:appengine-api-1.0-sdk:2.0.32/add-new-library-support/pi-generation-2026-05-04T13-53-51-944202Z.log:12417:[tool-exec] end id=call_AglMM4IdZ21CZV4WGaRKC1rj|fc_05907dcd1ddfd05d0169f8a43a842c8196bb36877895559d4b name=write status=success\nhuman-intervention-logs/com.google.appengine:appengine-api-1.0-sdk:2.0.32/add-new-library-support/pi-generation-2026-05-04T13-53-51-944202Z.log:12421:[recv] {\"type\": \"turn_end\", \"message\": {\"role\": \"assistant\", \"content\": [{\"type\": \"thinking\", \"thinking\": \"\", \"thinkingSignature\": \"{\\\"id\\\":\\\"rs_05907dcd1ddfd05d0169f8a439d4388196b0bd103c6f30a7c6\\\",\\\"type\\\":\\\"reasoning\\\",\\\"encrypted_content\\\":\\\"gAAAAABp-KQ6AS6Nire1J2mDfr_VJWWSo9iiNm8ANZbz6QKxiPC23M-kBj70OiVZ8N8QLW7r41tCO4cR6tHeDXVa9qXgYo6WQDOSB-aRY3M2zXc3Di1JmBQ36-5FhFiLLY21Q48p5349umgPj-bXwKpx-dXnlyMGK2Wo4Im1V9OhOieKn9XTEznDoMvaFKkbnVsuwaVqFm7x39HdKoE6awum1IzeUgdZvE03Ldhzwf7ogIeaiRBBoJlFO-GrpYc2szuzvm2Wb20k6lIg11Oo2hbil7bKsqidBjaG5W9h6kFzTg0t5m94TQPDeDzsKEiQ3-MOHunqYyI3mHQb028I0slzIhvCMEnDMDyp5znvGEL-9gBUsZVl7ROJUSXh3lxvRZVngZkX_zjBTMWbjFUqtydtoAYykVujNcZzxAn_nqmASFLZVihV5Cas9kE3InuXuoHuB6rvEL-nOIZp5LkeS8iUctjJ0KnACJqQ_YdxuxHAdWY7wGmI_0Mm00OSs1Q7_Kq98R-5jdxILFz2TL9ffoFUedPHcK0vIfAv05r8VQC2cP8K0C4bnNvWzhx7VQ1I_3YCPhMVMiyLagObxWHP8K1qpxuMYU5r1IZhQOanGEZ6cmWc1pMRT9uaNtk9fevoaBS8TnzSoPV0ypxhk2em8YOEnO5CSGduomtHIzgMZIi1N0dFHS83fmXhCpVk8MIObUwn6TpJaPMG6gdRGXyZhocaaZLmok6Q_4CWvxIjbN5kGEh41qtJfSwUKPJFY6JjR6avINYFU7Muo7xW79fwpJK0uL-Pg9-BBM6ulzTWxFf4aSewFljPe90XC9o