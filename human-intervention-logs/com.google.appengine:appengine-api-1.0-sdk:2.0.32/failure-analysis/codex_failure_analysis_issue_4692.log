\\" : \\\"https://github.com/GoogleCloudPlatform/appengine-java-standard/tree/v$version$/api/src/test\\\",\\n./metadata/com.google.appengine/appengine-api-1.0-sdk/index.json:8:    \\\"documentation-url\\\" : \\\"https://github.com/GoogleCloudPlatform/appengine-java-standard/blob/v$version$/README.md\\\",\\n./metadata/com.google.appengine/appengine-api-1.0-sdk/index.json:9:    \\\"description\\\" : \\\"This library provides the Google App Engine standard environment Java APIs, including services such as Datastore, Memcache, Task Queues, Blobstore, Users, Mail, URL Fetch, and related support classes. The appengine-api-1.0-sdk artifact packages those APIs for application use and shades or repackages selected dependencies to avoid exposing them directly.\\\",\\n\"}], \"isError\": false, \"timestamp\": 1777987836615}]}\nhuman-intervention-logs/com.google.appengine:appengine-api-1.0-sdk:2.0.32/add-new-library-support/pi-generation-2026-05-05T13-32-54-810291Z.log:295:  import com.google.appengine.api.blobstore.RangeFormatException;\nhuman-intervention-logs/com.google.appengine:appengine-api-1.0-sdk:2.0.32/add-new-library-support/pi-generation-2026-05-05T13-32-54-810291Z.log:296:  import com.google.appengine.api.blobstore.UnsupportedRangeFormatException;\nhuman-intervention-logs/com.google.appengine:appengine-api-1.0-sdk:2.0.32/add-new-library-support/pi-generation-2026-05-05T13-32-54-810291Z.log:351:  import static org.assertj.core.api.Assertions.assertThatExceptionOfType;\nhuman-intervention-logs/com.google.appengine:appengine-api-1.0-sdk:2.0.32/add-new-library-support/pi-generation-2026-05-05T13-32-54-810291Z.log:357:          assertThatExceptionOfType(IllegalArgumentException.class)\nhuman-intervention-logs/com.google.appengine:appengine-api-1.0-sdk:2.0.32/add-new-library-support/pi-generation-2026-05-05T13-32-54-810291Z.log:464:          assertThatExceptionOfType(IllegalArgumentException.class).isThrownBy(() -> new Rating(-1));\nhuman-intervention-logs/com.google.appen