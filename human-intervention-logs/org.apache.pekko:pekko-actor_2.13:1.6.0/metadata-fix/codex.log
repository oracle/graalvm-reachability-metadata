{"type":"item.completed","item":{"id":"item_124","type":"command_execution","command":"/usr/bin/bash -lc \"sed -n '1,220p' tests/src/org.apache.pekko/pekko-actor_2.13/1.6.0/src/test/scala/org_apache_pekko/pekko_actor_2_13/DnsSettingsTest.scala\"","aggregated_output":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_apache_pekko.pekko_actor_2_13\n\nimport com.typesafe.config.{Config, ConfigFactory}\nimport org.apache.pekko.actor.ActorSystem\nimport org.apache.pekko.io.Dns\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\n\nimport java.util.Hashtable\nimport java.util.concurrent.atomic.AtomicBoolean\nimport javax.naming.{Context, NamingException}\nimport javax.naming.spi.{InitialContextFactory, InitialContextFactoryBuilder, NamingManager}\nimport scala.concurrent.Await\nimport scala.concurrent.duration.DurationInt\nimport scala.util.{Failure, Success, Try}\n\nclass DnsSettingsTest {\n  import DnsSettingsTest._\n\n  @Test\n  def defaultNameserversFallBackToJdkResolverConfigurationWhenJndiFails(): Unit = {\n    installFailingDnsInitialContextFactory()\n\n    val system: ActorSystem = ActorSystem(\"DnsSettingsDefaultNameservers\", pekkoConfig(\"\"\"\n      pekko.loglevel = \"ERROR\"\n      pekko.stdout-loglevel = \"ERROR\"\n      pekko.io.dns.resolver = async-dns\n      pekko.io.dns.async-dns.nameservers = default\n      \"\"\"))\n\n    try {\n      Try(Dns(system).getResolver) match {\n        case Success(resolver) =>\n          assertThat(resolver.path.name).isEqualTo(\"IO-DNS\")\n        case Failure(exception) =>\n          assertThat(exception).isInstanceOf(classOf[IllegalStateException])\n          assertThat(exception).hasMessageContaining(\"Unable to obtain default nameservers\")\n      }\n    } finally {\n      Await.result(system.terminate(), 10.seconds)\n    }\n  }\n\n  private def pekkoConfig(config: String): Config =\n    ConfigFactory.parseString(config).withFallback(ConfigFactory.load()).resolve()\n}\n\nobject DnsSettingsTest {\n  private val builderInstalled: AtomicBoolean = new AtomicBoolean(false)\n\n  def installFailingDnsInitialContextFactory(): Unit = {\n    if (builderInstalled.compareAndSet(false, true)) {\n      NamingManager.setInitialContextFactoryBuilder(new InitialContextFactoryBuilder {\n        override def createInitialContextFactory(environment: Hashtable[_, _]): InitialContextFactory = {\n          new InitialContextFactory {\n            override def getInitialContext(environment: Hashtable[_, _]): Context = {\n              throw new NamingException(\"DNS JNDI lookup intentionally disabled for fallback coverage\")\n            }\n          }\n        }\n      })\n    }\n  }\n}\n","exit_code":0,"status":"completed"}}
