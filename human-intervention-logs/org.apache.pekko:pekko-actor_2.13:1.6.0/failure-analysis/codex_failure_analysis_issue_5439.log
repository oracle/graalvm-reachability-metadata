 scala.concurrent.duration.DurationInt\\n\\nclass VirtualThreadSupportTest {\\n  import VirtualThreadSupportTest._\\n\\n  @Test\\n  def virtualThreadExecutorCreatesVirtualThreadsAndDefaultSchedulerMetrics(): Unit = {\\n    val system: ActorSystem = ActorSystem(\\\"VirtualThreadSupportDefaultScheduler\\\", pekkoConfig(\\\"\\\"\\\"\\n      pekko.loglevel = \\\"ERROR\\\"\\n      pekko.stdout-loglevel = \\\"ERROR\\\"\\n      pekko.actor.default-dispatcher {\\n        executor = \\\"virtual-thread-executor\\\"\\n        throughput = 1\\n      }\\n      \\\"\\\"\\\"))\\n\\n    try {\\n      val observation: ThreadObservation = observeActorThread(system, Props(new ObservingActor()))\\n\\n      assertThat(observation.isVirtual).isTrue()\\n      assertThat(observation.name).contains(\\\"virtual-thread\\\")\\n    } finally {\\n      Await.result(system.terminate(), 10.seconds)\\n    }\\n  }\\n\\n  @Test\\n  def virtualizedForkJoinExecutorInstallsCustomVirtualThreadScheduler(): Unit = {\\n    val system: ActorSystem = ActorSystem(\\\"VirtualThreadSupportCustomScheduler\\\", pekkoConfig(\\\"\\\"\\\"\\n      pekko.loglevel = \\\"ERROR\\\"\\n      pekko.stdout-loglevel = \\\"ERROR\\\"\\n      custom-virtualized-dispatcher = ${pekko.actor.default-dispatcher}\\n      custom-virtualized-dispatcher {\\n        executor = \\\"fork-join-executor\\\"\\n        throughput = 1\\n        fork-join-executor {\\n          parallelism-min = 1\\n          parallelism-factor = 1.0\\n          parallelism-max = 2\\n          maximum-pool-size = 4\\n          virtualize = on\\n        }\\n      }\\n      \\\"\\\"\\\"))\\n\\n    try {\\n      val observation: ThreadObservation = observeDispatcherThread(system, \\\"custom-virtualized-dispatcher\\\")\\n\\n      assertThat(observation.isVirtual).isTrue()\\n      assertThat(observation.name).contains(\\\"virtual-thread\\\")\\n    } finally {\\n      Await.result(system.terminate(), 10.seconds)\\n    }\\n  }\\n\\n  private def pekkoConfig(config: String): Config =\\n    ConfigFactory.parseString(config).withFallback(ConfigFactory.load()).resolve()\\n\\n  private def observeActorThread(system: ActorSystem, props: Props): ThreadObservation = {\\n    val result: CompletableFuture[ThreadObservation] = new CompletableFuture[ThreadObservation]()\\n    system.actorOf(props) ! ObserveThread(result)\\n    result.get(10, TimeUnit.SECONDS)\\n  }\\n\\n  private def observeDispatcherThread(system: ActorSystem, dispatcherId: String): ThreadObservation = {\\n    val dispatcher: ExecutionContextExecutor = system.dispatchers.lookup(dispatcherId)\\n    val result: CompletableFuture[ThreadObservation] = new CompletableFuture[ThreadObservation]()\\n    dispatcher.execute(new Runnable {\\n      override def run(): Unit = completeWithCurrentThread(result)\\n    })\\n    result.get(10, TimeUnit.SECONDS)\\n  }\\n}\\n\\nobject VirtualThreadSupportTest {\\n  final case class ThreadObservation(isVirtual: Boolean, name: String)\\n  final case class ObserveThread(result: CompletableFuture[ThreadObservation])\\n\\n  def completeWithCurrentThread(result: CompletableFuture[ThreadObservation]): Unit = {\\n    val thread: Thread = Thread.currentThread()\\n    result.complete(ThreadObservation(thread.isVirtual, thread.getName))\\n  }\\n\\n  final class ObservingActor extends Actor {\\n    override def receive: Receive = {\\n      case ObserveThread(result) =>\\n        completeWithCurrentThread(result)\\n        context.stop(self)\\n    }\\n  }\\n}\\n\",\"exit_code\":0,\"status\":\"completed\"}}\n84:{\"type\":\"item.completed\",\"item\":{\"id\":\"item_44\",\"type\":\"command_execution\",\"command\":\"/usr/bin/bash -lc \\\"sed -n '1,220p' tests/src/org.apache.pekko/pekko-actor_2.13/1.6.0/src/test/scala/org_apache_pekko/pekko_actor_2_13/LineNumbersTest.scala\\\"\",\"aggregated_output\":\"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://cr