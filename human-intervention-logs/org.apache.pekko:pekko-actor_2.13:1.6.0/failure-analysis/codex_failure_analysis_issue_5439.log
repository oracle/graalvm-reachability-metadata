t, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage org_apache_pekko.pekko_actor_2_13\\n\\nimport com.typesafe.config.{Config, ConfigFactory}\\nimport org.apache.pekko.actor.ActorSystem\\nimport org.apache.pekko.io.Dns\\nimport org.assertj.core.api.Assertions.assertThat\\nimport org.junit.jupiter.api.Test\\n\\nimport java.util.Hashtable\\nimport java.util.concurrent.atomic.AtomicBoolean\\nimport javax.naming.{Context, NamingException}\\nimport javax.naming.spi.{InitialContextFactory, InitialContextFactoryBuilder, NamingManager}\\nimport scala.concurrent.Await\\nimport scala.concurrent.duration.DurationInt\\nimport scala.util.{Failure, Success, Try}\\n\\nclass DnsSettingsTest {\\n  import DnsSettingsTest._\\n\\n  @Test\\n  def defaultNameserversFallBackToJdkResolverConfigurationWhenJndiFails(): Unit = {\\n    installFailingDnsInitialContextFactory()\\n\\n    val system: ActorSystem = ActorSystem(\\\"DnsSettingsDefaultNameservers\\\", pekkoConfig(\\\"\\\"\\\"\\n      pekko.loglevel = \\\"ERROR\\\"\\n      pekko.stdout-loglevel = \\\"ERROR\\\"\\n      pekko.io.dns.resolver = async-dns\\n      pekko.io.dns.async-dns.nameservers = default\\n      \\\"\\\"\\\"))\\n\\n    try {\\n      Try(Dns(system).getResolver) match {\\n        case Success(resolver) =>\\n          assertThat(resolver.path.name).isEqualTo(\\\"IO-DNS\\\")\\n        case Failure(exception) =>\\n          assertThat(exception).isInstanceOf(classOf[IllegalStateException])\\n          assertThat(exception).hasMessageContaining(\\\"Unable to obtain default nameservers\\\")\\n      }\\n    } finally {\\n      Await.result(system.terminate(), 10.seconds)\\n    }\\n  }\\n\\n  private def pekkoConfig(config: String): Config =\\n    ConfigFactory.parseString(config).withFallback(ConfigFactory.load()).resolve()\\n}\\n\\nobject DnsSettingsTest {\\n  private val builderInstalled: AtomicBoolean = new AtomicBoolean(false)\\n\\n  def installFailingDnsInitialContextFactory(): Unit = {\\n    if (builderInstalled.compareAndSet(false, true)) {\\n      NamingManager.setInitialContextFactoryBuilder(new InitialContextFactoryBuilder {\\n        override def createInitialContextFactory(environment: Hashtable[_, _]): InitialContextFactory = {\\n          new InitialContextFactory {\\n            override def getInitialContext(environment: Hashtable[_, _]): Context = {\\n              throw new NamingException(\\\"DNS JNDI lookup intentionally disabled for fallback coverage\\\")\\n            }\\n          }\\n        }\\n      })\\n    }\\n  }\\n}\\n\",\"exit_code\":0,\"status\":\"completed\"}}\n{\"type\":\"item.started\",\"item\":{\"id\":\"item_125\",\"type\":\"command_execution\",\"command\":\"/usr/bin/bash -lc \\\"sed -n '1,220p' tests/src/org.apache.pekko/pekko-actor_2.13/1.6.0/src/test/scala/org_apache_pekko/pekko_actor_2_13/VirtualThreadSupportTest.scala\\\"\",\"aggregated_output\":\"\",\"exit_code\":null,\"status\":\"in_progress\"}}\n{\"type\":\"item.completed\",\"item\":{\"id\":\"item_125\",\"type\":\"command_execution\",\"command\":\"/usr/bin/bash -lc \\\"sed -n '1,220p' tests/src/org.apache.pekko/pekko-actor_2.13/1.6.0/src/test/scala/org_apache_pekko/pekko_actor_2_13/VirtualThreadSupportTest.scala\\\"\",\"aggregated_output\":\"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage org_apache_pekko.pekko_actor_2_13\\n\\nimport com.typesafe.config.{Config, ConfigFactory}\\nimport org.apache.pekko.actor.{Actor, ActorSystem, Props}\\nimport org.assertj.core.api.Assertions.assertThat\\nimport org.junit.jupiter.api.Test\\n\\nimport java.util.concurrent.{CompletableFuture, TimeUnit}\\nimport scala.concurrent.{Await, ExecutionContextExecutor}\\nimport scala.concurrent.duration.DurationInt\\n\\nclass VirtualThreadSupportTest {\\n  import VirtualThreadSupportTest._\\n\\n  @Test\\n  def virtualThreadExecutorCreatesVirtualThreadsAndDefaultSchedulerMetrics(): Unit = {\\n    val system: ActorSystem = ActorSystem(\\\"VirtualThreadSupportDefaultScheduler\\\", pekkoConfig(\\\"\\\"\\\"\\n      pekko.loglevel = \\\"ERROR\\\"\\n      pekko.stdout-loglevel = \\\"ERROR\\\"\\n      pekko.actor.default-dispatcher {\\n        executor = \\\"virtual-thread-executor\\\"\\n        throughput = 1\\n      }\\n      \\\"\\\"\\\"))\\n\\n    try {\\n      val observation: ThreadObservation = observeActorThread(system, Props(new ObservingActor()))\\n\\n      assertThat(observation.isVirtual).isTrue()\\n      assertThat(observation.name).contains(\\\"virtual-thread\\\")\\n    } finally {\\n      Await.result(system.terminate(), 10.seconds)\\n    }\\n  }\\n\\n  @Test\\n  def virtualizedForkJoinExecutorInstallsCustomVirtualThreadScheduler(): Unit = {\\n    val system: ActorSystem = ActorSystem(\\\"VirtualThreadSupportCustomScheduler\\\", pekkoConfig(\\\"\\\"\\\"\\n      pekko.loglevel = \\\"ERROR\\\"\\n      pekko.stdout-loglevel = \\\"ERROR\\\"\\n      custom-virtualized-dispatcher = ${pekko.actor.default-dispatcher}\\n      custom-virtualized-dispatcher {\\n        executor = \\\"fork-join-executor\\\"\\n        throughput = 1\\n        fork-join-executor {\\n          parallelism-min = 1\\n          parallelism-factor = 1.0\\n          parallelism-max = 2\\n          maximum-pool-size = 4\\n          virtualize = on\\n        }\\n      }\\n      \\\"\\\"\\\"))\\n\\n    try {\\n      val observation: ThreadObservation = observeDispatcherThread(system, \\\"custom-virtualized-dispatcher\\\")\\n\\n      assertThat(observation.isVirtual).isTrue()\\n      assertThat(observation.name).contains(\\\"virtual-thread\\\")\\n    } finally {\\n      Await.result(system.terminate(), 10.seconds)\\n    }\\n  }\\n\\n  private def pekkoConfig(config: String): Config =\\n    ConfigFactory.parseString(config).withFallback(ConfigFactory.load()).resolve()\\n\\n  private def observeActorThread(system: ActorSystem, props: Props): ThreadObservation = {\\n    val result: CompletableFuture[ThreadObservation] = new CompletableFuture[ThreadObservation]()\\n    system.actorOf(props) ! ObserveThread(result)\\n    result.get(10, TimeUnit.SECONDS)\\n  }\\n\\n  private def observeDispatcherThread(system: ActorSystem, dispatcherId: String): ThreadObservation = {\\n    val dispatcher: ExecutionContextExecutor = system.dispatchers.lookup(dispatcherId)\\n    val result: CompletableFuture[ThreadObservation] = new CompletableFuture[ThreadObservation]()\\n    dispatcher.execute(new Runnable {\\n      override def run(): Unit = completeWithCurrentThread(result)\\n    })\\n    result.get(10, TimeUnit.SECONDS)\\n  }\\n}\\n\\nobject VirtualThreadSupportTest {\\n  final case class ThreadObservation(isVirtual: Boolean, name: String)\\n  final case class ObserveThread(result: CompletableFuture[ThreadObservation])\\n\\n  def completeWithCurrentThread(result: CompletableFuture[ThreadObservation]): Unit = {\\n    val thread: Thread = Thread.currentThread()\\n    result.complete(ThreadObservation(thread.isVirtual, thread.getName))\\n  }\\n\\n  final class ObservingActor extends Actor {\\n    override def receive: Receive = {\\n      case ObserveThread(result) =>\\n        completeWithCurrentThread(result)\\n        context.stop(self)\\n    }\\n  }\\n}\\n\",\"exit_code\":0,\"status\":\"completed\"}}\n{\"type\":\"item.started\",\"item\":{\"id\":\"item_126\",\"type\":\"command_execution\",\"command\":\"/usr/bin/bash -lc \\\"sed -n '1,120p' metadata/commons-io/commons-io/2.17.0/reachability-metadata.json\\\"\",\"aggregated_output\":\"\",\"exit_code\":null,\"status\":\"in_progress\"}}\n{\"type\":\"item.completed\",\"item\":{\"id\":\"item_126\",\"type\":\"command_execution\",\"command\":\"/usr/bin/bash -lc \\\"sed -n '1,120p' metadata/commons-io/commons-io/2.17.0/reachability-metadata.json\\\"\",\"aggregated_output\":\"{\\n  \\\"reflection\\\" : [\\n    {\\n      \\\"condition\\\" : {\\n        \\\"typeR