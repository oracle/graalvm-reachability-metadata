  package org_apache_pekko.pekko_actor_2_13
  
  import org.apache.pekko.actor.{ AbstractActor, Props }
  import org.apache.pekko.japi.Creator
  import org.assertj.core.api.Assertions.assertThat
  import org.junit.jupiter.api.Test
  
  class AbstractPropsTest {
    import AbstractPropsTest._
  
    @Test
    def inspectsDeclaredConstructorsForEnclosedCreatorWithoutPublicConstructors(): Unit = {
      val creator: Creator[NoopActor] = privateConstructorCreator()
      val props: Props = Props.create(classOf[NoopActor], creator)
  
      assertThat(props.actorClass()).isEqualTo(classOf[NoopActor])
    }
  
    @Test
    def acceptsEnclosedCreatorWithPublicConstructor(): Unit = {
      val props: Props = Props.create(classOf[NoopActor], new NoopActorCreator)
  
      assertThat(props.actorClass()).isEqualTo(classOf[NoopActor])
    }
