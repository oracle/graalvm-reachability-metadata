  package org_apache_pekko.pekko_actor_2_13
  
  import org.apache.pekko.actor.{ AbstractActor, Props }
  import org.apache.pekko.japi.Creator
  import org.assertj.core.api.Assertions.{ assertThat, assertThatThrownBy }
  import org.assertj.core.api.ThrowableAssert.ThrowingCallable
  import org.junit.jupiter.api.Test
  
  class AbstractPropsTest {
    import AbstractPropsTest._
  
    @Test
    def inspectsDeclaredConstructorsForAnonymousLocalCreator(): Unit = {
      val creator: Creator[NoopActor] = new Creator[NoopActor] {
        override def create(): NoopActor = new NoopActor
      }
  
      assertThatThrownBy(new ThrowingCallable {
        override def call(): Unit = Props.create(classOf[NoopActor], creator)
      }).isInstanceOf(classOf[IllegalArgumentException])
        .hasMessageContaining("cannot use non-static local Creator")
    }
  
    @Test
    def acceptsTopLevelCreatorWithPublicConstructor(): Unit = {
      val props: Props = Props.create(classOf[NoopActor], new NoopActorCreator)
  
      assertThat(props.actorClass()).isEqualTo(classOf[NoopActor])
    }
  }
  
  object AbstractPropsTest {
    final class NoopActor extends AbstractActor {
      override def createReceive(): AbstractActor.Receive = AbstractActor.emptyBehavior
    }
  
    final class NoopActorCreator extends Creator[NoopActor] {
      override def create(): NoopActor = new NoopActor
    }
  }
