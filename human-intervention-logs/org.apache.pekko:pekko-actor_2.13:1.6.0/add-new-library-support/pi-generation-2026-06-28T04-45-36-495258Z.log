ethodCall(target)).isEqualTo(\"zero\")\n  }\n\n  @Test\n  def invokesNoArgumentMethodWhenParametersAreEmpty(): Unit = {\n    val target: InvocationTarget = new InvocationTarget\n    val method: Method = classOf[InvocationTarget].getMethod(\"zero\")\n    val methodCall: TypedActor.MethodCall = TypedActor.MethodCall(method, Array.empty[AnyRef])\n\n    assertThat(methodCall(target)).isEqualTo(\"zero\")\n  }\n\n  @Test\n  def invokesArgumentMethodWithParameters(): Unit = {\n    val target: InvocationTarget = new InvocationTarget\n    val method: Method = classOf[InvocationTarget].getMethod(\"concatenate\", classOf[String], classOf[String])\n    val methodCall: TypedActor.MethodCall = TypedActor.MethodCall(method, Array[AnyRef](\"left\", \"right\"))\n\n    assertThat(methodCall(target)).isEqualTo(\"left:right\")\n  }\n}\n\nobject TypedActorInnerMethodCallTest {\n  final class InvocationTarget {\n    def zero(): String = \"zero\"\n\n    def concatenate(left: String, right: String): String = s\"$left:$right\"\n  }\n}\n"}], "isError": false, "timestamp": 1782621827606}]}
