's good to know! However, I can still instantiate the class from a companion method within the same object. It's an interesting concept, and I'm eager to explore it further!\"}]}"}, {"type": "toolCall", "id": "call_DE6Sr5Dhn5IGqZWEPt5fHdZ0|fc_0761881ea5089f5a016a40a6b6ac14819099e1e948f359df3c", "name": "edit", "arguments": {"path": "tests/src/org.apache.pekko/pekko-actor_2.13/1.6.0/src/test/scala/org_apache_pekko/pekko_actor_2_13/AbstractPropsTest.scala", "edits": [{"oldText": "import org.assertj.core.api.Assertions.{ assertThat, assertThatThrownBy }\nimport org.assertj.core.api.ThrowableAssert.ThrowingCallable\nimport org.junit.jupiter.api.Test\n", "newText": "import org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\n"}, {"oldText": "  @Test\n  def inspectsDeclaredConstructorsForAnonymousLocalCreator(): Unit = {\n    val creator: Creator[NoopActor] = new Creator[NoopActor] {\n      override def create(): NoopActor = new NoopActor\n    }\n\n    assertThatThrownBy(new ThrowingCallable {\n      override def call(): Unit = Props.create(classOf[NoopActor], creator)\n    }).isInstanceOf(classOf[IllegalArgumentException])\n      .hasMessageContaining(\"cannot use non-static local Creator\")\n  }\n\n  @Test\n  def acceptsTopLevelCreatorWithPublicConstructor(): Unit = {\n    val props: Props = Props.create(classOf[NoopActor], new NoopActorCreator)\n\n    assertThat(props.actorClass()).isEqualTo(classOf[NoopActor])\n  }\n", "newText": "  @Test\n  def inspectsDeclaredConstructorsForEnclosedCreatorWithoutPublicConstructors(): Unit = {\n    val creator: Creator[NoopActor] = privateConstructorCreator()\n    val props: Props = Props.create(classOf[NoopActor], creator)\n\n    assertThat(props.actorClass()).isEqualTo(classOf[NoopActor])\n  }\n\n  @Test\n  def acceptsEnclosedCreatorWithPublicConstructor(): Unit = {\n    val props: Props = Props.create(classOf[NoopActor], new NoopActorCreator)\n\n    assertThat(props.actorClass()).isEqualTo(classOf[NoopActor])\n  }\n"}, {"oldText": "  final class NoopActorCreator extends Creator[NoopActor] {\n    override def create(): NoopActor = new NoopActor\n  }\n", "newText": "  final class NoopActorCreator extends Creator[NoopActor] {\n    override def create(): NoopActor = new NoopActor\n  }\n\n  def privateConstructorCreator(): Creator[NoopActor] = new PrivateConstructorCreator\n\n  private final class PrivateConstructorCreator private () extends Creator[NoopActor] {\n    override def create(): NoopActor = new NoopActor\n  }\n"}]}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 1050, "output": 1951, "cacheRead": 29696, "cacheWrite": 0, "totalTokens": 32697, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1782621860298, "responseId": "resp_0761881ea5089f5a016a40a6a4f650819087c4dc2e95df2030"}}
