[tool-call] delta {"path":"tests/src/org.apache.pekko/pekko-actor_2.13/1.6.0/src/test/scala/org_apache_pekko/pekko_actor_2_13/LineNumbersTest.scala","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_apache_pekko.pekko_actor_2_13\n\nimport org.apache.pekko.util.LineNumbers\nimport org.assertj.core.api.Assertions.{assertThat, fail}\nimport org.junit.jupiter.api.Test\n\nimport java.io.Serializable\nimport java.util.function.Supplier\n\nclass LineNumbersTest {\n  import LineNumbersTest._\n\n  @Test\n  def reportsSourceInfoForRegularClassResource(): Unit = {\n    val result: LineNumbers.Result = LineNumbers(new ClassResourceProbe)\n\n    assertLineNumbersTestSource(result)\n  }\n\n  @Test\n  def reportsSourceInfoForSerializableLambdaResource(): Unit = {\n    val supplier: SerializableStringSupplier = serializableSupplierLambda()\n\n    assertThat(supplier.get()).isEqualTo(\"lambda-source\")\n    assertLineNumbersTestSource(LineNumbers(supplier))\n  }\n\n  private def assertLineNumbersTestSource(result: LineNumbers.Result): Unit = {\n    result match {\n      case LineNumbers.SourceFile(filename) =>\n        assertThat(filename).isEqualTo(\"LineNumbersTest.scala\")\n      case LineNumbers.SourceFileLines(filename, from, to) =>\n        assertThat(filename).isEqualTo(\"LineNumbersTest.scala\")\n        assertThat(from).isPositive()\n        assertThat(to).isGreaterThanOrEqualTo(from)\n      case other =>\n        fail(s\"Expected source information for LineNumbersTest.scala, but got $other\")\n    }\n  }\n}\n\nobject LineNumbersTest {\n  trait SerializableStringSupplier extends Supplier[String] with Serializable\n\n  final class ClassResourceProbe\n\n  def serializableSupplierLambda(): SerializableStringSupplier = () => \"lambda-source\"\n}\n"}
