  package org_apache_pekko.pekko_actor_2_13
  
  import org.apache.pekko.util.LineNumbers
  import org.assertj.core.api.Assertions.{assertThat, fail}
  import org.junit.jupiter.api.Test
  
  import java.io.Serializable
  import java.util.function.Supplier
  
  class LineNumbersTest {
    import LineNumbersTest._
  
    @Test
    def reportsSourceInfoForRegularClassResource(): Unit = {
      val result: LineNumbers.Result = LineNumbers(new ClassResourceProbe)
  
      assertLineNumbersTestSource(result)
    }
  
    @Test
    def reportsSourceInfoForSerializableLambdaResource(): Unit = {
      val supplier: SerializableStringSupplier = serializableSupplierLambda()
  
      assertThat(supplier.get()).isEqualTo("lambda-source")
      assertLineNumbersTestSource(LineNumbers(supplier))
    }
  
    private def assertLineNumbersTestSource(result: LineNumbers.Result): Unit = {
