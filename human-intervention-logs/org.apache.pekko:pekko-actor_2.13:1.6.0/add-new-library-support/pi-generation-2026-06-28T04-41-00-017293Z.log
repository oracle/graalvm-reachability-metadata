\nimport java.util.Hashtable\nimport java.util.concurrent.atomic.AtomicBoolean\nimport javax.naming.{Context, NamingException}\nimport javax.naming.spi.{InitialContextFactory, InitialContextFactoryBuilder, NamingManager}\nimport scala.concurrent.Await\nimport scala.concurrent.duration.DurationInt\nimport scala.util.{Failure, Success, Try}\n\nclass DnsSettingsTest {\n  import DnsSettingsTest._\n\n  @Test\n  def defaultNameserversFallBackToJdkResolverConfigurationWhenJndiFails(): Unit = {\n    installFailingDnsInitialContextFactory()\n\n    val system: ActorSystem = ActorSystem(\"DnsSettingsDefaultNameservers\", pekkoConfig(\"\"\"\n      pekko.loglevel = \"ERROR\"\n      pekko.stdout-loglevel = \"ERROR\"\n      pekko.io.dns.resolver = async-dns\n      pekko.io.dns.async-dns.nameservers = default\n      \"\"\"))\n\n    try {\n      Try(Dns(system).getResolver) match {\n        case Success(resolver) =>\n          assertThat(resolver.path.name).isEqualTo(\"IO-DNS\")\n        case Failure(exception) =>\n          assertThat(exception).isInstanceOf(classOf[IllegalStateException])\n          assertThat(exception).hasMessageContaining(\"Unable to obtain default nameservers\")\n      }\n    } finally {\n      Await.result(system.terminate(), 10.seconds)\n    }\n  }\n\n  private def pekkoConfig(config: String): Config =\n    ConfigFactory.parseString(config).withFallback(ConfigFactory.load()).resolve()\n}\n\nobject DnsSettingsTest {\n  private val builderInstalled: AtomicBoolean = new AtomicBoolean(false)\n\n  def installFailingDnsInitialContextFactory(): Unit = {\n    if (builderInstalled.compareAndSet(false, true)) {\n      NamingManager.setInitialContextFactoryBuilder(new InitialContextFactoryBuilder {\n        override def createInitialContextFactory(environment: Hashtable[_, _]): InitialContextFactory = {\n          new InitialContextFactory {\n            override def getInitialContext(environment: Hashtable[_, _]): Context = {\n              throw new NamingException(\"DNS JNDI lookup intentionally disabled for fallback coverage\")\n            }\n          }\n        }\n      })\n    }\n  }\n}\n"}], "isError": false, "timestamp": 1782621632785}, {"role": "toolResult", "toolCallId": "call_8XOrh8oaB03om1to444ClpRy|fc_0574422a4ab18c81016a40a5c050008197a0dd5b4d6f2d38d8", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_apache_pekko.pekko_actor_2_13\n\nimport org.apache.pekko.util.LineNumbers\nimport org.assertj.core.api.Assertions.{assertThat, fail}\nimport org.junit.jupiter.api.Test\n\nimport java.io.Serializable\nimport java.util.function.Supplier\n\nclass LineNumbersTest {\n  import LineNumbersTest._\n\n  @Test\n  def reportsSourceInfoForRegularClassResource(): Unit = {\n    val result: LineNumbers.Result = LineNumbers(new ClassResourceProbe)\n\n    assertLineNumbersTestSource(result)\n  }\n\n  @Test\n  def reportsSourceInfoForSerializableLambdaResource(): Unit = {\n    val supplier: SerializableStringSupplier = serializableSupplierLambda()\n\n    assertThat(supplier.get()).isEqualTo(\"lambda-source\")\n    assertLineNumbersTestSource(LineNumbers(supplier))\n  }\n\n  private def assertLineNumbersTestSource(result: LineNumbers.Result): Unit = {\n    result match {\n      case LineNumbers.SourceFile(filename) =>\n        assertThat(filename).isEqualTo(\"LineNumbersTest.scala\")\n      case LineNumbers.SourceFileLines(filename, from, to) =>\n        assertThat(filename).isEqualTo(\"LineNumbersTest.scala\")\n        assertThat(from).isPositive()\n        assertThat(to).isGreaterThanOrEqualTo(from)\n      case other =>\n        fail(s\"Expected source information for LineNumbersTest.scala, but got $other\")\n    }\n  }\n}\n\nobject LineNumbersTest {\n  trait SerializableStringSupplier extends Supplier[String] with Serializable\n\n  final class ClassResourceProbe\n\n  def serializableSupplierLambda(): SerializableStringSupplier = () => \"lambda-source\"\n}\n"}], "isError": false, "timestamp": 1782621632786}, {"role": "toolResult", "toolCallId": "call_Ng06FcYKwFVon6tUkvNvPdld|fc_0574422a4ab18c81016a40a5c0500881978b8987306cec2c96", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_apache_pekko.pekko_actor_2_13\n\nimport com.typesafe.config.{Config, ConfigFactory}\nimport org.apache.pekko.actor.{Actor, ActorSystem, Props}\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\n\nimport java.util.concurrent.{CompletableFuture, TimeUnit}\nimport scala.concurrent.{Await, ExecutionContextExecutor}\nimport scala.concurrent.duration.DurationInt\n\nclass VirtualThreadSupportTest {\n  import VirtualThreadSupportTest._\n\n  @Test\n  def virtualThreadExecutorCreatesVirtualThreadsAndDefaultSchedulerMetrics(): Unit = {\n    val system: ActorSystem = ActorSystem(\"VirtualThreadSupportDefaultScheduler\", pekkoConfig(\"\"\"\n      pekko.loglevel = \"ERROR\"\n      pekko.stdout-loglevel = \"ERROR\"\n      pekko.actor.default-dispatcher {\n        executor = \"virtual-thread-executor\"\n        throughput = 1\n      }\n      \"\"\"))\n\n    try {\n      val observation: ThreadObservation = observeActorThread(system, Props(new ObservingActor()))\n\n      assertThat(observation.isVirtual).isTrue()\n      assertThat(observation.name).contains(\"virtual-thread\")\n    } finally {\n      Await.result(system.terminate(), 10.seconds)\n    }\n  }\n\n  @Test\n  def virtualizedForkJoinExecutorInstallsCustomVirtualThreadScheduler(): Unit = {\n    val system: ActorSystem = ActorSystem(\"VirtualThreadSupportCustomScheduler\", pekkoConfig(\"\"\"\n      pekko.loglevel = \"ERROR\"\n      pekko.stdout-loglevel = \"ERROR\"\n      custom-virtualized-dispatcher = ${pekko.actor.default-dispatcher}\n      custom-virtualized-dispatcher {\n        executor = \"fork-join-executor\"\n        throughput = 1\n        fork-join-executor {\n          parallelism-min = 1\n          parallelism-factor = 1.0\n          parallelism-max = 2\n          maximum-pool-size = 4\n          virtualize = on\n        }\n      }\n      \"\"\"))\n\n    try {\n      val observation: ThreadObservation = observeDispatcherThread(system, \"custom-virtualized-dispatcher\")\n\n      assertThat(observation.isVirtual).isTrue()\n      assertThat(observation.name).contains(\"virtual-thread\")\n    } finally {\n      Await.result(system.terminate(), 10.seconds)\n    }\n  }\n\n  private def pekkoConfig(config: String): Config =\n    ConfigFactory.parseString(config).withFallback(ConfigFactory.load()).resolve()\n\n  private def observeActorThread(system: ActorSystem, props: Props): ThreadObservation = {\n    val result: CompletableFuture[ThreadObservation] = new CompletableFuture[ThreadObservation]()\n    system.actorOf(props) ! ObserveThread(result)\n    result.get(10, TimeUnit.SECONDS)\n  }\n\n  private def observeDispatcherThread(system: ActorSystem, dispatcherId: String): ThreadObservation = {\n    val dispatcher: ExecutionContextExecutor = system.dispatchers.lookup(dispatcherId)\n    val result: CompletableFuture[ThreadObservation] = new CompletableFuture[ThreadObservation]()\n    dispatcher.execute(new Runnable {\n      override def run(): Unit = completeWithCurrentThread(result)\n    })\n    result.get(10, TimeUnit.SECONDS)\n  }\n}\n\nobject VirtualThreadSupportTest {\n  final case class ThreadObservation(isVirtual: Boolean, name: String)\n  final case class ObserveThread(result: CompletableFuture[ThreadObservation])\n\n  def completeWithCurrentThread(result: CompletableFuture[ThreadObservation]): Unit = {\n    val thread: Thread = Thread.currentThread()\n    result.complete(ThreadObservation(thread.isVirtual, thread.getName))\n  }\n\n  final class ObservingActor extends Actor {\n    override def receive: Receive = {\n      case ObserveThread(result) =>\n        completeWithCurrentThread(result)\n        context.stop(self)\n    }\n  }\n}\n"}], "isError": false, "timestamp": 1782621632786}]}
