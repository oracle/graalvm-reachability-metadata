  package org_apache_pekko.pekko_actor_2_13
  
  import com.typesafe.config.{Config, ConfigFactory}
  import org.apache.pekko.actor.ActorSystem
  import org.apache.pekko.io.Dns
  import org.assertj.core.api.Assertions.assertThat
  import org.junit.jupiter.api.Test
  
  import java.util.Hashtable
  import java.util.concurrent.atomic.AtomicBoolean
  import javax.naming.{Context, NamingException}
  import javax.naming.spi.{InitialContextFactory, InitialContextFactoryBuilder, NamingManager}
  import scala.concurrent.Await
  import scala.concurrent.duration.DurationInt
  import scala.util.{Failure, Success, Try}
  
  class DnsSettingsTest {
    import DnsSettingsTest._
  
    @Test
    def defaultNameserversFallBackToJdkResolverConfigurationWhenJndiFails(): Unit = {
      installFailingDnsInitialContextFactory()
  
      val system: ActorSystem = ActorSystem("DnsSettingsDefaultNameservers", pekkoConfig("""
        pekko.loglevel = "ERROR"
        pekko.stdout-loglevel = "ERROR"
        pekko.io.dns.resolver = async-dns
        pekko.io.dns.async-dns.nameservers = default
        """))
  
      try {
        Try(Dns(system).getResolver) match {
          case Success(resolver) =>
            assertThat(resolver.path.name).isEqualTo("IO-DNS")
          case Failure(exception) =>
            assertThat(exception).isInstanceOf(classOf[IllegalStateException])
            assertThat(exception).hasMessageContaining("Unable to obtain default nameservers")
        }
      } finally {
        Await.result(system.terminate(), 10.seconds)
      }
    }
  
    private def pekkoConfig(config: String): Config =
      ConfigFactory.parseString(config).withFallback(ConfigFactory.load()).resolve()
  }
  
  object DnsSettingsTest {
    private val builderInstalled: AtomicBoolean = new AtomicBoolean(false)
  
    def installFailingDnsInitialContextFactory(): Unit = {
      if (builderInstalled.compareAndSet(false, true)) {
        NamingManager.setInitialContextFactoryBuilder(new InitialContextFactoryBuilder {
          override def createInitialContextFactory(environment: Hashtable[_, _]): InitialContextFactory = {
            new InitialContextFactory {
              override def getInitialContext(environment: Hashtable[_, _]): Context = {
                throw new NamingException("DNS JNDI lookup intentionally disabled for fallback coverage")
              }
            }
          }
        })
      }
    }
  }
