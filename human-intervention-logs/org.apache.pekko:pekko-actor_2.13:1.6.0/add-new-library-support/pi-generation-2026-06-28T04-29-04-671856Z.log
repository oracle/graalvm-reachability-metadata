[tool-call] delta {"path":"tests/src/org.apache.pekko/pekko-actor_2.13/1.6.0/src/test/scala/org_apache_pekko/pekko_actor_2_13/VirtualThreadSupportTest.scala","edits":[{"oldText":"import scala.concurrent.Await\n","newText":"import scala.concurrent.{Await, ExecutionContextExecutor}\n"},{"oldText":"          parallelism-max = 1\n          maximum-pool-size = 1\n","newText":"          parallelism-max = 2\n          maximum-pool-size = 4\n"},{"oldText":"      val props: Props = Props(new ObservingActor()).withDispatcher(\"custom-virtualized-dispatcher\")\n      val observation: ThreadObservation = observeActorThread(system, props)\n\n      assertThat(observation.isVirtual).isTrue()\n      assertThat(observation.name).contains(\"virtual-thread\")","newText":"      val observation: ThreadObservation = observeDispatcherThread(system, \"custom-virtualized-dispatcher\")\n\n      assertThat(observation.isVirtual).isTrue()\n      assertThat(observation.name).contains(\"virtual-thread\")"},{"oldText":"  private def observeActorThread(system: ActorSystem, props: Props): ThreadObservation = {\n    val result: CompletableFuture[ThreadObservation] = new CompletableFuture[ThreadObservation]()\n    system.actorOf(props) ! ObserveThread(result)\n    result.get(10, TimeUnit.SECONDS)\n  }\n","newText":"  private def observeActorThread(system: ActorSystem, props: Props): ThreadObservation = {\n    val result: CompletableFuture[ThreadObservation] = new CompletableFuture[ThreadObservation]()\n    system.actorOf(props) ! ObserveThread(result)\n    result.get(10, TimeUnit.SECONDS)\n  }\n\n  private def observeDispatcherThread(system: ActorSystem, dispatcherId: String): ThreadObservation = {\n    val dispatcher: ExecutionContextExecutor = system.dispatchers.lookup(dispatcherId)\n    val result: CompletableFuture[ThreadObservation] = new CompletableFuture[ThreadObservation]()\n    dispatcher.execute(() => completeWithCurrentThread(result))\n    result.get(10, TimeUnit.SECONDS)\n  }\n"} ,{"oldText":"  final class ObservingActor extends Actor {\n    override def receive: Receive = {\n      case ObserveThread(result) =>\n        val thread: Thread = Thread.currentThread()\n        result.complete(ThreadObservation(thread.isVirtual, thread.getName))\n        context.stop(self)\n    }\n  }\n","newText":"  def completeWithCurrentThread(result: CompletableFuture[ThreadObservation]): Unit = {\n    val thread: Thread = Thread.currentThread()\n    result.complete(ThreadObservation(thread.isVirtual, thread.getName))\n  }\n\n  final class ObservingActor extends Actor {\n    override def receive: Receive = {\n      case ObserveThread(result) =>\n        completeWithCurrentThread(result)\n        context.stop(self)\n    }\n  }\n"}]}
