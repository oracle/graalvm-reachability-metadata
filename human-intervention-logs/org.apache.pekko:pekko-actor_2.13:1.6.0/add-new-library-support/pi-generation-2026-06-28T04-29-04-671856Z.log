    protected[pekko] def systemDispatch(receiver: ActorCell, invocation: SystemMessage): Unit = {
      val mbox = receiver.mailbox
      mbox.systemEnqueue(receiver.self, invocation)
      registerForExecution(mbox, false, true)
    }
  
