[recv] {"type": "turn_end", "message": {"role": "assistant", "content": [{"type": "toolCall", "id": "call_edM9EPPwHSQ1PcOsJwDpKq2L|fc_0c952e4df5d01a14016a40a2d360d08193866be5ab96c1b7c0", "name": "write", "arguments": {"path": "tests/src/org.apache.pekko/pekko-actor_2.13/1.6.0/src/test/scala/org_apache_pekko/pekko_actor_2_13/VirtualThreadSupportTest.scala", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_apache_pekko.pekko_actor_2_13\n\nimport com.typesafe.config.ConfigFactory\nimport org.apache.pekko.actor.{Actor, ActorSystem, Props}\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\n\nimport java.util.concurrent.{CompletableFuture, TimeUnit}\nimport scala.concurrent.Await\nimport scala.concurrent.duration.DurationInt\n\nclass VirtualThreadSupportTest {\n  import VirtualThreadSupportTest._\n\n  @Test\n  def virtualThreadExecutorCreatesVirtualThreadsAndDefaultSchedulerMetrics(): Unit = {\n    val system: ActorSystem = ActorSystem(\"VirtualThreadSupportDefaultScheduler\", ConfigFactory.parseString(\"\"\"\n      pekko.loglevel = \"ERROR\"\n      pekko.stdout-loglevel = \"ERROR\"\n      pekko.actor.default-dispatcher {\n        executor = \"virtual-thread-executor\"\n        throughput = 1\n      }\n      \"\"\"))\n\n    try {\n      val observation: ThreadObservation = observeActorThread(system, Props(new ObservingActor()))\n\n      assertThat(observation.isVirtual).isTrue()\n      assertThat(observation.name).contains(\"virtual-thread\")\n    } finally {\n      Await.result(system.terminate(), 10.seconds)\n    }\n  }\n\n  @Test\n  def virtualizedForkJoinExecutorInstallsCustomVirtualThreadScheduler(): Unit = {\n    val system: ActorSystem = ActorSystem(\"VirtualThreadSupportCustomScheduler\", ConfigFactory.parseString(\"\"\"\n      pekko.loglevel = \"ERROR\"\n      pekko.stdout-loglevel = \"ERROR\"\n      custom-virtualized-dispatcher = ${pekko.actor.default-dispatcher}\n      custom-virtualized-dispatcher {\n        executor = \"fork-join-executor\"\n        throughput = 1\n        fork-join-executor {\n          parallelism-min = 1\n          parallelism-factor = 1.0\n          parallelism-max = 1\n          maximum-pool-size = 1\n          virtualize = on\n        }\n      }\n      \"\"\"))\n\n    try {\n      val props: Props = Props(new ObservingActor()).withDispatcher(\"custom-virtualized-dispatcher\")\n      val observation: ThreadObservation = observeActorThread(system, props)\n\n      assertThat(observation.isVirtual).isTrue()\n      assertThat(observation.name).contains(\"virtual-thread\")\n    } finally {\n      Await.result(system.terminate(), 10.seconds)\n    }\n  }\n\n  private def observeActorThread(system: ActorSystem, props: Props): ThreadObservation = {\n    val result: CompletableFuture[ThreadObservation] = new CompletableFuture[ThreadObservation]()\n    system.actorOf(props) ! ObserveThread(result)\n    result.get(10, TimeUnit.SECONDS)\n  }\n}\n\nobject VirtualThreadSupportTest {\n  final case class ThreadObservation(isVirtual: Boolean, name: String)\n  final case class ObserveThread(result: CompletableFuture[ThreadObservation])\n\n  final class ObservingActor extends Actor {\n    override def receive: Receive = {\n      case ObserveThread(result) =>\n        val thread: Thread = Thread.currentThread()\n        result.complete(ThreadObservation(thread.isVirtual, thread.getName))\n        context.stop(self)\n    }\n  }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 844, "output": 852, "cacheRead": 38400, "cacheWrite": 0, "totalTokens": 40096, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1782620880848, "responseId": "resp_0c952e4df5d01a14016a40a2d1b55c81938bd85bc1bcb92348