                      requestHeaders.getFirst("Authorization"), requestHeaders.getFirst("X-Default"),
                      requestHeaders.getFirst("X-Interceptor"), requestHeaders.getFirst("X-Request-Customizer"));
              send(exchange, HttpStatus.OK.value(), response);
