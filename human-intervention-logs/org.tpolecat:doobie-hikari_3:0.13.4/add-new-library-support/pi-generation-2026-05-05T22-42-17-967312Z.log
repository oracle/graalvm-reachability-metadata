  package org_tpolecat.doobie_hikari_3
  
  import cats.effect.Blocker
  import cats.effect.ContextShift
  import cats.effect.IO
  import com.zaxxer.hikari.HikariDataSource
  import doobie.hikari.HikariTransactor
  import org.assertj.core.api.Assertions.assertThat
  import org.junit.jupiter.api.Test
  
  import scala.concurrent.ExecutionContext
  
  class HikariTransactorTest {
    private val connectEC: ExecutionContext = ExecutionContext.global
    private implicit val contextShift: ContextShift[IO] = IO.contextShift(connectEC)
  
    @Test
    def newHikariTransactorLoadsConfiguredClassNameAndConfiguresDataSource(): Unit = {
      val configuredValues: (String, String, String) =
        Blocker[IO]
          .flatMap { blocker: Blocker =>
            HikariTransactor.newHikariTransactor[IO](
              driverClassName = classOf[HikariDataSource].getName,
              url = "jdbc:graalvm-reachability-test",
              user = "test-user",
              pass = "test-password",
              connectEC = connectEC,
              blocker = blocker
            )
          }
          .use { transactor =>
            transactor.configure { dataSource =>
              IO {
                (
                  dataSource.getJdbcUrl,
                  dataSource.getUsername,
                  dataSource.getPassword
                )
              }
            }
          }
          .unsafeRunSync()
  
      assertThat(configuredValues).isEqualTo(("jdbc:graalvm-reachability-test", "test-user", "test-password"))
    }
