  public class StringConverter
      extends AbstractBasicConverter
  {
      @SuppressWarnings( "rawtypes" )
      public boolean canConvert( final Class type )
      {
          return type.equals( String.class );
      }
  
      @Override
      public Object fromString( final String str )
      {
          return str;
      }
  
  }
