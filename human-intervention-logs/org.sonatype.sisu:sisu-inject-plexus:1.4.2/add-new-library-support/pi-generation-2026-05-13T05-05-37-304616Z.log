  package org_sonatype_sisu.sisu_inject_plexus;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import org.junit.jupiter.api.Test;
  import org.sonatype.guice.asm.ClassWriter;
  
  public class ClassWriterTest extends ClassWriter {
      public ClassWriterTest() {
          super(0);
      }
  
      @Test
      void resolvesCommonSuperclassForLoadableTypes() {
          final String commonSuperclass = getCommonSuperClass("java/util/ArrayList", "java/util/LinkedList");
  
          assertThat(commonSuperclass).isEqualTo("java/util/AbstractList");
      }
  }
