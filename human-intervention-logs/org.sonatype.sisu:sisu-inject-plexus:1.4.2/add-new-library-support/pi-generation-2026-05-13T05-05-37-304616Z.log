  package org_sonatype_sisu.sisu_inject_plexus;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import org.junit.jupiter.api.Test;
  import org.sonatype.guice.asm.ClassWriter;
  
  public class ClassWriterTest extends ClassWriter {
      public ClassWriterTest() {
          super(0);
      }
  
      @Test
      void resolvesCommonSuperclassForLoadableApplicationTypes() {
          final String commonSuperclass = getCommonSuperClass(
                  internalName(FirstClassWriterType.class),
                  internalName(SecondClassWriterType.class));
  
          assertThat(commonSuperclass).isEqualTo(internalName(BaseClassWriterType.class));
      }
  
      private static String internalName(final Class<?> type) {
          return type.getName().replace('.', '/');
      }
  }
  
  class BaseClassWriterType {
  }
  
  class FirstClassWriterType extends BaseClassWriterType {
  }
  
  class SecondClassWriterType extends BaseClassWriterType {
  }
