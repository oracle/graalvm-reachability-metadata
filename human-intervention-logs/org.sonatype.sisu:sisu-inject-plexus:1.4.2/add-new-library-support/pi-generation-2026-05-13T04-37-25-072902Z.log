  /*
   * Copyright and related rights waived via CC0
   *
   * You should have received a copy of the CC0 legalcode along with this
   * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.
   */
  package org_sonatype_sisu.sisu_inject_plexus;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import com.google.inject.Guice;
  import com.google.inject.TypeLiteral;
  import java.util.Properties;
  import org.junit.jupiter.api.Test;
  import org.sonatype.guice.plexus.converters.PlexusXmlBeanConverter;
  
  public class PlexusXmlBeanConverterTest {
      @Test
      void convertsXmlElementsToArray() {
          PlexusXmlBeanConverter converter = newConverter();
  
          String[] values = (String[]) converter.convert(TypeLiteral.get(String[].class), """
                  <values>
                      <value>alpha</value>
                      <value>beta</value>
                  </values>
                  """);
  
          assertThat(values).containsExactly("alpha", "beta");
      }
  
      @Test
      void loadsImplementationFromThreadContextClassLoader() {
          PlexusXmlBeanConverter converter = newConverter();
          ClassLoader originalClassLoader = Thread.currentThread().getContextClassLoader();
          Thread.currentThread().setContextClassLoader(PlexusXmlBeanConverterTest.class.getClassLoader());
          try {
              EmptyRole role = (EmptyRole) converter.convert(TypeLiteral.get(EmptyRole.class), """
                      <role implementation="%s"> </role>
                      """.formatted(TcclLoadedRole.class.getName()));
  
              assertThat(role).isInstanceOf(TcclLoadedRole.class);
          } finally {
              Thread.currentThread().setContextClassLoader(originalClassLoader);
          }
      }
  
      @Test
      void fallsBackToPeerClassLoaderForImplementation() {
          PlexusXmlBeanConverter converter = newConverter();
          ClassLoader originalClassLoader = Thread.currentThread().getContextClassLoader();
          Thread.currentThread().setContextClassLoader(new RejectingClassLoader(originalClassLoader));
          try {
              EmptyRole role = (EmptyRole) converter.convert(TypeLiteral.get(EmptyRole.class), """
                      <role implementation="%s"> </role>
                      """.formatted(PeerLoadedRole.class.getName()));
  
              assertThat(role).isInstanceOf(PeerLoadedRole.class);
          } finally {
              Thread.currentThread().setContextClassLoader(originalClassLoader);
          }
      }
  
      @Test
      void fallsBackToClassForNameForBootstrapDefaultImplementation() {
          PlexusXmlBeanConverter converter = newConverter();
          ClassLoader originalClassLoader = Thread.currentThread().getContextClassLoader();
          Thread.currentThread().setContextClassLoader(null);
          try {
              Properties properties = (Properties) converter.convert(TypeLiteral.get(Properties.class), """
                      <properties implementation="java.util.Properties">
                          <property>
                              <name>server</name>
                              <value>native-image</value>
                          </property>
                      </properties>
                      """);
  
              assertThat(properties).containsEntry("server", "native-image");
          } finally {
              Thread.currentThread().setContextClassLoader(originalClassLoader);
          }
      }
  
      @Test
      void convertsPlainTextWithStringConstructor() {
          PlexusXmlBeanConverter converter = newConverter();
  
          ConstructedValue value = (ConstructedValue) converter.convert(
                  TypeLiteral.get(ConstructedValue.class), "from text");
  
          assertThat(value.value()).isEqualTo("from text");
      }
  
      private static PlexusXmlBeanConverter newConverter() {
          return Guice.createInjector().getInstance(PlexusXmlBeanConverter.class);
      }
  
      public static class EmptyRole {
          public EmptyRole() {
          }
      }
  
      public static final class TcclLoadedRole extends EmptyRole {
          public TcclLoadedRole() {
          }
      }
  
      public static final class PeerLoadedRole extends EmptyRole {
          public PeerLoadedRole() {
          }
      }
  
      public static final class ConstructedValue {
          private final String value;
  
          public ConstructedValue(final String value) {
              this.value = value;
          }
  
          public String value() {
              return value;
          }
      }
  
      private static final class RejectingClassLoader extends ClassLoader {
          RejectingClassLoader(final ClassLoader parent) {
              super(parent);
          }
  
          @Override
          public Class<?> loadClass(final String name) throws ClassNotFoundException {
              throw new ClassNotFoundException(name);
          }
      }
  }
[recv] {"type": "message_start", "message": {"role": "toolResult", "toolCallId": "call_BFRiPnicovSdNHozRahxmn7d|fc_0f497134a62d5e5d016a03ffc2b4308197806a670e7fdf9205", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_sonatype_sisu.sisu_inject_plexus;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport com.google.inject.Guice;\nimport com.google.inject.TypeLiteral;\nimport java.util.Properties;\nimport org.junit.jupiter.api.Test;\nimport org.sonatype.guice.plexus.converters.PlexusXmlBeanConverter;\n\npublic class PlexusXmlBeanConverterTest {\n    @Test\n    void convertsXmlElementsToArray() {\n        PlexusXmlBeanConverter converter = newConverter();\n\n        String[] values = (String[]) converter.convert(TypeLiteral.get(String[].class), \"\"\"\n                <values>\n                    <value>alpha</value>\n                    <value>beta</value>\n                </values>\n                \"\"\");\n\n        assertThat(values).containsExactly(\"alpha\", \"beta\");\n    }\n\n    @Test\n    void loadsImplementationFromThreadContextClassLoader() {\n        PlexusXmlBeanConverter converter = newConverter();\n        ClassLoader originalClassLoader = Thread.currentThread().getContextClassLoader();\n        Thread.currentThread().setContextClassLoader(PlexusXmlBeanConverterTest.class.getClassLoader());\n        try {\n            EmptyRole role = (EmptyRole) converter.convert(TypeLiteral.get(EmptyRole.class), \"\"\"\n                    <role implementation=\"%s\"> </role>\n                    \"\"\".formatted(TcclLoadedRole.class.getName()));\n\n            assertThat(role).isInstanceOf(TcclLoadedRole.class);\n        } finally {\n            Thread.currentThread().setContextClassLoader(originalClassLoader);\n        }\n    }\n\n    @Test\n    void fallsBackToPeerClassLoaderForImplementation() {\n        PlexusXmlBeanConverter converter = newConverter();\n        ClassLoader originalClassLoader = Thread.currentThread().getContextClassLoader();\n        Thread.currentThread().setContextClassLoader(new RejectingClassLoader(originalClassLoader));\n        try {\n            EmptyRole role = (EmptyRole) converter.convert(TypeLiteral.get(EmptyRole.class), \"\"\"\n                    <role implementation=\"%s\"> </role>\n                    \"\"\".formatted(PeerLoadedRole.class.getName()));\n\n            assertThat(role).isInstanceOf(PeerLoadedRole.class);\n        } finally {\n            Thread.currentThread().setContextClassLoader(originalClassLoader);\n        }\n    }\n\n    @Test\n    void fallsBackToClassForNameForBootstrapDefaultImplementation() {\n        PlexusXmlBeanConverter converter = newConverter();\n        ClassLoader originalClassLoader = Thread.currentThread().getContextClassLoader();\n        Thread.currentThread().setContextClassLoader(null);\n        try {\n            Properties properties = (Properties) converter.convert(TypeLiteral.get(Properties.class), \"\"\"\n                    <properties implementation=\"java.util.Properties\">\n                        <property>\n                            <name>server</name>\n                            <value>native-image</value>\n                        </property>\n                    </properties>\n                    \"\"\");\n\n            assertThat(properties).containsEntry(\"server\", \"native-image\");\n        } finally {\n            Thread.currentThread().setContextClassLoader(originalClassLoader);\n        }\n    }\n\n    @Test\n    void convertsPlainTextWithStringConstructor() {\n        PlexusXmlBeanConverter converter = newConverter();\n\n        ConstructedValue value = (ConstructedValue) converter.convert(\n                TypeLiteral.get(ConstructedValue.class), \"from text\");\n\n        assertThat(value.value()).isEqualTo(\"from text\");\n    }\n\n    private static PlexusXmlBeanConverter newConverter() {\n        return Guice.createInjector().getInstance(PlexusXmlBeanConverter.class);\n    }\n\n    public static class EmptyRole {\n        public EmptyRole() {\n        }\n    }\n\n    public static final class TcclLoadedRole extends EmptyRole {\n        public TcclLoadedRole() {\n        }\n    }\n\n    public static final class PeerLoadedRole extends EmptyRole {\n        public PeerLoadedRole() {\n        }\n    }\n\n    public static final class ConstructedValue {\n        private final String value;\n\n        public ConstructedValue(final String value) {\n            this.value = value;\n        }\n\n        public String value() {\n            return value;\n        }\n    }\n\n    private static final class RejectingClassLoader extends ClassLoader {\n        RejectingClassLoader(final ClassLoader parent) {\n            super(parent);\n        }\n\n        @Override\n        public Class<?> loadClass(final String name) throws ClassNotFoundException {\n            throw new ClassNotFoundException(name);\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778646978926}}
