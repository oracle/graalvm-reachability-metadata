  package io_vertx.vertx_core;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import io.vertx.core.impl.IsolatingClassLoader;
  
  import java.io.IOException;
  import java.net.URL;
  import java.util.Collections;
  import java.util.List;
  
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  
  public class IsolatingClassLoaderTest {
      private static final String VERTX_VERSION_RESOURCE = "META-INF/vertx/vertx-version.txt";
  
      @Test
      void isolatedSystemClassDelegatesToParentLoader() throws Exception {
          ClassLoader parentClassLoader = IsolatingClassLoaderTest.class.getClassLoader();
  
          try (IsolatingClassLoader classLoader = new IsolatingClassLoader(
                  new URL[0], parentClassLoader, List.of(String.class.getName()))) {
              Class<?> loadedClass = classLoader.loadClass(String.class.getName());
  
              assertThat(loadedClass).isSameAs(String.class);
          }
      }
  
      @Test
      void isolatedApplicationClassFallsBackToParentWhenChildCannotFindIt() throws Exception {
          ClassLoader parentClassLoader = IsolatingClassLoaderTest.class.getClassLoader();
  
          try (IsolatingClassLoader classLoader = new IsolatingClassLoader(
                  new URL[0], parentClassLoader, List.of(IsolatingClassLoaderTest.class.getName()))) {
              try {
                  Class<?> loadedClass = classLoader.loadClass(IsolatingClassLoaderTest.class.getName());
  
                  assertThat(loadedClass).isSameAs(IsolatingClassLoaderTest.class);
              } catch (Error error) {
                  if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                      throw error;
                  }
              }
          }
      }
  
      @Test
      void getResourceFallsBackToParentLoader() throws IOException {
          ClassLoader parentClassLoader = IsolatingClassLoaderTest.class.getClassLoader();
  
          try (IsolatingClassLoader classLoader = new IsolatingClassLoader(
                  new URL[0], parentClassLoader, Collections.emptyList())) {
              URL resource = classLoader.getResource(VERTX_VERSION_RESOURCE);
  
              assertThat(resource).isNotNull();
          }
      }
  
      @Test
      void getResourcesIncludesParentLoaderResources() throws IOException {
          ClassLoader parentClassLoader = IsolatingClassLoaderTest.class.getClassLoader();
  
          try (IsolatingClassLoader classLoader = new IsolatingClassLoader(
                  new URL[0], parentClassLoader, Collections.emptyList())) {
              List<URL> resources = Collections.list(classLoader.getResources(VERTX_VERSION_RESOURCE));
  
              assertThat(resources).isNotEmpty();
          }
      }
  }
