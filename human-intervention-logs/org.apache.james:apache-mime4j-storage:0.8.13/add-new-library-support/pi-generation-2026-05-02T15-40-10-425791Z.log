[tool-call] delta {"path":"tests/src/org.apache.james/apache-mime4j-storage/0.8.13/src/test/java/org_apache_james/apache_mime4j_storage/DefaultStorageProviderTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_apache_james.apache_mime4j_storage;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.InputStream;\nimport java.nio.charset.StandardCharsets;\n\nimport org.apache.james.mime4j.storage.DefaultStorageProvider;\nimport org.apache.james.mime4j.storage.MemoryStorageProvider;\nimport org.apache.james.mime4j.storage.Storage;\nimport org.apache.james.mime4j.storage.StorageProvider;\nimport org.junit.jupiter.api.Test;\n\npublic class DefaultStorageProviderTest {\n    private static final String DEFAULT_STORAGE_PROVIDER_PROPERTY =\n            \"org.apache.james.mime4j.defaultStorageProvider\";\n\n    @Test\n    public void loadsConfiguredStorageProviderDuringClassInitialization() throws Exception {\n        String previousProvider = System.getProperty(DEFAULT_STORAGE_PROVIDER_PROPERTY);\n        System.setProperty(DEFAULT_STORAGE_PROVIDER_PROPERTY, MemoryStorageProvider.class.getName());\n\n        try {\n            StorageProvider provider = DefaultStorageProvider.getInstance();\n\n            assertThat(provider).isInstanceOf(MemoryStorageProvider.class);\n            assertStoresAndReadsContent(provider);\n        } finally {\n            restoreDefaultStorageProviderProperty(previousProvider);\n        }\n    }\n\n    private static void assertStoresAndReadsContent(StorageProvider provider) throws Exception {\n        byte[] content = \"mime4j storage provider content\".getBytes(StandardCharsets.UTF_8);\n        Storage storage = provider.store(new ByteArrayInputStream(content));\n\n        try (InputStream input = storage.getInputStream()) {\n            assertThat(input.readAllBytes()).isEqualTo(content);\n        } finally {\n            storage.delete();\n        }\n    }\n\n    private static void restoreDefaultStorageProviderProperty(String previousProvider) {\n        if (previousProvider == null) {\n            System.clearProperty(DEFAULT_STORAGE_PROVIDER_PROPERTY);\n        } else {\n            System.setProperty(DEFAULT_STORAGE_PROVIDER_PROPERTY, previousProvider);\n        }\n    }\n}\n"}
