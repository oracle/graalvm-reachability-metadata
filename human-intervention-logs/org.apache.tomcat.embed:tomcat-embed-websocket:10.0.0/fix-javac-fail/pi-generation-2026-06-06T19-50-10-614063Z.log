  124:        }
  125:
  126:        static void reset() {
  127:            CONSTRUCTIONS.set(0);
  128:            INITIALIZED_WITH.set(null);
  129:        }
  130:
  131:        static int constructions() {
  132:            return CONSTRUCTIONS.get();
  133:        }
  134:
  135:        static EndpointConfig initializedWith() {
  136:            return INITIALIZED_WITH.get();
  137:        }
  138:
  139:        @Override
