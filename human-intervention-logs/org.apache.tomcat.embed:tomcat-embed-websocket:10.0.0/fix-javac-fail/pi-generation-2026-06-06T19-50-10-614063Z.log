xception {\n141:            return new Payload(string(bytes));\n142:        }\n143:\n144:        @Override\n145:        public boolean willDecode(ByteBuffer bytes) {\n146:            return bytes.hasRemaining();\n147:        }\n148:\n149:        @Override\n150:        public void init(EndpointConfig config) {\n151:            INITIALIZED_WITH.set(config);\n152:        }\n153:\n154:        @Override\n155:        public void destroy() {\n156:        }\n157:    }\n158:\n159:    public static class PayloadBinaryStreamDecoder implements Decoder.BinaryStream<Payload> {\n160:        private static final AtomicInteger CONSTRUCTIONS = new AtomicInteger();\n161:        private static final AtomicReference<EndpointConfig> INITIALIZED_WITH = new AtomicReference<>();\n162:\n163:        public PayloadBinaryStreamDecoder() {\n164:            CONSTRUCTIONS.incrementAndGet();\n165:        }\n166:\n167:        static void reset() {\n168:            CONSTRUCTIONS.set(0);\n169:            INITIALIZED_WITH.set(null);\n170:        }\n171:\n172:        static int constructions() {\n173:            return CONSTRUCTIONS.get();\n174:        }\n175:\n176:        static EndpointConfig initializedWith() {\n177:            return INITIALIZED_WITH.get();\n178:        }\n179:\n180:        @Override\n181:        public Payload decode(InputStream is) throws DecodeException, IOException {\n182:            ByteArrayOutputStream output = new ByteArrayOutputStream();\n183:            byte[] buffer = new byte[32];\n184:            int read = is.read(buffer);\n185:            while (read != -1) {\n186:                output.write(buffer, 0, read);\n187:                read = is.read(buffer);\n188:            }\n189:            return new Payload(output.toString(StandardCharsets.UTF_8));\n190:        }\n191:\n192:        @Override\n193:        public void init(EndpointConfig config) {\n194:            INITIALIZED_WITH.set(config);\n195:        }\n196:\n197:        @Override\n198:        public void destroy