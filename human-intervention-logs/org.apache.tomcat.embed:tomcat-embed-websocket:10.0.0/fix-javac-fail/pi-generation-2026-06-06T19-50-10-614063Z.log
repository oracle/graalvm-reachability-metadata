  78:    @SuppressWarnings("unchecked")
  79:    private static MessageHandler.Whole<ByteBuffer> asWholeBinaryHandler(MessageHandler handler) {
  80:        assertThat(handler).isInstanceOf(MessageHandler.Whole.class);
  81:        return (MessageHandler.Whole<ByteBuffer>) handler;
