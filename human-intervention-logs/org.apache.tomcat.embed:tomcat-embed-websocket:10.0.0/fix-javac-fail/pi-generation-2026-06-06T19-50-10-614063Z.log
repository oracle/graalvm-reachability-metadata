  208:    private static class NoOpRemoteEndpoint extends WsRemoteEndpointImplBase {
  209:        @Override
  210:        protected void doWrite(SendHandler handler, long blockingWriteTimeoutExpiry, ByteBuffer... data) {
  211:            handler.onResult(new SendResult());
  212:        }
