  95:    private static WsSession newSession(EndpointConfig endpointConfig) throws DeploymentException {
  96:        return new WsSession(new NoOpEndpoint(), new NoOpRemoteEndpoint(), new WsWebSocketContainer(),
  97:                URI.create("ws://localhost/test"), Collections.emptyMap(), null, null, null, Collections.emptyList(),
  98:                null, Collections.emptyMap(), false, endpointConfig);
  99:    }
  100:
  101:    public static class Payload {
  102:        private final String value;
