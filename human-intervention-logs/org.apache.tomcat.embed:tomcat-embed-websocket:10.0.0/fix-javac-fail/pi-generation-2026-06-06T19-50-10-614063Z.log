  159:    public static class PayloadBinaryStreamDecoder implements Decoder.BinaryStream<Payload> {
  160:        private static final AtomicInteger CONSTRUCTIONS = new AtomicInteger();
  161:        private static final AtomicReference<EndpointConfig> INITIALIZED_WITH = new AtomicReference<>();
  162:
  163:        public PayloadBinaryStreamDecoder() {
  164:            CONSTRUCTIONS.incrementAndGet();
  165:        }
  166:
  167:        static void reset() {
