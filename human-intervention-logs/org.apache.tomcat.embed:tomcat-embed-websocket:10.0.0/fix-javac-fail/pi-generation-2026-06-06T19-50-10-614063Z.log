e received a copy of the CC0 legalcode along with this\n5: * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n6: */\n7:package org_apache_tomcat_embed.tomcat_embed_websocket;\n8:\n9:import static org.assertj.core.api.Assertions.assertThat;\n10:\n11:import java.io.ByteArrayOutputStream;\n12:import java.io.IOException;\n13:import java.io.InputStream;\n14:import java.net.URI;\n15:import java.nio.ByteBuffer;\n16:import java.nio.charset.StandardCharsets;\n17:import java.util.Collections;\n18:import java.util.List;\n19:import java.util.concurrent.atomic.AtomicInteger;\n20:import java.util.concurrent.atomic.AtomicReference;\n21:\n22:import jakarta.websocket.ClientEndpointConfig;\n23:import jakarta.websocket.DecodeException;\n24:import jakarta.websocket.Decoder;\n25:import jakarta.websocket.DeploymentException;\n26:import jakarta.websocket.Endpoint;\n27:import jakarta.websocket.EndpointConfig;\n28:import jakarta.websocket.MessageHandler;\n29:import jakarta.websocket.SendHandler;\n30:import jakarta.websocket.SendResult;\n31:import jakarta.websocket.Session;\n32:\n33:import org.apache.tomcat.websocket.WsRemoteEndpointImplBase;\n34:import org.apache.tomcat.websocket.WsSession;\n35:import org.apache.tomcat.websocket.WsWebSocketContainer;\n36:import org.junit.jupiter.api.Test;\n37:\n38:public class PojoMessageHandlerWholeBinaryTest {\n39:\n40:    @Test\n41:    void wholeBinaryMessageWithBinaryDecoderInvokesWrappedPojoHandler() throws DeploymentException {\n42:        PayloadBinaryDecoder.reset();\n43:        ClientEndpointConfig config = ClientEndpointConfig.Builder.create()\n44:                .decoders(List.of(PayloadBinaryDecoder.class))\n45:                .build();\n46:        WsSession session = newSession(config);\n47:        PayloadHandler payloadHandler = new PayloadHandler();\n48:\n49:        session.addMessageHandler(payloadHandler);\n50:        MessageHandler wrappedHandler = session.getMessageHandlers().iterator().next();\n51:        asWholeBinaryHandler(wrappedHandler).onMessage(ByteBuffer.wrap(bytes(\"binary-payload\")));\n52:\n53:        assertThat(wrappedHandler).isNotSameAs(payloadHandler);\n54:        assertThat(PayloadBinaryDecoder.constructions()).isGreaterThanOrEqualTo(2);\n55:        assertThat(PayloadBinaryDecoder.initializedWith()).isSameAs(config);\n56:        assertThat(payloadHandler.receivedPayload.value).isEqualTo(\"binary-payload\");\n57:    }\n58:\n59:    @Test\n60:    void wholeBinaryMessageWithBinaryStreamDecoderInvokesWrappedPojoHandler() throws DeploymentException {\n61:        PayloadBinaryStreamDecoder.reset();\n62:        ClientEndpointConfig config = ClientEndpointConfig.Builder.create()\n63:                .decoders(List.of(PayloadBinaryStreamDecoder.class))\n64:                .build();\n65:        WsSession session = newSession(config);\n66:        PayloadHandler payloadHandler = new PayloadHandler();\n67:\n68:        session.addMessageHandler(payloadHandler);\n69:        MessageHandler wrappedHandler = session.getMessageHandlers().iterator().next();\n70:        asWholeBinaryHandler(wrappedHandler).onMessage(ByteBuffer.wrap(bytes(\"stream-payload\")));\n71:\n72:        assertThat(wrappedHandler).isNotSameAs(payloadHandler);\n73:        assertThat(PayloadBinaryStreamDecoder.constructions()).isGreaterThanOrEqualTo(2);\n74:        assertThat(PayloadBinaryStreamDecoder.initializedWith()).isSameAs(config);\n75:        assertThat(payloadHandler.receivedPayload.value).isEqualTo(\"stream-payload\");\n76:    }\n77:\n78:    @SuppressWarnings(\"unchecked\")\n79:    private static MessageHandler.Whole<ByteBuffer> asWholeBinaryHandler(MessageHandler handler) {\n80:        assertThat(handler).isInstanceOf(MessageHandler.Whole.class);\n81:        return (MessageHandler.Whole<ByteBuffer>) handler;\n82:    }\n83:\n84:    private static byte[] bytes(String value) {\n85:        return value.getBytes(StandardCharsets.UTF_8);\n86:    }\n87:\n88:    private static String string(ByteBuffer buffer)