                                      decoderClazz.getName()), e);
                  }
                  DecoderEntry entry = new DecoderEntry(
                          Util.getDecoderType(decoderClazz), decoderClazz);
                  result.add(entry);
              }
          }
  
          return result;
      }
  
  
