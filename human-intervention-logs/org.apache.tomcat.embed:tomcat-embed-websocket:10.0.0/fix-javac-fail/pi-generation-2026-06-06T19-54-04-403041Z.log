                          "pojoMessageHandlerWhole.maxBufferSize"));
              }
              session.setMaxTextMessageBufferSize((int) maxMessageSize);
          }
  
          // Check for primitives
          Class<?> type = method.getParameterTypes()[indexPayload];
          if (Util.isPrimitive(type)) {
              primitiveType = type;
