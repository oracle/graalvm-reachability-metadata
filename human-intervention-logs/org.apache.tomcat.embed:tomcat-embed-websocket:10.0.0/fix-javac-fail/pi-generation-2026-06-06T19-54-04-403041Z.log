          }
          return null;
      }
  
  
      @Override
      protected Object convert(String message) {
          return new StringReader(message);
      }
  
  
      @Override
      protected void onClose() {
          for (Decoder decoder : decoders) {
              decoder.destroy();
          }
      }
  }
