ons() {\n            return CONSTRUCTIONS.get();\n        }\n\n        static EndpointConfig initializedWith() {\n            return INITIALIZED_WITH.get();\n        }\n\n        @Override\n        public Payload decode(String s) throws DecodeException {\n            return new Payload(s);\n        }\n\n        @Override\n        public boolean willDecode(String s) {\n            return true;\n        }\n\n        @Override\n        public void init(EndpointConfig config) {\n            INITIALIZED_WITH.set(config);\n        }\n\n        @Override\n        public void destroy() {\n        }\n    }\n\n    private static class NoOpEndpoint extends Endpoint {\n        @Override\n        public void onOpen(Session session, EndpointConfig config) {\n        }\n    }\n\n    private static class NullInstanceManagerWebSocketContainer extends WsWebSocketContainer {\n        @Override\n        protected InstanceManager getInstanceManager(ClassLoader classLoader) {\n            return null;\n        }\n    }\n\n    private static class NoOpRemoteEndpoint extends WsRemoteEndpointImplBase {\n        private final Lock lock = new ReentrantLock();\n\n        @Override\n        protected void doWrite(SendHandler handler, long blockingWriteTimeoutExpiry, ByteBuffer... data) {\n            handler.onResult(new SendResult());\n        }\n\n        @Override\n        protected boolean isMasked() {\n            return false;\n        }\n\n        @Override\n        protected void doClose() {\n        }\n\n        @Override\n        protected Lock getLock() {\n            return lock;\n\n[4 more lines in file. Use offset=161 to continue.]"}], "isError": false, "timestamp": 1778180863893}, {"role": "toolResult", "toolCallId": "call_g5I1SF3KaSIXFHalqwNOlCBf|fc_01c638b97f50dc630169fce2ff779c819e9578772fc23fdd7c", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with