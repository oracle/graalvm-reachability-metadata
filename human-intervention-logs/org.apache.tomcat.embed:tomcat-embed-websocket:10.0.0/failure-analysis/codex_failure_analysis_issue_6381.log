ainer();\\n\\n            assertThat(container).isInstanceOf(WsWebSocketContainer.class);\\n        } finally {\\n            Thread.currentThread().setContextClassLoader(originalContextClassLoader);\\n            if (container instanceof WsWebSocketContainer) {\\n                ((WsWebSocketContainer) container).destroy();\\n            }\\n        }\\n    }\\n\\n    private static final class HidingServicesClassLoader extends ClassLoader {\\n        HidingServicesClassLoader(ClassLoader parent) {\\n            super(parent);\\n        }\\n\\n        @Override\\n        public URL getResource(String name) {\\n            if (CONTAINER_PROVIDER_SERVICE.equals(name)) {\\n                return null;\\n            }\\n            return super.getResource(name);\\n        }\\n\\n        @Override\\n        public Enumeration<URL> getResources(String name) throws IOException {\\n            if (CONTAINER_PROVIDER_SERVICE.equals(name)) {\\n                return Collections.emptyEnumeration();\\n            }\\n            return super.getResources(name);\\n        }\\n    }\\n}\\n\"}], \"isError\": false, \"timestamp\": 1778180823299}]}\n/home/vjovanov/c/forge/forge4/graalvm-reachability-metadata/forge/logs/org.apache.tomcat.embed:tomcat-embed-websocket:10.0.0/fix-javac-fail/pi-generation-2026-05-07T19-14-50-862629Z.log:2014:[thinking] I’m thinking about the transition from javax to jakarta, specifically with servlet 5.0. It seems that Tomcat 10 utilizes jakarta. I wonder if I need to move the class package from `org.apache.tomcat.websocket.ClientEndpointHolder` or `PojoClassHolder` to maybe `org.apache.tomcat.websocket.pojo`. I’ll need to ensure I find the corresponding names. This is kind of a puzzle but also a crucial update to get right!\n/home/vjovanov/c/forge/forge4/graalvm-reachability-metadata/forge/logs/org.apache.tomcat.embed:tomcat-embed-websocket:10.0.0/fix-javac-fail/pi-generation-2026-05-07T19-14-50-862629Z.log:2018:[tool-call] delta {\"command\":\"SRC=/h