, \"text\": \"tests/src/org.apache.tomcat.embed/tomcat-embed-websocket/9.0.83/src/test/java/org_apache_tomcat_embed/tomcat_embed_websocket/PojoMessageHandlerWholeBaseTest.java\\n\"}], \"isError\": false, \"timestamp\": 1780775507796}]}\n1371:  import javax.websocket.ClientEndpointConfig;\n1372:  import javax.websocket.DecodeException;\n1373:  import javax.websocket.Decoder;\n1374:  import javax.websocket.DeploymentException;\n1375:  import javax.websocket.Endpoint;\n1376:  import javax.websocket.EndpointConfig;\n1377:  import javax.websocket.MessageHandler;\n1378:  import javax.websocket.SendHandler;\n1379:  import javax.websocket.SendResult;\n1380:  import javax.websocket.Session;\n1515:[recv] {\"type\": \"message_start\", \"message\": {\"role\": \"toolResult\", \"toolCallId\": \"call_bChE5eM6ID97xLzRmOsOZHGa|fc_0dd267bb112c9197016a247a5527a88196a8265ff4315b5cea\", \"toolName\": \"read\", \"content\": [{\"type\": \"text\", \"text\": \"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage org_apache_tomcat_embed.tomcat_embed_websocket;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\n\\nimport java.net.URI;\\nimport java.nio.ByteBuffer;\\nimport java.util.Collections;\\nimport java.util.List;\\nimport java.util.concurrent.atomic.AtomicInteger;\\nimport java.util.concurrent.atomic.AtomicReference;\\nimport java.util.concurrent.locks.Lock;\\nimport java.util.concurrent.locks.ReentrantLock;\\n\\nimport javax.websocket.ClientEndpointConfig;\\nimport javax.websocket.DecodeException;\\nimport javax.websocket.Decoder;\\nimport javax.websocket.DeploymentException;\\nimport javax.websocket.Endpoint;\\nimport javax.websocket.EndpointConfig;\\nimport javax.websocket.MessageHandler;\\nimport javax.websocket.SendHandler;\\nimport javax.websocket.SendResult;\\nimport javax.websocket.Session;\\n\\ni