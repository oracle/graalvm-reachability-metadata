r += \"alpha\"\n    builder += \"beta\"\n\n    val result: Vector[String] = builder.result()\n\n    assertThat(result.asJava).containsExactly(\"alpha\", \"beta\")\n  }\n}\n","exit_code":0,"status":"completed"}}
