age could still extend a Java-public interface.\"}]}"}, {"type": "toolCall", "id": "call_Uf32vfueqtrcPeqjBegj0bKz|fc_099444905eef4ef20169fc374d27588190bcfb6a56887cc79b", "name": "write", "arguments": {"path": "tests/src/org.apache.pekko/pekko-parsing_3/2.0.0-M1/src/test/scala/org_apache_pekko/pekko_parsing_3/Pekko_parsing_3Test.scala", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_apache_pekko.pekko_parsing_3\n\nimport org.apache.pekko.macros.LogHelperMacro\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\n\nclass Pekko_parsing_3Test {\n  @Test\n  def guardDoesNotEvaluateDisabledBlock(): Unit = {\n    var evaluated: Boolean = false\n\n    MacroHarness.guard(false) {\n      evaluated = true\n    }\n\n    assertThat(evaluated).isFalse\n  }\n\n  @Test\n  def guardEvaluatesEnabledBlockExactlyOnce(): Unit = {\n    var invocationCount: Int = 0\n\n    MacroHarness.guard(true) {\n      invocationCount += 1\n    }\n\n    assertThat(invocationCount).isEqualTo(1)\n  }\n\n  @Test\n  def guardUsesRuntimeConditionForGeneratedLoggingCheck(): Unit = {\n    var isEnabled: Boolean = false\n    val messages: scala.collection.mutable.ArrayBuffer[String] = scala.collection.mutable.ArrayBuffer.empty\n\n    MacroHarness.guard(isEnabled) {\n      messages += \"debug-disabled\"\n    }\n\n    isEnabled = true\n    MacroHarness.guard(isEnabled) {\n      messages += s\"debug-${messages.size}\"\n    }\n\n    assertThat(messages.toSeq).containsExactly(\"debug-0\")\n  }\n\n  @Test\n  def guardAllowsNestedIndependentChecks(): Unit = {\n    val messages: scala.collection.mutable.ArrayBuffer[String] = scala.collection.mutable.ArrayBuffer.empty\n\n    MacroHarness.guard(true) {\n      messages += \"outer\"\n      MacroHarness.guard(false) {\n        messages += \"inner-disabled\"\n      }\n      MacroHarness.guard(true) {\n        messages += \"inner-enabled\"\n      }\n    }\n\n    assertThat(messages.toSeq).containsExactly(\"outer\", \"inner-enabled\")\n  }\n}\n\nprivate object MacroHarness {\n  inline def guard(inline isEnabled: Boolean)(inline guardedBlock: Unit): Unit =\n    ${ LogHelperMacro.guard('isEnabled, 'guardedBlock) }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1017, "output": 1504, "cacheRead": 32768, "cacheWrite": 0, "totalTokens": 35289, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778136894399, "responseId": "resp_099444905eef4ef20169fc373f2b6481909b1e5b88f706297c"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_Uf32vfueqtrcPeqjBegj0bKz|fc_099444905eef4ef20169fc374d27588190bcfb6a56887cc79b", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1923 bytes to tests/src/org.apache.pekko/pekko-parsing_3/2.0.0-M1/src/test/scala/org_apache_pekko/pekko_parsing_3/Pekko_parsing_3Test.scala"}], "isError": false, "timestamp": 1778136914417}]}
