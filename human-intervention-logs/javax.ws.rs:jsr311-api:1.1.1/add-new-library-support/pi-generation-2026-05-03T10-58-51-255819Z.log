eption {\n        RejectingServiceClassLoader contextClassLoader = new RejectingServiceClassLoader(getClass().getClassLoader());\n\n        RuntimeDelegate delegate = withContextClassLoader(contextClassLoader, RuntimeDelegate::getInstance);\n\n        assertThat(delegate).isInstanceOf(ProviderRuntimeDelegate.class);\n        assertThat(contextClassLoader.wasServiceResourceRequested()).isTrue();\n        assertThat(contextClassLoader.wasProviderLoadRejected()).isTrue();\n    }\n\n    private static <T> T withContextClassLoader(\n            ClassLoader classLoader,\n            ThrowingSupplier<T> supplier) throws Exception {\n        Thread currentThread = Thread.currentThread();\n        ClassLoader previousClassLoader = currentThread.getContextClassLoader();\n        RuntimeDelegate.setInstance(null);\n        currentThread.setContextClassLoader(classLoader);\n        try {\n            return supplier.get();\n        } finally {\n            currentThread.setContextClassLoader(previousClassLoader);\n        }\n    }\n\n    @FunctionalInterface\n    private interface ThrowingSupplier<T> {\n        T get() throws Exception;\n    }\n\n    private static final class RejectingServiceClassLoader extends ClassLoader {\n        private boolean serviceResourceRequested;\n        private boolean providerLoadRejected;\n\n        private RejectingServiceClassLoader(ClassLoader parent) {\n            super(parent);\n        }\n\n        @Override\n        public InputStream getResourceAsStream(String name) {\n            if (RUNTIME_DELEGATE_SERVICE.equals(name)) {\n                serviceResourceRequested = true;\n                return new ByteArrayInputStream(\n                        ProviderRuntimeDelegate.class.getName().getBytes(StandardCharsets.UTF_8));\n            }\n            return super.getResourceAsStream(name);\n        }\n\n        @Override\n        protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {\n            if (ProviderRuntimeDelegate.class.getName().equals(name)) {\n                providerLoadRejected = true;\n                throw new ClassNotFoundException(name);\n            }\n            return super.loadClass(name, resolve);\n        }\n\n        private boolean wasServiceResourceRequested() {\n            return serviceResourceRequested;\n        }\n\n        private boolean wasProviderLoadRejected() {\n            return providerLoadRejected;\n        }\n    }\n\n    public static final class ProviderRuntimeDelegate extends RuntimeDelegate {\n        public ProviderRuntimeDelegate() {\n        }\n\n        @Override\n        public UriBuilder createUriBuilder() {\n            throw new UnsupportedOperationException(\"URI building is not needed by this test\");\n        }\n\n        @Override\n        public ResponseBuilder createResponseBuilder() {\n            throw new UnsupportedOperationException(\"response building is not needed by this test\");\n        }\n\n        @Override\n        public VariantListBuilder createVariantListBuilder() {\n            throw new UnsupportedOperationException(\"variant building is not needed by this test\");\n        }\n\n        @Override\n        public <T> T createEndpoint(Application application, Class<T> endpointType) {\n            throw new UnsupportedOperationException(\"endpoint creation is not needed by this test\");\n        }\n\n        @Override\n        public <T> HeaderDelegate<T> createHeaderDelegate(Class<T> type) {\n            throw new UnsupportedOperationException(\"header delegates are not needed by this test\");\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777805916134}]}
