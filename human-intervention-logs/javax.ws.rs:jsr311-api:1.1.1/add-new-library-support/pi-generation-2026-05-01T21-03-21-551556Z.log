ResourceLocationsWhenProviderHasWrongType() {\n        currentThread.setContextClassLoader(new NoServiceResourceClassLoader());\n        System.setProperty(RUNTIME_DELEGATE_PROPERTY, NotRuntimeDelegate.class.getName());\n\n        assertThatThrownBy(RuntimeDelegate::getInstance)\n                .isInstanceOf(LinkageError.class)\n                .hasMessageContaining(\"ClassCastException\")\n                .hasMessageContaining(\"RuntimeDelegate.class\");\n    }\n\n    public static final class NotRuntimeDelegate {\n    }\n\n    private static final class NoServiceResourceClassLoader extends ClassLoader {\n        private NoServiceResourceClassLoader() {\n            super(null);\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1734, "output": 978, "cacheRead": 13312, "cacheWrite": 0, "totalTokens": 16024, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777669362433, "responseId": "resp_0a24562bfabefb160169f514f2c2088196b4e1faa2d157a26c"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_Ghyup5O7kPBceLJC6xzOB667|fc_0a24562bfabefb160169f514facb80819686be3289ee0debd9", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2109 bytes to tests/src/javax.ws.rs/jsr311-api/1.1.1/src/test/java/javax_ws_rs/jsr311_api/RuntimeDelegateTest.java"}], "isError": false, "timestamp": 1777669373806}]}
