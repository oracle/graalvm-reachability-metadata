\\\"$result\\\" -eq 124 ] || [ \\\"$result\\\" -eq 131 ] || [ \\\"$result\\\" -eq 137 ]; then\\n      echo \\\"⚠️  TIMEOUT: '$stage' for $VERSION took longer than $TIMEOUT (exit code $result).\\\"\\n    else\\n      echo \\\"❌ ERROR: '$stage' for $VERSION failed with exit code $result.\\\"\\n    fi\\n\\n    attempt=$((attempt + 1))\\n  done\\n\\n  if [ \\\"$report_failed\\\" -ne 0 ]; then\\n    echo \\\"FAILED[$stage][$VERSION][$cmd_str]\\\"\\n  else\\n    echo \\\"SOFT-FAIL[$stage][$VERSION][$cmd_str]\\\"\\n  fi\\n  return $result\\n}\\n\\nfor VERSION in \\\"${VERSIONS[@]}\\\"; do\\n  echo \\\"$DELIMITER\\\"\\n  echo \\\" Testing $TEST_COORDINATES:$VERSION\\\"\\n  echo \\\"$DELIMITER\\\"\\n\\n  if ! run_multiple_attempts \\\"native-image run\\\" 1 test 0; then\\n      # failing execution: bisect\\n      if ! run_multiple_attempts \\\"javac compile\\\" 1 compileTestJava; then\\n        break\\n      fi\\n\\n      if ! run_multiple_attempts \\\"java run\\\" 1 javaTest; then\\n        break\\n      fi\\n\\n      if ! run_multiple_attempts \\\"native-image build\\\" 1 nativeTestCompile; then\\n        break\\n      fi\\n\\n      if ! run_multiple_attempts \\\"native-image run\\\" 3 test; then\\n        break\\n      fi\\n  fi\\n\\n  echo \\\"PASSED:$VERSION\\\"\\ndone\\n\\nexit 0\\n\",\"exit_code\":0,\"status\":\"completed\"}}\nhuman-intervention-logs/org.jboss.resteasy:resteasy-client-api:6.2.15.Final/local-ci-fixup/run-consecutive-tests-2026-05-08T15-39-11-084254Z.log:61:{\"type\":\"item.completed\",\"item\":{\"id\":\"item_33\",\"type\":\"command_execution\",\"command\":\"/usr/bin/bash -lc \\\"sed -n '1,220p' metadata/org.jboss.resteasy/resteasy-client/6.2.12.Final/reachability-metadata.json | sed -n '1,220p'\\\"\",\"aggregated_output\":\"{\\n  \\\"reflection\\\" : [\\n    {\\n      \\\"condition\\\" : {\\n        \\\"typeReached\\\" : \\\"org.jboss.resteasy.resteasy_jaxrs.i18n.LogMessages\\\"\\n      },\\n      \\\"type\\\" : \\\"ch.qos.logback.classic.Logger\\\"\\n