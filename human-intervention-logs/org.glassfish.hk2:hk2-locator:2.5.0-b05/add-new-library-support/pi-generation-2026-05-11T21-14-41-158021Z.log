  package org_glassfish_hk2.hk2_locator;
  
  import static org.assertj.core.api.Assertions.assertThat;
  import static org.assertj.core.api.Assertions.assertThatExceptionOfType;
  
  import java.net.URL;
  
  import javax.inject.Singleton;
  
  import org.glassfish.hk2.api.DynamicConfigurationService;
  import org.glassfish.hk2.utilities.BuilderHelper;
  import org.jvnet.hk2.internal.DefaultClassAnalyzer;
  import org.jvnet.hk2.internal.DynamicConfigurationImpl;
  import org.jvnet.hk2.internal.DynamicConfigurationServiceImpl;
  import org.jvnet.hk2.internal.InstantiationServiceImpl;
  import org.jvnet.hk2.internal.ServiceLocatorImpl;
  import org.jvnet.hk2.internal.ServiceLocatorRuntimeImpl;
  import org.jvnet.hk2.internal.Utilities;
  import org.junit.jupiter.api.Test;
  
  public class DelegatingClassLoaderTest {
      @Test
      void proxyClassLoaderDelegatesClassAndResourceLookups() throws Exception {
          final ServiceLocatorImpl locator = new ServiceLocatorImpl("delegating-class-loader-test", null);
          try {
              final DynamicConfigurationImpl configuration = new DynamicConfigurationImpl(locator);
              configuration.bind(Utilities.getLocatorDescriptor(locator));
              configuration.addActiveDescriptor(Utilities.getThreeThirtyDescriptor(locator));
              configuration.bind(BuilderHelper.link(DynamicConfigurationServiceImpl.class, false)
                      .to(DynamicConfigurationService.class)
                      .in(Singleton.class.getName())
                      .localOnly()
                      .build());
              configuration.bind(BuilderHelper.createConstantDescriptor(new DefaultClassAnalyzer(locator)));
              configuration.bind(BuilderHelper.createDescriptorFromClass(ServiceLocatorRuntimeImpl.class));
              configuration.bind(BuilderHelper.createConstantDescriptor(new InstantiationServiceImpl()));
              configuration.bind(BuilderHelper.link(GreetingServiceImpl.class, false)
                      .to(GreetingService.class)
                      .in(Singleton.class.getName())
                      .proxy()
                      .build());
              configuration.commit();
  
              final GreetingService service = locator.getService(GreetingService.class);
  
              assertThat(service.greet()).isEqualTo("hello from hk2 proxy");
  
              final ClassLoader proxyLoader = service.getClass().getClassLoader();
              assertThat(proxyLoader.toString()).contains("DelegatingClassLoader");
  
              final Class<?> classFromParent = proxyLoader.loadClass(GreetingService.class.getName());
              assertThat(classFromParent).isEqualTo(GreetingService.class);
  
              assertThatExceptionOfType(ClassNotFoundException.class)
                      .isThrownBy(() -> proxyLoader.loadClass("example.hk2.DoesNotExist"));
  
              final URL missingResource = proxyLoader.getResource("example/hk2/missing-resource.txt");
              assertThat(missingResource).isNull();
          } finally {
              locator.shutdown();
          }
      }
  
      public interface GreetingService {
          String greet();
      }
  
      public static class GreetingServiceImpl implements GreetingService {
          @Override
          public String greet() {
              return "hello from hk2 proxy";
          }
      }
  }
