configuration.addActiveDescriptor(Utilities.getThreeThirtyDescriptor(locator));\n            configuration.bind(BuilderHelper.link(DynamicConfigurationServiceImpl.class, false)\n                    .to(DynamicConfigurationService.class)\n                    .in(Singleton.class.getName())\n                    .localOnly()\n                    .build());\n            configuration.bind(BuilderHelper.createConstantDescriptor(new DefaultClassAnalyzer(locator)));\n            configuration.bind(BuilderHelper.createDescriptorFromClass(ServiceLocatorRuntimeImpl.class));\n            configuration.bind(BuilderHelper.createConstantDescriptor(new InstantiationServiceImpl()));\n            configuration.bind(BuilderHelper.link(GreetingServiceImpl.class, false)\n                    .to(GreetingService.class)\n                    .in(Singleton.class.getName())\n                    .proxy()\n                    .build());\n            configuration.commit();\n\n            final GreetingService service = locator.getService(GreetingService.class);"},{"oldText":"        } finally {\n            ServiceLocatorFactory.getInstance().destroy(locator);\n        }","newText":"        } finally {\n            locator.shutdown();\n        }"}]}
