\\n            configuration.bind(BuilderHelper.createConstantDescriptor(new InstantiationServiceImpl()));\\\\n            configuration.bind(BuilderHelper.link(GreetingServiceImpl.class, false)\\\\n                    .to(GreetingService.class)\\\\n                    .in(Singleton.class.getName())\\\\n                    .proxy()\\\\n                    .build());\\\\n            configuration.commit();\\\\n\\\\n            final GreetingService service = locator.getService(GreetingService.class);\\\\n\\\\n            assertThat(service.greet()).isEqualTo(\\\\\\\"hello from hk2 proxy\\\\\\\");\\\\n\\\\n            final ClassLoader proxyLoader = service.getClass().getClassLoader();\\\\n            assertThat(proxyLoader.toString()).contains(\\\\\\\"DelegatingClassLoader\\\\\\\");\\\\n\\\\n            final Class<?> classFromParent = proxyLoader.loadClass(GreetingService.class.getName());\\\\n            assertThat(classFromParent).isEqualTo(GreetingService.class);\\\\n\\\\n            assertThatExceptionOfType(ClassNotFoundException.class)\\\\n                    .isThrownBy(() -> proxyLoader.loadClass(\\\\\\\"example.hk2.DoesNotExist\\\\\\\"));\\\\n\\\\n            final URL missingResource = proxyLoader.getResource(\\\\\\\"example/hk2/missing-resource.txt\\\\\\\");\\\\n            assertThat(missingResource).isNull();\\\\n        } finally {\\\\n            locator.shutdown();\\\\n        }\\\\n    }\\\\n\\\\n    public interface GreetingService {\\\\n        String greet();\\\\n    }\\\\n\\\\n    public static class GreetingServiceImpl implements GreetingService {\\\\n        @Override\\\\n        public String greet() {\\\\n            return \\\\\\\"hello from hk2 proxy\\\\\\\";\\\\n        }\\\\n    }\\\\n}\\\\n\\\"}], \\\"isError\\\": false, \\\"timestamp\\\": 1778534214554}]}\\n/home/vjovanov/c/forge/forge8/graalvm-reachability-metadata/forge/logs/org.glassfish.hk2:hk2-locator:2.5.0-b05/add-new-library-support/pi-generation-2026-05-11T21-14-41-158021Z.log: