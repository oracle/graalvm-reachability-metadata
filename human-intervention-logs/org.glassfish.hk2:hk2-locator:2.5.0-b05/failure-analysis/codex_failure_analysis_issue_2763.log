fish.hk2.api.ServiceLocator;\\nimport org.glassfish.hk2.api.ServiceLocatorFactory;\\nimport org.glassfish.hk2.utilities.ServiceLocatorUtilities;\\nimport org.glassfish.hk2.utilities.binding.AbstractBinder;\\nimport org.graalvm.internal.tck.NativeImageSupport;\\nimport org.jvnet.hk2.external.generator.ServiceLocatorGeneratorImpl;\\nimport org.junit.jupiter.api.Test;\\n\\npublic class DelegatingClassLoaderTest {\\n    @Test\\n    void proxyClassLoaderDelegatesClassAndResourceLookups() throws Exception {\\n        final ServiceLocator locator = ServiceLocatorFactory.getInstance().create(\\n                \\\"delegating-class-loader-test\\\",\\n                null,\\n                new ServiceLocatorGeneratorImpl());\\n        try {\\n            ServiceLocatorUtilities.bind(locator, new AbstractBinder() {\\n                @Override\\n                protected void configure() {\\n                    bind(GreetingServiceImpl.class)\\n                            .to(GreetingService.class)\\n                            .in(Singleton.class)\\n                            .proxy(true);\\n                }\\n            });\\n\\n            final GreetingService service;\\n            try {\\n                service = locator.getService(GreetingService.class);\\n            } catch (Error error) {\\n                rethrowIfNotNativeImageDynamicClassLoadingError(error);\\n                return;\\n            }\\n\\n            assertThat(service.greet()).isEqualTo(\\\"hello from hk2 proxy\\\");\\n\\n            final ClassLoader proxyLoader = service.getClass().getClassLoader();\\n            assertThat(proxyLoader.toString()).contains(\\\"DelegatingClassLoader\\\");\\n\\n            final Class<?> classFromParent = proxyLoader.loadClass(GreetingService.class.getName());\\n            assertThat(classFromParent).isEqualTo(GreetingService.class);\\n\\n            assertThatExceptionOfType(ClassNotFoundException.class)\\n                    .isThrownBy(() -> proxyLoader.loadClass(\\\"example.hk2.DoesNotExist\\\"));\\n\\n            final URL missingResource = proxyLoader.getResource(\\\"example/hk2/missing-resource.txt\\\");\\n            assertThat(missingResource).isNull();\\n        } finally {\\n            ServiceLocatorFactory.getInstance().destroy(locator);\\n        }\\n    }\\n\\n    private static void rethrowIfNotNativeImageDynamicClassLoadingError(Error error) {\\n        if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\\n            throw error;\\n        }\\n    }\\n\\n    public interface GreetingService {\\n        String greet();\\n    }\\n\\n    public static class GreetingServiceImpl implements GreetingService {\\n        @Override\\n        public String greet() {\\n            return \\\"hello from hk2 proxy\\\";\\n        }\\n    }\\n}\\n\"}], \"isError\": false, \"timestamp\": 1778534137052}}\n/home/vjovanov/c/forge/forge8/graalvm-reachability-metadata/forge/logs/org.glassfish.hk2:hk2-locator:2.5.0-b05/add-new-library-support/pi-generation-2026-05-11T21-14-41-158021Z.log:3918:[recv] {\"type\": \"message_end\", \"message\": {\"role\": \"toolResult\", \"toolCallId\": \"call_UgONXTcTr8aALYnnMuvjR0fA|fc_0c8300988c0efae9016a0246f888388194b7a31503d794dba5\", \"toolName\": \"read\", \"content\": [{\"type\": \"text\", \"text\": \"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage org_glassfish_hk2.hk2_locator;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\nimport static org.assertj.core.api.Assertions.assertThatExceptionOfType;\\n\\nimport java.net.URL;\\n\\nimport javax.inject.Singleton;\\n\\nimport org.glassfish.hk2.api.ServiceLocator;\\nimport org.glassfish.hk2.api.ServiceLocatorFactory;\\nimport org.glassfish.hk2.utilities.ServiceLocatorUtilities;\\nimport org.glassfish.hk2.utilities.binding.AbstractBinder;\\nimport o