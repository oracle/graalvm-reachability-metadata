[tool-call] delta {"path":"tests/src/org.apache.maven/maven-compat/3.0/src/test/java/org_apache_maven/maven_compat/ExpressionDocumenterTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_apache_maven.maven_compat;\n\nimport java.util.Map;\n\nimport org.apache.maven.usability.plugin.Expression;\nimport org.apache.maven.usability.plugin.ExpressionDocumenter;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ExpressionDocumenterTest {\n    @Test\n    void loadsBundledExpressionDocumentationResources() throws Exception {\n        Map<?, ?> documentationBySyntax = ExpressionDocumenter.load();\n\n        assertThat(documentationBySyntax).containsKeys(\"project.artifact\", \"settings.offline\", \"localRepository\");\n\n        Expression projectArtifact = (Expression) documentationBySyntax.get(\"project.artifact\");\n        assertThat(projectArtifact.getSyntax()).isEqualTo(\"project.artifact\");\n        assertThat(projectArtifact.getDescription()).contains(\"Artifact instance\");\n\n        Expression localRepository = (Expression) documentationBySyntax.get(\"localRepository\");\n        assertThat(localRepository.getSyntax()).isEqualTo(\"localRepository\");\n        assertThat(localRepository.getConfiguration()).contains(\"~/.m2/repository\");\n    }\n}\n"}
