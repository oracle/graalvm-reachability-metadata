[tool-call] delta {"path":"tests/src/org.apache.maven/maven-compat/3.0/src/test/java/org_apache_maven/maven_compat/ExpressionDocumenterTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_apache_maven.maven_compat;\n\nimport org.apache.maven.usability.plugin.Expression;\nimport org.apache.maven.usability.plugin.ExpressionDocumenter;\nimport org.junit.jupiter.api.Test;\n\nimport java.util.Map;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ExpressionDocumenterTest {\n    @Test\n    void loadsBundledPluginExpressionDocumentation() throws Exception {\n        Map<?, ?> documentation = ExpressionDocumenter.load();\n\n        assertThat(documentation).containsKey(\"project.artifact\");\n        Object projectArtifact = documentation.get(\"project.artifact\");\n        assertThat(projectArtifact).isInstanceOf(Expression.class);\n\n        Expression expression = (Expression) projectArtifact;\n        assertThat(expression.getSyntax()).isEqualTo(\"project.artifact\");\n        assertThat(expression.getDescription()).contains(\"MavenProject instance\");\n    }\n}\n"}
