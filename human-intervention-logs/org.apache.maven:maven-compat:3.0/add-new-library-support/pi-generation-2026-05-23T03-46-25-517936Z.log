  package org_apache_maven.maven_compat;
  
  import org.apache.maven.model.Dependency;
  import org.apache.maven.model.Model;
  import org.apache.maven.model.Organization;
  import org.apache.maven.project.DefaultProjectBuilderConfiguration;
  import org.apache.maven.project.ProjectBuilderConfiguration;
  import org.apache.maven.project.interpolation.StringSearchModelInterpolator;
  import org.junit.jupiter.api.Test;
  
  import java.io.File;
  import java.util.Date;
  import java.util.Properties;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class StringSearchModelInterpolatorInnerInterpolateObjectActionTest {
      @Test
      void interpolatesModelStringCollectionMapAndNestedObjectFields() throws Exception {
          Model model = new Model();
          model.setModelVersion("4.0.0");
          model.setGroupId("example");
          model.setArtifactId("demo");
          model.setVersion("${declared.version}");
          model.addModule("${module.name}");
          model.addProperty("custom.property", "${property.value}");
  
          Dependency dependency = new Dependency();
          dependency.setGroupId("dependency.group");
          dependency.setArtifactId("dependency-artifact");
          dependency.setVersion("${dependency.version}");
          model.addDependency(dependency);
  
          Organization organization = new Organization();
          organization.setName("${organization.name}");
          model.setOrganization(organization);
  
          StringSearchModelInterpolator interpolator = new StringSearchModelInterpolator();
          interpolator.initialize();
  
          interpolator.interpolate(model, new File("."), configuration(), false);
  
          assertThat(model.getVersion()).isEqualTo("1.0.0");
          assertThat(model.getModules()).containsExactly("core");
          assertThat(model.getProperties()).containsEntry("custom.property", "configured-property");
          assertThat(model.getDependencies()).singleElement().satisfies(interpolatedDependency ->
              assertThat(interpolatedDependency.getVersion()).isEqualTo("2.0.0"));
          assertThat(model.getOrganization().getName()).isEqualTo("Example Organization");
      }
  
      private static ProjectBuilderConfiguration configuration() {
          Properties userProperties = new Properties();
          userProperties.setProperty("declared.version", "1.0.0");
          userProperties.setProperty("module.name", "core");
          userProperties.setProperty("property.value", "configured-property");
          userProperties.setProperty("dependency.version", "2.0.0");
          userProperties.setProperty("organization.name", "Example Organization");
  
          return new DefaultProjectBuilderConfiguration()
              .setBuildStartTime(new Date(0L))
              .setExecutionProperties(new Properties())
              .setUserProperties(userProperties);
      }
  }
