  package org_apache_maven.maven_compat;
  
  import org.apache.maven.usability.plugin.Expression;
  import org.apache.maven.usability.plugin.ExpressionDocumenter;
  import org.junit.jupiter.api.Test;
  
  import java.util.Map;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ExpressionDocumenterTest {
      @Test
      void loadsBundledPluginExpressionDocumentation() throws Exception {
          Map<?, ?> documentation = ExpressionDocumenter.load();
  
          assertThat(documentation.containsKey("project.artifact")).isTrue();
          Object projectArtifact = documentation.get("project.artifact");
          assertThat(projectArtifact).isInstanceOf(Expression.class);
  
          Expression expression = (Expression) projectArtifact;
          assertThat(expression.getSyntax()).isEqualTo("project.artifact");
          assertThat(expression.getDescription()).contains("Artifact instance");
      }
  }
