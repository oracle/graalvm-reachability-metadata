  package org_apache_maven.maven_compat;
  
  import java.util.Map;
  
  import org.apache.maven.usability.plugin.Expression;
  import org.apache.maven.usability.plugin.ExpressionDocumenter;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ExpressionDocumenterTest {
      @Test
      void loadsBundledExpressionDocumentationResources() throws Exception {
          Map<?, ?> documentationBySyntax = ExpressionDocumenter.load();
  
          assertThat(documentationBySyntax.containsKey("project.artifact")).isTrue();
          assertThat(documentationBySyntax.containsKey("settings.offline")).isTrue();
          assertThat(documentationBySyntax.containsKey("localRepository")).isTrue();
  
          Expression projectArtifact = (Expression) documentationBySyntax.get("project.artifact");
          assertThat(projectArtifact.getSyntax()).isEqualTo("project.artifact");
          assertThat(projectArtifact.getDescription()).contains("Artifact instance");
  
          Expression localRepository = (Expression) documentationBySyntax.get("localRepository");
          assertThat(localRepository.getSyntax()).isEqualTo("localRepository");
          assertThat(localRepository.getConfiguration()).contains("<localRepository>/path/to/local/repository</localRepository>");
      }
  }
