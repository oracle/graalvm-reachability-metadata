[tool-call] delta {"path":"tests/src/com.alibaba.fastjson2/fastjson2/2.0.53/src/test/java/com_alibaba_fastjson2/fastjson2/Fastjson2Test.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_alibaba_fastjson2.fastjson2;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport com.alibaba.fastjson2.JSONArray;\nimport com.alibaba.fastjson2.JSONObject;\nimport org.junit.jupiter.api.Test;\n\npublic class Fastjson2Test {\n    @Test\n    void buildsMutableObjectAndArrayTrees() {\n        JSONObject order = JSONObject.of(\"id\", \"A-100\", \"status\", \"created\");\n        JSONArray lines = order.putArray(\"lines\");\n\n        lines.addObject()\n                .fluentPut(\"sku\", \"coffee\")\n                .fluentPut(\"quantity\", 1);\n        lines.addObject()\n                .fluentPut(\"sku\", \"tea\")\n                .fluentPut(\"quantity\", 2);\n        order.putObject(\"shipping\")\n                .fluentPut(\"city\", \"Prague\")\n                .fluentPut(\"priority\", true);\n        order.fluentPut(\"status\", \"paid\");\n\n        assertThat(order.getString(\"status\")).isEqualTo(\"paid\");\n        assertThat(order.getJSONArray(\"lines\")).hasSize(2);\n        assertThat(order.getJSONArray(\"lines\").getJSONObject(1).getString(\"sku\")).isEqualTo(\"tea\");\n        assertThat(order.getJSONObject(\"shipping\").getString(\"city\")).isEqualTo(\"Prague\");\n        assertThat(order.getJSONObject(\"shipping\").getBooleanValue(\"priority\")).isTrue();\n    }\n\n    @Test\n    void readsTypedValuesFromObjectAndArrayContainers() {\n        JSONObject metrics = JSONObject.of(\n                \"name\", \"fastjson2\",\n                \"enabled\", true,\n                \"count\", 42,\n                \"ratio\", 0.75D);\n        JSONArray values = JSONArray.of(\"first\", 7, false, metrics);\n\n        assertThat(metrics.getString(\"name\")).isEqualTo(\"fastjson2\");\n        assertThat(metrics.getBooleanValue(\"enabled\")).isTrue();\n        assertThat(metrics.getIntValue(\"count\")).isEqualTo(42);\n        assertThat(metrics.getDoubleValue(\"ratio\")).isEqualTo(0.75D);\n        assertThat(values.getString(0)).isEqualTo(\"first\");\n        assertThat(values.getIntValue(1)).isEqualTo(7);\n        assertThat(values.getBooleanValue(2)).isFalse();\n        assertThat(values.getJSONObject(3).getString(\"name\")).isEqualTo(\"fastjson2\");\n    }\n\n    @Test\n    void supportsFluentArrayMutations() {\n        JSONArray items = JSONArray.of(\"draft\")\n                .fluentAdd(\"review\")\n                .fluentAdd(\"publish\")\n                .fluentSet(1, \"approved\")\n                .fluentRemove(\"draft\");\n\n        items.addArray()\n                .fluentAdd(\"archive\")\n                .fluentAdd(\"notify\");\n\n        assertThat(items).hasSize(3);\n        assertThat(items.getString(0)).isEqualTo(\"approved\");\n        assertThat(items.getString(1)).isEqualTo(\"publish\");\n        assertThat(items.getJSONArray(2)).containsExactly(\"archive\", \"notify\");\n    }\n}\n"}
