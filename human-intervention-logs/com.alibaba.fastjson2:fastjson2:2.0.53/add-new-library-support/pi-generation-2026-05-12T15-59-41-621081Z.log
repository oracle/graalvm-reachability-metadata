[tool-call] delta {"path":"tests/src/com.alibaba.fastjson2/fastjson2/2.0.53/src/test/java/com_alibaba_fastjson2/fastjson2/Fastjson2Test.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_alibaba_fastjson2.fastjson2;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport com.alibaba.fastjson2.JSON;\nimport com.alibaba.fastjson2.JSONArray;\nimport com.alibaba.fastjson2.JSONObject;\nimport com.alibaba.fastjson2.JSONPath;\nimport org.junit.jupiter.api.Test;\n\npublic class Fastjson2Test {\n    @Test\n    void readsNestedValuesWithCompiledJsonPath() {\n        JSONObject document = JSON.parseObject(\"\"\"\n                {\n                  \"store\": {\n                    \"book\": [\n                      {\"title\": \"Native Image\", \"price\": 29.95},\n                      {\"title\": \"Fast JSON\", \"price\": 19.50}\n                    ]\n                  }\n                }\n                \"\"\");\n\n        JSONPath titlePath = JSONPath.of(\"$.store.book[1].title\");\n        JSONPath booksPath = JSONPath.of(\"$.store.book\");\n\n        assertThat(titlePath.eval(document)).isEqualTo(\"Fast JSON\");\n        assertThat(booksPath.eval(document)).isInstanceOf(JSONArray.class);\n        assertThat((JSONArray) booksPath.eval(document)).hasSize(2);\n    }\n\n    @Test\n    void updatesParsedDocumentsWithJsonPath() {\n        JSONObject document = JSON.parseObject(\"\"\"\n                {\n                  \"order\": {\n                    \"id\": \"A-100\",\n                    \"status\": \"created\",\n                    \"lines\": [\n                      {\"sku\": \"coffee\", \"quantity\": 1},\n                      {\"sku\": \"tea\", \"quantity\": 2}\n                    ]\n                  }\n                }\n                \"\"\");\n\n        JSONPath.of(\"$.order.status\").set(document, \"paid\");\n        JSONPath.of(\"$.order.lines[0].quantity\").set(document, 3);\n\n        JSONObject order = document.getJSONObject(\"order\");\n        JSONArray lines = order.getJSONArray(\"lines\");\n        assertThat(order.getString(\"status\")).isEqualTo(\"paid\");\n        assertThat(lines.getJSONObject(0).getIntValue(\"quantity\")).isEqualTo(3);\n        assertThat(lines.getJSONObject(1).getIntValue(\"quantity\")).isEqualTo(2);\n    }\n}\n"}
