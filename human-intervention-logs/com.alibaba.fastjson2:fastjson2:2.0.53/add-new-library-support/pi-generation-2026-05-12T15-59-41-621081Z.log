\"order\": {\n                    \"id\": \"A-100\",\n                    \"status\": \"created\",\n                    \"lines\": [\n                      {\"sku\": \"coffee\", \"quantity\": 1},\n                      {\"sku\": \"tea\", \"quantity\": 2}\n                    ]\n                  }\n                }\n                \"\"\");\n\n        JSONPath.of(\"$.order.status\").set(document, \"paid\");\n        JSONPath.of(\"$.order.lines[0].quantity\").set(document, 3);\n\n        JSONObject order = document.getJSONObject(\"order\");\n        JSONArray lines = order.getJSONArray(\"lines\");\n        assertThat(order.getString(\"status\")).isEqualTo(\"paid\");\n        assertThat(lines.getJSONObject(0).getIntValue(\"quantity\")).isEqualTo(3);\n        assertThat(lines.getJSONObject(1).getIntValue(\"quantity\")).isEqualTo(2);\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 677, "output": 1354, "cacheRead": 8704, "cacheWrite": 0, "totalTokens": 10735, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778601554892, "responseId": "resp_02f810402655cb01016a034e53884481a3bb12831358b84d9d"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_ECaMAAszmZJYxS5YC4oAfg5x|fc_02f810402655cb01016a034e5f333881a3812e36a1157efa80", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2202 bytes to tests/src/com.alibaba.fastjson2/fastjson2/2.0.53/src/test/java/com_alibaba_fastjson2/fastjson2/Fastjson2Test.java"}], "isError": false, "timestamp": 1778601571660}]}
