      {\"sku\": \"tea\", \"quantity\": 2}\n                    ]\n                  }\n                }\n                \"\"\");\n\n        JSONObject order = document.getJSONObject(\"order\");\n        JSONArray lines = order.getJSONArray(\"lines\");\n\n        assertThat(order.getString(\"id\")).isEqualTo(\"A-100\");\n        assertThat(order.getBooleanValue(\"paid\")).isTrue();\n        assertThat(lines).hasSize(2);\n        assertThat(lines.getJSONObject(0).getString(\"sku\")).isEqualTo(\"coffee\");\n        assertThat(lines.getJSONObject(0).getIntValue(\"quantity\")).isOne();\n        assertThat(lines.getJSONObject(1).getString(\"sku\")).isEqualTo(\"tea\");\n        assertThat(lines.getJSONObject(1).getIntValue(\"quantity\")).isEqualTo(2);\n    }\n\n    @Test\n    void buildsMutableObjectAndArrayTrees() {\n        JSONObject order = JSONObject.of(\"id\", \"A-100\", \"status\", \"created\");\n        JSONArray lines = order.putArray(\"lines\");\n\n        lines.addObject()\n                .fluentPut(\"sku\", \"coffee\")\n                .fluentPut(\"quantity\", 1);\n        lines.addObject()\n                .fluentPut(\"sku\", \"tea\")\n                .fluentPut(\"quantity\", 2);\n        order.putObject(\"shipping\")\n                .fluentPut(\"city\", \"Prague\")\n                .fluentPut(\"priority\", true);\n        order.fluentPut(\"status\", \"paid\");\n\n        assertThat(order.getString(\"status\")).isEqualTo(\"paid\");\n        assertThat(order.getJSONArray(\"lines\")).hasSize(2);\n        assertThat(order.getJSONArray(\"lines\").getJSONObject(1).getString(\"sku\")).isEqualTo(\"tea\");\n        assertThat(order.getJSONObject(\"shipping\").getString(\"city\")).isEqualTo(\"Prague\");\n        assertThat(order.getJSONObject(\"shipping\").getBooleanValue(\"priority\")).isTrue();\n    }\n\n    @Test\n    void validatesJsonDocumentShape() {\n        assertThat(JSON.isValidObject(\"{\\\"name\\\":\\\"fastjson2\\\",\\\"features\\\":[\\\"parse\\\",\\\"validate\\\"]}\")).isTrue();\n        assertThat(JSON.isValidArray(\"[{\\\"name\\\":\\\"parse\\\"},{\\\"name\\\":\\\"validate\\\"}]\")).isTrue();\n        assertThat(JSON.isValidObject(\"[1,2,3]\")).isFalse();\n        assertThat(JSON.isValidArray(\"{\\\"name\\\":\\\"fastjson2\\\"}\")).isFalse();\n        assertThat(JSON.isValid(\"{\\\"unterminated\\\": true\")).isFalse();\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1171, "output": 1178, "cacheRead": 32768, "cacheWrite": 0, "totalTokens": 35117, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778601650330, "responseId": "resp_02f810402655cb01016a034eb361d481a3ae560f4ca4e1ec2d"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_oKwVW5yCGhudyHMkWlKVz4bq|fc_02f810402655cb01016a034eb8e43c81a3983ba337635358f2", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 3002 bytes to tests/src/com.alibaba.fastjson2/fastjson2/2.0.53/src/test/java/com_alibaba_fastjson2/fastjson2/Fastjson2Test.java"}], "isError": false, "timestamp": 1778601662697}]}
