     \"items\", JSONArray.of(\n                        JSONObject.of(\"sku\", \"book\", \"quantity\", 2),\n                        JSONObject.of(\"sku\", \"pen\", \"quantity\", 5)));\n\n        JSONPath customerName = JSONPath.of(\"$.customer.name\");\n        JSONPath firstQuantity = JSONPath.of(\"$.items[0].quantity\");\n        JSONPath items = JSONPath.of(\"$.items\");\n\n        assertThat(customerName.eval(order)).isEqualTo(\"Ada\");\n        assertThat(firstQuantity.eval(order)).isEqualTo(2);\n        assertThat(JSONPath.contains(order, \"$.items[1].sku\")).isTrue();\n\n        firstQuantity.setInt(order, 3);\n        JSONPath.setCallback(order, \"$.items[1].quantity\", value -> ((Number) value).intValue() + 1);\n        items.arrayAdd(order, JSONObject.of(\"sku\", \"notebook\", \"quantity\", 1));\n        boolean removedCustomerId = JSONPath.of(\"$.customer.id\").remove(order);\n\n        assertThat(firstQuantity.eval(order)).isEqualTo(3);\n        assertThat(JSONPath.eval(order, \"$.items[1].quantity\")).isEqualTo(6);\n        assertThat(JSONPath.eval(order, \"$.items[2].sku\")).isEqualTo(\"notebook\");\n        assertThat(removedCustomerId).isTrue();\n        assertThat(JSONPath.contains(order, \"$.customer.id\")).isFalse();\n    }\n"}]}
