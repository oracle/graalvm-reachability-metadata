[tool-call] delta {"path":"tests/src/com.alibaba.fastjson2/fastjson2/2.0.53/src/test/java/com_alibaba_fastjson2/fastjson2/Fastjson2Test.java","edits":[{"oldText":"import com.alibaba.fastjson2.JSONArray;\nimport com.alibaba.fastjson2.JSONObject;\nimport com.alibaba.fastjson2.JSONPath;\nimport com.alibaba.fastjson2.PropertyNamingStrategy;\n","newText":"import com.alibaba.fastjson2.JSONValidator;\nimport com.alibaba.fastjson2.PropertyNamingStrategy;\n"},{"oldText":"    @Test\n    void navigatesAndMutatesObjectGraphsWithJsonPath() {\n        JSONObject order = JSONObject.of(\n                \"customer\", JSONObject.of(\"id\", 7, \"name\", \"Ada\"),\n                \"items\", JSONArray.of(\n                        JSONObject.of(\"sku\", \"book\", \"quantity\", 2),\n                        JSONObject.of(\"sku\", \"pen\", \"quantity\", 5)));\n\n        JSONPath customerName = JSONPath.of(\"$.customer.name\");\n        JSONPath firstQuantity = JSONPath.of(\"$.items[0].quantity\");\n        JSONPath items = JSONPath.of(\"$.items\");\n\n        assertThat(customerName.eval(order)).isEqualTo(\"Ada\");\n        assertThat(firstQuantity.eval(order)).isEqualTo(2);\n        assertThat(JSONPath.contains(order, \"$.items[1].sku\")).isTrue();\n\n        firstQuantity.setInt(order, 3);\n        JSONPath.setCallback(order, \"$.items[1].quantity\", value -> ((Number) value).intValue() + 1);\n        items.arrayAdd(order, JSONObject.of(\"sku\", \"notebook\", \"quantity\", 1));\n        boolean removedCustomerId = JSONPath.of(\"$.customer.id\").remove(order);\n\n        assertThat(firstQuantity.eval(order)).isEqualTo(3);\n        assertThat(JSONPath.eval(order, \"$.items[1].quantity\")).isEqualTo(6);\n        assertThat(JSONPath.eval(order, \"$.items[2].sku\")).isEqualTo(\"notebook\");\n        assertThat(removedCustomerId).isTrue();\n        assertThat(JSONPath.contains(order, \"$.customer.id\")).isFalse();\n    }\n","newText":"    @Test\n    void validatesJsonDocumentsAndReportsTopLevelType() {\n        JSONValidator objectValidator = JSONValidator.from(\"{\\\"customer\\\":\\\"Ada\\\",\\\"items\\\":[1,2,3]}\");\n        JSONValidator arrayValidator = JSONValidator.fromUtf8(\"[true,false,null]\".getBytes());\n        JSONValidator scalarValidator = JSONValidator.from(\"42\");\n        JSONValidator invalidValidator = JSONValidator.from(\"{\\\"customer\\\":}\");\n\n        assertThat(objectValidator.validate()).isTrue();\n        assertThat(objectValidator.getType()).isEqualTo(JSONValidator.Type.Object);\n        assertThat(arrayValidator.validate()).isTrue();\n        assertThat(arrayValidator.getType()).isEqualTo(JSONValidator.Type.Array);\n        assertThat(scalarValidator.validate()).isTrue();\n        assertThat(scalarValidator.getType()).isEqualTo(JSONValidator.Type.Value);\n        assertThat(invalidValidator.validate()).isFalse();\n    }\n"}]}
