with:\n+          file-patterns: |\n+            - 'metadata/**/index.json'\n+\n+      - name: \"🔧 Setup Java\"\n+        if: steps.filter.outputs.changed == 'true'\n+        uses: actions/setup-java@v4\n+        with:\n+          distribution: 'graalvm'\n+          java-version: '21'\n+\n+      - name: \"🕸️ Populate matrix\"\n+        id: set-matrix\n+        if: steps.filter.outputs.changed == 'true'\n+        run: |\n+          ./gradlew generateChangedTestedVersionsMatrix -PbaseCommit=${{ github.event.pull_request.base.sha }} -PnewCommit=${{ github.event.pull_request.head.sha }}\n+\n+  test-new-library-versions:\n+    name: \"🧪 ${{ matrix.coordinates }} tested-version diff (GraalVM for JDK ${{ matrix.version }} @ ${{ matrix.os }})\"\n+    if: needs.get-changed-index-metadata.outputs.relevant-files-changed == 'true' && needs.get-changed-index-metadata.result == 'success' && needs.get-changed-index-metadata.outputs.none-found != 'true' && github.repository == 'oracle/graalvm-reachability-metadata'\n+    runs-on: ${{ matrix.os }}\n+    timeout-minutes: 480\n+    needs: get-changed-index-metadata\n+\n+    strategy:\n+      fail-fast: false\n+      matrix: ${{ fromJson(needs.get-changed-index-metadata.outputs.matrix) }}\n+    steps:\n+      - name: \"☁️ Checkout repository\"\n+        uses: actions/checkout@v4\n+        with:\n+          fetch-depth: 0\n+\n+      - name: \"🛠️ Setup latest native-build-tools snapshot\"\n+        uses: ./.github/actions/setup-native-build-tools\n+\n+      - name: \"🔧 Setup java\"\n+        uses: actions/setup-java@v4\n+        with:\n+          distribution: 'graalvm'\n+          java-version: '21'\n+\n+      - name: \"🔧 Download GraalVM for metadata testing\"\n+        uses: graalvm/setup-graalvm@v1\n+        with:\n+          distribution: 'graalvm'\n+          java-version: ${{ matrix.version }}\n+          set-java-home: 'false'\n+          native-image-job-reports: 'true'\n+          github-token: ${{ secrets.GITHUB_TOKEN }}\n+\n+      - name: \"Pull allowed docker images\"\n+        run: |\n+          ./gradlew pullAllowedDockerImages -Pcoordinates=${{ matrix.coordinates }}\n+\n+      - name: \"Disable docker networking\"\n+        run: bash ./.github/workflows/scripts/disable-docker.sh\n+\n+      - name: \"🔎 Check metadata files content\"\n+        run: |\n+          ./gradlew checkMetadataFiles -Pcoordinates=${{ matrix.coordinates }}\n+\n+      - name: \"🧪 Run '${{ matrix.coordinates }}' tests for newly added tested versions\"\n+        run: |\n+          GAV_COORDINATES=\"${{ matrix.coordinates }}\"\n+          VERSIONS_JSON='${{ toJson(matrix.versions) }}'\n+\n+          bash ./.github/workflows/scripts/run-consecutive-tests.sh \"$GAV_COORDINATES\" \"$VERSIONS_JSON\" 2>&1 | tee test_results.txt || true\n+\n+          if grep -q \"^FAILED\" test_results.txt; then\n+            FAILED_VERSION=$(grep \"^FAILED\" test_results.txt | head -n 1 | awk -F'[][]' '{print $4}')\n+            echo \"Tests failed for version $FAILED_VERSION\"\n+            exit 1\n+          fi\n+\n+  all-new-library-version-tests-passed:\n+    name: \"🧪 All new library version tests have passed\"\n+    runs-on: \"ubuntu-22.04\"\n+    timeout-minutes: 1\n+    needs: [get-changed-index-metadata, test-new-library-versions]\n+    if: always()\n+    steps:\n+      - name: \"All tests passed\"\n+        if: needs.test-new-library-versions.result == 'success' || needs.get-changed-index-metadata.outputs.relevant-files-changed == 'false'\n+        run: exit 0\n+\n+      - name: \"Some tests failed\"\n+        if: needs.test-new-library-versions.result == 'failure'\n+        run: exit 1\ndiff --git a/ci.json b/ci.json\nindex fcd207d89d..2427fd99e2 100644\n--- a/ci.json\n+++ b/ci.json\n@@ -20,6 +20,10 @@\n     \"java\": [\"25\", \"latest-ea\"],\n     \"os\": [\"ubuntu-latest\"]\n   },\n+  \"generateChangedTestedVersionsMatrix\": {\n+    \"java\": [\"25\", \"latest-ea\"],\n+    \"os\": [\"ubuntu-latest\"]\n+  },\n   \"generateAffectedSpringTestMatrix\": {\n     \"java-branch-mapping\": {\n       \"main\": \"25\"\ndiff --git a/tests/tck-build-logic/src/main/groovy/org.graalvm.internal.tck-harness.gradle b/tests/tck-build-logic/src/main/groovy/org.graalvm.internal.tck-harness.gradle\nindex d97e8e4094..8647fbbceb 100644\n--- a/tests/tck-build-logic/src/main/groovy/org.graalvm.internal.tck-harness.gradle\n+++ b/tests/tck-build-logic/src/main/groovy/org.graalvm.internal.tck-harness.gradle\n@@ -257,6 +257,32 @@ List<Map<String, Object>> expandNewLibraryVersionCompatibilityMatrix(List<Map<St\n     include\n }\n \n+List<Map<String, Object>> expandChangedTestedVersionsMatrix(List<Map<String, Object>> entries) {\n+    def defaults = matrixDefaultsFor(\"generateChangedTestedVersionsMatrix\")\n+    List<String> javaVersions = defaults[\"version\"]\n+    List<String> operatingSystems = defaults[\"os\"]\n+\n+    List<Map<String, Object>> include = []\n+    entries.each { Map<String, Object> entry ->\n+        List<Map<String, Object>> matrixEntries = entry.containsKey(\"entries\")\n+                ? (entry[\"entries\"] as List<Map<String, Object>>)\n+                : [entry]\n+        matrixEntries.each { Map<String, Object> matrixEntry ->\n+            javaVersions.each { String javaVersion ->\n+                operatingSystems.each { String operatingSystem ->\n+                    include.add([\n+                            \"coordinates\": matrixEntry[\"coordinates\"],\n+                            \"versions\": matrixEntry[\"versions\"],\n+                            \"version\": javaVersion,\n+                            \"os\": operatingSystem\n+                    ])\n+                }\n+            }\n+        }\n+    }\n+    include\n+}\n+\n // gradle generateMatrixMatchingCoordinates -Pcoordinates=<maven-coordinates>\n Provider<Task> generateMatrixMatchingCoordinates = tasks.register(\"generateMatrixMatchingCoordinates\", DefaultTask) { task ->\n     task.setDescription(\"Returns matrix definition populated with all matching coordinates\")\n@@ -312,6 +338,31 @@ Provider<Task> generateChangedCoordinatesMatrix = tasks.register(\"generateChange\n     }\n }\n \n+// gradle generateChangedTestedVersionsMatrix -PbaseCommit=<base-commit> -PnewCommit=<new-commit>\n+Provider<Task> generateChangedTestedVersionsMatrix = tasks.register(\"generateChangedTestedVersionsMatrix\", DefaultTask) { task ->\n+    task.setDescription(\"Returns matrix definition populated with artifact coordinates and newly added tested versions from changed metadata index files\")\n+    task.setGroup(METADATA_GROUP)\n+    task.doFirst {\n+        if (!project.hasProperty(\"baseCommit\")) {\n+            throw new GradleException(\"Missing 'baseCommit' property! Rerun Gradle with '-PbaseCommit=<commit-hash>'\")\n+        }\n+\n+        String base = project.property(\"baseCommit\")\n+        String head = project.findProperty(\"newCommit\") ?: \"HEAD\"\n+        List<Map<String, Object>> changedIndexEntries = tck.diffIndexTestedVersions(base, head)\n+\n+        boolean noneFound = changedIndexEntries.isEmpty()\n+        List<Map<String, Object>> include = noneFound ? [] : expandChangedTestedVersionsMatrix(changedIndexEntries)\n+        def matrix = [include: include]\n+        if (noneFound) {\n+            println \"No changed metadata index tested-version additions were found!\"\n+        }\n+\n+        writeGithubOutput(\"matrix\", JsonOutput.toJson(matrix))\n+        writeGithubOutput(\"none-found\", noneFound.toString())\n+    }\n+}\n+\n // gradle generateChangedCoordinatesOnlyMatrix -PbaseCommit=<base-commit> -PnewCommit=<new-commit>\n Provider<Task> generateChangedCoordinatesOnlyMatrix = tasks.register(\"generateChangedCoordinatesOnlyMatrix\", DefaultTask) { task ->\n     task.setDescription(\"Returns a coordinate-only matrix definition populated with changed coordinates\")\n","exit_code":0,"status":"completed"}}
