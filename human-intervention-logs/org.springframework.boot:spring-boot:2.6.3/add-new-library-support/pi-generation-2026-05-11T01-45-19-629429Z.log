[tool-call] delta {"path":"tests/src/org.springframework.boot/spring-boot/2.6.3/src/test/java/org_springframework_boot/spring_boot/JavaBeanBinderInnerBeanPropertyTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_springframework_boot.spring_boot;\n\nimport org.junit.jupiter.api.Test;\n\nimport org.springframework.boot.context.properties.bind.BindResult;\nimport org.springframework.boot.context.properties.bind.Bindable;\nimport org.springframework.boot.context.properties.bind.Binder;\nimport org.springframework.boot.context.properties.source.MapConfigurationPropertySource;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class JavaBeanBinderInnerBeanPropertyTest {\n\n    @Test\n    void bindsNestedJavaBeanFromExistingValueUsingBeanPropertyAccessors() {\n        MapConfigurationPropertySource source = new MapConfigurationPropertySource();\n        source.put(\"sample.nested.name\", \"spring\");\n        source.put(\"sample.description\", \"boot\");\n        Binder binder = new Binder(source);\n        RootProperties existing = new RootProperties();\n\n        BindResult<RootProperties> bindResult = binder.bind(\"sample\", Bindable.ofInstance(existing));\n\n        assertThat(bindResult.isBound()).isTrue();\n        RootProperties bound = bindResult.get();\n        assertThat(bound).isSameAs(existing);\n        assertThat(bound.getDescription()).isEqualTo(\"boot\");\n        assertThat(bound.getNested()).isNotNull();\n        assertThat(bound.getNested().getName()).isEqualTo(\"spring\");\n    }\n\n    public static final class RootProperties {\n\n        private String description;\n\n        private NestedProperties nested;\n\n        public String getDescription() {\n            return this.description;\n        }\n\n        public void setDescription(String description) {\n            this.description = description;\n        }\n\n        public NestedProperties getNested() {\n            return this.nested;\n        }\n\n        public void setNested(NestedProperties nested) {\n            this.nested = nested;\n        }\n\n    }\n\n    public static final class NestedProperties {\n\n        private String name;\n\n        public String getName() {\n            return this.name;\n        }\n\n        public void setName(String name) {\n            this.name = name;\n        }\n\n    }\n\n}\n"}
