  package org_springframework_boot.spring_boot;
  
  import org.junit.jupiter.api.Test;
  
  import org.springframework.boot.SpringApplication;
  import org.springframework.context.ApplicationContext;
  import org.springframework.context.support.GenericApplicationContext;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class BeanDefinitionLoaderTest {
  
      @Test
      void loadsClassSourceAsBeanDefinition() {
          try (GenericApplicationContext context = new GenericApplicationContext()) {
              new TestSpringApplication().loadInto(context, CandidateConfiguration.class);
  
              assertThat(context.containsBeanDefinition("beanDefinitionLoaderTest.CandidateConfiguration")).isTrue();
          }
      }
  
      @Test
      void loadsPackageSourceByFindingClassInPackage() {
          try (GenericApplicationContext context = new GenericApplicationContext()) {
              new TestSpringApplication().loadInto(context, "org.springframework.boot.admin");
  
              assertThat(Package.getPackage("org.springframework.boot.admin")).isNotNull();
          }
      }
  
      public static final class CandidateConfiguration {
  
          public CandidateConfiguration() {
          }
  
      }
  
      private static final class TestSpringApplication extends SpringApplication {
  
          void loadInto(ApplicationContext context, Object... sources) {
              load(context, sources);
          }
  
      }
  
  }
