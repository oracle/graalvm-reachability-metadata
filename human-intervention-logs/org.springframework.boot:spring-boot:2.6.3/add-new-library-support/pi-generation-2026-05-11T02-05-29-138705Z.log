  package org_springframework_boot.spring_boot;
  
  import java.util.Optional;
  
  import org.junit.jupiter.api.Test;
  
  import org.springframework.boot.SpringApplication;
  import org.springframework.context.ApplicationListener;
  import org.springframework.context.event.ContextRefreshedEvent;
  import org.springframework.context.support.GenericApplicationContext;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ClearCachesApplicationListenerTest {
  
      @Test
      void clearsContextClassLoaderCacheWhenContextIsRefreshed() {
          ClassLoader previousClassLoader = Thread.currentThread().getContextClassLoader();
          CacheClearingClassLoader cacheClearingClassLoader = new CacheClearingClassLoader();
          ApplicationListener<ContextRefreshedEvent> listener = getClearCachesApplicationListener();
          GenericApplicationContext context = new GenericApplicationContext();
          try {
              Thread.currentThread().setContextClassLoader(cacheClearingClassLoader);
  
              listener.onApplicationEvent(new ContextRefreshedEvent(context));
          }
          finally {
              Thread.currentThread().setContextClassLoader(previousClassLoader);
              context.close();
          }
  
          assertThat(cacheClearingClassLoader.isCacheCleared()).isTrue();
      }
  
      private static ApplicationListener<ContextRefreshedEvent> getClearCachesApplicationListener() {
          SpringApplication application = new SpringApplication(TestApplication.class);
          Optional<ApplicationListener<?>> listener = application.getListeners().stream()
                  .filter(candidate -> candidate.getClass().getName()
                          .equals("org.springframework.boot.ClearCachesApplicationListener"))
                  .findFirst();
          assertThat(listener).isPresent();
          return asContextRefreshedEventListener(listener.get());
      }
  
      @SuppressWarnings("unchecked")
      private static ApplicationListener<ContextRefreshedEvent> asContextRefreshedEventListener(
              ApplicationListener<?> listener) {
          return (ApplicationListener<ContextRefreshedEvent>) listener;
      }
  
      public static final class TestApplication {
  
          public TestApplication() {
          }
  
      }
  
      public static final class CacheClearingClassLoader extends ClassLoader {
  
          private boolean cacheCleared;
  
          CacheClearingClassLoader() {
              super(null);
          }
  
          public void clearCache() {
              this.cacheCleared = true;
          }
  
          boolean isCacheCleared() {
              return this.cacheCleared;
          }
  
      }
  
  }
