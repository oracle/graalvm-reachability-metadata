[tool-call] delta {"path":"tests/src/org.springframework.boot/spring-boot/2.6.3/src/test/java/org_springframework_boot/spring_boot/ConfigurationPropertiesBindConstructorProviderTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_springframework_boot.spring_boot;\n\nimport org.junit.jupiter.api.Test;\n\nimport org.springframework.boot.context.properties.ConfigurationProperties;\nimport org.springframework.boot.context.properties.ConfigurationPropertiesBean;\nimport org.springframework.boot.context.properties.ConstructorBinding;\nimport org.springframework.context.support.GenericApplicationContext;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ConfigurationPropertiesBindConstructorProviderTest {\n\n    @Test\n    void detectsTypeLevelConstructorBindingAsValueObject() {\n        try (GenericApplicationContext context = new GenericApplicationContext()) {\n            ConstructorBoundProperties properties = new ConstructorBoundProperties(\"spring\");\n\n            ConfigurationPropertiesBean bean = ConfigurationPropertiesBean.get(context, properties,\n                    \"constructorBoundProperties\");\n\n            assertThat(bean).isNotNull();\n            assertThat(bean.getBindMethod()).isEqualTo(ConfigurationPropertiesBean.BindMethod.VALUE_OBJECT);\n            assertThat(bean.getInstance()).isSameAs(properties);\n        }\n    }\n\n    @ConstructorBinding\n    @ConfigurationProperties(\"sample\")\n    public static final class ConstructorBoundProperties {\n\n        private final String name;\n\n        public ConstructorBoundProperties(String name) {\n            this.name = name;\n        }\n\n        public String getName() {\n            return this.name;\n        }\n\n    }\n\n}\n"}
