  import org.springframework.context.ApplicationContext;
  import org.springframework.context.support.GenericApplicationContext;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class BeanDefinitionLoaderTest {
  
      @Test
      void loadsClassSourceAsBeanDefinition() {
          try (GenericApplicationContext context = new GenericApplicationContext()) {
              new TestSpringApplication().loadInto(context, CandidateConfiguration.class);
  
              assertThat(context.containsBeanDefinition("beanDefinitionLoaderTest.CandidateConfiguration")).isTrue();
          }
      }
  
