      void loadsPackageSourceByFindingClassInPackage() {
          try (GenericApplicationContext context = new GenericApplicationContext()) {
              new TestSpringApplication().loadInto(context, "org.springframework.boot.admin");
  
              assertThat(Package.getPackage("org.springframework.boot.admin")).isNotNull();
          }
      }
  
      public static final class CandidateConfiguration {
  
          public CandidateConfiguration() {
          }
  
      }
  
      private static final class TestSpringApplication extends SpringApplication {
  
          void loadInto(ApplicationContext context, Object... sources) {
              load(context, sources);
          }
  
      }
  
  }
