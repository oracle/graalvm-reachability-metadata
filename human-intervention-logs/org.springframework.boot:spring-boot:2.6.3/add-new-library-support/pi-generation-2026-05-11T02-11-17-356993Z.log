[tool-call] delta {"path":"tests/src/org.springframework.boot/spring-boot/2.6.3/src/test/java/org_springframework_boot/spring_boot/LoggingSystemTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_springframework_boot.spring_boot;\n\nimport org.junit.jupiter.api.Test;\n\nimport org.springframework.boot.logging.LogLevel;\nimport org.springframework.boot.logging.LoggingSystem;\nimport org.springframework.boot.logging.java.JavaLoggingSystem;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class LoggingSystemTest {\n\n    @Test\n    void createsConfiguredLoggingSystemFromSystemProperty() {\n        String previousLoggingSystem = System.getProperty(LoggingSystem.SYSTEM_PROPERTY);\n        try {\n            System.setProperty(LoggingSystem.SYSTEM_PROPERTY, JavaLoggingSystem.class.getName());\n\n            ClassLoader classLoader = LoggingSystemTest.class.getClassLoader();\n            LoggingSystem loggingSystem = LoggingSystem.get(classLoader);\n\n            assertThat(loggingSystem).isInstanceOf(JavaLoggingSystem.class);\n            assertThat(loggingSystem.getSupportedLogLevels()).contains(LogLevel.INFO, LogLevel.ERROR);\n        }\n        finally {\n            restoreLoggingSystemProperty(previousLoggingSystem);\n        }\n    }\n\n    private static void restoreLoggingSystemProperty(String previousLoggingSystem) {\n        if (previousLoggingSystem != null) {\n            System.setProperty(LoggingSystem.SYSTEM_PROPERTY, previousLoggingSystem);\n        }\n        else {\n            System.clearProperty(LoggingSystem.SYSTEM_PROPERTY);\n        }\n    }\n\n}\n"}
