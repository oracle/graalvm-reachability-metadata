  import org.springframework.boot.SpringApplication;
  import org.springframework.boot.WebApplicationType;
  
  import static org.assertj.core.api.Assertions.assertThatThrownBy;
  
  public class FailureAnalyzersTest {
  
      @Test
      void loadsFailureAnalyzersWhenApplicationRunFails() {
          SpringApplication application = new SpringApplication(TestApplication.class);
          application.setBannerMode(Banner.Mode.OFF);
          application.setLogStartupInfo(false);
          application.setWebApplicationType(WebApplicationType.NONE);
          application.addInitializers(context -> {
              throw new IllegalStateException("planned startup failure");
          });
  
          assertThatThrownBy(application::run).isInstanceOf(IllegalStateException.class)
                  .hasMessage("planned startup failure");
      }
  
      public static final class TestApplication {
  
          public TestApplication() {
          }
  
      }
  
  }
