   199: 					//": WARNING -- Expected writable property '" + propertyName + "' left at default value");
   200: 					if (logger.isLoggable( MLevel.WARNING ))
   201: 					    logger.warning(this.getClass().getName() + " -- Expected writable property '" + propertyName + "' left at default value");
   202: 				    }
