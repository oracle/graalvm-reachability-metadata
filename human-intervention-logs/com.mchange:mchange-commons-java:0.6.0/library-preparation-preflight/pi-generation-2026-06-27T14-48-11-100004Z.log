   139: 		String type = (String) ii.next();
   140: 		if (logger.isLoggable( MLevel.WARNING ))
   141: 		    logger.warning(this.getClass().getName() + " -- RefAddr for unknown property: " + type);
   142: 	    }
   143: 	return out;
   144:     }
   145: 
   146:     protected void handleDeserializeBinaryRefAddressContent( String propertyName, Map out, byte[] content ) throws ClassNotFoundException, IOException
   147:     {
   148:         if ( logger.isLoggable( MLevel.WARNING ) )
   149:             logger.log(
   150:                 MLevel.WARNING,
   151:                 "Deserialization of BinaryRefAddr contents interpreted as Java-Serialized objects has been disabled. " +
   152:                 "The functionality still exists, but to restore it you must define your own subclass of " +
   153:                 this.getClass().getName() +
   154:                 "and override 'protected void handleDeserializeBinaryRefAddressContent( String propertyName, Map out, byte[] content ) throws ClassNotFoundException, IOException' " +
   155:                 "to call 'dangerousDeserializeBinaryRefAddressContent( propertyName, out, content )' rather than merely log this warning. " +
   156:                 "For now, property '" + propertyName + "' will be skipped. " +
   157:                 "It will take its default value upon construction and not be updated from the reference."
   158:             );
   159:     }
   160: 
   161:     protected void dangerousDeserializeBinaryRefAddressContent( String propertyName, Map out, byte[] content ) throws ClassNotFoundException, IOException
   162:     {
   163: 	out.put( propertyName, SerializableUtils.fromByteArray( content ) ); //this will handle "indirectly serialized" objects.
   164:     }
   165: 
   166:     protected Object createBlankInstance(Class beanClass) throws Exception
   167:     { return beanClass.newInstance(); }
   168: 
   169:     protected Object findBean(Class beanClass, Map propertyMap, Set refProps ) throws Exception
   170:     {
   171: 	Object bean = createBlankInstance( beanClass );
   172: 	BeanInfo bi = Introspector.getBeanInfo( bean.getClass() );
   173: 	PropertyDescriptor[] pds = bi.getPropertyDescriptors();
   174: 
   175: 	for (int i = 0, len = pds.length; i < len; ++i)
   176: 	    {
   177: 		PropertyDescriptor pd = pds[i];
   178: 		String propertyName = pd.getName();
   179: 		Object value = propertyMap.get( propertyName );
   180: 		Method setter = pd.getWriteMethod();
   181: 		if (value != null)
   182: 		    {
   183: 			if (setter != null)
   184: 			    setter.invoke( bean, new Object[] { (value == NULL_TOKEN ? null : value) } );
   185: 			else
   186: 			    {
   187: 				//System.err.println(this.getClass().getName() + ": Could not restore read-only property '" + propertyName + "'.");
   188: 				if (logger.isLoggable( MLevel.WARNING ))
   189: 				    logger.warning(this.getClass().getName() + ": Could not restore read-only property '" + propertyName + "'.");
   190: 			    }
   191: 		    }
   192: 		else
   193: 		    {
   194: 			if (setter != null)
   195: 			    {
   196: 				if (refProps == null || refProps.contains( propertyName ))
   197: 				    {
   198: 					//System.err.println(this.getClass().getName() +
   199: 					//": WARNING -- Expected writable property '" + propertyName + "' left at default value");
   200: 					if (logger.isLoggable( MLevel.WARNING ))
   201: 					    logger.warning(this.getClass().getName() + " -- Expected writable property '" + propertyName + "' left at default value");
   202: 				    }
   203: 			    }
   204: 		    }
   205: 	    }
   206: 
   207: 	return bean;
   208:     }
   209: }
  
