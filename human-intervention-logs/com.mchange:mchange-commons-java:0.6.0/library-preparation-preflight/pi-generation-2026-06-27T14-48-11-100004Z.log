   333:     public static ExtractRec extractNestedReference(Reference extractFrom, int index)
   334: 	throws NamingException
   335:     {
   336: 	try
   337: 	    {
   338: 		int version = Integer.parseInt((String) extractFrom.get(index++).getContent());
   339: 		if (version == 1)
   340: 		    {
   341: 			String className = (String) extractFrom.get(index++).getContent();
   342: 			String factoryClassName = (String) extractFrom.get(index++).getContent();
   343: 			String factoryClassLocation = (String) extractFrom.get(index++).getContent();
   344: 
   345: 			Reference outRef = new Reference( className,
   346: 							  factoryClassName,
   347: 							  factoryClassLocation );
   348: 			int size = Integer.parseInt((String) extractFrom.get(index++).getContent());
   349: 			for (int i = 0; i < size; ++i)
   350: 			    outRef.add( extractFrom.get( index++ ) );
   351: 			return new ExtractRec( outRef, index );
   352: 		    }
   353: 		else
   354: 		    throw new NamingException("Bad version of nested reference!!!");
   355: 	    }
   356: 	catch (NumberFormatException e)
   357: 	    {
   358: 		if (Debug.DEBUG)
   359: 		    {
   360: 			//e.printStackTrace();
   361: 			if ( logger.isLoggable( MLevel.FINE ) )
   362: 			    logger.log( MLevel.FINE, "Version or size nested reference was not a number!!!", e);
   363: 		    }
   364: 		throw new NamingException("Version or size nested reference was not a number!!!");
   365: 	    }
   366:     }
