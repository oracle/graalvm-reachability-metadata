6HMxcQHrTVBsopVgkf3pIOn|fc_0e1db2ae7ab5491e016a3fe29c1c288196bf09eaa213f5c8a4", "name": "bash", "arguments": {"command": "python3 - <<'PY'\nimport zipfile\nsrc='/tmp/mchange-commons-java-0.6.0-sources.jar'\nfor path in ['com/mchange/v2/naming/ReferenceableUtils.java','com/mchange/v2/naming/JavaBeanReferenceMaker.java','com/mchange/v2/naming/JavaBeanObjectFactory.java','com/mchange/v2/naming/SecurityConfigKey.java','com/mchange/v2/cfg/MConfig.java']:\n  print('\\n===== '+path+' =====')\n  with zipfile.ZipFile(src) as z:\n    data=z.read(path).decode('utf-8','replace').splitlines()\n    if path.endswith('ReferenceableUtils.java'):\n      ranges=[(1,120),(330,475)]\n    else:\n      ranges=[(1,min(len(data),260))]\n    for a,b in ranges:\n      for i in range(a,b+1):\n        if i<=len(data): print(f'{i:4}: {data[i-1]}')\nPY", "timeout": 10}}, {"type": "toolCall", "id": "call_uPmPmfrFm8p4echfZuhvMpeC|fc_0e1db2ae7ab5491e016a3fe29c1c3c8196bed4f9c62b92dc83", "name": "bash", "arguments": {"command": "python3 - <<'PY'\nimport urllib.request\nfor u in [\n 'https://raw.githubusercontent.com/swaldman/mchange-commons-java/mchange-commons-java-0.6.0/README.md',\n 'https://raw.githubusercontent.com/swaldman/mchange-commons-java/v0.6.0/README.md',\n 'https://raw.githubusercontent.com/swaldman/mchange-commons-java/master/README.md'\n]:\n    try:\n        print('URL',u)\n        print(urllib.request.urlopen(u, timeout=10).read().decode()[:4000])\n    except Exception as e: print('ERR',e)\nPY", "timeout": 40}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 6426, "output": 832, "cacheRead": 30720, "cacheWrite": 0, "totalTokens": 37978, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1782571664676, "responseId": "resp_0e1db2ae7ab5491e016a3fe29143f88196825a444cc11a6c9d"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_46HMxcQHrTVBsopVgkf3pIOn|fc_0e1db2ae7ab5491e016a3fe29c1c288196bf09eaa213f5c8a4", "toolName": "bash", "content": [{"type": "text", "text": "\n===== com/mchange/v2/naming/ReferenceableUtils.java =====\n   1: package com.mchange.v2.naming;\n   2: \n   3: import java.net.*;\n   4: import java.util.*;\n   5: import javax.naming.*;\n   6: import java.lang.reflect.Constructor;\n   7: import java.lang.reflect.InvocationTargetException;\n   8: import com.mchange.v2.cfg.PropertiesConfig;\n   9: import com.mchange.v2.log.MLevel;\n  10: import com.mchange.v2.log.MLog;\n  11: import com.mchange.v2.log.MLogger;\n  12: import com.mchange.v2.util.IterableUtils;\n  13: import javax.naming.spi.ObjectFactory;\n  14: \n  15: public final class ReferenceableUtils\n  16: {\n  17: \n  18:     final static MLogger logger = MLog.getLogger( ReferenceableUtils.class );\n  19: \n  20:     /* don't worry -- References can have duplicate RefAddrs (I think!) */\n  21:     final static String REFADDR_VERSION                = \"version\";\n  22:     final static String REFADDR_CLASSNAME              = \"classname\";\n  23:     final static String REFADDR_FACTORY                = \"factory\";\n  24:     final static String REFADDR_FACTORY_CLASS_LOCATION = \"factoryClassLocation\";\n  25:     final static String REFADDR_SIZE                   = \"size\";\n  26: \n  27:     final static int CURRENT_REF_VERSION = 1;\n  28: \n  29:     // This set is a special case, a token.\n  30:     //\n  31:     // Semantically, it does not mean empty set (which would imply nothing passes the white list),\n  32:     // but it means NO WHITELIST, any factoryClassName is accepted.\n  33:     //\n  34:     // It is and must be tested by reference identity, not semantic equality\n  35:     public final static Set ALL_FACTORY_CLASS_NAMES = Collections.unmodifiableSet(new HashSet());\n  36: \n  37:     private final static Set ACCEPT_ANY_WHITELIST;\n  38:     static\n  39:     {\n  40:         Set tmp = new HashSet();\n  41:         tmp.add(\"*\");\n  42:         ACCEPT_ANY_WHITELIST = Collections.unmodifiableSet(tmp);\n  43:     }\n  44: \n  45:     /**\n  46:      * A null string value in a Reference sometimes goes to the literal\n  47:      * \"null\". Sigh. We convert this string to a Java null.\n  48:      */\n  49:     public static String literalNullToNull( String s )\n  50:     {\n  51: \tif (s == null || \"null\".equals( s ))\n  52: \t    return null;\n  53: \telse\n  54: \t    return s;\n  55:     }\n  56: \n  57:     public static Object referenceToObject( Reference ref, Name name, Context nameCtx, Hashtable env )\n  58: \tthrows NamingException\n  59:     { return referenceToObject( ref, name, nameCtx, env, (PropertiesConfig) null ); }\n  60: \n  61:     public static Object referenceToObject( Reference ref, Name name, Context nameCtx, Hashtable env, PropertiesConfig pcfg )\n  62: \tthrows NamingException\n  63:     {\n  64:         Set allowedFactoryClassNames = findMandatoryObjectFactoryWhitelist( pcfg );\n  65:         return referenceToObject( ref, name, nameCtx, env, allowedFactoryClassNames, pcfg );\n  66:     }\n  67: \n  68:     /**\n  69:      * The allowedFactoryClassNames whitelist test can be (but generally should not be) circumvented by explicitly providing ReferenceUtils.ALL_FACTORY_CLASS_NAMES\n  70:      * as the argument allowedFactoryClassNames. allowedFactoryClassNames must not be null. (A NullPointerException will be provoked if it is.)\n  71:      */\n  72:     public static Object referenceToObject( Reference ref, Name name, Context nameCtx, Hashtable env, Set allowedFactoryClassNames )\n  73: \tthrows NamingException\n  74:     { return referenceToObject( ref, name, nameCtx, env, allowedFactoryClassNames, null ); }\n  75: \n  76:     /**\n  77:      * The allowedFactoryClassNames whitelist test can be (but generally should not be) circumvented by explicitly providing ReferenceUtils.ALL_FACTORY_CLASS_NAMES\n  78:      * as the argument allowedFactoryClassNames. allowedFactoryClassNames must not be null. (A NullPointerException will be provoked if it is.)\n  79:      */\n  80:     public static Object referenceToObject( Reference ref, Name name, Context nameCtx, Hashtable env, Set allowedFactoryClassNames, PropertiesConfig pcfg )\n  81: \tthrows NamingException\n  82:     {\n  83: \ttry\n  84: \t    {\n  85:                 // name and nameCtx are optional parameters. name can just be null\n  86:                 //\n  87:                 // this function isn't really a JNDI lookup, but we are erring on the side of\n  88:                 // conservatism with this stuff now.\n  89: \n  90:                 if (name != null) assertAcceptableName(name,pcfg);\n  91: \n  92: \t\tString fClassName = ref.getFactoryClassName();\n  93: \t\tString fClassLocation = ref.getFactoryClassLocation();\n  94: \n  95:                 // for now, we simply do not support null factoryClassName\n  96:                 //\n  97:                 // if ever there is a need to, we could adopt the behavior of, or delegate to, javax.naming.spi.NamingManager\n  98:                 // see https://docs.oracle.com/en/java/javase/11/docs/api/java.naming/javax/naming/spi/NamingManager.html\n  99:                 // but as this is likely legacy functionality, for now we'll just reject such References\n 100:                 if (fClassName == null)\n 101:                     throw new NamingException(\n 102:                         \"A null factoryClassName was encountered. ReferenceableUtils.referenceToObject(...) does not support null factory class names. \" +\n 103:                         \"If the null is intentional, consider using javax.naming.spi.NamingManager.getObjectInstance(...) \" +\n 104:                         \"which employs certain conventions to dereference with an unspecified factoryClassName. Reference: \" + ref\n 105:                     );\n 106: \n 107:                 // note that the test of reference identity, rather than semantic equality, against token ALL_FACTORY_CLASS_NAMES is essential!\n 108:                 if (allowedFactoryClassNames != ALL_FACTORY_CLASS_NAMES && !allowedFactoryClassNames.contains(fClassName))\n 109:                     throw new NamingException(\n 110:                         \"factoryClassName '\" + fClassName + \"' is not in allowedFactoryClassNames [\" + IterableUtils.joinAsString(\",\",allowedFactoryClassNames) + \"]\"\n 111:                     );\n 112: \n 113: \t\tClassLoader defaultClassLoader = Thread.currentThread().getContextClassLoader();\n 114: \t\tif ( defaultClassLoader == null ) defaultClassLoader = ReferenceableUtils.class.getClassLoader();\n 115: \n 116: \t\tClassLoader cl;\n 117: \t\tif ( fClassLocation == null )\n 118: \t\t    cl = defaultClassLoader;\n 119: \t\telse\n 120: \t\t    {\n 330:      *             references are Serializable and can be stored in a BinaryRefAddr.\n 331:      *             Oops.\n 332:      */\n 333:     public static ExtractRec extractNestedReference(Reference extractFrom, int index)\n 334: \tthrows NamingException\n 335:     {\n 336: \ttry\n 337: \t    {\n 338: \t\tint version = Integer.parseInt((String) extractFrom.get(index++).getContent());\n 339: \t\tif (version == 1)\n 340: \t\t    {\n 341: \t\t\tString className = (String) extractFrom.get(index++).getContent();\n 342: \t\t\tString factoryClassName = (String) extractFrom.get(index++).getContent();\n 343: \t\t\tString factoryClassLocation = (String) extractFrom.get(index++).getContent();\n 344: \n 345: \t\t\tReference outRef = new Reference( className,\n 346: \t\t\t\t\t\t\t  factoryClassName,\n 347: \t\t\t\t\t\t\t  factoryClassLocation );\n 348: \t\t\tint size = Integer.parseInt((String) extractFrom.get(index++).getContent());\n 349: \t\t\tfor (int i = 0; i < size; ++i)\n 350: \t\t\t    outRef.add( extractFrom.get( index++ ) );\n 351: \t\t\treturn new ExtractRec( outRef, index );\n 352: \t\t    }\n 353: \t\telse\n 354: \t\t    throw new NamingException(\"Bad version of nested reference!!!\");\n 355: \t    }\n 356: \tcatch (NumberFormatException e)\n 357: \t    {\n 358: \t\tif (Debug.DEBUG)\n 359: \t\t    {\n 360: \t\t\t//e.printStackTrace();\n 361: \t\t\tif ( logger.isLoggable( MLevel.FINE ) )\n 362: \t\t\t    logger.log( MLevel.FINE, \"Version or size nested reference was not a number!!!\", e);\n 363: \t\t    }\n 364: \t\tthrow new NamingException(\"Version or size nested reference was not a number!!!\");\n 365: \t    }\n 366:     }\n 367: \n 368:     private static Set commaSeparatedStringListToModifiableSet( String csList )\n 369:     {\n 370:         String[] items = csList.split(\"\\\\s*,\\\\s*\");\n 371:         return new HashSet(Arrays.asList(items));\n 372:     }\n 373: \n 374:     private static Set commaSeparatedStringListToSet( String csList )\n 375:     { return Collections.unmodifiableSet(commaSeparatedStringListToModifiableSet(csList)); }\n 376: \n 377:     /* intentionally package-scope, accessed by JavaBeanReferenceMaker */\n 378:     /* pcfg can be null */\n 379:     static void ensureWhitelistedJavaBeanClass( Object bean, PropertiesConfig pcfg ) throws NamingException\n 380:     { ensureWhitelistedJavaBeanClass( bean.getClass().getName(), pcfg ); }\n 381: \n 382:     private static boolean whitelistIsDisabled(Set whitelisted, PropertiesConfig pcfg, String whitelistKey)\n 383:     {\n 384:         if (!ACCEPT_ANY_WHITELIST.equals(whitelisted))\n 385:             return false;\n 386:         else if (pcfg == null) // if pcfg is null, the '*' whitelist was uniquely specified in System properties\n 387:             return true;\n 388:         else\n 389:         {\n 390:             String syspropsWhitelist = System.getProperty( whitelistKey );\n 391:             String pcfgWhitelist     = pcfg.getProperty( whitelistKey );\n 392:             if (syspropsWhitelist == null) // if syspropsWhitelist is null, the '*' whitelist was uniquely specified in pcfg\n 393:                 return true;\n 394:             else if (pcfgWhitelist == null) // if pcfgWhitelist is null, the '*' whitelist was uniquely specified in System properties\n 395:                 return true;\n 396:             else // the whitelist is specified in both places. make sure both are trying to disable enforcement\n 397:                 return\n 398:                     ACCEPT_ANY_WHITELIST.equals(commaSeparatedStringListToModifiableSet(syspropsWhitelist)) &&\n 399:                     ACCEPT_ANY_WHITELIST.equals(commaSeparatedStringListToModifiableSet(pcfgWhitelist));\n 400:         }\n 401:     }\n 402: \n 403:     private static boolean objectFactoryWhitelistIsDisabled(Set whitelisted, PropertiesConfig pcfg)\n 404:     { return whitelistIsDisabled(whitelisted,pcfg,SecurityConfigKey.OBJECT_FACTORY_WHITELIST); }\n 405: \n 406:     private static boolean javaBeanWhitelistIsDisabled(Set whitelisted, PropertiesConfig pcfg)\n 407:     { return whitelistIsDisabled(whitelisted,pcfg,SecurityConfigKey.REFERENCEABLE_JAVA_BEAN_CLASS_WHITELIST); }\n 408: \n 409:     /* intentionally package-scope, accessed by JavaBeanObjectFactory */\n 410:     /* pcfg can be null */\n 411:     static void ensureWhitelistedJavaBeanClass( String fqcn, PropertiesConfig pcfg ) throws NamingException\n 412:     {\n 413:         Set whitelisted = referenceableJavaBeanClassWhiteList( pcfg );\n 414:         if (whitelisted != null)\n 415:         {\n 416:             if (!javaBeanWhitelistIsDisabled(whitelisted, pcfg) && !whitelisted.contains(fqcn))\n 417:             {\n 418:                 StringBuilder sb = new StringBuilder();\n 419:                 boolean first = true;\n 420:                 for ( Object cn : whitelisted )\n 421:                 {\n 422:                     if (!first)\n 423:                         sb.append(\",\");\n 424:                     else\n 425:                         first = false;\n 426:                     sb.append(cn);\n 427:                 }\n 428:                 throw new NamingException(\n 429:                     \"The whitelist of acceptable JavaBeanClasses to which to create or look up references does not contain referenced class '\" + fqcn + \"'. \" +\n 430:                     \"Please add that class to comma-separated list at config key '\" + SecurityConfigKey.REFERENCEABLE_JAVA_BEAN_CLASS_WHITELIST + \"' if \" +\n 431:                     \"you wish for this reference to be created or resolved. \" +\n 432:                     \"(If this is unexpected, note that if you have set the whitelist in multiple places, only the INTERSECTION becomes whitelisted. \" +\n 433:                     \"Check for distinct whitelists in system properties and other config.) \" +\n 434:                     \"Current whitelist: \" + sb.toString() + \" -- \" + \"Missing class: \" + fqcn\n 435:                 );\n 436:             }\n 437:         }\n 438:         else\n 439:         {\n 440:             throw new NamingException(\n 441:                 \"No whitelist is set for referenceable java beans. This is dangerous. Please set '\" + SecurityConfigKey.REFERENCEABLE_JAVA_BEAN_CLASS_WHITELIST +\n 442:                 \"'. You are currently creating or dereferencing an object of class '\" + fqcn + \"'. If that is intended and desirable, please include it \" +\n 443:                 \"in the whitelist! (If this is unexpected, note that if you have set the whitelist in multiple places, only the INTERSECTION becomes whitelisted. \" +\n 444:                 \"Check for distinct whitelists in system properties and other config.) No classes are currently whitelisted. -- Missing class: \" + fqcn\n 445:             );\n 446:         }\n 447:     }\n 448: \n 449:     private static Set referenceableJavaBeanClassWhiteList( PropertiesConfig pcfg )\n 450:     {\n 451:         Set out = narrowestStringListPropertiesConfigSystemProperties( SecurityConfigKey.REFERENCEABLE_JAVA_BEAN_CLASS_WHITELIST, pcfg );\n 452:         if (out != null && out.size() == 0) return null;\n 453:         else return out;\n 454:     }\n 455: \n 456:     // pcfg can be null\n 457:     private static Set findMandatoryObjectFactoryWhitelist( PropertiesConfig pcfg ) throws NamingException\n 458:     {\n 459:         Set narrowest = narrowestStringListPropertiesConfigSystemProperties( SecurityConfigKey.OBJECT_FACTORY_WHITELIST, pcfg );\n 460:         if (narrowest == null)\n 461:             throw new NamingException(\n 462:                 \"No ObjectFactory whitelist found. \" +\n 463:                 \"When calling referenceToObject(...) using overloads that lack an explicit allowedFactoryClassNames Set, a '\" +\n 464:                 SecurityConfigKey.OBJECT_FACTORY_WHITELIST + \"' must be provided either as a System property or a provided com.mchange.v2.PropertiesConfig instance. \" +\n 465:                 \"If you really want to live dangerously and accept any ObjectFactory (why?!?), you may provide a whitelist with a unique entry of '*'.\"\n 466:             );\n 467:         if (objectFactoryWhitelistIsDisabled(narrowest,pcfg))\n 468:             return ALL_FACTORY_CLASS_NAMES;\n 469:         else\n 470:             return narrowest;\n 471:     }\n 472: \n 473:     // pcfg can be null\n 474:     private static Set narrowestStringListPropertiesConfigSystemProperties( String propStyleKey, PropertiesConfig pcfg )\n 475:     {\n\n===== com/mchange/v2/naming/JavaBeanReferenceMaker.java =====\n   1: package com.mchange.v2.naming;\n   2: \n   3: import java.beans.*;\n   4: import java.io.*;\n   5: import java.util.*;\n   6: import javax.naming.*;\n   7: import com.mchange.v2.log.*;\n   8: import java.lang.reflect.Method;\n   9: import com.mchange.v2.cfg.PropertiesConfig;\n  10: import com.mchange.v2.csv.FastCsvUtils;\n  11: import com.mchange.v2.lang.Coerce;\n  12: import com.mchange.v2.beans.BeansUtils;\n  13: import com.mchange.v2.ser.SerializableUtils;\n  14: import com.mchange.v2.ser.IndirectPolicy;\n  15: \n  16: public class JavaBeanReferenceMaker implements ReferenceMaker\n  17: {\n  18:     private final static MLogger logger = MLog.getLogger( JavaBeanReferenceMaker.class );\n  19: \n  20:     final static String REF_PROPS_KEY = \"com.mchange.v2.naming.JavaBeanReferenceMaker.REF_PROPS_KEY\";\n  21: \n  22:     final static Object[] EMPTY_ARGS = new Object[0];\n  23: \n  24:     final static byte[] NULL_TOKEN_BYTES = new byte[0];\n  25: \n  26:     String factoryClassName = \"com.mchange.v2.naming.JavaBeanObjectFactory\";\n  27:     String defaultFactoryClassLocation = null;\n  28: \n  29:     Set referenceProperties = new HashSet();\n  30: \n  31:     ReferenceIndirector indirector = new ReferenceIndirector();\n  32: \n  33:     JavaBeanReferencePropertyOverrider overrider = null;\n  34: \n  35:     protected boolean skipUnwritableProperties = false;\n  36: \n  37:     public Hashtable getEnvironmentProperties()\n  38:     { return indirector.getEnvironmentProperties(); }\n  39: \n  40:     public void setEnvironmentProperties( Hashtable environmentProperties )\n  41:     { indirector.setEnvironmentProperties( environmentProperties ); }\n  42: \n  43:     public void setReferencePropertyOverrider(JavaBeanReferencePropertyOverrider overrider)\n  44:     { this.overrider = overrider; }\n  45: \n  46:     public JavaBeanReferencePropertyOverrider getReferencePropertyOverrider()\n  47:     { return this.overrider; }\n  48: \n  49:     public void setFactoryClassName(String factoryClassName)\n  50:     { this.factoryClassName = factoryClassName; }\n  51: \n  52:     public String getFactoryClassName()\n  53:     { return factoryClassName; }\n  54: \n  55:     public String getDefaultFactoryClassLocation()\n  56:     { return defaultFactoryClassLocation; }\n  57: \n  58:     public void setDefaultFactoryClassLocation( String defaultFactoryClassLocation )\n  59:     { this.defaultFactoryClassLocation = defaultFactoryClassLocation; }\n  60: \n  61:     public void addReferenceProperty( String propName )\n  62:     { referenceProperties.add( propName ); }\n  63: \n  64:     public void removeReferenceProperty( String propName )\n  65:     { referenceProperties.remove( propName ); }\n  66: \n  67:     public Reference createReference( Object bean, PropertiesConfig pcfg )\n  68: \tthrows NamingException\n  69:     {\n  70: \ttry\n  71: \t    {\n  72:                 ReferenceableUtils.ensureWhitelistedJavaBeanClass( bean, pcfg );\n  73:                 Class beanClass = bean.getClass();\n  74: \t\tBeanInfo bi = Introspector.getBeanInfo( beanClass );\n  75: \t\tPropertyDescriptor[] pds = bi.getPropertyDescriptors();\n  76: \t\tList refAddrs = new ArrayList();\n  77: \t\tString factoryClassLocation = defaultFactoryClassLocation;\n  78: \n  79: \t\tboolean using_ref_props = referenceProperties.size() > 0;\n  80: \n  81: \t\t// we only include this so that on dereference we are not surprised to find some properties missing\n  82: \t\tif (using_ref_props)\n  83:                 {\n  84:                     String[] refPropsArray = new String[referenceProperties.size()];\n  85:                     referenceProperties.toArray(refPropsArray);\n  86:                     String refPropsAsCsvLine = FastCsvUtils.generateCsvLineQuotedUnterminated(refPropsArray);\n  87:                     //System.err.println(refPropsAsCsvLine);\n  88: \t\t    refAddrs.add( new StringRefAddr( REF_PROPS_KEY, refPropsAsCsvLine ) );\n  89:                 }\n  90: \n  91: \t\tfor (int i = 0, len = pds.length; i < len; ++i)\n  92: \t\t    {\n  93: \t\t\tPropertyDescriptor pd = pds[i];\n  94: \t\t\tString propertyName = pd.getName();\n  95: \t\t\t//System.err.println(\"Making Reference: \" + propertyName);\n  96: \n  97: \t\t\tif (using_ref_props && ! referenceProperties.contains( propertyName ))\n  98: \t\t\t    {\n  99: \t\t\t\t//System.err.println(\"Not a ref_prop -- continuing.\");\n 100: \t\t\t\tcontinue;\n 101: \t\t\t    }\n 102: \n 103: \t\t\tClass  propertyType = pd.getPropertyType();\n 104: \t\t\tMethod getter = pd.getReadMethod();\n 105: \t\t\tMethod setter = pd.getWriteMethod();\n 106: \t\t\tif (getter != null && setter != null) //only use properties that are both readable and writable\n 107: \t\t\t    {\n 108: \t\t\t\tObject val = getter.invoke( bean, EMPTY_ARGS );\n 109: \t\t\t\t//System.err.println( \"val: \" + val );\n 110: \t\t\t\tif (propertyName.equals(\"factoryClassLocation\"))\n 111: \t\t\t\t    {\n 112: \t\t\t\t\tif (String.class != propertyType)\n 113: \t\t\t\t\t    throw new NamingException(this.getClass().getName() + \" requires a factoryClassLocation property to be a string, \" +\n 114: \t\t\t\t\t\t\t\t      propertyType.getName() + \" is not valid.\");\n 115: \t\t\t\t\tfactoryClassLocation = (String) val;\n 116: \t\t\t\t    }\n 117: \n 118:                                 RefAddr addMe = null;\n 119: \t\t\t\tif (val == null)\n 120: \t\t\t\t    {\n 121: \t\t\t\t\taddMe = new BinaryRefAddr( propertyName, NULL_TOKEN_BYTES );\n 122: \t\t\t\t\trefAddrs.add( addMe );\n 123: \t\t\t\t    }\n 124:                                 else if (this.overrider != null && (addMe = this.overrider.overrideRefAddr(beanClass,pcfg,propertyName,propertyType,val)) != null)\n 125:                                     {\n 126: \t\t\t\t\trefAddrs.add( addMe );\n 127:                                     }\n 128: \t\t\t\telse if ( Coerce.canCoerce( propertyType ) )\n 129: \t\t\t\t    {\n 130: \t\t\t\t\taddMe = new StringRefAddr( propertyName, String.valueOf( val ) );\n 131: \t\t\t\t\trefAddrs.add( addMe );\n 132: \t\t\t\t    }\n 133: \t\t\t\telse  //other Object properties\n 134: \t\t\t\t    {\n 135: \t\t\t\t\tPropertyEditor pe = BeansUtils.findPropertyEditor( pd );\n 136: \t\t\t\t\tif (pe != null)\n 137: \t\t\t\t\t    {\n 138: \t\t\t\t\t\tpe.setValue( val );\n 139: \t\t\t\t\t\tString textValue = pe.getAsText();\n 140: \t\t\t\t\t\tif (textValue != null)\n 141: \t\t\t\t\t\t    addMe = new StringRefAddr( propertyName, textValue );\n 142: \t\t\t\t\t    }\n 143:                                         if ( addMe == null ) //property editor approach failed\n 144:                                             {\n 145:                                                 // note that it's the concrete class, not the declared bean type, that must be SecurelyStringified!\n 146:                                                 if ( SecurelyStringifiable.isSecurelyStringifiable( val.getClass() ) )\n 147:                                                     addMe = new StringRefAddr( propertyName, SecurelyStringifiable.securelyStringify( val ) );\n 148:                                             }\n 149: \t\t\t\t\tif (addMe == null) // all String-based approaches have failed\n 150:                                         {\n 151:                                             if (ReferenceableUtils.generateSerializedObjectBinaryRefAddr( pcfg ))\n 152:                                             {\n 153:                                                 addMe = new BinaryRefAddr( propertyName, SerializableUtils.toByteArray( val, \n 154:                                                                                                                         indirector, \n 155:                                                                                                                         IndirectPolicy.INDIRECT_ON_EXCEPTION ) );\n 156:                                             }\n 157:                                             else\n 158:                                             {\n 159:                                                 String baseMessage =\n 160:                                                     \"While creating a javax.naming.Reference to '\" +\n 161:                                                     bean +\n 162:                                                     \"', found a property of type '\" +\n 163:                                                     pd.getName() +\n 164:                                                     \"' and concrete class '\" + val.getClass().getName() +\n 165:                                                     \"' that cannot be embedded as a String or null. \" +\n 166:                                                     \"No other approach has worked, and embedding properties as Java Serialized objects is disabled.\";\n 167:                                                 if (skipUnwritableProperties)\n 168:                                                 {\n 169:                                                     if (logger.isLoggable(MLevel.WARNING))\n 170:                                                         logger.log(MLevel.WARNING, baseMessage + \" This property has been skipped, and will not be included in the generated reference!\");\n 171:                                                 }\n 172:                                                 else\n 173:                                                     throw new NamingException(baseMessage);\n 174:                                             }\n 175:                                         }\n 176:                                         if (addMe != null)\n 177:                                             refAddrs.add( addMe );\n 178: \t\t\t\t    }\n 179: \t\t\t    }\n 180: \t\t\telse\n 181: \t\t\t    {\n 182: // \t\t\t\tSystem.err.println(this.getClass().getName() +\n 183: // \t\t\t\t\t\t   \": Skipping \" + propertyName + \" because it is \" + (setter == null ? \"read-only.\" : \"write-only.\"));\n 184: \n 185: \t\t\t\tif ( logger.isLoggable( MLevel.WARNING ) )\n 186: \t\t\t\t    logger.warning(this.getClass().getName() + \": Skipping \" + propertyName + \n 187: \t\t\t\t\t\t   \" because it is \" + (setter == null ? \"read-only.\" : \"write-only.\"));\n 188: \t\t\t    }\n 189: \n 190: \t\t    }\n 191: \t\tReference out = new Reference( beanClass.getName(), factoryClassName, factoryClassLocation );\n 192: \t\tfor (Iterator ii = refAddrs.iterator(); ii.hasNext(); )\n 193: \t\t    out.add( (RefAddr) ii.next() );\n 194: \t\treturn out;\n 195: \t    }\n 196:         catch ( NamingException ne )\n 197:             { throw ne; }\n 198: \tcatch ( Exception e )\n 199: \t    {\n 200: \t\t//e.printStackTrace();\n 201: \t\tif ( Debug.DEBUG && logger.isLoggable( MLevel.FINE ) )\n 202: \t\t    logger.log( MLevel.FINE, \"Exception trying to create Reference.\", e);\n 203: \n 204: \t\tthrow new NamingException(\"Could not create reference from bean: \" + e.toString() );\n 205: \t    }\n 206:     }\n 207: \n 208:     public Reference createReference( Object bean )\n 209: \tthrows NamingException\n 210:     { return createReference( bean, null ); }\n 211: }\n 212: \n\n===== com/mchange/v2/naming/JavaBeanObjectFactory.java =====\n   1: package com.mchange.v2.naming;\n   2: \n   3: import java.beans.*;\n   4: import java.util.*;\n   5: import javax.naming.*;\n   6: import com.mchange.v2.log.*;\n   7: import java.io.IOException;\n   8: import java.lang.reflect.Method;\n   9: import javax.naming.spi.ObjectFactory;\n  10: import com.mchange.v2.beans.BeansUtils;\n  11: import com.mchange.v2.cfg.CurrentConfigFinder;\n  12: import com.mchange.v2.cfg.PropertiesConfig;\n  13: import com.mchange.v2.csv.FastCsvUtils;\n  14: import com.mchange.v2.lang.Coerce;\n  15: import com.mchange.v2.ser.SerializableUtils;\n  16: \n  17: public class JavaBeanObjectFactory implements ObjectFactory\n  18: {\n  19:     private final static MLogger logger = MLog.getLogger( JavaBeanObjectFactory.class );\n  20: \n  21:     final static Object NULL_TOKEN = new Object();\n  22: \n  23:     JavaBeanReferencePropertyOverrider overrider = null;\n  24: \n  25:     CurrentConfigFinder cfgFinder = null;\n  26: \n  27:     public void setReferencePropertyOverrider(JavaBeanReferencePropertyOverrider overrider)\n  28:     { this.overrider = overrider; }\n  29: \n  30:     public JavaBeanReferencePropertyOverrider getReferencePropertyOverrider()\n  31:     { return this.overrider; }\n  32: \n  33:     public void setConfigFinder(CurrentConfigFinder cfgFinder)\n  34:     { this.cfgFinder = cfgFinder; }\n  35: \n  36:     public CurrentConfigFinder getConfigFinder()\n  37:     { return this.cfgFinder; }\n  38: \n  39:     public Object getObjectInstance(Object refObj, Name name, Context nameCtx, Hashtable env)\n  40: \tthrows Exception\n  41:     {\n  42: \tif (refObj instanceof Reference)\n  43: \t    {\n  44: \t\tReference ref = (Reference) refObj;\n  45: \t\tMap refAddrsMap = new HashMap();\n  46: \t\tfor (Enumeration e = ref.getAll(); e.hasMoreElements(); )\n  47: \t\t    {\n  48: \t\t\tRefAddr addr = (RefAddr) e.nextElement();\n  49: \t\t\trefAddrsMap.put( addr.getType(), addr );\n  50: \t\t    }\n  51:                 String fqcn = ref.getClassName();\n  52:                 PropertiesConfig pcfg = (cfgFinder != null ? cfgFinder.findCurrentConfig() : null);\n  53:                 ReferenceableUtils.ensureWhitelistedJavaBeanClass( fqcn, pcfg );\n  54: \t\tClass beanClass = Class.forName( fqcn );\n  55: \t\tSet refProps = null;\n  56: \t\tRefAddr refPropsRefAddr = (StringRefAddr) refAddrsMap.remove( JavaBeanReferenceMaker.REF_PROPS_KEY );\n  57: \t\tif ( refPropsRefAddr != null )\n  58:                 {\n  59:                     String[] refPropsArray = FastCsvUtils.csvSplitLine((String) refPropsRefAddr.getContent());\n  60: \t\t    refProps = new HashSet();\n  61:                     Collections.addAll(refProps, refPropsArray);\n  62:                     //System.err.println(refProps);\n  63:                 }\n  64: \t\tMap propMap = createPropertyMap( beanClass, refAddrsMap );\n  65: \t\treturn findBean( beanClass, propMap, refProps );\n  66: \t    }\n  67: \telse\n  68: \t    return null;\n  69:     }\n  70: \n  71:     private Map createPropertyMap( Class beanClass, Map refAddrsMap ) throws Exception\n  72:     {\n  73: \tBeanInfo bi = Introspector.getBeanInfo( beanClass );\n  74: \tPropertyDescriptor[] pds = bi.getPropertyDescriptors();\n  75: \n  76: \tMap out = new HashMap();\n  77: \tfor (int i = 0, len = pds.length; i < len; ++i)\n  78: \t    {\n  79: \t\tPropertyDescriptor pd = pds[i];\n  80: \t\tString propertyName = pd.getName();\n  81: \t\tClass  propertyType = pd.getPropertyType();\n  82: \t\tRefAddr addr = (RefAddr) refAddrsMap.remove( propertyName );\n  83: \t\tif (addr != null)\n  84: \t\t    {\n  85:                         Object override;\n  86:                         if ( this.overrider != null && (override = this.overrider.overrideDecodeRefAddr( beanClass, (cfgFinder != null ? cfgFinder.findCurrentConfig() : null), propertyName, propertyType, addr )) != null )\n  87:                             {\n  88:                                 out.put( propertyName, override );\n  89:                             }\n  90: \t\t\telse if ( addr instanceof StringRefAddr )\n  91: \t\t\t    {\n  92: \t\t\t\tString content = (String) ((StringRefAddr) addr).getContent();\n  93: \t\t\t\tif ( Coerce.canCoerce( propertyType ) )\n  94: \t\t\t\t    out.put( propertyName, Coerce.toObject( content, propertyType ) );\n  95: \t\t\t\telse\n  96:                                 {\n  97:                                     PropertyEditor pe = BeansUtils.findPropertyEditor( pd );\n  98:                                     if (pe != null)\n  99:                                     {\n 100:                                         pe.setAsText( content );\n 101:                                         out.put( propertyName, pe.getValue() );\n 102:                                     }\n 103:                                     else // the only remaining valid possibility is that it is securely Stringified\n 104:                                     {\n 105:                                         try\n 106:                                         {\n 107:                                             out.put( propertyName, SecurelyStringifiable.constructSecurelyStringified( content ) );\n 108:                                         }\n 109:                                         catch (Exception e)\n 110:                                         {\n 111:                                             if (logger.isLoggable( MLevel.WARNING ))\n 112:                                                 logger.log(\n 113:                                                     MLevel.WARNING,\n 114:                                                     \"Failed to find an acceptable means to decode StringRefAddr for property '\" + propertyName +\n 115:                                                     \"' of \" + beanClass + \". Tried and failed to decode as SecurelyStringified. Content: \" + content,\n 116:                                                     e\n 117:                                                 );\n 118:                                         }\n 119:                                     }\n 120:                                 }\n 121: \t\t\t    }\n 122: \t\t\telse if ( addr instanceof BinaryRefAddr )\n 123: \t\t\t    {\n 124: \t\t\t\tbyte[] content = (byte[]) ((BinaryRefAddr) addr).getContent();\n 125: \t\t\t\tif ( content.length == 0 )\n 126: \t\t\t\t    out.put( propertyName, NULL_TOKEN ); //we use an empty array to mean null\n 127: \t\t\t\telse\n 128:                                     handleDeserializeBinaryRefAddressContent( propertyName, out, content );\n 129: \t\t\t    }\n 130: \t\t\telse\n 131: \t\t\t    {\n 132: \t\t\t\tif (logger.isLoggable( MLevel.WARNING ))\n 133: \t\t\t\t    logger.warning(this.getClass().getName() + \" -- unknown RefAddr subclass: \" + addr.getClass().getName());\n 134: \t\t\t    }\n 135: \t\t    }\n 136: \t    }\n 137: \tfor ( Iterator ii = refAddrsMap.keySet().iterator(); ii.hasNext(); )\n 138: \t    {\n 139: \t\tString type = (String) ii.next();\n 140: \t\tif (logger.isLoggable( MLevel.WARNING ))\n 141: \t\t    logger.warning(this.getClass().getName() + \" -- RefAddr for unknown property: \" + type);\n 142: \t    }\n 143: \treturn out;\n 144:     }\n 145: \n 146:     protected void handleDeserializeBinaryRefAddressContent( String propertyName, Map out, byte[] content ) throws ClassNotFoundException, IOException\n 147:     {\n 148:         if ( logger.isLoggable( MLevel.WARNING ) )\n 149:             logger.log(\n 150:                 MLevel.WARNING,\n 151:                 \"Deserialization of BinaryRefAddr contents interpreted as Java-Serialized objects has been disabled. \" +\n 152:                 \"The functionality still exists, but to restore it you must define your own subclass of \" +\n 153:                 this.getClass().getName() +\n 154:                 \"and override 'protected void handleDeserializeBinaryRefAddressContent( String propertyName, Map out, byte[] content ) throws ClassNotFoundException, IOException' \" +\n 155:                 \"to call 'dangerousDeserializeBinaryRefAddressContent( propertyName, out, content )' rather than merely log this warning. \" +\n 156:                 \"For now, property '\" + propertyName + \"' will be skipped. \" +\n 157:                 \"It will take its default value upon construction and not be updated from the reference.\"\n 158:             );\n 159:     }\n 160: \n 161:     protected void dangerousDeserializeBinaryRefAddressContent( String propertyName, Map out, byte[] content ) throws ClassNotFoundException, IOException\n 162:     {\n 163: \tout.put( propertyName, SerializableUtils.fromByteArray( content ) ); //this will handle \"indirectly serialized\" objects.\n 164:     }\n 165: \n 166:     protected Object createBlankInstance(Class beanClass) throws Exception\n 167:     { return beanClass.newInstance(); }\n 168: \n 169:     protected Object findBean(Class beanClass, Map propertyMap, Set refProps ) throws Exception\n 170:     {\n 171: \tObject bean = createBlankInstance( beanClass );\n 172: \tBeanInfo bi = Introspector.getBeanInfo( bean.getClass() );\n 173: \tPropertyDescriptor[] pds = bi.getPropertyDescriptors();\n 174: \n 175: \tfor (int i = 0, len = pds.length; i < len; ++i)\n 176: \t    {\n 177: \t\tPropert