    16: public class JavaBeanReferenceMaker implements ReferenceMaker
    17: {
    18:     private final static MLogger logger = MLog.getLogger( JavaBeanReferenceMaker.class );
    19: 
    20:     final static String REF_PROPS_KEY = "com.mchange.v2.naming.JavaBeanReferenceMaker.REF_PROPS_KEY";
    21: 
    22:     final static Object[] EMPTY_ARGS = new Object[0];
    23: 
    24:     final static byte[] NULL_TOKEN_BYTES = new byte[0];
