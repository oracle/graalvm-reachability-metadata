   403:     private static boolean objectFactoryWhitelistIsDisabled(Set whitelisted, PropertiesConfig pcfg)
   404:     { return whitelistIsDisabled(whitelisted,pcfg,SecurityConfigKey.OBJECT_FACTORY_WHITELIST); }
   405: 
   406:     private static boolean javaBeanWhitelistIsDisabled(Set whitelisted, PropertiesConfig pcfg)
   407:     { return whitelistIsDisabled(whitelisted,pcfg,SecurityConfigKey.REFERENCEABLE_JAVA_BEAN_CLASS_WHITELIST); }
   408: 
   409:     /* intentionally package-scope, accessed by JavaBeanObjectFactory */
   410:     /* pcfg can be null */
   411:     static void ensureWhitelistedJavaBeanClass( String fqcn, PropertiesConfig pcfg ) throws NamingException
   412:     {
   413:         Set whitelisted = referenceableJavaBeanClassWhiteList( pcfg );
   414:         if (whitelisted != null)
   415:         {
   416:             if (!javaBeanWhitelistIsDisabled(whitelisted, pcfg) && !whitelisted.contains(fqcn))
   417:             {
   418:                 StringBuilder sb = new StringBuilder();
   419:                 boolean first = true;
   420:                 for ( Object cn : whitelisted )
   421:                 {
   422:                     if (!first)
   423:                         sb.append(",");
   424:                     else
   425:                         first = false;
   426:                     sb.append(cn);
   427:                 }
   428:                 throw new NamingException(
   429:                     "The whitelist of acceptable JavaBeanClasses to which to create or look up references does not contain referenced class '" + fqcn + "'. " +
   430:                     "Please add that class to comma-separated list at config key '" + SecurityConfigKey.REFERENCEABLE_JAVA_BEAN_CLASS_WHITELIST + "' if " +
   431:                     "you wish for this reference to be created or resolved. " +
   432:                     "(If this is unexpected, note that if you have set the whitelist in multiple places, only the INTERSECTION becomes whitelisted. " +
   433:                     "Check for distinct whitelists in system properties and other config.) " +
   434:                     "Current whitelist: " + sb.toString() + " -- " + "Missing class: " + fqcn
   435:                 );
   436:             }
   437:         }
   438:         else
   439:         {
   440:             throw new NamingException(
   441:                 "No whitelist is set for referenceable java beans. This is dangerous. Please set '" + SecurityConfigKey.REFERENCEABLE_JAVA_BEAN_CLASS_WHITELIST +
   442:                 "'. You are currently creating or dereferencing an object of class '" + fqcn + "'. If that is intended and desirable, please include it " +
   443:                 "in the whitelist! (If this is unexpected, note that if you have set the whitelist in multiple places, only the INTERSECTION becomes whitelisted. " +
   444:                 "Check for distinct whitelists in system properties and other config.) No classes are currently whitelisted. -- Missing class: " + fqcn
   445:             );
   446:         }
   447:     }
   448: 
   449:     private static Set referenceableJavaBeanClassWhiteList( PropertiesConfig pcfg )
   450:     {
   451:         Set out = narrowestStringListPropertiesConfigSystemProperties( SecurityConfigKey.REFERENCEABLE_JAVA_BEAN_CLASS_WHITELIST, pcfg );
   452:         if (out != null && out.size() == 0) return null;
   453:         else return out;
   454:     }
   455: 
   456:     // pcfg can be null
   457:     private static Set findMandatoryObjectFactoryWhitelist( PropertiesConfig pcfg ) throws NamingException
   458:     {
   459:         Set narrowest = narrowestStringListPropertiesConfigSystemProperties( SecurityConfigKey.OBJECT_FACTORY_WHITELIST, pcfg );
   460:         if (narrowest == null)
   461:             throw new NamingException(
   462:                 "No ObjectFactory whitelist found. " +
   463:                 "When calling referenceToObject(...) using overloads that lack an explicit allowedFactoryClassNames Set, a '" +
   464:                 SecurityConfigKey.OBJECT_FACTORY_WHITELIST + "' must be provided either as a System property or a provided com.mchange.v2.PropertiesConfig instance. " +
   465:                 "If you really want to live dangerously and accept any ObjectFactory (why?!?), you may provide a whitelist with a unique entry of '*'."
   466:             );
   467:         if (objectFactoryWhitelistIsDisabled(narrowest,pcfg))
   468:             return ALL_FACTORY_CLASS_NAMES;
   469:         else
   470:             return narrowest;
   471:     }
