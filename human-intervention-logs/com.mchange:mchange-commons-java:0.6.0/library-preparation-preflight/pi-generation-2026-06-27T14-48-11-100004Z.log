   103: 
   104: 	public Object recreateFromKey(Object key) throws Exception
   105: 	{
   106: 	    PathsKey pk = (PathsKey) key;
   107: 
   108: 	    /*
   109: 	    for( Iterator ii = pk.delayedLogItems.iterator(); ii.hasNext(); )
   110: 	    {
   111: 		DelayedLogItem pm = (DelayedLogItem) ii.next();
   112: 		logger.log( pm.getLevel(), pm.getText(), pm.getException() );
   113: 	    }
   114: 	    */
   115: 
   116: 	    List<DelayedLogItem> items = new ArrayList<DelayedLogItem>();
   117: 	    items.addAll( pk.delayedLogItems );
