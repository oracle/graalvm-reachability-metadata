    67:     public Reference createReference( Object bean, PropertiesConfig pcfg )
    68: 	throws NamingException
    69:     {
    70: 	try
    71: 	    {
    72:                 ReferenceableUtils.ensureWhitelistedJavaBeanClass( bean, pcfg );
    73:                 Class beanClass = bean.getClass();
    74: 		BeanInfo bi = Introspector.getBeanInfo( beanClass );
    75: 		PropertyDescriptor[] pds = bi.getPropertyDescriptors();
    76: 		List refAddrs = new ArrayList();
    77: 		String factoryClassLocation = defaultFactoryClassLocation;
    78: 
    79: 		boolean using_ref_props = referenceProperties.size() > 0;
    80: 
    81: 		// we only include this so that on dereference we are not surprised to find some properties missing
    82: 		if (using_ref_props)
    83:                 {
    84:                     String[] refPropsArray = new String[referenceProperties.size()];
    85:                     referenceProperties.toArray(refPropsArray);
    86:                     String refPropsAsCsvLine = FastCsvUtils.generateCsvLineQuotedUnterminated(refPropsArray);
    87:                     //System.err.println(refPropsAsCsvLine);
    88: 		    refAddrs.add( new StringRefAddr( REF_PROPS_KEY, refPropsAsCsvLine ) );
    89:                 }
    90: 
    91: 		for (int i = 0, len = pds.length; i < len; ++i)
    92: 		    {
    93: 			PropertyDescriptor pd = pds[i];
    94: 			String propertyName = pd.getName();
    95: 			//System.err.println("Making Reference: " + propertyName);
    96: 
    97: 			if (using_ref_props && ! referenceProperties.contains( propertyName ))
    98: 			    {
    99: 				//System.err.println("Not a ref_prop -- continuing.");
   100: 				continue;
   101: 			    }
   102: 
   103: 			Class  propertyType = pd.getPropertyType();
   104: 			Method getter = pd.getReadMethod();
   105: 			Method setter = pd.getWriteMethod();
   106: 			if (getter != null && setter != null) //only use properties that are both readable and writable
   107: 			    {
   108: 				Object val = getter.invoke( bean, EMPTY_ARGS );
   109: 				//System.err.println( "val: " + val );
   110: 				if (propertyName.equals("factoryClassLocation"))
   111: 				    {
   112: 					if (String.class != propertyType)
   113: 					    throw new NamingException(this.getClass().getName() + " requires a factoryClassLocation property to be a string, " +
   114: 								      propertyType.getName() + " is not valid.");
   115: 					factoryClassLocation = (String) val;
   116: 				    }
   117: 
   118:                                 RefAddr addMe = null;
   119: 				if (val == null)
   120: 				    {
   121: 					addMe = new BinaryRefAddr( propertyName, NULL_TOKEN_BYTES );
   122: 					refAddrs.add( addMe );
   123: 				    }
   124:                                 else if (this.overrider != null && (addMe = this.overrider.overrideRefAddr(beanClass,pcfg,propertyName,propertyType,val)) != null)
   125:                                     {
   126: 					refAddrs.add( addMe );
   127:                                     }
   128: 				else if ( Coerce.canCoerce( propertyType ) )
   129: 				    {
   130: 					addMe = new StringRefAddr( propertyName, String.valueOf( val ) );
   131: 					refAddrs.add( addMe );
   132: 				    }
   133: 				else  //other Object properties
   134: 				    {
   135: 					PropertyEditor pe = BeansUtils.findPropertyEditor( pd );
   136: 					if (pe != null)
   137: 					    {
   138: 						pe.setValue( val );
   139: 						String textValue = pe.getAsText();
   140: 						if (textValue != null)
   141: 						    addMe = new StringRefAddr( propertyName, textValue );
   142: 					    }
   143:                                         if ( addMe == null ) //property editor approach failed
   144:                                             {
   145:                                                 // note that it's the concrete class, not the declared bean type, that must be SecurelyStringified!
   146:                                                 if ( SecurelyStringifiable.isSecurelyStringifiable( val.getClass() ) )
   147:                                                     addMe = new StringRefAddr( propertyName, SecurelyStringifiable.securelyStringify( val ) );
   148:                                             }
   149: 					if (addMe == null) // all String-based approaches have failed
   150:                                         {
   151:                                             if (ReferenceableUtils.generateSerializedObjectBinaryRefAddr( pcfg ))
   152:                                             {
   153:                                                 addMe = new BinaryRefAddr( propertyName, SerializableUtils.toByteArray( val, 
   154:                                                                                                                         indirector, 
   155:                                                                                                                         IndirectPolicy.INDIRECT_ON_EXCEPTION ) );
   156:                                             }
   157:                                             else
   158:                                             {
   159:                                                 String baseMessage =
   160:                                                     "While creating a javax.naming.Reference to '" +
   161:                                                     bean +
   162:                                                     "', found a property of type '" +
   163:                                                     pd.getName() +
   164:                                                     "' and concrete class '" + val.getClass().getName() +
   165:                                                     "' that cannot be embedded as a String or null. " +
   166:                                                     "No other approach has worked, and embedding properties as Java Serialized objects is disabled.";
   167:                                                 if (skipUnwritableProperties)
   168:                                                 {
   169:                                                     if (logger.isLoggable(MLevel.WARNING))
   170:                                                         logger.log(MLevel.WARNING, baseMessage + " This property has been skipped, and will not be included in the generated reference!");
   171:                                                 }
   172:                                                 else
   173:                                                     throw new NamingException(baseMessage);
   174:                                             }
   175:                                         }
   176:                                         if (addMe != null)
   177:                                             refAddrs.add( addMe );
   178: 				    }
   179: 			    }
   180: 			else
   181: 			    {
   182: // 				System.err.println(this.getClass().getName() +
   183: // 						   ": Skipping " + propertyName + " because it is " + (setter == null ? "read-only." : "write-only."));
   184: 
   185: 				if ( logger.isLoggable( MLevel.WARNING ) )
   186: 				    logger.warning(this.getClass().getName() + ": Skipping " + propertyName + 
   187: 						   " because it is " + (setter == null ? "read-only." : "write-only."));
   188: 			    }
   189: 
   190: 		    }
   191: 		Reference out = new Reference( beanClass.getName(), factoryClassName, factoryClassLocation );
   192: 		for (Iterator ii = refAddrs.iterator(); ii.hasNext(); )
   193: 		    out.add( (RefAddr) ii.next() );
   194: 		return out;
   195: 	    }
   196:         catch ( NamingException ne )
   197:             { throw ne; }
   198: 	catch ( Exception e )
   199: 	    {
   200: 		//e.printStackTrace();
   201: 		if ( Debug.DEBUG && logger.isLoggable( MLevel.FINE ) )
   202: 		    logger.log( MLevel.FINE, "Exception trying to create Reference.", e);
   203: 
   204: 		throw new NamingException("Could not create reference from bean: " + e.toString() );
   205: 	    }
   206:     }
   207: 
   208:     public Reference createReference( Object bean )
   209: 	throws NamingException
   210:     { return createReference( bean, null ); }
   211: }
