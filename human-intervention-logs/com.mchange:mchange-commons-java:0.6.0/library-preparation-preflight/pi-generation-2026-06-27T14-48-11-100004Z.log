    59:     { this.defaultFactoryClassLocation = defaultFactoryClassLocation; }
    60: 
    61:     public void addReferenceProperty( String propName )
    62:     { referenceProperties.add( propName ); }
    63: 
    64:     public void removeReferenceProperty( String propName )
    65:     { referenceProperties.remove( propName ); }
