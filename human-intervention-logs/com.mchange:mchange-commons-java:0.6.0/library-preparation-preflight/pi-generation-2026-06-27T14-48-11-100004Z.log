   368:     private static Set commaSeparatedStringListToModifiableSet( String csList )
   369:     {
   370:         String[] items = csList.split("\\s*,\\s*");
   371:         return new HashSet(Arrays.asList(items));
   372:     }
   373: 
   374:     private static Set commaSeparatedStringListToSet( String csList )
   375:     { return Collections.unmodifiableSet(commaSeparatedStringListToModifiableSet(csList)); }
