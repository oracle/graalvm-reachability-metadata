   189: 				    logger.warning(this.getClass().getName() + ": Could not restore read-only property '" + propertyName + "'.");
   190: 			    }
   191: 		    }
   192: 		else
   193: 		    {
   194: 			if (setter != null)
   195: 			    {
   196: 				if (refProps == null || refProps.contains( propertyName ))
