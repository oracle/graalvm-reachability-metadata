   169:     protected Object findBean(Class beanClass, Map propertyMap, Set refProps ) throws Exception
   170:     {
   171: 	Object bean = createBlankInstance( beanClass );
   172: 	BeanInfo bi = Introspector.getBeanInfo( bean.getClass() );
   173: 	PropertyDescriptor[] pds = bi.getPropertyDescriptors();
   174: 
   175: 	for (int i = 0, len = pds.length; i < len; ++i)
   176: 	    {
   177: 		PropertyDescriptor pd = pds[i];
   178: 		String propertyName = pd.getName();
   179: 		Object value = propertyMap.get( propertyName );
   180: 		Method setter = pd.getWriteMethod();
   181: 		if (value != null)
   182: 		    {
   183: 			if (setter != null)
   184: 			    setter.invoke( bean, new Object[] { (value == NULL_TOKEN ? null : value) } );
