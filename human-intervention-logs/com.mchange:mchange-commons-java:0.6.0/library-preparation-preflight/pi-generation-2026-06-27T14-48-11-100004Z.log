   380:     { ensureWhitelistedJavaBeanClass( bean.getClass().getName(), pcfg ); }
   381: 
   382:     private static boolean whitelistIsDisabled(Set whitelisted, PropertiesConfig pcfg, String whitelistKey)
   383:     {
   384:         if (!ACCEPT_ANY_WHITELIST.equals(whitelisted))
   385:             return false;
   386:         else if (pcfg == null) // if pcfg is null, the '*' whitelist was uniquely specified in System properties
   387:             return true;
   388:         else
   389:         {
   390:             String syspropsWhitelist = System.getProperty( whitelistKey );
   391:             String pcfgWhitelist     = pcfg.getProperty( whitelistKey );
   392:             if (syspropsWhitelist == null) // if syspropsWhitelist is null, the '*' whitelist was uniquely specified in pcfg
   393:                 return true;
   394:             else if (pcfgWhitelist == null) // if pcfgWhitelist is null, the '*' whitelist was uniquely specified in System properties
   395:                 return true;
   396:             else // the whitelist is specified in both places. make sure both are trying to disable enforcement
   397:                 return
   398:                     ACCEPT_ANY_WHITELIST.equals(commaSeparatedStringListToModifiableSet(syspropsWhitelist)) &&
   399:                     ACCEPT_ANY_WHITELIST.equals(commaSeparatedStringListToModifiableSet(pcfgWhitelist));
   400:         }
   401:     }
