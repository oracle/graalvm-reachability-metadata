  +package args4j.args4j;
  +
  +import org.junit.jupiter.api.Test;
  +import org.kohsuke.args4j.CmdLineParser;
  +import org.kohsuke.args4j.FieldParser;
  +
  +import static org.assertj.core.api.Assertions.assertThat;
  +
  +public class FieldParserTest {
  +    @Test
  +    void parsesDeclaredAndInheritedFieldsAsOptions() throws Exception {
  +        FieldParserBean bean = new FieldParserBean();
  +        CmdLineParser parser = new CmdLineParser(null);
  +
  +        new FieldParser().parse(parser, bean);
  +        parser.parseArgument("-name", "parsed-name", "-description", "parsed-description");
  +
  +        assertThat(bean.name).isEqualTo("parsed-name");
  +        assertThat(bean.description()).isEqualTo("parsed-description");
  +    }
  +
  +    public static class FieldParserBaseBean {
  +        public String name;
  +    }
  +
  +    public static class FieldParserBean extends FieldParserBaseBean {
  +        private String description;
  +
  +        String description() {
  +            return description;
  +        }
  +    }
  +}
