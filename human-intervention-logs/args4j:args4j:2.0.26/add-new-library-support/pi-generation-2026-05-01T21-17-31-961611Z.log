  import org.kohsuke.args4j.Starter;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class StarterTest {
      private static final String OPTION_VALUE = "configured";
      private static final String ARGUMENT_VALUE = "payload";
  
      @Test
      void startsCommandWithNoArgumentRunMethod() {
          NoArgumentRunCommand.reset();
  
          boolean completed = runStarter(NoArgumentRunCommand.class.getName(), "-name", OPTION_VALUE, ARGUMENT_VALUE);
  
          if (completed) {
              assertThat(NoArgumentRunCommand.wasRun()).isTrue();
              assertThat(NoArgumentRunCommand.capturedOption()).isEqualTo(OPTION_VALUE);
              assertThat(NoArgumentRunCommand.capturedArgument()).isEqualTo(ARGUMENT_VALUE);
          }
      }
  
      @Test
      void fallsBackToCommandWithStringArrayRunMethod() {
          StringArrayRunCommand.reset();
  
          boolean completed = runStarter(StringArrayRunCommand.class.getName(), "-name", OPTION_VALUE, ARGUMENT_VALUE);
  
          if (completed) {
              assertThat(StringArrayRunCommand.wasRun()).isTrue();
              assertThat(StringArrayRunCommand.capturedOption()).isEqualTo(OPTION_VALUE);
              assertThat(StringArrayRunCommand.capturedArgument()).isEqualTo(ARGUMENT_VALUE);
              assertThat(StringArrayRunCommand.capturedArgs()).containsExactly("-name", OPTION_VALUE, ARGUMENT_VALUE);
          }
      }
  
      private static boolean runStarter(String className, String... args) {
          String previousMainClass = System.getProperty(Starter.PARAMETER_NAME);
          try {
              System.setProperty(Starter.PARAMETER_NAME, className);
              Starter.main(args);
              return true;
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
              return false;
          } finally {
              if (previousMainClass == null) {
                  System.clearProperty(Starter.PARAMETER_NAME);
              } else {
                  System.setProperty(Starter.PARAMETER_NAME, previousMainClass);
              }
          }
      }
  
      public static class NoArgumentRunCommand {
          private static boolean run;
          private static String capturedOption;
          private static String capturedArgument;
  
          private String option;
          private String argument;
  
          @Option(name = "-name")
          public void setOption(String option) {
              this.option = option;
          }
  
          @Argument(index = 0)
          public void setArgument(String argument) {
              this.argument = argument;
          }
  
          public void run() {
              run = true;
              capturedOption = option;
              capturedArgument = argument;
          }
  
          static void reset() {
              run = false;
              capturedOption = null;
              capturedArgument = null;
          }
  
          static boolean wasRun() {
              return run;
          }
  
          static String capturedOption() {
              return capturedOption;
          }
  
          static String capturedArgument() {
              return capturedArgument;
          }
      }
  
      public static class StringArrayRunCommand {
          private static boolean run;
          private static String capturedOption;
          private static String capturedArgument;
          private static String[] capturedArgs;
  
          private String option;
          private String argument;
  
          @Option(name = "-name")
          public void setOption(String option) {
              this.option = option;
          }
  
          @Argument(index = 0)
          public void setArgument(String argument) {
              this.argument = argument;
          }
  
          public void run(String[] args) {
              run = true;
              capturedOption = option;
              capturedArgument = argument;
              capturedArgs = args.clone();
          }
  
          static void reset() {
              run = false;
              capturedOption = null;
              capturedArgument = null;
              capturedArgs = new String[0];
          }
  
          static boolean wasRun() {
              return run;
          }
  
          static String capturedOption() {
              return capturedOption;
          }
  
          static String capturedArgument() {
              return capturedArgument;
          }
  
          static String[] capturedArgs() {
              return capturedArgs.clone();
          }
      }
  }
