[tool-call] delta {"path":"tests/src/args4j/args4j/2.0.26/src/test/java/args4j/args4j/XmlParserTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage args4j.args4j;\n\nimport java.io.StringReader;\n\nimport org.junit.jupiter.api.Test;\nimport org.kohsuke.args4j.CmdLineParser;\nimport org.kohsuke.args4j.XmlParser;\nimport org.xml.sax.InputSource;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class XmlParserTest {\n    @Test\n    void parsesOptionsMappedToFieldAndMethodFromXml() throws Exception {\n        XmlConfiguredBean bean = new XmlConfiguredBean();\n        CmdLineParser parser = new CmdLineParser(null);\n        XmlParser xmlParser = new XmlParser();\n        String xml = \"\"\"\n                <args>\n                    <option name=\"-field\" field=\"fieldValue\" usage=\"value assigned through a field\"/>\n                    <option name=\"-method\" method=\"setMethodValue(String)\" usage=\"value assigned through a method\"/>\n                </args>\n                \"\"\";\n\n        xmlParser.parse(new InputSource(new StringReader(xml)), parser, bean);\n        parser.parseArgument(\"-field\", \"from-field\", \"-method\", \"from-method\");\n\n        assertThat(bean.fieldValue()).isEqualTo(\"from-field\");\n        assertThat(bean.methodValue()).isEqualTo(\"from-method\");\n    }\n\n    public static class XmlConfiguredBean {\n        private String fieldValue;\n        private String methodValue;\n\n        public void setMethodValue(String methodValue) {\n            this.methodValue = methodValue;\n        }\n\n        String fieldValue() {\n            return fieldValue;\n        }\n\n        String methodValue() {\n            return methodValue;\n        }\n    }\n}\n"}
