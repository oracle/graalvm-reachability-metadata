 = new XmlConfiguredBean();\n        CmdLineParser parser = new CmdLineParser(null);\n        XmlParser xmlParser = new XmlParser();\n        String xml = \"\"\"\n                <args>\n                    <option name=\"-field\" field=\"fieldValue\" usage=\"value assigned through a field\"/>\n                    <option name=\"-method\" method=\"setMethodValue(String)\" usage=\"value assigned through a method\"/>\n                </args>\n                \"\"\";\n\n        xmlParser.parse(new InputSource(new StringReader(xml)), parser, bean);\n        parser.parseArgument(\"-field\", \"from-field\", \"-method\", \"from-method\");\n\n        assertThat(bean.fieldValue()).isEqualTo(\"from-field\");\n        assertThat(bean.methodValue()).isEqualTo(\"from-method\");\n    }\n\n    public static class XmlConfiguredBean {\n        private String fieldValue;\n        private String methodValue;\n\n        public void setMethodValue(String methodValue) {\n            this.methodValue = methodValue;\n        }\n\n        String fieldValue() {\n            return fieldValue;\n        }\n\n        String methodValue() {\n            return methodValue;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1847, "output": 1197, "cacheRead": 23552, "cacheWrite": 0, "totalTokens": 26596, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777670212642, "responseId": "resp_0f6b868b8b4f04ad0169f5184517fc8194b14161cddb76d215"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_APEBchgWszl8czgFFpd7WnkR|fc_0f6b868b8b4f04ad0169f5184e617c8194978e55880fece3d2", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1724 bytes to tests/src/args4j/args4j/2.0.26/src/test/java/args4j/args4j/XmlParserTest.java"}], "isError": false, "timestamp": 1777670225021}]}
