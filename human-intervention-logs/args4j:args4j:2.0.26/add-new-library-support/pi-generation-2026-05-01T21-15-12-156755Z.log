  	private void printSingleLineOption(PrintWriter pw, OptionHandler h, ResourceBundle rb) {
  		pw.print(' ');
  		if (!h.option.required())
  			pw.print('[');
  		pw.print(h.getNameAndMeta(rb));
  		if (h.option.isMultiValued()) {
  			pw.print(" ...");
  		}
  		if (!h.option.required())
  			pw.print(']');
  	}
  
