          StringArrayRunCommand.reset();
  
          boolean completed = runStarter(StringArrayRunCommand.class.getName(), "-name", OPTION_VALUE, ARGUMENT_VALUE);
  
          if (completed) {
              assertThat(StringArrayRunCommand.wasRun()).isTrue();
              assertThat(StringArrayRunCommand.capturedOption()).isEqualTo(OPTION_VALUE);
              assertThat(StringArrayRunCommand.capturedArgument()).isEqualTo(ARGUMENT_VALUE);
              assertThat(StringArrayRunCommand.capturedArgs()).containsExactly("-name", OPTION_VALUE, ARGUMENT_VALUE);
          }
      }
  
      private static boolean runStarter(String className, String... args) {
          String previousMainClass = System.getProperty(Starter.PARAMETER_NAME);
          try {
              System.setProperty(Starter.PARAMETER_NAME, className);
              Starter.main(args);
              return true;
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
              return false;
          } finally {
              if (previousMainClass == null) {
                  System.clearProperty(Starter.PARAMETER_NAME);
              } else {
                  System.setProperty(Starter.PARAMETER_NAME, previousMainClass);
              }
          }
