          CmdLineImpl( String[] args ) {
              this.args = args;
              pos = 0;
          }
  
          protected boolean hasMore() {
              return pos<args.length;
          }
  
          protected String getCurrentToken() {
              return args[pos];
          }
  
          private void proceed( int n ) {
              pos += n;
          }
  
