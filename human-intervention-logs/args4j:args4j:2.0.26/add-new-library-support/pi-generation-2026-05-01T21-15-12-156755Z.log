  package args4j.args4j;
  
  import java.util.HashMap;
  import java.util.Map;
  
  import org.junit.jupiter.api.Test;
  import org.kohsuke.args4j.CmdLineException;
  import org.kohsuke.args4j.CmdLineParser;
  import org.kohsuke.args4j.Option;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class FieldSetterTest {
      @Test
      void parsesOptionIntoPublicField() throws CmdLineException {
          PublicOptionBean bean = new PublicOptionBean();
          CmdLineParser parser = new CmdLineParser(bean);
  
          parser.parseArgument("-name", "public-value");
  
          assertThat(bean.name).isEqualTo("public-value");
      }
  
      @Test
      void parsesOptionIntoPrivateField() throws CmdLineException {
          PrivateOptionBean bean = new PrivateOptionBean();
          CmdLineParser parser = new CmdLineParser(bean);
  
          parser.parseArgument("-name", "private-value");
  
          assertThat(bean.name()).isEqualTo("private-value");
      }
  
      @Test
      void parsesMapOptionIntoPublicField() throws CmdLineException {
          PublicMapOptionBean bean = new PublicMapOptionBean();
          CmdLineParser parser = new CmdLineParser(bean);
  
          parser.parseArgument("-property", "alpha=one", "-property", "beta=two");
  
          assertThat(bean.properties)
                  .containsEntry("alpha", "one")
                  .containsEntry("beta", "two");
      }
  
      @Test
      void parsesMapOptionIntoExistingPrivateField() throws CmdLineException {
          PrivateMapOptionBean bean = new PrivateMapOptionBean();
          CmdLineParser parser = new CmdLineParser(bean);
  
          parser.parseArgument("-property", "alpha=one");
  
          assertThat(bean.properties()).containsEntry("alpha", "one");
      }
  
      public static class PublicOptionBean {
          @Option(name = "-name")
          public String name;
      }
  
      public static class PrivateOptionBean {
          @Option(name = "-name")
          private String name;
  
          String name() {
              return name;
          }
      }
  
      public static class PublicMapOptionBean {
          @Option(name = "-property")
          public Map<String, String> properties;
      }
  
      public static class PrivateMapOptionBean {
          @Option(name = "-property")
          private Map<String, String> properties = new HashMap<String, String>();
  
          Map<String, String> properties() {
              return properties;
          }
      }
  }
