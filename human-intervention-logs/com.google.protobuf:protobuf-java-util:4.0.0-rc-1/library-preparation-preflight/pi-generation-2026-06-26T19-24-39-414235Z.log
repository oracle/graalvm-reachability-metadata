sion>\n  <parent>\n    <groupId>com.google.protobuf</groupId>\n    <artifactId>protobuf-parent</artifactId>\n    <version>4.0.0-rc-1</version>\n  </parent>\n\n  <artifactId>protobuf-java-util</artifactId>\n  <packaging>bundle</packaging>\n\n  <name>Protocol Buffers [Util]</name>\n  <description>Utilities for Protocol Buffers</description>\n\n  <dependencies>\n    <dependency>\n      <groupId>${project.groupId}</groupId>\n      <artifactId>protobuf-java</artifactId>\n    </dependency>\n    <dependency>\n      <groupId>com.google.guava</groupId>\n      <artifactId>guava</artifactId>\n    </dependency>\n    <dependency>\n      <groupId>com.google.errorprone</groupId>\n      <artifactId>error_prone_annotations</artifactId>\n      <version>2.3.4</version>\n    </dependency>\n    <dependency>\n      <groupId>com.google.guava</groupId>\n      <artifactId>guava-testlib</artifactId>\n      <scope>test</scope>\n    </dependency>\n    <dependency>\n      <groupId>com.google.code.gson</groupId>\n      <artifactId>gson</artifactId>\n      <version>2.8.6</version>\n    </dependency>\n    <dependency>\n      <groupId>junit</groupId>\n      <artifactId>junit</artifactId>\n    </dependency>\n    <dependency>\n      <groupId>org.easymock</groupId>\n      <artifactId>easymock</artifactId>\n    </dependency>\n    <dependency>\n      <groupId>org.easymock</groupId>\n      <artifactId>easymockclassextension</artifactId>\n    </dependency>\n    <dependency>\n      <groupId>com.google.truth</groupId>\n      <artifactId>truth</artifactId>\n      <scope>test</scope>\n    </dependency>\n  </dependencies>\n\n  <properties>\n    <!-- Use the core proto dir so that we can call the core generation script -->\n    <test.proto.dir>../core/src/test/proto</test.proto.dir>\n  </properties>\n\n  <build>\n    <plugins>\n      <plugin>\n        <artifactId>maven-antrun-plugin</artifactId>\n        <executions>\n          <!-- Generate the test protos -->\n          <execution>\n            <id>generate-test-sources</id>\n            <phase>generate-test-sources</phase>\n            <configuration>\n              <target>\n                <!-- Generate all of the test protos from the core module -->\n                <ant antfile=\"../core/generate-test-sources-build.xml\"/>\n\n                <!-- Generate additional test protos for this module -->\n                <exec executable=\"${protoc}\">\n                  <arg value=\"--java_out=${generated.testsources.dir}\"/>\n                  <arg value=\"--proto_path=${protobuf.source.dir}\"/>\n                  <arg value=\"--proto_path=src/test/proto\"/>\n                  <arg value=\"src/test/proto/com/google/protobuf/util/json_test.proto\"/>\n                </exec>\n              </target>\n            </configuration>\n            <goals>\n              <goal>run</goal>\n            </goals>\n          </execution>\n        </executions>\n      </plugin>\n\n      <!-- Add the generated test sources to the build -->\n      <plugin>\n        <groupId>org.codehaus.mojo</groupId>\n        <artifactId>build-helper-maven-plugin</artifactId>\n        <executions>\n          <execution>\n            <id>add-generated-test-sources</id>\n            <phase>generate-test-sources</phase>\n            <goals>\n              <goal>add-test-source</goal>\n            </goals>\n            <configuration>\n              <sources>\n                <source>${generated.testsources.dir}</source>\n              </sources>\n            </configuration>\n          </execution>\n        </executions>\n      </plugin>\n\n      <!-- Configure the OSGI bundle -->\n      <plugin>\n        <groupId>org.apache.felix</groupId>\n        <artifactId>maven-bundle-plugin</artifactId>\n        <extensions>true</extensions>\n        <configuration>\n          <instructions>\n            <Automatic-Module-Name>com.google.protobuf.util</Automatic-Module-Name> <!-- Java9+ Jigsaw module name -->\n            <Bundle-DocURL>https://developers.google.com/protocol-buffers/</Bundle-DocURL>\n            <Bundle-SymbolicName>com.google.protobuf.util</Bundle-SymbolicName>\n            <Export-Package>com.google.protobuf.util;version=${project.version}</Export-Package>\n          </instructions>\n        </configuration>\n      </plugin>\n\n      <!-- Configure the fat jar to include all dependencies -->\n      <plugin>\n        <artifactId>maven-assembly-plugin</artifactId>\n        <configuration>\n          <descriptorRefs>\n            <descriptorRef>jar-with-dependencies</descriptorRef>\n          </descriptorRefs>\n        </configuration>\n      </plugin>\n    </plugins>\n  </build>\n</project>\n\n--- https://repo1.maven.org/maven2/com/google/protobuf/protobuf-java-util/3.25.9/protobuf-java-util-3.25.9.pom\n<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<project xmlns=\"http://maven.apache.org/POM/4.0.0\" xmlns:xsi=\"http://www.w3.org/2001/XMLSchema-instance\" xsi:schemaLocation=\"http://maven.apache.org/POM/4.0.0 http://maven.apache.org/maven-v4_0_0.xsd\">\n  <modelVersion>4.0.0</modelVersion>\n  <parent>\n    <groupId>com.google.protobuf</groupId>\n    <artifactId>protobuf-parent</artifactId>\n    <version>3.25.9</version>\n  </parent>\n\n  <artifactId>protobuf-java-util</artifactId>\n  <packaging>jar</packaging>\n\n  <name>Protocol Buffers [Util]</name>\n  <description>Utilities for Protocol Buffers</description>\n  <dependencies>\n    <dependency>\n      <groupId>com.google.protobuf</groupId>\n      <artifactId>protobuf-java</artifactId>\n      <version>3.25.9</version>\n    </dependency>\n            <dependency>\n            <groupId>com.google.code.findbugs</groupId>\n            <artifactId>jsr305</artifactId>\n            <version>3.0.2</version>\n        </dependency>\n        <dependency>\n            <groupId>com.google.code.gson</groupId>\n            <artifactId>gson</artifactId>\n            <version>2.8.9</version>\n        </dependency>\n        <dependency>\n            <groupId>com.google.errorpro