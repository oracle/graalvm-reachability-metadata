"oldText": "import androidx.compose.runtime.snapshots.SnapshotStateObserver\nimport androidx.compose.runtime.snapshots.asContextElement\nimport androidx.compose.runtime.snapshotFlow", "newText": "import androidx.compose.runtime.snapshots.SnapshotStateObserver\nimport androidx.compose.runtime.snapshotFlow"}, {"oldText": "import kotlinx.coroutines.withContext\nimport kotlinx.coroutines.withTimeout\nimport kotlinx.coroutines.yield", "newText": "import kotlinx.coroutines.withTimeout\nimport kotlinx.coroutines.yield"}, {"oldText": "    @Test\n    fun snapshotContextElementMaintainsMutableSnapshotAcrossCoroutineSuspensions() = runBlocking {\n        val state = mutableStateOf(\"global\")\n        val snapshot = Snapshot.takeMutableSnapshot()\n\n        try {\n            snapshot.enter {\n                state.value = \"snapshot\"\n            }\n            assertThat(state.value).isEqualTo(\"global\")\n\n            val result = withContext(snapshot.asContextElement()) {\n                val beforeYield = state.value\n                yield()\n                state.value = \"coroutine\"\n                val afterYield = state.value\n\n                \"$beforeYield -> $afterYield\"\n            }\n\n            assertThat(result).isEqualTo(\"snapshot -> coroutine\")\n            assertThat(state.value).isEqualTo(\"global\")\n\n            snapshot.apply().check()\n            assertThat(state.value).isEqualTo(\"coroutine\")\n        } finally {\n            snapshot.dispose()\n        }\n    }\n\n    @Test\n    fun customSnapshotMutationPolicyMergesConcurrentSnapshotWrites() {", "newText": "    @Test\n    fun applyObserverIsNotifiedWhenMutableSnapshotCommitsChanges() {\n        val state = mutableStateOf(\"initial\")\n        val observedValues = mutableListOf<String>()\n        val changedObjectCounts = mutableListOf<Int>()\n        val observerHandle = Snapshot.registerApplyObserver { changedObjects, _ ->\n            changedObjectCounts.add(changedObjects.size)\n     