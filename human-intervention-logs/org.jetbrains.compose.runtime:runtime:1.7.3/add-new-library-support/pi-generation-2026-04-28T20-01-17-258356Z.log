[tool-call] delta {"path":"tests/src/org.jetbrains.compose.runtime/runtime/1.7.3/src/test/kotlin/org_jetbrains_compose_runtime/runtime/RuntimeTest.kt","edits":[{"oldText":"import androidx.compose.runtime.snapshots.Snapshot\nimport androidx.compose.runtime.snapshots.SnapshotStateObserver\nimport androidx.compose.runtime.snapshots.asContextElement\n","newText":"import androidx.compose.runtime.snapshots.Snapshot\nimport androidx.compose.runtime.snapshots.SnapshotStateObserver\n"},{"oldText":"import kotlinx.coroutines.async\nimport kotlinx.coroutines.flow.take\n","newText":"import kotlinx.coroutines.flow.take\n"},{"oldText":"    @Test\n    fun snapshotContextElementPropagatesMutableSnapshotToCoroutines() = runBlocking {\n        val state: MutableState<String> = mutableStateOf(\"global\")\n        val snapshot = Snapshot.takeMutableSnapshot()\n\n        try {\n            val changedInSnapshot = async(snapshot.asContextElement()) {\n                state.value = \"coroutine\"\n                state.value\n            }\n\n            assertThat(changedInSnapshot.await()).isEqualTo(\"coroutine\")\n            assertThat(state.value).isEqualTo(\"global\")\n\n            snapshot.apply().check()\n            assertThat(state.value).isEqualTo(\"coroutine\")\n        } finally {\n            snapshot.dispose()\n        }\n    }\n\n","newText":"    @Test\n    fun applyObserversReceiveChangedStateUntilDisposed() {\n        val state: MutableState<String> = mutableStateOf(\"initial\")\n        val appliedChanges = mutableListOf<Set<Any>>()\n        val observerHandle = Snapshot.registerApplyObserver { changed, _ ->\n            appliedChanges += changed\n        }\n\n        try {\n            Snapshot.withMutableSnapshot {\n                state.value = \"updated\"\n            }\n\n            assertThat(appliedChanges).hasSize(1)\n            assertThat(appliedChanges.single()).contains(state)\n        } finally {\n            observerHandle.dispose()\n        }\n\n        appliedChanges.clear()\n        Snapshot.withMutableSnapshot {\n            state.value = \"ignored\"\n        }\n\n        assertThat(appliedChanges).isEmpty()\n    }\n\n"}]}
[tool-call] end id=call_vpVgMjwE9GPH1wpyX3RYr5zI|fc_0fd9067046ac8e020169f111d552f881928af945ce72782f39 name=edit args={"path": "tests/src/org.jetbrains.compose.runtime/runtime/1.7.3/src/test/kotlin/org_jetbrains_compose_runtime/runtime/RuntimeTest.kt", "edits": [{"oldText": "import androidx.compose.runtime.snapshots.Snapshot\nimport androidx.compose.runtime.snapshots.SnapshotStateObserver\nimport androidx.compose.runtime.snapshots.asContextElement\n", "newText": "import androidx.compose.runtime.snapshots.Snapshot\nimport androidx.compose.runtime.snapshots.SnapshotStateObserver\n"}, {"oldText": "import kotlinx.coroutines.async\nimport kotlinx.coroutines.flow.take\n", "newText": "import kotlinx.coroutines.flow.take\n"}, {"oldText": "    @Test\n    fun snapshotContextElementPropagatesMutableSnapshotToCoroutines() = runBlocking {\n        val state: MutableState<String> = mutableStateOf(\"global\")\n        val snapshot = Snapshot.takeMutableSnapshot()\n\n        try {\n            val changedInSnapshot = async(snapshot.asContextElement()) {\n                state.value = \"coroutine\"\n                state.value\n            }\n\n            assertThat(changedInSnapshot.await()).isEqualTo(\"coroutine\")\n            assertThat(state.value).isEqualTo(\"global\")\n\n            snapshot.apply().check()\n            assertThat(state.value).isEqualTo(\"coroutine\")\n        } finally {\n            snapshot.dispose()\n        }\n    }\n\n", "newText": "    @Test\n    fun applyObserversReceiveChangedStateUntilDisposed() {\n        val state: MutableState<String> = mutableStateOf(\"initial\")\n        val appliedChanges = mutableListOf<Set<Any>>()\n        val observerHandle = Snapshot.registerApplyObserver { changed, _ ->\n            appliedChanges += changed\n        }\n\n        try {\n            Snapshot.withMutableSnapshot {\n                state.value = \"updated\"\n            }\n\n            assertThat(appliedChanges).hasSize(1)\n            assertThat(appliedCh