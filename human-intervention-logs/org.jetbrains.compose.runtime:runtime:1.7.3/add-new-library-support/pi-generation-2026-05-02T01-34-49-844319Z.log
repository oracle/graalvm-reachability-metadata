[tool-call] delta {"path":"tests/src/org.jetbrains.compose.runtime/runtime/1.7.3/src/test/kotlin/org_jetbrains_compose_runtime/runtime/RuntimeTest.kt","edits":[{"oldText":"import androidx.compose.runtime.snapshots.Snapshot\nimport androidx.compose.runtime.snapshots.SnapshotStateObserver\nimport androidx.compose.runtime.snapshotFlow\n","newText":"import androidx.compose.runtime.snapshots.Snapshot\nimport androidx.compose.runtime.snapshots.SnapshotStateObserver\nimport androidx.compose.runtime.snapshots.asContextElement\nimport androidx.compose.runtime.snapshotFlow\n"},{"oldText":"import kotlinx.coroutines.runBlocking\nimport kotlinx.coroutines.withTimeout\n","newText":"import kotlinx.coroutines.runBlocking\nimport kotlinx.coroutines.withContext\nimport kotlinx.coroutines.withTimeout\n"},{"oldText":"    @Test\n    fun snapshotStateObserverInvalidatesOnlyObservedScope() {\n","newText":"    @Test\n    fun snapshotContextElementPropagatesMutableSnapshotAcrossSuspension() = runBlocking {\n        val state = mutableStateOf(\"global\")\n        val snapshot = Snapshot.takeMutableSnapshot()\n\n        try {\n            val observedValues = withContext(snapshot.asContextElement()) {\n                val activeSnapshotBeforeSuspension = Snapshot.current\n                val valueBeforeWrite = state.value\n\n                state.value = \"snapshot-local\"\n                yield()\n\n                val activeSnapshotAfterSuspension = Snapshot.current\n                listOf(\n                    activeSnapshotBeforeSuspension.id,\n                    activeSnapshotAfterSuspension.id,\n                    valueBeforeWrite,\n                    state.value,\n                )\n            }\n\n            assertThat(observedValues).containsExactly(\n                snapshot.id,\n                snapshot.id,\n                \"global\",\n                \"snapshot-local\",\n            )\n            assertThat(state.value).isEqualTo(\"global\")\n\n            snapshot.apply().check()\n            assertThat(state.value).isEqualTo(\"snapshot-local\")\n        } finally {\n            snapshot.dispose()\n        }\n    }\n\n    @Test\n    fun snapshotStateObserverInvalidatesOnlyObservedScope() {\n"}]}
