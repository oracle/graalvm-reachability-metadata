teString(scope, \"\"\"\n                    new JavaAdapter(\n                        java.lang.Runnable,\n                        java.util.concurrent.Callable,\n                        implementation);\n                    \"\"\", \"java-adapter-test\", 1, null);\n\n            assertThat(adapterWrapper).isInstanceOf(Wrapper.class);\n            Object adapter = ((Wrapper) adapterWrapper).unwrap();\n\n            Runnable runnable = Runnable.class.cast(\n                    Context.jsToJava(adapterWrapper, Runnable.class));\n            Callable<?> callable = Callable.class.cast(\n                    Context.jsToJava(adapterWrapper, Callable.class));\n            runnable.run();\n            assertThat(callable.call()).isNull();\n\n            scope.put(\"implementedOperation\", scope,\n                    new NativeJavaClass(scope, ImplementedOperation.class));\n            scope.put(\"operationBase\", scope,\n                    new NativeJavaClass(scope, OperationBase.class));\n            Object operationAdapterWrapper = context.evaluateString(scope, \"\"\"\n                    new JavaAdapter(\n                        operationBase,\n                        implementedOperation,\n                        implementation);\n                    \"\"\", \"java-adapter-operation-test\", 1, null);\n            Object operationAdapter = Context.jsToJava(\n                    operationAdapterWrapper, ImplementedOperation.class);\n            assertThat(operationAdapter).isInstanceOf(ImplementedOperation.class);\n            ImplementedOperation operation = ImplementedOperation.class.cast(operationAdapter);\n            assertThat(operation.operate(\"alpha\")).isEqualTo(\"base:alpha\");\n\n            implementation.setParentScope(null);\n            implementation.setPrototype(null);\n            byte[] serializedAdapter = writeAdapter(adapter);\n            Object restoredAdapter = readAdapter(scope, serializedAdapter);\n\n            assertThat(restoredAdapter)\n                    .isInstanceOf(Runnable.class)\n                    .isInstanceOf(Callable.class);\n            Runnable restoredRunnable = Runnable.class.cast(restoredAdapter);\n            Callable<?> restoredCallable = Callable.class.cast(restoredAdapter);\n            restoredRunnable.run();\n            assertThat(restoredCallable.call()).isNull();\n        } finally {\n            Context.exit();\n        }\n    }\n\n    private static byte[] writeAdapter(Object adapter) throws IOException {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            JavaAdapter.writeAdapterObject(adapter, output);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static Object readAdapter(Scriptable scope, byte[] serializedAdapter)\n            throws IOException, ClassNotFoundException {\n        try (ObjectInputStream input = new ObjectInputStream(\n                new ByteArrayInputStream(serializedAdapter))) {\n            return JavaAdapter.readAdapterObject(scope, input);\n        }\n    }\n\n    public interface ImplementedOperation {\n        String operate(String value);\n    }\n\n    public static class OperationBase {\n        public String operate(String value) {\n            return \"base:\" + value;\n        }\n    }\n}\n","exit_code":0,"status":"completed"}}
