  package org_mozilla.rhino;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import org.junit.jupiter.api.Test;
  import org.mozilla.javascript.Context;
  import org.mozilla.javascript.ContextFactory;
  import org.mozilla.javascript.tools.debugger.Main;
  
  public class ContextTest {
      @SuppressWarnings("deprecation")
      @Test
      void addContextListenerAttachesLegacyDebuggerListener() {
          Main listener = new Main();
  
          Context.addContextListener(listener);
  
          assertThat(listener.attachInvocations()).isEqualTo(1);
          assertThat(listener.attachedFactory()).isSameAs(ContextFactory.getGlobal());
      }
  }
