  package org_mozilla.rhino;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import org.junit.jupiter.api.Test;
  import org.mozilla.javascript.Context;
  import org.mozilla.javascript.ScriptRuntime;
  import org.mozilla.javascript.Scriptable;
  import org.mozilla.javascript.ScriptableObject;
  import org.mozilla.javascript.tools.shell.Global;
  
  public class ScriptRuntimeTest {
      @Test
      void getGlobalCreatesInitializedShellGlobalWhenAvailable() {
          Context context = Context.enter();
          try {
              ScriptableObject global = ScriptRuntime.getGlobal(context);
  
              assertThat(global).isInstanceOf(Global.class);
              Global shellGlobal = (Global) global;
  
              assertThat(shellGlobal.isInitialized()).isTrue();
              assertThat(ScriptableObject.getProperty(global, "print")).isNotSameAs(Scriptable.NOT_FOUND);
          } finally {
              Context.exit();
          }
      }
  }
