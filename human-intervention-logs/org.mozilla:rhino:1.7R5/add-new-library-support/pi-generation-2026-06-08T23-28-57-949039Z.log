ontext.jsToJava(adapterWrapper, Callable.class));\n            runnable.run();\n            assertThat(callable.call()).isNull();\n\n            scope.put(\"implementedOperation\", scope,\n                    new NativeJavaClass(scope, ImplementedOperation.class));\n            scope.put(\"operationBase\", scope,\n                    new NativeJavaClass(scope, OperationBase.class));\n            Object operationAdapterWrapper = context.evaluateString(scope, \"\"\"\n                    new JavaAdapter(\n                        operationBase,\n                        implementedOperation,\n                        implementation);\n                    \"\"\", \"java-adapter-operation-test\", 1, null);\n            Object operationAdapter = Context.jsToJava(\n                    operationAdapterWrapper, ImplementedOperation.class);\n            assertThat(operationAdapter).isInstanceOf(ImplementedOperation.class);\n            ImplementedOperation operation = ImplementedOperation.class.cast(operationAdapter);\n            assertThat(operation.operate(\"alpha\")).isEqualTo(\"base:alpha\");\n\n            implementation.setParentScope(null);\n            implementation.setPrototype(null);\n            byte[] serializedAdapter = writeAdapter(adapter);\n            Object restoredAdapter = readAdapter(scope, serializedAdapter);\n\n            assertThat(restoredAdapter)\n                    .isInstanceOf(Runnable.class)\n                    .isInstanceOf(Callable.class);\n            Runnable restoredRunnable = Runnable.class.cast(restoredAdapter);\n            Callable<?> restoredCallable = Callable.class.cast(restoredAdapter);\n            restoredRunnable.run();\n            assertThat(restoredCallable.call()).isNull();\n        } finally {\n            Context.exit();\n        }\n    }\n\n    private static byte[] writeAdapter(Object adapter) throws IOException {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            JavaAdapter.writeAdapterObject(adapter, output);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static Object readAdapter(Scriptable scope, byte[] serializedAdapter)\n            throws IOException, ClassNotFoundException {\n        try (ObjectInputStream input = new ObjectInputStream(\n                new ByteArrayInputStream(serializedAdapter))) {\n            return JavaAdapter.readAdapterObject(scope, input);\n        }\n    }\n\n    public interface ImplementedOperation {\n        String operate(String value);\n    }\n\n    public static class OperationBase {\n        public String operate(String value) {\n            return \"base:\" + value;\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1780961043635}, {"role": "toolResult", "toolCallId": "call_0lB4gjwPpxgNhzuLvU2NeU6y|fc_0f94c8a518926ae0016a274f134eac8196b98be6cf4e4aa2de", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_mozilla.rhino;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\nimport org.mozilla.javascript.CompilerEnvirons;\nimport org.mozilla.javascript.Context;\nimport org.mozilla.javascript.ContextFactory;\nimport org.mozilla.javascript.ContextListener;\nimport org.mozilla.javascript.GeneratedClassLoader;\nimport org.mozilla.javascript.optimizer.ClassCompiler;\n\npublic class ContextTest {\n    private static final String DEBUGGER_MAIN_CLASS_NAME =\n            \"org.mozilla.javascript.tools.debugger.Main\";\n\n    private static final String DEBUGGER_SOURCE = \"\"\"\n            function contextEntered(context) {}\n            function contextExited(context) {}\n            function contextCreated(context) {}\n            function contextReleased(context) {}\n            \"\"\";\n\n    @Test\n    @SuppressWarnings(\"deprecation\")\n    void addContextListenerAttachesDebuggerCompatibilityListener() throws Exception {\n        DebuggerRecorder.reset();\n        try {\n            Context context = Context.enter();\n            try {\n                Class<?> debuggerClass = compileDebuggerCompatibilityListener(context);\n                ContextListener listener = (ContextListener) debuggerClass\n                        .getDeclaredConstructor()\n                        .newInstance();\n\n                Context.addContextListener(listener);\n\n                assertThat(DebuggerRecorder.attachedFactory)\n                        .isSameAs(ContextFactory.getGlobal());\n                assertThat(DebuggerRecorder.attachCount).isEqualTo(1);\n            } finally {\n                Context.exit();\n            }\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    private static Class<?> compileDebuggerCompatibilityListener(Context context) {\n        CompilerEnvirons compilerEnvirons = new CompilerEnvirons();\n        compilerEnvirons.initFromContext(context);\n\n        ClassCompiler compiler = new ClassCompiler(compilerEnvirons);\n        compiler.setTargetExtends(DebuggerCompatibilityBase.class);\n        compiler.setTargetImplements(new Class<?>[] {ContextListener.class});\n\n        Object[] classFiles = compiler.compileToClassFiles(\n                DEBUGGER_SOURCE, \"debugger-compatibility-listener.js\", 1, DEBUGGER_MAIN_CLASS_NAME);\n        GeneratedClassLoader loader = context.createClassLoader(ContextTest.class.getClassLoader());\n        Class<?> debuggerClass = null;\n        Class<?>[] definedClasses = new Class<?>[classFiles.length / 2];\n        for (int index = 0; index < classFiles.length; index += 2) {\n            String className = (String) classFiles[index];\n            byte[] bytecode = (byte[]) classFiles[index + 1];\n            Class<?> definedClass = loader.defineClass(className, bytecode);\n            definedClasses[index / 2] = definedClass;\n            if (DEBUGGER_MAIN_CLASS_NAME.equals(className)) {\n                debuggerClass = definedClass;\n            }\n        }\n        for (Class<?> definedClass : definedClasses) {\n            loader.linkClass(definedClass);\n        }\n        return debuggerClass;\n    }\n\n    public static class DebuggerCompatibilityBase {\n        public void attachTo(ContextFactory factory) {\n            DebuggerRecorder.attached(factory);\n        }\n    }\n\n    public static final class DebuggerRecorder {\n        private static ContextFactory attachedFactory;\n        private static int attachCount;\n\n        private DebuggerRecorder() {\n        }\n\n        public static void reset() {\n            attachedFactory = null;\n            attachCount = 0;\n        }\n\n        public static void attached(ContextFactory factory) {\n            attachedFactory = factory;\n            attachCount++;\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1780961043635}, {"role": "toolResult", "toolCallId": "call_AzzsZ2BzhymJPJzNoQEyBQ72|fc_0f94c8a518926ae0016a274f134eb48196b7fe8f178f77684c", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\nplugins {\n    id \"org.graalvm.internal.tck\"\n}\n\nString libraryVersion = tck.testedLibraryVersion.get()\n\nconfigurations {\n    jlineVersion1\n}\n\ndependencies {\n    testImplementation \"org.mozilla:rhino:$libraryVersion\"\n    testImplementation 'jline:jline:2.14.6'\n    testImplementation 'org.assertj:assertj-core:3.22.0'\n\n    jlineVersion1 'jline:jline:1.0'\n}\n