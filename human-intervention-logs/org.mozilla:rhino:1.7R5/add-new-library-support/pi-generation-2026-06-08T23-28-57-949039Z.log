fix) {\n            return prefix + \":\" + label + \":\" + count;\n        }\n    }\n\n    public interface RestrictedInterface {\n        static String publicStaticValue() {\n            return \"public\";\n        }\n\n        private String privateValue() {\n            return \"private\";\n        }\n    }\n\n    @SuppressWarnings(\"removal\")\n    private static boolean installReflectAccessDenyingSecurityManager(\n            SecurityManager previousSecurityManager) {\n        if (previousSecurityManager != null) {\n            return false;\n        }\n        try {\n            System.setSecurityManager(new DeclaredAccessDenyingSecurityManager());\n            return true;\n        } catch (UnsupportedOperationException | SecurityException exception) {\n            return false;\n        }\n    }\n\n    @SuppressWarnings(\"removal\")\n    private static final class DeclaredAccessDenyingSecurityManager extends SecurityManager {\n        @Override\n        public void checkPermission(Permission permission) {\n            denyDeclaredAccess(permission);\n        }\n\n        @Override\n        public void checkPermission(Permission permission, Object context) {\n            denyDeclaredAccess(permission);\n        }\n\n        private void denyDeclaredAccess(Permission permission) {\n            if (permission instanceof ReflectPermission\n                    && \"suppressAccessChecks\".equals(permission.getName())) {\n                throw new SecurityException(permission.getName());\n            }\n            if (permission instanceof RuntimePermission\n                    && \"accessDeclaredMembers\".equals(permission.getName())) {\n                throw new SecurityException(permission.getName());\n            }\n        }\n    }\n\n    private static final class EnhancedJavaAccessContextFactory extends ContextFactory {\n        @Override\n        protected boolean hasFeature(Context context, int featureIndex) {\n            if (featureIndex == Context.FEATURE_ENHANCED_JAVA_ACCESS) {\n                return true;\n            }\n            return super.hasFeature(context, featureIndex);\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1780961201129}]}
