[tool-call] delta {"path":"tests/src/org.mozilla/rhino/1.7R5/src/test/java/org_mozilla/rhino/SecureCallerAnonymous2Test.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_mozilla.rhino;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.net.URL;\nimport java.security.CodeSource;\nimport java.security.cert.Certificate;\nimport java.util.concurrent.atomic.AtomicInteger;\n\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\nimport org.mozilla.javascript.Callable;\nimport org.mozilla.javascript.Context;\nimport org.mozilla.javascript.ContextFactory;\nimport org.mozilla.javascript.Scriptable;\nimport org.mozilla.javascript.ScriptableObject;\n\npublic class SecureCallerAnonymous2Test {\n    @Test\n    void enhancedJavaAccessInvokesSecureCallerWithCodeSource() throws Exception {\n        try {\n            exerciseSecureCaller();\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    private static void exerciseSecureCaller() throws Exception {\n        AtomicInteger callCount = new AtomicInteger();\n        CodeSource codeSource = new CodeSource(\n                new URL(\"file:/secure-caller-test.js\"), (Certificate[]) null);\n        Object[] arguments = {\"alpha\", 7};\n\n        Object result = new EnhancedJavaAccessContextFactory().call(context -> {\n            Scriptable scope = context.initStandardObjects();\n            Callable callable = (callContext, callScope, thisObject, callArguments) -> {\n                assertThat(callContext).isSameAs(context);\n                assertThat(callScope).isSameAs(scope);\n                assertThat(thisObject).isSameAs(scope);\n                callCount.incrementAndGet();\n                return callArguments[0] + \":\" + callArguments[1];\n            };\n\n            ScriptableObject.putProperty(scope, \"codeSource\", codeSource);\n            ScriptableObject.putProperty(scope, \"callable\", callable);\n            ScriptableObject.putProperty(scope, \"context\", context);\n            ScriptableObject.putProperty(scope, \"scope\", scope);\n            ScriptableObject.putProperty(scope, \"callArguments\", arguments);\n\n            return context.evaluateString(scope, \"\"\"\n                    Packages.org.mozilla.javascript.SecureCaller.callSecurely(\n                        codeSource, callable, context, scope, scope, callArguments);\n                    \"\"\", \"secure-caller-test.js\", 1, null);\n        });\n\n        assertThat(Context.toString(result)).isEqualTo(\"alpha:7\");\n        assertThat(callCount).hasValue(1);\n    }\n\n    private static final class EnhancedJavaAccessContextFactory extends ContextFactory {\n        @Override\n        protected boolean hasFeature(Context context, int featureIndex) {\n            if (featureIndex == Context.FEATURE_ENHANCED_JAVA_ACCESS) {\n                return true;\n            }\n            return super.hasFeature(context, featureIndex);\n        }\n    }\n}\n"}
[tool-call] end id=call_vZhGBcZGhvOG5aW1a4Zbz6t0|fc_0f94c8a518926ae0016a274febcd088196badf4b0d7a634ca2 name=write args={"path": "tests/src/org.mozilla/rhino/1.7R5/src/test/java/org_mozilla/rhino/SecureCallerAnonymous2Test.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_mozilla.rhino;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.net.URL;\nimport java.security.CodeSource;\nimport java.security.cert.Certificate;\nimport java.util.concurrent.atomic.AtomicInteger;\n\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\nimport org.mozilla.javascript.Callable;\nimport org.mozilla.javascript.Context;\nimport org.mozilla.javascript.ContextFactory;\nimport org.mozilla.javascript.Scriptable;\nimport org.mozilla.javascript.ScriptableObject;\n\npublic class SecureCallerAnonymous2Test {\n    @Test\n    void enhancedJavaAccessInvokesSecureCallerWithCodeSource() throws Exception {\n        try {\n            exerciseSecureCaller();\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    private static void exerciseSecureCaller() throws Exception {\n        AtomicInteger callCount = new AtomicInteger();\n        CodeSource codeSource = new CodeSource(\n                new URL(\"file:/secure-caller-test.js\"), (Certificate[]) null);\n        Object[] arguments = {\"alpha\", 7};\n\n        Object result = new EnhancedJavaAccessContextFactory().call(context -> {\n            Scriptable scope = context.initStandardObjects();\n            Callable callable = (callContext, callScope, thisObject, callArguments) -> {\n                assertThat(callContext).isSameAs(context);\n                assertThat(callScope).isSameAs(scope);\n                assertThat(thisObject).isSameAs(scope);\n                callCount.incrementAndGet();\n                return callArguments[0] + \":\" + callArguments[1];\n            };\n\n            ScriptableObject.putProperty(scope, \"codeSource\", codeSource);\n            ScriptableObject.putProperty(scope, \"callable\", callable);\n            ScriptableObject.putProperty(scope, \"context\", context);\n            ScriptableObject.putProperty(scope, \"scope\", scope);\n            ScriptableObject.putProperty(scope, \"callArguments\", arguments);\n\n            return context.evaluateString(scope, \"\"\"\n                    Packages.org.mozilla.javascript.SecureCaller.callSecurely(\n                        codeSource, callable, context, scope, scope, callArguments);\n                    \"\"\", \"secure-caller-test.js\", 1, null);\n        });\n\n        assertThat(Context.toString(result)).isEqualTo(\"alpha:7\");\n        assertThat(callCount).hasValue(1);\n    }\n\n    private static final class EnhancedJavaAccessContextFactory extends ContextFactory {\n        @Override\n        protected boolean hasFeature(Context context, int featureIndex) {\n            if (featureIndex == Context.FEATURE_ENHANCED_JAVA_ACCESS) {\n                return true;\n            }\n            return super.hasFeature(context, featureIndex);\n        }\n    }\n}\n"}
