[tool-call] delta {"path":"tests/src/org.mozilla/rhino/1.7R5/src/test/java/org_mozilla/rhino/DelegatorTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_mozilla.rhino;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport org.junit.jupiter.api.Test;\nimport org.mozilla.javascript.Context;\nimport org.mozilla.javascript.Delegator;\nimport org.mozilla.javascript.Scriptable;\n\npublic class DelegatorTest {\n    @Test\n    void constructOnPrototypeCreatesNewDelegatorWithNativeObjectDelegee() {\n        Context context = Context.enter();\n        try {\n            Scriptable scope = context.initStandardObjects();\n            Delegator prototype = new Delegator();\n\n            Scriptable constructed = prototype.construct(context, scope, new Object[0]);\n\n            assertThat(constructed).isInstanceOf(Delegator.class);\n            assertThat(constructed).isNotSameAs(prototype);\n\n            Delegator delegator = (Delegator) constructed;\n            assertThat(delegator.getDelegee()).isNotNull();\n\n            delegator.put(\"answer\", delegator, 42);\n            assertThat(delegator.get(\"answer\", delegator)).isEqualTo(42);\n        } finally {\n            Context.exit();\n        }\n    }\n}\n"}
