          // overrides.
          ObjToIntMap.Iterator iter = new ObjToIntMap.Iterator(functionNames);
          for (iter.start(); !iter.done(); iter.next()) {
              String functionName = (String)iter.getKey();
              if (generatedMethods.has(functionName))
                  continue;
