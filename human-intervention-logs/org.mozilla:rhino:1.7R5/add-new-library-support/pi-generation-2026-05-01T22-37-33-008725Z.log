  package org_mozilla.rhino;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  import org.mozilla.javascript.Context;
  import org.mozilla.javascript.ContextFactory;
  import org.mozilla.javascript.Scriptable;
  import org.mozilla.javascript.ScriptableObject;
  import org.mozilla.javascript.serialize.ScriptableInputStream;
  import org.mozilla.javascript.serialize.ScriptableOutputStream;
  
  public class JavaAdapterTest {
      @Test
      void createsAdapterForInterfaceAndOverridableSuperclassMethods() throws Exception {
          runAllowingNativeImageUnsupportedClassGeneration(() -> {
              Context context = ContextFactory.getGlobal().enterContext();
              try {
                  Scriptable scope = context.initStandardObjects();
                  String source = """
                          var adapter = new JavaAdapter(Packages.%s, java.lang.Comparable, {
                              greet: function(name) {
                                  return 'hello, ' + name;
                              }
                          });
                          adapter.greet('rhino') + ':' + adapter.compareTo('ignored');
                          """.formatted(ComparableGreeter.class.getName());
  
                  Object result = context.evaluateString(scope, source, "java-adapter-create", 1, null);
  
                  assertThat(Context.toString(result)).isEqualTo("hello, rhino:7");
              } finally {
                  Context.exit();
              }
          });
      }
  
      @Test
      void serializesAndRestoresAdapterWrapper() throws Exception {
          runAllowingNativeImageUnsupportedClassGeneration(() -> {
              Context context = ContextFactory.getGlobal().enterContext();
              context.setOptimizationLevel(-1);
              try {
                  Scriptable scope = context.initStandardObjects();
                  Scriptable adapter = (Scriptable) context.evaluateString(scope, """
                          new JavaAdapter(java.lang.Runnable, {
                              count: 0,
                              run: function() {
                                  this.count = this.count + 1;
                              },
                              value: function() {
                                  return this.count;
                              }
                          });
                          """, "java-adapter-serialize", 1, null);
  
                  ByteArrayOutputStream buffer = new ByteArrayOutputStream();
                  try (ScriptableOutputStream output = new ScriptableOutputStream(buffer, scope)) {
                      output.writeObject(adapter);
                  }
  
                  Object restored;
                  try (ScriptableInputStream input = new ScriptableInputStream(
                          new ByteArrayInputStream(buffer.toByteArray()),
                          scope
                  )) {
                      restored = input.readObject();
                  }
  
                  ScriptableObject.putProperty(scope, "adapter", restored);
                  Object result = context.evaluateString(scope, """
                          adapter.run();
                          adapter.run();
                          adapter.value();
                          """, "java-adapter-restored", 1, null);
  
                  assertThat(Context.toNumber(result)).isEqualTo(2.0d);
              } finally {
                  Context.exit();
              }
          });
      }
  
      @FunctionalInterface
      private interface ThrowingRunnable {
          void run() throws Exception;
      }
  
