     Context context = ContextFactory.getGlobal().enterContext();\n            try {\n                Scriptable scope = context.initStandardObjects();\n                Object[] arguments = new Object[] {\"payload\"};\n                Callable callable = (cx, callableScope, thisObject, args) -> {\n                    assertThat(cx).isSameAs(context);\n                    assertThat(callableScope).isSameAs(scope);\n                    assertThat(thisObject).isSameAs(scope);\n                    assertThat(args).containsExactly(\"payload\");\n                    return \"called securely\";\n                };\n                CodeSource codeSource = new CodeSource(\n                        new URL(\"file:/rhino-secure-caller-test.js\"),\n                        (Certificate[]) null\n                );\n\n                Object result = callSecurely(codeSource, callable, context, scope, scope, arguments);\n\n                assertThat(result).isEqualTo(\"called securely\");\n            } finally {\n                Context.exit();\n            }\n        });\n    }\n\n    private static Object callSecurely(\n            CodeSource codeSource,\n            Callable callable,\n            Context context,\n            Scriptable scope,\n            Scriptable thisObject,\n            Object[] arguments\n    ) throws Throwable {\n        MethodHandle methodHandle = MethodHandles.privateLookupIn(SecureCaller.class, MethodHandles.lookup())\n                .findStatic(SecureCaller.class, \"callSecurely\", methodType(\n                        Object.class,\n                        CodeSource.class,\n                        Callable.class,\n                        Context.class,\n                        Scriptable.class,\n                        Scriptable.class,\n                        Object[].class\n                ));\n        return (Object) methodHandle.invokeExact(codeSource, callable, context, scope, thisObject, arguments);\n    }\n\n    @FunctionalInterface\n    private interface ThrowingRunnable {\n        void run() throws Throwable;\n    }\n\n    private static void runAllowingNativeImageUnsupportedClassGeneration(ThrowingRunnable action) throws Throwable {\n        try {\n            action.run();\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 495, "output": 1114, "cacheRead": 39936, "cacheWrite": 0, "totalTokens": 41545, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777674722636, "responseId": "resp_0363e61edc4a913f0169f529e31a8481a2a4a5b944fdae23b7"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_KkL1eLwmuw7CPPgzFkamloZg|fc_0363e61edc4a913f0169f529ea10dc81a29936994c34232340", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 3360 bytes to tests/src/org.mozilla/rhino/1.7R5/src/test/java/org_mozilla/rhino/SecureCallerAnonymous2Test.java"}], "isError": false, "timestamp": 1777674734834}]}
