  package org_mozilla.rhino;
  
  import static java.lang.invoke.MethodType.methodType;
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.lang.invoke.MethodHandle;
  import java.lang.invoke.MethodHandles;
  import java.net.URL;
  import java.security.CodeSource;
  import java.security.cert.Certificate;
  
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  import org.mozilla.javascript.Callable;
  import org.mozilla.javascript.Context;
  import org.mozilla.javascript.ContextFactory;
  import org.mozilla.javascript.Scriptable;
  import org.mozilla.javascript.SecureCaller;
  
  public class SecureCallerAnonymous2Test {
      @Test
      void createsSecureCallerForCodeSourceAndInvokesCallable() throws Throwable {
          runAllowingNativeImageUnsupportedClassGeneration(() -> {
              Context context = ContextFactory.getGlobal().enterContext();
              try {
                  Scriptable scope = context.initStandardObjects();
                  Object[] arguments = new Object[] {"payload"};
                  Callable callable = (cx, callableScope, thisObject, args) -> {
                      assertThat(cx).isSameAs(context);
                      assertThat(callableScope).isSameAs(scope);
                      assertThat(thisObject).isSameAs(scope);
                      assertThat(args).containsExactly("payload");
                      return "called securely";
                  };
                  CodeSource codeSource = new CodeSource(
                          new URL("file:/rhino-secure-caller-test.js"),
                          (Certificate[]) null
                  );
  
                  Object result = callSecurely(codeSource, callable, context, scope, scope, arguments);
  
                  assertThat(result).isEqualTo("called securely");
              } finally {
                  Context.exit();
              }
          });
      }
  
      private static Object callSecurely(
              CodeSource codeSource,
              Callable callable,
              Context context,
              Scriptable scope,
              Scriptable thisObject,
              Object[] arguments
      ) throws Throwable {
          MethodHandle methodHandle = MethodHandles.privateLookupIn(SecureCaller.class, MethodHandles.lookup())
                  .findStatic(SecureCaller.class, "callSecurely", methodType(
                          Object.class,
                          CodeSource.class,
                          Callable.class,
                          Context.class,
                          Scriptable.class,
                          Scriptable.class,
                          Object[].class
                  ));
          return (Object) methodHandle.invokeExact(codeSource, callable, context, scope, thisObject, arguments);
      }
  
      @FunctionalInterface
      private interface ThrowingRunnable {
          void run() throws Throwable;
      }
  
      private static void runAllowingNativeImageUnsupportedClassGeneration(ThrowingRunnable action) throws Throwable {
          try {
              action.run();
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
      }
  }
