      public static Object call(ContextFactory factory, final Callable callable,
                                final Scriptable scope, final Scriptable thisObj,
                                final Object[] args)
      {
          if(factory == null) {
              factory = ContextFactory.getGlobal();
          }
          return call(factory, new ContextAction() {
