  package org_mozilla.rhino;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import org.junit.jupiter.api.Test;
  import org.mozilla.javascript.Context;
  import org.mozilla.javascript.FunctionObject;
  import org.mozilla.javascript.Scriptable;
  import org.mozilla.javascript.ScriptableObject;
  
  public class ScriptableObjectTest {
      @Test
      void invokesThreeArgumentStaticInitializerWhenDefiningScriptableClass() throws Exception {
          ThreeArgumentInitScriptable.reset();
  
          Context context = Context.enter();
          try {
              Scriptable scope = context.initStandardObjects();
  
              ScriptableObject.defineClass(scope, ThreeArgumentInitScriptable.class, true);
  
              assertThat(ThreeArgumentInitScriptable.initialized).isTrue();
              assertThat(ThreeArgumentInitScriptable.context).isSameAs(context);
              assertThat(ThreeArgumentInitScriptable.scope).isSameAs(scope);
              assertThat(ThreeArgumentInitScriptable.sealed).isTrue();
              assertThat(ScriptableObject.getProperty(scope, "threeArgumentInit"))
                      .isEqualTo("initialized");
          } finally {
              Context.exit();
          }
      }
  
      @Test
      void invokesOneArgumentStaticInitializerWhenDefiningScriptableClass() throws Exception {
          OneArgumentInitScriptable.reset();
  
          Context context = Context.enter();
          try {
              Scriptable scope = context.initStandardObjects();
  
              ScriptableObject.defineClass(scope, OneArgumentInitScriptable.class);
  
              assertThat(OneArgumentInitScriptable.initialized).isTrue();
              assertThat(OneArgumentInitScriptable.scope).isSameAs(scope);
              assertThat(ScriptableObject.getProperty(scope, "oneArgumentInit"))
                      .isEqualTo("initialized");
          } finally {
              Context.exit();
          }
      }
  
      @Test
      void buildsConstructorFromScriptableClassAndCallsFinishInit() throws Exception {
          FinishInitScriptable.reset();
  
          Context context = Context.enter();
          try {
              Scriptable scope = context.initStandardObjects();
  
              ScriptableObject.defineClass(scope, FinishInitScriptable.class);
  
              Object constructorObject = ScriptableObject.getProperty(scope, "FinishInitScriptable");
              Scriptable prototype = ScriptableObject.getClassPrototype(scope, "FinishInitScriptable");
  
              assertThat(constructorObject).isInstanceOf(FunctionObject.class);
              assertThat(prototype).isInstanceOf(FinishInitScriptable.class);
              assertThat(FinishInitScriptable.prototypeInstances).isEqualTo(1);
              assertThat(FinishInitScriptable.finishInitCalled).isTrue();
              assertThat(FinishInitScriptable.finishInitScope).isSameAs(scope);
              assertThat(FinishInitScriptable.finishInitConstructor).isSameAs(constructorObject);
              assertThat(FinishInitScriptable.finishInitPrototype).isSameAs(prototype);
              assertThat(ScriptableObject.getProperty((Scriptable) constructorObject, "createdByFinishInit"))
                      .isEqualTo(Boolean.TRUE);
              assertThat(ScriptableObject.getProperty(prototype, "finishInitMarker"))
                      .isEqualTo("ready");
          } finally {
              Context.exit();
          }
      }
  
      public static class ThreeArgumentInitScriptable extends ScriptableObject {
          static boolean initialized;
          static Context context;
          static Scriptable scope;
          static boolean sealed;
  
          static void reset() {
              initialized = false;
              context = null;
              scope = null;
              sealed = false;
          }
  
          public ThreeArgumentInitScriptable() {
          }
  
          public static void init(Context context, Scriptable scope, boolean sealed) {
              ThreeArgumentInitScriptable.initialized = true;
              ThreeArgumentInitScriptable.context = context;
              ThreeArgumentInitScriptable.scope = scope;
              ThreeArgumentInitScriptable.sealed = sealed;
              ScriptableObject.putProperty(scope, "threeArgumentInit", "initialized");
          }
  
          @Override
          public String getClassName() {
              return "ThreeArgumentInitScriptable";
