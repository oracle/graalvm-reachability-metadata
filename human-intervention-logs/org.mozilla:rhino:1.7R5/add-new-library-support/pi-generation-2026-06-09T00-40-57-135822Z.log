  package org_mozilla.rhino;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.IOException;
  import java.lang.management.ManagementFactory;
  import java.lang.reflect.ReflectPermission;
  import java.nio.charset.StandardCharsets;
  import java.nio.file.Files;
  import java.nio.file.Path;
  import java.security.Permission;
  import java.util.ArrayList;
  import java.util.LinkedHashSet;
  import java.util.List;
  import java.util.Set;
  import java.util.concurrent.TimeUnit;
  
  import org.junit.jupiter.api.Test;
  import org.mozilla.javascript.Context;
  import org.mozilla.javascript.ScriptableObject;
  
  public class FunctionObjectTest {
      private static final String FORKED_SCENARIO_ARGUMENT = "runSecurityManagerScenario";
  
      @Test
      @SuppressWarnings("removal")
      void definesFunctionPropertiesAndUsesPublicMethodFallbackWhenAvailable() throws Exception {
          if (!runSecurityManagerScenario()) {
              runForkedSecurityManagerScenarioIfPossible();
          }
      }
  
      public static void main(String[] arguments) {
          if (arguments.length != 1 || !FORKED_SCENARIO_ARGUMENT.equals(arguments[0])) {
              throw new IllegalArgumentException("Unexpected arguments");
          }
          if (!runSecurityManagerScenario()) {
              throw new IllegalStateException("SecurityManager could not be installed");
          }
      }
  
      @SuppressWarnings("removal")
      private static boolean runSecurityManagerScenario() {
          Context context = Context.enter();
          try {
              ScriptableObject scope = (ScriptableObject) context.initStandardObjects();
              SecurityManager previousSecurityManager = System.getSecurityManager();
              boolean securityManagerInstalled = installReflectAccessDenyingSecurityManager(
                      previousSecurityManager);
              try {
                  defineAndCallFunctionProperty(context, scope);
                  return securityManagerInstalled;
              } finally {
                  if (securityManagerInstalled) {
                      System.setSecurityManager(previousSecurityManager);
                  }
              }
          } finally {
              Context.exit();
          }
      }
  
      private static void defineAndCallFunctionProperty(Context context, ScriptableObject scope) {
          scope.defineFunctionProperties(
                  new String[] {"fallbackGreeting"},
                  PublicFunctions.class,
                  ScriptableObject.DONTENUM);
  
          Object result = ScriptableObject.callMethod(
                  context, scope, "fallbackGreeting", new Object[] {"Rhino"});
          String greeting = Context.toString(result);
          if (!"hello Rhino".equals(greeting)) {
              throw new AssertionError("Unexpected greeting: " + greeting);
          }
      }
  
      private static void runForkedSecurityManagerScenarioIfPossible() throws Exception {
          if (currentJavaAgentArguments().isEmpty()) {
              return;
          }
          List<String> unsupportedOutputs = new ArrayList<>();
          for (Path javaExecutable : candidateJavaExecutables()) {
              ForkResult result = runForkedSecurityManagerScenario(javaExecutable);
              if (result.exitCode() == 0) {
                  return;
              }
              if (isUnsupportedSecurityManagerStartup(result.output())
                      || isUnsupportedClassVersion(result.output())) {
                  unsupportedOutputs.add(result.output());
                  continue;
              }
              assertThat(result.exitCode()).as(result.output()).isZero();
          }
          assertThat(unsupportedOutputs).isNotEmpty();
      }
  
      private static ForkResult runForkedSecurityManagerScenario(Path javaExecutable)
              throws Exception {
          Process process = new ProcessBuilder(forkedJavaCommand(javaExecutable))
                  .redirectErrorStream(true)
                  .start();
          boolean completed = process.waitFor(30, TimeUnit.SECONDS);
          if (!completed) {
              process.destroyForcibly();
          }
          String output = readProcessOutput(process);
  
          assertThat(completed).as(output).isTrue();
          return new ForkResult(process.exitValue(), output);
      }
  
      private static List<String> forkedJavaCommand(Path javaExecutable) {
          List<String> command = new ArrayList<>();
          command.add(javaExecutable.toString());
          command.addAll(currentJavaAgentArguments());
          command.add("-Djava.security.manager=allow");
          command.add("-cp");
          command.add(System.getProperty("java.class.path"));
          command.add(FunctionObjectTest.class.getName());
          command.add(FORKED_SCENARIO_ARGUMENT);
          return command;
      }
  
      private static List<String> currentJavaAgentArguments() {
          return ManagementFactory.getRuntimeMXBean().getInputArguments().stream()
                  .filter(argument -> argument.startsWith("-javaagent:"))
                  .toList();
      }
  
      private static Set<Path> candidateJavaExecutables() throws IOException {
          Set<Path> executables = new LinkedHashSet<>();
          addJavaExecutable(executables, Path.of(System.getProperty("java.home")));
          String javaHome = System.getenv("JAVA_HOME");
          if (javaHome != null && !javaHome.isBlank()) {
              addJavaExecutable(executables, Path.of(javaHome));
          }
          addSiblingJavaExecutables(executables, Path.of(System.getProperty("java.home")));
          addJavaHomes(executables, Path.of("/usr/lib/jvm"));
          return executables;
      }
  
      private static void addSiblingJavaExecutables(Set<Path> executables, Path javaHome)
              throws IOException {
          Path parent = javaHome.getParent();
          if (parent != null) {
              addJavaHomes(executables, parent);
          }
      }
  
      private static void addJavaHomes(Set<Path> executables, Path parent) throws IOException {
          if (!Files.isDirectory(parent)) {
              return;
          }
          try (var children = Files.list(parent)) {
              for (Path child : children.toList()) {
                  addJavaExecutable(executables, child);
              }
          }
      }
  
      private static void addJavaExecutable(Set<Path> executables, Path javaHome) {
          Path javaExecutable = javaHome.resolve("bin").resolve("java");
          if (Files.isExecutable(javaExecutable)) {
              executables.add(javaExecutable);
          }
      }
  
      private static String readProcessOutput(Process process) throws IOException {
          return new String(process.getInputStream().readAllBytes(), StandardCharsets.UTF_8);
      }
  
      private static boolean isUnsupportedSecurityManagerStartup(String output) {
          return output.contains("Enabling a Security Manager is not supported")
                  || output.contains("Setting a Security Manager is not supported");
      }
  
      private static boolean isUnsupportedClassVersion(String output) {
          return output.contains("UnsupportedClassVersionError");
      }
  
      public static final class PublicFunctions {
          private PublicFunctions() {
          }
  
          public static String fallbackGreeting(String name) {
              return "hello " + name;
          }
      }
  
      @SuppressWarnings("removal")
      private static boolean installReflectAccessDenyingSecurityManager(
              SecurityManager previousSecurityManager) {
          if (previousSecurityManager != null) {
              return false;
          }
          try {
              System.setSecurityManager(new DeclaredAccessDenyingSecurityManager());
              return true;
          } catch (UnsupportedOperationException | SecurityException exception) {
              return false;
          }
      }
  
      @SuppressWarnings("removal")
      private static final class DeclaredAccessDenyingSecurityManager extends SecurityManager {
          @Override
          public void checkPermission(Permission permission) {
              denyDeclaredAccess(permission);
          }
  
          @Override
          public void checkPermission(Permission permission, Object context) {
              denyDeclaredAccess(permission);
          }
  
          private void denyDeclaredAccess(Permission permission) {
              if (permission instanceof ReflectPermission
                      && "suppressAccessChecks".equals(permission.getName())) {
                  throw new SecurityException(permission.getName());
              }
              if (permission instanceof RuntimePermission
                      && "accessDeclaredMembers".equals(permission.getName())) {
                  throw new SecurityException(permission.getName());
              }
          }
      }
  }
