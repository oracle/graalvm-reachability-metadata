  package org_mozilla.rhino.tools.jsc;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.Serializable;
  import java.util.ArrayList;
  
  import org.junit.jupiter.api.Test;
  import org.mozilla.javascript.tools.jsc.Main;
  
  public class MainTest {
      @Test
      void processOptionsLoadsConfiguredSuperclassAndInterfaces() {
          Main main = new Main();
  
          String[] sourceFiles = main.processOptions(new String[] {
                  "-extends",
                  ArrayList.class.getName(),
                  "-implements",
                  Runnable.class.getName() + "," + Serializable.class.getName(),
                  "script.js"
          });
  
          assertThat(sourceFiles).containsExactly("script.js");
      }
