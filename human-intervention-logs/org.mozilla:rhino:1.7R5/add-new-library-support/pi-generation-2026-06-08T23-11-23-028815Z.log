  package org_mozilla.rhino;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import org.junit.jupiter.api.Test;
  import org.mozilla.javascript.Context;
  import org.mozilla.javascript.ContextFactory;
  import org.mozilla.javascript.ContextListener;
  
  public class ContextTest {
      @Test
      @SuppressWarnings("deprecation")
      void addContextListenerRegistersCreationAndReleaseCallbacks() {
          RecordingContextListener listener = new RecordingContextListener();
          Context.addContextListener(listener);
          try {
              Context context = Context.enter();
              try {
                  assertThat(listener.createdContext).isSameAs(context);
                  assertThat(listener.createdCount).isEqualTo(1);
              } finally {
                  Context.exit();
              }
  
              assertThat(listener.releasedContext).isSameAs(context);
              assertThat(listener.releasedCount).isEqualTo(1);
          } finally {
              ContextFactory.getGlobal().removeListener(listener);
          }
      }
  
      private static final class RecordingContextListener implements ContextListener {
          private Context createdContext;
          private Context releasedContext;
          private int createdCount;
          private int releasedCount;
  
          @Override
          public void contextEntered(Context context) {
              // Rhino keeps this legacy callback for compatibility only.
          }
  
          @Override
          public void contextExited(Context context) {
              // Rhino keeps this legacy callback for compatibility only.
          }
  
          @Override
          public void contextCreated(Context context) {
              createdContext = context;
              createdCount++;
          }
  
          @Override
          public void contextReleased(Context context) {
              releasedContext = context;
              releasedCount++;
          }
      }
  }
