  package org_mozilla.rhino;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  import org.mozilla.javascript.CompilerEnvirons;
  import org.mozilla.javascript.Context;
  import org.mozilla.javascript.ContextFactory;
  import org.mozilla.javascript.ContextListener;
  import org.mozilla.javascript.GeneratedClassLoader;
  import org.mozilla.javascript.optimizer.ClassCompiler;
  
  public class ContextTest {
      private static final String DEBUGGER_MAIN_CLASS_NAME = "org.mozilla.javascript.tools.debugger.Main";
  
      private static final String DEBUGGER_SOURCE = """
              function contextEntered(context) {}
              function contextExited(context) {}
              function contextCreated(context) {}
              function contextReleased(context) {}
              """;
  
      @Test
      @SuppressWarnings("deprecation")
      void addContextListenerAttachesDebuggerCompatibilityListener() throws Exception {
          DebuggerRecorder.reset();
          try {
              Context context = Context.enter();
              try {
                  Class<?> debuggerClass = compileDebuggerCompatibilityListener(context);
                  ContextListener listener = (ContextListener) debuggerClass
                          .getDeclaredConstructor()
                          .newInstance();
  
                  Context.addContextListener(listener);
  
                  assertThat(DebuggerRecorder.attachedFactory)
                          .isSameAs(ContextFactory.getGlobal());
                  assertThat(DebuggerRecorder.attachCount).isEqualTo(1);
              } finally {
                  Context.exit();
              }
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
      }
  
      private static Class<?> compileDebuggerCompatibilityListener(Context context) {
          CompilerEnvirons compilerEnvirons = new CompilerEnvirons();
          compilerEnvirons.initFromContext(context);
  
          ClassCompiler compiler = new ClassCompiler(compilerEnvirons);
          compiler.setTargetExtends(DebuggerCompatibilityBase.class);
          compiler.setTargetImplements(new Class<?>[] {ContextListener.class});
  
          Object[] classFiles = compiler.compileToClassFiles(
                  DEBUGGER_SOURCE, "debugger-compatibility-listener.js", 1, DEBUGGER_MAIN_CLASS_NAME);
          GeneratedClassLoader loader = context.createClassLoader(ContextTest.class.getClassLoader());
          Class<?> debuggerClass = null;
          Class<?>[] definedClasses = new Class<?>[classFiles.length / 2];
          for (int index = 0; index < classFiles.length; index += 2) {
              String className = (String) classFiles[index];
              byte[] bytecode = (byte[]) classFiles[index + 1];
              Class<?> definedClass = loader.defineClass(className, bytecode);
              definedClasses[index / 2] = definedClass;
              if (DEBUGGER_MAIN_CLASS_NAME.equals(className)) {
                  debuggerClass = definedClass;
              }
          }
          for (Class<?> definedClass : definedClasses) {
              loader.linkClass(definedClass);
          }
          return debuggerClass;
      }
  
      public static class DebuggerCompatibilityBase {
          public void attachTo(ContextFactory factory) {
              DebuggerRecorder.attached(factory);
          }
      }
  
      public static final class DebuggerRecorder {
          private static ContextFactory attachedFactory;
          private static int attachCount;
  
          private DebuggerRecorder() {
          }
  
          public static void reset() {
              attachedFactory = null;
              attachCount = 0;
