[tool-call] delta {"path":"tests/src/org.mozilla/rhino/1.7R5/src/test/java/org_mozilla/rhino/NativeJavaClassTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_mozilla.rhino;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport org.junit.jupiter.api.Test;\nimport org.mozilla.javascript.Context;\nimport org.mozilla.javascript.Scriptable;\n\npublic class NativeJavaClassTest {\n    @Test\n    void constructsJavaClassWithExpandedVarargs() {\n        Context context = Context.enter();\n        try {\n            Scriptable scope = context.initStandardObjects();\n\n            Object result = context.evaluateString(scope, \"\"\"\n                    var target = new Packages.org_mozilla.rhino.NativeJavaClassTest.VarargsTarget(\n                        'scores', 2, 3, 5);\n                    target.describe();\n                    \"\"\", \"native-java-class-varargs\", 1, null);\n\n            assertThat(Context.toString(result)).isEqualTo(\"scores=10\");\n        } finally {\n            Context.exit();\n        }\n    }\n\n    public static final class VarargsTarget {\n        private final String label;\n        private final int sum;\n\n        public VarargsTarget(String label, int... values) {\n            this.label = label;\n            int total = 0;\n            for (int value : values) {\n                total += value;\n            }\n            this.sum = total;\n        }\n\n        public String describe() {\n            return label + \"=\" + sum;\n        }\n    }\n}\n"}
