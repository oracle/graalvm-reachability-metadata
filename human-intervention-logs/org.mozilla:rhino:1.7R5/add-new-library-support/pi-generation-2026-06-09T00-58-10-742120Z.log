  package org_mozilla.rhino;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import org.junit.jupiter.api.Test;
  import org.mozilla.javascript.Context;
  import org.mozilla.javascript.Scriptable;
  import org.mozilla.javascript.Wrapper;
  
  public class NativeJavaClassTest {
      @Test
      void constructsJavaClassWithExpandedVarargs() {
          Context context = Context.enter();
          try {
              Scriptable scope = context.initStandardObjects();
  
              Object result = context.evaluateString(scope, """
                      new Packages.org_mozilla.rhino.NativeJavaClassTest.VarargsTarget(
                          'scores', 2, 3, 5);
                      """, "native-java-class-varargs", 1, null);
  
              assertThat(result).isInstanceOf(Wrapper.class);
              VarargsTarget target = (VarargsTarget) ((Wrapper) result).unwrap();
              assertThat(target.label).isEqualTo("scores");
              assertThat(target.sum).isEqualTo(10);
          } finally {
              Context.exit();
          }
      }
  
      public static final class VarargsTarget {
          private final String label;
          private final int sum;
  
          public VarargsTarget(String label, int... values) {
              this.label = label;
              int total = 0;
              for (int value : values) {
                  total += value;
              }
              this.sum = total;
          }
  
      }
