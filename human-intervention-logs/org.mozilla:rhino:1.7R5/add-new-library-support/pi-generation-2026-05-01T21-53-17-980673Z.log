  package org_mozilla.rhino;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import org.junit.jupiter.api.Test;
  import org.mozilla.javascript.Context;
  import org.mozilla.javascript.ContextAction;
  import org.mozilla.javascript.ContextFactory;
  import org.mozilla.javascript.Scriptable;
  import org.mozilla.javascript.ScriptableObject;
  
  public class JavaMembersTest {
      @Test
      void readsAndWritesPublicJavaFieldsFromScript() {
          Context context = ContextFactory.getGlobal().enterContext();
          try {
              Scriptable scope = context.initStandardObjects();
              PublicFieldRecord record = new PublicFieldRecord("initial", 7);
              ScriptableObject.putProperty(scope, "record", Context.javaToJS(record, scope));
  
              Object result = context.evaluateString(
                      scope,
                      "record.text = 'updated'; record.count = record.count + 5;"
                              + "record.text + ':' + record.count + ':' + record.describe();",
                      "java-members-fields",
                      1,
                      null
              );
  
              assertThat(Context.toString(result)).isEqualTo("updated:12:updated:12");
              assertThat(record.text).isEqualTo("updated");
              assertThat(record.count).isEqualTo(12);
          } finally {
              Context.exit();
          }
      }
  
      @Test
      void exposesInterfaceMembersWhenEnhancedJavaAccessIsEnabled() {
          ContextFactory contextFactory = new EnhancedJavaAccessContextFactory();
  
          Object result = contextFactory.call(new ContextAction() {
              @Override
              public Object run(Context context) {
                  Scriptable scope = context.initStandardObjects();
                  ScriptableObject.putProperty(
                          scope,
                          "JavaMembersInterface",
                          context.getWrapFactory().wrapJavaClass(context, scope, JavaMembersInterface.class)
                  );
                  return context.evaluateString(
                          scope,
                          "JavaMembersInterface.base + JavaMembersInterface.twice(21);",
                          "java-members-enhanced-interface",
                          1,
                          null
                  );
              }
          });
  
          assertThat(Context.toString(result)).isEqualTo("49");
      }
  
      public static class PublicFieldRecord {
          public String text;
          public int count;
  
          public PublicFieldRecord(String text, int count) {
              this.text = text;
              this.count = count;
          }
  
          public String describe() {
              return text + ":" + count;
          }
      }
  
      public interface JavaMembersInterface {
          int base = 7;
  
          static int twice(int value) {
              return value * 2;
          }
      }
  
      private static class EnhancedJavaAccessContextFactory extends ContextFactory {
          @Override
          protected boolean hasFeature(Context context, int featureIndex) {
              if (featureIndex == Context.FEATURE_ENHANCED_JAVA_ACCESS) {
                  return true;
              }
              return super.hasFeature(context, featureIndex);
          }
      }
  }
