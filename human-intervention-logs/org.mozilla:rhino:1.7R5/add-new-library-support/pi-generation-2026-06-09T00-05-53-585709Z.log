              int end = sb.getEnd() - 1;
              itsCodeBuffer[end] = (byte) ByteCode.ATHROW;
              for (int bci = sb.getStart(); bci < end; bci++) {
                  itsCodeBuffer[bci] = (byte) ByteCode.NOP;
              }
