                      SuperBlock targetSB = getBranchTarget(bci);
                      if (DEBUGSTACKMAP) {
                          System.out.println("sb " + work.getIndex() +
                                             " points to sb " +
                                             targetSB.getIndex() +
                                             " (offset " + bci + " -> " +
                                             targetSB.getStart() + ")");
                          System.out.println("type state at " + bci + ":");
                          TypeInfo.print(locals, localsTop, stack, stackTop,
                                         itsConstantPool);
                      }
                      flowInto(targetSB);
                      if (DEBUGSTACKMAP) {
                          System.out.println("type state of " + targetSB +
