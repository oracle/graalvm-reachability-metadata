                              return new URLConnection(url) {
                                  @Override
                                  public void connect() {
                                      connected = true;
                                  }
  
                                  @Override
                                  public InputStream getInputStream() {
                                      return new ByteArrayInputStream(JAVA_6_CLASS_HEADER);
                                  }
                              };
                          }
                      });
          }
  
