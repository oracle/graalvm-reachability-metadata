  /*
   * Copyright and related rights waived via CC0
   *
   * You should have received a copy of the CC0 legalcode along with this
   * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.
   */
  plugins {
      id "org.graalvm.internal.tck"
  }
  
  String libraryVersion = tck.testedLibraryVersion.get()
  
  configurations {
      jlineVersion1
  }
  
  dependencies {
      testImplementation "org.mozilla:rhino:$libraryVersion"
      testImplementation 'jline:jline:2.14.6'
      testImplementation 'org.assertj:assertj-core:3.22.0'
  
      jlineVersion1 'jline:jline:1.0'
  }
  
  String jlineVersion1ClasspathProperty = 'org_mozilla.rhino.jlineVersion1Classpath'
  
  String jlineVersion1Classpath = configurations.jlineVersion1.asPath
  
  tasks.withType(Test).configureEach {
      systemProperty jlineVersion1ClasspathProperty, jlineVersion1Classpath
  }
  
  tasks.named("nativeTest") {
      runtimeArgs.add("-D${jlineVersion1ClasspathProperty}=${jlineVersion1Classpath}")
  }
  
  graalvmNative {
      agent {
          defaultMode = "conditional"
          modes {
              conditional {
                  userCodeFilterPath = "user-code-filter.json"
              }
          }
      }
  }
