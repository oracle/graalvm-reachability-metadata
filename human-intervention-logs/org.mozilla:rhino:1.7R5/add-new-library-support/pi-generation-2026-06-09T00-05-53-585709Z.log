[tool-call] delta {"path":"tests/src/org.mozilla/rhino/1.7R5/src/test/java/org_mozilla/rhino/TypeInfoTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_mozilla.rhino;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.IOException;\nimport java.io.InputStream;\nimport java.net.URL;\nimport java.net.URLClassLoader;\nimport java.net.URLConnection;\nimport java.net.URLStreamHandler;\nimport java.nio.charset.StandardCharsets;\nimport java.security.CodeSource;\nimport java.util.ArrayList;\nimport java.util.Collections;\nimport java.util.Enumeration;\nimport java.util.LinkedList;\nimport java.util.List;\nimport java.util.ServiceLoader;\nimport java.util.concurrent.Callable;\n\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\nimport org.mozilla.classfile.ByteCode;\nimport org.mozilla.classfile.ClassFileWriter;\n\npublic class TypeInfoTest {\n    private static final String CALLABLE_SERVICE_RESOURCE =\n            \"META-INF/services/java.util.concurrent.Callable\";\n    private static final String CLASS_FILE_WRITER_RESOURCE =\n            \"org/mozilla/classfile/ClassFileWriter.class\";\n    private static final byte[] JAVA_6_CLASS_HEADER = {\n            (byte) 0xCA, (byte) 0xFE, (byte) 0xBA, (byte) 0xBE,\n            0, 0,\n            0, 50\n    };\n    private static final short PUBLIC_STATIC =\n            (short) (ClassFileWriter.ACC_PUBLIC | ClassFileWriter.ACC_STATIC);\n\n    @Test\n    void mergesDifferentObjectTypesWhenGeneratingStackMap() throws Exception {\n        try {\n            assertThat(exerciseStackMapMergeWithJava6ClassFileVersion())\n                    .isEqualTo(\"generated/TypeInfoMerge\");\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    private static String exerciseStackMapMergeWithJava6ClassFileVersion() throws Exception {\n        URL[] urls = {\n                codeSourceUrl(ClassFileWriter.class),\n                codeSourceUrl(TypeInfoTest.class)\n        };\n\n        try (StackMapClassLoader loader = new StackMapClassLoader(\n                urls, ClassLoader.getPlatformClassLoader())) {\n            Callable<?> exercise = ServiceLoader.load(Callable.class, loader)\n                    .findFirst()\n                    .orElseThrow(() -> new AssertionError(\n                            \"Expected a TypeInfo stack map exercise\"));\n            return (String) exercise.call();\n        }\n    }\n\n    private static URL codeSourceUrl(Class<?> type) {\n        CodeSource codeSource = type.getProtectionDomain().getCodeSource();\n        assertThat(codeSource).isNotNull();\n        return codeSource.getLocation();\n    }\n\n    public static final class StackMapMergeExercise implements Callable<String> {\n        @Override\n        public String call() {\n            ClassFileWriter writer = new ClassFileWriter(\n                    \"generated/TypeInfoMerge\", \"java/lang/Object\", \"TypeInfoMerge.java\");\n            int elseLabel = writer.acquireLabel();\n            int mergeLabel = writer.acquireLabel();\n\n            writer.startMethod(\"choose\", \"(Z)Ljava/lang/Object;\", PUBLIC_STATIC);\n            writer.addILoad(0);\n            writer.add(ByteCode.IFEQ, elseLabel);\n            addNewInstance(writer, ArrayList.class);\n            writer.add(ByteCode.GOTO, mergeLabel);\n\n            writer.markLabel(elseLabel, (short) 0);\n            addNewInstance(writer, LinkedList.class);\n\n            writer.markLabel(mergeLabel, (short) 1);\n            writer.add(ByteCode.ARETURN);\n            writer.stopMethod((short) 1);\n\n            byte[] classBytes = writer.toByteArray();\n            assertThat(classBytes).startsWith(\n                    (byte) 0xCA, (byte) 0xFE, (byte) 0xBA, (byte) 0xBE);\n            return writer.getClassName();\n        }\n\n        private static void addNewInstance(ClassFileWriter writer, Class<?> type) {\n            String internalName = internalName(type);\n            writer.add(ByteCode.NEW, internalName);\n            writer.add(ByteCode.DUP);\n            writer.addInvoke(ByteCode.INVOKESPECIAL, internalName, \"<init>\", \"()V\");\n        }\n\n        private static String internalName(Class<?> type) {\n            return type.getName().replace('.', '/');\n        }\n    }\n\n    private static final class StackMapClassLoader extends URLClassLoader {\n        private static final String[] CHILD_FIRST_CLASSES = {\n                \"org.mozilla.classfile.\",\n                \"org.mozilla.javascript.\",\n                \"org_mozilla.rhino.TypeInfoTest$StackMapMergeExercise\"\n        };\n\n        StackMapClassLoader(URL[] urls, ClassLoader parent) {\n            super(urls, parent);\n        }\n\n        @Override\n        public InputStream getResourceAsStream(String name) {\n            if (CLASS_FILE_WRITER_RESOURCE.equals(name)) {\n                return new ByteArrayInputStream(JAVA_6_CLASS_HEADER);\n            }\n            return super.getResourceAsStream(name);\n        }\n\n        @Override\n        public URL getResource(String name) {\n            if (CLASS_FILE_WRITER_RESOURCE.equals(name)) {\n                try {\n                    return classFileWriterHeaderUrl();\n                } catch (IOException exception) {\n                    throw new IllegalStateException(exception);\n                }\n            }\n            return super.getResource(name);\n        }\n\n        @Override\n        public Enumeration<URL> getResources(String name) throws IOException {\n            if (CALLABLE_SERVICE_RESOURCE.equals(name)) {\n                return Collections.enumeration(List.of(serviceProviderUrl()));\n            }\n            return super.getResources(name);\n        }\n\n        private static URL classFileWriterHeaderUrl() throws IOException {\n            return new URL(null, \"memory:/\" + CLASS_FILE_WRITER_RESOURCE,\n                    new URLStreamHandler() {\n                        @Override\n                        protected URLConnection openConnection(URL url) {\n                            return new URLConnection(url) {\n                                @Override\n                                public void connect() {\n                                    connected = true;\n                                }\n\n                                @Override\n                                public InputStream getInputStream() {\n                                    return new ByteArrayInputStream(JAVA_6_CLASS_HEADER);\n                                }\n                            };\n                        }\n                    });\n        }\n\n        private static URL serviceProviderUrl() throws IOException {\n            return new URL(null, \"memory:/\" + CALLABLE_SERVICE_RESOURCE,\n                    new URLStreamHandler() {\n                        @Override\n                        protected URLConnection openConnection(URL url) {\n                            return new URLConnection(url) {\n                                @Override\n                                public void connect() {\n                                    connected = true;\n                                }\n\n                                @Override\n                                public InputStream getInputStream() {\n                                    String providerClass = StackMapMergeExercise.class.getName();\n                                    byte[] provider = (providerClass + System.lineSeparator())\n                                            .getBytes(StandardCharsets.UTF_8);\n                                    return new ByteArrayInputStream(provider);\n                                }\n                            };\n                        }\n                    });\n        }\n\n        @Override\n        protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {\n            if (isChildFirstClass(name)) {\n                synchronized (getClassLoadingLock(name)) {\n                    Class<?> loadedClass = findLoadedClass(name);\n                    if (loadedClass == null) {\n                        try {\n                            loadedClass = findClass(name);\n                        } catch (ClassNotFoundException ignored) {\n                            loadedClass = super.loadClass(name, false);\n                        }\n                    }\n                    if (resolve) {\n                        resolveClass(loadedClass);\n                    }\n                    return loadedClass;\n                }\n            }\n            return super.loadClass(name, resolve);\n        }\n\n        private static boolean isChildFirstClass(String name) {\n            for (String childFirstClass : CHILD_FIRST_CLASSES) {\n                if (name.startsWith(childFirstClass)) {\n                    return true;\n                }\n            }\n            return false;\n        }\n    }\n}\n"}
[tool-call] end id=call_i2PK0kQKzzB1UQIlQ7eUZ5Dk|fc_07944b9078291de0016a27594f57d88193aab6d9753694bf97 name=write args={"path": "tests/src/org.mozilla/rhino/1.7R5/src/test/java/org_mozilla/rhino/TypeInfoTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_mozilla.rhino;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.IOException;\nimport java.io.InputStream;\nimport java.net.URL;\nimport java.net.URLClassLoader;\nimport java.net.URLConnection;\nimport java.net.URLStreamHandler;\nimport java.nio.charset.StandardCharsets;\nimport java.security.CodeSource;\nimport java.util.ArrayList;\nimport java.util.Collections;\nimport java.util.Enumeration;\nimport java.util.LinkedList;\nimport java.util.List;\nimport java.util.ServiceLoader;\nimport java.util.concurrent.Callable;\n\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\nimport org.mozilla.classfile.ByteCode;\nimport org.mozilla.classfile.ClassFileWriter;\n\npublic class TypeInfoTest {\n    private static final String CALLABLE_SERVICE_RESOURCE =\n            \"META-INF/services/java.util.concurrent.Callable\";\n    private static final String CLASS_FILE_WRITER_RESOURCE =\n            \"org/mozilla/classfile/ClassFileWriter.class\";\n    private static final byte[] JAVA_6_CLASS_HEADER = {\n            (byte) 0xCA, (byte) 0xFE, (byte) 0xBA, (byte) 0xBE,\n            0, 0,\n            0, 50\n    };\n    private static final short PUBLIC_STATIC =\n            (short) (ClassFileWriter.ACC_PUBLIC | ClassFileWriter.ACC_STATIC);\n\n    @Test\n    void mergesDifferentObjectTypesWhenGeneratingStackMap() throws Exception {\n        try {\n            assertThat(exerciseStackMapMergeWithJava6ClassFileVersion())\n                    .isEqualTo(\"generated/TypeInfoMerge\");\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    private static String exerciseStackMapMergeWithJava6ClassFileVersion() throws Exception {\n        URL[] urls = {\n                codeSourceUrl(ClassFileWriter.class),\n                codeSourceUrl(TypeInfoTest.class)\n        };\n\n        try (StackMapClassLoader loader = new StackMapClassLoader(\n                urls, ClassLoader.getPlatformClassLoader())) {\n            Callable<?> exercise = ServiceLoader.load(Callable.class, loader)\n                    .findFirst()\n                    .orElseThrow(() -> new AssertionError(\n                            \"Expected a TypeInfo stack map exercise\"));\n            return (String) exercise.call();\n        }\n    }\n\n    private static URL codeSourceUrl(Class<?> type) {\n        CodeSource codeSource = type.getProtectionDomain().getCodeSource();\n        assertThat(codeSource).isNotNull();\n        return codeSource.getLocation();\n    }\n\n    public static final class StackMapMergeExercise implements Callable<String> {\n        @Override\n        public String call() {\n            ClassFileWriter writer = new ClassFileWriter(\n                    \"generated/TypeInfoMerge\", \"java/lang/Object\", \"TypeInfoMerge.java\");\n            int elseLabel = writer.acquireLabel();\n            int mergeLabel = writer.acquireLabel();\n\n            writer.startMethod(\"choose\", \"(Z)Ljava/lang/Object;\", PUBLIC_STATIC);\n            writer.addILoad(0);\n            writer.add(ByteCode.IFEQ, elseLabel);\n            addNewInstance(writer, ArrayList.class);\n            writer.add(ByteCode.GOTO, mergeLabel);\n\n            writer.markLabel(elseLabel, (short) 0);\n            addNewInstance(writer, LinkedList.class);\n\n            writer.markLabel(mergeLabel, (short) 1);\n            writer.add(ByteCode.ARETURN);\n            writer.stopMethod((short) 1);\n\n            byte[] classBytes = writer.toByteArray();\n            assertThat(classBytes).startsWith(\n                    (byte) 0xCA, (byte) 0xFE, (byte) 0xBA, (byte) 0xBE);\n            return writer.getClassName();\n        }\n\n        private static void addNewInstance(ClassFileWriter writer, Class<?> type) {\n            String internalName = internalName(type);\n            writer.add(ByteCode.NEW, internalName);\n            writer.add(ByteCode.DUP);\n            writer.addInvoke(ByteCode.INVOKESPECIAL, internalName, \"<init>\", \"()V\");\n        }\n\n        private static String internalName(Class<?> type) {\n            return type.getName().replace('.', '/');\n        }\n    }\n\n    private static final class StackMapClassLoader extends URLClassLoader {\n        private static final String[] CHILD_FIRST_CLASSES = {\n                \"org.mozilla.classfile.\",\n                \"org.mozilla.javascript.\",\n                \"org_mozilla.rhino.TypeInfoTest$StackMapMergeExercise\"\n        };\n\n        StackMapClassLoader(URL[] urls, ClassLoader parent) {\n            super(urls, parent);\n        }\n\n        @Override\n        public InputStream getResourceAsStream(String name) {\n            if (CLASS_FILE_WRITER_RESOURCE.equals(name)) {\n                return new ByteArrayInputStream(JAVA_6_CLASS_HEADER);\n            }\n            return super.getResourceAsStream(name);\n        }\n\n        @Override\n        public URL getResource(String name) {\n            if (CLASS_FILE_WRITER_RESOURCE.equals(name)) {\n                try {\n                    return classFileWriterHeaderUrl();\n                } catch (IOException exception) {\n                    throw new IllegalStateException(exception);\n                }\n            }\n            return super.getResource(name);\n        }\n\n        @Override\n        public Enumeration<URL> getResources(String name) throws IOException {\n            if (CALLABLE_SERVICE_RESOURCE.equals(name)) {\n                return Collections.enumeration(List.of(serviceProviderUrl()));\n            }\n            return super.getResources(name);\n        }\n\n        private static URL classFileWriterHeaderUrl() throws IOException {\n            return new URL(null, \"memory:/\" + CLASS_FILE_WRITER_RESOURCE,\n                    new URLStreamHandler() {\n                        @Override\n                        protected URLConnection openConnection(URL url) {\n                            return new URLConnection(url) {\n                                @Override\n                                public void connect() {\n                                    connected = true;\n                                }\n\n                                @Override\n                                public InputStream getInputStream() {\n                                    return new ByteArrayInputStream(JAVA_6_CLASS_HEADER);\n                                }\n                            };\n                        }\n                    });\n        }\n\n        private static URL serviceProviderUrl() throws IOException {\n            return new URL(null, \"memory:/\" + CALLABLE_SERVICE_RESOURCE,\n                    new URLStreamHandler() {\n                        @Override\n                        protected URLConnection openConnection(URL url) {\n                            return new URLConnection(url) {\n                                @Override\n                                public void connect() {\n                                    connected = true;\n                                }\n\n                                @Override\n                                public InputStream getInputStream() {\n                                    String providerClass = StackMapMergeExercise.class.getName();\n                                    byte[] provider = (providerClass + System.lineSeparator())\n                                            .getBytes(StandardCharsets.UTF_8);\n                                    return new ByteArrayInputStream(provider);\n                                }\n                            };\n                        }\n                    });\n        }\n\n        @Override\n        protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {\n            if (isChildFirstClass(name)) {\n                synchronized (getClassLoadingLock(name)) {\n                    Class<?> loadedClass = findLoadedClass(name);\n                    if (loadedClass == null) {\n                        try {\n                            loadedClass = findClass(name);\n                        } catch (ClassNotFoundException ignored) {\n                            loadedClass = super.loadClass(name, false);\n                        }\n                    }\n                    if (resolve) {\n                        resolveClass(loadedClass);\n                    }\n                    return loadedClass;\n                }\n            }\n            return super.loadClass(name, resolve);\n        }\n\n        private static boolean isChildFirstClass(String name) {\n            for (String childFirstClass : CHILD_FIRST_CLASSES) {\n                if (name.startsWith(childFirstClass)) {\n                    return true;\n                }\n            }\n            return false;\n        }\n    }\n}\n"}
