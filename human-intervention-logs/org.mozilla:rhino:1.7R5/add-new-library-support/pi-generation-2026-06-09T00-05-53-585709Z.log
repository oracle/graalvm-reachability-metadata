  import java.util.concurrent.Callable;
  
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  import org.mozilla.classfile.ByteCode;
  import org.mozilla.classfile.ClassFileWriter;
  
  import sun.misc.Unsafe;
  
  public class TypeInfoTest {
      private static final String CALLABLE_SERVICE_RESOURCE =
              "META-INF/services/java.util.concurrent.Callable";
      private static final String CLASS_FILE_WRITER_RESOURCE =
              "org/mozilla/classfile/ClassFileWriter.class";
      private static final byte[] JAVA_6_CLASS_HEADER = {
              (byte) 0xCA, (byte) 0xFE, (byte) 0xBA, (byte) 0xBE,
              0, 0,
              0, 50
      };
      @Test
      void mergesDifferentObjectTypesWhenGeneratingStackMap() throws Exception {
          StackMapGenerationSwitch stackMapGenerationSwitch = enableStackMapGeneration();
          try {
              assertThat(generateMergedObjectStackMapClass())
                      .isEqualTo("generated/TypeInfoMerge");
          } finally {
              stackMapGenerationSwitch.close();
          }
      }
  
      @Test
      void mergesDifferentObjectTypesWithJava6ClassFileResource() throws Exception {
          try {
              assertThat(exerciseStackMapMergeWithJava6ClassFileVersion())
                      .isEqualTo("generated/TypeInfoMerge");
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
      }
  
      private static String generateMergedObjectStackMapClass() {
          return new StackMapMergeExercise().call();
      }
  
      private static StackMapGenerationSwitch enableStackMapGeneration() throws Exception {
          ClassFileWriter warmup = new ClassFileWriter(
                  "generated/TypeInfoWarmup", "java/lang/Object", null);
          assertThat(warmup.getClassName()).isEqualTo("generated/TypeInfoWarmup");
  
          Unsafe unsafe = unsafe();
          Field generateStackMap = ClassFileWriter.class.getDeclaredField("GenerateStackMap");
          Object base = unsafe.staticFieldBase(generateStackMap);
          long offset = unsafe.staticFieldOffset(generateStackMap);
          boolean previous = unsafe.getBoolean(base, offset);
          unsafe.putBoolean(base, offset, true);
          return new StackMapGenerationSwitch(unsafe, base, offset, previous);
      }
  
      private static Unsafe unsafe() throws Exception {
          Field unsafe = Unsafe.class.getDeclaredField("theUnsafe");
          unsafe.setAccessible(true);
          return (Unsafe) unsafe.get(null);
      }
  
      private static String exerciseStackMapMergeWithJava6ClassFileVersion() throws Exception {
          URL[] urls = {
                  codeSourceUrl(ClassFileWriter.class),
                  codeSourceUrl(TypeInfoTest.class)
          };
  
          try (StackMapClassLoader loader = new StackMapClassLoader(
                  urls, ClassLoader.getPlatformClassLoader())) {
              Callable<?> exercise = ServiceLoader.load(Callable.class, loader)
                      .findFirst()
                      .orElseThrow(() -> new AssertionError(
                              "Expected a TypeInfo stack map exercise"));
              return (String) exercise.call();
          }
      }
  
      private static URL codeSourceUrl(Class<?> type) {
          CodeSource codeSource = type.getProtectionDomain().getCodeSource();
          assertThat(codeSource).isNotNull();
          return codeSource.getLocation();
      }
  
      private static final class StackMapGenerationSwitch implements AutoCloseable {
          private final Unsafe unsafe;
          private final Object base;
          private final long offset;
          private final boolean previous;
  
          StackMapGenerationSwitch(Unsafe unsafe, Object base, long offset, boolean previous) {
              this.unsafe = unsafe;
              this.base = base;
              this.offset = offset;
              this.previous = previous;
          }
  
          @Override
          public void close() {
              unsafe.putBoolean(base, offset, previous);
          }
      }
  
      public static final class StackMapMergeExercise implements Callable<String> {
          private static final short PUBLIC_STATIC =
                  (short) (ClassFileWriter.ACC_PUBLIC | ClassFileWriter.ACC_STATIC);
  
          @Override
          public String call() {
              ClassFileWriter writer = new ClassFileWriter(
                      "generated/TypeInfoMerge", "java/lang/Object", "TypeInfoMerge.java");
              int elseLabel = writer.acquireLabel();
              int mergeLabel = writer.acquireLabel();
  
              writer.startMethod("choose", "(Z)Ljava/lang/Object;", PUBLIC_STATIC);
              writer.addILoad(0);
              writer.add(ByteCode.IFEQ, elseLabel);
              addNewInstance(writer, ArrayList.class);
              writer.add(ByteCode.GOTO, mergeLabel);
  
              writer.markLabel(elseLabel, (short) 0);
              addNewInstance(writer, LinkedList.class);
  
              writer.markLabel(mergeLabel, (short) 1);
              writer.add(ByteCode.ARETURN);
              writer.stopMethod((short) 1);
  
              byte[] classBytes = writer.toByteArray();
              if (classBytes.length < 4
                      || classBytes[0] != (byte) 0xCA
                      || classBytes[1] != (byte) 0xFE
                      || classBytes[2] != (byte) 0xBA
                      || classBytes[3] != (byte) 0xBE) {
                  throw new AssertionError("Expected generated class bytes");
              }
              return writer.getClassName();
          }
  
          private static void addNewInstance(ClassFileWriter writer, Class<?> type) {
              String internalName = internalName(type);
              writer.add(ByteCode.NEW, internalName);
              writer.add(ByteCode.DUP);
              writer.addInvoke(ByteCode.INVOKESPECIAL, internalName, "<init>", "()V");
          }
  
          private static String internalName(Class<?> type) {
              return type.getName().replace('.', '/');
          }
      }
  
