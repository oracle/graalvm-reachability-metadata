                  SuperBlock work = workList[--workListTop];
                  work.setInQueue(false);
                  locals = work.getLocals();
                  stack = work.getStack();
                  localsTop = locals.length;
                  stackTop = stack.length;
                  executeBlock(work);
              }
          }
  
          /**
