              // Start from the top of the method and queue up block dependencies
              // as they come along.
              workList = new SuperBlock[] { superBlocks[0] };
              workListTop = 1;
              executeWorkList();
  
              // Replace dead code with no-ops.
              for (int i = 0; i < superBlocks.length; i++) {
                  SuperBlock sb = superBlocks[i];
                  if (!sb.isInitialized()) {
