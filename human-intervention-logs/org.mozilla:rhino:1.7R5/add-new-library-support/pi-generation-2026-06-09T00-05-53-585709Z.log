riter.class),\n                codeSourceUrl(ClassFileWriterTest.class)\n        };\n\n        try (MaskingClassLoader loader = new MaskingClassLoader(\n                urls, ClassLoader.getPlatformClassLoader())) {\n            Callable<?> exercise = ServiceLoader.load(Callable.class, loader)\n                    .findFirst()\n                    .orElseThrow(() -> new AssertionError(\n                            \"Expected a ClassFileWriter exercise\"));\n            return (String) exercise.call();\n        }\n    }\n\n    private static URL codeSourceUrl(Class<?> type) {\n        CodeSource codeSource = type.getProtectionDomain().getCodeSource();\n        assertThat(codeSource).isNotNull();\n        return codeSource.getLocation();\n    }\n\n    public static final class SystemResourceFallbackExercise implements Callable<String> {\n        @Override\n        public String call() {\n            ClassFileWriter writer = new ClassFileWriter(\n                    \"generated/RhinoGenerated\", \"java/lang/Object\", \"RhinoGenerated.java\");\n            writer.startMethod(\"<init>\", \"()V\", ClassFileWriter.ACC_PUBLIC);\n            writer.add(ByteCode.ALOAD_0);\n            writer.addInvoke(ByteCode.INVOKESPECIAL, \"java/lang/Object\", \"<init>\", \"()V\");\n            writer.add(ByteCode.RETURN);\n            writer.stopMethod((short) 1);\n\n            byte[] classBytes = writer.toByteArray();\n            if (classBytes.length < 4\n                    || classBytes[0] != (byte) 0xCA\n                    || classBytes[1] != (byte) 0xFE\n                    || classBytes[2] != (byte) 0xBA\n                    || classBytes[3] != (byte) 0xBE) {\n                throw new AssertionError(\"Expected generated class bytes\");\n            }\n            return writer.getClassName();\n        }\n    }\n\n    private static final class MaskingClassLoader extends URLClassLoader {\n        private static final String[] CHILD_FIRST_CLASSES = {\n                \"org.mozilla.classfile.\",\n                \"org.mozilla.javascript.\",\n                \"org_mozilla.rhino.ClassFileWriterTest$SystemResourceFallbackExercise\"\n        };\n\n        MaskingClassLoader(URL[] urls, ClassLoader parent) {\n            super(urls, parent);\n        }\n\n        @Override\n        public InputStream getResourceAsStream(String name) {\n            if (CLASS_FILE_WRITER_RESOURCE.equals(name)) {\n                return null;\n            }\n            return super.getResourceAsStream(name);\n        }\n\n        @Override\n        public URL getResource(String name) {\n            if (CLASS_FILE_WRITER_RESOURCE.equals(name)) {\n                return null;\n            }\n            return super.getResource(name);\n        }\n\n        @Override\n        public Enumeration<URL> getResources(String name) throws IOException {\n            if (CALLABLE_SERVICE_RESOURCE.equals(name)) {\n                return Collections.enumeration(List.of(serviceProviderUrl()));\n            }\n            return super.getResources(name);\n        }\n\n        private static URL serviceProviderUrl() throws IOException {\n            return new URL(null, \"memory:/\" + CALLABLE_SERVICE_RESOURCE,\n                    new URLStreamHandler() {\n                        @Override\n                        protected URLConnection openConnection(URL url) {\n                            return new URLConnection(url) {\n                                @Override\n                                public void connect() {\n                                    connected = true;\n                                }\n\n                                @Override\n                                public InputStream getInputStream() {\n                                    String providerClass = SystemResourceFallbackExercise.class\n                                            .getName();\n                                    byte[] provider = (providerClass + System.lineSeparator())\n                                            .getBytes(StandardCharsets.UTF_8);\n                                    return new ByteArrayInputStream(provider);\n                                }\n                            };\n                        }\n                    });\n        }\n\n        @Override\n        protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {\n            if (isChildFirstClass(name)) {\n                synchronized (getClassLoadingLock(name)) {\n                    Class<?> loadedClass = findLoadedClass(name);\n                    if (loadedClass == null) {\n                        try {\n                            loadedClass = findClass(name);\n                        } catch (ClassNotFoundException ignored) {\n                            loadedClass = super.loadClass(name, false);\n                        }\n                    }\n                    if (resolve) {\n                        resolveClass(loadedClass);\n                    }\n                    return loadedClass;\n                }\n            }\n            return super.loadClass(name, resolve);\n        }\n\n        private static boolean isChildFirstClass(String name) {\n            for (String childFirstClass : CHILD_FIRST_CLASSES) {\n                if (name.startsWith(childFirstClass)) {\n                    return true;\n                }\n            }\n            return false;\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1780963423248}]}
