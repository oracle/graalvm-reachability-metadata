  /*
   * Copyright and related rights waived via CC0
   *
   * You should have received a copy of the CC0 legalcode along with this
   * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.
   */
  package org_mozilla.rhino;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.nio.file.Path;
  
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  import org.junit.jupiter.api.io.TempDir;
  import org.mozilla.javascript.Context;
  import org.mozilla.javascript.Script;
  import org.mozilla.javascript.Scriptable;
  import org.mozilla.javascript.ScriptableObject;
  import org.mozilla.javascript.tools.shell.Global;
  
  public class GlobalTest {
      @TempDir
      Path tempDirectory;
  
      @Test
      void serializesAndDeserializesObjectsThroughShellGlobal() throws Exception {
          Context context = Context.enter();
          try {
              Global global = new Global(context);
              Path serializedFile = tempDirectory.resolve("rhino-serialized-object.bin");
  
              Global.serialize(context, global, new Object[] {"serialized value", serializedFile.toString()}, null);
              Object deserialized = Global.deserialize(context, global, new Object[] {serializedFile.toString()}, null);
  
              assertThat(serializedFile).exists().isNotEmptyFile();
              assertThat(Context.toString(deserialized)).isEqualTo("serialized value");
          } finally {
              Context.exit();
          }
      }
  
      @Test
      void loadsScriptClassByNameAndExecutesIt() throws Exception {
          runAllowingNativeImageUnsupportedClassLoading(() -> {
              LoadableScript.executions = 0;
  
              Context context = Context.enter();
              try {
                  Global global = new Global(context);
  
                  Global.loadClass(context, global, new Object[] {LoadableScript.class.getName()}, null);
  
                  assertThat(LoadableScript.executions).isEqualTo(1);
                  assertThat(ScriptableObject.getProperty(global, "loadedByGlobalLoadClass"))
                          .isEqualTo("executed");
              } finally {
                  Context.exit();
              }
          });
      }
  
      private static void runAllowingNativeImageUnsupportedClassLoading(ThrowingRunnable action) throws Exception {
          try {
              action.run();
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
      }
  
      @FunctionalInterface
      private interface ThrowingRunnable {
          void run() throws Exception;
      }
  
      public static class LoadableScript implements Script {
          static int executions;
  
          public LoadableScript() {
          }
  
          @Override
          public Object exec(Context context, Scriptable scope) {
              executions++;
              ScriptableObject.putProperty(scope, "loadedByGlobalLoadClass", "executed");
              return "executed";
          }
      }
  }
