              } else {
                  return declaring.getConstructor(parms);
              }
          } catch (NoSuchMethodException e) {
              throw new IOException("Cannot find member: " + e);
          }
      }
  
      private static final Class<?>[] primitives = {
          Boolean.TYPE,
          Byte.TYPE,
          Character.TYPE,
          Double.TYPE,
          Float.TYPE,
          Integer.TYPE,
          Long.TYPE,
          Short.TYPE,
          Void.TYPE
      };
  
      /**
