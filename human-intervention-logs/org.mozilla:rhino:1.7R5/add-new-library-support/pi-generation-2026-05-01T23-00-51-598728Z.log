  package org_mozilla.rhino.tools.shell;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.lang.reflect.InvocationTargetException;
  import java.net.URL;
  import java.net.URLClassLoader;
  import java.nio.charset.StandardCharsets;
  import java.nio.file.Files;
  import java.nio.file.Path;
  
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  import org.junit.jupiter.api.io.TempDir;
  import org.mozilla.javascript.Context;
  import org.mozilla.javascript.ScriptableObject;
  import org.mozilla.javascript.tools.shell.Global;
  import org.mozilla.javascript.tools.shell.Main;
  
  public class MainTest {
      @TempDir
      Path tempDirectory;
  
      @Test
      void startsShellWithJavaPolicySecuritySupportEnabled() throws Exception {
          runAllowingNativeImageUnsupportedClassLoading(() -> {
              String previousValue = System.getProperty("rhino.use_java_policy_security");
              System.setProperty("rhino.use_java_policy_security", "true");
              try (ChildFirstRhinoClassLoader classLoader = new ChildFirstRhinoClassLoader(rhinoCodeSource())) {
                  Class<?> mainClass = Class.forName("org.mozilla.javascript.tools.shell.Main", true, classLoader);
  
                  mainClass.getMethod("main", String[].class)
                          .invoke(null, (Object) new String[] {"-e", "var javaPolicySecuritySupport = 'initialized';"});
              } catch (InvocationTargetException exception) {
                  rethrowInvocationCause(exception);
              } finally {
                  restoreProperty("rhino.use_java_policy_security", previousValue);
              }
          });
      }
  
      @Test
      void loadsCompiledShellScriptClassAndExecutesIt() throws Exception {
          runAllowingNativeImageUnsupportedClassLoading(() -> {
              Path sourceFile = tempDirectory.resolve("CompiledShellScript.js");
              Files.write(sourceFile, "var compiledShellScriptResult = 6 * 7;\n".getBytes(StandardCharsets.UTF_8));
  
              org.mozilla.javascript.tools.jsc.Main compiler = new org.mozilla.javascript.tools.jsc.Main();
              String[] sourceFiles = compiler.processOptions(new String[] {
                      "-d",
                      tempDirectory.toString(),
                      sourceFile.toString()
              });
              compiler.processSource(sourceFiles);
  
              Path classFile = tempDirectory.resolve("CompiledShellScript.class");
              assertThat(classFile).exists().isNotEmptyFile();
  
              Context context = Context.enter();
              try {
                  Global global = new Global(context);
  
                  Main.processFile(context, global, classFile.toUri().toURL().toExternalForm());
  
                  Object result = ScriptableObject.getProperty(global, "compiledShellScriptResult");
  
                  assertThat(Context.toNumber(result)).isEqualTo(42.0d);
              } finally {
                  Context.exit();
              }
          });
      }
  
      private static URL rhinoCodeSource() {
          return Main.class.getProtectionDomain().getCodeSource().getLocation();
      }
  
      private static void restoreProperty(String propertyName, String previousValue) {
          if (previousValue == null) {
              System.clearProperty(propertyName);
          } else {
              System.setProperty(propertyName, previousValue);
          }
      }
  
      private static void rethrowInvocationCause(InvocationTargetException exception) throws Exception {
          Throwable cause = exception.getCause();
          if (cause instanceof Error) {
              throw (Error) cause;
          }
          if (cause instanceof Exception) {
              throw (Exception) cause;
          }
          throw new RuntimeException(cause);
      }
  
      private static void runAllowingNativeImageUnsupportedClassLoading(ThrowingRunnable action) throws Exception {
          try {
              action.run();
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
      }
  
      @FunctionalInterface
      private interface ThrowingRunnable {
          void run() throws Exception;
      }
  
      private static final class ChildFirstRhinoClassLoader extends URLClassLoader {
          private ChildFirstRhinoClassLoader(URL rhinoCodeSource) {
              super(new URL[] {rhinoCodeSource}, MainTest.class.getClassLoader());
          }
  
          @Override
          protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {
              if (!name.startsWith("org.mozilla.")) {
                  return super.loadClass(name, resolve);
              }
              synchronized (getClassLoadingLock(name)) {
                  Class<?> loadedClass = findLoadedClass(name);
                  if (loadedClass == null) {
                      try {
                          loadedClass = findClass(name);
                      } catch (ClassNotFoundException exception) {
                          loadedClass = super.loadClass(name, false);
                      }
                  }
                  if (resolve) {
                      resolveClass(loadedClass);
                  }
                  return loadedClass;
              }
          }
      }
  }
