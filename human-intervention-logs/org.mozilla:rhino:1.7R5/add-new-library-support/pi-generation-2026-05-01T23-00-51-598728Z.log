nit.jupiter.api.Test;\n\npublic class ClassFileWriterTest {\n    private static final String CLASS_FILE_WRITER_NAME = \"org.mozilla.classfile.ClassFileWriter\";\n    private static final String CLASS_FILE_WRITER_RESOURCE = \"org/mozilla/classfile/ClassFileWriter.class\";\n\n    @Test\n    void initializesFromSystemResourceWhenPackageResourceIsUnavailable() throws Exception {\n        runAllowingNativeImageUnsupportedClassLoading(() -> {\n            try (ResourceBlockingClassLoader classLoader = new ResourceBlockingClassLoader(classPathUrls())) {\n                Class<?> writerClass = Class.forName(CLASS_FILE_WRITER_NAME, true, classLoader);\n\n                assertThat(writerClass.getName()).isEqualTo(CLASS_FILE_WRITER_NAME);\n                assertThat(classLoader.getBlockedResourceRequests()).isPositive();\n            }\n        });\n    }\n\n    private static URL[] classPathUrls() throws IOException {\n        String classPath = System.getProperty(\"java.class.path\");\n        String[] entries = classPath.split(File.pathSeparator);\n        List<URL> urls = new ArrayList<>(entries.length);\n        for (String entry : entries) {\n            urls.add(new File(entry).toURI().toURL());\n        }\n        return urls.toArray(URL[]::new);\n    }\n\n    private static void runAllowingNativeImageUnsupportedClassLoading(ThrowingRunnable action) throws Exception {\n        try {\n            action.run();\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    @FunctionalInterface\n    private interface ThrowingRunnable {\n        void run() throws Exception;\n    }\n\n    private static final class ResourceBlockingClassLoader extends URLClassLoader {\n        private boolean blockClassFileWriterResource;\n        private int blockedResourceRequests;\n\n        private ResourceBlockingClassLoader(URL[] urls) {\n            super(urls, ClassFileWriterTest.class.getClassLoader());\n        }\n\n        private int getBlockedResourceRequests() {\n            return blockedResourceRequests;\n        }\n\n        @Override\n        public URL getResource(String name) {\n            if (blockClassFileWriterResource && CLASS_FILE_WRITER_RESOURCE.equals(name)) {\n                blockedResourceRequests++;\n                return null;\n            }\n            return super.getResource(name);\n        }\n\n        @Override\n        protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {\n            if (!name.startsWith(\"org.mozilla.classfile.\")) {\n                return super.loadClass(name, resolve);\n            }\n            synchronized (getClassLoadingLock(name)) {\n                Class<?> loadedClass = findLoadedClass(name);\n                if (loadedClass == null) {\n                    try {\n                        loadedClass = findClass(name);\n                    } catch (ClassNotFoundException exception) {\n                        loadedClass = super.loadClass(name, false);\n                    }\n                }\n                if (CLASS_FILE_WRITER_NAME.equals(name)) {\n                    blockClassFileWriterResource = true;\n                }\n                if (resolve) {\n                    resolveClass(loadedClass);\n                }\n                return loadedClass;\n            }\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1264, "output": 1930, "cacheRead": 14336, "cacheWrite": 0, "totalTokens": 17530, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777676414856, "responseId": "resp_056a957e57bafb920169f5307f338c8197b4cb9a2a2c33149c"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_zd7z1pA0sGuZZhHi6QWna3Fk|fc_056a957e57bafb920169f5308f16c48197b6fef23d1b06b8db", "toolName": "write", "content"