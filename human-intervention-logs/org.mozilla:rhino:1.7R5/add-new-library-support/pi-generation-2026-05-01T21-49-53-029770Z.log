  package org_mozilla.rhino;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.lang.reflect.Constructor;
  import java.lang.reflect.Method;
  
  import org.junit.jupiter.api.Test;
  import org.mozilla.javascript.Context;
  import org.mozilla.javascript.ContextFactory;
  import org.mozilla.javascript.FunctionObject;
  import org.mozilla.javascript.Scriptable;
  import org.mozilla.javascript.ScriptableObject;
  import org.mozilla.javascript.serialize.ScriptableInputStream;
  import org.mozilla.javascript.serialize.ScriptableOutputStream;
  
  public class MemberBoxTest {
      @Test
      void serializesAndRestoresFunctionObjectBackedByMethod() throws Exception {
          Context context = ContextFactory.getGlobal().enterContext();
          try {
              Scriptable scope = context.initStandardObjects();
              Method method = SerializableApi.class.getMethod("format", String.class);
              FunctionObject original = new FunctionObject("format", method, scope);
  
              FunctionObject restored = roundTripFunction(original, scope);
              Object result = restored.call(context, scope, scope, new Object[] { "rhino" });
  
              assertThat(Context.toString(result)).isEqualTo("method:rhino");
          } finally {
              Context.exit();
          }
      }
  
      @Test
      void serializesAndRestoresFunctionObjectBackedByConstructor() throws Exception {
          Context context = ContextFactory.getGlobal().enterContext();
          try {
              Scriptable scope = context.initStandardObjects();
              Constructor<ConstructedScriptable> constructor = ConstructedScriptable.class.getConstructor(String.class);
              FunctionObject original = new FunctionObject("ConstructedScriptable", constructor, scope);
  
              FunctionObject restored = roundTripFunction(original, scope);
              Object result = restored.call(context, scope, scope, new Object[] { "constructor" });
  
              assertThat(result).isInstanceOf(ConstructedScriptable.class);
              assertThat(((ConstructedScriptable) result).getValue()).isEqualTo("constructor");
          } finally {
              Context.exit();
          }
      }
  
      @Test
      void invokesInaccessibleImplementationMethodThroughPublicInterface() throws Exception {
          Context context = ContextFactory.getGlobal().enterContext();
          try {
              Scriptable scope = context.initStandardObjects();
              Method method = InterfaceImplementation.class.getDeclaredMethod("describe", String.class);
              FunctionObject function = new FunctionObject("describe", method, scope);
              InterfaceImplementation target = new InterfaceImplementation();
  
              Object result = function.call(context, scope, target, new Object[] { "interface" });
  
              assertThat(Context.toString(result)).isEqualTo("interface:interface");
          } finally {
              Context.exit();
          }
      }
  
      @Test
      void invokesInaccessibleOverrideThroughPublicSuperclass() throws Exception {
          Context context = ContextFactory.getGlobal().enterContext();
          try {
              Scriptable scope = context.initStandardObjects();
              Method method = SuperclassImplementation.class.getDeclaredMethod("describe", String.class);
              FunctionObject function = new FunctionObject("describe", method, scope);
              SuperclassImplementation target = new SuperclassImplementation();
  
              Object result = function.call(context, scope, target, new Object[] { "superclass" });
  
              assertThat(Context.toString(result)).isEqualTo("superclass:superclass");
          } finally {
              Context.exit();
          }
      }
  
      @Test
      void constructsInaccessibleScriptableAfterMakingConstructorAccessible() throws Exception {
          Context context = ContextFactory.getGlobal().enterContext();
          try {
              Scriptable scope = context.initStandardObjects();
              Constructor<HiddenConstructedScriptable> constructor =
                      HiddenConstructedScriptable.class.getDeclaredConstructor(String.class);
              FunctionObject function = new FunctionObject("HiddenConstructedScriptable", constructor, scope);
  
              Object result = function.call(context, scope, scope, new Object[] { "hidden" });
  
              assertThat(result).isInstanceOf(HiddenConstructedScriptable.class);
              assertThat(((HiddenConstructedScriptable) result).getValue()).isEqualTo("hidden");
          } finally {
              Context.exit();
          }
      }
  
      private static FunctionObject roundTripFunction(FunctionObject function, Scriptable scope) throws Exception {
          ByteArrayOutputStream buffer = new ByteArrayOutputStream();
          try (ScriptableOutputStream output = new ScriptableOutputStream(buffer, scope)) {
              output.writeObject(function);
          }
  
          try (ScriptableInputStream input = new ScriptableInputStream(new ByteArrayInputStream(buffer.toByteArray()), scope)) {
              return (FunctionObject) input.readObject();
          }
      }
  
      public static class SerializableApi {
          public static String format(String value) {
              return "method:" + value;
          }
      }
  
      public static class ConstructedScriptable extends ScriptableObject {
          private final String value;
  
          public ConstructedScriptable(String value) {
              this.value = value;
          }
  
          @Override
          public String getClassName() {
              return "ConstructedScriptable";
          }
  
          public String getValue() {
              return value;
          }
      }
  
      public interface PublicDescriber {
          String describe(String value);
      }
  
      private static class InterfaceImplementation extends ScriptableObject implements PublicDescriber {
          @Override
          public String getClassName() {
              return "InterfaceImplementation";
          }
  
          @Override
          public String describe(String value) {
              return "interface:" + value;
          }
      }
  
      public static class PublicDescriberBase extends ScriptableObject {
          @Override
          public String getClassName() {
              return "PublicDescriberBase";
          }
  
          public String describe(String value) {
              return "superclass:" + value;
          }
      }
  
      private static class SuperclassImplementation extends PublicDescriberBase {
          @Override
          public String getClassName() {
              return "SuperclassImplementation";
          }
  
          @Override
          public String describe(String value) {
              return "superclass:" + value;
          }
      }
  
      private static class HiddenConstructedScriptable extends ScriptableObject {
          private final String value;
  
          public HiddenConstructedScriptable(String value) {
              this.value = value;
          }
  
          @Override
          public String getClassName() {
              return "HiddenConstructedScriptable";
          }
  
          public String getValue() {
              return value;
          }
      }
  }
