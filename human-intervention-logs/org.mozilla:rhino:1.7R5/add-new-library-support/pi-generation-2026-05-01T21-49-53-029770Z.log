  package org_mozilla.rhino;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.Serializable;
  import java.util.Arrays;
  
  import org.junit.jupiter.api.Test;
  import org.mozilla.javascript.Context;
  import org.mozilla.javascript.ContextFactory;
  import org.mozilla.javascript.NativeJavaObject;
  import org.mozilla.javascript.Scriptable;
  import org.mozilla.javascript.ScriptableObject;
  import org.mozilla.javascript.serialize.ScriptableInputStream;
  import org.mozilla.javascript.serialize.ScriptableOutputStream;
  
  public class NativeJavaObjectTest {
      @Test
      void serializesAndRestoresWrappedJavaObjectWithStaticType() throws Exception {
          Context context = ContextFactory.getGlobal().enterContext();
          try {
              Scriptable scope = context.initStandardObjects();
              NativeJavaObject original = new NativeJavaObject(scope, String.class, Class.class);
  
              NativeJavaObject restored = roundTrip(original, scope);
  
              assertThat(restored.unwrap()).isEqualTo(String.class);
              assertThat(restored.getClassName()).isEqualTo("JavaObject");
          } finally {
              Context.exit();
          }
      }
  
      @Test
      void coercesJavaScriptArrayToJavaArrayArgument() {
          Context context = ContextFactory.getGlobal().enterContext();
          try {
              Scriptable scope = context.initStandardObjects();
              ScriptableObject.putProperty(scope, "api", Context.javaToJS(new ConversionApi(), scope));
  
              Object result = context.evaluateString(scope, "api.join(['rhino', 7, true]);", "array-coercion", 1, null);
  
              assertThat(Context.toString(result)).isEqualTo("rhino,7,true");
          } finally {
              Context.exit();
          }
      }
  
      @Test
      void coercesWrappedObjectWithDoubleValueToJavaDoubleArgument() {
          Context context = ContextFactory.getGlobal().enterContext();
          try {
              Scriptable scope = context.initStandardObjects();
              ScriptableObject.putProperty(scope, "api", Context.javaToJS(new ConversionApi(), scope));
              ScriptableObject.putProperty(scope, "numeric", Context.javaToJS(new NumericValue(21.25d), scope));
  
              Object result = context.evaluateString(scope, "api.describeDouble(numeric);", "double-coercion", 1, null);
  
              assertThat(Context.toString(result)).isEqualTo("42.5");
          } finally {
              Context.exit();
          }
      }
  
      private static NativeJavaObject roundTrip(NativeJavaObject original, Scriptable scope) throws Exception {
          ByteArrayOutputStream buffer = new ByteArrayOutputStream();
          try (ScriptableOutputStream output = new ScriptableOutputStream(buffer, scope)) {
              output.writeObject(original);
          }
  
          try (ScriptableInputStream input = new ScriptableInputStream(
                  new ByteArrayInputStream(buffer.toByteArray()),
                  scope
          )) {
              return (NativeJavaObject) input.readObject();
          }
      }
  
      public static class ConversionApi {
          public String join(String[] values) {
              return String.join(",", Arrays.asList(values));
          }
  
          public String describeDouble(double value) {
              return Double.toString(value * 2.0d);
          }
      }
  
      public static class NumericValue implements Serializable {
          private static final long serialVersionUID = 1L;
  
          private final double value;
  
          public NumericValue(double value) {
              this.value = value;
          }
  
          public Double doubleValue() {
              return value;
          }
      }
  }
