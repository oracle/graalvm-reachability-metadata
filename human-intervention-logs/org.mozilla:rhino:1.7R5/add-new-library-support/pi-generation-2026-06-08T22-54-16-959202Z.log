[tool-call] delta {"path":"tests/src/org.mozilla/rhino/1.7R5/src/test/java/org_mozilla/rhino/VMBridgeJdk13Test.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_mozilla.rhino;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport org.junit.jupiter.api.Test;\nimport org.mozilla.javascript.Context;\nimport org.mozilla.javascript.Scriptable;\nimport org.mozilla.javascript.ScriptableObject;\n\npublic class VMBridgeJdk13Test {\n    @Test\n    void convertsJavaScriptFunctionArgumentToJavaInterfaceProxy() {\n        Context context = Context.enter();\n        try {\n            context.setOptimizationLevel(-1);\n            Scriptable scope = context.initStandardObjects();\n            InterfaceConsumer consumer = new InterfaceConsumer();\n            ScriptableObject.putProperty(scope, \"consumer\",\n                    Context.javaToJS(consumer, scope));\n\n            context.evaluateString(scope, \"\"\"\n                    consumer.accept(function(value) {\n                        return 'hello ' + value;\n                    });\n                    \"\"\", \"vmbridge-jdk13-interface-proxy-test\", 1, null);\n\n            assertThat(consumer.result).isEqualTo(\"hello Rhino\");\n            assertThat(consumer.proxyEqualsItself).isTrue();\n            assertThat(consumer.proxyDescription).contains(\"Proxy[\");\n        } finally {\n            Context.exit();\n        }\n    }\n\n    public interface Greeting {\n        String greet(String value);\n    }\n\n    public static class InterfaceConsumer {\n        private String result;\n        private boolean proxyEqualsItself;\n        private String proxyDescription;\n\n        public void accept(Greeting greeting) {\n            result = greeting.greet(\"Rhino\");\n            proxyEqualsItself = greeting.equals(greeting);\n            proxyDescription = greeting.toString();\n        }\n    }\n}\n"}
