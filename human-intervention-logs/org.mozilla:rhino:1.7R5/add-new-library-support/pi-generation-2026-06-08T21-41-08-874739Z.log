[tool-call] delta {"path":"tests/src/org.mozilla/rhino/1.7R5/src/test/java/org_mozilla/rhino/JavaAdapterTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_mozilla.rhino;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.IOException;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.util.concurrent.Callable;\n\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\nimport org.mozilla.javascript.Context;\nimport org.mozilla.javascript.JavaAdapter;\nimport org.mozilla.javascript.Scriptable;\nimport org.mozilla.javascript.Wrapper;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class JavaAdapterTest {\n    @Test\n    void createsInvokesSerializesAndRestoresJavaAdapter() throws Exception {\n        try {\n            exerciseJavaAdapter();\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    private static void exerciseJavaAdapter() throws Exception {\n        Context context = Context.enter();\n        try {\n            Scriptable scope = context.initStandardObjects();\n            Object adapterWrapper = context.evaluateString(scope, \"\"\"\n                    new JavaAdapter(java.lang.Runnable, java.util.concurrent.Callable, {});\n                    \"\"\", \"java-adapter-test\", 1, null);\n\n            assertThat(adapterWrapper).isInstanceOf(Wrapper.class);\n            Object adapter = ((Wrapper) adapterWrapper).unwrap();\n\n            Runnable runnable = Runnable.class.cast(Context.jsToJava(adapterWrapper, Runnable.class));\n            Callable<?> callable = Callable.class.cast(Context.jsToJava(adapterWrapper, Callable.class));\n            runnable.run();\n            assertThat(callable.call()).isNull();\n\n            byte[] serializedAdapter = writeAdapter(adapter);\n            Object restoredAdapter = readAdapter(scope, serializedAdapter);\n\n            assertThat(restoredAdapter).isInstanceOf(Runnable.class).isInstanceOf(Callable.class);\n            Runnable restoredRunnable = Runnable.class.cast(restoredAdapter);\n            Callable<?> restoredCallable = Callable.class.cast(restoredAdapter);\n            restoredRunnable.run();\n            assertThat(restoredCallable.call()).isNull();\n        } finally {\n            Context.exit();\n        }\n    }\n\n    private static byte[] writeAdapter(Object adapter) throws IOException {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            JavaAdapter.writeAdapterObject(adapter, output);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static Object readAdapter(Scriptable scope, byte[] serializedAdapter)\n            throws IOException, ClassNotFoundException {\n        try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(serializedAdapter))) {\n            return JavaAdapter.readAdapterObject(scope, input);\n        }\n    }\n}\n"}
[tool-call] end id=call_OBdTVw58pJY3u3eqy31bcINC|fc_01fc0e625fba6484016a2736acea5481908536b79742eeba25 name=write args={"path": "tests/src/org.mozilla/rhino/1.7R5/src/test/java/org_mozilla/rhino/JavaAdapterTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_mozilla.rhino;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.IOException;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.util.concurrent.Callable;\n\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\nimport org.mozilla.javascript.Context;\nimport org.mozilla.javascript.JavaAdapter;\nimport org.mozilla.javascript.Scriptable;\nimport org.mozilla.javascript.Wrapper;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class JavaAdapterTest {\n    @Test\n    void createsInvokesSerializesAndRestoresJavaAdapter() throws Exception {\n        try {\n            exerciseJavaAdapter();\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    private static void exerciseJavaAdapter() throws Exception {\n        Context context = Context.enter();\n        try {\n            Scriptable scope = context.initStandardObjects();\n            Object adapterWrapper = context.evaluateString(scope, \"\"\"\n                    new JavaAdapter(java.lang.Runnable, java.util.concurrent.Callable, {});\n                    \"\"\", \"java-adapter-test\", 1, null);\n\n            assertThat(adapterWrapper).isInstanceOf(Wrapper.class);\n            Object adapter = ((Wrapper) adapterWrapper).unwrap();\n\n            Runnable runnable = Runnable.class.cast(Context.jsToJava(adapterWrapper, Runnable.class));\n            Callable<?> callable = Callable.class.cast(Context.jsToJava(adapterWrapper, Callable.class));\n            runnable.run();\n            assertThat(callable.call()).isNull();\n\n            byte[] serializedAdapter = writeAdapter(adapter);\n            Object restoredAdapter = readAdapter(scope, serializedAdapter);\n\n            assertThat(restoredAdapter).isInstanceOf(Runnable.class).isInstanceOf(Callable.class);\n            Runnable restoredRunnable = Runnable.class.cast(restoredAdapter);\n            Callable<?> restoredCallable = Callable.class.cast(restoredAdapter);\n            restoredRunnable.run();\n            assertThat(restoredCallable.call()).isNull();\n        } finally {\n            Context.exit();\n        }\n    }\n\n    private static byte[] writeAdapter(Object adapter) throws IOException {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            JavaAdapter.writeAdapterObject(adapter, output);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static Object readAdapter(Scriptable scope, byte[] serializedAdapter)\n            throws IOException, ClassNotFoundException {\n        try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(serializedAdapter))) {\n            return JavaAdapter.readAdapterObject(scope, input);\n        }\n    }\n}\n"}
