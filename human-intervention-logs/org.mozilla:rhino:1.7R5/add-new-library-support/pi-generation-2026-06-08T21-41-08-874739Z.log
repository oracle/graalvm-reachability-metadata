ort org.mozilla.javascript.NativeJavaClass;\nimport org.mozilla.javascript.NativeObject;\nimport org.mozilla.javascript.Scriptable;\nimport org.mozilla.javascript.ScriptableObject;\nimport org.mozilla.javascript.Wrapper;\n\npublic class JavaAdapterTest {\n    @Test\n    void createsInvokesSerializesAndRestoresJavaAdapter() throws Exception {\n        try {\n            exerciseJavaAdapter();\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    private static void exerciseJavaAdapter() throws Exception {\n        Context context = Context.enter();\n        try {\n            Scriptable scope = context.initStandardObjects();\n            NativeObject implementation = new NativeObject();\n            implementation.setParentScope(scope);\n            implementation.setPrototype(ScriptableObject.getObjectPrototype(scope));\n            scope.put(\"implementation\", scope, implementation);\n            Object adapterWrapper = context.evaluateString(scope, \"\"\"\n                    new JavaAdapter(\n                        java.lang.Runnable,\n                        java.util.concurrent.Callable,\n                        implementation);\n                    \"\"\", \"java-adapter-test\", 1, null);\n\n            assertThat(adapterWrapper).isInstanceOf(Wrapper.class);\n            Object adapter = ((Wrapper) adapterWrapper).unwrap();\n\n            Runnable runnable = Runnable.class.cast(\n                    Context.jsToJava(adapterWrapper, Runnable.class));\n            Callable<?> callable = Callable.class.cast(\n                    Context.jsToJava(adapterWrapper, Callable.class));\n            runnable.run();\n            assertThat(callable.call()).isNull();\n\n            scope.put(\"implementedOperation\", scope,\n                    new NativeJavaClass(scope, ImplementedOperation.class));\n            scope.put(\"operationBase\", scope,\n 