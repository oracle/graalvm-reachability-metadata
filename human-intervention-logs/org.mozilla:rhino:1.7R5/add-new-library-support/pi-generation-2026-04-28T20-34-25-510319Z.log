      protected int getMaxInstanceId()
      {
          return MAX_INSTANCE_ID;
      }
  
      @Override
      protected void setInstanceIdAttributes(int id, int attr) {
          if (id == Id_length) {
              lengthAttr = attr;
          }
      }
  
      @Override
      protected int findInstanceIdInfo(String s)
