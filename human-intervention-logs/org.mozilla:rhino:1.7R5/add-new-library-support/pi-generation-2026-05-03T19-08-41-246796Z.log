.class.getConstructor(\n                    String.class, Integer.TYPE);\n            FunctionObject function = new FunctionObject(\"ConstructedScriptable\", constructor, scope);\n\n            FunctionObject restored = serializeAndDeserialize(function);\n            Scriptable constructed = restored.construct(cx, scope, new Object[] {\"item\", 3});\n\n            ConstructedScriptable scriptable = assertInstanceOf(ConstructedScriptable.class, constructed);\n            assertEquals(\"item:3\", scriptable.description());\n        } finally {\n            Context.exit();\n        }\n    }\n\n    @Test\n    public void invokesInaccessibleMethodThroughPublicInterfaceFallback() throws Exception {\n        Context cx = Context.enter();\n        try {\n            Scriptable scope = cx.initStandardObjects();\n            HiddenInterfaceImplementation target = new HiddenInterfaceImplementation();\n            target.setParentScope(scope);\n            target.setPrototype(ScriptableObject.getObjectPrototype(scope));\n            Method method = HiddenInterfaceImplementation.class.getDeclaredMethod(\"interfaceName\", String.class);\n            FunctionObject function = new FunctionObject(\"interfaceName\", method, scope);\n\n            Object result = function.call(cx, scope, target, new Object[] {\"fallback\"});\n\n            assertEquals(\"interface:fallback\", Context.toString(result));\n        } finally {\n            Context.exit();\n        }\n    }\n\n    @Test\n    public void invokesInaccessibleMethodThroughPublicSuperclassFallback() throws Exception {\n        Context cx = Context.enter();\n        try {\n            Scriptable scope = cx.initStandardObjects();\n            HiddenBaseImplementation target = new HiddenBaseImplementation();\n            target.setParentScope(scope);\n            target.setPrototype(ScriptableObject.getObjectPrototype(scope));\n            Method method = HiddenBaseImplementation.class.getDeclaredMethod(\"inheritedName\", String.class);\n            FunctionObject function = new FunctionObject(\"inheritedName\", method, scope);\n\n            Object result = function.call(cx, scope, target, new Object[] {\"fallback\"});\n\n            assertEquals(\"hidden:fallback\", Context.toString(result));\n        } finally {\n            Context.exit();\n        }\n    }\n\n    @Test\n    public void constructsInaccessibleClassAfterMakingConstructorAccessible() throws Exception {\n        Context cx = Context.enter();\n        try {\n            Scriptable scope = cx.initStandardObjects();\n            Constructor<HiddenConstructedScriptable> constructor = HiddenConstructedScriptable.class.getDeclaredConstructor(\n                    String.class);\n            FunctionObject function = new FunctionObject(\"HiddenConstructedScriptable\", constructor, scope);\n\n            Scriptable constructed = function.construct(cx, scope, new Object[] {\"created\"});\n\n            HiddenConstructedScriptable scriptable = assertInstanceOf(HiddenConstructedScriptable.class, constructed);\n            assertEquals(\"created\", scriptable.value());\n        } finally {\n            Context.exit();\n        }\n    }\n\n    public static String echo(String value) {\n        return \"echo:\" + value;\n    }\n\n    private FunctionObject serializeAndDeserialize(FunctionObject function) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(function);\n        }\n\n        try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(bytes.toByteArray()))) {\n            return assertInstanceOf(FunctionObject.class, input.readObject());\n        }\n    }\n}\n"}
