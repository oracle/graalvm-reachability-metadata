[tool-call] delta {"path":"tests/src/org.mozilla/rhino/1.7R5/src/test/java/org_mozilla/rhino/MemberBoxTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_mozilla.rhino;\n\nimport static org.junit.jupiter.api.Assertions.assertEquals;\nimport static org.junit.jupiter.api.Assertions.assertInstanceOf;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.lang.reflect.Constructor;\nimport java.lang.reflect.Method;\n\nimport org.junit.jupiter.api.Test;\nimport org.mozilla.javascript.Context;\nimport org.mozilla.javascript.FunctionObject;\nimport org.mozilla.javascript.Scriptable;\nimport org.mozilla.javascript.ScriptableObject;\n\npublic class MemberBoxTest {\n    public interface AccessibleName {\n        String interfaceName(String value);\n    }\n\n    public static class PublicBaseScriptable extends ScriptableObject {\n        @Override\n        public String getClassName() {\n            return \"PublicBaseScriptable\";\n        }\n\n        public String inheritedName(String value) {\n            return \"base:\" + value;\n        }\n    }\n\n    public static class ConstructedScriptable extends ScriptableObject {\n        private final String name;\n        private final int count;\n\n        public ConstructedScriptable(String name, int count) {\n            this.name = name;\n            this.count = count;\n        }\n\n        @Override\n        public String getClassName() {\n            return \"ConstructedScriptable\";\n        }\n\n        public String description() {\n            return name + \":\" + count;\n        }\n    }\n\n    private static final class HiddenInterfaceImplementation extends ScriptableObject implements AccessibleName {\n        @Override\n        public String getClassName() {\n            return \"HiddenInterfaceImplementation\";\n        }\n\n        @Override\n        public String interfaceName(String value) {\n            return \"interface:\" + value;\n        }\n    }\n\n    private static final class HiddenBaseImplementation extends PublicBaseScriptable {\n        @Override\n        public String inheritedName(String value) {\n            return \"hidden:\" + value;\n        }\n    }\n\n    private static final class HiddenConstructedScriptable extends ScriptableObject {\n        private final String value;\n\n        public HiddenConstructedScriptable(String value) {\n            this.value = value;\n        }\n\n        @Override\n        public String getClassName() {\n            return \"HiddenConstructedScriptable\";\n        }\n\n        public String value() {\n            return value;\n        }\n    }\n\n    @Test\n    public void serializesMethodMemberAndRestoresItByPublicSignature() throws Exception {\n        Context cx = Context.enter();\n        try {\n            Scriptable scope = cx.initStandardObjects();\n            Method method = MemberBoxTest.class.getMethod(\"echo\", String.class);\n            FunctionObject function = new FunctionObject(\"echo\", method, scope);\n\n            FunctionObject restored = serializeAndDeserialize(function);\n\n            Object result = restored.call(cx, scope, scope, new Object[] {\"restored\"});\n            assertEquals(\"echo:restored\", Context.toString(result));\n        } finally {\n            Context.exit();\n        }\n    }\n\n    @Test\n    public void serializesConstructorMemberAndRestoresItByPublicSignature() throws Exception {\n        Context cx = Context.enter();\n        try {\n            Scriptable scope = cx.initStandardObjects();\n            Constructor<ConstructedScriptable> constructor = ConstructedScriptable.class.getConstructor(\n                    String.class, Integer.TYPE);\n            FunctionObject function = new FunctionObject(\"ConstructedScriptable\", constructor, scope);\n\n            FunctionObject restored = serializeAndDeserialize(function);\n            Scriptable constructed = restored.construct(cx, scope, new Object[] {\"item\", 3});\n\n            ConstructedScriptable scriptable = assertInstanceOf(ConstructedScriptable.class, constructed);\n            assertEquals(\"item:3\", scriptable.description());\n        } finally {\n            Context.exit();\n        }\n    }\n\n    @Test\n    public void invokesInaccessibleMethodThroughPublicInterfaceFallback() throws Exception {\n        Context cx = Context.enter();\n        try {\n            Scriptable scope = cx.initStandardObjects();\n            HiddenInterfaceImplementation target = new HiddenInterfaceImplementation();\n            target.setParentScope(scope);\n            target.setPrototype(ScriptableObject.getObjectPrototype(scope));\n            Method method = HiddenInterfaceImplementation.class.getDeclaredMethod(\"interfaceName\", String.class);\n            FunctionObject function = new FunctionObject(\"interfaceName\", method, scope);\n\n            Object result = function.call(cx, scope, target, new Object[] {\"fallback\"});\n\n            assertEquals(\"interface:fallback\", Context.toString(result));\n        } finally {\n            Context.exit();\n        }\n    }\n\n    @Test\n    public void invokesInaccessibleMethodThroughPublicSuperclassFallback() throws Exception {\n        Context cx = Context.enter();\n        try {\n            Scriptable scope = cx.initStandardObjects();\n            HiddenBaseImplementation target = new HiddenBaseImplementation();\n            target.setParentScope(scope);\n            target.setPrototype(ScriptableObject.getObjectPrototype(scope));\n            Method method = HiddenBaseImplementation.class.getDeclaredMethod(\"inheritedName\", String.class);\n            FunctionObject function = new FunctionObject(\"inheritedName\", method, scope);\n\n            Object result = function.call(cx, scope, target, new Object[] {\"fallback\"});\n\n            assertEquals(\"hidden:fallback\", Context.toString(result));\n        } finally {\n            Context.exit();\n        }\n    }\n\n    @Test\n    public void constructsInaccessibleClassAfterMakingConstructorAccessible() throws Exception {\n        Context cx = Context.enter();\n        try {\n            Scriptable scope = cx.initStandardObjects();\n            Constructor<HiddenConstructedScriptable> constructor = HiddenConstructedScriptable.class.getDeclaredConstructor(\n                    String.class);\n            FunctionObject function = new FunctionObject(\"HiddenConstructedScriptable\", constructor, scope);\n\n            Scriptable constructed = function.construct(cx, scope, new Object[] {\"created\"});\n\n            HiddenConstructedScriptable scriptable = assertInstanceOf(HiddenConstructedScriptable.class, constructed);\n            assertEquals(\"created\", scriptable.value());\n        } finally {\n            Context.exit();\n        }\n    }\n\n    public static String echo(String value) {\n        return \"echo:\" + value;\n    }\n\n    private FunctionObject serializeAndDeserialize(FunctionObject function) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(function);\n        }\n\n        try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(bytes.toByteArray()))) {\n            return assertInstanceOf(FunctionObject.class, input.readObject());\n        }\n    }\n}\n"}
