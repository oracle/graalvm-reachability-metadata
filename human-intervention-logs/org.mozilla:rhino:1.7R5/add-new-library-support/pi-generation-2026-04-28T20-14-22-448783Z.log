[tool-call] delta {"path":"tests/src/org.mozilla/rhino/1.7R5/src/test/java/org_mozilla/rhino/TypeInfoTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_mozilla.rhino;\n\nimport org.junit.jupiter.api.Test;\nimport org.mozilla.classfile.ByteCode;\nimport org.mozilla.classfile.ClassFileWriter;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.IOException;\nimport java.io.InputStream;\nimport java.lang.reflect.Method;\nimport java.nio.charset.StandardCharsets;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class TypeInfoTest {\n    private static final String CLASS_FILE_WRITER_NAME = \"org.mozilla.classfile.ClassFileWriter\";\n    private static final String CLASS_FILE_WRITER_RESOURCE = \"org/mozilla/classfile/ClassFileWriter.class\";\n    private static final String CLASSFILE_PACKAGE_PREFIX = \"org.mozilla.classfile.\";\n    private static final short JAVA_6_CLASS_FILE_MAJOR_VERSION = 50;\n\n    @Test\n    void stackMapGenerationMergesDifferentReferenceTypesAtBranchJoin() throws Exception {\n        GeneratedClass generatedClass = generateClassWithPatchedStackMapWriter();\n\n        assertThat(generatedClass.classBytes()).startsWith((byte) 0xCA, (byte) 0xFE, (byte) 0xBA, (byte) 0xBE);\n        if (generatedClass.stackMapGenerationEnabled()) {\n            String classFileText = new String(generatedClass.classBytes(), StandardCharsets.ISO_8859_1);\n            assertThat(classFileText).contains(\"StackMapTable\");\n        }\n    }\n\n    private static GeneratedClass generateClassWithPatchedStackMapWriter() throws Exception {\n        try {\n            StackMapClassLoader classLoader = new StackMapClassLoader(TypeInfoTest.class.getClassLoader());\n            Class<?> writerClass = Class.forName(CLASS_FILE_WRITER_NAME, true, classLoader);\n            Object writer = writerClass\n                    .getConstructor(String.class, String.class, String.class)\n                    .newInstance(\n                            \"org.example.TypeInfoBranchJoinSample\",\n                            \"java.lang.Object\",\n                            \"TypeInfoBranchJoinSample.java\");\n            generateBranchJoinMethod(writerClass, writer);\n            return new GeneratedClass((byte[]) invoke(writerClass, writer, \"toByteArray\"), true);\n        } catch (Throwable ex) {\n            if (!isRuntimeClassDefinitionUnavailable(ex)) {\n                throw ex;\n            }\n            ClassFileWriter writer = new ClassFileWriter(\n                    \"org.example.TypeInfoBranchJoinSample\",\n                    \"java.lang.Object\",\n                    \"TypeInfoBranchJoinSample.java\");\n            generateBranchJoinMethod(writer);\n            return new GeneratedClass(writer.toByteArray(), false);\n        }\n    }\n\n    private static void generateBranchJoinMethod(ClassFileWriter writer) {\n        short methodFlags = ClassFileWriter.ACC_PUBLIC | ClassFileWriter.ACC_STATIC;\n        writer.startMethod(\"choose\", \"(Z)Ljava/lang/Object;\", methodFlags);\n        int elseLabel = writer.acquireLabel();\n        int joinLabel = writer.acquireLabel();\n\n        writer.addILoad(0);\n        writer.add(ByteCode.IFEQ, elseLabel);\n        writer.addPush(\"string branch\");\n        writer.add(ByteCode.GOTO, joinLabel);\n\n        writer.markLabel(elseLabel, (short) 0);\n        writer.add(ByteCode.GETSTATIC, \"java/lang/System\", \"out\", \"Ljava/io/PrintStream;\");\n\n        writer.markLabel(joinLabel);\n        writer.add(ByteCode.ARETURN);\n        writer.stopMethod((short) 1);\n    }\n\n    private static void generateBranchJoinMethod(Class<?> writerClass, Object writer) throws Exception {\n        short methodFlags = ClassFileWriter.ACC_PUBLIC | ClassFileWriter.ACC_STATI