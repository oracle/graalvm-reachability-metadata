alize(serialize(provider));\n            ModuleScript restoredModule = restoredProvider.getModuleScript(context, \"sample\", null, null, null);\n\n            assertThat(restoredModule).isNotSameAs(originalModule);\n            assertThat(execute(restoredModule, context)).isEqualTo(42.0d);\n        } finally {\n            Context.exit();\n        }\n    }\n\n    private static double execute(ModuleScript moduleScript, Context context) {\n        Scriptable scope = context.initStandardObjects();\n        Object result = moduleScript.getScript().exec(context, scope);\n        return Context.toNumber(result);\n    }\n\n    private static byte[] serialize(SoftCachingModuleScriptProvider provider) throws IOException {\n        ByteArrayOutputStream outputStream = new ByteArrayOutputStream();\n\n        try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(outputStream)) {\n            objectOutputStream.writeObject(provider);\n        }\n\n        return outputStream.toByteArray();\n    }\n\n    private static SoftCachingModuleScriptProvider deserialize(byte[] serialized) throws IOException, ClassNotFoundException {\n        try (ObjectInputStream objectInputStream = new ObjectInputStream(new ByteArrayInputStream(serialized))) {\n            return (SoftCachingModuleScriptProvider) objectInputStream.readObject();\n        }\n    }\n\n    private static final class SingleUseModuleSourceProvider implements ModuleSourceProvider, Serializable {\n        private static final long serialVersionUID = 1L;\n        private static final String VALIDATOR = \"sample-validator\";\n        private static final URI MODULE_URI = URI.create(\"memory:/sample.js\");\n        private boolean loaded;\n\n        @Override\n        public ModuleSource loadSource(String moduleId, Scriptable paths, Object validator)\n                throws IOException, URISyntaxException {\n            return loadSource(validator);\n        }\n\n        @Override\n        public ModuleSource loadSource(URI uri, URI baseUri, Object validator) throws IOException, URISyntaxException {\n            return loadSource(validator);\n        }\n\n        private ModuleSource loadSource(Object validator) throws IOException {\n            if (VALIDATOR.equals(validator)) {\n                return ModuleSourceProvider.NOT_MODIFIED;\n            }\n            if (loaded) {\n                throw new IOException(\"Expected cached module revalidation instead of source reload\");\n            }\n            loaded = true;\n            return new ModuleSource(new StringReader(\"var answer = 40 + 2; answer;\"), null, MODULE_URI, null, VALIDATOR);\n        }\n    }\n}\n"}
