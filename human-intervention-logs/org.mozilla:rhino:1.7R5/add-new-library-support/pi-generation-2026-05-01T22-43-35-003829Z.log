void serializesAndDeserializesObjectAndIntegerValues() throws Exception {\n        UintMap original = new UintMap(2);\n        original.put(7, \"seven\");\n        original.put(7, 70);\n        original.put(11, \"eleven\");\n        original.put(11, 110);\n        original.put(19, \"removed\");\n        original.remove(19);\n        original.put(23, \"twenty-three\");\n        original.put(23, 230);\n\n        UintMap restored = deserialize(serialize(original));\n\n        assertThat(restored.size()).isEqualTo(3);\n        assertThat(restored.getObject(7)).isEqualTo(\"seven\");\n        assertThat(restored.getInt(7, -1)).isEqualTo(70);\n        assertThat(restored.getObject(11)).isEqualTo(\"eleven\");\n        assertThat(restored.getInt(11, -1)).isEqualTo(110);\n        assertThat(restored.getObject(23)).isEqualTo(\"twenty-three\");\n        assertThat(restored.getInt(23, -1)).isEqualTo(230);\n        assertThat(restored.has(19)).isFalse();\n        assertThat(restored.getObject(19)).isNull();\n        assertThat(restored.getInt(19, 42)).isEqualTo(42);\n        assertThat(restored.getKeys()).containsExactlyInAnyOrder(7, 11, 23);\n    }\n\n    private static byte[] serialize(UintMap value) throws Exception {\n        ByteArrayOutputStream outputStream = new ByteArrayOutputStream();\n\n        try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(outputStream)) {\n            objectOutputStream.writeObject(value);\n        }\n\n        return outputStream.toByteArray();\n    }\n\n    private static UintMap deserialize(byte[] serialized) throws Exception {\n        try (ObjectInputStream objectInputStream = new ObjectInputStream(new ByteArrayInputStream(serialized))) {\n            return (UintMap) objectInputStream.readObject();\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777675334159}, {"role": "toolResult", "toolCallId": "call_eov6SyT5649bUOdXwDs8FF5z|fc_0452a51efe222f950169f52c45f178819f8926e61702c9e34a", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_mozilla.rhino;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\n\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\nimport org.mozilla.javascript.Context;\nimport org.mozilla.javascript.ContextFactory;\nimport org.mozilla.javascript.Scriptable;\nimport org.mozilla.javascript.ScriptableObject;\nimport org.mozilla.javascript.serialize.ScriptableInputStream;\nimport org.mozilla.javascript.serialize.ScriptableOutputStream;\n\npublic class JavaAdapterTest {\n    @Test\n    void createsAdapterForInterfaceAndOverridableSuperclassMethods() throws Exception {\n        runAllowingNativeImageUnsupportedClassGeneration(() -> {\n            Context context = ContextFactory.getGlobal().enterContext();\n            try {\n                Scriptable scope = context.initStandardObjects();\n                String source = \"\"\"\n                        var adapter = new JavaAdapter(Packages.%s, java.lang.Comparable, {\n                            greet: function(name) {\n                                return 'hello, ' + name;\n                            }\n                        });\n                        adapter.greet('rhino') + ':' + adapter.compareTo('ignored');\n                        \"\"\".formatted(ComparableGreeter.class.getName());\n\n                Object result = context.evaluateString(scope, source, \"java-adapter-create\", 1, null);\n\n                assertThat(Context.toString(result)).isEqualTo(\"hello, rhino:7\");\n            } finally {\n                Context.exit();\n            }\n        });\n    }\n\n    @Test\n    void serializesAndRestoresAdapterWrapper() throws Exception {\n        runAllowingNativeImageUnsupportedClassGeneration(() -> {\n            Context context = ContextFactory.getGlobal().enterContext();\n            context.setOptimizationLevel(-1);\n            try {\n                Scriptable scope = context.initStandardObjects();\n                Scriptable adapter = (Scriptable) context.evaluateString(scope, \"\"\"\n                        new JavaAdapter(java.lang.Runnable, {\n                            count: 0,\n                            run: function() {\n                                this.count = this.count + 1;\n                            },\n                            value: function() {\n                                return this.count;\n                            }\n                        });\n                        \"\"\", \"java-adapter-serialize\", 1, null);\n\n                ByteArrayOutputStream buffer = new ByteArrayOutputStream();\n                try (ScriptableOutputStream output = new ScriptableOutputStream(buffer, scope)) {\n                    output.writeObject(adapter);\n                }\n\n                Object restored;\n                try (ScriptableInputStream input = new ScriptableInputStream(\n                        new ByteArrayInputStream(buffer.toByteArray()),\n                        scope\n                )) {\n                    restored = input.readObject();\n                }\n\n                ScriptableObject.putProperty(scope, \"adapter\", restored);\n                Object result = context.evaluateString(scope, \"\"\"\n                        adapter.run();\n                        adapter.run();\n                        adapter.value();\n                        \"\"\", \"java-adapter-restored\", 1, null);\n\n                assertThat(Context.toNumber(result)).isEqualTo(2.0d);\n            } finally {\n                Context.exit();\n            }\n        });\n    }\n\n    @FunctionalInterface\n    private interface ThrowingRunnable {\n        void run() throws Exception;\n    }\n\n    private static void runAllowingNativeImageUnsupportedClassGeneration(ThrowingRunnable action) throws Exception {\n        try {\n            action.run();\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    public static class ComparableGreeter implements Comparable<Object> {\n        public String greet(String name) {\n            return \"base \" + name;\n        }\n\n        @Override\n        public int compareTo(Object other) {\n            return 7;\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777675334159}, {"role": "toolResult", "toolCallId": "call_26adek5XmUsyATzwgzJzb8OZ|fc_0452a51efe222f950169f52c45f184819f919c2bb139820b75", "toolName": "read", "content": [{"type": "text", "text": "{\n  \"reflection\": [\n    {\n      \"condition\": {\n        \"typeReached\": \"org_mozilla.rhino.SecureCallerAnonymous2Test\"\n      },\n      \"type\": \"org.mozilla.javascript.SecureCaller\",\n      \"methods\": [\n        {\n          \"name\": \"callSecurely\",\n          \"parameterTypes\": [\n            \"java.security.CodeSource\",\n            \"org.mozilla.javascript.Callable\",\n            \"org.mozilla.javascript.Context\",\n            \"org.mozilla.javascript.Scriptable\",\n            \"org.mozilla.javascript.Scriptable\",\n            \"java.lang.Object[]\"\n          ]\n        }\n      ]\n    }\n  ],\n  \"resources\": [\n    {\n      \"condition\": {\n        \"typeReached\": \"org.mozilla.javascript.SecureCaller\"\n      },\n      \"glob\": \"org/mozilla/javascript/SecureCallerImpl.clazz\"\n    }\n  ]\n}\n"}], "isError": false, "timestamp": 1777675334159}]}
