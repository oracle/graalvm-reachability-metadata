          obj.prototypePropertyAttributes = DONTENUM | READONLY | PERMANENT;
          obj.exportAsJSClass(MAX_PROTOTYPE_ID, scope, sealed);
      }
  
      public BaseFunction()
      {
      }
  
      public BaseFunction(Scriptable scope, Scriptable prototype)
      {
          super(scope, prototype);
