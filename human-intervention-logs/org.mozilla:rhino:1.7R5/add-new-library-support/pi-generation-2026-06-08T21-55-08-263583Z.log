 void serializesAndRestoresPlainJavaObjectWrappers() throws Exception {\n        Context context = Context.enter();\n        try {\n            Scriptable scope = context.initStandardObjects();\n\n            SerializablePayload staticallyTypedPayload = new SerializablePayload(\"typed\");\n            NativeJavaObject staticallyTypedWrapper = new NativeJavaObject(\n                    scope, staticallyTypedPayload, SerializablePayload.class);\n            NativeJavaObject restoredStaticallyTypedWrapper = roundTrip(\n                    staticallyTypedWrapper, scope);\n            assertThat(restoredStaticallyTypedWrapper.unwrap())\n                    .isEqualTo(staticallyTypedPayload);\n\n            SerializablePayload dynamicallyTypedPayload = new SerializablePayload(\"dynamic\");\n            NativeJavaObject dynamicallyTypedWrapper = new NativeJavaObject(\n                    scope, dynamicallyTypedPayload, null);\n            NativeJavaObject restoredDynamicallyTypedWrapper = roundTrip(\n                    dynamicallyTypedWrapper, scope);\n            assertThat(restoredDynamicallyTypedWrapper.unwrap())\n                    .isEqualTo(dynamicallyTypedPayload);\n        } finally {\n            Context.exit();\n        }\n    }\n\n    @Test\n    void serializesAndRestoresJavaAdapterWrappers() throws Exception {\n        try {\n            exerciseJavaAdapterWrapperSerialization();\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    private static void exerciseJavaAdapterWrapperSerialization() throws Exception {\n        Context context = Context.enter();\n        try {\n            Scriptable scope = context.initStandardObjects();\n            NativeObject implementation = new NativeObject();\n            implementation.setParentScope(scope);\n            implementation.setPrototype(ScriptableObject.getObjectPrototype(scope));\n\n        