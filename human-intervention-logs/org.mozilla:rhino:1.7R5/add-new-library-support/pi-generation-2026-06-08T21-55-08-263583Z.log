  import org.mozilla.javascript.serialize.ScriptableOutputStream;
  
  public class MemberBoxTest {
      @Test
      void invokesMethodsConstructorsAndRestoresSerializedMembers() throws Exception {
          Context context = Context.enter();
          try {
              Scriptable scope = context.initStandardObjects();
  
              Method method = PublicOperations.class.getMethod(
                      "combine", String.class, int.class);
              FunctionObject function = new FunctionObject("combine", method, scope);
