              return value + ":" + count;
          }
      }
  
      public static class PublicConstructedScriptable extends ScriptableObject {
          private final String value;
          private final int count;
  
          public PublicConstructedScriptable() {
              this("", 0);
          }
  
          public PublicConstructedScriptable(String value, int count) {
              this.value = value;
              this.count = count;
          }
  
