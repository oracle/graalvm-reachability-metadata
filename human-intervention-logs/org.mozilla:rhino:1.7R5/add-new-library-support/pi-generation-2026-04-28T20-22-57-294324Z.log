ascript;\n\n/**\n * Load generated classes.\n *\n * @author Norris Boyd\n */\npublic class DefiningClassLoader extends ClassLoader\n    implements GeneratedClassLoader\n{\n    public DefiningClassLoader() {\n        this.parentLoader = getClass().getClassLoader();\n    }\n\n    public DefiningClassLoader(ClassLoader parentLoader) {\n        this.parentLoader = parentLoader;\n    }\n\n    public Class<?> defineClass(String name, byte[] data) {\n        // Use our own protection domain for the generated classes.\n        // TODO: we might want to use a separate protection domain for classes\n        // compiled from scripts, based on where the script was loaded from.\n        return super.defineClass(name, data, 0, data.length,\n                SecurityUtilities.getProtectionDomain(getClass()));\n    }\n\n    public void linkClass(Class<?> cl) {\n        resolveClass(cl);\n    }\n\n    @Override\n    public Class<?> loadClass(String name, boolean resolve)\n        throws ClassNotFoundException\n    {\n        Class<?> cl = findLoadedClass(name);\n        if (cl == null) {\n            if (parentLoader != null) {\n                cl = parentLoader.loadClass(name);\n            } else {\n                cl = findSystemClass(name);\n            }\n        }\n        if (resolve) {\n            resolveClass(cl);\n        }\n        return cl;\n    }\n\n    private final ClassLoader parentLoader;\n}\n"}], "isError": false, "timestamp": 1777407749971}, {"role": "toolResult", "toolCallId": "call_gWfpm2fLSoRWICgRqsPoW2RW|fc_0b73a88f9e6de4810169f11705ad5c81a3a8f12bf417945567", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\nplugins {\n    id \"org.graalvm.internal.tck\"\n}\n\nString libraryVersion = tck.testedLibraryVersion.get()\n\ndependencies {\n    testImplementation \"org.mozilla:rhino:$libraryVersion\"\n    testImplementation 'org.assertj:assertj-core:3.22.0'\n}\n\ngraalvmNative {\n    binaries {\n        test {\n            runtimeArgs(\"-Djava.security.manager=allow\")\n        }\n    }\n    agent {\n        defaultMode = \"conditional\"\n        modes {\n            conditional {\n                userCodeFilterPath = \"user-code-filter.json\"\n            }\n        }\n    }\n}\n\ntasks.named(\"test\") {\n    if ((JavaVersion.current().majorVersion as int) < 24) {\n        jvmArgs += [\"-Djava.security.manager=allow\"]\n    }\n}\n"}], "isError": false, "timestamp": 1777407749971}, {"role": "toolResult", "toolCallId": "call_D4pDsxXXLQrU5jm9WgXA4G2V|fc_0b73a88f9e6de4810169f11705ad6481a3ab2a47f4c3775214", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_mozilla.rhino;\n\nimport org.junit.jupiter.api.Test;\nimport org.mozilla.javascript.Context;\nimport org.mozilla.javascript.Function;\nimport org.mozilla.javascript.Scriptable;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class CodegenTest {\n    @Test\n    void compileFunctionCreatesOptimizedCallableFunction() {\n        Context cx = Context.enter();\n        try {\n            cx.setOptimizationLevel(1);\n            Scriptable scope = cx.initStandardObjects();\n            Function function = cx.compileFunction(\n                    scope,\n                    \"function add(left, right) { return left + right; }\",\n                    \"codegen-compile-function-test\",\n                    1,\n                    null);\n\n            Object result = function.call(cx, scope, scope, new Object[] {6, 7});\n\n            assertThat(Context.toNumber(result)).isEqualTo(13.0D);\n        } finally {\n            Context.exit();\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777407749971}, {"role": "toolResult", "toolCallId": "call_OeqbIxBc6TewKDzsWiff3r5e|fc_0b73a88f9e6de4810169f11705ad6c81a3864b3808437fc0a6", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_mozilla.rhino;\n\nimport org.junit.jupiter.api.Test;\n\npublic class RhinoTest {\n    @Test\n    void test() throws Exception {\n        System.out.println(\"This is just a placeholder, implement your test\");\n    }\n}\n"}], "isError": false, "timestamp": 1777407749971}]}
