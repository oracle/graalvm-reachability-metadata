c_07e50cb8dc8e5212016a274e128d608196a853a086bd70506a", "name": "write", "arguments": {"path": "tests/src/org.mozilla/rhino/1.7R5/src/test/java/org_mozilla/rhino/ObjArrayTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_mozilla.rhino;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\n\nimport org.junit.jupiter.api.Test;\nimport org.mozilla.javascript.ObjArray;\n\npublic class ObjArrayTest {\n    @Test\n    void serializesAndRestoresFieldAndOverflowElements() throws Exception {\n        ObjArray values = new ObjArray();\n        values.add(\"zero\");\n        values.add(\"one\");\n        values.add(null);\n        values.add(\"three\");\n        values.add(\"four\");\n        values.add(\"five\");\n        values.add(\"six\");\n        values.seal();\n\n        ObjArray restored = roundTrip(values);\n\n        assertThat(restored.isSealed()).isTrue();\n        assertThat(restored.toArray())\n                .containsExactly(\"zero\", \"one\", null, \"three\", \"four\", \"five\", \"six\");\n        assertThat(restored.peek()).isEqualTo(\"six\");\n        assertThat(restored.indexOf(\"five\")).isEqualTo(5);\n        assertThat(restored.lastIndexOf(\"one\")).isEqualTo(1);\n    }\n\n    private static ObjArray roundTrip(ObjArray values) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(values);\n        }\n        try (ObjectInputStream input = new ObjectInputStream(\n                new ByteArrayInputStream(bytes.toByteArray()))) {\n            return (ObjArray) input.readObject();\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 1445, "output": 760, "cacheRead": 18432, "cacheWrite": 0, "totalTokens": 20637, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780960773305, "responseId": "resp_07e50cb8dc8e5212016a274e05e9c081969568a11104dde461"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_ZfODkQIvto4r6nOZs8offKLe|fc_07e50cb8dc8e5212016a274e128d608196a853a086bd70506a", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1751 bytes to tests/src/org.mozilla/rhino/1.7R5/src/test/java/org_mozilla/rhino/ObjArrayTest.java"}], "isError": false, "timestamp": 1780960791650}]}
