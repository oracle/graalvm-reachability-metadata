[tool-call] delta {"path":"tests/src/org.mozilla/rhino/1.7R5/src/test/java/org_mozilla/rhino/SoftCachingModuleScriptProviderTest.java","edits":[{"oldText":"    void serializesCachedModulesAndRestoresThemForCacheValidation() throws Exception {\n        Context cx = Context.enter();\n        try {\n            cx.setOptimizationLevel(-1);\n            Scriptable scope = cx.initStandardObjects();\n            StaticModuleSourceProvider sourceProvider = new StaticModuleSourceProvider(\n                    \"var cachedModuleValue = 40 + 2; cachedModuleValue;\",\n                    URI.create(\"memory:/modules/cached-module.js\"),\n                    \"cached-validator\");\n            SoftCachingModuleScriptProvider provider = new SoftCachingModuleScriptProvider(sourceProvider);\n\n            ModuleScript loadedModule = provider.getModuleScript(cx, \"cached-module\", null, null, null);\n            assertThat(loadedModule).isNotNull();\n            sourceProvider.rejectUnvalidatedReloads();\n\n            byte[] serializedProvider = serialize(provider);\n            SoftCachingModuleScriptProvider restoredProvider = deserialize(serializedProvider);\n\n            ModuleScript restoredModule = restoredProvider.getModuleScript(cx, \"cached-module\", null, null, null);\n            Object result = restoredModule.getScript().exec(cx, scope);\n\n            assertThat(Context.toNumber(result)).isEqualTo(42.0);\n        } finally {\n            Context.exit();\n        }\n    }\n","newText":"    void serializesProviderAndInitializesCacheAfterRestore() throws Exception {\n        Context cx = Context.enter();\n        try {\n            cx.setOptimizationLevel(-1);\n            Scriptable scope = cx.initStandardObjects();\n            StaticModuleSourceProvider sourceProvider = new StaticModuleSourceProvider(\n                    \"var restoredProviderValue = 40 + 2; restoredProviderValue;\",\n                    URI.create(\"memory:/modules/restored-provider.js\"),\n                    \"restored-validator\");\n            SoftCachingModuleScriptProvider provider = new SoftCachingModuleScriptProvider(sourceProvider);\n\n            byte[] serializedProvider = serialize(provider);\n            SoftCachingModuleScriptProvider restoredProvider = deserialize(serializedProvider);\n\n            ModuleScript restoredModule = restoredProvider.getModuleScript(cx, \"restored-provider\", null, null, null);\n            Object result = restoredModule.getScript().exec(cx, scope);\n\n            assertThat(Context.toNumber(result)).isEqualTo(42.0);\n        } finally {\n            Context.exit();\n        }\n    }\n"},{"oldText":"        private boolean rejectUnvalidatedReloads;\n\n        StaticModuleSourceProvider(String source, URI uri, String validator) {\n            this.source = source;\n            this.uri = uri;\n            this.validator = validator;\n        }\n\n        void rejectUnvalidatedReloads() {\n            rejectUnvalidatedReloads = true;\n        }\n","newText":"\n        StaticModuleSourceProvider(String source, URI uri, String validator) {\n            this.source = source;\n            this.uri = uri;\n            this.validator = validator;\n        }\n"},{"oldText":"            if (rejectUnvalidatedReloads) {\n                throw new IOException(\"Cache validator was not restored\");\n            }\n            return new ModuleSource(new StringReader(source), null, uri, null, validator);\n","newText":"            return new ModuleSource(new StringReader(source), null, uri, null, validator);\n"}]}
