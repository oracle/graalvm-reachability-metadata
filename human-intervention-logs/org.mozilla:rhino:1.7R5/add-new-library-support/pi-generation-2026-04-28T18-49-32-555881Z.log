      public NativeJavaObject(Scriptable scope, Object javaObject,
                              Class<?> staticType, boolean isAdapter)
      {
          this.parent = scope;
          this.javaObject = javaObject;
          this.staticType = staticType;
          this.isAdapter = isAdapter;
          initMembers();
      }
  
      protected void initMembers() {
