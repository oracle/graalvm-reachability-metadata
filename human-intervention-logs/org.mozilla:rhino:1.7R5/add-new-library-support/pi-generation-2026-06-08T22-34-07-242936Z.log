  /*
   * Copyright and related rights waived via CC0
   *
   * You should have received a copy of the CC0 legalcode along with this
   * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.
   */
  package org_mozilla.rhino;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.IOException;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.util.concurrent.Callable;
  
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  import org.mozilla.javascript.Context;
  import org.mozilla.javascript.JavaAdapter;
  import org.mozilla.javascript.NativeJavaClass;
  import org.mozilla.javascript.NativeObject;
  import org.mozilla.javascript.Scriptable;
  import org.mozilla.javascript.ScriptableObject;
  import org.mozilla.javascript.Wrapper;
  
  public class JavaAdapterTest {
      @Test
      void createsInvokesSerializesAndRestoresJavaAdapter() throws Exception {
          try {
              exerciseJavaAdapter();
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
      }
  
      private static void exerciseJavaAdapter() throws Exception {
          Context context = Context.enter();
          try {
              Scriptable scope = context.initStandardObjects();
              NativeObject implementation = new NativeObject();
              implementation.setParentScope(scope);
              implementation.setPrototype(ScriptableObject.getObjectPrototype(scope));
              scope.put("implementation", scope, implementation);
              Object adapterWrapper = context.evaluateString(scope, """
                      new JavaAdapter(
                          java.lang.Runnable,
                          java.util.concurrent.Callable,
                          implementation);
                      """, "java-adapter-test", 1, null);
  
              assertThat(adapterWrapper).isInstanceOf(Wrapper.class);
              Object adapter = ((Wrapper) adapterWrapper).unwrap();
  
              Runnable runnable = Runnable.class.cast(
                      Context.jsToJava(adapterWrapper, Runnable.class));
              Callable<?> callable = Callable.class.cast(
                      Context.jsToJava(adapterWrapper, Callable.class));
              runnable.run();
              assertThat(callable.call()).isNull();
  
              scope.put("implementedOperation", scope,
                      new NativeJavaClass(scope, ImplementedOperation.class));
              scope.put("operationBase", scope,
                      new NativeJavaClass(scope, OperationBase.class));
              Object operationAdapterWrapper = context.evaluateString(scope, """
                      new JavaAdapter(
                          operationBase,
                          implementedOperation,
                          implementation);
                      """, "java-adapter-operation-test", 1, null);
              Object operationAdapter = Context.jsToJava(
                      operationAdapterWrapper, ImplementedOperation.class);
              assertThat(operationAdapter).isInstanceOf(ImplementedOperation.class);
              ImplementedOperation operation = ImplementedOperation.class.cast(operationAdapter);
              assertThat(operation.operate("alpha")).isEqualTo("base:alpha");
  
              implementation.setParentScope(null);
              implementation.setPrototype(null);
              byte[] serializedAdapter = writeAdapter(adapter);
              Object restoredAdapter = readAdapter(scope, serializedAdapter);
  
              assertThat(restoredAdapter)
                      .isInstanceOf(Runnable.class)
                      .isInstanceOf(Callable.class);
              Runnable restoredRunnable = Runnable.class.cast(restoredAdapter);
              Callable<?> restoredCallable = Callable.class.cast(restoredAdapter);
              restoredRunnable.run();
              assertThat(restoredCallable.call()).isNull();
          } finally {
              Context.exit();
          }
      }
  
      private static byte[] writeAdapter(Object adapter) throws IOException {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {
              JavaAdapter.writeAdapterObject(adapter, output);
          }
          return bytes.toByteArray();
      }
  
      private static Object readAdapter(Scriptable scope, byte[] serializedAdapter)
              throws IOException, ClassNotFoundException {
          try (ObjectInputStream input = new ObjectInputStream(
                  new ByteArrayInputStream(serializedAdapter))) {
              return JavaAdapter.readAdapterObject(scope, input);
          }
      }
  
      public interface ImplementedOperation {
          String operate(String value);
      }
  
      public static class OperationBase {
          public String operate(String value) {
              return "base:" + value;
          }
      }
  }
