"write", "arguments": {"path": "tests/src/org.mozilla/rhino/1.7R5/src/test/java/org_mozilla/rhino/ScriptableObjectTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_mozilla.rhino;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\n\nimport org.junit.jupiter.api.Test;\nimport org.mozilla.javascript.Context;\nimport org.mozilla.javascript.FunctionObject;\nimport org.mozilla.javascript.Scriptable;\nimport org.mozilla.javascript.ScriptableObject;\n\npublic class ScriptableObjectTest {\n    @Test\n    void definesScriptableClassesUsingInitializersConstructorsAndFinishHooks()\n            throws Exception {\n        Context context = Context.enter();\n        try {\n            Scriptable scope = context.initStandardObjects();\n\n            String initializedClassName = ScriptableObject.defineClass(\n                    scope, ScriptableInitializer.class);\n            assertThat(initializedClassName).isNull();\n            assertThat(ScriptableObject.getProperty(scope, \"scriptableInitializerCalled\"))\n                    .isEqualTo(Boolean.TRUE);\n\n            String constructedClassName = ScriptableObject.defineClass(\n                    scope, ConstructorBackedScriptable.class);\n            assertThat(constructedClassName).isEqualTo(\"ConstructorBackedScriptable\");\n\n            Object result = context.evaluateString(scope, \"\"\"\n                    var instance = new ConstructorBackedScriptable('alpha');\n                    instance.describe() + ':'\n                        + ConstructorBackedScriptable.staticDescribe() + ':'\n                        + ConstructorBackedScriptable.finished + ':'\n                        + instance.finishMarker;\n                    \"\"\", \"scriptable-object-define-class\", 1, null);\n            assertThat(Context.toString(result)).isEqualTo(\"alpha:static:complete:prototype\");\n        } finally {\n            Context.exit();\n        }\n    }\n\n    @Test\n    void serializesAndRestoresScriptableObjectSlots() throws Exception {\n        SerializableScriptable scriptable = new SerializableScriptable();\n        scriptable.put(\"alpha\", scriptable, \"one\");\n        scriptable.put(7, scriptable, \"seven\");\n\n        SerializableScriptable restored = roundTrip(scriptable);\n\n        assertThat(restored.get(\"alpha\", restored)).isEqualTo(\"one\");\n        assertThat(restored.get(7, restored)).isEqualTo(\"seven\");\n    }\n\n    private static SerializableScriptable roundTrip(SerializableScriptable scriptable)\n            throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(scriptable);\n        }\n        try (ObjectInputStream input = new ObjectInputStream(\n                new ByteArrayInputStream(bytes.toByteArray()))) {\n            return (SerializableScriptable) input.readObject();\n        }\n    }\n\n    public static class ScriptableInitializer extends ScriptableObject {\n        private static final long serialVersionUID = 1L;\n\n        public static void init(Scriptable scope) {\n            ScriptableObject.putProperty(scope, \"scriptableInitializerCalled\", Boolean.TRUE);\n        }\n\n        @Override\n        public String getClassName() {\n            return \"ScriptableInitializer\";\n        }\n    }\n\n    public static class ConstructorBackedScriptable extends ScriptableObject {\n        private static final long serialVersionUID = 1L;\n\n        private String value;\n\n        public ConstructorBackedScriptable() {\n        }\n\n        public void jsConstructor(String newValue) {\n            value = newValue;\n        }\n\n        public String jsFunction_describe() {\n            return value;\n        }\n\n        public static String jsStaticFunction_staticDescribe() {\n            return \"static\";\n        }\n\n        public static void finishInit(\n                Scriptable scope, FunctionObject constructor, Scriptable prototype) {\n            ScriptableObject.putProperty(constructor, \"finished\", \"complete\");\n            ScriptableObject.putProperty(prototype, \"finishMarker\", \"prototype\");\n        }\n\n        @Override\n        public String getClassName() {\n            return \"ConstructorBackedScriptable\";\n        }\n    }\n\n    public static class SerializableScriptable extends ScriptableObject {\n        private static final long serialVersionUID = 1L;\n\n        @Override\n        public String getClassName() {\n            return \"SerializableScriptable\";\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 773, "output": 1506, "cacheRead": 43520, "cacheWrite": 0, "totalTokens": 45799, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780957988616, "responseId": "resp_0807a6b14b5c4db3016a274325e6e88193a1cde5e4e84a3472"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_7yqFDU4v2J1R6WeQGIHxJq1B|fc_0807a6b14b5c4db3016a2743301a988193aa2a2bdd0aa5e68c", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 4652 bytes to tests/src/org.mozilla/rhino/1.7R5/src/test/java/org_mozilla/rhino/ScriptableObjectTest.java"}], "isError": false, "timestamp": 1780958010123}]}
