ut(\"implementation\", scope, implementation);\n\n            Object adapterWrapper = context.evaluateString(scope, \"\"\"\n                    new JavaAdapter(java.lang.Runnable, implementation);\n                    \"\"\", \"adapter-wrapper-serialization\", 1, null);\n            assertThat(adapterWrapper).isInstanceOf(NativeJavaObject.class);\n            Runnable runnable = Runnable.class.cast(Context.jsToJava(\n                    adapterWrapper, Runnable.class));\n            runnable.run();\n\n            NativeJavaObject restoredWrapper = roundTrip(\n                    (NativeJavaObject) adapterWrapper, scope);\n            assertThat(restoredWrapper).isInstanceOf(Wrapper.class);\n            Runnable restoredRunnable = Runnable.class.cast(Context.jsToJava(\n                    restoredWrapper, Runnable.class));\n            restoredRunnable.run();\n        } finally {\n            Context.exit();\n        }\n    }\n\n    private static NativeJavaObject roundTrip(NativeJavaObject wrapper, Scriptable scope)\n            throws IOException, ClassNotFoundException {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ScriptableOutputStream(bytes, scope)) {\n            output.writeObject(wrapper);\n        }\n        try (ObjectInputStream input = new ScriptableInputStream(\n                new ByteArrayInputStream(bytes.toByteArray()), scope)) {\n            return (NativeJavaObject) input.readObject();\n        }\n    }\n\n    public static final class DoubleValuedObject {\n        private final double value;\n\n        DoubleValuedObject(double value) {\n            this.value = value;\n        }\n\n        public Number doubleValue() {\n            return Double.valueOf(value);\n        }\n    }\n\n    public static final class SerializablePayload implements Serializable {\n        private static final long serialVersionUID = 1L;\n\n        private final String value;\n\n        SerializablePayload(String value) {\n            this.value = value;\n        }\n\n        @Override\n        public boolean equals(Object other) {\n            if (this == other) {\n                return true;\n            }\n            if (!(other instanceof SerializablePayload)) {\n                return false;\n            }\n            SerializablePayload payload = (SerializablePayload) other;\n            return value.equals(payload.value);\n        }\n\n        @Override\n        public int hashCode() {\n            return value.hashCode();\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1780957918992}}
