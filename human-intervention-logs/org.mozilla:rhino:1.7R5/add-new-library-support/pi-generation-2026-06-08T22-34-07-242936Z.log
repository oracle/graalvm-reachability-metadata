import java.lang.reflect.Method;\n\nimport org.junit.jupiter.api.Test;\nimport org.mozilla.javascript.Context;\nimport org.mozilla.javascript.FunctionObject;\nimport org.mozilla.javascript.Scriptable;\nimport org.mozilla.javascript.ScriptableObject;\nimport org.mozilla.javascript.serialize.ScriptableInputStream;\nimport org.mozilla.javascript.serialize.ScriptableOutputStream;\n\npublic class MemberBoxTest {\n    @Test\n    void invokesMethodsConstructorsAndRestoresSerializedMembers() throws Exception {\n        Context context = Context.enter();\n        try {\n            Scriptable scope = context.initStandardObjects();\n\n            Method method = PublicOperations.class.getMethod(\n                    \"combine\", String.class, int.class);\n            FunctionObject function = new FunctionObject(\"combine\", method, scope);\n            assertThat(function.call(context, scope, scope, new Object[] {\"alpha\", 3}))\n                    .isEqualTo(\"alpha:3\");\n\n            FunctionObject restoredFunction = roundTripFunction(function, scope);\n            assertThat(restoredFunction.call(context, scope, scope, new Object[] {\"beta\", 4}))\n                    .isEqualTo(\"beta:4\");\n\n            Constructor<PublicConstructedScriptable> constructor =\n                    PublicConstructedScriptable.class.getConstructor(String.class, int.class);\n            FunctionObject constructorFunction = new FunctionObject(\n                    \"PublicConstructedScriptable\", constructor, scope);\n            PublicConstructedScriptable constructed = (PublicConstructedScriptable)\n                    constructorFunction.call(context, scope, scope, new Object[] {\"gamma\", 5});\n            assertThat(constructed.describe()).isEqualTo(\"gamma:5\");\n\n            FunctionObject restoredConstructorFunction = roundTripFunction(\n                    constructorFunction, scope);\n            PublicConstructedScriptable restoredConstructed = (PublicConstructedScriptable)\n                    restoredConstructorFunction.call(\n                            context, scope, scope, new Object[] {\"delta\", 6});\n            assertThat(restoredConstructed.describe()).isEqualTo(\"delta:6\");\n        } finally {\n            Context.exit();\n        }\n    }\n\n    @Test\n    void recoversAccessibleMethodsAndConstructorsFromNonPublicDeclaringClasses()\n            throws Exception {\n        Context context = Context.enter();\n        try {\n            Scriptable scope = context.initStandardObjects();\n\n            HiddenInterfaceScriptable interfaceTarget = new HiddenInterfaceScriptable();\n            Method interfaceMethod = HiddenInterfaceScriptable.class.getMethod(\n                    \"interfaceValue\", String.class);\n            FunctionObject interfaceFunction = new FunctionObject(\n                    \"interfaceValue\", interfaceMethod, scope);\n            assertThat(interfaceFunction.call(\n                    context, scope, interfaceTarget, new Object[] {\"alpha\"}))\n                    .isEqualTo(\"interface:alpha\");\n\n            HiddenSubclassScriptable subclassTarget = new HiddenSubclassScriptable();\n            Method superclassMethod = HiddenSubclassScriptable.class.getDeclaredMethod(\n                    \"baseValue\", String.class);\n            FunctionObject superclassFunction = new FunctionObject(\n                    \"baseValue\", superclassMethod, scope);\n            assertThat(superclassFunction.call(\n                    context, scope, subclassTarget, new Object[] {\"beta\"}))\n                    .isEqualTo(\"hidden-base:beta\");\n\n            Constructor<HiddenConstructedScriptable> hiddenConstructor =\n                    HiddenConstructedScriptable.class.getDeclaredConstructor();\n            FunctionObject hiddenConstructorFunction = new FunctionObject(\n                    \"HiddenConstructedScriptable\", hiddenConstructor, scope);\n            HiddenConstructedScriptable hiddenConstructed = (HiddenConstructedScriptable)\n                    hiddenConstructorFunction.call(context, scope, scope, new Object[0]);\n            assertThat(hiddenConstructed.getClassName()).isEqualTo(\"HiddenConstructed\");\n        } finally {\n            Context.exit();\n        }\n    }\n\n    private static FunctionObject roundTripFunction(FunctionObject function, Scriptable scope)\n            throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ScriptableOutputStream(bytes, scope)) {\n            output.writeObject(function);\n        }\n        try (ObjectInputStream input = new ScriptableInputStream(\n                new ByteArrayInputStream(bytes.toByteArray()), scope)) {\n            return (FunctionObject) input.readObject();\n        }\n    }\n\n    public static final class PublicOperations {\n        private PublicOperations() {\n        }\n\n        public static String combine(String value, int count) {\n            return value + \":\" + count;\n        }\n    }\n\n    public static class PublicConstructedScriptable extends ScriptableObject {\n        private final String value;\n        private final int count;\n\n        public PublicConstructedScriptable() {\n            this(\"\", 0);\n        }\n\n        public PublicConstructedScriptable(String value, int count) {\n            this.value = value;\n            this.count = count;\n        }\n\n        @Override\n        public String getClassName() {\n            return \"PublicConstructed\";\n        }\n\n        public String describe() {\n            return value + \":\" + count;\n        }\n    }\n\n    public interface PublicInterfaceOperation {\n        String interfaceValue(String value);\n    }\n\n    private static final class HiddenInterfaceScriptable extends ScriptableObject\n            implements PublicInterfaceOperation {\n        @Override\n        public String getClassName() {\n            return \"HiddenInterface\";\n        }\n\n        @Override\n        public String interfaceValue(String value) {\n            return \"interface:\" + value;\n        }\n    }\n\n    public static class PublicBaseScriptable extends ScriptableObject {\n        @Override\n        public String getClassName() {\n            return \"PublicBase\";\n        }\n\n        public String baseValue(String value) {\n            return \"base:\" + value;\n        }\n    }\n\n    private static final class HiddenSubclassScriptable extends PublicBaseScriptable {\n        @Override\n        public String baseValue(String value) {\n            return \"hidden-base:\" + value;\n        }\n    }\n\n    private static final class HiddenConstructedScriptable extends ScriptableObject {\n        public HiddenConstructedScriptable() {\n        }\n\n        @Override\n        public String getClassName() {\n            return \"HiddenConstructed\";\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1780957918991}, {"role": "toolResult", "toolCallId": "call_SLZf1O86tl9ASOJ1H4ozkrYu|fc_0807a6b14b5c4db3016a2742debf648193810c7dc04fb31aa8", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_mozilla.rhino;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.IOException;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.io.Serializable;\n\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\nimport org.mozilla.javascript.Context;\nimport org.mozilla.javascript.NativeJavaObject;\nimport org.mozilla.javascript.NativeObject;\nimport org.mozilla.javascript.Scriptable;\nimport org.mozilla.javascript.ScriptableObject;\nimport org.mozilla.javascript.Wrapper;\nimport org.mozilla.javascript.serialize.ScriptableInputStream;\nimport org.mozilla.javascript.serialize.ScriptableOutputStream;\n\npublic class NativeJavaObjectTest {\n    @Test\n    void coercesNativeArraysAndDoubleValuedJavaObjects() {\n        Context context = Context.enter();\n        try {\n            Scriptable scope = context.initStandardObjects();\n\n            Object arrayValue = context.evaluateString(\n                    scope, \"['red', 'green', 'blue']\", \"array-coercion\", 1, null);\n            Object strings = Context.jsToJava(arrayValue, String[].class);\n            assertThat((String[]) strings).containsExactly(\"red\", \"green\", \"blue\");\n\n            Object number = Context.jsToJava(new DoubleValuedObject(12.75), Double.TYPE);\n            assertThat(number).isEqualTo(12.75D);\n        } finally {\n            Context.exit();\n        }\n    }\n\n    @Test\n    void serializesAndRestoresPlainJavaObjectWrappers() throws Exception {\n        Context context = Context.enter();\n        try {\n            Scriptable scope = context.initStandardObjects();\n\n            SerializablePayload staticallyTypedPayload = new SerializablePayload(\"typed\");\n            NativeJavaObject staticallyTypedWrapper = new NativeJavaObject(\n                    scope, staticallyTypedPayload, SerializablePayload.class);\n            NativeJavaObject restoredStaticallyTypedWrapper = roundTrip(\n                    staticallyTypedWrapper, scope);\n            assertThat(restoredStaticallyTypedWrapper.unwrap())\n                    .isEqualTo(staticallyTypedPayload);\n\n            SerializablePayload dynamicallyTypedPayload = new SerializablePayload(\"dynamic\");\n            NativeJavaObject dynamicallyTypedWrapper = new NativeJavaObject(\n                    scope, dynamicallyTypedPayload, null);\n            NativeJavaObject restoredDynamicallyTypedWrapper = roundTrip(\n                    dynamicallyTypedWrapper, scope);\n            assertThat(restoredDynamicallyTypedWrapper.unwrap())\n                    .isEqualTo(dynamicallyTypedPayload);\n        } finally {\n            Context.exit();\n        }\n    }\n\n    @Test\n    void serializesAndRestoresJavaAdapterWrappers() throws Exception {\n        try {\n            exerciseJavaAdapterWrapperSerialization();\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    private static void exerciseJavaAdapterWrapperSerialization() throws Exception {\n        Context context = Context.enter();\n        try {\n            Scriptable scope = context.initStandardObjects();\n            NativeObject implementation = new NativeObject();\n            implementation.setParentScope(scope);\n            implementation.setPrototype(ScriptableObject.getObjectPrototype(scope));\n            scope.put(\"implementation\", scope, implementation);\n\n            Object adapterWrapper = context.evaluateString(scope, \"\"\"\n                    new JavaAdapter(java.lang.Runnable, implementation);\n                    \"\"\", \"adapter-wrapper-serialization\", 1, null);\n            assertThat(adapterWrapper).isInstanceOf(NativeJavaObject.class);\n            Runnable runnable = Runnable.class.cast(Context.jsToJava(\n                    adapterWrapper, Runnable.class));\n            runnable.run();\n\n            NativeJavaObject restoredWrapper = roundTrip(\n                    (NativeJavaObject) adapterWrapper, scope);\n            assertThat(restoredWrapper).isInstanceOf(Wrapper.class);\n            Runnable restoredRunnable = Runnable.class.cast(Context.jsToJava(\n                    restoredWrapper, Runnable.class));\n            restoredRunnable.run();\n        } finally {\n            Context.exit();\n        }\n    }\n\n    private static NativeJavaObject roundTrip(NativeJavaObject wrapper, Scriptable scope)\n            throws IOException, ClassNotFoundException {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ScriptableOutputStream(bytes, scope)) {\n            output.writeObject(wrapper);\n        }\n        try (ObjectInputStream input = new ScriptableInputStream(\n                new ByteArrayInputStream(bytes.toByteArray()), scope)) {\n            return (NativeJavaObject) input.readObject();\n        }\n    }\n\n    public static final class DoubleValuedObject {\n        private final double value;\n\n        DoubleValuedObject(double value) {\n            this.value = value;\n        }\n\n        public Number doubleValue() {\n            return Double.valueOf(value);\n        }\n    }\n\n    public static final class SerializablePayload implements Serializable {\n        private static final long serialVersionUID = 1L;\n\n        private final String value;\n\n        SerializablePayload(String value) {\n            this.value = value;\n        }\n\n        @Override\n        public boolean equals(Object other) {\n            if (this == other) {\n                return true;\n            }\n            if (!(other instanceof SerializablePayload)) {\n                return false;\n            }\n            SerializablePayload payload = (SerializablePayload) other;\n            return value.equals(payload.value);\n        }\n\n        @Override\n        public int hashCode() {\n            return value.hashCode();\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1780957918992}, {"role": "toolResult", "toolCallId": "call_2IkS1kM7pgFxo67UzDzUcyXF|fc_0807a6b14b5c4db3016a2742debf708193baa95bda06788a81", "toolName": "read", "content": [{"type": "text", "text": "ENOENT: no such file or directory, access '/home/vjovanov/c/forge/forge1/graalvm-reachability-metadata/forge/local_repositories/forge_worktrees/2735-fbbdc93a/tests/src/org.mozilla/rhino/1.7R5/build/reports/dynamic-access/summary.md'"}], "details": {}, "is