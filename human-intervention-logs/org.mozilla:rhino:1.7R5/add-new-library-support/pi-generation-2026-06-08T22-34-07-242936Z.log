  package org_mozilla.rhino;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.lang.reflect.Constructor;
  import java.lang.reflect.Method;
  
  import org.junit.jupiter.api.Test;
  import org.mozilla.javascript.Context;
  import org.mozilla.javascript.FunctionObject;
  import org.mozilla.javascript.Scriptable;
  import org.mozilla.javascript.ScriptableObject;
  import org.mozilla.javascript.serialize.ScriptableInputStream;
  import org.mozilla.javascript.serialize.ScriptableOutputStream;
  
  public class MemberBoxTest {
      @Test
      void invokesMethodsConstructorsAndRestoresSerializedMembers() throws Exception {
          Context context = Context.enter();
          try {
              Scriptable scope = context.initStandardObjects();
  
              Method method = PublicOperations.class.getMethod(
                      "combine", String.class, int.class);
              FunctionObject function = new FunctionObject("combine", method, scope);
              assertThat(function.call(context, scope, scope, new Object[] {"alpha", 3}))
                      .isEqualTo("alpha:3");
  
              FunctionObject restoredFunction = roundTripFunction(function, scope);
              assertThat(restoredFunction.call(context, scope, scope, new Object[] {"beta", 4}))
                      .isEqualTo("beta:4");
  
              Constructor<PublicConstructedScriptable> constructor =
                      PublicConstructedScriptable.class.getConstructor(String.class, int.class);
              FunctionObject constructorFunction = new FunctionObject(
                      "PublicConstructedScriptable", constructor, scope);
              PublicConstructedScriptable constructed = (PublicConstructedScriptable)
                      constructorFunction.call(context, scope, scope, new Object[] {"gamma", 5});
              assertThat(constructed.describe()).isEqualTo("gamma:5");
  
              FunctionObject restoredConstructorFunction = roundTripFunction(
                      constructorFunction, scope);
              PublicConstructedScriptable restoredConstructed = (PublicConstructedScriptable)
                      restoredConstructorFunction.call(
                              context, scope, scope, new Object[] {"delta", 6});
              assertThat(restoredConstructed.describe()).isEqualTo("delta:6");
          } finally {
              Context.exit();
          }
      }
  
      @Test
      void recoversAccessibleMethodsAndConstructorsFromNonPublicDeclaringClasses()
              throws Exception {
          Context context = Context.enter();
          try {
              Scriptable scope = context.initStandardObjects();
  
              HiddenInterfaceScriptable interfaceTarget = new HiddenInterfaceScriptable();
              Method interfaceMethod = HiddenInterfaceScriptable.class.getMethod(
                      "interfaceValue", String.class);
              FunctionObject interfaceFunction = new FunctionObject(
                      "interfaceValue", interfaceMethod, scope);
              assertThat(interfaceFunction.call(
                      context, scope, interfaceTarget, new Object[] {"alpha"}))
                      .isEqualTo("interface:alpha");
  
              HiddenSubclassScriptable subclassTarget = new HiddenSubclassScriptable();
              Method superclassMethod = HiddenSubclassScriptable.class.getDeclaredMethod(
                      "baseValue", String.class);
              FunctionObject superclassFunction = new FunctionObject(
                      "baseValue", superclassMethod, scope);
              assertThat(superclassFunction.call(
                      context, scope, subclassTarget, new Object[] {"beta"}))
                      .isEqualTo("hidden-base:beta");
  
              Constructor<HiddenConstructedScriptable> hiddenConstructor =
                      HiddenConstructedScriptable.class.getDeclaredConstructor();
              FunctionObject hiddenConstructorFunction = new FunctionObject(
                      "HiddenConstructedScriptable", hiddenConstructor, scope);
              HiddenConstructedScriptable hiddenConstructed = (HiddenConstructedScriptable)
                      hiddenConstructorFunction.call(context, scope, scope, new Object[0]);
              assertThat(hiddenConstructed.getClassName()).isEqualTo("HiddenConstructed");
          } finally {
              Context.exit();
          }
      }
  
      private static FunctionObject roundTripFunction(FunctionObject function, Scriptable scope)
              throws Exception {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream output = new ScriptableOutputStream(bytes, scope)) {
              output.writeObject(function);
          }
          try (ObjectInputStream input = new ScriptableInputStream(
                  new ByteArrayInputStream(bytes.toByteArray()), scope)) {
              return (FunctionObject) input.readObject();
          }
      }
  
      public static final class PublicOperations {
          private PublicOperations() {
          }
  
          public static String combine(String value, int count) {
              return value + ":" + count;
          }
      }
  
      public static class PublicConstructedScriptable extends ScriptableObject {
          private final String value;
          private final int count;
  
          public PublicConstructedScriptable() {
              this("", 0);
          }
  
          public PublicConstructedScriptable(String value, int count) {
              this.value = value;
              this.count = count;
          }
  
          @Override
          public String getClassName() {
              return "PublicConstructed";
          }
  
          public String describe() {
              return value + ":" + count;
          }
      }
  
      public interface PublicInterfaceOperation {
          String interfaceValue(String value);
      }
  
      private static final class HiddenInterfaceScriptable extends ScriptableObject
              implements PublicInterfaceOperation {
          @Override
          public String getClassName() {
              return "HiddenInterface";
          }
  
          @Override
          public String interfaceValue(String value) {
              return "interface:" + value;
          }
      }
  
      public static class PublicBaseScriptable extends ScriptableObject {
          @Override
          public String getClassName() {
              return "PublicBase";
          }
  
          public String baseValue(String value) {
              return "base:" + value;
          }
      }
  
      private static final class HiddenSubclassScriptable extends PublicBaseScriptable {
          @Override
          public String baseValue(String value) {
              return "hidden-base:" + value;
          }
      }
  
      private static final class HiddenConstructedScriptable extends ScriptableObject {
          public HiddenConstructedScriptable() {
          }
  
          @Override
          public String getClassName() {
              return "HiddenConstructed";
          }
      }
  }
