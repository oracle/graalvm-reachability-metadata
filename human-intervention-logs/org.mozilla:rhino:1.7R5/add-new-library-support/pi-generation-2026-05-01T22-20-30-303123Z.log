d rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_mozilla.rhino;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.lang.reflect.Field;\nimport java.lang.reflect.Method;\n\nimport org.junit.jupiter.api.Test;\nimport org.mozilla.javascript.Context;\nimport org.mozilla.javascript.ContextFactory;\nimport org.mozilla.javascript.FunctionObject;\nimport org.mozilla.javascript.Scriptable;\nimport org.mozilla.javascript.ScriptableObject;\n\npublic class FunctionObjectTest {\n    @Test\n    void constructsScriptableInstanceForMethodBackedFunction() throws Exception {\n        Context context = ContextFactory.getGlobal().enterContext();\n        try {\n            Scriptable scope = context.initStandardObjects();\n            Method method = MethodBackedScriptable.class.getMethod(\"jsFunction_record\", String.class);\n            FunctionObject function = new FunctionObject(\"RecordConstructed\", method, scope);\n            MethodBackedScriptable prototype = new MethodBackedScriptable();\n            function.addAsConstructor(scope, prototype);\n\n            Scriptable constructed = function.construct(context, scope, new Object[] { \"created\" });\n\n            assertThat(constructed).isInstanceOf(MethodBackedScriptable.class);\n            assertThat(ScriptableObject.getProperty(constructed, \"recorded\")).isEqualTo(\"created\");\n            assertThat(constructed.getParentScope()).isSameAs(scope);\n            assertThat(constructed.getPrototype()).isSameAs(prototype);\n        } finally {\n            Context.exit();\n        }\n    }\n\n    @Test\n    void definesScriptableClassUsingPublicMethodFallback() throws Exception {\n        Field sawSecurityException = FunctionObject.class.getDeclaredField(\"sawSecurityException\");\n        sawSecurityException.setAccessible(true);\n        boolean originalSawSecurityException = sawSecurityException.getBoolean(null);\n        sawSecurityException.setBoolean(null, true);\n\n        try {\n            Context context = ContextFactory.getGlobal().enterContext();\n            try {\n                Scriptable scope = context.initStandardObjects();\n\n                ScriptableObject.defineClass(scope, PublicMethodFallbackScriptable.class);\n                Object result = context.evaluateString(\n                        scope,\n                        \"new PublicMethodFallbackScriptable().visible()\",\n                        \"function-object-fallback\",\n                        1,\n                        null);\n\n                assertThat(Context.toString(result)).isEqualTo(\"visible\");\n            } finally {\n                Context.exit();\n            }\n        } finally {\n            sawSecurityException.setBoolean(null, originalSawSecurityException);\n        }\n    }\n\n    public static class MethodBackedScriptable extends ScriptableObject {\n        public MethodBackedScriptable() {\n        }\n\n        public String jsFunction_record(String value) {\n            ScriptableObject.putProperty(this, \"recorded\", value);\n            return value;\n        }\n\n        @Override\n        public String getClassName() {\n            return \"MethodBackedScriptable\";\n        }\n    }\n\n    public static class PublicMethodFallbackScriptable extends ScriptableObject {\n        public PublicMethodFallbackScriptable() {\n        }\n\n        public String jsFunction_visible() {\n            return \"visible\";\n        }\n\n        @Override\n        public String getClassName() {\n            return \"PublicMethodFallbackScriptable\";\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1938, "output": 2128, "cacheRead": 50176, "cacheWrite": 0, "totalTokens": 54242, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777673978231, "responseId": "resp_0efc3a474a824cab0169f526faccb4819c9a56a81535693ca6"}}
