t context = ContextFactory.getGlobal().enterContext();\n        try {\n            Scriptable scope = context.initStandardObjects();\n            Method method = SerializableApi.class.getMethod(\"format\", String.class);\n            FunctionObject original = new FunctionObject(\"format\", method, scope);\n\n            FunctionObject restored = roundTripFunction(original, scope);\n            Object result = restored.call(context, scope, scope, new Object[] { \"rhino\" });\n\n            assertThat(Context.toString(result)).isEqualTo(\"method:rhino\");\n        } finally {\n            Context.exit();\n        }\n    }\n\n    @Test\n    void serializesAndRestoresFunctionObjectBackedByConstructor() throws Exception {\n        Context context = ContextFactory.getGlobal().enterContext();\n        try {\n            Scriptable scope = context.initStandardObjects();\n            Constructor<ConstructedScriptable> constructor = ConstructedScriptable.class.getConstructor(String.class);\n            FunctionObject original = new FunctionObject(\"ConstructedScriptable\", constructor, scope);\n\n            FunctionObject restored = roundTripFunction(original, scope);\n            Object result = restored.call(context, scope, scope, new Object[] { \"constructor\" });\n\n            assertThat(result).isInstanceOf(ConstructedScriptable.class);\n            assertThat(((ConstructedScriptable) result).getValue()).isEqualTo(\"constructor\");\n        } finally {\n            Context.exit();\n        }\n    }\n\n    @Test\n    void invokesInaccessibleImplementationMethodThroughPublicInterface() throws Exception {\n        Context context = ContextFactory.getGlobal().enterContext();\n        try {\n            Scriptable scope = context.initStandardObjects();\n            Method method = InterfaceImplementation.class.getDeclaredMethod(\"describe\", String.class);\n            FunctionObject function = new FunctionObject(\"describe\", method, scope);\n            InterfaceImplementation target = new InterfaceImplementation();\n\n            Object result = function.call(context, scope, target, new Object[] { \"interface\" });\n\n            assertThat(Context.toString(result)).isEqualTo(\"interface:interface\");\n        } finally {\n            Context.exit();\n        }\n    }\n\n    @Test\n    void invokesInaccessibleOverrideThroughPublicSuperclass() throws Exception {\n        Context context = ContextFactory.getGlobal().enterContext();\n        try {\n            Scriptable scope = context.initStandardObjects();\n            Method method = SuperclassImplementation.class.getDeclaredMethod(\"describe\", String.class);\n            FunctionObject function = new FunctionObject(\"describe\", method, scope);\n            SuperclassImplementation target = new SuperclassImplementation();\n\n            Object result = function.call(context, scope, target, new Object[] { \"superclass\" });\n\n            assertThat(Context.toString(result)).isEqualTo(\"superclass:superclass\");\n        } finally {\n            Context.exit();\n        }\n    }\n\n    @Test\n    void constructsInaccessibleScriptableAfterMakingConstructorAccessible() throws Exception {\n        Context context = ContextFactory.getGlobal().enterContext();\n        try {\n            Scriptable scope = context.initStandardObjects();\n            Constructor<HiddenConstructedScriptable> constructor =\n                    HiddenConstructedScriptable.class.getDeclaredConstructor(String.class);\n            FunctionObject function = new FunctionObject(\"HiddenConstructedScriptable\", constructor, scope);\n\n            Object result = function.call(context, scope, scope, new Object[] { \"hidden\" });\n\n            assertThat(result).isInstanceOf(HiddenConstructedScriptable.class);\n            assertThat(((HiddenConstructedScriptable) result).getValue()).isEqualTo(\"hidden\");\n        } finally {\n            Context.exit();\n        }\n    }\n\n    private static FunctionObject roundTripFunction(FunctionObject function, Scriptable scope) throws Exception {\n        ByteArrayOutputStream buffer = new ByteArrayOutputStream();\n        try (ScriptableOutputStream output = new ScriptableOutputStream(buffer, scope)) {\n            output.writeObject(function);\n        }\n\n        try (ScriptableInputStream input = new ScriptableInputStream(new ByteArrayInputStream(buffer.toByteArray()), scope)) {\n            return (FunctionObject) input.readObject();\n        }\n    }\n\n    public static class SerializableApi {\n        public static String format(String value) {\n            return \"method:\" + value;\n        }\n    }\n\n    public static class ConstructedScriptable extends ScriptableObject {\n        private final String value;\n\n        public ConstructedScriptable(String value) {\n            this.value = value;\n        }\n\n        @Override\n        public String getClassName() {\n            return \"ConstructedScriptable\";\n        }\n\n        public String getValue() {\n            return value;\n        }\n    }\n\n    public interface PublicDescriber {\n        String describe(String value);\n    }\n\n    private static class InterfaceImplementation extends ScriptableObject implements PublicDescriber {\n        @Override\n        public String getClassName() {\n            return \"InterfaceImplementation\";\n        }\n\n        @Override\n        public String describe(String value) {\n            return \"interface:\" + value;\n        }\n    }\n\n    public static class PublicDescriberBase extends ScriptableObject {\n        @Override\n        public String getClassName() {\n            return \"PublicDescriberBase\";\n        }\n\n        public String describe(String value) {\n            return \"superclass:\" + value;\n        }\n    }\n\n    private static class SuperclassImplementation extends PublicDescriberBase {\n        @Override\n        public String getClassName() {\n            return \"SuperclassImplementati