          private MethodSignature(String name, Class<?>[] args)
          {
              this.name = name;
              this.args = args;
          }
  
          MethodSignature(Method method)
          {
              this(method.getName(), method.getParameterTypes());
          }
  
          @Override
          public boolean equals(Object o)
          {
              if(o instanceof MethodSignature)
