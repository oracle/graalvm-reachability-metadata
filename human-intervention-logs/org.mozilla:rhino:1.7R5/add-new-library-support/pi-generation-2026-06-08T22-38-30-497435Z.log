  package org_mozilla.rhino;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import org.junit.jupiter.api.Test;
  import org.mozilla.javascript.Context;
  import org.mozilla.javascript.ContextFactory;
  import org.mozilla.javascript.NativeJavaClass;
  import org.mozilla.javascript.NativeJavaObject;
  import org.mozilla.javascript.Scriptable;
  import org.mozilla.javascript.ScriptableObject;
  import org.mozilla.javascript.Wrapper;
  
  public class JavaMembersTest {
      @Test
      void reflectsJavaObjectMethodsAndReadsAndWritesPublicFields() {
          Context context = Context.enter();
          try {
              Scriptable scope = context.initStandardObjects();
              FieldBackedRecord record = new FieldBackedRecord("alpha", 7);
              NativeJavaObject wrapper = new NativeJavaObject(
                      scope, record, FieldBackedRecord.class);
  
              Object initialCount = wrapper.get("count", wrapper);
              assertThat(Context.jsToJava(initialCount, Integer.class)).isEqualTo(7);
  
              wrapper.put("count", wrapper, 12);
              wrapper.put("label", wrapper, "beta");
  
              Object description = ScriptableObject.callMethod(
                      context, wrapper, "describe", new Object[] {"value"});
              assertThat(Context.toString(description)).isEqualTo("value:beta:12");
              assertThat(record.count).isEqualTo(12);
              assertThat(record.label).isEqualTo("beta");
          } finally {
              Context.exit();
          }
      }
  
      @Test
      void enhancedJavaAccessReflectsAndInvokesPrivateConstructors() {
          Object constructed = new EnhancedJavaAccessContextFactory().call(context -> {
              Scriptable scope = context.initStandardObjects();
              NativeJavaClass javaClass = new NativeJavaClass(
                      scope, PrivateConstructorRecord.class);
              Scriptable wrapper = javaClass.construct(
                      context, scope, new Object[] {"secret", 4});
              return ((Wrapper) wrapper).unwrap();
          });
  
          assertThat(constructed).isInstanceOf(PrivateConstructorRecord.class);
          PrivateConstructorRecord record = (PrivateConstructorRecord) constructed;
          assertThat(record.reveal()).isEqualTo("secret:4");
      }
  
      public static final class FieldBackedRecord {
          public String label;
          public int count;
  
          public FieldBackedRecord(String label, int count) {
              this.label = label;
              this.count = count;
          }
  
          public String describe(String prefix) {
              return prefix + ":" + label + ":" + count;
          }
      }
  
      public static final class PrivateConstructorRecord {
          private final String label;
          private final int count;
  
          private PrivateConstructorRecord(String label, int count) {
              this.label = label;
              this.count = count;
          }
  
          public String reveal() {
              return label + ":" + count;
          }
      }
  
      private static final class EnhancedJavaAccessContextFactory extends ContextFactory {
          @Override
          protected boolean hasFeature(Context context, int featureIndex) {
              if (featureIndex == Context.FEATURE_ENHANCED_JAVA_ACCESS) {
                  return true;
              }
              return super.hasFeature(context, featureIndex);
          }
      }
  }
