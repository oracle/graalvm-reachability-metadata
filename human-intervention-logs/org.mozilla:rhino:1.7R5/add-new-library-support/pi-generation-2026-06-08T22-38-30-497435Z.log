                                            isAdapter);
          fieldAndMethods
              = members.getFieldAndMethodsObjects(this, javaObject, false);
      }
  
      public boolean has(String name, Scriptable start) {
          return members.has(name, false);
      }
  
      public boolean has(int index, Scriptable start) {
  
