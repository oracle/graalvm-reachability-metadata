  package org_mozilla.rhino;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  
  import org.junit.jupiter.api.Test;
  import org.mozilla.javascript.Context;
  import org.mozilla.javascript.FunctionObject;
  import org.mozilla.javascript.Scriptable;
  import org.mozilla.javascript.ScriptableObject;
  
  public class ScriptableObjectTest {
      @Test
      void definesScriptableClassesUsingInitializersConstructorsAndFinishHooks()
              throws Exception {
          Context context = Context.enter();
          try {
              Scriptable scope = context.initStandardObjects();
  
              String initializedClassName = ScriptableObject.defineClass(
                      scope, ScriptableInitializer.class, false, false);
              assertThat(initializedClassName).isNull();
              assertThat(ScriptableObject.getProperty(scope, "scriptableInitializerCalled"))
                      .isEqualTo(Boolean.TRUE);
  
              String constructedClassName = ScriptableObject.defineClass(
                      scope, ConstructorBackedScriptable.class, false, false);
              assertThat(constructedClassName).isEqualTo("ConstructorBackedScriptable");
  
              Object result = context.evaluateString(scope, """
                      var instance = new ConstructorBackedScriptable('alpha');
                      instance.describe() + ':'
                          + ConstructorBackedScriptable.staticDescribe() + ':'
                          + ConstructorBackedScriptable.finished + ':'
                          + instance.finishMarker;
                      """, "scriptable-object-define-class", 1, null);
              assertThat(Context.toString(result)).isEqualTo("alpha:static:complete:prototype");
          } finally {
              Context.exit();
          }
      }
  
      @Test
      void serializesAndRestoresScriptableObjectSlots() throws Exception {
          SerializableScriptable scriptable = new SerializableScriptable();
          scriptable.put("alpha", scriptable, "one");
          scriptable.put(7, scriptable, "seven");
  
          SerializableScriptable restored = roundTrip(scriptable);
  
          assertThat(restored.get("alpha", restored)).isEqualTo("one");
          assertThat(restored.get(7, restored)).isEqualTo("seven");
      }
  
      private static SerializableScriptable roundTrip(SerializableScriptable scriptable)
              throws Exception {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {
              output.writeObject(scriptable);
          }
          try (ObjectInputStream input = new ObjectInputStream(
                  new ByteArrayInputStream(bytes.toByteArray()))) {
              return (SerializableScriptable) input.readObject();
          }
      }
  
      public static class ScriptableInitializer extends ScriptableObject {
          private static final long serialVersionUID = 1L;
  
          public static void init(Scriptable scope) {
              ScriptableObject.putProperty(scope, "scriptableInitializerCalled", Boolean.TRUE);
          }
  
          @Override
          public String getClassName() {
              return "ScriptableInitializer";
          }
      }
  
      public static class ConstructorBackedScriptable extends ScriptableObject {
          private static final long serialVersionUID = 1L;
  
          private String value;
  
          public ConstructorBackedScriptable() {
          }
  
          public void jsConstructor(String newValue) {
              value = newValue;
          }
  
          public String jsFunction_describe() {
              return value;
          }
  
          public static String jsStaticFunction_staticDescribe() {
              return "static";
          }
  
          public static void finishInit(
                  Scriptable scope, FunctionObject constructor, Scriptable prototype) {
              ScriptableObject.putProperty(constructor, "finished", "complete");
              ScriptableObject.putProperty(prototype, "finishMarker", "prototype");
          }
  
          @Override
          public String getClassName() {
              return "ConstructorBackedScriptable";
          }
      }
  
      public static class SerializableScriptable extends ScriptableObject {
          private static final long serialVersionUID = 1L;
  
          @Override
          public String getClassName() {
              return "SerializableScriptable";
          }
      }
  }
