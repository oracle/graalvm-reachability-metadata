ts waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_mozilla.rhino;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\n\nimport org.junit.jupiter.api.Test;\nimport org.mozilla.javascript.Context;\nimport org.mozilla.javascript.FunctionObject;\nimport org.mozilla.javascript.Scriptable;\nimport org.mozilla.javascript.ScriptableObject;\n\npublic class ScriptableObjectTest {\n    @Test\n    void definesScriptableClassesUsingInitializersConstructorsAndFinishHooks()\n            throws Exception {\n        Context context = Context.enter();\n        try {\n            Scriptable scope = context.initStandardObjects();\n\n            String initializedClassName = ScriptableObject.defineClass(\n                    scope, ScriptableInitializer.class, false, false);\n            assertThat(initializedClassName).isNull();\n            assertThat(ScriptableObject.getProperty(scope, \"scriptableInitializerCalled\"))\n                    .isEqualTo(Boolean.TRUE);\n\n            String constructedClassName = ScriptableObject.defineClass(\n                    scope, ConstructorBackedScriptable.class, false, false);\n            assertThat(constructedClassName).isEqualTo(\"ConstructorBackedScriptable\");\n\n            Object result = context.evaluateString(scope, \"\"\"\n                    var instance = new ConstructorBackedScriptable('alpha');\n                    instance.describe() + ':'\n                        + ConstructorBackedScriptable.staticDescribe() + ':'\n                        + ConstructorBackedScriptable.finished + ':'\n                        + instance.finishMarker;\n                    \"\"\", \"scriptable-object-define-class\", 1, null);\n            assertThat(Context.toString(result)).isEqualTo(\"alpha:static:complete:prototype\");\n        } finally {\n            Context.exit();\n        }\n    }\n\n    @Test\n    void serializesAndRestoresScriptableObjectSlots() throws Exception {\n        SerializableScriptable scriptable = new SerializableScriptable();\n        scriptable.put(\"alpha\", scriptable, \"one\");\n        scriptable.put(7, scriptable, \"seven\");\n\n        SerializableScriptable restored = roundTrip(scriptable);\n\n        assertThat(restored.get(\"alpha\", restored)).isEqualTo(\"one\");\n        assertThat(restored.get(7, restored)).isEqualTo(\"seven\");\n    }\n\n    private static SerializableScriptable roundTrip(SerializableScriptable scriptable)\n            throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(scriptable);\n        }\n        try (ObjectInputStream input = new ObjectInputStream(\n                new ByteArrayInputStream(bytes.toByteArray()))) {\n            return (SerializableScriptable) input.readObject();\n        }\n    }\n\n    public static class ScriptableInitializer extends ScriptableObject {\n        private static final long serialVersionUID = 1L;\n\n        public static void init(Scriptable scope) {\n            ScriptableObject.putProperty(scope, \"scriptableInitializerCalled\", Boolean.TRUE);\n        }\n\n        @Override\n        public String getClassName() {\n            return \"ScriptableInitializer\";\n        }\n    }\n\n    public static class ConstructorBackedScriptable extends ScriptableObject {\n        private static final long serialVersionUID = 1L;\n\n        private String value;\n\n        public ConstructorBackedScriptable() {\n        }\n\n        public void jsConstructor(String newValue) {\n            value = newValue;\n        }\n\n        public String jsFunction_describe() {\n            return value;\n        }\n\n        public static String jsStaticFunction_staticDescribe() {\n            return \"static\";\n        }\n\n        public static void finishInit(\n                Scriptable scope, FunctionObject constructor, Scriptable prototype) {\n            ScriptableObject.putProperty(constructor, \"finished\", \"complete\");\n            ScriptableObject.putProperty(prototype, \"finishMarker\", \"prototype\");\n        }\n\n        @Override\n        public String getClassName() {\n            return \"ConstructorBackedScriptable\";\n        }\n    }\n\n    public static class SerializableScriptable extends ScriptableObject {\n        private static final long serialVersionUID = 1L;\n\n        @Override\n        public String getClassName() {\n            return \"SerializableScriptable\";\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1780958176022}, {"role": "toolResult", "toolCallId": "call_Lbd0W8j9y3pRh1Njt2I0IEN6|fc_0f7eb2e5bab4dc30016a2743dfb45c81908af40f4163656c81", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_mozilla.rhino;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.lang.reflect.Constructor;\nimport java.lang.reflect.Method;\n\nimport org.junit.jupiter.api.Test;\nimport org.mozilla.javascript.Context;\nimport org.mozilla.javascript.FunctionObject;\nimport org.mozilla.javascript.Scriptable;\nimport org.mozilla.javascript.ScriptableObject;\nimport org.mozilla.javascript.serialize.ScriptableInputStream;\nimport org.mozilla.javascript.serialize.ScriptableOutputStream;\n\npublic class MemberBoxTest {\n    @Test\n    void invokesMethodsConstructorsAndRestoresSerializedMembers() throws Exception {\n        Context context = Context.enter();\n        try {\n            Scriptable scope = context.initStandardObjects();\n\n            Method method = PublicOperations.class.getMethod(\n                    \"combine\", String.class, int.class);\n            FunctionObject function = new FunctionObject(\"combine\", method, scope);\n            assertThat(function.call(context, scope, scope, new Object[] {\"alpha\", 3}))\n                    .isEqualTo(\"alpha:3\");\n\n            FunctionObject restoredFunction = roundTripFunction(function, scope);\n            assertThat(restoredFunction.call(context, scope, scope, new Object[] {\"beta\", 4}))\n                    .isEqualTo(\"beta:4\");\n\n            Constructor<PublicConstructedScriptable> constructor =\n                    PublicConstructedScriptable.class.getConstructor(String.class, int.class);\n            FunctionObject constructorFunction = new FunctionObject(\n                    \"PublicConstructedScriptable\", constructor, scope);\n            PublicConstructedScriptable constructed = (PublicConstructedScriptable)\n                    constructorFunction.call(context, scope, scope, new Object[] {\"gamma\", 5});\n            assertThat(constructed.describe()).isEqualTo(\"gamma:5\");\n\n            FunctionObject restoredConstructorFunction = roundTripFunction(\n                    constructorFunction, scope);\n            PublicConstructedScriptable restoredConstructed = (PublicConstructedScriptable)\n                    restoredConstructorFunction.call(\n                            context, scope, scope, new Object[] {\"delta\", 6});\n            assertThat(restoredConstructed.describe()).isEqualTo(\"delta:6\");\n        } finally {\n            Context.exit();\n        }\n    }\n\n    @Test\n    void recoversAccessibleMethodsAndConstructorsFromNonPublicDeclaringClasses()\n            throws Exception {\n        Context context = Context.enter();\n        try {\n            Scriptable scope = context.initStandardObjects();\n\n            HiddenInterfaceScriptable interfaceTarget = new HiddenInterfaceScriptable();\n            Method interfaceMethod = HiddenInterfaceScriptable.class.getMethod(\n                    \"interfaceValue\", String.class);\n            FunctionObject interfaceFunction = new FunctionObject(\n                    \"interfaceValue\", interfaceMethod, scope);\n            assertThat(interfaceFunction.call(\n                    context, scope, interfaceTarget, new Object[] {\"alpha\"}))\n                    .isEqualTo(\"interface:alpha\");\n\n            HiddenSubclassScriptable subclassTarget = new HiddenSubclassScriptable();\n            Method superclassMethod = HiddenSubclassScriptable.class.getDeclaredMethod(\n                    \"baseValue\", String.class);\n            FunctionObject superclassFunction = new FunctionObject(\n                    \"baseValue\", superclassMethod, scope);\n            assertThat(superclassFunction.call(\n                    context, scope, subclassTarget, new Object[] {\"beta\"}))\n                    .isEqualTo(\"hidden-base:beta\");\n\n            Constructor<HiddenConstructedScriptable> hiddenConstructor =\n                    HiddenConstructedScriptable.class.getDeclaredConstructor();\n            FunctionObject hiddenConstructorFunction = new FunctionObject(\n                    \"HiddenConstructedScriptable\", hiddenConstructor, scope);\n            HiddenConstructedScriptable hiddenConstructed = (HiddenConstructedScriptable)\n                    hiddenConstructorFunction.call(context, scope, scope, new Object[0]);\n            assertThat(hiddenConstructed.getClassName()).isEqualTo(\"HiddenConstructed\");\n        } finally {\n            Context.exit();\n        }\n    }\n\n    private static FunctionObject roundTripFunction(FunctionObject function, Scriptable scope)\n            throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ScriptableOutputStream(bytes, scope)) {\n            output.writeObject(function);\n        }\n        try (ObjectInputStream input = new ScriptableInputStream(\n                new ByteArrayInputStream(bytes.toByteArray()), scope)) {\n            return (FunctionObject) input.readObject();\n        }\n    }\n\n    public static final class PublicOperations {\n        private PublicOperations() {\n        }\n\n        public static String combine(String value, int count) {\n            return value + \":\" + count;\n        }\n    }\n\n    public static class PublicConstructedScriptable extends ScriptableObject {\n        private final String value;\n        private final int count;\n\n        public PublicConstructedScriptable() {\n            this(\"\", 0);\n        }\n\n        public PublicConstructedScriptable(String value, int count) {\n            this.value = value;\n            this.count = count;\n        }\n\n        @Override\n        public String getClassName() {\n            return \"PublicConstructed\";\n        }\n\n        public String describe() {\n            return value + \":\" + count;\n        }\n    }\n\n    public interface PublicInterfaceOperation {\n        String interfaceValue(String value);\n    }\n\n    private static final class HiddenInterfaceScriptable extends ScriptableObject\n            implements PublicInterfaceOperation {\n        @Override\n        public String getClassName() {\n            return \"HiddenInterface\";\n        }\n\n        @Override\n        public String interfaceValue(String value) {\n            return \"interface:\" + value;\n        }\n    }\n\n    public static class PublicBaseScriptable extends ScriptableObject {\n        @Override\n        public String getClassName() {\n            return \"PublicBase\";\n        }\n\n        public String baseValue(String value) {\n            return \"base:\" + value;\n        }\n    }\n\n    private static final class HiddenSubclassScriptable extends PublicBaseScriptable {\n        @Override\n        public String baseValue(String value) {\n            return \"hidden-base:\" + value;\n        }\n    }\n\n    private static final class HiddenConstructedScriptable extends ScriptableObject {\n        public HiddenConstructedScriptable() {\n        }\n\n        @Override\n        public String getClassName() {\n            return \"HiddenConstructed\";\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1780958176023}, {"role": "toolResult", "toolCallId": "call_Po0U09RQzTGsGanK0Llh9V1m|fc_0f7eb2e5bab4dc30016a2743dfb46481909ede5811c29110e8", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_mozilla.rhino;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.IOException;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.util.concurrent.Callable;\n\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\nimport org.mozilla.javascript.Context;\nimport org.mozilla.javascript.JavaAdapter;\nimport org.mozilla.javascript.NativeJavaClass;\nimport org.mozilla.javascript.NativeObject;\nimport org.mozilla.javascript.Scriptable;\nimport org.mozilla.javascript.ScriptableObject;\nimport org.mozilla.javascript.Wrapper;\n\npublic class JavaAdapterTest {\n    @Test\n    void createsInvokesSerializesAndRestoresJavaAdapter() throws Exception {\n        try {\n            exerciseJavaAdapter();\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    private static void exerciseJavaAdapter() throws Exception {\n        Context context = Context.enter();\n        try {\n            Scriptable scope = context.initStandardObjects();\n            NativeObject implementation = new NativeObject();\n            implementation.setParentScope(scope);\n            implementation.setPrototype(ScriptableObject.getObjectPrototype(scope));\n            scope.put(\"implementation\", scope, implementation);\n            Object adapterWrapper = context.evaluateString(scope, \"\"\"\n                    new JavaAdapter(\n                        java.lang.Runnable,\n                        java.util.concurrent.Callable,\n                        implementation);\n                    \"\"\", \"java-adapter-test\", 1, null);\n\n            assertThat(adapterWrapper).isInstanceOf(Wrapper.class);\n            Object adapter = ((Wrapper) adapterWrapper).unwrap();\n\n            Runnable runnable = Runnable.class.cast(\n                    Context.jsToJava(adapterWrapper, Runnable.class));\n            Callable<?> callable = Callable.class.cast(\n                    Context.jsToJava(adapterWrapper, Callable.class));\n            runnable.run();\n            assertThat(callable.call()).isNull();\n\n            scope.put(\"implementedOperation\", scope,\n                    new NativeJavaClass(scope, ImplementedOperation.class));\n            scope.put(\"operationBase\", scope,\n                    new NativeJavaClass(scope, OperationBase.class));\n            Object operationAdapterWrapper = context.evaluateString(scope, \"\"\"\n                    new JavaAdapter(\n                        operationBase,\n                        implementedOperation,\n                        implementation);\n                    \"\"\", \"java-adapter-operation-test\", 1, null);\n            Object operationAdapter = Context.jsToJava(\n                    operationAdapterWrapper, ImplementedOperation.class);\n            assertThat(operationAdapter).isInstanceOf(ImplementedOperation.class);\n            ImplementedOperation operation = ImplementedOperation.class.cast(operationAdapter);\n            assertThat(operation.operate(\"alpha\")).isEqualTo(\"base:alpha\");\n\n            implementation.setParentScope(null);\n            implementation.setPrototype(null);\n            byte[] serializedAdapter = writeAdapter(adapter);\n            Object restoredAdapter = readAdapter(scope, serializedAdapter);\n\n            assertThat(restoredAdapter)\n                    .isInstanceOf(Runnable.class)\n                    .isInstanceOf(Callable.class);\n            Runnable restoredRunnable = Runnable.class.cast(restoredAdapter);\n            Callable<?> restoredCallable = Callable.class.cast(restoredAdapter);\n            restoredRunnable.run();\n            assertThat(restoredCallable.call()).isNull();\n        } finally {\n            Context.exit();\n        }\n    }\n\n    private static byte[] writeAdapter(Object adapter) throws IOException {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            JavaAdapter.writeAdapterObject(adapter, output);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static Object readAdapter(Scriptable scope, byte[] serializedAdapter)\n            throws IOException, ClassNotFoundException {\n        try (ObjectInputStream input = new ObjectInputStream(\n                new ByteArrayInputStream(serializedAdapter))) {\n            return JavaAdapter.readAdapterObject(scope, input);\n        }\n    }\n\n    public interface ImplementedOperation {\n        String operate(String value);\n    }\n\n    public static class OperationBase {\n        public String operate(String value) {\n            return \"base:\" + value;\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1780958176023}]}
