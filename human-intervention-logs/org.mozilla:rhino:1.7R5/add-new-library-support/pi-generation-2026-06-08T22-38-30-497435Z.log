  package org_mozilla.rhino;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.lang.reflect.ReflectPermission;
  import java.security.Permission;
  
  import org.junit.jupiter.api.Test;
  import org.mozilla.javascript.Context;
  import org.mozilla.javascript.ContextFactory;
  import org.mozilla.javascript.NativeJavaClass;
  import org.mozilla.javascript.NativeJavaObject;
  import org.mozilla.javascript.Scriptable;
  import org.mozilla.javascript.ScriptableObject;
  
  public class JavaMembersTest {
      @Test
      void reflectsJavaObjectMethodsAndReadsAndWritesPublicFields() {
          Context context = Context.enter();
          try {
              Scriptable scope = context.initStandardObjects();
              FieldBackedRecord record = new FieldBackedRecord("alpha", 7);
              NativeJavaObject wrapper = new NativeJavaObject(
                      scope, record, FieldBackedRecord.class);
  
              Object initialCount = wrapper.get("count", wrapper);
              assertThat(Context.jsToJava(initialCount, Integer.class)).isEqualTo(7);
  
              wrapper.put("count", wrapper, 12);
              wrapper.put("label", wrapper, "beta");
  
              Object description = ScriptableObject.callMethod(
                      context, wrapper, "describe", new Object[] {"value"});
              assertThat(Context.toString(description)).isEqualTo("value:beta:12");
              assertThat(record.count).isEqualTo(12);
              assertThat(record.label).isEqualTo("beta");
          } finally {
              Context.exit();
          }
      }
  
      @Test
      @SuppressWarnings("removal")
      void enhancedJavaAccessFallsBackToPublicMethodsWhenPrivateAccessIsDenied() {
          SecurityManager previousSecurityManager = System.getSecurityManager();
          boolean securityManagerInstalled = installReflectAccessDenyingSecurityManager(
                  previousSecurityManager);
  
          try {
              Object hasPublicMethod = new EnhancedJavaAccessContextFactory().call(context -> {
                  Scriptable scope = context.initStandardObjects();
                  NativeJavaClass javaClass = new NativeJavaClass(
                          scope, RestrictedInterface.class);
                  return javaClass.has("publicStaticValue", javaClass);
              });
  
              assertThat(hasPublicMethod).isEqualTo(Boolean.TRUE);
          } finally {
              if (securityManagerInstalled) {
                  System.setSecurityManager(previousSecurityManager);
              }
          }
      }
  
      public static final class FieldBackedRecord {
          public String label;
          public int count;
  
          public FieldBackedRecord(String label, int count) {
              this.label = label;
              this.count = count;
          }
  
          public String describe(String prefix) {
              return prefix + ":" + label + ":" + count;
          }
      }
  
      public interface RestrictedInterface {
          static String publicStaticValue() {
              return "public";
          }
  
          private String privateValue() {
              return "private";
          }
      }
  
      @SuppressWarnings("removal")
      private static boolean installReflectAccessDenyingSecurityManager(
              SecurityManager previousSecurityManager) {
          if (previousSecurityManager != null) {
              return false;
          }
          try {
              System.setSecurityManager(new ReflectAccessDenyingSecurityManager());
              return true;
          } catch (UnsupportedOperationException | SecurityException exception) {
              return false;
          }
      }
  
      @SuppressWarnings("removal")
      private static final class ReflectAccessDenyingSecurityManager extends SecurityManager {
          @Override
          public void checkPermission(Permission permission) {
              denyReflectAccess(permission);
          }
  
          @Override
          public void checkPermission(Permission permission, Object context) {
              denyReflectAccess(permission);
          }
  
          private void denyReflectAccess(Permission permission) {
              if (permission instanceof ReflectPermission
                      && "suppressAccessChecks".equals(permission.getName())) {
                  throw new SecurityException(permission.getName());
              }
          }
      }
  
      private static final class EnhancedJavaAccessContextFactory extends ContextFactory {
          @Override
          protected boolean hasFeature(Context context, int featureIndex) {
              if (featureIndex == Context.FEATURE_ENHANCED_JAVA_ACCESS) {
                  return true;
              }
              return super.hasFeature(context, featureIndex);
          }
      }
  }
