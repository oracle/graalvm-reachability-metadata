ap(2);\n        original.put(\"first\", 11);\n        original.put(\"second\", 22);\n        original.put(\"removed\", 99);\n        original.remove(\"removed\");\n        original.put(\"third\", 33);\n\n        ObjToIntMap restored = deserialize(serialize(original));\n\n        assertThat(restored.size()).isEqualTo(3);\n        assertThat(restored.get(\"first\", -1)).isEqualTo(11);\n        assertThat(restored.get(\"second\", -1)).isEqualTo(22);\n        assertThat(restored.get(\"third\", -1)).isEqualTo(33);\n        assertThat(restored.has(\"removed\")).isFalse();\n        assertThat(restored.get(\"missing\", 42)).isEqualTo(42);\n        assertThat(restored.getKeys()).containsExactlyInAnyOrder(\"first\", \"second\", \"third\");\n    }\n\n    private static byte[] serialize(ObjToIntMap value) throws Exception {\n        ByteArrayOutputStream outputStream = new ByteArrayOutputStream();\n\n        try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(outputStream)) {\n            objectOutputStream.writeObject(value);\n        }\n\n        return outputStream.toByteArray();\n    }\n\n    private static ObjToIntMap deserialize(byte[] serialized) throws Exception {\n        try (ObjectInputStream objectInputStream = new ObjectInputStream(new ByteArrayInputStream(serialized))) {\n            return (ObjToIntMap) objectInputStream.readObject();\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777675148546}]}
