      Object invokeImpl(Context cx,
                        Object target,
                        Scriptable topScope,
                        Object thisObject,
                        Method method,
                        Object[] args)
      {
          Callable function;
          if (target instanceof Callable) {
              function = (Callable)target;
          } else {
              Scriptable s = (Scriptable)target;
              String methodName = method.getName();
