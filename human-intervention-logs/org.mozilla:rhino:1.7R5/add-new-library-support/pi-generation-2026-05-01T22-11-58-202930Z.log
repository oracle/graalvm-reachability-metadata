javaToJS(new ConversionApi(), scope));\n\n            Object result = context.evaluateString(scope, \"api.join(['rhino', 7, true]);\", \"array-coercion\", 1, null);\n\n            assertThat(Context.toString(result)).isEqualTo(\"rhino,7,true\");\n        } finally {\n            Context.exit();\n        }\n    }\n\n    @Test\n    void coercesWrappedObjectWithDoubleValueToJavaDoubleArgument() {\n        Context context = ContextFactory.getGlobal().enterContext();\n        try {\n            Scriptable scope = context.initStandardObjects();\n            ScriptableObject.putProperty(scope, \"api\", Context.javaToJS(new ConversionApi(), scope));\n            ScriptableObject.putProperty(scope, \"numeric\", Context.javaToJS(new NumericValue(21.25d), scope));\n\n            Object result = context.evaluateString(scope, \"api.describeDouble(numeric);\", \"double-coercion\", 1, null);\n\n            assertThat(Context.toString(result)).isEqualTo(\"42.5\");\n        } finally {\n            Context.exit();\n        }\n    }\n\n    private static NativeJavaObject roundTrip(NativeJavaObject original, Scriptable scope) throws Exception {\n        ByteArrayOutputStream buffer = new ByteArrayOutputStream();\n        try (ScriptableOutputStream output = new ScriptableOutputStream(buffer, scope)) {\n            output.writeObject(original);\n        }\n\n        try (ScriptableInputStream input = new ScriptableInputStream(\n                new ByteArrayInputStream(buffer.toByteArray()),\n                scope\n        )) {\n            return (NativeJavaObject) input.readObject();\n        }\n    }\n\n    public static class ConversionApi {\n        public String join(String[] values) {\n            return String.join(\",\", Arrays.asList(values));\n        }\n\n        public String describeDouble(double value) {\n            return Double.toString(value * 2.0d);\n        }\n    }\n\n    public static class NumericValue implements Serializable {\n        private static final long 