[tool-call] delta {"path":"tests/src/org.mozilla/rhino/1.7R5/src/test/java/org_mozilla/rhino/VMBridgeJdk13Test.java","edits":[{"oldText":"    @Test\n    void adaptsJavaScriptFunctionToJavaInterfaceProxy() throws Exception {\n        Context context = ContextFactory.getGlobal().enterContext();\n        try {\n            Scriptable scope = context.initStandardObjects();\n            Object function = context.evaluateString(scope,\n                    \"(function() { return 'rhino interface proxy'; })\",\n                    \"interface-proxy\",\n                    1,\n                    null);\n\n            Object proxy = Context.jsToJava(function, Callable.class);\n            Object result = ((Callable<?>) proxy).call();\n\n            assertThat(proxy).isInstanceOf(Callable.class);\n            assertThat(Context.toString(result)).isEqualTo(\"rhino interface proxy\");\n        } finally {\n            Context.exit();\n        }\n    }\n","newText":"    @Test\n    void adaptsJavaScriptFunctionToJavaInterfaceProxy() {\n        Context context = ContextFactory.getGlobal().enterContext();\n        try {\n            Scriptable scope = context.initStandardObjects();\n            Object api = Context.javaToJS(new CallableConsumer(), scope);\n            ScriptableObject.putProperty(scope, \"api\", api);\n\n            Object result = context.evaluateString(scope, \"\"\"\n                    api.call(function() {\n                        return 'rhino interface proxy';\n                    });\n                    \"\"\", \"interface-proxy\", 1, null);\n\n            assertThat(Context.toString(result)).isEqualTo(\"rhino interface proxy\");\n        } finally {\n            Context.exit();\n        }\n    }\n\n    public static class CallableConsumer {\n        public Object call(Callable<?> callable) throws Exception {\n            return callable.call();\n        }\n    }\n"}]}
