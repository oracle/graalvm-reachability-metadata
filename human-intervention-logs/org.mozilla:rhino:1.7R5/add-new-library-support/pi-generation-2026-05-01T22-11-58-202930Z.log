[tool-call] delta {"path":"tests/src/org.mozilla/rhino/1.7R5/src/test/java/org_mozilla/rhino/VMBridgeJdk13Test.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_mozilla.rhino;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.util.concurrent.Callable;\n\nimport org.junit.jupiter.api.Test;\nimport org.mozilla.javascript.Context;\nimport org.mozilla.javascript.ContextFactory;\nimport org.mozilla.javascript.Scriptable;\n\npublic class VMBridgeJdk13Test {\n    @Test\n    void adaptsJavaScriptFunctionToJavaInterfaceProxy() throws Exception {\n        Context context = ContextFactory.getGlobal().enterContext();\n        try {\n            Scriptable scope = context.initStandardObjects();\n            Object function = context.evaluateString(scope,\n                    \"(function() { return 'rhino interface proxy'; })\",\n                    \"interface-proxy\",\n                    1,\n                    null);\n\n            Object proxy = Context.jsToJava(function, Callable.class);\n            Object result = ((Callable<?>) proxy).call();\n\n            assertThat(proxy).isInstanceOf(Callable.class);\n            assertThat(Context.toString(result)).isEqualTo(\"rhino interface proxy\");\n        } finally {\n            Context.exit();\n        }\n    }\n}\n"}
