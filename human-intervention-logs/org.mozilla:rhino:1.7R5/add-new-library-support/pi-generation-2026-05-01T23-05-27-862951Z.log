                  case ByteCode.GOTO:
                  case ByteCode.GOTO_W:
                  case ByteCode.IFEQ:
                  case ByteCode.IFGE:
                  case ByteCode.IFGT:
                  case ByteCode.IFLE:
                  case ByteCode.IFLT:
                  case ByteCode.IFNE:
                  case ByteCode.IFNONNULL:
                  case ByteCode.IFNULL:
                  case ByteCode.IF_ACMPEQ:
                  case ByteCode.IF_ACMPNE:
                  case ByteCode.IF_ICMPEQ:
