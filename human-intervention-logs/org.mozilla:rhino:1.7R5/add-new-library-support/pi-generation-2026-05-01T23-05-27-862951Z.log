  package org_mozilla.rhino;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.File;
  import java.io.IOException;
  import java.net.URL;
  import java.net.URLClassLoader;
  import java.util.ArrayList;
  import java.util.List;
  
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  
  public class ClassFileWriterTest {
      private static final String CLASS_FILE_WRITER_NAME = "org.mozilla.classfile.ClassFileWriter";
      private static final String CLASS_FILE_WRITER_RESOURCE = "org/mozilla/classfile/ClassFileWriter.class";
  
      @Test
      void initializesFromSystemResourceWhenPackageResourceIsUnavailable() throws Exception {
          runAllowingNativeImageUnsupportedClassLoading(() -> {
              try (ResourceBlockingClassLoader classLoader = new ResourceBlockingClassLoader(classPathUrls())) {
                  Class<?> writerClass = Class.forName(CLASS_FILE_WRITER_NAME, true, classLoader);
  
                  assertThat(writerClass.getName()).isEqualTo(CLASS_FILE_WRITER_NAME);
                  assertThat(classLoader.getBlockedResourceRequests()).isPositive();
              }
          });
      }
  
      private static URL[] classPathUrls() throws IOException {
          String classPath = System.getProperty("java.class.path");
          String[] entries = classPath.split(File.pathSeparator);
          List<URL> urls = new ArrayList<>(entries.length);
          for (String entry : entries) {
              urls.add(new File(entry).toURI().toURL());
          }
          return urls.toArray(URL[]::new);
      }
  
      private static void runAllowingNativeImageUnsupportedClassLoading(ThrowingRunnable action) throws Exception {
          try {
              action.run();
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
      }
  
      @FunctionalInterface
      private interface ThrowingRunnable {
          void run() throws Exception;
      }
  
      private static final class ResourceBlockingClassLoader extends URLClassLoader {
          private boolean blockClassFileWriterResource;
          private int blockedResourceRequests;
  
          private ResourceBlockingClassLoader(URL[] urls) {
              super(urls, ClassFileWriterTest.class.getClassLoader());
          }
  
          private int getBlockedResourceRequests() {
              return blockedResourceRequests;
          }
  
          @Override
          public URL getResource(String name) {
              if (blockClassFileWriterResource && CLASS_FILE_WRITER_RESOURCE.equals(name)) {
                  blockedResourceRequests++;
                  return null;
              }
              return super.getResource(name);
          }
  
          @Override
          protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {
              if (!name.startsWith("org.mozilla.classfile.")) {
                  return super.loadClass(name, resolve);
              }
              synchronized (getClassLoadingLock(name)) {
                  Class<?> loadedClass = findLoadedClass(name);
                  if (loadedClass == null) {
                      try {
                          loadedClass = findClass(name);
                      } catch (ClassNotFoundException exception) {
                          loadedClass = super.loadClass(name, false);
                      }
                  }
                  if (CLASS_FILE_WRITER_NAME.equals(name)) {
                      blockClassFileWriterResource = true;
                  }
                  if (resolve) {
                      resolveClass(loadedClass);
                  }
                  return loadedClass;
              }
          }
      }
  }
