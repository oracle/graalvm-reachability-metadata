      static String toString(int type, ConstantPool pool) {
          int tag = getTag(type);
          switch (tag) {
              case TypeInfo.TOP:
                  return "top";
              case TypeInfo.INTEGER:
                  return "int";
              case TypeInfo.FLOAT:
                  return "float";
              case TypeInfo.DOUBLE:
                  return "double";
              case TypeInfo.LONG:
                  return "long";
