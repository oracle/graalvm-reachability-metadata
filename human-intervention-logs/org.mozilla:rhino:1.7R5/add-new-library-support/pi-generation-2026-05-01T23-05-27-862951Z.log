  package org_mozilla.rhino;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import org.junit.jupiter.api.Test;
  import org.mozilla.classfile.ByteCode;
  import org.mozilla.classfile.ClassFileWriter;
  
  public class TypeInfoTest {
      @Test
      void mergesDifferentReferenceTypesWhenBuildingStackMapTable() {
          ClassFileWriter writer = new ClassFileWriter(
                  "generated.TypeInfoMergeCoverage", "java.lang.Object", "TypeInfoMergeCoverage.java");
          short methodFlags = ClassFileWriter.ACC_PUBLIC | ClassFileWriter.ACC_STATIC;
          writer.startMethod("choose", "(Z)Ljava/lang/Object;", methodFlags);
  
          int falseBranch = writer.acquireLabel();
          int mergePoint = writer.acquireLabel();
  
          writer.addILoad(0);
          writer.add(ByteCode.IFEQ, falseBranch);
  
          writer.add(ByteCode.ICONST_1);
          writer.addInvoke(ByteCode.INVOKESTATIC, "java/lang/Integer", "valueOf", "(I)Ljava/lang/Integer;");
          writer.add(ByteCode.GOTO, mergePoint);
  
          writer.markLabel(falseBranch, (short) 0);
          writer.add(ByteCode.ICONST_0);
          writer.addInvoke(ByteCode.INVOKESTATIC, "java/lang/String", "valueOf", "(I)Ljava/lang/String;");
  
          writer.markLabel(mergePoint, (short) 1);
          writer.add(ByteCode.ARETURN);
          writer.stopMethod((short) 1);
  
          byte[] classBytes = writer.toByteArray();
  
          assertThat(classBytes).hasSizeGreaterThan(4);
          assertThat(classBytes[0]).isEqualTo((byte) 0xCA);
          assertThat(classBytes[1]).isEqualTo((byte) 0xFE);
          assertThat(classBytes[2]).isEqualTo((byte) 0xBA);
          assertThat(classBytes[3]).isEqualTo((byte) 0xBE);
      }
  }
