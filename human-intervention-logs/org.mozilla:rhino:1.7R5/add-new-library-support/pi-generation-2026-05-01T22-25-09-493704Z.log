          power = i;
          if (check && power < 2) Kit.codeBug();
      }
  
      public boolean isEmpty() {
          return keyCount == 0;
      }
  
      public int size() {
          return keyCount;
      }
  
      public boolean has(Object key) {
          if (key == null) { key = UniqueTag.NULL_VALUE; }
          return 0 <= findIndex(key);
      }
  
      /**
