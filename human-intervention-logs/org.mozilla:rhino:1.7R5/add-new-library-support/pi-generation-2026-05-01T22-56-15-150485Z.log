       */
      public static void main(String args[]) {
          try {
              if (Boolean.getBoolean("rhino.use_java_policy_security")) {
                  initJavaPolicySecuritySupport();
              }
          } catch (SecurityException ex) {
              ex.printStackTrace(System.err);
          }
  
          int result = exec(args);
          if (result != 0) {
              System.exit(result);
          }
      }
  
