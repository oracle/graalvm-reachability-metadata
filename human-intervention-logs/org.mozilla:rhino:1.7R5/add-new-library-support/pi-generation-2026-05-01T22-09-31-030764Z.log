  package org_mozilla.rhino;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.File;
  import java.io.IOException;
  import java.net.URL;
  import java.net.URLClassLoader;
  import java.nio.charset.StandardCharsets;
  import java.util.ArrayList;
  import java.util.List;
  import java.util.Map;
  import java.util.ServiceLoader;
  import java.util.concurrent.Callable;
  
  import jline.console.ConsoleReader;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  import org.mozilla.javascript.Context;
  import org.mozilla.javascript.ContextFactory;
  import org.mozilla.javascript.Scriptable;
  import org.mozilla.javascript.ScriptableObject;
  import org.mozilla.javascript.tools.shell.ShellConsole;
  
  public class ShellConsoleTest {
      @Test
      void createsJLineV2ConsoleAndDelegatesOperationsReflectively() throws Exception {
          ConsoleReader.reset();
          Context context = ContextFactory.getGlobal().enterContext();
          try {
              Scriptable scope = context.initStandardObjects();
              ScriptableObject.putProperty(scope, "consoleCandidate", "value");
  
              ShellConsole console = ShellConsole.getConsole(scope, StandardCharsets.UTF_8);
  
              assertThat(console).isNotNull();
              console.print("hello");
              console.println(" world");
              console.flush();
              String line = console.readLine("rhino> ");
              List<String> candidates = ConsoleReader.complete("console", "console".length());
  
              assertThat(line).isEqualTo("v2-line");
              assertThat(ConsoleReader.isBellEnabled()).isFalse();
              assertThat(ConsoleReader.getOutput()).isEqualTo("hello world\n");
              assertThat(ConsoleReader.getLastPrompt()).isEqualTo("rhino> ");
              assertThat(ConsoleReader.getFlushCount()).isEqualTo(1);
              assertThat(candidates).contains("consoleCandidate");
          } finally {
              Context.exit();
          }
      }
  
      @Test
      void createsJLineV1ConsoleWhenOnlyLegacyJLineIsVisible() throws Exception {
          runAllowingNativeImageUnsupportedClassLoading(() -> {
              try (BlockingJLineV2ClassLoader classLoader = new BlockingJLineV2ClassLoader(classPathUrls())) {
                  Callable<?> scenario = ServiceLoader.load(Callable.class, classLoader).iterator().next();
  
                  @SuppressWarnings("unchecked")
                  Map<String, Object> result = (Map<String, Object>) scenario.call();
  
                  assertThat(result)
                          .containsEntry("line", "v1-line")
                          .containsEntry("bellEnabled", Boolean.FALSE)
                          .containsEntry("output", "legacy console\n")
                          .containsEntry("lastPrompt", "legacy> ")
                          .containsEntry("flushCount", 1);
                  assertThat((List<String>) result.get("candidates")).contains("legacyCandidate");
              }
          });
      }
  
      private static URL[] classPathUrls() throws IOException {
