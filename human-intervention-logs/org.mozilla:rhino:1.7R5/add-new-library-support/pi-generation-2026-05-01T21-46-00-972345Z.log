util.ArrayList;\nimport java.util.List;\nimport java.util.Map;\nimport java.util.ServiceLoader;\nimport java.util.concurrent.Callable;\n\nimport jline.console.ConsoleReader;\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\nimport org.mozilla.javascript.Context;\nimport org.mozilla.javascript.ContextFactory;\nimport org.mozilla.javascript.Scriptable;\nimport org.mozilla.javascript.ScriptableObject;\nimport org.mozilla.javascript.tools.shell.ShellConsole;\n\npublic class ShellConsoleTest {\n    @Test\n    void createsJLineV2ConsoleAndDelegatesOperationsReflectively() throws Exception {\n        ConsoleReader.reset();\n        Context context = ContextFactory.getGlobal().enterContext();\n        try {\n            Scriptable scope = context.initStandardObjects();\n            ScriptableObject.putProperty(scope, \"consoleCandidate\", \"value\");\n\n            ShellConsole console = ShellConsole.getConsole(scope, StandardCharsets.UTF_8);\n\n            assertThat(console).isNotNull();\n            console.print(\"hello\");\n            console.println(\" world\");\n            console.flush();\n            String line = console.readLine(\"rhino> \");\n            List<String> candidates = ConsoleReader.complete(\"console\", \"console\".length());\n\n            assertThat(line).isEqualTo(\"v2-line\");\n            assertThat(ConsoleReader.isBellEnabled()).isFalse();\n            assertThat(ConsoleReader.getOutput()).isEqualTo(\"hello world\\n\");\n            assertThat(ConsoleReader.getLastPrompt()).isEqualTo(\"rhino> \");\n            assertThat(ConsoleReader.getFlushCount()).isEqualTo(1);\n            assertThat(candidates).contains(\"consoleCandidate\");\n        } finally {\n            Context.exit();\n        }\n    }\n\n    @Test\n    void createsJLineV1ConsoleWhenOnlyLegacyJLineIsVisible() throws Exception {\n        runAllowingNativeImageUnsupportedClassLoading(() -> {\n            try (BlockingJLineV2ClassLoader classLoader = new BlockingJLineV2ClassLoader(classPathUrls())) {\n                Callable<?> scenario = ServiceLoader.load(Callable.class, classLoader).iterator().next();\n\n                @SuppressWarnings(\"unchecked\")\n                Map<String, Object> result = (Map<String, Object>) scenario.call();\n\n                assertThat(result)\n                        .containsEntry(\"line\", \"v1-line\")\n                        .containsEntry(\"bellEnabled\", Boolean.FALSE)\n                        .containsEntry(\"output\", \"legacy console\\n\")\n                        .containsEntry(\"lastPrompt\", \"legacy> \")\n                        .containsEntry(\"flushCount\", 1);\n                assertThat((List<String>) result.get(\"candidates\")).contains(\"legacyCandidate\");\n            }\n        });\n    }\n\n    private static URL[] classPathUrls() throws IOException {\n        String classPath = System.getProperty(\"java.class.path\");\n        String[] entries = classPath.split(File.pathSeparator);\n        List<URL> urls = new ArrayList<>(entries.length);\n        for (String entry : entries) {\n            urls.add(new File(entry).toURI().toURL());\n        }\n        return urls.toArray(URL[]::new);\n    }\n\n    private static void runAllowingNativeImageUnsupportedClassLoading(ThrowingRunnable action) throws Exception {\n        try {\n            action.run();\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    @FunctionalInterface\n    private interface ThrowingRunnable {\n        void run() throws Exception;\n    }\n\n    private static final class BlockingJLineV2ClassLoader extends URLClassLoader {\n        private BlockingJLineV2ClassLoader(URL[] urls) {\n            super(urls, ShellConsoleTest.class.getClassLoader());\n        }\n\n        @Override\n        protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {\n            if (name.startsWith(\"jline.console.\")) {\n                throw new ClassNotFoundException(name);\n            }\n            if (name.startsWith(\"org.mozilla.javascript.\")\n                    || name.equals(\"org_mozilla.rhino.ShellConsoleV1Scenario\")\n                    || name.startsWith(\"jline.\")) {\n                synchronized (getClassLoadingLock(name)) {\n                    Class<?> loadedClass = findLoadedClass(name);\n                    if (loadedClass == null) {\n                        try {\n                            loadedClass = findClass(name);\n                        } catch (ClassNotFoundException ignored) {\n                            loadedClass = super.loadClass(name, false);\n                        }\n                    }\n                    if (resolve) {\n                        resolveClass(loadedClass);\n                    }\n                    return loadedClass;\n                }\n            }\n            return super.loadClass(name, resolve);\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 4295, "output": 1263, "cacheRead": 30208, "cacheWrite": 0, "totalTokens": 35766, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777671889707, "responseId": "resp_0568128f112b68520169f51ed22ae081a0aadde3233c6eb1ee"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_HdQHWasZbGfBm0V0iJQ6Vs1J|fc_0568128f112b68520169f51ed355f881a09467e72326b75797", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 5331 bytes to tests/src/org.mozilla/rhino/1.7R5/src/test/java/org_mozilla/rhino/ShellConsoleTest.java"}], "isError": false, "timestamp": 1777671903502}]}
