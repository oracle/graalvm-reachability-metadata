  package org_mozilla.rhino;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.IOException;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.io.Serializable;
  
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  import org.mozilla.javascript.Context;
  import org.mozilla.javascript.NativeJavaObject;
  import org.mozilla.javascript.NativeObject;
  import org.mozilla.javascript.Scriptable;
  import org.mozilla.javascript.ScriptableObject;
  import org.mozilla.javascript.Wrapper;
  import org.mozilla.javascript.serialize.ScriptableInputStream;
  import org.mozilla.javascript.serialize.ScriptableOutputStream;
  
  public class NativeJavaObjectTest {
      @Test
      void coercesNativeArraysAndDoubleValuedJavaObjects() {
          try {
              Context context = Context.enter();
              try {
                  Scriptable scope = context.initStandardObjects();
  
                  Object arrayValue = context.evaluateString(
                          scope, "['red', 'green', 'blue']", "array-coercion", 1, null);
                  Object strings = Context.jsToJava(arrayValue, String[].class);
                  assertThat((String[]) strings).containsExactly("red", "green", "blue");
  
                  Object number = Context.jsToJava(new DoubleValuedObject(12.75), Double.TYPE);
                  assertThat(number).isEqualTo(12.75D);
              } finally {
                  Context.exit();
              }
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
      }
  
      @Test
      void serializesAndRestoresPlainJavaObjectWrappers() throws Exception {
          Context context = Context.enter();
          try {
              Scriptable scope = context.initStandardObjects();
  
              SerializablePayload staticallyTypedPayload = new SerializablePayload("typed");
              NativeJavaObject staticallyTypedWrapper = new NativeJavaObject(
                      scope, staticallyTypedPayload, SerializablePayload.class);
              NativeJavaObject restoredStaticallyTypedWrapper = roundTrip(
                      staticallyTypedWrapper, scope);
              assertThat(restoredStaticallyTypedWrapper.unwrap())
                      .isEqualTo(staticallyTypedPayload);
  
              SerializablePayload dynamicallyTypedPayload = new SerializablePayload("dynamic");
              NativeJavaObject dynamicallyTypedWrapper = new NativeJavaObject(
                      scope, dynamicallyTypedPayload, null);
              NativeJavaObject restoredDynamicallyTypedWrapper = roundTrip(
                      dynamicallyTypedWrapper, scope);
              assertThat(restoredDynamicallyTypedWrapper.unwrap())
                      .isEqualTo(dynamicallyTypedPayload);
          } finally {
              Context.exit();
          }
      }
  
      @Test
      void serializesAndRestoresJavaAdapterWrappers() throws Exception {
          try {
              exerciseJavaAdapterWrapperSerialization();
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
      }
  
      private static void exerciseJavaAdapterWrapperSerialization() throws Exception {
          Context context = Context.enter();
          try {
              Scriptable scope = context.initStandardObjects();
              NativeObject implementation = new NativeObject();
              implementation.setParentScope(scope);
              implementation.setPrototype(ScriptableObject.getObjectPrototype(scope));
              scope.put("implementation", scope, implementation);
  
              Object adapterWrapper = context.evaluateString(scope, """
                      new JavaAdapter(java.lang.Runnable, implementation);
                      """, "adapter-wrapper-serialization", 1, null);
              assertThat(adapterWrapper).isInstanceOf(NativeJavaObject.class);
              Runnable runnable = Runnable.class.cast(Context.jsToJava(
                      adapterWrapper, Runnable.class));
              runnable.run();
  
              NativeJavaObject restoredWrapper = roundTrip(
                      (NativeJavaObject) adapterWrapper, scope);
              assertThat(restoredWrapper).isInstanceOf(Wrapper.class);
              Runnable restoredRunnable = Runnable.class.cast(Context.jsToJava(
                      restoredWrapper, Runnable.class));
              restoredRunnable.run();
          } finally {
              Context.exit();
          }
      }
  
      private static NativeJavaObject roundTrip(NativeJavaObject wrapper, Scriptable scope)
              throws IOException, ClassNotFoundException {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream output = new ScriptableOutputStream(bytes, scope)) {
              output.writeObject(wrapper);
          }
          try (ObjectInputStream input = new ScriptableInputStream(
                  new ByteArrayInputStream(bytes.toByteArray()), scope)) {
              return (NativeJavaObject) input.readObject();
          }
      }
  
      public static final class DoubleValuedObject {
          private final double value;
  
          DoubleValuedObject(double value) {
              this.value = value;
          }
  
          public Number doubleValue() {
              return Double.valueOf(value);
          }
      }
  
      public static final class SerializablePayload implements Serializable {
          private static final long serialVersionUID = 1L;
  
          private final String value;
  
          SerializablePayload(String value) {
              this.value = value;
          }
  
          @Override
          public boolean equals(Object other) {
              if (this == other) {
                  return true;
              }
              if (!(other instanceof SerializablePayload)) {
                  return false;
              }
              SerializablePayload payload = (SerializablePayload) other;
              return value.equals(payload.value);
          }
  
          @Override
          public int hashCode() {
              return value.hashCode();
          }
      }
  }
