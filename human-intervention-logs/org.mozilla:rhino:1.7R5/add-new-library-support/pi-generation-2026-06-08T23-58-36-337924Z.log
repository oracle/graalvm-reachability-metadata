          private static final int SYSTEM_EXIT = 3;
  
          private int type;
          String[] args;
          String scriptText;
  
          IProxy(int type)
          {
              this.type = type;
          }
  
          public Object run(Context cx)
          {
              if (useRequire) {
                  require = global.installRequire(cx, modulePath, sandboxed);
              }
