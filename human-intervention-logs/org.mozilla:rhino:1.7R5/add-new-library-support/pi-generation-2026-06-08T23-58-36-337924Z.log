  package org_mozilla.rhino;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.Serializable;
  import java.util.ArrayList;
  
  import org.junit.jupiter.api.Test;
  import org.mozilla.javascript.tools.jsc.Main;
  
  public class MainTest {
      @Test
      void resolvesCompilerTargetSuperclassAndInterfaces() {
          Main compilerMain = new Main();
  
          String[] filenames = compilerMain.processOptions(new String[] {
                  "-extends", ArrayList.class.getName(),
                  "-implements", Runnable.class.getName() + "," + Serializable.class.getName(),
                  "script.js"
          });
  
          assertThat(filenames).containsExactly("script.js");
      }
