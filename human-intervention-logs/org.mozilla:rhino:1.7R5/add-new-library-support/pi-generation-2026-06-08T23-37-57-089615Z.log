[tool-call] delta {"path":"tests/src/org.mozilla/rhino/1.7R5/src/test/java/org_mozilla/rhino/UintMapTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_mozilla.rhino;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\n\nimport org.junit.jupiter.api.Test;\nimport org.mozilla.javascript.UintMap;\n\npublic class UintMapTest {\n    @Test\n    void serializesAndRestoresIntegerKeysWithObjectAndIntegerValues() throws Exception {\n        UintMap valuesByKey = new UintMap();\n        valuesByKey.put(3, \"three\");\n        valuesByKey.put(7, 70);\n        valuesByKey.put(11, \"eleven\");\n        valuesByKey.put(19, 190);\n        valuesByKey.remove(11);\n        valuesByKey.put(23, \"twenty-three\");\n\n        UintMap restored = roundTrip(valuesByKey);\n\n        assertThat(restored.size()).isEqualTo(4);\n        assertThat(restored.has(3)).isTrue();\n        assertThat(restored.getObject(3)).isEqualTo(\"three\");\n        assertThat(restored.getInt(7, -1)).isEqualTo(70);\n        assertThat(restored.has(11)).isFalse();\n        assertThat(restored.getObject(23)).isEqualTo(\"twenty-three\");\n        assertThat(restored.getExistingInt(19)).isEqualTo(190);\n        assertThat(restored.getKeys()).containsExactlyInAnyOrder(3, 7, 19, 23);\n    }\n\n    private static UintMap roundTrip(UintMap valuesByKey) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(valuesByKey);\n        }\n        try (ObjectInputStream input = new ObjectInputStream(\n                new ByteArrayInputStream(bytes.toByteArray()))) {\n            return (UintMap) input.readObject();\n        }\n    }\n}\n"}
