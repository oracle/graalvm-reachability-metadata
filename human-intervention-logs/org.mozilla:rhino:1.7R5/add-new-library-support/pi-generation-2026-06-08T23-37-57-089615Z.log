  package org_mozilla.rhino;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  
  import org.junit.jupiter.api.Test;
  import org.mozilla.javascript.ObjToIntMap;
  
  public class ObjToIntMapTest {
      @Test
      void serializesAndRestoresObjectKeysWithIntegerValues() throws Exception {
          ObjToIntMap valuesByKey = new ObjToIntMap();
          valuesByKey.put("alpha", 11);
          valuesByKey.put("beta", 22);
          valuesByKey.put("gamma", 33);
          valuesByKey.remove("beta");
          valuesByKey.put("delta", 44);
  
          ObjToIntMap restored = roundTrip(valuesByKey);
  
          assertThat(restored.size()).isEqualTo(3);
          assertThat(restored.get("alpha", -1)).isEqualTo(11);
          assertThat(restored.get("beta", -1)).isEqualTo(-1);
          assertThat(restored.get("gamma", -1)).isEqualTo(33);
          assertThat(restored.getExisting("delta")).isEqualTo(44);
          assertThat(restored.getKeys()).containsExactlyInAnyOrder("alpha", "gamma", "delta");
      }
  
      private static ObjToIntMap roundTrip(ObjToIntMap valuesByKey) throws Exception {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {
              output.writeObject(valuesByKey);
          }
          try (ObjectInputStream input = new ObjectInputStream(
                  new ByteArrayInputStream(bytes.toByteArray()))) {
              return (ObjToIntMap) input.readObject();
          }
      }
  }
