  package org_mozilla.rhino;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.lang.reflect.ReflectPermission;
  import java.security.Permission;
  
  import org.junit.jupiter.api.Test;
  import org.mozilla.javascript.Context;
  import org.mozilla.javascript.ContextAction;
  import org.mozilla.javascript.ContextFactory;
  import org.mozilla.javascript.Scriptable;
  import org.mozilla.javascript.ScriptableObject;
  
  public class JavaMembersTest {
      @Test
      void readsAndWritesPublicJavaFieldsFromScript() {
          Context context = ContextFactory.getGlobal().enterContext();
          try {
              Scriptable scope = context.initStandardObjects();
              PublicFieldRecord record = new PublicFieldRecord("initial", 7);
              ScriptableObject.putProperty(scope, "record", Context.javaToJS(record, scope));
  
              Object result = context.evaluateString(
                      scope,
                      "record.text = 'updated'; record.count = record.count + 5;"
                              + "record.text + ':' + record.count + ':' + record.describe();",
                      "java-members-fields",
                      1,
                      null
              );
  
              assertThat(Context.toString(result)).isEqualTo("updated:12:updated:12");
              assertThat(record.text).isEqualTo("updated");
              assertThat(record.count).isEqualTo(12);
          } finally {
              Context.exit();
          }
      }
  
      @Test
      void exposesInterfaceMembersWhenEnhancedJavaAccessIsEnabled() {
          Object result = evaluateEnhancedJavaAccessInterface(JavaMembersInterface.class, "JavaMembersInterface", 21);
  
          assertThat(Context.toString(result)).isEqualTo("49");
      }
  
      @Test
      @SuppressWarnings("removal")
      void fallsBackToPublicMethodsWhenMethodAccessibilityCannotBeChanged() {
          DenyingJavaMembersReflectionSecurityManager securityManager =
                  new DenyingJavaMembersReflectionSecurityManager();
          SecurityManager originalSecurityManager = System.getSecurityManager();
          boolean installedSecurityManager = installSecurityManager(securityManager);
          try {
              Object result = evaluateEnhancedJavaAccessInterface(
                      RestrictedJavaMembersInterface.class,
                      "RestrictedJavaMembersInterface",
                      17
              );
  
              assertThat(Context.toString(result)).isEqualTo("41");
              if (installedSecurityManager) {
                  assertThat(securityManager.deniedJavaMembersMethodAccess()).isTrue();
              }
          } finally {
              if (installedSecurityManager) {
                  System.setSecurityManager(originalSecurityManager);
              }
          }
      }
  
      @SuppressWarnings("removal")
      private static boolean installSecurityManager(SecurityManager securityManager) {
          try {
              System.setSecurityManager(securityManager);
              return true;
          } catch (SecurityException | UnsupportedOperationException ex) {
              return false;
          }
      }
  
      private static Object evaluateEnhancedJavaAccessInterface(
              Class<?> interfaceClass,
              String scriptName,
              int input
      ) {
          ContextFactory contextFactory = new EnhancedJavaAccessContextFactory();
          return contextFactory.call(new ContextAction() {
              @Override
              public Object run(Context context) {
                  Scriptable scope = context.initStandardObjects();
                  ScriptableObject.putProperty(
                          scope,
                          scriptName,
                          context.getWrapFactory().wrapJavaClass(context, scope, interfaceClass)
                  );
                  return context.evaluateString(
