    static Scriptable scope;\n        static boolean sealed;\n\n        static void reset() {\n            initialized = false;\n            context = null;\n            scope = null;\n            sealed = false;\n        }\n\n        public ThreeArgumentInitScriptable() {\n        }\n\n        public static void init(Context context, Scriptable scope, boolean sealed) {\n            ThreeArgumentInitScriptable.initialized = true;\n            ThreeArgumentInitScriptable.context = context;\n            ThreeArgumentInitScriptable.scope = scope;\n            ThreeArgumentInitScriptable.sealed = sealed;\n            ScriptableObject.putProperty(scope, \"threeArgumentInit\", \"initialized\");\n        }\n\n        @Override\n        public String getClassName() {\n            return \"ThreeArgumentInitScriptable\";\n        }\n    }\n\n    public static class OneArgumentInitScriptable extends ScriptableObject {\n        static boolean initialized;\n        static Scriptable scope;\n\n        static void reset() {\n            initialized = false;\n            scope = null;\n        }\n\n        public OneArgumentInitScriptable() {\n        }\n\n        public static void init(Scriptable scope) {\n            initialized = true;\n            OneArgumentInitScriptable.scope = scope;\n            ScriptableObject.putProperty(scope, \"oneArgumentInit\", \"initialized\");\n        }\n\n        @Override\n        public String getClassName() {\n            return \"OneArgumentInitScriptable\";\n        }\n    }\n\n    public static class FinishInitScriptable extends ScriptableObject {\n        static int prototypeInstances;\n        static boolean finishInitCalled;\n        static Scriptable finishInitScope;\n        static FunctionObject finishInitConstructor;\n        static Scriptable finishInitPrototype;\n\n        static void reset() {\n            prototypeInstances = 0;\n            finishInitCalled = false;\n            finishInitScope = null;\n            finishInitConstructor = null;\n            finishInitPrototype = null;\n        }\n\n        public FinishInitScriptable() {\n            prototypeInstances++;\n        }\n\n        public static void finishInit(\n                Scriptable scope,\n                FunctionObject constructor,\n                Scriptable prototype\n        ) {\n            finishInitCalled = true;\n            finishInitScope = scope;\n            finishInitConstructor = constructor;\n            finishInitPrototype = prototype;\n            ScriptableObject.putProperty(constructor, \"createdByFinishInit\", Boolean.TRUE);\n            ScriptableObject.putProperty(prototype, \"finishInitMarker\", \"ready\");\n        }\n\n        public String jsFunction_instanceValue() {\n            return \"instance\";\n        }\n\n        @Override\n        public String getClassName() {\n            return \"FinishInitScriptable\";\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777673212059}}
