       */
      public Scriptable getDelegee() {
          return obj;
      }
      /**
       * Set the delegee.
       *
       * @param obj the delegee
       * @see org.mozilla.javascript.Scriptable
       */
      public void setDelegee(Scriptable obj) {
          this.obj = obj;
      }
