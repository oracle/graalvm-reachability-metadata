  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  import org.mozilla.javascript.Context;
  import org.mozilla.javascript.Scriptable;
  import org.mozilla.javascript.tools.shell.ShellConsole;
  
  public class ShellConsoleTest {
      private static final String JLINE_VERSION1_CONSOLE_CLASS =
              "org.mozilla.javascript.tools.shell.ShellConsole$JLineShellConsoleV1";
      private static final String CALLABLE_SERVICE_RESOURCE =
              "META-INF/services/java.util.concurrent.Callable";
  
      @Test
      void createsJLineConsoleAndInvokesOutputOperations() throws Exception {
          String previousTerminal = System.getProperty("jline.terminal");
          System.setProperty("jline.terminal", "jline.UnsupportedTerminal");
          Context context = Context.enter();
          try {
              Scriptable scope = context.initStandardObjects();
  
              ShellConsole console = ShellConsole.getConsole(scope, StandardCharsets.UTF_8);
  
              assertThat(console).isNotNull();
              assertThat(console.getIn()).isNotNull();
              console.print("alpha");
              console.println("beta");
              console.println();
              console.flush();
          } finally {
              Context.exit();
              restoreSystemProperty("jline.terminal", previousTerminal);
          }
      }
  
      @Test
      void createsJLineVersion1ConsoleFromIsolatedClasspath() throws Exception {
          try {
              assertThat(exerciseJLineVersion1Console())
                      .isEqualTo(JLINE_VERSION1_CONSOLE_CLASS);
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
      }
  
      private static String exerciseJLineVersion1Console() throws Exception {
          String jlineVersion1Classpath = System.getProperty(
                  "org_mozilla.rhino.jlineVersion1Classpath");
          assertThat(jlineVersion1Classpath).isNotBlank();
  
          List<URL> urls = new ArrayList<>();
          urls.add(codeSourceUrl(Context.class));
          urls.add(codeSourceUrl(JLineVersion1Exercise.class));
          for (String entry : jlineVersion1Classpath.split(File.pathSeparator)) {
              urls.add(new File(entry).toURI().toURL());
          }
  
          try (ChildFirstUrlClassLoader loader = new ChildFirstUrlClassLoader(
                  urls.toArray(new URL[0]), ClassLoader.getPlatformClassLoader())) {
              Callable<?> exercise = ServiceLoader.load(Callable.class, loader)
                      .findFirst()
                      .orElseThrow(() -> new AssertionError(
                              "Expected a JLine v1 shell console exercise"));
              return (String) exercise.call();
          }
      }
  
      private static URL codeSourceUrl(Class<?> type) {
          CodeSource codeSource = type.getProtectionDomain().getCodeSource();
          assertThat(codeSource).isNotNull();
          return codeSource.getLocation();
      }
  
      private static void restoreSystemProperty(String key, String previousValue) {
          if (previousValue == null) {
              System.clearProperty(key);
          } else {
              System.setProperty(key, previousValue);
          }
      }
  
      public static final class JLineVersion1Exercise implements Callable<String> {
          @Override
          public String call() throws Exception {
              String previousTerminal = System.getProperty("jline.terminal");
              System.setProperty("jline.terminal", "jline.UnsupportedTerminal");
              Context context = Context.enter();
              try {
                  Scriptable scope = context.initStandardObjects();
  
                  ShellConsole console = ShellConsole.getConsole(scope, StandardCharsets.UTF_8);
                  if (console == null) {
                      throw new AssertionError("Expected a JLine v1 shell console");
                  }
                  console.print("alpha");
                  console.println("beta");
                  console.println();
                  console.flush();
                  return console.getClass().getName();
              } finally {
                  Context.exit();
                  if (previousTerminal == null) {
                      System.clearProperty("jline.terminal");
                  } else {
                      System.setProperty("jline.terminal", previousTerminal);
                  }
              }
          }
      }
  
      private static final class ChildFirstUrlClassLoader extends URLClassLoader {
          private static final String[] CHILD_FIRST_PREFIXES = {
                  "jline.",
                  "org.mozilla.",
                  "org_mozilla.rhino.ShellConsoleTest$JLineVersion1Exercise"
          };
  
