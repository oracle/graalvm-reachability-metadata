      private static byte[] loadBytecode()
      {
          String secureCallerClassName = SecureCaller.class.getName();
          ClassFileWriter cfw = new ClassFileWriter(
                  secureCallerClassName + "Impl", secureCallerClassName,
                  "<generated>");
