[tool-call] delta {"path":"tests/src/org.mozilla/rhino/1.7R5/src/test/java/org_mozilla/rhino/GlobalTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_mozilla.rhino;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.nio.file.Path;\n\nimport org.junit.jupiter.api.Test;\nimport org.junit.jupiter.api.io.TempDir;\nimport org.mozilla.javascript.Context;\nimport org.mozilla.javascript.Script;\nimport org.mozilla.javascript.Scriptable;\nimport org.mozilla.javascript.ScriptableObject;\nimport org.mozilla.javascript.tools.shell.Global;\n\npublic class GlobalTest {\n    @TempDir\n    Path temporaryDirectory;\n\n    @Test\n    void loadClassLoadsAndExecutesScriptImplementation() {\n        Context context = Context.enter();\n        try {\n            Global global = new Global(context);\n            String source = \"loadClass('\" + LoadedScript.class.getName() + \"');\";\n\n            context.evaluateString(global, source, \"load-class-test\", 1, null);\n\n            assertThat(ScriptableObject.getProperty(global, LoadedScript.PROPERTY_NAME))\n                    .isEqualTo(Boolean.TRUE);\n        } finally {\n            Context.exit();\n        }\n    }\n\n    @Test\n    void serializeAndDeserializeRoundTripJavaScriptValue() {\n        Context context = Context.enter();\n        try {\n            Global global = new Global(context);\n            Path serialized = temporaryDirectory.resolve(\"payload.ser\");\n            String source = \"\"\"\n                    serialize('rhino-payload', '%s');\n                    deserialize('%s');\n                    \"\"\".formatted(javaScriptString(serialized.toString()),\n                    javaScriptString(serialized.toString()));\n\n            Object result = context.evaluateString(global, source, \"serialization-test\", 1, null);\n\n            assertThat(Context.toString(result)).isEqualTo(\"rhino-payload\");\n            assertThat(serialized).exists();\n        } finally {\n            Context.exit();\n        }\n    }\n\n    private static String javaScriptString(String value) {\n        return value.replace(\"\\\\\", \"\\\\\\\\\")\n                .replace(\"'\", \"\\\\'\")\n                .replace(\"\\n\", \"\\\\n\")\n                .replace(\"\\r\", \"\\\\r\");\n    }\n\n    public static class LoadedScript implements Script {\n        static final String PROPERTY_NAME = \"loadedScriptExecuted\";\n\n        @Override\n        public Object exec(Context context, Scriptable scope) {\n            ScriptableObject.putProperty(scope, PROPERTY_NAME, Boolean.TRUE);\n            return Boolean.TRUE;\n        }\n    }\n}\n"}
