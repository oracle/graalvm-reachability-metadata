ry {\n            Global global = new Global(context);\n            Path serialized = temporaryDirectory.resolve(\"payload.ser\");\n            String source = \"\"\"\n                    serialize('rhino-payload', '%s');\n                    deserialize('%s');\n                    \"\"\".formatted(javaScriptString(serialized.toString()),\n                    javaScriptString(serialized.toString()));\n\n            Object result = context.evaluateString(global, source, \"serialization-test\", 1, null);\n\n            assertThat(Context.toString(result)).isEqualTo(\"rhino-payload\");\n            assertThat(serialized).exists();\n        } finally {\n            Context.exit();\n        }\n    }\n\n    private static String javaScriptString(String value) {\n        return value.replace(\"\\\\\", \"\\\\\\\\\")\n                .replace(\"'\", \"\\\\'\")\n                .replace(\"\\n\", \"\\\\n\")\n                .replace(\"\\r\", \"\\\\r\");\n    }\n\n    public static class LoadedScript implements Script {\n        static final String PROPERTY_NAME = \"loadedScriptExecuted\";\n\n        @Override\n        public Object exec(Context context, Scriptable scope) {\n            ScriptableObject.putProperty(scope, PROPERTY_NAME, Boolean.TRUE);\n            return Boolean.TRUE;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 1659, "output": 1691, "cacheRead": 18944, "cacheWrite": 0, "totalTokens": 22294, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780958970940, "responseId": "resp_0966bed7b86802af016a2746fb66d48194accc1213a50bf58e"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_18RDYqiW3auL4OUNMosC8CNT|fc_0966bed7b86802af016a27471c64e08194b887d70837f6ff65", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2580 bytes to tests/src/org.mozilla/rhino/1.7R5/src/test/java/org_mozilla/rhino/Gl