c org.assertj.core.api.Assertions.assertThat;\\n\\npublic class JavaAdapterTest {\\n    @Test\\n    void createsJavaAdapterFromScriptObject() throws Exception {\\n        runWithUnsupportedFeatureCheck(() -> {\\n            Context context = Context.enter();\\n            try {\\n                context.setOptimizationLevel(-1);\\n                Scriptable scope = context.initStandardObjects();\\n                exposeJavaClass(context, scope, AdapterBase.class);\\n                exposeJavaClass(context, scope, AdapterContract.class);\\n\\n                Object adapterWrapper = context.evaluateString(scope, \\\"\\\"\\\"\\n                        new JavaAdapter(AdapterBase, AdapterContract, {\\n                            count: function() {\\n                                return 7;\\n                            },\\n                            dynamicOnly: function(left, right) {\\n                                return String(left) + ':' + String(right);\\n                            }\\n                        });\\n                        \\\"\\\"\\\", \\\"java-adapter-create\\\", 1, null);\\n\\n                Object adapter = unwrap(adapterWrapper);\\n                assertThat(adapter).isInstanceOf(AdapterBase.class);\\n                assertThat(adapter).isInstanceOf(AdapterContract.class);\\n\\n                AdapterContract contract = (AdapterContract) adapter;\\n                assertThat(contract.echo(\\\"value\\\")).isEqualTo(\\\"base:value\\\");\\n                assertThat(contract.count()).isEqualTo(7);\\n            } finally {\\n                Context.exit();\\n            }\\n        });\\n    }\\n\\n    @Test\\n    void serializesAndReadsJavaAdapterObject() throws Exception {\\n        runWithUnsupportedFeatureCheck(() -> {\\n            Context context = Context.enter();\\n            try {\\n                context.setOptimizationLevel(-1);\\n                Scriptable scope = context.initStandardObjects();\\n                exposeJavaClass(context, scope, AdapterBase.class);\\n                exposeJavaClass(context, scope, AdapterContract.class);\\n\\n                Object adapterWrapper = context.evaluateString(scope, \\\"\\\"\\\"\\n                        new JavaAdapter(AdapterBase, AdapterContract, {\\n                            count: function() {\\n                                return 11;\\n                            },\\n                            missing: function(value) {\\n                                return 'js:' + value;\\n                            }\\n                        });\\n                        \\\"\\\"\\\", \\\"java-adapter-serialize\\\", 1, null);\\n                Object adapter = unwrap(adapterWrapper);\\n\\n                byte[] serialized = serializeAdapter(scope, adapter);\\n                Object restored = deserializeAdapter(scope, (Scriptable) adapterWrapper, serialized);\\n\\n                assertThat(restored).isInstanceOf(AdapterBase.class);\\n                assertThat(restored).isInstanceOf(AdapterContract.class);\\n\\n                AdapterContract contract = (AdapterContract) restored;\\n                assertThat(contract.echo(\\\"after-read\\\")).isEqualTo(\\\"base:after-read\\\");\\n                assertThat(contract.count()).isEqualTo(11);\\n                assertThat(contract.missing(\\\"method\\\")).isEqualTo(\\\"js:method\\\");\\n            } finally {\\n                Context.exit();\\n            }\\n        });\\n    }\\n\\n    private static void exposeJavaClass(Context context, Scriptable scope, Class<?> type) {\\n        Scriptable javaClass = context.getWrapFactory().wrapJavaClass(context, scope, type);\\n        ScriptableObject.putProperty(scope, type.getSimpleName(), javaClass);\\n    }\\n\\n    private static Object unwrap(Object adapterWrapper) {\\n        assertThat(adapterWrapper).isInstanceOf(Wrapper.class);\\n        return ((Wrapper) adapterWrapper).unwrap();\\n    }\\n\\n    private static byte[] serializeAdapter(Scriptable scope, Object adapter) throws Exception {\\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\\n        try (ScriptableOutputStream output = new ScriptableOutputStream(bytes, scope)) {\\n            JavaAdapter.writeAdapterObject(adapter, output);\\n        }\\n        return bytes.toByteArray();\\n    }\\n\\n    private static Object deserializeAdapter(Scriptable scope, Scriptable self, byte[] serialized) throws Exception {\\n        ByteArrayInputStream bytes = new ByteArrayInputStream(serialized);\\n        try (ScriptableInputStream input = new ScriptableInputStream(bytes, scope)) {\\n            return JavaAdapter.readAdapterObject(self, input);\\n        }\\n    }\\n\\n    private static void runWithUnsupportedFeatureCheck(ThrowingRunnable runnable) throws Exception {\\n        try {\\n            runnable.run();\\n        } catch (Error error) {\\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\\n                throw error;\\n            }\\n        }\\n    }\\n\\n    @FunctionalInterface\\n    private interface ThrowingRunnable {\\n        void run() throws Exception;\\n    }\\n\\n    public static class AdapterBase implements Serializable {\\n        private static final long serialVersionUID = 1L;\\n\\n        public AdapterBase() {\\n        }\\n\\n        public String echo(String value) {\\n            return \\\"base:\\\" + value;\\n        }\\n\\n        protected String protectedMessage() {\\n            return \\\"protected\\\";\\n        }\\n\\n        public final String finalMessage() {\\n            return \\\"final\\\";\\n        }\\n    }\\n\\n    public interface AdapterContract {\\n        String echo(String value);\\n\\n        String missing(String value);\\n\\n        int count();\\n    }\\n}\\n\",\"exit_code\":0,\"status\":\"completed\"}}\n{\"type\":\"item.completed\",\"item\":{\"id\":\"item_10\",\"type\":\"agent_message\",\"text\":\"The current Rhino metadata file is empty and the test 