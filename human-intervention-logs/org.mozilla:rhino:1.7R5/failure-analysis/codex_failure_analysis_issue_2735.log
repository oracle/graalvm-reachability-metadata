r;\\nimport java.lang.reflect.Method;\\n\\nimport org.junit.jupiter.api.Test;\\nimport org.mozilla.javascript.Context;\\nimport org.mozilla.javascript.FunctionObject;\\nimport org.mozilla.javascript.Scriptable;\\nimport org.mozilla.javascript.ScriptableObject;\\n\\npublic class MemberBoxTest {\\n    public interface AccessibleName {\\n        String interfaceName(String value);\\n    }\\n\\n    public static class PublicBaseScriptable extends ScriptableObject {\\n        @Override\\n        public String getClassName() {\\n            return \\\"PublicBaseScriptable\\\";\\n        }\\n\\n        public String inheritedName(String value) {\\n            return \\\"base:\\\" + value;\\n        }\\n    }\\n\\n    public static class ConstructedScriptable extends ScriptableObject {\\n        private final String name;\\n        private final int count;\\n\\n        public ConstructedScriptable(String name, int count) {\\n            this.name = name;\\n            this.count = count;\\n        }\\n\\n        @Override\\n        public String getClassName() {\\n            return \\\"ConstructedScriptable\\\";\\n        }\\n\\n        public String description() {\\n            return name + \\\":\\\" + count;\\n        }\\n    }\\n\\n    private static final class HiddenInterfaceImplementation extends ScriptableObject implements AccessibleName {\\n        @Override\\n        public String getClassName() {\\n            return \\\"HiddenInterfaceImplementation\\\";\\n        }\\n\\n        @Override\\n        public String interfaceName(String value) {\\n            return \\\"interface:\\\" + value;\\n        }\\n    }\\n\\n    private static final class HiddenBaseImplementation extends PublicBaseScriptable {\\n        @Override\\n        public String inheritedName(String value) {\\n            return \\\"hidden:\\\" + value;\\n        }\\n    }\\n\\n    private static final class HiddenConstructedScriptable extends ScriptableObject {\\n        private final String value;\\n\\n        public HiddenConstructedScriptable(String value) {\\n            this.value = value;\\n        }\\n\\n        @Override\\n        public String getClassName() {\\n            return \\\"HiddenConstructedScriptable\\\";\\n        }\\n\\n        public String value() {\\n            return value;\\n        }\\n    }\\n\\n    @Test\\n    public void serializesMethodMemberAndRestoresItByPublicSignature() throws Exception {\\n        Context cx = Context.enter();\\n        try {\\n            Scriptable scope = cx.initStandardObjects();\\n            Method method = MemberBoxTest.class.getMethod(\\\"echo\\\", String.class);\\n            FunctionObject function = new FunctionObject(\\\"echo\\\", method, scope);\\n\\n            FunctionObject restored = serializeAndDeserialize(function);\\n\\n            Object result = restored.call(cx, scope, scope, new Object[] {\\\"restored\\\"});\\n            assertEquals(\\\"echo:restored\\\", Context.toString(result));\\n        } finally {\\n            Context.exit();\\n        }\\n    }\\n\\n    @Test\\n    public void serializesConstructorMemberAndRestoresItByPublicSignature() throws Exception {\\n        Context cx = Context.enter();\\n        try {\\n            Scriptable scope = cx.initStandardObjects();\\n            Constructor<ConstructedScriptable> constructor = ConstructedScriptable.class.getConstructor(\\n                    String.class, Integer.TYPE);\\n            FunctionObject function = new FunctionObject(\\\"ConstructedScriptable\\\", constructor, scope);\\n\\n            FunctionObject restored = serializeAndDeserialize(function);\\n            Scriptable constructed = restored.construct(cx, scope, new Object[] {\\\"item\\\", 3});\\n\\n            ConstructedScriptable scriptable = assertInstanceOf(ConstructedScriptable.class, constructed);\\n            assertEquals(\\\"item:3\\\", scriptable.description());\\n        } finally {\\n            Context.exit();\\n        }\\n    }\\n\\n    @T