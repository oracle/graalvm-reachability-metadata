rn 'js:' + value;\\n                  },\\n                  greet: function(name) {\\n                    return 'hello ' + name;\\n                  }\\n                });\\n                [\\n                  adapter.describe('item'),\\n                  adapter.inherited(),\\n                  adapter.greet('Bob'),\\n                  adapter.super$greet('Bob')\\n                ].join('|');\\n                \\\"\\\"\\\".formatted(AdapterBase.class.getName(), NamedJob.class.getName());\\n    }\\n\\n    private String serializableAdapterScript() {\\n        return \\\"\\\"\\\"\\n                new JavaAdapter(Packages.%s, Packages.%s, {\\n                  describe: function(value) {\\n                    return 'stored:' + value;\\n                  },\\n                  greet: function(name) {\\n                    return 'stored-greet:' + name;\\n                  }\\n                });\\n                \\\"\\\"\\\".formatted(AdapterBase.class.getName(), NamedJob.class.getName());\\n    }\\n\\n    private void rethrowUnlessUnsupportedDynamicClassLoading(Error error) {\\n        if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\\n            throw error;\\n        }\\n    }\\n}\\n\"}\n../2735-578f0697/human-intervention-logs/org.mozilla:rhino:1.7R5/add-new-library-support/pi-generation-2026-05-03T18-45-33-804758Z.log:2794:[tool-call] end id=call_9Dmqk3RqKmx8vzG14ZD9lKlz|fc_05d6d4edd3301d4e0169f79793ac2c8196b61579dd18746ba3 name=write args={\"path\": \"tests/src/org.mozilla/rhino/1.7R5/src/test/java/org_mozilla/rhino/JavaAdapterTest.java\", \"content\": \"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage org_mozilla.rhino;\\n\\nimport static org.junit.jupiter.api.Assertions.assertEquals;\\nimport static org.junit.jupiter.api.Assertions.assertInstanceOf;\\n\\nimport java.io.B