  import java.io.ObjectStreamConstants;
  import org.junit.jupiter.api.Test;
  
  public class GeneratedMessageLiteInnerSerializedFormTest {
      private static final String SERIALIZED_FORM_CLASS_NAME =
              "com.google.protobuf.GeneratedMessageLite$SerializedForm";
      private static final long BYTE_ARRAY_SERIAL_VERSION_UID = -5984413125824719648L;
  
      @Test
      void readResolveUsesDefaultInstanceField() throws Exception {
          Object serializedForm = CurrentStyleMessage.serializedFormOf(CurrentStyleMessage.defaultInstance());
  
          Object resolved = deserialize(serialize(serializedForm));
  
          assertThat(resolved).isInstanceOf(CurrentStyleMessage.class);
          assertThat((MessageLite) resolved).hasToString(CurrentStyleMessage.defaultInstance().toString());
      }
  
      @Test
      void readResolveFallsBackToLegacyDefaultInstanceField() throws Exception {
          Object serializedForm = CurrentStyleMessage.serializedFormOf(LegacyStyleMessage.defaultInstance());
  
          Object resolved = deserialize(serialize(serializedForm));
  
          assertThat(resolved).isInstanceOf(LegacyStyleMessage.class);
          assertThat((MessageLite) resolved).hasToString(LegacyStyleMessage.defaultInstance().toString());
      }
  
      @Test
      void readResolveLoadsMessageClassByNameForLegacySerializedForm() throws Exception {
          byte[] legacySerializedForm = legacySerializedFormStream(CurrentStyleMessage.class);
  
          Object resolved = deserialize(legacySerializedForm);
  
          assertThat(resolved).isInstanceOf(CurrentStyleMessage.class);
          assertThat((MessageLite) resolved).hasToString(CurrentStyleMessage.defaultInstance().toString());
      }
  
      private static byte[] serialize(Object value) throws IOException {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {
              output.writeObject(value);
          }
          return bytes.toByteArray();
