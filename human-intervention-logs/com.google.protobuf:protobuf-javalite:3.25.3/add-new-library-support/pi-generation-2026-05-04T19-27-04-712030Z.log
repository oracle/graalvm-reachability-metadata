[tool-call] delta {"path":"tests/src/com.google.protobuf/protobuf-javalite/3.25.3/src/test/java/com_google_protobuf/protobuf_javalite/ExtensionRegistryLiteTest.java","edits":[{"oldText":"import static org.assertj.core.api.Assertions.assertThat;\nimport static org.assertj.core.api.Assertions.assertThatThrownBy;\n\nimport com.google.protobuf.Descriptors;\nimport com.google.protobuf.Extension;\nimport com.google.protobuf.ExtensionRegistry;\nimport com.google.protobuf.ExtensionRegistryLite;\nimport com.google.protobuf.Message;\nimport com.google.protobuf.WireFormat;\nimport org.junit.jupiter.api.Test;\n\npublic class ExtensionRegistryLiteTest {\n    @Test\n    void addingFullExtensionDelegatesToFullRegistryThroughReflection() {\n        ExtensionRegistryLite registry = ExtensionRegistryLite.newInstance();\n        Extension<?, ?> extension = new DescriptorlessFullExtension();\n\n        assertThat(registry).isInstanceOf(ExtensionRegistry.class);\n        assertThatThrownBy(() -> registry.add(extension))\n                .isInstanceOf(IllegalArgumentException.class)\n                .hasMessageContaining(\"Could not invoke ExtensionRegistry#add\");\n    }\n\n    private static final class DescriptorlessFullExtension extends Extension<Message, Integer> {\n        private static final int FIELD_NUMBER = 1001;\n\n        @Override\n        public int getNumber() {\n            return FIELD_NUMBER;\n        }\n","newText":"import static org.assertj.core.api.Assertions.assertThat;\n\nimport com.google.protobuf.DescriptorProtos;\nimport com.google.protobuf.Descriptors;\nimport com.google.protobuf.Extension;\nimport com.google.protobuf.ExtensionLite;\nimport com.google.protobuf.ExtensionRegistry;\nimport com.google.protobuf.ExtensionRegistryLite;\nimport com.google.protobuf.Message;\nimport com.google.protobuf.WireFormat;\nimport org.junit.jupiter.api.Test;\n\npublic class ExtensionRegistryLiteTest {\n    @Test\n    void addingFullExtensionDelegatesToFullRegistryThroughReflection() throws Exception {\n        Descriptors.FileDescriptor fileDescriptor = extensionFileDescriptor();\n        Descriptors.Descriptor extendeeDescriptor = fileDescriptor.findMessageTypeByName(\"Extendee\");\n        Descriptors.FieldDescriptor extensionDescriptor = fileDescriptor.findExtensionByName(\"answer\");\n        ExtensionRegistryLite registry = ExtensionRegistry.newInstance();\n        Extension<?, ?> extension = new Int32FullExtension(extensionDescriptor);\n\n        registry.add((ExtensionLite<?, ?>) extension);\n\n        ExtensionRegistry.ExtensionInfo extensionInfo = ((ExtensionRegistry) registry)\n                .findImmutableExtensionByNumber(extendeeDescriptor, extensionDescriptor.getNumber());\n        assertThat(extensionInfo.descriptor).isSameAs(extensionDescriptor);\n    }\n\n    private static Descriptors.FileDescriptor extensionFileDescriptor()\n            throws Descriptors.DescriptorValidationException {\n        DescriptorProtos.DescriptorProto extendee = DescriptorProtos.DescriptorProto.newBuilder()\n                .setName(\"Extendee\")\n                .addExtensionRange(DescriptorProtos.DescriptorProto.ExtensionRange.newBuilder()\n                        .setStart(100)\n                        .setEnd(536870912))\n                .build();\n        DescriptorProtos.FieldDescriptorProto extension = DescriptorProtos.FieldDescriptorProto.newBuilder()\n                .setName(\"answer\")\n                .setNumber(100)\n                .setLabel(DescriptorProtos.FieldDescriptorProto.Label.LABEL_OPTIONAL)\n                .setType(DescriptorProtos.FieldDescriptorProto.Type.TYPE_INT32)\n                .setExtendee(\".coverage.Extendee\")\n                .build();\n        DescriptorProtos.FileDescriptorProto file = DescriptorProtos.FileDescriptorProto.newBuilder()\n                .setSyntax(\"proto2\")\n                .setName(\"coverage.proto\")\n                .setPackage(\"coverage\")\n                .addMessageType(extendee)\n                .addExtension(extension)\n                .build();\n        return Descriptors.FileDescriptor.buildFrom(file, new Descriptors.FileDescriptor[0]);\n    }\n\n    private static final class Int32FullExtension extends Extension<Message, Integer> {\n        private final Descriptors.FieldDescriptor descriptor;\n\n        private Int32FullExtension(Descriptors.FieldDescriptor descriptor) {\n            this.descriptor = descriptor;\n        }\n\n        @Override\n        public int getNumber() {\n            return descriptor.getNumber();\n        }\n"}]}
