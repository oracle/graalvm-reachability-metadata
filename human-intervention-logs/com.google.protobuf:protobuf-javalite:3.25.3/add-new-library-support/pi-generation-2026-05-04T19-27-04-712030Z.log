    }
  
    public static boolean isEagerlyParseMessageSets() {
      return eagerlyParseMessageSets;
    }
  
    public static void setEagerlyParseMessageSets(boolean isEagerlyParse) {
      eagerlyParseMessageSets = isEagerlyParse;
