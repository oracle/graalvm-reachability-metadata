.jupiter/junit-jupiter-params/index.json\n./metadata/org.junit.jupiter/junit-jupiter/index.json\n./metadata/org.junit.jupiter/junit-jupiter-engine/index.json\n./metadata/org.apache.thrift/libthrift/index.json\n./metadata/jakarta.authentication/jakarta.authentication-api/index.json\n./metadata/org.springframework/spring-jcl/index.json\n./metadata/org.springframework/spring-aspects/index.json\n./metadata/org.springframework/spring-instrument/index.json\n./metadata/com.rabbitmq/amqp-client/index.json\n./metadata/com.fasterxml.jackson.dataformat/jackson-dataformat-yaml/index.json\n./metadata/com.fasterxml.jackson.dataformat/jackson-dataformat-toml/index.json\n./metadata/com.fasterxml.jackson.dataformat/jackson-dataformat-cbor/index.json\n./metadata/net.postgis/postgis-jdbc/index.json\n./metadata/net.postgis/postgis-geometry/index.json\n./metadata/io.prometheus/simpleclient_tracer_otel/index.json\n./metadata/io.prometheus/simpleclient_tracer_common/index.json\n./metadata/io.prometheus/simpleclient_tracer_otel_agent/index.json\n./metadata/io.prometheus/simpleclient/index.json\n./metadata/io.prometheus/simpleclient_caffeine/index.json\n./metadata/org.wildfly.openssl/wildfly-openssl-java/index.json\n./COVERAGE.md:116:| [`com.softwaremill.sttp.model:core_3`](https://github.com/softwaremill/sttp-model) | 1.7.12 | 100% (0/0 calls) | <details><summary>Show</summary> sttp model provides Scala HTTP model classes such as URI, method, status code, media type, headers, query parameters, multipart parts, and server-sent events. It includes parsing and serialization helpers for these values and is used by sttp client and tapir as a shared HTTP modeling layer.</details> |\n./metadata/com.softwaremill.sttp.shared/zio_3/index.json:9:    \"description\" : \"sttp-shared zio_3 is the Scala 3 JVM module that adds ZIO stream support to sttp-shared's streaming capability abstraction. It provides the ZioStreams capability, including byte-limit handling for ZStream values used by sttp client, Tapir, and related sttp projects.\",\n./metadata/com.softwaremill.sttp.shared/core_3/index.json:9:    \"description\" : \"sttp-shared core provides common Scala abstractions used across the sttp ecosystem, including typed capability markers, attribute maps, monad error typeclasses, and streaming and web socket capability definitions. This artifact is the Scala 3 JVM build of that shared foundation, enabling sttp client, tapir, model, and related modules to express effects, streams, and request and response metadata consistently.\",\n./metadata/com.monovore/decline-effect_3/index.json:9:    \"description\" : \"Decline Effect adds Cats Effect integration to the decline command-line parser for Scala. It provides CommandIOApp so applications can define composable CLI parsers with decline and execute commands as cats-effect IO programs.\",\n./metadata/org.typelevel/cats-effect_3/index.json:5:    \"source-code-url\" : \"https://repo.maven.apache.org/maven2/org/typelevel/cats-effect_3/$version$/cats-effect_3-$version$-sources.jar\",\n./metadata/org.typelevel/cats-effect_3/index.json:6:    \"repository-url\" : \"https://github.com/typelevel/cats-effect\",\n./metadata/org.typelevel/cats-effect_3/index.json:7:    \"test-code-url\" : \"https://github.com/typelevel/cats-effect/tree/v$version$/tests\",\n./metadata/org.typelevel/cats-effect_3/index.json:8:    \"documentation-url\" : \"https://github.com/typelevel/cats-effect/tree/v$version$/docs\",\n./metadata/org.typelevel/cats-effect_3/index.json:53:    \"source-code-url\" : \"https://repo1.maven.org/maven2/org/typelevel/cats-effect_3/2.5.1/cats-effect_3-2.5.1-sources.jar\",\n./metadata/org.typelevel/cats-effect_3/index.json:54:    \"repository-url\" : \"https://github.com/typelevel/cats-effect\",\n./metadata/org.typelevel/cats-effect_3/index.json:55:    \"test-code-url\" : \"https://github.com/typelevel/cats-effect/tree/v2.5.1/core/shared/src/test/scala\",\n./metadata/org.typelevel/cats-effect_3/index.json:56:    \"documentation-url\" : \"https://repo1.maven.org/maven2/org/typelevel/cats-effect_3/2.5.1/cats-effect_3-2.5.1-javadoc.jar\",\n./metadata/org.typelevel/munit-cats-effect_3/index.json:5:    \"source-code-url\" : \"https://repo1.maven.org/maven2/org/typelevel/munit-cats-effect_3/2.2.0/munit-cats-effect_3-2.2.0-sources.jar\",\n./metadata/org.typelevel/munit-cats-effect_3/index.json:6:    \"repository-url\" : \"https://github.com/typelevel/munit-cats-effect\",\n./metadata/org.typelevel/munit-cats-effect_3/index.json:7:    \"test-code-url\" : \"https://github.com/typelevel/munit-cats-effect/tree/v2.2.0/core/src/test\",\n./metadata/org.typelevel/munit-cats-effect_3/index.json:8:    \"documentation-url\" : \"https://repo1.maven.org/maven2/org/typelevel/munit-cats-effect_3/2.2.0/munit-cats-effect_3-2.2.0-javadoc.jar\",\n./metadata/org.typelevel/munit-cats-effect_3/index.json:9:    \"description\" : \"munit-cats-effect integrates the MUnit testing framework with Cats Effect so Scala tests can return IO and SyncIO values directly. It provides CatsEffectSuite, Cats Effect-aware assertions, and resource fixtures for writing effectful test suites without unsafe execution in test code.\",\n./metadata/org.typelevel/cats-effect-kernel_3/index.json:5:    \"source-code-url\" : \"https://repo.maven.apache.org/maven2/org/typelevel/cats-effect-kernel_3/$version$/cats-effect-kernel_3-$version$-sources.jar\",\n./metadata/org.typelevel/cats-effect-kernel_3/index.json:6:    \"repository-url\" : \"https://github.com/typelevel/cats-effect\",\n./metadata/org.typelevel/cats-effect-kernel_3/index.json:7:    \"test-code-url\" : \"https://github.com/typelevel/cats-effect/tree/v$version$/kernel/shared/src/test\",\n./metadata/org.typelevel/cats-effect-kernel_3/index.json:8:    \"documentation-url\" : \"https://repo.maven.apache.org/maven2/org/typelevel/cats-effect-kernel_3/$version$/cats-effect-kernel_3-$version$-javadoc.jar\",\n./metadata/com.softwaremill.sttp.model/core_3/index.json:9:    \"description\" : \"sttp model provides Scala HTTP model classes such as URI, method, status code, media type, headers, query parameters, multipart parts, and server-sent events. It includes parsing and serialization helpers for these values and is used by sttp client and tapir as a shared HTTP modeling layer.\",\n./metadata/org.http4s/http4s-ember-server_3/index.json:9:    \"description\" : \"http4s Ember Server is the Ember backend implementation for running http4s servers on the JVM. It provides a lightweight, functional HTTP server for the http4s ecosystem using cats-effect and FS2.\",\n./metadata/com.softwaremill.sttp.tapir/tapir-http4s-server_3/index.json:5:    \"source-code-url\" : \"https://repo1.maven.org/maven2/com/softwaremill/sttp/tapir/tapir-http4s-server_3/$version$/tapir-http4s-server_3-$version$-sources.jar\",\n./metadata/com.softwaremill.sttp.tapir/tapir-http4s-server_3/index.json:6:    \"repository-url\" : \"https://github.com/softwaremill/tapir\",\n./metadata/com.softwaremill.sttp.tapir/tapir-http4s-server_3/index.json:7:    \"test-code-url\" : \"https://github.com/softwaremill/tapir/tree/v$version$/server/http4s-server/src/test/scala\",\n./metadata/com.softwaremill.sttp.tapir/tapir-http4s-server_3/index.json:8:    \"documentation-url\" : \"https://repo1.maven.org/maven2/com/softwaremill/sttp/tapir/tapir-http4s-server_3/$version$/tapir-http4s-server_3-$version$-javadoc.jar\",\n./metadata/com.softwaremill.sttp.tapir/tapir-http4s-server_3/index.json:9:    \"description\" : \"Tapir lets Scala developers describe HTTP API endpoints as immutable, reusable values and derive server, client, and OpenAPI integrations from those descriptions. The tapir-http4s-server module interprets Tapir server endpoints as http4s routes for cats-effect applications, including request and response handling, fs2 streaming, server-sent events, and WebSocket support.\",\n./metadata/com.softwaremill.sttp.tapir/tapir-http4s-server_3/index.json:66:      \"sttp.tapir.server.http4s\"\n./metadata/com.softwaremill.sttp.tapir/tapir-cats-effect_3/index.json:5:    \"source-code-url\" : \"https://repo.maven.apache.org/maven2/com/softwaremill/sttp/tapir/tapir-cats-effect_3/$version$/tapir-cats-effect_3-$version$-sources.jar\",\n./metadata/com.softwaremill.sttp.tapir/tapir-cats-effect_3/index.json:6:    \"repository-url\" : \"https://github.com/softwaremill/tapir\",\n./metadata/com.softwaremill.sttp.tapir/tapir-cats-effect_3/index.json:8:    \"documentation-url\" : \"https://repo.maven.apache.org/maven2/com/softwaremill/sttp/tapir/tapir-cats-effect_3/$version$/tapir-cats-effect_3-$version$-javadoc.jar\",\n./metadata/com.softwaremill.sttp.tapir/tapir-cats-effect_3/index.json:9:    \"description\" : \"Tapir is a Scala library for describing HTTP API endpoints as immutable, type-safe values and deriving server, client, and OpenAPI, AsyncAPI, or JSON Schema integrations from them. The tapir-cats-effect module provides a Cats Effect Sync-backed MonadError adapter so Tapir interpreters and endpoint logic can run in Cats Effect-based applications.\",\n./metadata/com.softwaremill.sttp.tapir/tapir-cats-effect_3/index.json:18:      \"sttp.tapir.integ.cats.effect\"\n./metadata/com.softwaremill.sttp.tapir/tapir-zio_3/index.json:5:    \"source-code-url\" : \"https://repo1.maven.org/maven2/com/softwaremill/sttp/tapir/tapir-zio_3/$version$/tapir-zio_3-$version$-sources.jar\",\n./metadata/com.softwaremill.sttp.tapir/tapir-zio_3/index.json:6:    \"repository-url\" : \"https://github.com/softwaremill/tapir\",\n./metadata/com.softwaremill.sttp.tapir/tapir-zio_3/index.json:7:    \"test-code-url\" : \"https://github.com/softwaremill/tapir/tree/v$version$/integrations/zio/src/test\",\n./metadata/com.softwaremill.sttp.tapir/tapir-zio_3/index.json:8:    \"documentation-url\" : \"https://repo1.maven.org/maven2/com/softwaremill/sttp/tapir/tapir-zio_3/$version$/tapir-zio_3-$version$-javadoc.jar\",\n./metadata/com.softwaremill.sttp.tapir/tapir-zio_3/index.json:9:    \"description\" : \"Tapir is a S