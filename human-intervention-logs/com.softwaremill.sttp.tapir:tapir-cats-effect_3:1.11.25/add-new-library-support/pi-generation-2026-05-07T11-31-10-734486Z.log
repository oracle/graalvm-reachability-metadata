[tool-call] delta {"path":"tests/src/com.softwaremill.sttp.tapir/tapir-cats-effect_3/1.11.25/src/test/scala/com_softwaremill_sttp_tapir/tapir_cats_effect_3/Tapir_cats_effect_3Test.scala","edits":[{"oldText":"import org.junit.jupiter.api.Test\nimport sttp.tapir.integ.cats.effect.CatsMonadError\n","newText":"import org.junit.jupiter.api.Test\nimport sttp.monad.MonadError\nimport sttp.monad.syntax.*\nimport sttp.tapir.integ.cats.effect.CatsMonadError\n"},{"oldText":"  @Test\n  def blockingRunsSynchronousComputationInIo(): Unit = {\n    val program: IO[String] = monad.map(monad.blocking {\n      val result: Int = 40 + 2\n      s\"blocking:$result\"\n    })(identity)\n\n    assertEquals(\"blocking:42\", await(program))\n  }\n\n  private def append(events: CopyOnWriteArrayList[String], event: String): IO[Unit] =\n","newText":"  @Test\n  def blockingRunsSynchronousComputationInIo(): Unit = {\n    val program: IO[String] = monad.map(monad.blocking {\n      val result: Int = 40 + 2\n      s\"blocking:$result\"\n    })(identity)\n\n    assertEquals(\"blocking:42\", await(program))\n  }\n\n  @Test\n  def catsMonadErrorCanPowerTapirMonadSyntaxForIoPrograms(): Unit = {\n    given MonadError[IO] = monad\n\n    val events: CopyOnWriteArrayList[String] = new CopyOnWriteArrayList[String]()\n    val boom: IllegalStateException = new IllegalStateException(\"syntax failure\")\n    val program: IO[String] = \"request\".unit[IO]\n      .flatTap { (value: String) =>\n        monad.eval {\n          events.add(s\"seen:$value\")\n          ()\n        }\n      }\n      .flatMap(_ => monad.error[String](boom))\n      .handleError {\n        case e: IllegalStateException if e eq boom => \"recovered\".unit[IO]\n      }\n      .ensure(monad.eval {\n        events.add(\"finalized\")\n        ()\n      })\n\n    assertSame(monad, MonadError[IO])\n    assertEquals(\"recovered\", await(program))\n    assertEquals(List(\"seen:request\", \"finalized\"), events.asScala.toList)\n  }\n\n  private def append(events: CopyOnWriteArrayList[String], event: String): IO[Unit] =\n"}]}
