) {\n      case e: IllegalArgumentException if e eq boom => monad.unit(\"recovered\")\n    }\n\n    assertTrue(events.isEmpty)\n    assertEquals(\"recovered\", await(recovered))\n    assertEquals(List(\"construct\", \"finalizer\"), events.asScala.toList)\n  }\n\n  @Test\n  def ensureRunsFinalizerWhenProgramIsCanceled(): Unit = {\n    val started: CountDownLatch = new CountDownLatch(1)\n    val finalized: AtomicBoolean = new AtomicBoolean(false)\n    val neverCompleting: IO[String] = monad.flatMap(monad.eval(started.countDown()))(_ => IO.never)\n    val guarded: IO[String] = monad.ensure(\n      neverCompleting,\n      monad.eval {\n        finalized.set(true)\n        ()\n      }\n    )\n\n    val program: IO[Unit] = for {\n      fiber <- guarded.start\n      _ <- IO.blocking(assertTrue(started.await(2, TimeUnit.SECONDS)))\n      _ <- fiber.cancel\n    } yield ()\n\n    await(program)\n    assertTrue(finalized.get())\n  }\n\n  @Test\n  def blockingRunsSynchronousComputationInIo(): Unit = {\n    val program: IO[String] = monad.map(monad.blocking {\n      val result: Int = 40 + 2\n      s\"blocking:$result\"\n    })(identity)\n\n    assertEquals(\"blocking:42\", await(program))\n  }\n\n  private def append(events: CopyOnWriteArrayList[String], event: String): IO[Unit] =\n    monad.eval {\n      events.add(event)\n      ()\n    }\n\n  private def await[A](io: IO[A]): A =\n    io.timeout(5.seconds).unsafeRunSync()\n}\n"}], "isError": false, "timestamp": 1778153384140}]}
