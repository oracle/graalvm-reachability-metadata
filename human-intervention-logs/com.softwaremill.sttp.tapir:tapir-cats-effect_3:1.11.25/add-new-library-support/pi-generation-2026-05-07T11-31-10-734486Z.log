  +        events.add("finalized")
  +        ()
  +      })
  +
  +    assertSame(monad, MonadError[IO])
  +    assertEquals("recovered", await(program))
  +    assertEquals(List("seen:request", "finalized"), events.asScala.toList)
  +  }
