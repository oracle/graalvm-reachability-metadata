= monad.unit(monad.unit(\"nested\"))\n    38\t\n    39\t    val program: IO[String] = monad.flatMap(monad.map(monad.unit(21))(_ + 1)) { (value: Int) =>\n    40\t      monad.flatMap(monad.flatten(nested)) { (prefix: String) =>\n    41\t        monad.flatMap(monad.flatTap(monad.unit(value * 2)) { (computed: Int) =>\n    42\t          monad.eval(sideEffects.addAndGet(computed))\n    43\t        }) { (computed: Int) =>\n    44\t          monad.unit(s\"$prefix:$computed\")\n    45\t        }\n    46\t      }\n    47\t    }\n    48\t\n    49\t    assertEquals(\"nested:44\", await(program))\n    50\t    assertEquals(44, sideEffects.get())\n    51\t  }\n    52\t\n    53\t  @Test\n    54\t  def fromTryErrorAndHandleErrorPreserveThrowableSemantics(): Unit = {\n    55\t    val boom: IllegalStateException = new IllegalStateException(\"boom\")\n    56\t    val recoveredFromFailure: IO[String] = monad.handleError(monad.fromTry(Failure[String](boom))) {\n    57\t      case e: IllegalStateException if e.getMessage == \"boom\" => monad.unit(\"recovered-from-try\")\n    58\t    }\n    59\t    val recoveredFromRaisedError: IO[String] = monad.handleError(monad.error[String](boom)) {\n    60\t      case e: IllegalStateException if e eq boom => monad.unit(\"recovered-from-error\")\n    61\t    }\n    62\t\n    63\t    assertEquals(7, await(monad.fromTry(Success(7))))\n    64\t    assertEquals(\"recovered-from-try\", await(recoveredFromFailure))\n    65\t    assertEquals(\"recovered-from-error\", await(recoveredFromRaisedError))\n    66\t\n    67\t    val thrown: IllegalStateException = assertThrows(classOf[IllegalStateException], () => await(monad.error[String](boom)))\n    68\t    assertSame(boom, thrown)\n    69\t  }\n    70\t\n    71\t  @Test\n    72\t  def handleErrorCatchesExceptionsThrownWhileConstructingTheEffect(): Unit = {\n    73\t    val boom: IllegalArgumentException = new IllegalArgumentException(\"constructed too early\")\n    74\t\n    75\t    val recovered: IO[String] = monad.handleError[String]({\n    76\t      throw boom\n    77\t    }) {\n    78\t      case e: IllegalArgumentException if e eq boom => monad.unit(\"recovered\")\n    79\t    }\n    80\t\n    81\t    assertEquals(\"recovered\", await(recovered))\n    82\t  }\n    83\t\n    84\t  @Test\n    85\t  def evalAndSuspendAreLazyAndRunInsideIo(): Unit = {\n    86\t    val evalWasRun: AtomicBoolean = new AtomicBoolean(false)\n    87\t    val suspendWasConstructed: AtomicBoolean = new AtomicBoolean(false)\n    88\t\n    89\t    val delayed: IO[String] = monad.eval {\n    90\t      evalWasRun.set(true)\n    91\t      \"evaluated\"\n    92\t    }\n    93\t    val suspended: IO[String] = monad.suspend {\n    94\t      suspendWasConstructed.set(true)\n    95\t      monad.unit(\"suspended\")\n    96\t    }\n    97\t\n    98\t    assertFalse(evalWasRun.get())\n    99\t    assertFalse(suspendWasConstructed.get())\n   100\t    assertEquals(\"evaluated\", await(delayed))\n   101\t    assertEquals(\"suspended\", await(suspended))\n   102\t    assertTrue(evalWasRun.get())\n   103\t    assertTrue(suspendWasConstructed.get())\n   104\t  }\n   105\t\n   106\t  @Test\n   107\t  def suspendTurnsEffectConstructionFailuresIntoRecoverableIoFailures(): Unit = {\n   108\t    val boom: RuntimeException = new RuntimeException(\"deferred failure\")\n   109\t    val program: IO[String] = monad.handleError(monad.suspend[String] {\n   110\t      throw boom\n   111\t    }) {\n   112\t      case e: RuntimeException if e eq boom => monad.unit(\"recovered\")\n   113\t    }\n   114\t\n   115\t    assertEquals(\"recovered\", await(program))\n   116\t  }\n   117\t\n   118\t  @Test\n   119\t  def ensure2RunsFinalizerAfterSuccessfulProgram(): Unit = {\n   120\t    val events: CopyOnWriteArrayList[String] = new CopyOnWriteArrayList[String]()\n   121\t    val program: IO[String] = monad.ensure2(\n   122\t      monad.eval {\n   123\t        events.add(\"body\")\n   124\t        \"ok\"\n   125\t      },\n   126\t    