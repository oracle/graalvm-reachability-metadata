lean = new AtomicBoolean(false)\n   168\t    val neverCompleting: IO[String] = monad.flatMap(monad.eval(started.countDown()))(_ => IO.never)\n   169\t    val guarded: IO[String] = monad.ensure(\n   170\t      neverCompleting,\n   171\t      monad.eval {\n   172\t        finalized.set(true)\n   173\t        ()\n   174\t      }\n   175\t    )\n   176\t\n   177\t    val program: IO[Unit] = for {\n   178\t      fiber <- guarded.start\n   179\t      _ <- IO.blocking(assertTrue(started.await(2, TimeUnit.SECONDS)))\n   180\t      _ <- fiber.cancel\n   181\t    } yield ()\n   182\t\n   183\t    await(program)\n   184\t    assertTrue(finalized.get())\n   185\t  }\n   186\t\n   187\t  @Test\n   188\t  def blockingRunsSynchronousComputationInIo(): Unit = {\n   189\t    val program: IO[String] = monad.map(monad.blocking {\n   190\t      val result: Int = 40 + 2\n   191\t      s\"blocking:$result\"\n   192\t    })(identity)\n   193\t\n   194\t    assertEquals(\"blocking:42\", await(program))\n   195\t  }\n   196\t\n   197\t  @Test\n   198\t  def catsMonadErrorCanPowerTapirMonadSyntaxForIoPrograms(): Unit = {\n   199\t    given MonadError[IO] = monad\n   200\t\n   201\t    val events: CopyOnWriteArrayList[String] = new CopyOnWriteArrayList[String]()\n   202\t    val boom: IllegalStateException = new IllegalStateException(\"syntax failure\")\n   203\t    val program: IO[String] = syntaxProgram[IO](events, boom)\n   204\t\n   205\t    assertSame(monad, MonadError[IO])\n   206\t    assertEquals(\"recovered\", await(program))\n   207\t    assertEquals(List(\"seen:request\", \"finalized\"), events.asScala.toList)\n   208\t  }\n   209\t\n   210\t  private def syntaxProgram[F[_]](\n   211\t      events: CopyOnWriteArrayList[String],\n   212\t      boom: IllegalStateException\n   213\t  )(using effect: MonadError[F]): F[String] =\n   214\t    effect.unit(\"request\")\n   215\t      .flatTap { (value: String) =>\n   216\t        effect.eval {\n   217\t          events.add(s\"seen:$value\"