[tool-exec] end id=call_WhUamOp9RJUS3F7IqKChAuaK|fc_0e758d19629206f8016a0cc52b0ecc81a1bb7ac5bab19dc9d0 name=read status=success
  /*
   * Copyright and related rights waived via CC0
   *
   * You should have received a copy of the CC0 legalcode along with this
   * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.
   */
  plugins {
      id "org.graalvm.internal.tck"
  }
  
  String libraryVersion = tck.testedLibraryVersion.get()
  File extractedWeb3jAarJarsDirectory = layout.buildDirectory.dir("extracted-web3j-aar-jars").get().asFile
  TaskProvider<Task> extractWeb3jAndroidAars = tasks.register("extractWeb3jAndroidAars") {
      inputs.files(configurations.web3jAndroidAars)
      outputs.dir(extractedWeb3jAarJarsDirectory)
  
      doLast {
          delete(extractedWeb3jAarJarsDirectory)
          extractedWeb3jAarJarsDirectory.mkdirs()
          configurations.web3jAndroidAars.files.each { File aar ->
              copy {
                  from(zipTree(aar)) {
                      include "classes.jar"
                      rename { String ignored -> aar.name.replace(".aar", ".jar") }
                  }
                  into extractedWeb3jAarJarsDirectory
              }
          }
      }
  }
  FileTree extractedWeb3jAarJars = fileTree(dir: extractedWeb3jAarJarsDirectory, include: "*.jar")
  extractedWeb3jAarJars.builtBy(extractWeb3jAndroidAars)
  
  repositories {
      maven {
          url = uri("https://artifacts.consensys.net/public/maven/maven/")
          content {
              includeGroup "tech.pegasys"
          }
      }
  }
  
  configurations {
      web3jAndroidAars
  }
  
  dependencies {
      web3jAndroidAars "org.web3j:core:$libraryVersion@aar"
      web3jAndroidAars "org.web3j:abi:$libraryVersion@aar"
      web3jAndroidAars "org.web3j:crypto:$libraryVersion@aar"
      web3jAndroidAars "org.web3j:rlp:$libraryVersion@aar"
      web3jAndroidAars "org.web3j:tuples:$libraryVersion@aar"
      web3jAndroidAars "org.web3j:utils:$libraryVersion@aar"
  
      testImplementation extractedWeb3jAarJars
      testImplementation 'com.fasterxml.jackson.core:jackson-databind:2.17.1'
      testImplementation 'com.github.jnr:jnr-unixsocket:0.38.22'
      testImplementation 'com.squareup.okhttp3:okhttp:4.12.0'
      testImplementation 'com.squareup.okhttp3:logging-interceptor:4.12.0'
      testImplementation 'io.consensys.protocols:jc-kzg-4844:2.0.0'
      testImplementation 'io.github.adraffy:ens-normalize:0.2.0'
      testImplementation 'io.reactivex.rxjava2:rxjava:2.2.21'
      testImplementation 'io.tmio:tuweni-bytes:2.4.2'
      testImplementation 'io.tmio:tuweni-units:2.4.2'
      testImplementation 'org.bouncycastle:bcprov-jdk18on:1.78.1'
      testImplementation 'org.java-websocket:Java-WebSocket:1.5.6'
      testImplementation 'org.slf4j:slf4j-api:2.0.13'
      testImplementation 'org.assertj:assertj-core:3.22.0'
  }
  
  graalvmNative {
      agent {
          defaultMode = "conditional"
          modes {
              conditional {
                  userCodeFilterPath = "user-code-filter.json"
              }
          }
      }
  }
