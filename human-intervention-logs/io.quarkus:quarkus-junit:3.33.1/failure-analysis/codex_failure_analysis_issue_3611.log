ides;\\n        }\\n\\n        @Override\\n        public Set<Class<?>> getEnabledAlternatives() {\\n            return Set.of(String.class);\\n        }\\n\\n        @Override\\n        public String getConfigProfile() {\\n            return \\\"integration\\\";\\n        }\\n\\n        @Override\\n        public List<TestResourceEntry> testResources() {\\n            return List.of(new TestResourceEntry(RecordingResource.class, Map.of(\\\"name\\\", \\\"primary\\\"), true));\\n        }\\n\\n        @Override\\n        public boolean disableGlobalTestResources() {\\n            return true;\\n        }\\n\\n        @Override\\n        public Set<String> tags() {\\n            return Set.of(\\\"smoke\\\", \\\"fast\\\");\\n        }\\n\\n        @Override\\n        public String[] commandLineParameters() {\\n            return new String[] { \\\"--verbose\\\", \\\"input.txt\\\" };\\n        }\\n\\n        @Override\\n        public boolean runMainMethod() {\\n            return true;\\n        }\\n\\n        @Override\\n        public boolean disableApplicationLifecycleObservers() {\\n            return true;\\n        }\\n    }\\n\\n    public static final class RecordingResource implements QuarkusTestResourceLifecycleManager {\\n        private final List<String> events = new ArrayList<>();\\n\\n        @Override\\n        public void init(Map<String, String> initArgs) {\\n            events.add(\\\"init:\\\" + initArgs);\\n        }\\n\\n        @Override\\n        public Map<String, String> start() {\\n            events.add(\\\"start\\\");\\n            return Map.of(\\\"resource.started\\\", \\\"true\\\");\\n        }\\n\\n        @Override\\n        public void stop() {\\n            events.add(\\\"stop\\\");\\n        }\\n    }\\n\\n    private static final class StaticResourceContext implements QuarkusTestResourceLifecycleManager.Context {\\n        private final String testProfile;\\n        private final TestStatus testStatus = new TestStatus(null);\\n\\n 