\n        assertThat(profile.disableApplicationLifecycleObservers()).isFalse();\\n    }\\n\\n    @Test\\n    void customTestProfileComposesOverridesResourcesTagsAndMainArguments() {\\n        QuarkusTestProfile profile = new CustomProfile();\\n\\n        assertThat(profile.getConfigOverrides())\\n                .containsEntry(\\\"quarkus.http.test-port\\\", \\\"0\\\")\\n                .containsEntry(\\\"feature.enabled\\\", \\\"true\\\");\\n        assertThat(profile.getEnabledAlternatives()).containsExactly(String.class);\\n        assertThat(profile.getConfigProfile()).isEqualTo(\\\"integration\\\");\\n        assertThat(profile.disableGlobalTestResources()).isTrue();\\n        assertThat(profile.tags()).containsExactlyInAnyOrder(\\\"fast\\\", \\\"smoke\\\");\\n        assertThat(profile.commandLineParameters()).containsExactly(\\\"--verbose\\\", \\\"input.txt\\\");\\n        assertThat(profile.runMainMethod()).isTrue();\\n        assertThat(profile.disableApplicationLifecycleObservers()).isTrue();\\n\\n        QuarkusTestProfile.TestResourceEntry resourceEntry = profile.testResources().get(0);\\n        assertThat(resourceEntry.getClazz()).isEqualTo(RecordingResource.class);\\n        assertThat(resourceEntry.getArgs()).containsExactly(Map.entry(\\\"name\\\", \\\"primary\\\"));\\n        assertThat(resourceEntry.isParallel()).isTrue();\\n    }\\n\\n    @Test\\n    void testResourceEntryConstructorsRetainManagerClassArgumentsAndParallelFlag() {\\n        QuarkusTestProfile.TestResourceEntry defaultEntry = new QuarkusTestProfile.TestResourceEntry(\\n                RecordingResource.class);\\n        QuarkusTestProfile.TestResourceEntry configuredEntry = new QuarkusTestProfile.TestResourceEntry(\\n                RecordingResource.class, Map.of(\\\"port\\\", \\\"0\\\"));\\n        QuarkusTestProfile.TestResourceEntry parallelEntry = new QuarkusTestProfile.TestResourceEntry(\\n                RecordingResource.class, Map.of(\\\"pool\\\", \\\"shared\\\"), true);\\n\\n        assertThat(defaultEntry.getClazz()).isEqualTo(RecordingResource.class);\\n        assertThat(defaultEntry.getArgs()).isEmpty();\\n        assertThat(defaultEntry.isParallel()).isFalse();\\n\\n        assertThat(configuredEntry.getClazz()).isEqualTo(RecordingResource.class);\\n        assertThat(configuredEntry.getArgs()).containsExactly(Map.entry(\\\"port\\\", \\\"0\\\"));\\n        assertThat(configuredEntry.isParallel()).isFalse();\\n\\n        assertThat(parallelEntry.getClazz()).isEqualTo(RecordingResource.class);\\n        assertThat(parallelEntry.getArgs()).containsExactly(Map.entry(\\\"pool\\\", \\\"shared\\\"));\\n        assertThat(parallelEntry.isParallel()).isTrue();\\n    }\\n\\n    @Test\\n    void testResourceLifecycleManagerDefaultsAreNoOpsAroundRequiredLifecycleMethods() {\\n        RecordingResource resource = new RecordingResource();\\n        QuarkusTestResourceLifecycleManager.Context context = new StaticResourceContext(CustomProfile.class.getName());\\n\\n        assertThatCode(() -> resource.setContext(context)).doesNotThrowAnyException();\\n        assertThatCode(() -> resource.inject(new Object())).doesNotThrowAnyException();\\n        List<Object> injectedValues = new ArrayList<>();\\n        QuarkusTestResourceLifecycleManager.TestInjector injector = (value, predicate) -> injectedValues.add(value);\\n        assertThatCode(() -> resource.inject(injector)).doesNotThrowAnyException();\\n        assertThat(injectedValues).isEmpty();\\n        assertThat(resource.order()).isZero();\\n\\n        resource.init(Map.of(\\\"alpha\\\", \\\"one\\\"));\\n        Map<String, String> startedConfig = resource.start();\\n        resource.stop();\\n\\n        assertThat(resource.events).containsExactly(\\\"init:{alpha=one}\\\", \\\"start\\\", \\\"stop\\\");\\n        assertThat(startedConfig).containsExactly(Map.entry(\\\"resource.started\\\", \\\"true\\\"));\\n        assertThat(context.testProfile()).isEqualTo(CustomProfile.class.getName());\\n        assertThat(context.getTestStatus().isTestFailed()).isFalse();\\n    }\\n\\n    @Test\\n    void launchResultDefaultMethodsJoinCapturedOutputStreams() {\\n        LaunchResult result = new CapturedLaunchResult(\\n                List.of(\\\"first line\\\", \\\"second line\\\"),\\n                List.of(\\\"warning\\\", \\\"details\\\"),\\n                7);\\n\\n        assertThat(result.getOutputStream()).containsExactly(\\\"first line\\\", \\\"second line\\\");\\n        assertThat(result.getOutput()).isEqualTo(\\\"first line\\\\nsecond line\\\");\\n        assertThat(result.getErrorStream()).containsExactly(\\\"warning\\\", \\\"details\\\");\\n        assertThat(result.getErrorOutput()).isEqualTo(\\\"warning\\\\ndetails\\\");\\n        assertThat(result.exitCode()).isEqualTo(7);\\n    }\\n\\n    @Test\\n    void quarkusMainLauncherCanReturnArgumentSensitiveLaunchResults() {\\n        QuarkusMainLauncher launcher = args -> new CapturedLaunchResult(\\n                List.of(\\\"args=\\\" + String.join(\\\",\\\", args)),\\n                List.of(),\\n                args.length);\\n\\n        LaunchResult noArguments = launcher.launch();\\n        LaunchResult twoArguments = launcher.launch(\\\"--name\\\", \\\"quarkus\\\");\\n\\n        assertThat(noArguments.getOutput()).isEqualTo(\\\"args=\\\");\\n        assertThat(noArguments.exitCode()).isZero();\\n        assertThat(twoArguments.getOutput()).isEqualTo(\\\"args=--name,quarkus\\\");\\n        assertThat(twoArguments.exitCode()).isEqualTo(2);\\n    }\\n\\n    @Test\\n    void artifactTypeUtilitiesAndLauncherProvidersAgreeOnSupportedArtifacts() {\\n        assertThat(ArtifactTypeUtil.isJar(\\\"jar\\\")).isTrue();\\n        assertThat(ArtifactTypeUtil.isJar(\\\"native\\\")).isFalse();\\n        assertThat(ArtifactTypeUtil.isNativeBinary(\\\"native\\\")).isTrue();\\n        assertThat(ArtifactTypeUtil.isNativeBinary(\\\"jar\\\")).isFalse();\\n        assertThat(ArtifactTypeUtil.isContainer(\\\"jar-container\\\")).isTrue();\\n        assertThat(ArtifactTypeUtil.isContainer(\\\"native-container\\\")).isTrue();\\n        assertThat(ArtifactTypeUtil.isContainer(\\\"native\\\")).isFalse();\\n\\n        JarLauncherProvider jarProvider = new JarLauncherProvider();\\n        NativeImageLauncherProvider nativeProvider = new NativeImageLauncherProvider();\\n        DockerContainerLauncherProvider dockerProvider = new DockerContainerLauncherProvider();\\n\\n        assertThat(jarProvider.supportsArtifactType(\\\"jar\\\", null)).isTrue();\\n        assertThat(jarProvider.supportsArtifactType(\\\"native\\\", null)).isFalse();\\n        assertThat(nativeProvider.supportsArtifactType(\\\"native\\\", null)).isTrue();\\n        assertThat(nativeProvider.supportsArtifactType(\\\"jar\\\", null)).isFalse();\\n        assertThat(dockerProvider.supportsArtifactType(\\\"jar-container\\\", null)).isTrue();\\n        assertThat(dockerProvider.supportsArtifactType(\\\"native-container\\\", null)).isTrue();\\n        assertThat(dockerProvider.supportsArtifactType(\\\"jar\\\", \\\"test-with-native-agent\\\")).isTrue();\\n        assertThat(dockerProvider.supportsArtifactType(\\\"jar\\\", \\\"default\\\")).isFalse();\\n    }\\n\\n    @Test\\n    void mockOptionsExposeFluentObserverMockingConfiguration() {\\n        QuarkusMock.Options options = new QuarkusMock.Options();\\n\\n        assertThat(options.isMockObservers()).isFalse();\\n        assertThat(options.setMockObservers(true)).isSameAs(options);\\n        assertThat(options.isMockObservers()).isTrue();\\n        assertThat(options.setMockObservers(false)).isSameAs(options);\\n        assertThat(options.isMockObservers()).isFalse();\\n    }\\n\\n    @Test\\n    void graalVmVersionEnumExposesUnderlyingRuntimeVersion() {\\n        assertThat(GraalVMVersion.GRAALVM_24_2_0.getVersion()).isNotNull();\\n        assertThat(GraalVMVersion.GRAALVM_24_2_0.getVersion().getVersionAsString()).isNotBlank();\\n        assertThat(GraalVMVersion.GRAALVM_24_2_0.toString())\\n                .startsWith(\\\"GraalVMVersion{\\\")\\n                .contains(\\\"version=\\\");\\n    }\\n\\n    @Test\\n    void disabledOnIntegrationTestArtifactTypesCoverAllSupportedProductionArtifacts() {\\n        assertThat(Arrays.asList(DisabledOnIntegrationTest.ArtifactType.values()))\\n                .containsExactly(\\n                        DisabledOnIntegrationTest.ArtifactType.ALL,\\n                        DisabledOnIntegrationTest.ArtifactType.JAR,\\n                        DisabledOnIntegrationTest.ArtifactType.CONTAINER,\\n                        DisabledOnIntegrationTest.ArtifactType.NATIVE_BINARY);\\n    }\\n\\n    private static final class CustomProfile implements QuarkusTestProfile {\\n        @Override\\n        public Map<String, String> getConfigOverrides() {\\n            Map<String, String> overrides = new LinkedHashMap<>();\\n            overrides.put(\\\"quarkus.http.test-port\\\", \\\"0\\\");\\n            overrides.put(\\\"feature.enabled\\\", \\\"true\\\");\\n            return overrides;\\n        }\\n\\n        @Override\\n        public Set<Class<?>> getEnabledAlternatives() {\\n            return Set.of(String.class);\\n        }\\n\\n        @Override\\n        public String getConfigProfile() {\\n            return \\\"integration\\\";\\n        }\\n\\n        @Override\\n        public List<TestResourceEntry> testResources() {\\n            return List.of(new TestResourceEntry(RecordingResource.class, Map.of(\\\"name\\\", \\\"primary\\\"), true));\\n        }\\n\\n        @Override\\n        public boolean disableGlobalTestResources() {\\n            return true;\\n        }\\n\\n        @Override\\n        public Set<String> tags() {\\n            return Set.of(\\\"smoke\\\", \\\"fast\\\");\\n        }\\n\\n        @Override\\n        public String[] commandLineParameters() {\\n            return new String[] { \\\"--verbose\\\", \\\"input.txt\\\" };\\n        }\\n\\n        @Override\\n        public