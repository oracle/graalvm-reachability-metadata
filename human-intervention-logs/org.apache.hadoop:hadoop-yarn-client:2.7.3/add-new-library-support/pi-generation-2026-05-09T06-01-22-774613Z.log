kenCacheWithoutResourceManager() {\n        AMRMClient<AMRMClient.ContainerRequest> client = AMRMClient.createAMRMClient();\n        try {\n            client.init(newConfiguration());\n            NMTokenCache tokenCache = new NMTokenCache();\n            client.setNMTokenCache(tokenCache);\n\n            Resource capability = Resource.newInstance(MEMORY_MB, VIRTUAL_CORES);\n            Priority priority = Priority.newInstance(3);\n            AMRMClient.ContainerRequest request = new AMRMClient.ContainerRequest(capability, null, null, priority);\n\n            client.addContainerRequest(request);\n            List<? extends Collection<AMRMClient.ContainerRequest>> matchingRequests =\n                    client.getMatchingRequests(priority, ResourceRequest.ANY, capability);\n\n            assertThat(client.getNMTokenCache()).isSameAs(tokenCache);\n            assertThat(matchingRequests).isNotEmpty();\n            assertThat(matchingRequests).anySatisfy(requests -> assertThat(requests).contains(request));\n\n            client.updateBlacklist(Collections.singletonList(\"bad-node.example.test\"), Collections.emptyList());\n            client.releaseAssignedContainer(ContainerId.newContainerId(\n                    ApplicationAttemptId.newInstance(ApplicationId.newInstance(1234L, 1), 1),\n                    1L));\n            client.removeContainerRequest(request);\n\n            assertThat(client.getMatchingRequests(priority, ResourceRequest.ANY, capability))\n                    .allSatisfy(requests -> assertThat(requests).doesNotContain(request));\n        } finally {\n            stopQuietly(client);\n        }\n    }\n", "newText": "    void amrmClientTracksContainerRequestsAndTokenCacheWithoutResourceManager() {\n        AMRMClient<AMRMClient.ContainerRequest> client = AMRMClient.createAMRMClient();\n        NMTokenCache tokenCache = new NMTokenCache();\n        client.setNMTokenCache(tokenCache);\n\n        Resource capability = Resource.newInstance(MEMORY_MB, VIRTUAL_CORES);\n        Priority priority = Priority.newInstance(3);\n        AMRMClient.ContainerRequest request = new AMRMClient.ContainerRequest(capability, null, null, priority);\n\n        client.addContainerRequest(request);\n        List<? extends Collection<AMRMClient.ContainerRequest>> matchingRequests =\n                client.getMatchingRequests(priority, ResourceRequest.ANY, capability);\n\n        assertThat(client.getNMTokenCache()).isSameAs(tokenCache);\n        assertThat(matchingRequests).isNotEmpty();\n        assertThat(matchingRequests).anySatisfy(requests -> assertThat(requests).contains(request));\n\n        client.updateBlacklist(Collections.singletonList(\"bad-node.example.test\"), Collections.emptyList());\n        client.releaseAssignedContainer(ContainerId.newContainerId(\n                ApplicationAttemptId.newInstance(ApplicationId.newInstance(1234L, 1), 1),\n                1L));\n        client.removeContainerRequest(request);\n\n        assertThat(client.getMatchingRequests(priority, ResourceRequest.ANY, capability))\n                .allSatisfy(requests -> assertThat(requests).doesNotContain(request));\n    }\n"}, {"oldText": "    @Test\n    void clientFactoriesCreateInitializableServiceImplementations() {\n        YarnConfiguration configuration = newConfiguration();\n        YarnClient yarnClient = YarnClient.createYarnClient();\n        AHSClient ahsClient = AHSClient.createAHSClient();\n        NMClient nmClient = NMClient.createNMClient(\"test-nm-client\");\n        SharedCacheClient sharedCacheClient = SharedCacheClient.createSharedCacheClient();\n        AMRMClient<AMRMClient.ContainerRequest> amrmClient = AMRMClient.createAMRMClient();\n        try {\n            yarnClient.init(configuration);\n            ahsClient.init(configuration);\n            nmClient.init(configuration);\n            sharedCacheClient.init(configuration);\n            amrmClient.init(configuration);\n\n            NMTokenCache cache = new NMTokenCache();\n            nmClient.setNMTokenCache(cache);\n            nmClient.cleanupRunningContainersOnStop(false);\n\n            assertThat(yarnClient.getServiceState()).isEqualTo(Service.STATE.INITED);\n            assertThat(ahsClient.getServiceState()).isEqualTo(Service.STATE.INITED);\n            assertThat(nmClient.getName()).isEqualTo(\"test-nm-client\");\n            assertThat(nmClient.getNMTokenCache()).isSameAs(cache);\n            assertThat(sharedCacheClient.getServiceState()).isEqualTo(Service.STATE.INITED);\n            assertThat(amrmClient.getServiceState()).isEqualTo(Service.STATE.INITED);\n        } finally {\n            stopQuietly(amrmClient);\n            stopQuietly(sharedCacheClient);\n            stopQuietly(nmClient);\n            stopQuietly(ahsClient);\n            stopQuietly(yarnClient);\n        }\n    }\n\n", "newText": "    @Test\n    void nmClientFactoryExposesTokenCacheWithoutStartingNetworkServices() {\n        NMClient nmClient = NMClient.createNMClient(\"test-nm-client\");\n        NMTokenCache cache = new NMTokenCache();\n\n        nmClient.setNMTokenCache(cache);\n        nmClient.cleanupRunningContainersOnStop(false);\n\n        assertThat(nmClient.getNMTokenCache()).isSameAs(cache);\n    }\n\n"}, {"oldText": "    void asyncClientsExposeCallbacksAndDelegateLocalState() {\n        AMRMClientAsync.CallbackHandler amrmHandler = new RecordingAMRMCallbackHandler();\n        AMRMClientAsync<AMRMClient.ContainerRequest> amrmClient = AMRMClientAsync.createAMRMClientAsync(25, amrmHandler);\n        RecordingNMCallbackHandler nmHandler = new RecordingNMCallbackHandler();\n        NMClientAsync nmClient = NMClientAsync.createNMClientAsync(nmHandler);\n        NMClient delegate = NMClient.createNMClient(\"delegate-nm-client\");\n        try {\n            amrmClient.init(newConfiguration());\n            amrmClient.setHeartbeatInterval(10);\n            nmClient.init(newConfiguration());\n            delegate.init(newConfiguration());\n            nmClient.setClient(delegate);\n\n            Resource capability = Resource.newInstance(MEMORY_MB, VIRTUAL_CORES);\n            Priority priority = Priority.newInstance(5);\n            AMRMClient.ContainerRequest request = new AMRMClient.ContainerRequest(capability, null, null, priority);\n            amrmClient.addContainerRequest(request);\n\n            assertThat(amrmClient.getMatchingRequests(priority, ResourceRequest.ANY, capability))\n                    .anySatisfy(requests -> assertThat(requests).contains(request));\n            assertThat(nmClient.getCallbackHandler()).isSameAs(nmHandler);\n            assertThat(nmClient.getClient()).isSameAs(delegate);\n        } finally {\n            stopQuietly(nmClient);\n            stopQuietly(delegate);\n            stopQuietly(amrmClient);\n        }\n    }\n", "newText": "    void asyncClientsExposeCallbacksAndDelegateLocalState() {\n        AMRMClientAsync.CallbackHandler amrmHandler = new RecordingAMRMCallbackHandler();\n        AMRMClientAsync<AMRMClient.ContainerRequest> amrmClient = AMRMClientAsync.createAMRMClientAsync(25, amrmHandler);\n        RecordingNMCallbackHandler nmHandler = new RecordingNMCallbackHandler();\n        NMClientAsync nmClient = NMClientAsync.createNMClientAsync(nmHandler);\n        NMClient delegate = NMClient.createNMClient(\"delegate-nm-client\");\n\n        amrmClient.setHeartbeatInterval(10);\n        nmClient.setClient(delegate);\n\n        Resource capability = Resource.newInstance(MEMORY_MB, VIRTUAL_CORES);\n        Priority priority = Priority.newInstance(5);\n        AMRMClient.ContainerRequest request = new AMRMClient.ContainerRequest(capability, null, null, priority);\n        amrmClient.addContainerRequest(request);\n\n        assertThat(amrmClient.getMatchingRequests(priority, ResourceRequest.ANY, capability))\n                .anySatisfy(requests -> assertThat(requests).contains(request));\n        assertThat(nmClient.getCallbackHandler()).isSameAs(nmHandler);\n        assertThat(nmClient.getClient()).isSameAs(delegate);\n    }\n"}, {"oldText": "    private static YarnConfiguration newConfiguration() {\n        YarnConfiguration configuration = new YarnConfiguration();\n        configuration.setLong(YarnConfiguration.RESOURCEMANAGER_CONNECT_MAX_WAIT_MS, 500L);\n        configuration.setLong(YarnConfiguration.RESOURCEMANAGER_CONNECT_RETRY_INTERVAL_MS, 100L);\n        return configuration;\n    }\n\n    private static void stopQuietly(Service service) {\n        if (service != null && service.getServiceState() != Service.STATE.STOPPED) {\n            service.stop();\n        }\n    }\n\n", "newText": ""}]}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 3957, "output": 3301, "cacheRead": 79872, "cacheWrite": 0, "totalTokens": 87130, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778306608546, "responseId": "resp_070345f6deca852e0169fece3196a08195b28d7c29f22dd8e2"}}
