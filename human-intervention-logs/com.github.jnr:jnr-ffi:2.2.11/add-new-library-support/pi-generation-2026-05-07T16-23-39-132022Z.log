  /*
   * Copyright and related rights waived via CC0
   *
   * You should have received a copy of the CC0 legalcode along with this
   * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.
   */
  package com_github_jnr.jnr_ffi;
  
  import java.io.PrintWriter;
  import java.io.StringWriter;
  import java.lang.invoke.MethodHandle;
  import java.lang.invoke.MethodHandles;
  import java.lang.invoke.MethodType;
  
  import jnr.ffi.LibraryLoader;
  import jnr.ffi.mapper.FromNativeContext;
  import jnr.ffi.mapper.FromNativeConverter;
  import jnr.ffi.mapper.ToNativeContext;
  import jnr.ffi.mapper.ToNativeConverter;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  import org.objectweb.asm.ClassVisitor;
  import org.objectweb.asm.ClassWriter;
  
  import static org.junit.jupiter.api.Assertions.assertEquals;
  import static org.junit.jupiter.api.Assertions.assertNotSame;
  
  public class AsmUtilTest {
      @Test
      void traceClassVisitorOverloadWrapsAnExistingVisitor() throws Throwable {
          Class<?> asmUtilType = Class.forName("jnr.ffi.provider.jffi.AsmUtil");
          MethodHandle newTraceClassVisitor = MethodHandles.privateLookupIn(asmUtilType, MethodHandles.lookup())
                  .findStatic(asmUtilType, "newTraceClassVisitor",
                          MethodType.methodType(ClassVisitor.class, ClassVisitor.class, PrintWriter.class));
  
          ClassVisitor delegate = new ClassWriter(0);
          ClassVisitor traced = (ClassVisitor) newTraceClassVisitor.invoke(delegate, new PrintWriter(new StringWriter()));
  
          assertNotSame(delegate, traced);
      }
  
      @Test
      void generatedAsmDiscoversPublicConverterMethodsAndDebugVisitors() {
          String originalDumpProperty = System.getProperty("jnr.ffi.compile.dump");
          System.setProperty("jnr.ffi.compile.dump", "true");
          try {
              try {
                  LibraryLoader<CLibrary> loader = LibraryLoader.create(CLibrary.class)
                          .map(SpecializedInteger.class, new SpecializedToNativeConverter())
                          .map(RawInteger.class, new RawToNativeConverter())
                          .map(SpecializedLength.class, new SpecializedFromNativeConverter());
                  loader.map(RawLength.class, (FromNativeConverter) new RawFromNativeConverter());
                  CLibrary library = loader
                          .map("rawAbs", "abs")
                          .map("rawStrlen", "strlen")
                          .load("c");
  
                  assertEquals(7, library.abs(new SpecializedInteger(-7)));
                  assertEquals(5, library.rawAbs(new RawInteger(-5)));
                  assertEquals(5L, library.strlen("hello").value);
                  assertEquals(6L, library.rawStrlen("native").value);
              } catch (RuntimeException exception) {
                  if (!hasUnsupportedFeatureErrorCause(exception)) {
                      throw exception;
                  }
              } catch (Error error) {
                  if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                      throw error;
                  }
              }
          } finally {
              if (originalDumpProperty == null) {
                  System.clearProperty("jnr.ffi.compile.dump");
              } else {
                  System.setProperty("jnr.ffi.compile.dump", originalDumpProperty);
              }
          }
      }
  
      private static boolean hasUnsupportedFeatureErrorCause(Throwable throwable) {
          Throwable current = throwable;
          while (current != null) {
              if (current instanceof Error error && NativeImageSupport.isUnsupportedFeatureError(error)) {
                  return true;
              }
              current = current.getCause();
          }
          return false;
      }
  
      public interface CLibrary {
          int abs(SpecializedInteger value);
  
          int rawAbs(RawInteger value);
  
          SpecializedLength strlen(String value);
  
          RawLength rawStrlen(String value);
      }
  
      public static final class SpecializedInteger {
          private final int value;
  
          private SpecializedInteger(int value) {
              this.value = value;
          }
      }
  
      public static final class RawInteger {
          private final int value;
  
          private RawInteger(int value) {
              this.value = value;
          }
      }
  
      public static final class SpecializedLength {
          private final long value;
  
          private SpecializedLength(long value) {
              this.value = value;
          }
      }
  
      public static final class RawLength {
          private final long value;
  
          private RawLength(long value) {
              this.value = value;
          }
      }
  
      public static final class SpecializedToNativeConverter implements ToNativeConverter<SpecializedInteger, Integer> {
          @Override
          public Integer toNative(SpecializedInteger value, ToNativeContext context) {
              return value.value;
          }
  
          @Override
          public Class<Integer> nativeType() {
              return Integer.class;
          }
      }
  
      public static final class RawToNativeConverter implements ToNativeConverter<RawInteger, Object> {
          @Override
          public Object toNative(RawInteger value, ToNativeContext context) {
              return value.value;
          }
  
          @Override
          @SuppressWarnings("unchecked")
          public Class<Object> nativeType() {
              return (Class<Object>) (Class<?>) Integer.class;
          }
      }
  
      public static final class SpecializedFromNativeConverter implements FromNativeConverter<SpecializedLength, Long> {
          @Override
          public SpecializedLength fromNative(Long nativeValue, FromNativeContext context) {
              return new SpecializedLength(nativeValue);
          }
  
          @Override
          public Class<Long> nativeType() {
              return Long.class;
          }
      }
  
      public static final class RawFromNativeConverter implements FromNativeConverter<Object, Object> {
          @Override
          public Object fromNative(Object nativeValue, FromNativeContext context) {
              return new RawLength(((Number) nativeValue).longValue());
          }
  
          @Override
          @SuppressWarnings("unchecked")
          public Class<Object> nativeType() {
              return (Class<Object>) (Class<?>) Long.class;
          }
      }
  }
