[tool-call] delta {"path":"tests/src/com.github.jnr/jnr-ffi/2.2.11/src/test/java/com_github_jnr/jnr_ffi/StructTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_github_jnr.jnr_ffi;\n\nimport jnr.ffi.Runtime;\nimport jnr.ffi.Struct;\nimport org.junit.jupiter.api.Test;\n\nimport static org.junit.jupiter.api.Assertions.assertEquals;\nimport static org.junit.jupiter.api.Assertions.assertFalse;\nimport static org.junit.jupiter.api.Assertions.assertNotSame;\nimport static org.junit.jupiter.api.Assertions.assertTrue;\n\npublic class StructTest {\n    @Test\n    void arrayOfCreatesStructInstancesBackedByContiguousNativeMemory() {\n        Runtime runtime = Runtime.getSystemRuntime();\n\n        ArrayElementStruct[] elements = Struct.arrayOf(runtime, ArrayElementStruct.class, 2);\n        elements[0].value.set(17);\n        elements[1].value.set(42);\n\n        assertEquals(2, elements.length);\n        assertNotSame(elements[0], elements[1]);\n        assertEquals(17, elements[0].value.get());\n        assertEquals(42, elements[1].value.get());\n    }\n\n    @Test\n    void protectedArrayCreatesNestedStructInstances() {\n        Runtime runtime = Runtime.getSystemRuntime();\n\n        StructArrayContainer container = new StructArrayContainer(runtime);\n        container.children[0].value.set(3);\n        container.children[1].value.set(5);\n\n        assertEquals(2, container.children.length);\n        assertNotSame(container.children[0], container.children[1]);\n        assertEquals(3, container.children[0].value.get());\n        assertEquals(5, container.children[1].value.get());\n    }\n\n    @Test\n    void protectedArrayCreatesMemberInstances() {\n        Runtime runtime = Runtime.getSystemRuntime();\n\n        MemberArrayStruct struct = new MemberArrayStruct(runtime);\n        struct.flags[0].set(true);\n\n        assertEquals(3, struct.flags.length);\n        assertTrue(struct.flags[0].get());\n        assertFalse(struct.flags[1].get());\n    }\n\n    @Test\n    void toStringIncludesDeclaredFieldValuesAndNullFields() {\n        Runtime runtime = Runtime.getSystemRuntime();\n        ToStringStruct struct = new ToStringStruct(runtime);\n        struct.value.set(99);\n\n        String description = struct.toString();\n\n        assertTrue(description.contains(\"ToStringStruct\"));\n        assertTrue(description.contains(\"value = 99\"));\n        assertTrue(description.contains(\"missing = - null -\"));\n    }\n\n    public static final class ArrayElementStruct extends Struct {\n        public final Signed32 value = new Signed32();\n\n        public ArrayElementStruct(Runtime runtime) {\n            super(runtime);\n        }\n    }\n\n    public static final class StructArrayContainer extends Struct {\n        public final ChildStruct[] children = array(new ChildStruct[2]);\n\n        public StructArrayContainer(Runtime runtime) {\n            super(runtime);\n        }\n    }\n\n    public static final class ChildStruct extends Struct {\n        public final Signed32 value = new Signed32();\n\n        public ChildStruct(Runtime runtime) {\n            super(runtime);\n        }\n    }\n\n    public static final class MemberArrayStruct extends Struct {\n        public final Struct.Boolean[] flags = array(new Struct.Boolean[3]);\n\n        public MemberArrayStruct(Runtime runtime) {\n            super(runtime);\n        }\n    }\n\n    public static final class ToStringStruct extends Struct {\n        public final Signed32 value = new Signed32();\n        public final Object missing = null;\n\n        public ToStringStruct(Runtime runtime) {\n            super(runtime);\n        }\n    }\n}\n"}
[tool-call] end id=call_GUon7lQdIG8uTYIPSdNC2Fh0|fc_0d1fbd5ac3449b980169fcbc65f38081a3a81c07ace5b5cb78 name=write args={"path": "tests/src/com.github.jnr/jnr-ffi/2.2.11/src/test/java/com_github_jnr/jnr_ffi/StructTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_github_jnr.jnr_ffi;\n\nimport jnr.ffi.Runtime;\nimport jnr.ffi.Struct;\nimport org.junit.jupiter.api.Test;\n\nimport static org.junit.jupiter.api.Assertions.assertEquals;\nimport static org.junit.jupiter.api.Assertions.assertFalse;\nimport static org.junit.jupiter.api.Assertions.assertNotSame;\nimport static org.junit.jupiter.api.Assertions.assertTrue;\n\npublic class StructTest {\n    @Test\n    void arrayOfCreatesStructInstancesBackedByContiguousNativeMemory() {\n        Runtime runtime = Runtime.getSystemRuntime();\n\n        ArrayElementStruct[] elements = Struct.arrayOf(runtime, ArrayElementStruct.class, 2);\n        elements[0].value.set(17);\n        elements[1].value.set(42);\n\n        assertEquals(2, elements.length);\n        assertNotSame(elements[0], elements[1]);\n        assertEquals(17, elements[0].value.get());\n        assertEquals(42, elements[1].value.get());\n    }\n\n    @Test\n    void protectedArrayCreatesNestedStructInstances() {\n        Runtime runtime = Runtime.getSystemRuntime();\n\n        StructArrayContainer container = new StructArrayContainer(runtime);\n        container.children[0].value.set(3);\n        container.children[1].value.set(5);\n\n        assertEquals(2, container.children.length);\n        assertNotSame(container.children[0], container.children[1]);\n        assertEquals(3, container.children[0].value.get());\n        assertEquals(5, container.children[1].value.get());\n    }\n\n    @Test\n    void protectedArrayCreatesMemberInstances() {\n        Runtime runtime = Runtime.getSystemRuntime();\n\n        MemberArrayStruct struct = new MemberArrayStruct(runtime);\n        struct.flags[0].set(true);\n\n        assertEquals(3, struct.flags.length);\n        assertTrue(struct.flags[0].get());\n        assertFalse(struct.flags[1].get());\n    }\n\n    @Test\n    void toStringIncludesDeclaredFieldValuesAndNullFields() {\n        Runtime runtime = Runtime.getSystemRuntime();\n        ToStringStruct struct = new ToStringStruct(runtime);\n        struct.value.set(99);\n\n        String description = struct.toString();\n\n        assertTrue(description.contains(\"ToStringStruct\"));\n        assertTrue(description.contains(\"value = 99\"));\n        assertTrue(description.contains(\"missing = - null -\"));\n    }\n\n    public static final class ArrayElementStruct extends Struct {\n        public final Signed32 value = new Signed32();\n\n        public ArrayElementStruct(Runtime runtime) {\n            super(runtime);\n        }\n    }\n\n    public static final class StructArrayContainer extends Struct {\n        public final ChildStruct[] children = array(new ChildStruct[2]);\n\n        public StructArrayContainer(Runtime runtime) {\n            super(runtime);\n        }\n    }\n\n    public static final class ChildStruct extends Struct {\n        public final Signed32 value = new Signed32();\n\n        public ChildStruct(Runtime runtime) {\n            super(runtime);\n        }\n    }\n\n    public static final class MemberArrayStruct extends Struct {\n        public final Struct.Boolean[] flags = array(new Struct.Boolean[3]);\n\n        public MemberArrayStruct(Runtime runtime) {\n            super(runtime);\n        }\n    }\n\n    public static final class ToStringStruct extends Struct {\n        public final Signed32 value = new Signed32();\n        public final Object missing = null;\n\n        public ToStringStruct(Runtime runtime) {\n            super(runtime);\n        }\n    }\n}\n"}
