[tool-call] delta {"path":"tests/src/com.github.jnr/jnr-ffi/2.2.11/src/test/java/com_github_jnr/jnr_ffi/StructInnerStructRefTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_github_jnr.jnr_ffi;\n\nimport jnr.ffi.Runtime;\nimport jnr.ffi.Struct;\nimport org.junit.jupiter.api.Test;\n\nimport static org.junit.jupiter.api.Assertions.assertEquals;\n\npublic class StructInnerStructRefTest {\n    @Test\n    void structReferenceReturnsSingleStructFromExplicitOffset() {\n        Runtime runtime = Runtime.getSystemRuntime();\n        ReferencedStruct expected = new ReferencedStruct(runtime);\n        expected.value.set(1234);\n\n        ExplicitOffsetContainer container = new ExplicitOffsetContainer(runtime);\n        container.reference.set(expected);\n\n        ReferencedStruct actual = container.reference.get();\n\n        assertEquals(1234, actual.value.get());\n    }\n\n    @Test\n    void structReferenceReturnsStructArrayFromContiguousMemory() {\n        Runtime runtime = Runtime.getSystemRuntime();\n        ReferencedStruct first = new ReferencedStruct(runtime);\n        first.value.set(17);\n        ReferencedStruct second = new ReferencedStruct(runtime);\n        second.value.set(42);\n\n        DefaultContainer container = new DefaultContainer(runtime);\n        container.reference.set(new ReferencedStruct[] { first, second });\n\n        ReferencedStruct[] actual = container.reference.get(2);\n\n        assertEquals(2, actual.length);\n        assertEquals(17, actual[0].value.get());\n        assertEquals(42, actual[1].value.get());\n    }\n\n    public static final class ReferencedStruct extends Struct {\n        public final Signed32 value = new Signed32();\n\n        public ReferencedStruct(Runtime runtime) {\n            super(runtime);\n        }\n    }\n\n    public static final class DefaultContainer extends Struct {\n        public final StructRef<ReferencedStruct> reference = new StructRef<>(ReferencedStruct.class);\n\n        public DefaultContainer(Runtime runtime) {\n            super(runtime);\n        }\n    }\n\n    public static final class ExplicitOffsetContainer extends Struct {\n        public final StructRef<ReferencedStruct> reference = new StructRef<>(new Offset(0), ReferencedStruct.class);\n\n        public ExplicitOffsetContainer(Runtime runtime) {\n            super(runtime);\n        }\n    }\n}\n"}
