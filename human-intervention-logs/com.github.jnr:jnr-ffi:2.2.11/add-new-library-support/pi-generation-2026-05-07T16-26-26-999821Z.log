  package com_github_jnr.jnr_ffi;
  
  import jnr.ffi.Runtime;
  import jnr.ffi.Struct;
  import org.junit.jupiter.api.Test;
  
  import static org.junit.jupiter.api.Assertions.assertEquals;
  import static org.junit.jupiter.api.Assertions.assertFalse;
  import static org.junit.jupiter.api.Assertions.assertNotSame;
  import static org.junit.jupiter.api.Assertions.assertTrue;
  
  public class StructTest {
      @Test
      void arrayOfCreatesStructInstancesBackedByContiguousNativeMemory() {
          Runtime runtime = Runtime.getSystemRuntime();
  
          ArrayElementStruct[] elements = Struct.arrayOf(runtime, ArrayElementStruct.class, 2);
          elements[0].value.set(17);
          elements[1].value.set(42);
  
          assertEquals(2, elements.length);
          assertNotSame(elements[0], elements[1]);
          assertEquals(17, elements[0].value.get());
          assertEquals(42, elements[1].value.get());
      }
  
      @Test
      void protectedArrayCreatesNestedStructInstances() {
          Runtime runtime = Runtime.getSystemRuntime();
  
          StructArrayContainer container = new StructArrayContainer(runtime);
          container.children[0].value.set(3);
          container.children[1].value.set(5);
  
          assertEquals(2, container.children.length);
          assertNotSame(container.children[0], container.children[1]);
          assertEquals(3, container.children[0].value.get());
          assertEquals(5, container.children[1].value.get());
      }
  
      @Test
      void protectedArrayCreatesMemberInstances() {
          Runtime runtime = Runtime.getSystemRuntime();
  
          MemberArrayStruct struct = new MemberArrayStruct(runtime);
          struct.flags[0].set(true);
          struct.flags[1].set(false);
  
          assertEquals(3, struct.flags.length);
          assertTrue(struct.flags[0].get());
          assertFalse(struct.flags[1].get());
      }
  
      @Test
      void toStringIncludesDeclaredFieldValuesAndNullFields() {
          Runtime runtime = Runtime.getSystemRuntime();
          ToStringStruct struct = new ToStringStruct(runtime);
          struct.value.set(99);
  
          String description = struct.toString();
  
          assertTrue(description.contains("ToStringStruct"));
          assertTrue(description.contains("value = 99"));
          assertTrue(description.contains("missing = - null -"));
      }
  
      public static final class ArrayElementStruct extends Struct {
          public final Signed32 value = new Signed32();
  
          public ArrayElementStruct(Runtime runtime) {
              super(runtime);
          }
      }
  
      public static final class StructArrayContainer extends Struct {
          public final ChildStruct[] children = array(new ChildStruct[2]);
  
          public StructArrayContainer(Runtime runtime) {
              super(runtime);
          }
      }
  
      public static final class ChildStruct extends Struct {
          public final Signed32 value = new Signed32();
  
          public ChildStruct(Runtime runtime) {
              super(runtime);
          }
      }
  
      public static final class MemberArrayStruct extends Struct {
          public final Struct.Boolean[] flags = array(new Struct.Boolean[3]);
  
          public MemberArrayStruct(Runtime runtime) {
              super(runtime);
          }
      }
  
      public static final class ToStringStruct extends Struct {
          public final Signed32 value = new Signed32();
          public final Object missing = null;
  
          public ToStringStruct(Runtime runtime) {
              super(runtime);
          }
      }
  }
