layout.fields[0]);\n        assertNotNull(layout.fields[1]);\n        assertSame(layout, layout.fields[0].enclosing());\n        assertSame(layout, layout.fields[1].enclosing());\n        assertEquals(0, layout.fields[0].offset());\n        assertEquals(1, layout.fields[1].offset());\n        assertTrue(layout.size() >= 2);\n    }\n\n    @Test\n    void toStringInspectsDeclaredFieldsOnStructLayoutSubclass() {\n        Runtime runtime = Runtime.getSystemRuntime();\n        LayoutWithNamedFields layout = new LayoutWithNamedFields(runtime);\n\n        String description = layout.toString();\n\n        assertTrue(description.startsWith(\"LayoutWithNamedFields {\"));\n        assertEquals(2, description.lines().filter(\"    \"::equals).count());\n    }\n\n    public static final class LayoutWithFieldArray extends StructLayout {\n        public final ByteField[] fields = array(new ByteField[2]);\n\n        public LayoutWithFieldArray(Runtime runtime) {\n            super(runtime);\n        }\n\n        public final class ByteField extends AbstractField {\n            public ByteField() {\n                super(NativeType.SCHAR);\n            }\n        }\n    }\n\n    public static final class LayoutWithNamedFields extends StructLayout {\n        public final ByteField first = new ByteField();\n        public final ByteField second = new ByteField();\n\n        public LayoutWithNamedFields(Runtime runtime) {\n            super(runtime);\n        }\n\n        public final class ByteField extends AbstractField {\n            public ByteField() {\n                super(NativeType.SCHAR);\n            }\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 456, "output": 730, "cacheRead": 17408, "cacheWrite": 0, "totalTokens": 18594, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778171165456, "responseId": "resp_05cb58a2041706350169fcbd1e819c819