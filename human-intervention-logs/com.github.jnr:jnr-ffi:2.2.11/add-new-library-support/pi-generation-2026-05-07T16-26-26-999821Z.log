  package com_github_jnr.jnr_ffi;
  
  import jnr.ffi.Runtime;
  import jnr.ffi.Struct;
  import org.junit.jupiter.api.Test;
  
  import static org.junit.jupiter.api.Assertions.assertEquals;
  
  public class StructInnerStructRefTest {
      @Test
      void structReferenceReturnsSingleStructFromExplicitOffset() {
          Runtime runtime = Runtime.getSystemRuntime();
          ReferencedStruct expected = new ReferencedStruct(runtime);
          expected.value.set(1234);
  
          ExplicitOffsetContainer container = new ExplicitOffsetContainer(runtime);
          container.reference.set(expected);
  
          ReferencedStruct actual = container.reference.get();
  
          assertEquals(1234, actual.value.get());
      }
  
      @Test
      void structReferenceReturnsStructArrayFromContiguousMemory() {
          Runtime runtime = Runtime.getSystemRuntime();
          ReferencedStruct first = new ReferencedStruct(runtime);
          first.value.set(17);
          ReferencedStruct second = new ReferencedStruct(runtime);
          second.value.set(42);
  
          DefaultContainer container = new DefaultContainer(runtime);
          container.reference.set(new ReferencedStruct[] { first, second });
  
          ReferencedStruct[] actual = container.reference.get(2);
  
          assertEquals(2, actual.length);
          assertEquals(17, actual[0].value.get());
          assertEquals(42, actual[1].value.get());
      }
  
      public static final class ReferencedStruct extends Struct {
          public final Signed32 value = new Signed32();
  
          public ReferencedStruct(Runtime runtime) {
              super(runtime);
          }
      }
  
      public static final class DefaultContainer extends Struct {
          public final StructRef<ReferencedStruct> reference = new StructRef<>(ReferencedStruct.class);
  
          public DefaultContainer(Runtime runtime) {
              super(runtime);
          }
      }
  
      public static final class ExplicitOffsetContainer extends Struct {
          public final StructRef<ReferencedStruct> reference = new StructRef<>(new Offset(0), ReferencedStruct.class);
  
          public ExplicitOffsetContainer(Runtime runtime) {
              super(runtime);
          }
      }
