  package org_osgi.org_osgi_service_log;
  
  import java.io.File;
  import java.io.IOException;
  import java.io.InputStream;
  import java.net.URL;
  import java.security.cert.X509Certificate;
  import java.util.ArrayList;
  import java.util.Collections;
  import java.util.Dictionary;
  import java.util.Enumeration;
  import java.util.Hashtable;
  import java.util.List;
  import java.util.Map;
  
  import org.junit.jupiter.api.Test;
  import org.osgi.framework.Bundle;
  import org.osgi.framework.BundleContext;
  import org.osgi.framework.BundleException;
  import org.osgi.framework.ServiceReference;
  import org.osgi.framework.Version;
  import org.osgi.service.log.LogEntry;
  import org.osgi.service.log.LogListener;
  import org.osgi.service.log.LogReaderService;
  import org.osgi.service.log.LogService;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class Org_osgi_service_logTest {
      @Test
      void logLevelConstantsMatchOsgiSpecification() {
          assertThat(LogService.LOG_ERROR).isEqualTo(1);
          assertThat(LogService.LOG_WARNING).isEqualTo(2);
          assertThat(LogService.LOG_INFO).isEqualTo(3);
          assertThat(LogService.LOG_DEBUG).isEqualTo(4);
          assertThat(List.of(LogService.LOG_ERROR, LogService.LOG_WARNING, LogService.LOG_INFO, LogService.LOG_DEBUG))
                  .containsExactly(1, 2, 3, 4);
      }
  
      @Test
      void logServiceOverloadsPopulateLogEntryAccessors() {
          InMemoryLogService logService = new InMemoryLogService();
          RuntimeException warning = new RuntimeException("configuration warning");
          IllegalStateException custom = new IllegalStateException("custom level failure");
          long start = System.currentTimeMillis();
  
          logService.log(LogService.LOG_INFO, "framework started");
          logService.log(LogService.LOG_WARNING, "using default configuration", warning);
          logService.log(null, LogService.LOG_DEBUG, null);
          logService.log(null, 99, "application-specific level", custom);
  
          long end = System.currentTimeMillis();
          List<LogEntry> entries = logEntries(logService.getLog());
  
          assertThat(entries).hasSize(4);
          assertLogEntry(entries.get(0), 99, "application-specific level", custom, start, end);
          assertLogEntry(entries.get(1), LogService.LOG_DEBUG, null, null, start, end);
          assertLogEntry(entries.get(2), LogService.LOG_WARNING, "using default configuration", warning, start, end);
          assertLogEntry(entries.get(3), LogService.LOG_INFO, "framework started", null, start, end);
      }
  
      @Test
      void serviceReferenceOverloadsAssociateEntriesWithServiceReference() {
          InMemoryLogService logService = new InMemoryLogService();
          ServiceReference<Object> serviceReference = new TestServiceReference();
          IllegalArgumentException exception = new IllegalArgumentException("service failure");
  
          logService.log(serviceReference, LogService.LOG_INFO, "service event");
          logService.log(serviceReference, LogService.LOG_ERROR, "service failed", exception);
  
          List<LogEntry> entries = logEntries(logService.getLog());
  
          assertThat(entries).hasSize(2);
          assertThat(entries).extracting(LogEntry::getServiceReference)
                  .containsExactly(serviceReference, serviceReference);
          assertThat(entries).extracting(LogEntry::getMessage).containsExactly("service failed", "service event");
          assertThat(entries.get(0).getException()).isSameAs(exception);
          assertThat(entries.get(1).getException()).isNull();
      }
  
      @Test
      void logReaderNotifiesListenersByIdentityAndHonorsRemoval() {
          InMemoryLogService logService = new InMemoryLogService();
          RecordingLogListener first = new RecordingLogListener();
          RecordingLogListener second = new RecordingLogListener();
  
          logService.addLogListener(first);
          logService.addLogListener(first);
          logService.log(LogService.LOG_ERROR, "first entry");
  
          logService.addLogListener(second);
          logService.log(LogService.LOG_INFO, "second entry");
  
          logService.removeLogListener(first);
          logService.removeLogListener(first);
          logService.log(LogService.LOG_DEBUG, "third entry");
  
          logService.removeLogListener(second);
          logService.log(LogService.LOG_WARNING, "fourth entry");
  
          assertThat(first.messages()).containsExactly("first entry", "second entry");
          assertThat(second.messages()).containsExactly("second entry", "third entry");
          assertThat(logEntries(logService.getLog()))
                  .extracting(LogEntry::getMessage)
                  .containsExactly("fourth entry", "third entry", "second entry", "first entry");
      }
  
      @Test
      void getLogReturnsSnapshotOfMostRecentEntriesFirst() {
          InMemoryLogService logService = new InMemoryLogService();
  
          logService.log(LogService.LOG_INFO, "one");
          Enumeration<?> snapshot = logService.getLog();
          logService.log(LogService.LOG_INFO, "two");
  
          assertThat(logEntries(snapshot)).extracting(LogEntry::getMessage).containsExactly("one");
          assertThat(logEntries(logService.getLog())).extracting(LogEntry::getMessage).containsExactly("two", "one");
      }
  
      @Test
      void logEntryCanExposeOriginatingBundleToListener() {
          Bundle bundle = new TestBundle(7L, "org.example.producer");
          LogEntry entry = new SimpleLogEntry(bundle, null, LogService.LOG_INFO, "bundle event", null,
                  System.currentTimeMillis());
          RecordingLogListener listener = new RecordingLogListener();
  
          listener.logged(entry);
  
          assertThat(listener.entries()).containsExactly(entry);
          assertThat(listener.entries().get(0).getBundle()).isSameAs(bundle);
          assertThat(listener.entries().get(0).getBundle().getBundleId()).isEqualTo(7L);
          assertThat(listener.entries().get(0).getBundle().getSymbolicName()).isEqualTo("org.example.producer");
          assertThat(listener.entries().get(0).getBundle().getState()).isEqualTo(Bundle.ACTIVE);
      }
  
      private static void assertLogEntry(LogEntry entry, int level, String message, Throwable exception, long start,
              long end) {
          assertThat(entry.getBundle()).isNull();
          assertThat(entry.getServiceReference()).isNull();
          assertThat(entry.getLevel()).isEqualTo(level);
          assertThat(entry.getMessage()).isEqualTo(message);
          assertThat(entry.getException()).isSameAs(exception);
          assertThat(entry.getTime()).isBetween(start, end);
      }
  
      private static List<LogEntry> logEntries(Enumeration<?> enumeration) {
          List<LogEntry> entries = new ArrayList<>();
          while (enumeration.hasMoreElements()) {
              entries.add((LogEntry) enumeration.nextElement());
          }
          return entries;
      }
  
      private static final class InMemoryLogService implements LogService, LogReaderService {
          private final List<LogEntry> entries = new ArrayList<>();
          private final List<LogListener> listeners = new ArrayList<>();
  
          @Override
          public void log(int level, String message) {
              log(null, level, message, null);
          }
  
          @Override
          public void log(int level, String message, Throwable exception) {
              log(null, level, message, exception);
          }
  
          @Override
          public void log(ServiceReference serviceReference, int level, String message) {
              log(serviceReference, level, message, null);
          }
  
          @Override
          public void log(ServiceReference serviceReference, int level, String message, Throwable exception) {
              LogEntry entry = new SimpleLogEntry(null, serviceReference, level, message, exception,
                      System.currentTimeMillis());
              entries.add(0, entry);
              for (LogListener listener : new ArrayList<>(listeners)) {
                  listener.logged(entry);
              }
          }
  
          @Override
          public void addLogListener(LogListener listener) {
              for (LogListener registeredListener : listeners) {
                  if (registeredListener == listener) {
                      return;
                  }
              }
              listeners.add(listener);
          }
  
          @Override
          public void removeLogListener(LogListener listener) {
              listeners.removeIf(registeredListener -> registeredListener == listener);
          }
  
          @Override
          public Enumeration<?> getLog() {
              return Collections.enumeration(new ArrayList<>(entries));
          }
      }
  
      private static final class SimpleLogEntry implements LogEntry {
          private final Bundle bundle;
          private final ServiceReference serviceReference;
          private final int level;
          private final String message;
          private final Throwable exception;
          private final long time;
  
          private SimpleLogEntry(Bundle bundle, ServiceReference serviceReference, int level, String message,
                  Throwable exception, long time) {
              this.bundle = bundle;
              this.serviceReference = serviceReference;
              this.level = level;
              this.message = message;
              this.exception = exception;
              this.time = time;
          }
  
          @Override
          public Bundle getBundle() {
              return bundle;
          }
  
          @Override
          public ServiceReference getServiceReference() {
              return serviceReference;
          }
  
          @Override
          public int getLevel() {
              return level;
          }
  
          @Override
          public String getMessage() {
              return message;
          }
  
          @Override
          public Throwable getException() {
              return exception;
          }
  
          @Override
          public long getTime() {
              return time;
          }
      }
  
