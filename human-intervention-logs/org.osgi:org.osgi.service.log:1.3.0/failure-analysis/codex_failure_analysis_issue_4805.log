PopulateLogEntryAccessors() {\\n        InMemoryLogService logService = new InMemoryLogService();\\n        RuntimeException warning = new RuntimeException(\\\"configuration warning\\\");\\n        IllegalStateException custom = new IllegalStateException(\\\"custom level failure\\\");\\n        long start = System.currentTimeMillis();\\n\\n        logService.log(LogService.LOG_INFO, \\\"framework started\\\");\\n        logService.log(LogService.LOG_WARNING, \\\"using default configuration\\\", warning);\\n        logService.log(null, LogService.LOG_DEBUG, null);\\n        logService.log(null, 99, \\\"application-specific level\\\", custom);\\n\\n        long end = System.currentTimeMillis();\\n        List<LogEntry> entries = logEntries(logService.getLog());\\n\\n        assertThat(entries).hasSize(4);\\n        assertLogEntry(entries.get(0), 99, \\\"application-specific level\\\", custom, start, end);\\n        assertLogEntry(entries.get(1), LogService.LOG_DEBUG, null, null, start, end);\\n        assertLogEntry(entries.get(2), LogService.LOG_WARNING, \\\"using default configuration\\\", warning, start, end);\\n        assertLogEntry(entries.get(3), LogService.LOG_INFO, \\\"framework started\\\", null, start, end);\\n    }\\n\\n    @Test\\n    void serviceReferenceOverloadsAssociateEntriesWithServiceReference() {\\n        InMemoryLogService logService = new InMemoryLogService();\\n        ServiceReference<Object> serviceReference = new TestServiceReference();\\n        IllegalArgumentException exception = new IllegalArgumentException(\\\"service failure\\\");\\n\\n        logService.log(serviceReference, LogService.LOG_INFO, \\\"service event\\\");\\n        logService.log(serviceReference, LogService.LOG_ERROR, \\\"service failed\\\", exception);\\n\\n        List<LogEntry> entries = logEntries(logService.getLog());\\n\\n        assertThat(entries).hasSize(2);\\n        assertThat(entries).extracting(LogEntry::getServiceReference)\\n                .containsExactly(serviceReference, serviceReference);\\n        assertThat(entries).extracting(LogEntry::getMessage).containsExactly(\\\"service failed\\\", \\\"service event\\\");\\n        assertThat(entries.get(0).getException()).isSameAs(exception);\\n        assertThat(entries.get(1).getException()).isNull();\\n    }\\n\\n    @Test\\n    void logReaderNotifiesListenersByIdentityAndHonorsRemoval() {\\n        InMemoryLogService logService = new InMemoryLogService();\\n        RecordingLogListener first = new RecordingLogListener();\\n        RecordingLogListener second = new RecordingLogListener();\\n\\n        logService.addLogListener(first);\\n        logService.addLogListener(first);\\n        logService.log(LogService.LOG_ERROR, \\\"first entry\\\");\\n\\n        logService.addLogListener(second);\\n        logService.log(LogService.LOG_INFO, \\\"second entry\\\");\\n\\n        logService.removeLogListener(first);\\n        logService.removeLogListener(first);\\n        logService.log(LogService.LOG_DEBUG, \\\"third entry\\\");\\n\\n        logService.removeLogListener(second);\\n        logService.log(LogService.LOG_WARNING, \\\"fourth entry\\\");\\n\\n        assertThat(first.messages()).containsExactly(\\\"first entry\\\", \\\"second entry\\\");\\n        assertThat(second.messages()).containsExactly(\\\"second entry\\\", \\\"third entry\\\");\\n        assertThat(logEntries(logService.getLog()))\\n                .extracting(LogEntry::getMessage)\\n                .containsExactly(\\\"fourth entry\\\", \\\"third entry\\\", \\\"second entry\\\", \\\"first entry\\\");\\n    }\\n\\n    @Test\\n    void getLogReturnsSnapshotOfMostRecentEntriesFirst() {\\n        InMemoryLogService logService = new InMemoryLogService();\\n\\n        logService.log(LogService.LOG_INFO, \\\"one\\\");\\n        Enumeration<?> snapshot = logService.getLog();\\n        logService.log(LogService.LOG_INFO, \\\"two\\\");\\n\\n        assertThat(logEntries(snapshot)).extracting(LogEntry::getMessage).containsExactly(\\\"one\\\");\\n        assertThat(logEntries(logService.getLog())).extracting(LogEntry::getMessage).containsExactly(\\\"two\\\", \\\"one\\\");\\n    }\\n\\n    private static void assertLogEntry(LogEntry entry, int level, String message, Throwable exception, long start,\\n            long end) {\\n        assertThat(entry.getBundle()).isNull();\\n        assertThat(entry.getServiceReference()).isNull();\\n        assertThat(entry.getLevel()).isEqualTo(level);\\n        assertThat(entry.getMessage()).isEqualTo(message);\\n        assertThat(entry.getException()).isSameAs(exception);\\n        assertThat(entry.getTime()).isBetween(start, end);\\n    }\\n\\n    private static List<LogEntry> logEntries(Enumeration<?> enumeration) {\\n        List<LogEntry> entries = new ArrayList<>();\\n        while (enumeration.hasMoreElements()) {\\n            entries.add((LogEntry) enumeration.nextElement());\\n        }\\n        return entries;\\n    }\\n\\n    private static final class InMemoryLogService implements LogService, LogReaderService {\\n        private final List<LogEntry> entries = new ArrayList<>();\\n        private final List<LogListener> listeners = new ArrayList<>();\\n\\n        @Override\\n        public void log(int level, String message) {\\n            log(null, level, message, null);\\n        }\\n\\n        @Override\\n        public void log(int level, String message, Throwable exception) {\\n            log(null, level, message, exception);\\n        }\\n\\n        @Override\\n        public void log(ServiceReference serviceReference, int level, String message) {\\n            log(serviceReference, level, message, null);\\n        }\\n\\n        @Override\\n        public void log(ServiceReference serviceReference, int level, String message, Throwable exception) {\\n            LogEntry entry = new SimpleLogEntry(null, serviceReference, level, message, exception,\\n                    System.currentTimeMillis());\\n            entries.add(0, entry);\\n            for (LogListener listener : new ArrayList<>(listeners)) {\\n                listener.logged(entry);\\n            }\\n        }\\n\\n        @Override\\n        public void addLogListener(LogListener listener) {\\n            for (LogListener registeredListener : listeners) {\\n                if (registeredListener == listener) {\\n                    return;\\n                }\\n            }\\n            listeners.add(listener);\\n        }\\n\\n        @Override\\n        public void removeLogListener(LogListener listener) {\\n            listeners.removeIf(registeredListener -> registeredListener == listener);\\n        }\\n\\n        @Override\\n        public Enumeration<?> getLog() {\\n            return Collections.enumeration(new ArrayList<>(entries));\\n        }\\n    }\\n\\n    private static final class SimpleLogEntry implements LogEntry {\\n        private final Bundle bundle;\\n        private final ServiceReference serviceReference;\\n        private final int level;\\n        private final String message;\\n        private final Throwable exception;\\n        private final long time;\\n\\n        private SimpleLogEntry(Bundle bundle, ServiceReference serviceReference, int level, String message,\\n                Throwable exception, long time) {\\n            this.bundle = bundle;\\n            this.serviceReference = serviceReference;\\n            this.level = level;\\n            this.message = message;\\n            this.exception = exception;\\n            this.time = time;\\n        }\\n\\n        @Override\\n        public Bundle getBundle() {\\n            return bundle;\\n        }\\n\\n        @Override\\n        public ServiceReference getServiceReference() {\\n            return serviceReference;\\n        }\\n\\n        @Override\\n        public int getLevel() {\\n            return level;\\n        }\\n\\n        @Override\\n        public String getMessage() {\\n            return message;\\n      