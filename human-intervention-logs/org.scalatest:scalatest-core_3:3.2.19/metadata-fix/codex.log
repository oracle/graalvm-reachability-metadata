   val passed: Boolean = Runner.run(Array(\"-oW\", \"-s\", classOf[RunnerPlainSuite].getName))\n\n    assertThat(passed).isTrue()\n  }\n\n  @Test\n  def instantiatesAnnotatedClassThroughWrapWithSuite(): Unit = {\n    val passed: Boolean = Runner.run(Array(\"-oW\", \"-s\", classOf[RunnerWrappedTarget].getName))\n\n    assertThat(passed).isTrue()\n  }\n\n  @Test\n  def instantiatesJUnitAndTestNGWrapperSuites(): Unit = {\n    val passed: Boolean = Runner.run(\n      Array(\n        \"-oW\",\n        \"-j\",\n        \"example.LegacyJUnitTest\",\n        \"-b\",\n        \"testng-suite.xml\"\n      )\n    )\n\n    assertThat(passed).isTrue()\n  }\n}\n\nclass RunnerPlainSuite extends Suite\n\n@WrapWith(classOf[RunnerClassWrappingSuite])\nclass RunnerWrappedTarget\n\nclass RunnerClassWrappingSuite(wrappedClass: Class[?]) extends Suite {\n  override def suiteName: String = wrappedClass.getName\n}\n}\n\npackage org.scalatestplus.junit {\n\nimport org.scalatest.Suite\n\nclass JUnitWrapperSuite(className: String, loader: ClassLoader) extends Suite {\n  override def suiteName: String = s\"JUnitWrapperSuite($className, ${loader.getClass.getName})\"\n}\n}\n\npackage org.scalatestplus.testng {\n\nimport org.scalatest.Suite\n\nclass TestNGWrapperSuite(suiteFileNames: List[String]) extends Suite {\n  override def suiteName: String = suiteFileNames.mkString(\"TestNGWrapperSuite(\", \",\", \")\")\n}\n}\n\n---FILE---\n/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_scalatest.scalatest_core_3\n\nimport java.nio.file.Files\nimport java.nio.file.Path\nimport java.nio.file.Paths\n\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\nimport org.scalatest.Suite\nimport org.scalatest.WrapWith\nimport org.scalatest.tools.Runner\nimport org_scalatest.scalatest_core_3.discovery.DiscoveryWrappedTarget\n\nclass DiscoverySuiteTest {\n\n  @Test\n  def discoversPlainAndWrappedSuitesFromRunpath(): Unit = {\n    System.clearProperty(DiscoverySuiteTest.PlainInstantiationsProperty)\n    System.clearProperty(DiscoverySuiteTest.WrappedClassNameProperty)\n\n    val passed: Boolean = Runner.run(\n      Array(\n        \"-oW\",\n        \"-R\",\n        testClassesRunpath.toString,\n        \"-w\",\n        \"org_scalatest.scalatest_core_3.discovery\"\n      )\n    )\n\n    assertThat(passed).isTrue()\n    assertThat(System.getProperty(DiscoverySuiteTest.PlainInstantiationsProperty).toInt)\n      .isGreaterThan(0)\n    assertThat(System.getProperty(DiscoverySuiteTest.WrappedClassNameProperty))\n      .isEqualTo(classOf[DiscoveryWrappedTarget].getName)\n  }\n\n  private def testClassesRunpath: Path = {\n    val scalaTestClasses: Path = Paths.get(\"build\", \"classes\", \"scala\", \"test\")\n    if (Files.isDirectory(scalaTestClasses)) {\n      scalaTestClasses.toAbsolutePath\n    } else {\n      Paths.get(classOf[DiscoverySuiteTest].getProtectionDomain.getCodeSource.getLocation.toURI).toAbsolutePath\n    }\n  }\n}\n\nobject DiscoverySuiteTest {\n  val PlainInstantiationsProperty: String =\n    \"org_scalatest.scalatest_core_3.discovery.DiscoveryPlainSuite.instantiations\"\n  val WrappedClassNameProperty: String =\n    \"org_scalatest.scalatest_core_3.discovery.DiscoveryWrappingSuite.wrappedClassName\"\n}\n\npackage discovery {\n\nclass DiscoveryPlainSuite extends Suite {\n  val previousInstantiations: Int =\n    Option(System.getProperty(DiscoverySuiteTest.PlainInstantiationsProperty))\n      .map(_.toInt)\n      .getOrElse(0)\n  System.setProperty(\n    DiscoverySuiteTest.PlainInstantiationsProperty,\n    (previousInstantiations + 1).toString\n  )\n}\n\n@WrapWith(classOf[DiscoveryWrappingSuite])\nclass DiscoveryWrappedTarget\n\nclass DiscoveryWrappingSuite(wrappedClass: Class[?]) extends Suite {\n  System.setProperty(DiscoverySuiteTest.WrappedClassNameProperty, wrappedClass.getName)\n}\n}\n","exit_code":0,"status":"completed"}}
