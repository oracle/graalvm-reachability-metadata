  def locatesMethodForIgnoredSuiteTestName(): Unit = {\n    val suite: SuiteIgnoredTestTarget = new SuiteIgnoredTestTarget()\n    val reporter: SuiteRecordingReporter = new SuiteRecordingReporter()\n\n    val status: Status = suite.run(None, Args(reporter = reporter))\n\n    assertThat(status.isCompleted()).isTrue()\n    assertThat(status.succeeds()).isTrue()\n    assertThat(reporter.events).hasAtLeastOneElementOfType(classOf[TestIgnored])\n    assertThat(SuiteAccess.methodForTestName(suite, \"testIgnoredExample\").getName)\n      .isEqualTo(\"testIgnoredExample\")\n  }\n\n  @Test\n  def discoversYeOldeTestNamesFromPublicSuiteMethods(): Unit = {\n    val names: Set[String] = SuiteAccess.yeOldeTestNames(new SuiteLegacyTestNameTarget())\n\n    assertThat(names.contains(\"testLegacy\")).isTrue()\n    assertThat(names.contains(\"testWithInformer(Informer)\")).isTrue()\n    assertThat(names.contains(\"helperMethod\")).isFalse()\n  }\n}\n\nclass SuiteNoArgConstructorTarget extends Suite\n\nclass SuiteConfigOnlyConstructorTarget(name: String) extends Suite {\n  override def suiteName: String = name\n}\n\nclass SuiteIgnoredTestTarget extends Suite {\n  override def testNames: Set[String] = Set(\"testIgnoredExample\")\n  override def tags: Map[String, Set[String]] = Map(\"testIgnoredExample\" -> Set(classOf[Ignore].getName))\n\n  def testIgnoredExample(): Unit = ()\n}\n\nclass SuiteLegacyTestNameTarget extends Suite {\n  def testLegacy(): Unit = ()\n\n  def testWithInformer(informer: Informer): Unit = {\n    informer(\"legacy informer method\")\n  }\n\n  def helperMethod(): Unit = ()\n}\n\nclass SuiteRecordingReporter extends Reporter {\n  val events: CopyOnWriteArrayList[Event] = new CopyOnWriteArrayList[Event]()\n\n  override def apply(event: Event): Unit = {\n    events.add(event)\n    ()\n  }\n}\n\n---FILE---\n/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_scalatest.scalatest_core_3;\n\nimport java.lang.reflect.Method;\nimport org.scalatest.Suite;\nimport org.scalatest.Suite$;\nimport scala.collection.immutable.Set;\n\nfinal class SuiteAccess {\n    private SuiteAccess() {\n    }\n\n    static boolean hasPublicNoArgConstructor(Class<?> suiteClass) {\n        return Suite$.MODULE$.checkForPublicNoArgConstructor(suiteClass);\n    }\n\n    static Method methodForTestName(Suite suite, String testName) {\n        return Suite$.MODULE$.getMethodForTestName(suite, testName);\n    }\n\n    static Set<String> yeOldeTestNames(Suite suite) {\n        return Suite$.MODULE$.yeOldeTestNames(suite);\n    }\n}\n","exit_code":0,"status":"completed"}}
