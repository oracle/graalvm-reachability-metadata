  package org_scalatest.scalatest_core_3
  
  import org.assertj.core.api.Assertions.assertThat
  import org.junit.jupiter.api.Test
  import org.scalatest.PrivateMethodTester
  
  class PrivateMethodTesterInnerInvokerTest extends PrivateMethodTester {
  
    @Test
    def invokesMatchingPrivateMethodByNameAndArguments(): Unit = {
      val target: PrivateMethodTesterInnerInvokerTarget =
        new PrivateMethodTesterInnerInvokerTarget("open")
      val addRepeatedWord: PrivateMethod[String] = PrivateMethod[String](Symbol("addRepeatedWord"))
  
      val result: String = target invokePrivate addRepeatedWord("sesame", 2)
  
      assertThat(result).isEqualTo("open sesame sesame")
    }
  }
  
  class PrivateMethodTesterInnerInvokerTarget(prefix: String) {
    private def addRepeatedWord(word: String, repetitions: Int): String = {
      (prefix +: List.fill(repetitions)(word)).mkString(" ")
    }
  }
