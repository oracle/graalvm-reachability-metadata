[tool-call] delta {"path":"tests/src/org.scalatest/scalatest-core_3/3.2.19/src/test/scala/org_scalatest/scalatest_core_3/IconEmbellishedListCellRendererInnerIconsTest.scala","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_scalatest.scalatest_core_3\n\nimport java.lang.reflect.Constructor\nimport java.lang.reflect.Method\n\nimport javax.swing.ImageIcon\n\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\n\nclass IconEmbellishedListCellRendererInnerIconsTest {\n\n  @Test\n  def initializesEveryRendererIconResource(): Unit = {\n    val rendererClass: Class[?] = Class.forName(\"org.scalatest.tools.IconEmbellishedListCellRenderer\")\n    val renderer: Object = rendererClass.getConstructor().newInstance().asInstanceOf[Object]\n    val iconsClass: Class[?] = Class.forName(\"org.scalatest.tools.IconEmbellishedListCellRenderer$Icons$\")\n    val iconsConstructor: Constructor[?] = iconsClass.getConstructor(rendererClass)\n    val icons: Object = iconsConstructor.newInstance(renderer).asInstanceOf[Object]\n\n    val iconResources: Map[String, String] = Map(\n      \"testStartingIcon\" -> \"purpledot.gif\",\n      \"testSucceededIcon\" -> \"greendot.gif\",\n      \"testFailedIcon\" -> \"reddot.gif\",\n      \"infoProvidedIcon\" -> \"bluedot.gif\",\n      \"runStartingIcon\" -> \"graydot.gif\",\n      \"suiteStartingIcon\" -> \"cyandot.gif\",\n      \"testIgnoredIcon\" -> \"yellowdot.gif\",\n      \"testStartingSelIcon\" -> \"purpledotsel.gif\",\n      \"testSucceededSelIcon\" -> \"greendotsel.gif\",\n      \"testFailedSelIcon\" -> \"reddotsel.gif\",\n      \"infoProvidedSelIcon\" -> \"bluedotsel.gif\",\n      \"runStartingSelIcon\" -> \"graydotsel.gif\",\n      \"suiteStartingSelIcon\" -> \"cyandotsel.gif\",\n      \"testIgnoredSelIcon\" -> \"yellowdotsel.gif\"\n    )\n\n    iconResources.foreach { case (methodName: String, resourceName: String) =>\n      val method: Method = iconsClass.getMethod(methodName)\n      val icon: ImageIcon = method.invoke(icons).asInstanceOf[ImageIcon]\n\n      assertThat(icon.getDescription()).endsWith(s\"images/$resourceName\")\n      assertThat(icon.getIconWidth()).isGreaterThan(0)\n      assertThat(icon.getIconHeight()).isGreaterThan(0)\n    }\n  }\n}\n"}
[tool-call] end id=call_kSm9CKcuAHHWcCyFJ0qu3WX9|fc_08953fcd1000c0ed0169fa71996428819db94ad9a62db6dee8 name=write args={"path": "tests/src/org.scalatest/scalatest-core_3/3.2.19/src/test/scala/org_scalatest/scalatest_core_3/IconEmbellishedListCellRendererInnerIconsTest.scala", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_scalatest.scalatest_core_3\n\nimport java.lang.reflect.Constructor\nimport java.lang.reflect.Method\n\nimport javax.swing.ImageIcon\n\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\n\nclass IconEmbellishedListCellRendererInnerIconsTest {\n\n  @Test\n  def initializesEveryRendererIconResource(): Unit = {\n    val rendererClass: Class[?] = Class.forName(\"org.scalatest.tools.IconEmbellishedListCellRenderer\")\n    val renderer: Object = rendererClass.getConstructor().newInstance().asInstanceOf[Object]\n    val iconsClass: Class[?] = Class.forName(\"org.scalatest.tools.IconEmbellishedListCellRenderer$Icons$\")\n    val iconsConstructor: Constructor[?] = iconsClass.getConstructor(rendererClass)\n    val icons: Object = iconsConstructor.newInstance(renderer).asInstanceOf[Object]\n\n    val iconResources: Map[String, String] = Map(\n      \"testStartingIcon\" -> \"purpledot.gif\",\n      \"testSucceededIcon\" -> \"greendot.gif\",\n      \"testFailedIcon\" -> \"reddot.gif\",\n      \"infoProvidedIcon\" -> \"bluedot.gif\",\n      \"runStartingIcon\" -> \"graydot.gif\",\n      \"suiteStartingIcon\" -> \"cyandot.gif\",\n      \"testIgnoredIcon\" -> \"yellowdot.gif\",\n      \"testStartingSelIcon\" -> \"purpledotsel.gif\",\n      \"testSucceededSelIcon\" -> \"greendotsel.gif\",\n      \"testFailedSelIcon\" -> \"reddotsel.gif\",\n      \"infoProvidedSelIcon\" -> \"bluedotsel.gif\",\n      \"runStartingSelIcon\" -> \"graydotsel.gif\",\n      \"suiteStartingSelIcon\" -> \"cyandotsel.gif\",\n      \"testIgnoredSelIcon\" -> \"yellowdotsel.gif\"\n    )\n\n    iconResources.foreach { case (methodName: String, resourceName: String) =>\n      val method: Method = iconsClass.getMethod(methodName)\n      val icon: ImageIcon = method.invoke(icons).asInstanceOf[ImageIcon]\n\n      assertThat(icon.getDescription()).endsWith(s\"images/$resourceName\")\n      assertThat(icon.getIconWidth()).isGreaterThan(0)\n      assertThat(icon.getIconHeight()).isGreaterThan(0)\n    }\n  }\n}\n"}
