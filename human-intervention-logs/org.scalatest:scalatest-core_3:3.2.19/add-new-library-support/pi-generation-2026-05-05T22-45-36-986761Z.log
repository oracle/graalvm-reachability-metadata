          println("ScalaTest " + version + " (Built for Scala " + scalaVersion + ")")
          runOptionallyWithPassFailReporter(args.filter(arg => arg != "-v" && arg != "--version"), true)
        }
        else
          runOptionallyWithPassFailReporter(args, true)
  
      if (result)
        System.exit(0)
      else
        System.exit(1)
    }
  
