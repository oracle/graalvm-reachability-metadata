[tool-call] delta {"path":"tests/src/org.scalatest/scalatest-core_3/3.2.19/src/test/scala/org_scalatest/scalatest_core_3/DiscoverySuiteTest.scala","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_scalatest.scalatest_core_3\n\nimport java.nio.file.Files\nimport java.nio.file.Path\nimport java.nio.file.Paths\nimport java.util.concurrent.atomic.AtomicInteger\nimport java.util.concurrent.atomic.AtomicReference\n\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\nimport org.scalatest.Suite\nimport org.scalatest.WrapWith\nimport org.scalatest.tools.Runner\n\nclass DiscoverySuiteTest {\n\n  @Test\n  def discoversPlainAndWrappedSuitesFromRunpath(): Unit = {\n    DiscoveryPlainSuite.instantiations.set(0)\n    DiscoveryWrappingSuite.wrappedClassName.set(null)\n\n    val passed: Boolean = Runner.run(\n      Array(\n        \"-oW\",\n        \"-R\",\n        testClassesRunpath.toString,\n        \"-w\",\n        \"org_scalatest.scalatest_core_3.discovery\"\n      )\n    )\n\n    assertThat(passed).isTrue()\n    assertThat(DiscoveryPlainSuite.instantiations.get()).isGreaterThan(0)\n    assertThat(DiscoveryWrappingSuite.wrappedClassName.get())\n      .isEqualTo(classOf[DiscoveryWrappedTarget].getName)\n  }\n\n  private def testClassesRunpath: Path = {\n    val scalaTestClasses: Path = Paths.get(\"build\", \"classes\", \"scala\", \"test\")\n    if (Files.isDirectory(scalaTestClasses)) {\n      scalaTestClasses.toAbsolutePath\n    } else {\n      Paths.get(classOf[DiscoverySuiteTest].getProtectionDomain.getCodeSource.getLocation.toURI).toAbsolutePath\n    }\n  }\n}\n\npackage discovery {\n\nclass DiscoveryPlainSuite extends Suite {\n  DiscoveryPlainSuite.instantiations.incrementAndGet()\n}\n\nobject DiscoveryPlainSuite {\n  val instantiations: AtomicInteger = new AtomicInteger()\n}\n\n@WrapWith(classOf[DiscoveryWrappingSuite])\nclass DiscoveryWrappedTarget\n\nclass DiscoveryWrappingSuite(wrappedClass: Class[?]) extends Suite {\n  DiscoveryWrappingSuite.wrappedClassName.set(wrappedClass.getName)\n}\n\nobject DiscoveryWrappingSuite {\n  val wrappedClassName: AtomicReference[String] = new AtomicReference[String]()\n}\n}\n"}
