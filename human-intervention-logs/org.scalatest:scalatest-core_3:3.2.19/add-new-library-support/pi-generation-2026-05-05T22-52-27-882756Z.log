  package org_scalatest.scalatest_core_3
  
  import scala.jdk.CollectionConverters._
  
  import org.assertj.core.api.Assertions.assertThat
  import org.junit.jupiter.api.Test
  
  class IconEmbellishedListCellRendererInnerIconsTest {
  
    @Test
    def initializesEveryRendererIconResource(): Unit = {
      val iconResources: Seq[IconEmbellishedListCellRendererInnerIconsAccess.IconResource] =
        IconEmbellishedListCellRendererInnerIconsAccess.loadPrimaryIcons().asScala.toSeq
  
      assertThat(iconResources.size).isEqualTo(14)
      iconResources.foreach { (iconResource: IconEmbellishedListCellRendererInnerIconsAccess.IconResource) =>
        assertThat(iconResource.icon().getDescription()).endsWith(iconResource.resourcePath())
        assertThat(iconResource.icon().getIconWidth()).isGreaterThan(0)
        assertThat(iconResource.icon().getIconHeight()).isGreaterThan(0)
      }
    }
  }
