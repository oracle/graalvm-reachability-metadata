  package org_scalatest.scalatest_core_3 {
  
  import org.assertj.core.api.Assertions.assertThat
  import org.junit.jupiter.api.Test
  import org.scalatest.Suite
  import org.scalatest.WrapWith
  import org.scalatest.tools.Runner
  
  class RunnerTest {
  
    @Test
    def instantiatesNamedSuiteByClassName(): Unit = {
      val passed: Boolean = Runner.run(Array("-oW", "-s", classOf[RunnerPlainSuite].getName))
  
      assertThat(passed).isTrue()
    }
  
    @Test
    def instantiatesAnnotatedClassThroughWrapWithSuite(): Unit = {
      val passed: Boolean = Runner.run(Array("-oW", "-s", classOf[RunnerWrappedTarget].getName))
  
      assertThat(passed).isTrue()
    }
  
    @Test
    def instantiatesJUnitAndTestNGWrapperSuites(): Unit = {
      val passed: Boolean = Runner.run(
        Array(
          "-oW",
          "-j",
          "example.LegacyJUnitTest",
          "-b",
          "testng-suite.xml"
        )
      )
  
      assertThat(passed).isTrue()
    }
  }
  
  class RunnerPlainSuite extends Suite
  
  @WrapWith(classOf[RunnerClassWrappingSuite])
  class RunnerWrappedTarget
  
  class RunnerClassWrappingSuite(wrappedClass: Class[?]) extends Suite {
    override def suiteName: String = wrappedClass.getName
  }
  }
  
  package org.scalatestplus.junit {
  
  import org.scalatest.Suite
  
  class JUnitWrapperSuite(className: String, loader: ClassLoader) extends Suite {
    override def suiteName: String = s"JUnitWrapperSuite($className, ${loader.getClass.getName})"
  }
  }
  
  package org.scalatestplus.testng {
  
  import org.scalatest.Suite
  
  class TestNGWrapperSuite(suiteFileNames: List[String]) extends Suite {
    override def suiteName: String = suiteFileNames.mkString("TestNGWrapperSuite(", ",", ")")
  }
  }
