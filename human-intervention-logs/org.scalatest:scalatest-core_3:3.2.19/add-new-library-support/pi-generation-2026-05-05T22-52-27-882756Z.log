[tool-call] delta {"path":"tests/src/org.scalatest/scalatest-core_3/3.2.19/src/test/scala/org_scalatest/scalatest_core_3/ConfigMapWrapperSuiteTest.scala","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_scalatest.scalatest_core_3\n\nimport java.util.concurrent.atomic.AtomicInteger\nimport java.util.concurrent.atomic.AtomicReference\n\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\nimport org.scalatest.Args\nimport org.scalatest.ConfigMap\nimport org.scalatest.ConfigMapWrapperSuite\nimport org.scalatest.Reporter\nimport org.scalatest.Status\nimport org.scalatest.SucceededStatus\nimport org.scalatest.Suite\nimport org.scalatest.events.Event\n\nclass ConfigMapWrapperSuiteTest {\n\n  @Test\n  def wrappedSuiteMetadataConstructsSuiteWithEmptyConfigMap(): Unit = {\n    ConfigMapWrapperTargetSuite.reset()\n\n    val wrapper: ConfigMapWrapperSuite = new ConfigMapWrapperSuite(classOf[ConfigMapWrapperTargetSuite])\n\n    assertThat(ConfigMapWrapperTargetSuite.constructorCalls.get()).isZero()\n    assertThat(wrapper.suiteName).isEqualTo(\"ConfigMapWrapperTargetSuite(empty)\")\n    assertThat(ConfigMapWrapperTargetSuite.constructorCalls.get()).isEqualTo(1)\n    assertThat(ConfigMapWrapperTargetSuite.constructorConfigMap.get().asInstanceOf[Map[?, ?]]).isEmpty()\n  }\n\n  @Test\n  def runConstructsSuiteWithSuppliedConfigMap(): Unit = {\n    ConfigMapWrapperTargetSuite.reset()\n\n    val wrapper: ConfigMapWrapperSuite = new ConfigMapWrapperSuite(classOf[ConfigMapWrapperTargetSuite])\n    val configMap: ConfigMap = ConfigMap(\"message\" -> \"from-run\")\n    val args: Args = Args(reporter = SilentReporter, configMap = configMap)\n\n    val status: Status = wrapper.run(None, args)\n\n    assertThat(status.isCompleted()).isTrue()\n    assertThat(status.succeeds()).isTrue()\n    assertThat(ConfigMapWrapperTargetSuite.constructorCalls.get()).isEqualTo(1)\n    assertThat(ConfigMapWrapperTargetSuite.runCalls.get()).isEqualTo(1)\n    assertThat(ConfigMapWrapperTargetSuite.constructorConfigMap.get()).isSameAs(configMap)\n    assertThat(ConfigMapWrapperTargetSuite.runConfigMap.get()).isSameAs(configMap)\n  }\n}\n\nclass ConfigMapWrapperTargetSuite(configMap: Map[?, ?]) extends Suite {\n  ConfigMapWrapperTargetSuite.constructorCalls.incrementAndGet()\n  ConfigMapWrapperTargetSuite.constructorConfigMap.set(configMap.asInstanceOf[AnyRef])\n\n  override def suiteName: String =\n    s\"ConfigMapWrapperTargetSuite(${configMap.getOrElse(\"message\", \"empty\")})\"\n\n  override def run(testName: Option[String], args: Args): Status = {\n    ConfigMapWrapperTargetSuite.runCalls.incrementAndGet()\n    ConfigMapWrapperTargetSuite.runConfigMap.set(args.configMap)\n    SucceededStatus\n  }\n}\n\nobject ConfigMapWrapperTargetSuite {\n  val constructorCalls: AtomicInteger = new AtomicInteger()\n  val runCalls: AtomicInteger = new AtomicInteger()\n  val constructorConfigMap: AtomicReference[AnyRef] = new AtomicReference[AnyRef]()\n  val runConfigMap: AtomicReference[AnyRef] = new AtomicReference[AnyRef]()\n\n  def reset(): Unit = {\n    constructorCalls.set(0)\n    runCalls.set(0)\n    constructorConfigMap.set(null)\n    runConfigMap.set(null)\n  }\n}\n\nobject SilentReporter extends Reporter {\n  override def apply(event: Event): Unit = ()\n}\n"}
