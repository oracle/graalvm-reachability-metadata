                  new IconResource("images/reddotsel.gif", icons.testFailedSelIcon()),
                  new IconResource("images/bluedotsel.gif", icons.infoProvidedSelIcon()),
                  new IconResource("images/graydotsel.gif", icons.runStartingSelIcon()),
                  new IconResource("images/cyandotsel.gif", icons.suiteStartingSelIcon()),
                  new IconResource("images/yellowdotsel.gif", icons.testIgnoredSelIcon()));
      }
  
      static final class IconResource {
          private final String resourcePath;
          private final ImageIcon icon;
  
          IconResource(String resourcePath, ImageIcon icon) {
              this.resourcePath = resourcePath;
              this.icon = icon;
          }
  
          String resourcePath() {
              return resourcePath;
          }
  
          ImageIcon icon() {
              return icon;
          }
      }
  }
