[tool-call] delta {"path":"tests/src/org.scalatest/scalatest-core_3/3.2.19/src/test/scala/org_scalatest/scalatest_core_3/SuiteTest.scala","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_scalatest.scalatest_core_3\n\nimport java.util.concurrent.CopyOnWriteArrayList\n\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\nimport org.scalatest.Args\nimport org.scalatest.Informer\nimport org.scalatest.Reporter\nimport org.scalatest.Status\nimport org.scalatest.Suite\nimport org.scalatest.events.Event\nimport org.scalatest.events.TestIgnored\n\nclass SuiteTest {\n\n  @Test\n  def detectsPublicNoArgConstructorsUsedBySuiteRerunSupport(): Unit = {\n    assertThat(SuiteAccess.hasPublicNoArgConstructor(classOf[SuiteNoArgConstructorTarget])).isTrue()\n    assertThat(SuiteAccess.hasPublicNoArgConstructor(classOf[SuiteConfigOnlyConstructorTarget])).isFalse()\n  }\n\n  @Test\n  def locatesMethodForIgnoredSuiteTestName(): Unit = {\n    val suite: SuiteIgnoredTestTarget = new SuiteIgnoredTestTarget()\n    val reporter: SuiteRecordingReporter = new SuiteRecordingReporter()\n\n    val status: Status = suite.run(None, Args(reporter = reporter))\n\n    assertThat(status.isCompleted()).isTrue()\n    assertThat(status.succeeds()).isTrue()\n    assertThat(reporter.events).hasAtLeastOneElementOfType(classOf[TestIgnored])\n    assertThat(SuiteAccess.methodForTestName(suite, \"testIgnoredExample\").getName)\n      .isEqualTo(\"testIgnoredExample\")\n  }\n\n  @Test\n  def discoversYeOldeTestNamesFromPublicSuiteMethods(): Unit = {\n    val names: Set[String] = SuiteAccess.yeOldeTestNames(new SuiteLegacyTestNameTarget())\n\n    assertThat(names.contains(\"testLegacy\")).isTrue()\n    assertThat(names.contains(\"testWithInformer(Informer)\")).isTrue()\n    assertThat(names.contains(\"helperMethod\")).isFalse()\n  }\n}\n\nclass SuiteNoArgConstructorTarget extends Suite\n\nclass SuiteConfigOnlyConstructorTarget(name: String) extends Suite {\n  override def suiteName: String = name\n}\n\nclass SuiteIgnoredTestTarget extends Suite {\n  override def testNames: Set[String] = Set(\"testIgnoredExample\")\n  override def tags: Map[String, Set[String]] = Map(\"testIgnoredExample\" -> Set(\"org.scalatest.Ignore\"))\n\n  def testIgnoredExample(): Unit = ()\n}\n\nclass SuiteLegacyTestNameTarget extends Suite {\n  def testLegacy(): Unit = ()\n\n  def testWithInformer(informer: Informer): Unit = {\n    informer(\"legacy informer method\")\n  }\n\n  def helperMethod(): Unit = ()\n}\n\nclass SuiteRecordingReporter extends Reporter {\n  val events: CopyOnWriteArrayList[Event] = new CopyOnWriteArrayList[Event]()\n\n  override def apply(event: Event): Unit = {\n    events.add(event)\n    ()\n  }\n}\n"}
