      val candidate = getSimpleNameOfAnObjectsClass(theSuite)
      val simpleName =
        substitution match {
          case Some((from, to)) if (candidate == from) => to
          case None => candidate
        }
     if (theSuite.nestedSuites.isEmpty) simpleName
     else simpleName + theSuite.nestedSuites.mkString("(", ", ", ")")
    }
  
