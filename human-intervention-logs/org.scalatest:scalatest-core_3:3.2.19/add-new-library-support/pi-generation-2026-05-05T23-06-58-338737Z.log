  package org_scalatest.scalatest_core_3
  
  import java.util.concurrent.atomic.AtomicInteger
  import java.util.concurrent.atomic.AtomicReference
  
  import org.assertj.core.api.Assertions.assertThat
  import org.junit.jupiter.api.Test
  import org.scalatest.Args
  import org.scalatest.ConfigMap
  import org.scalatest.ConfigMapWrapperSuite
  import org.scalatest.Reporter
  import org.scalatest.Status
  import org.scalatest.SucceededStatus
  import org.scalatest.Suite
  import org.scalatest.events.Event
  
  class ConfigMapWrapperSuiteTest {
  
    @Test
    def wrappedSuiteMetadataConstructsSuiteWithEmptyConfigMap(): Unit = {
      ConfigMapWrapperTargetSuite.reset()
  
      val wrapper: ConfigMapWrapperSuite = new ConfigMapWrapperSuite(classOf[ConfigMapWrapperTargetSuite])
  
      assertThat(ConfigMapWrapperTargetSuite.constructorCalls.get()).isZero()
      assertThat(wrapper.suiteName).isEqualTo("ConfigMapWrapperTargetSuite(empty)")
      assertThat(ConfigMapWrapperTargetSuite.constructorCalls.get()).isEqualTo(1)
      assertThat(ConfigMapWrapperTargetSuite.constructorConfigMap.get().asInstanceOf[Map[?, ?]].isEmpty).isTrue()
    }
  
    @Test
    def runConstructsSuiteWithSuppliedConfigMap(): Unit = {
      ConfigMapWrapperTargetSuite.reset()
  
      val wrapper: ConfigMapWrapperSuite = new ConfigMapWrapperSuite(classOf[ConfigMapWrapperTargetSuite])
      val configMap: ConfigMap = ConfigMap("message" -> "from-run")
      val args: Args = Args(reporter = SilentReporter, configMap = configMap)
  
      val status: Status = wrapper.run(None, args)
  
      assertThat(status.isCompleted()).isTrue()
      assertThat(status.succeeds()).isTrue()
      assertThat(ConfigMapWrapperTargetSuite.constructorCalls.get()).isEqualTo(1)
      assertThat(ConfigMapWrapperTargetSuite.runCalls.get()).isEqualTo(1)
      assertThat(ConfigMapWrapperTargetSuite.constructorConfigMap.get()).isSameAs(configMap)
      assertThat(ConfigMapWrapperTargetSuite.runConfigMap.get()).isSameAs(configMap)
    }
  }
  
  class ConfigMapWrapperTargetSuite(configMap: Map[String, Any]) extends Suite {
    ConfigMapWrapperTargetSuite.constructorCalls.incrementAndGet()
    ConfigMapWrapperTargetSuite.constructorConfigMap.set(configMap.asInstanceOf[AnyRef])
  
    override def suiteName: String =
      s"ConfigMapWrapperTargetSuite(${configMap.getOrElse("message", "empty")})"
  
    override def run(testName: Option[String], args: Args): Status = {
      ConfigMapWrapperTargetSuite.runCalls.incrementAndGet()
      ConfigMapWrapperTargetSuite.runConfigMap.set(args.configMap)
      SucceededStatus
    }
  }
  
  object ConfigMapWrapperTargetSuite {
    val constructorCalls: AtomicInteger = new AtomicInteger()
    val runCalls: AtomicInteger = new AtomicInteger()
    val constructorConfigMap: AtomicReference[AnyRef] = new AtomicReference[AnyRef]()
    val runConfigMap: AtomicReference[AnyRef] = new AtomicReference[AnyRef]()
  
    def reset(): Unit = {
      constructorCalls.set(0)
      runCalls.set(0)
      constructorConfigMap.set(null)
      runConfigMap.set(null)
    }
  }
  
  object SilentReporter extends Reporter {
    override def apply(event: Event): Unit = ()
  }
