      private static String decodeUtf8(List<ByteBuffer> buffers) {
          StringBuilder text = new StringBuilder();
          for (ByteBuffer buffer : buffers) {
              ByteBuffer copy = buffer.asReadOnlyBuffer();
              byte[] bytes = new byte[copy.remaining()];
