          int errorCode();
  
          /**
           * Returns the SQLState.
           *
           * @return the SQLState
           */
          @Nullable
          String sqlState();
  
          /**
           * Returns the message text.
           *
           * @return the message text.                                                                                MockResult.java
           */
          String message();
  
      }
  
  }
