de-url\" : \"https://repo1.maven.org/maven2/org/slf4j/slf4j-api/1.7.36/slf4j-api-1.7.36-tests.jar\",\nmetadata/org.slf4j/slf4j-api/index.json:22:    \"documentation-url\" : \"https://repo1.maven.org/maven2/org/slf4j/slf4j-api/1.7.36/slf4j-api-1.7.36-javadoc.jar\",\nmetadata/org.slf4j/slf4j-api/index.json:23:    \"description\" : \"SLF4J defines a common logging API for Java applications and libraries. It lets code route log messages to different logging implementations without changing application code.\",\nmetadata/org.slf4j/slf4j-nop/index.json:5:    \"source-code-url\" : \"https://repo1.maven.org/maven2/org/slf4j/slf4j-nop/1.5.3/slf4j-nop-1.5.3-sources.jar\",\nmetadata/org.slf4j/slf4j-nop/index.json:6:    \"repository-url\" : \"https://github.com/qos-ch/slf4j\",\nmetadata/org.slf4j/slf4j-nop/index.json:7:    \"test-code-url\" : \"https://github.com/qos-ch/slf4j/tree/SLF4J_1.5.3/slf4j-nop/src/test/java\",\nmetadata/org.slf4j/slf4j-nop/index.json:8:    \"documentation-url\" : \"https://github.com/qos-ch/slf4j/blob/SLF4J_1.5.3/slf4j-site/src/site/pages/manual.html\",\nmetadata/org.slf4j/slf4j-nop/index.json:9:    \"description\" : \"SLF4J NOP is a no-operation binding for the SLF4J logging facade. It satisfies SLF4J's binding requirement while discarding all logging output.\",\nmetadata/javax.activation/javax.activation-api/index.json:6:    \"source-code-url\": \"https://repo1.maven.org/maven2/javax/activation/javax.activation-api/1.2.0/javax.activation-api-1.2.0-sources.jar\",\nmetadata/javax.activation/javax.activation-api/index.json:7:    \"repository-url\": \"https://github.com/javaee/activation\",\nmetadata/javax.activation/javax.activation-api/index.json:8:    \"test-code-url\": \"N/A\",\nmetadata/javax.activation/javax.activation-api/index.json:9:    \"documentation-url\": \"https://repo1.maven.org/maven2/javax/activation/javax.activation-api/1.2.0/javax.activation-api-1.2.0-javadoc.jar\",\nmetadata/javax.activation/javax.activation-api/index.json:10:    \"description\": \"JavaBeans Activation Framework API defines the javax.activation types for describing data sources, determining MIME types, and dispatching data to content handlers. It provides the standard activation API that other libraries use to work with arbitrary data without bundling the implementation classes.\",\nmetadata/org.slf4j/slf4j-jdk14/index.json:5:    \"source-code-url\" : \"https://repo1.maven.org/maven2/org/slf4j/slf4j-jdk14/1.5.6/slf4j-jdk14-1.5.6-sources.jar\",\nmetadata/org.slf4j/slf4j-jdk14/index.json:6:    \"repository-url\" : \"https://github.com/qos-ch/slf4j\",\nmetadata/org.slf4j/slf4j-jdk14/index.json:7:    \"test-code-url\" : \"https://github.com/qos-ch/slf4j/tree/SLF4J_1.5.6/slf4j-jdk14/src/test\",\nmetadata/org.slf4j/slf4j-jdk14/index.json:8:    \"documentation-url\" : \"https://github.com/qos-ch/slf4j/blob/SLF4J_1.5.6/slf4j-site/src/site/pages/manual.html\",\nmetadata/org.slf4j/slf4j-jdk14/index.json:9:    \"description\" : \"SLF4J JDK14 binding routes SLF4J API logging calls to Java's built-in java.util.logging framework. It provides the runtime provider needed for applications using SLF4J 1.5.6 to emit logs through the JDK 1.4 logging system.\",\nmetadata/javax.activation/activation/index.json:5:    \"source-code-url\" : \"https://repo1.maven.org/maven2/javax/activation/activation/1.1/activation-1.1-sources.jar\",\nmetadata/javax.activation/activation/index.json:6:    \"repository-url\" : \"https://github.com/javaee/activation\",\nmetadata/javax.activation/activation/index.json:7:    \"test-code-url\" : \"N/A\",\nmetadata/javax.activation/activation/index.json:8:    \"documentation-url\" : \"https://www.oracle.com/docs/tech/java/jaf-1.pdf\",\nmetadata/javax.activation/activation/index.json:9:    \"description\" : \"JavaBeans Activation Framework provides a standard API for detecting data types, accessing arbitrary data through DataSource abstractions, and locating content handlers for that data. It is commonly used by JavaMail to process MIME content and dispatch operations such as viewing, editing, or transferring data.\",\nmetadata/com.squareup.okio/okio/index.json:5:    \"source-code-url\" : \"https://repo1.maven.org/maven2/com/squareup/okio/okio/1.17.2/okio-1.17.2-sources.jar\",\nmetadata/com.squareup.okio/okio/index.json:6:    \"repository-url\" : \"https://github.com/square/okio\",\nmetadata/com.squareup.okio/okio/index.json:7:    \"test-code-url\" : \"https://github.com/square/okio/tree/okio-parent-1.17.2/okio/src/test\",\nmetadata/com.squareup.okio/okio/index.json:8:    \"documentation-url\" : \"https://repo1.maven.org/maven2/com/squareup/okio/okio/1.17.2/okio-1.17.2-javadoc.jar\",\nmetadata/com.squareup.okio/okio/index.json:9:    \"description\" : \"Okio complements java.io and java.nio to make it easier to access, store, and process data. It provides efficient byte strings, buffers, sources, and sinks for I/O operations.\",\nmetadata/org.jvnet/animal-sniffer-annotation/index.json:6:    \"source-code-url\": \"https://repo.maven.apache.org/maven2/org/jvnet/animal-sniffer-annotation/1.0/animal-sniffer-annotation-1.0-sources.jar\",\nmetadata/org.jvnet/animal-sniffer-annotation/index.json:7:    \"repository-url\": \"https://github.com/mojohaus/animal-sniffer\",\nmetadata/org.jvnet/animal-sniffer-annotation/index.json:8:    \"test-code-url\": \"N/A\",\nmetadata/org.jvnet/animal-sniffer-annotation/index.json:9:    \"documentation-url\": \"https://repo.maven.apache.org/maven2/org/jvnet/animal-sniffer-annotation/1.0/animal-sniffer-annotation-1.0-javadoc.jar\",\nmetadata/org.jvnet/animal-sniffer-annotation/index.json:10:    \"description\": \"This artifact provides the @IgnoreJRERequirement annotation used by Animal Sniffer to mark code that should be excluded from JRE API compatibility checks. It lets libraries document members that intentionally rely on newer JDK APIs while still validating their minimum runtime requirements.\",\nmetadata/org.jboss.interceptor/jboss-interceptor-api/index.json:5:    \"source-code-url\" : \"https://repo.maven.apache.org/maven2/org/jboss/interceptor/jboss-interceptor-api/1.1/jboss-interceptor-api-1.1-sources.jar\",\nmetadata/org.jboss.interceptor/jboss-interceptor-api/index.json:6:    \"repository-url\" : \"https://svn.jboss.org/repos/jbossas/projects/interceptors/api\",\nmetadata/org.jboss.interceptor/jboss-interceptor-api/index.json:7:    \"test-code-url\" : \"N/A\",\nmetadata/org.jboss.interceptor/jboss-interceptor-api/index.json:8:    \"documentation-url\" : \"N/A\",\nmetadata/org.jboss.interceptor/jboss-interceptor-api/index.json:9:    \"description\" : \"This library provides the EJB 3.1 Interceptor API annotations and interfaces in the javax.interceptor package. It defines interceptor bindings, invocation lifecycle annotations, and InvocationContext contracts used by containers and applications to intercept method calls and lifecycle events.\",\nmetadata/org.apache.zookeeper/zookeeper/index.json:5:    \"source-code-url\" : \"https://repo1.maven.org/maven2/org/apache/zookeeper/zookeeper/3.8.1/zookeeper-3.8.1-sources.jar\",\nmetadata/org.apache.zookeeper/zookeeper/index.json:6:    \"repository-url\" : \"https://github.com/apache/zookeeper\",\nmetadata/org.apache.zookeeper/zookeeper/index.json:7:    \"test-code-url\" : \"https://repo1.maven.org/maven2/org/apache/zookeeper/zookeeper/3.8.1/zookeeper-3.8.1-tests.jar\",\nmetadata/org.apache.zookeeper/zookeeper/index.json:8:    \"documentation-url\" : \"https://repo1.maven.org/maven2/org/apache/zookeeper/zookeeper/3.8.1/zookeeper-3.8.1-javadoc.jar\",\nmetadata/org.apache.zookeeper/zookeeper/index.json:9:    \"description\" : \"Apache ZooKeeper is a centralized coordination service for distributed applications. It provides primitives for configuration management, naming, distributed synchronization, and group services.\",\nmetadata/org.apache.zookeeper/zookeeper-jute/index.json:5:    \"source-code-url\" : \"https://repo1.maven.org/maven2/org/apache/zookeeper/zookeeper-jute/3