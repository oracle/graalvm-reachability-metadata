th.endsWith(suffix)) {\n            throw new AssertionError(\"Unexpected ModelMapper resource URL: \" + path);\n        }\n        return new URL(path.substring(0, path.length() - suffix.length()));\n    }\n\n    public static final class FactoryResolutionScenario implements Runnable {\n        public FactoryResolutionScenario() {\n        }\n\n        @Override\n        public void run() {\n            String previousValue = System.setProperty(BYTE_BUDDY_SAFE_PROPERTY, \"true\");\n            try {\n                Factory factory = new Factory(NoOpAccessResolver.INSTANCE);\n                if (factory.isAvailable()) {\n                    throw new AssertionError(\"Unsafe factory should be unavailable\");\n                }\n                Factory resolvedFactory = Factory.resolve(new NoOpInstrumentation(), false);\n                if (resolvedFactory == null) {\n                    throw new AssertionError(\"Resolved factory should not be null\");\n                }\n            } finally {\n                if (previousValue == null) {\n                    System.clearProperty(BYTE_BUDDY_SAFE_PROPERTY);\n                } else {\n                    System.setProperty(BYTE_BUDDY_SAFE_PROPERTY, previousValue);\n                }\n            }\n        }\n\n        private enum NoOpAccessResolver implements Factory.AccessResolver {\n            INSTANCE;\n\n            @Override\n            public void apply(java.lang.reflect.AccessibleObject accessibleObject) {\n                // Intentionally leave the member inaccessible so Factory records\n                // the unavailable dispatcher after attempting to read Unsafe.\n            }\n        }\n\n        private static final class NoOpInstrumentation implements Instrumentation {\n            @Override\n            public void addTransformer(\n                    ClassFileTransformer transformer,\n                    boolean canRetransform) {\n            }\n\n            @Override\n            public void a