{"type":"item.completed","item":{"id":"item_175","type":"command_execution","command":"/bin/bash -lc \"sed -n '1,220p' tests/src/org.modelmapper/modelmapper/3.2.0/src/test/java/org_modelmapper/modelmapper/ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeInjectionTest.java\"","aggregated_output":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_modelmapper.modelmapper;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.security.ProtectionDomain;\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\nimport org.modelmapper.internal.bytebuddy.ByteBuddy;\nimport org.modelmapper.internal.bytebuddy.dynamic.DynamicType;\nimport org.modelmapper.internal.bytebuddy.dynamic.loading.ClassInjector.UsingReflection;\n\npublic class ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeInjectionTest {\n    private static final String SAFE_PROPERTY = \"org.modelmapper.internal.bytebuddy.safe\";\n    private static final String INJECTED_TYPE_NAME = \"org_modelmapper.modelmapper.generated.\"\n            + \"UnsafeInjectedType\";\n    private static final String INJECTED_PACKAGE_NAME = \"org_modelmapper.modelmapper.generated\";\n\n    @Test\n    void unsafeReflectionDispatcherDefinesPackageAndClass() {\n        String originalSafeProperty = System.getProperty(SAFE_PROPERTY);\n        System.setProperty(SAFE_PROPERTY, Boolean.FALSE.toString());\n        try {\n            exerciseUnsafeDispatcher();\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        } finally {\n            restoreProperty(originalSafeProperty);\n        }\n    }\n\n    private static void exerciseUnsafeDispatcher() {\n        DispatcherAccess.exercise();\n    }\n\n    private static byte[] makeClassBytes() {\n        DynamicType.Unloaded<?> unloadedType = new ByteBuddy()\n                .subclass(Object.class)\n                .name(INJECTED_TYPE_NAME)\n                .make();\n        return unloadedType.getBytes();\n    }\n\n    private static ClassLoader testClassLoader() {\n        return ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeInjectionTest.class\n                .getClassLoader();\n    }\n\n    private static ProtectionDomain testProtectionDomain() {\n        return ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeInjectionTest.class\n                .getProtectionDomain();\n    }\n\n    private static void restoreProperty(String originalSafeProperty) {\n        if (originalSafeProperty == null) {\n            System.clearProperty(SAFE_PROPERTY);\n        } else {\n            System.setProperty(SAFE_PROPERTY, originalSafeProperty);\n        }\n    }\n\n    private static final class DispatcherAccess extends UsingReflection {\n        static {\n            java.lang.System.setProperty(SAFE_PROPERTY, Boolean.FALSE.toString());\n        }\n\n        private DispatcherAccess() {\n            super(testClassLoader());\n        }\n\n        static void exercise() {\n            Dispatcher.Initializable initializable = Dispatcher.CreationAction.INSTANCE.run();\n            if (initializable.isAvailable()) {\n                exerciseAvailableDispatcher(initializable.initialize());\n            } else {\n                assertThat(new DispatcherAccess().isAlive()).isFalse();\n            }\n        }\n\n        private static void exerciseAvailableDispatcher(Dispatcher dispatcher) {\n            ClassLoader targetClassLoader = new ClassLoader(testClassLoader()) {\n            };\n            byte[] classBytes = makeClassBytes();\n\n            Object classLoadingLock = dispatcher.getClassLoadingLock(\n                    targetClassLoader,\n                    INJECTED_TYPE_NAME);\n            assertThat(classLoadingLock).isNotNull();\n            assertThat(dispatcher.findClass(targetClassLoader, INJECTED_TYPE_NAME)).isNull();\n            assertThat(dispatcher.getDefinedPackage(\n                    targetClassLoader,\n                    INJECTED_PACKAGE_NAME)).isNull();\n\n            Package definedPackage = dispatcher.definePackage(\n                    targetClassLoader,\n                    INJECTED_PACKAGE_NAME,\n                    \"ModelMapper test specification\",\n                    \"1\",\n                    \"ModelMapper test vendor\",\n                    \"ModelMapper test implementation\",\n                    \"1\",\n                    \"ModelMapper test vendor\",\n                    null);\n            assertThat(definedPackage.getName()).isEqualTo(INJECTED_PACKAGE_NAME);\n            assertThat(dispatcher.getDefinedPackage(targetClassLoader, INJECTED_PACKAGE_NAME))\n                    .isSameAs(definedPackage);\n            assertThat(dispatcher.getPackage(targetClassLoader, INJECTED_PACKAGE_NAME))\n                    .isSameAs(definedPackage);\n\n            Class<?> injectedType = dispatcher.defineClass(\n                    targetClassLoader,\n                    INJECTED_TYPE_NAME,\n                    classBytes,\n                    testProtectionDomain());\n            assertThat(injectedType.getName()).isEqualTo(INJECTED_TYPE_NAME);\n            assertThat(injectedType.getClassLoader()).isSameAs(targetClassLoader);\n            assertThat(dispatcher.findClass(targetClassLoader, INJECTED_TYPE_NAME))\n                    .isSameAs(injectedType);\n        }\n    }\n}\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_176","type":"command_execution","command":"/bin/bash -lc \"sed -n '1,220p' tests/src/org.modelmapper/modelmapper/3.2.0/src/test/java/org_modelmapper/modelmapper/ByteArrayClassLoaderInnerChildFirstTest.java\"","aggregated_output":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_modelmapper.modelmapper;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.IOException;\nimport java.net.URL;\nimport java.util.Collections;\nimport java.util.Enumeration;\nimport java.util.List;\nimport java.util.Map;\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\nimport org.modelmapper.internal.bytebuddy.ByteBuddy;\nimport org.modelmapper.internal.bytebuddy.description.type.TypeDescription;\nimport org.modelmapper.internal.bytebuddy.dynamic.DynamicType;\nimport org.modelmapper.internal.bytebuddy.dynamic.loading.ByteArrayClassLoader.ChildFirst;\nimport org.modelmapper.internal.bytebuddy.dynamic.loading.ByteArrayClassLoader.PersistenceHandler;\n\npublic class ByteArrayClassLoaderInnerChildFirstTest {\n    private static final String GENERATED_PACKAGE = \"org_modelmapper.modelmapper.generated\";\n    private static final String STATIC_LOAD_TYPE_NAME = GENERATED_PACKAGE\n            + \".ChildFirstStaticLoadType\";\n    private static final String MANIFEST_TYPE_NAME = GENERATED_PACKAGE + \".ChildFirstManifestType\";\n    private static final String LATENT_TYPE_NAME = GENERATED_PACKAGE + \".ChildFirstLatentType\";\n    private static final String PARENT_RESOURCE = \"org_modelmapper/modelmapper/parent-resource.txt\";\n\n    @Test\n    void staticLoadDefinesGeneratedTypesThroughChildFirstLoader() {\n        try {\n            DynamicType.Unloaded<?> unloadedType = makeUnloaded(STATIC_LOAD_TYPE_NAME);\n            TypeDescription typeDescription = unloadedType.getTypeDescription();\n\n            Map<TypeDescription, Class<?>> loadedTypes = ChildFirst.load(\n                    testClassLoader(),\n                    Map.of(typeDescription, unloadedType.getBytes()));\n\n            Class<?> loadedType = loadedTypes.get(typeDescription);\n            assertThat(loadedType).isNotNull();\n            assertThat(loadedType.getName()).isEqualTo(STATIC_LOAD_TYPE_NAME);\n            assertThat(loadedType.getClassLoader()).isInstanceOf(ChildFirst.class);\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    @Test\n    void manifestPersistenceServesGeneratedClassResourcesAndDelegatesToParentResources()\n            throws IOException {\n        try {\n            DynamicType.Unloaded<?> unloadedType = makeUnloaded(MANIFEST_TYPE_NAME);\n            String generatedResourceName = resourceName(MANIFEST_TYPE_NAME);\n            URL parentResource = new URL(\"file:/modelmapper-child-first-parent-resource.txt\");\n            ClassLoader parentClassLoader = new ResourceOnlyClassLoader(\n                    testClassLoader(),\n                    PARENT_RESOURCE,\n                    parentResource);\n            ChildFirst classLoader = new ChildFirst(\n                    parentClassLoader,\n                    Map.of(MANIFEST_TYPE_NAME, unloadedType.getBytes()),\n                    PersistenceHandler.MANIFEST);\n\n            URL generatedResource = classLoader.getResource(generatedResourceName);\n            assertThat(generatedResource).isNotNull();\n\n            assertThat(classLoader.getResource(PARENT_RESOURCE)).isEqualTo(parentResource);\n\n            List<URL> parentResources = Collections.list(classLoader.getResources(PARENT_RESOURCE));\n            assertThat(parentResources).containsExactly(parentResource);\n\n            List<URL> generatedResources = Collections.list(\n                    classLoader.getResources(generatedResourceName));\n            assertThat(generatedResources).isNotEmpty();\n            assertThat(generatedResources.get(0)).isEqualTo(generatedResource);\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    @Test\n    void latentLoadedClassResourceShadowsParentResourceWithSameName()\n            throws Exception {\n        try {\n            DynamicType.Unloaded<?> unloadedType = makeUnloaded(LATENT_TYPE_NAME);\n            String generatedResourceName = resourceName(LATENT_TYPE_NAME);\n            URL parentResource = new URL(\"file:/modelmapper-child-first-shadowed-resource.class\");\n            ClassLoader parentClassLoader = new ResourceOnlyClassLoader(\n                    testClassLoader(),\n                    generatedResourceName,\n                    parentResource);\n            ChildFirst classLoader = new ChildFirst(\n                    parentClassLoader,\n                    Map.of(LATENT_TYPE_NAME, unloadedType.getBytes()),\n                    PersistenceHandler.LATENT);\n\n            Class<?> loadedType = classLoader.loadClass(LATENT_TYPE_NAME);\n            assertThat(loadedType.getName()).isEqualTo(LATENT_TYPE_NAME);\n            assertThat(loadedType.getClassLoader()).isSameAs(classLoader);\n\n            assertThat(classLoader.getResource(generatedResourceName)).isNull();\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    private static DynamicType.Unloaded<?> makeUnloaded(String typeName) {\n        return new ByteBuddy()\n                .subclass(Object.class)\n                .name(typeName)\n                .make();\n    }\n\n    private static ClassLoader testClassLoader() {\n        return ByteArrayClassLoaderInnerChildFirstTest.class.getClassLoader();\n    }\n\n    private static String resourceName(String typeName) {\n        return typeName.replace('.', '/') + \".class\";\n    }\n\n    private static final class ResourceOnlyClassLoader extends ClassLoader {\n        private final String resourceName;\n        private final URL resource;\n\n        private ResourceOnlyClassLoader(ClassLoader parent, String resourceName, URL resource) {\n            super(parent);\n            this.resourceName = resourceName;\n            this.resource = resource;\n        }\n\n        @Override\n        public URL getResource(String name) {\n            if (resourceName.equals(name)) {\n                return resource;\n            }\n            return super.getResource(name);\n        }\n\n        @Override\n        public Enumeration<URL> getResources(String name) throws IOException {\n            if (resourceName.equals(name)) {\n                return Collections.enumeration(List.of(resource));\n            }\n            return super.getResources(name);\n        }\n    }\n}\n","exit_code":0,"status":"completed"}}
