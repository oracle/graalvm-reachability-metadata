  import org.junit.jupiter.api.Order;
  import org.junit.jupiter.api.Test;
  import org.modelmapper.internal.bytebuddy.ByteBuddy;
  import org.modelmapper.internal.bytebuddy.dynamic.DynamicType;
  import org.modelmapper.internal.bytebuddy.dynamic.loading.ClassInjector.UsingReflection;
  import org.modelmapper.internal.bytebuddy.dynamic.loading.ClassInjector.UsingUnsafe;
  import org.modelmapper.internal.bytebuddy.dynamic.loading.PackageDefinitionStrategy;
  import org.modelmapper.internal.bytebuddy.dynamic.loading.PackageDefinitionStrategy.Definition;
  import org.modelmapper.internal.bytebuddy.dynamic.scaffold.subclass.ConstructorStrategy;
  
  @Order(1)
  public class ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeOverrideTest {
      private static final String BYTE_BUDDY_SAFE_PROPERTY =
              "org.modelmapper.internal.bytebuddy.safe";
  
      @Test
      void injectsGeneratedClassesThroughUnsafeOverrideDispatcher() throws Exception {
          try {
              if (!runThroughSystemLoader()) {
                  runInIsolatedModelMapperLoader();
              }
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          } catch (UnsupportedOperationException exception) {
              assertThat(exception.getMessage())
                      .startsWith("Cannot ")
                      .contains(" using reflection: ");
          }
      }
  
      private static boolean runThroughSystemLoader() {
          String previousValue = System.setProperty(BYTE_BUDDY_SAFE_PROPERTY, "true");
          SecurityManager previousSecurityManager = System.getSecurityManager();
          boolean securityManagerChanged = false;
          try {
              if (UsingUnsafe.isAvailable()) {
                  return false;
              }
              System.setProperty(BYTE_BUDDY_SAFE_PROPERTY, "false");
              securityManagerChanged =
                      UnsafeOverrideDispatcherScenario.installPermissiveSecurityManager();
              return UnsafeOverrideDispatcherAccess.runDispatcherScenario();
          } finally {
              if (securityManagerChanged) {
                  System.setSecurityManager(previousSecurityManager);
              }
              if (previousValue == null) {
                  System.clearProperty(BYTE_BUDDY_SAFE_PROPERTY);
              } else {
                  System.setProperty(BYTE_BUDDY_SAFE_PROPERTY, previousValue);
              }
          }
      }
  
      private static void runInIsolatedModelMapperLoader() throws Exception {
          URL modelMapperUrl = modelMapperJarUrl();
          Class<?> testClass =
                  ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeOverrideTest.class;
          URL testClassesUrl = testClass.getProtectionDomain().getCodeSource().getLocation();
          try (ChildFirstClassLoader classLoader = new ChildFirstClassLoader(
                  new URL[] {testClassesUrl, modelMapperUrl},
                  ClassLoader.getSystemClassLoader())) {
              Class<?> scenarioClass = classLoader.loadClass(
                      UnsafeOverrideDispatcherScenario.class.getName());
              Runnable scenario = (Runnable) scenarioClass.getConstructor().newInstance();
              scenario.run();
          } catch (InvocationTargetException exception) {
              Throwable target = exception.getTargetException();
              if (target instanceof Exception) {
                  throw (Exception) target;
              }
              if (target instanceof Error) {
                  throw (Error) target;
              }
              throw exception;
          }
      }
  
      private static URL modelMapperJarUrl() throws IOException {
          Enumeration<URL> resources = ClassLoader.getSystemResources(
                  "org/modelmapper/ModelMapper.class");
          URL fallback = null;
          while (resources.hasMoreElements()) {
              URL resource = resources.nextElement();
              URL rootUrl = resourceRootUrl(resource);
              if (rootUrl.toString().contains("/build/jacoco/effective/")) {
                  return rootUrl;
              }
              if (fallback == null) {
                  fallback = rootUrl;
              }
          }
          assertThat(fallback).as("ModelMapper class resource").isNotNull();
          return fallback;
      }
  
      private static URL resourceRootUrl(URL resource) throws IOException {
          if ("jar".equals(resource.getProtocol())) {
              return ((JarURLConnection) resource.openConnection()).getJarFileURL();
          }
          String path = resource.toString();
          String suffix = "org/modelmapper/ModelMapper.class";
          assertThat(path).endsWith(suffix);
          return new URL(path.substring(0, path.length() - suffix.length()));
      }
  
      public static final class UnsafeOverrideDispatcherScenario implements Runnable {
          public static final Definition PACKAGE_DEFINITION = new Definition.Simple(
                  "ModelMapper test specification",
                  "1",
                  "ModelMapper tests",
                  "ModelMapper test implementation",
                  "1",
                  "ModelMapper tests",
                  null);
  
          @Override
          public void run() {
              String previousValue = System.setProperty(BYTE_BUDDY_SAFE_PROPERTY, "true");
              SecurityManager previousSecurityManager = System.getSecurityManager();
              boolean securityManagerChanged = false;
              try {
                  if (UsingUnsafe.isAvailable()) {
                      throw new AssertionError(
                              "UsingUnsafe should be unavailable before override dispatcher setup");
