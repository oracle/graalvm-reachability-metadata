     @Override\n        public ModuleReader open() {\n            return new ExplodedModelMapperModuleReader(classesDirectory);\n        }\n\n        private static ModuleDescriptor moduleDescriptor(Path classesDirectory)\n                throws IOException {\n            Set<String> packages = packages(classesDirectory);\n            ModuleDescriptor.Builder builder = ModuleDescriptor\n                    .newModule(ExplodedModelMapperModuleFinder.MODULE_NAME);\n            for (String packageName : packages) {\n                builder.exports(packageName);\n            }\n            return builder.packages(packages).build();\n        }\n\n        private static Set<String> packages(Path classesDirectory) throws IOException {\n            Set<String> packages = new HashSet<>();\n            try (Stream<Path> paths = Files.walk(classesDirectory)) {\n                for (Path path : paths.filter(Files::isRegularFile).toList()) {\n                    String entryName = classesDirectory.relativize(path).toString()\n                            .replace(File.separatorChar, '/');\n                    if (entryName.endsWith(\".class\") && entryName.contains(\"/\")) {\n                        packages.add(entryName.substring(0, entryName.lastIndexOf('/'))\n                                .replace('/', '.'));\n                    }\n                }\n            }\n            return packages;\n        }\n    }\n\n    private static final class ExplodedModelMapperModuleReader implements ModuleReader {\n        private final Path classesDirectory;\n\n        private ExplodedModelMapperModuleReader(Path classesDirectory) {\n            this.classesDirectory = classesDirectory;\n        }\n\n        @Override\n        public Optional<URI> find(String name) {\n            Path path = classesDirectory.resolve(name);\n            if (Files.isRegularFile(path)) {\n                return Optional.of(path.toUri());\n            }\n            return Optional.empty();\n        }\n\n        @Override\n        public Optional<ByteBuffer> read(String name) throws IOException {\n            Path path = classesDirectory.resolve(name);\n            if (Files.isRegularFile(path)) {\n                return Optional.of(ByteBuffer.wrap(Files.readAllBytes(path)));\n            }\n            return Optional.empty();\n        }\n\n        @Override\n        public void release(ByteBuffer byteBuffer) {\n        }\n\n        @Override\n        public Stream<String> list() throws IOException {\n            return Files.walk(classesDirectory)\n                    .filter(Files::isRegularFile)\n                    .map(path -> classesDirectory.relativize(path).toString()\n                            .replace(File.separatorChar, '/'));\n        }\n\n        @Override\n        public void close() {\n        }\n    }\n\n    private static final class ChildFirstClassLoader extends URLClassLoader {\n"}]}
