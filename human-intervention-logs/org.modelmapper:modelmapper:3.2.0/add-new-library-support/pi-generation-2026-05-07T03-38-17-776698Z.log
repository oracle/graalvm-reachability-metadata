 java.io.IOException;\nimport java.lang.module.Configuration;\nimport java.lang.module.ModuleFinder;\nimport java.lang.module.ModuleReference;\nimport java.lang.reflect.InvocationTargetException;\nimport java.lang.reflect.Method;\nimport java.net.JarURLConnection;\nimport java.net.URI;\nimport java.net.URISyntaxException;\nimport java.net.URL;\nimport java.net.URLClassLoader;\nimport java.nio.file.Files;\nimport java.nio.file.Path;\nimport java.nio.file.Paths;\nimport java.util.Enumeration;\nimport java.util.Set;\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.MethodOrderer.OrderAnnotation;\nimport org.junit.jupiter.api.Order;\nimport org.junit.jupiter.api.Test;\nimport org.junit.jupiter.api.TestMethodOrder;\nimport org.modelmapper.internal.bytebuddy.dynamic.NexusAccessor.Dispatcher;\nimport org.modelmapper.internal.bytebuddy.dynamic.NexusAccessor.Dispatcher.CreationAction;\n\n@TestMethodOrder(OrderAnnotation.class)\npublic class NexusAccessorInnerDispatcherInnerCreationActionTest {\n    private static final String BYTE_BUDDY_SAFE_PROPERTY =\n            \"org.modelmapper.internal.bytebuddy.safe\";\n    private static final String NEXUS_DISABLED_PROPERTY =\n            \"org.modelmapper.internal.bytebuddy.nexus.disabled\";\n    private static final String CREATION_ACTION_CLASS_NAME =\n            \"org.modelmapper.internal.bytebuddy.dynamic.NexusAccessor$Dispatcher$CreationAction\";\n    private static final String SCENARIO_CLASS_NAME =\n            InjectionCreationActionScenario.class.getName();\n\n    @Test\n    @Order(1)\n    void createsDispatcherByInjectingNexusIntoSystemClassLoader() throws Exception {\n        try {\n            runInIsolatedModelMapperLoader();\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    @Test\n    @Order(2)\n    void createsDispatcherFromSystemLoadedNexusInNamedModuleFallback() throws Exception {\n        try {\n            runInNamedModelMapperModule();\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    private static void runInIsolatedModelMapperLoader() throws Exception {\n        Class<?> testClass = NexusAccessorInnerDispatcherInnerCreationActionTest.class;\n        URL testClassesUrl = testClass.getProtectionDomain().getCodeSource().getLocation();\n        try (ChildFirstClassLoader classLoader = new ChildFirstClassLoader(\n                new URL[] {testClassesUrl, modelMapperCodeSourceUrl()},\n                ClassLoader.getSystemClassLoader())) {\n            Class<?> scenarioClass = classLoader.loadClass(SCENARIO_CLASS_NAME);\n            Runnable scenario = (Runnable) scenarioClass.getConstructor().newInstance();\n            scenario.run();\n        } catch (InvocationTargetException exception) {\n            throw targetException(exception);\n        }\n    }\n\n    private static void runInNamedModelMapperModule() throws Exception {\n        String previousSafeValue = System.setProperty(BYTE_BUDDY_SAFE_PROPERTY, \"true\");\n        String previousDisabledValue = System.clearProperty(NEXUS_DISABLED_PROPERTY);\n        try {\n            ModuleFinder finder = ModuleFinder.of(modelMapperJarPath());\n            ModuleReference moduleReference = finder.findAll().stream().findFirst().orElseThrow(\n                    () -> new AssertionError(\"ModelMapper module was not found\"));\n            String moduleName = moduleReference.descriptor().name();\n            ModuleLayer parentLayer = ModuleLayer.boot();\n            Configuration configuration = parentLayer.configuration()\n                    .resolve(finder, ModuleFinder.of(), Set.of(moduleName));\n            ModuleLayer layer = parentLayer.defineModulesWithOneLoader(\n                    configuration,\n                    ClassLoader.getPlatformClassLoader());\n            Class<?> actionClass = layer.findLoader(moduleName).loadClass(\n                    CREATION_ACTION_CLASS_NAME);\n            Object action = enumConstant(actionClass, \"INSTANCE\");\n            Object dispatcher = actionClass.getMethod(\"run\").invoke(action);\n            Method isAlive = dispatcher.getClass().getMethod(\"isAlive\");\n            assertThat(isAlive.invoke(dispatcher)).isEqualTo(Boolean.TRUE);\n        } catch (InvocationTargetException exception) {\n            throw targetException(exception);\n        } finally {\n            restoreProperty(BYTE_BUDDY_SAFE_PROPERTY, previousSafeValue);\n            restoreProperty(NEXUS_DISABLED_PROPERTY, previousDisabledValue);\n        }\n    }\n\n    @SuppressWarnings({\"rawtypes\", \"unchecked\"})\n    private static Object enumConstant(Class<?> enumClass, String name) {\n        return Enum.valueOf((Class<? extends Enum>) enumClass.asSubclass(Enum.class), name);\n    }\n\n    private static Exception targetException(InvocationTargetException exception) throws Exception {\n        Throwable target = exception.getTargetException();\n        if (target instanceof Exception) {\n            return (Exception) target;\n        }\n        if (target instanceof Error) {\n            throw (Error) target;\n        }\n        return exception;\n    }\n\n    private static URL modelMapperCodeSourceUrl() throws IOException {\n        Enumeration<URL> resources = ClassLoader.getSystemResources(\n                \"org/modelmapper/ModelMapper.class\");\n        URL fallback = null;\n        while (resources.hasMoreElements()) {\n            URL resource = resources.nextElement();\n            URL rootUrl = resourceRootUrl(resource);\n            if (rootUrl.toString().contains(\"/build/jacoco/effective/\")) {\n                return rootUrl;\n            }\n            if (fallback == null) {\n                fallback = rootUrl;\n            }\n        }\n        assertThat(fallback).as(\"ModelMapper class resource\").isNotNull();\n        return fallback;\n    }\n\n    private static Path modelMapperJarPath() throws IOException, URISyntaxException {\n        for (String entry : System.getProperty(\"java.class.path\", \"\")\n                .split(File.pathSeparator)) {\n            if (!entry.isEmpty()) {\n                Path path = Paths.get(entry);\n                String fileName = path.getFileName() == null ? \"\" : path.getFileName().toString();\n                if (Files.isRegularFile(path)\n                        && fileName.startsWith(\"modelmapper-\")\n                        && fileName.endsWith(\".jar\")) {\n                    return path;\n                }\n            }\n        }\n\n        Enumeration<URL> resources = ClassLoader.getSystemResources(\n                \"org/modelmapper/ModelMapper.class\");\n        while (resources.hasMoreElements()) {\n            URL resource = resources.nextElement();\n            if (\"jar\".equals(resource.getProtocol())) {\n                URI uri = ((JarURLConnection) resource.openConnection()).getJarFileURL().toURI();\n                return Paths.get(uri);\n            }\n        }\n        throw new AssertionError(\"ModelMapper jar was not found on the test class path\");\n    }\n\n    private static URL resourceRootUrl(URL resource) throws IOException {\n        if (\"jar\".equals(resource.getProtocol())) {\n            return ((JarURLConnection) resource.openConnection()).getJarFileURL();\n        }\n        String path = resource.toString();\n        String suffix = \"org/modelmapper/ModelMapper.class\";\n        assertThat(path).endsWith(suffix);\n        return new URL(path.substring(0, path.length() - suffix.length()));\n    }\n\n    private static void restoreProperty(String name, String value) {\n        if (value == null) {\n            System.clearProperty(name);\n        } else {\n            System.setProperty(name, value);\n        }\n    }\n\n    public static final class InjectionCreationActionScenario implements Runnable {\n        public InjectionCreationActionScenario() {\n        }\n\n        @Override\n        public void run() {\n            String previousSafeValue = System.setProperty(BYTE_BUDDY_SAFE_PROPERTY, \"false\");\n            String previousDisabledValue = System.clearProperty(NEXUS_DISABLED_PROPERTY);\n            try {\n                Dispatcher dispatcher = CreationAction.INSTANCE.run();\n                if (!dispatcher.isAlive()) {\n                    throw new AssertionError(\"Nexus dispatcher should be available\");\n                }\n            } finally {\n                restoreProperty(BYTE_BUDDY_SAFE_PROPERTY, previousSafeValue);\n                restoreProperty(NEXUS_DISABLED_PROPERTY, previousDisabledValue);\n            }\n        }\n    }\n\n    private static final class ChildFirstClassLoader extends URLClassLoader {\n        private ChildFirstClassLoader(URL[] urls, ClassLoader parent) {\n            super(urls, parent);\n        }\n\n        @Override\n        protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {\n            synchronized (getClassLoadingLock(name)) {\n                Class<?> loadedClass = findLoadedClass(name);\n                if (loadedClass == null && shouldLoadChildFirst(name)) {\n                    try {\n                        loadedClass = findClass(name);\n                    } catch (ClassNotFoundException ignored) {\n                        loadedClass = super.loadClass(name, false);\n                    }\n                } else if (loadedClass == null) {\n                    loadedClass = super.loadClass(name, false);\n                }\n                if (resolve) {\n                    resolveClass(loadedClass);\n                }\n                return loadedClass;\n            }\n        }\n\n        private static boolean shouldLoadChildFirst(String name) {\n            return name.startsWith(\"org.modelmapper.\")\n                    || name.equals(SCENARIO_CLASS_NAME)\n                    || name.startsWith(SCENARIO_CLASS_NAME + Character.toString((char) 36));\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1545, "output": 4351, "cacheRead": 26624, "cacheWrite": 0, "totalTokens": 32520, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778124984433, "responseId": "resp_06417f7ca03b05b00169fc08b904d0819095fd8320b823e99c"}}
[tool-exec] start id=call_2J2KGT1FZpibSfRg9IoXxH1D|fc_06417f7ca03b05b00169fc08d67bd08190a9f8375e40095d04 name=write args={"path": "tests/src/org.modelmapper/modelmapper/3.2.0/src/test/java/org_modelmapper/modelmapper/NexusAccessorInnerDispatcherInnerCreationActionTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_modelmapper.modelmapper;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.File;\nimport java.io.IOException;\nimport java.lang.module.Configuration;\nimport java.lang.module.ModuleFinder;\nimport java.lang.module.ModuleReference;\nimport java.lang.reflect.InvocationTargetException;\nimport java.lang.reflect.Method;\nimport java.net.JarURLConnection;\nimport java.net.URI;\nimport java.net.URISyntaxException;\nimport java.net.URL;\nimport java.net.URLClassLoader;\nimport java.nio.file.Files;\nimport java.nio.file.Path;\nimport java.nio.file.Paths;\nimport java.util.Enumeration;\nimport java.util.Set;\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.MethodOrderer.OrderAnnotation;\nimport org.junit.jupiter.api.Order;\nimport org.junit.jupiter.api.Test;\nimport org.junit.jupiter.api.TestMethodOrder;\nimport org.modelmapper.internal.bytebuddy.dynamic.NexusAccessor.Dispatcher;\nimport org.modelmapper.internal.bytebuddy.dynamic.NexusAccessor.Dispatcher.CreationAction;\n\n@TestMethodOrder(OrderAnnotation.class)\npublic class NexusAccessorInnerDispatcherInnerCreationActionTest {\n    private static final String BYTE_BUDDY_SAFE_PROPERTY =\n            \"org.modelmapper.internal.bytebuddy.safe\";\n    private static final String NEXUS_DISABLED_PROPERTY =\n            \"org.modelmapper.internal.bytebuddy.nexus.disabled\";\n    private static final String CREATION_ACTION_CLASS_NAME =\n            \"org.modelmapper.internal.bytebuddy.dynamic.NexusAccessor$Dispatcher$CreationAction\";\n    private static final String SCENARIO_CLASS_NAME =\n            InjectionCreationActionScenario.class.getName();\n\n    @Test\n    @Order(1)\n    void createsDispatcherByInjectingNexusIntoSystemClassLoader() throws Exception {\n        try {\n            runInIsolatedModelMapperLoader();\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    @Test\n    @Order(2)\n    void createsDispatcherFromSystemLoadedNexusInNamedModuleFallback() throws Exception {\n        try {\n            runInNamedModelMapperModule();\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    private static void runInIsolatedModelMapperLoader() throws Exception {\n        Class<?> testClass = NexusAccessorInnerDispatcherInnerCreationActionTest.class;\n        URL testClassesUrl = testClass.getProtectionDomain().getCodeSource().getLocation();\n        try (ChildFirstClassLoader classLoader = new ChildFirstClassLoader(\n                new URL[] {testClassesUrl, modelMapperCodeSourceUrl()},\n                ClassLoader.getSystemClassLoader())) {\n            Class<?> scenarioClass = classLoader.loadClass(SCENARIO_CLASS_NAME);\n            Runnable scenario = (Runnable) scenarioClass.getConstructor().newInstance();\n            scenario.run();\n        } catch (InvocationTargetException exception) {\n            throw targetException(exception);\n        }\n    }\n\n    private static void runInNamedModelMapperModule() throws Exception {\n        String previousSafeValue = System.setProperty(BYTE_BUDDY_SAFE_PROPERTY, \"true\");\n        String previousDisabledValue = System.clearProperty(NEXUS_DISABLED_PROPERTY);\n        try {\n            ModuleFinder finder = ModuleFinder.of(modelMapperJarPath());\n            ModuleReference moduleReference = finder.findAll().stream().findFirst().orElseThrow(\n                    () -> new AssertionError(\"ModelMapper module was not found\"));\n            String moduleName = moduleReference.descriptor().name();\n            ModuleLayer parentLayer = ModuleLayer.boot();\n            Configuration configuration = parentLayer.configuration()\n                    .resolve(finder, ModuleFinder.of(), Set.of(moduleName));\n            ModuleLayer layer = parentLayer.defineModulesWithOneLoader(\n                    configuration,\n                    ClassLoader.getPlatformClassLoader());\n            Class<?> actionClass = layer.findLoader(moduleName).loadClass(\n                    CREATION_ACTION_CLASS_NAME);\n            Object action = enumConstant(actionClass, \"INSTANCE\");\n            Object dispatcher = actionClass.getMethod(\"run\").invoke(action);\n            Method isAlive = dispatcher.getClass().getMethod(\"isAlive\");\n            assertThat(isAlive.invoke(dispatcher)).isEqualTo(Boolean.TRUE);\n        } catch (InvocationTargetException exception) {\n            throw targetException(exception);\n        } finally {\n            restoreProperty(BYTE_BUDDY_SAFE_PROPERTY, previousSafeValue);\n            restoreProperty(NEXUS_DISABLED_PROPERTY, previousDisabledValue);\n        }\n    }\n\n    @SuppressWarnings({\"rawtypes\", \"unchecked\"})\n    private static Object enumConstant(Class<?> enumClass, String name) {\n        return Enum.valueOf((Class<? extends Enum>) enumClass.asSubclass(Enum.class), name);\n    }\n\n    private static Exception targetException(InvocationTargetException exception) throws Exception {\n        Throwable target = exception.getTargetException();\n        if (target instanceof Exception) {\n            return (Exception) target;\n        }\n        if (target instanceof Error) {\n            throw (Error) target;\n        }\n        return exception;\n    }\n\n    private static URL modelMapperCodeSourceUrl() throws IOException {\n        Enumeration<URL> resources = ClassLoader.getSystemResources(\n                \"org/modelmapper/ModelMapper.class\");\n        URL fallback = null;\n        while (resources.hasMoreElements()) {\n            URL resource = resources.nextElement();\n            URL rootUrl = resourceRootUrl(resource);\n            if (rootUrl.toString().contains(\"/build/jacoco/effective/\")) {\n                return rootUrl;\n            }\n            if (fallback == null) {\n                fallback = rootUrl;\n            }\n        }\n        assertThat(fallback).as(\"ModelMapper class resource\").isNotNull();\n        return fallback;\n    }\n\n    private static Path modelMapperJarPath() throws IOException, URISyntaxException {\n        for (String entry : System.getProperty(\"java.class.path\", \"\")\n                .split(File.pathSeparator)) {\n            if (!entry.isEmpty()) {\n                Path path = Paths.get(entry);\n                String fileName = path.getFileName() == null ? \"\" : path.getFileName().toString();\n                if (Files.isRegularFile(path)\n                        && fileName.startsWith(\"modelmapper-\")\n                        && fileName.endsWith(\".jar\")) {\n                    return path;\n                }\n            }\n        }\n\n        Enumeration<URL> resources = ClassLoader.getSystemResources(\n                \"org/modelmapper/ModelMapper.class\");\n        while (resources.hasMoreElements()) {\n            URL resource = resources.nextElement();\n            if (\"jar\".equals(resource.getProtocol())) {\n                URI uri = ((JarURLConnection) resource.openConnection()).getJarFileURL().toURI();\n                return Paths.get(uri);\n            }\n        }\n        throw new AssertionError(\"ModelMapper jar was not found on the test class path\");\n    }\n\n    private static URL resourceRootUrl(URL resource) throws IOException {\n        if (\"jar\".equals(resource.getProtocol())) {\n            return ((JarURLConnection) resource.openConnection()).getJarFileURL();\n        }\n        String path = resource.toString();\n        String suffix = \"org/modelmapper/ModelMapper.class\";\n        assertThat(path).endsWith(suffix);\n        return new URL(path.substring(0, path.length() - suffix.length()));\n    }\n\n    private static void restoreProperty(String name, String value) {\n        if (value == null) {\n            System.clearProperty(name);\n        } else {\n            System.setProperty(name, value);\n        }\n    }\n\n    public static final class InjectionCreationActionScenario implements Runnable {\n        public InjectionCreationActionScenario() {\n        }\n\n        @Override\n        public void run() {\n            String previousSafeValue = System.setProperty(BYTE_BUDDY_SAFE_PROPERTY, \"false\");\n            String previousDisabledValue = System.clearProperty(NEXUS_DISABLED_PROPERTY);\n            try {\n                Dispatcher dispatcher = CreationAction.INSTANCE.run();\n                if (!dispatcher.isAlive()) {\n                    throw new AssertionError(\"Nexus dispatcher should be available\");\n                }\n            } finally {\n                restoreProperty(BYTE_BUDDY_SAFE_PROPERTY, previousSafeValue);\n                restoreProperty(NEXUS_DISABLED_PROPERTY, previousDisabledValue);\n            }\n        }\n    }\n\n    private static final class ChildFirstClassLoader extends URLClassLoader {\n        private ChildFirstClassLoader(URL[] urls, ClassLoader parent) {\n            super(urls, parent);\n        }\n\n        @Override\n        protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {\n            synchronized (getClassLoadingLock(name)) {\n                Class<?> loadedClass = findLoadedClass(name);\n                if (loadedClass == null && shouldLoadChildFirst(name)) {\n                    try {\n                        loadedClass = findClass(name);\n                    } catch (ClassNotFoundException ignored) {\n                        loadedClass = super.loadClass(name, false);\n                    }\n                } else if (loadedClass == null) {\n                    loadedClass = super.loadClass(name, false);\n                }\n                if (resolve) {\n                    resolveClass(loadedClass);\n                }\n                return loadedClass;\n            }\n        }\n\n        private static boolean shouldLoadChildFirst(String name) {\n            return name.startsWith(\"org.modelmapper.\")\n                    || name.equals(SCENARIO_CLASS_NAME)\n                    || name.startsWith(SCENARIO_CLASS_NAME + Character.toString((char) 36));\n        }\n    }\n}\n"}
