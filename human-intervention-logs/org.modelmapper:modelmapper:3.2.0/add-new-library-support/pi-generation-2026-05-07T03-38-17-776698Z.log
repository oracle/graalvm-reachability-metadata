          public InjectionCreationActionScenario() {
          }
  
          @Override
          public void run() {
              String safeProperty = "org.modelmapper.internal.bytebuddy.safe";
              String disabledProperty = "org.modelmapper.internal.bytebuddy.nexus.disabled";
              String previousSafeValue = System.setProperty(safeProperty, "false");
              String previousDisabledValue = System.clearProperty(disabledProperty);
              try {
                  if (!CreationActionAccess.runCreationAction()) {
                      throw new AssertionError("Nexus dispatcher should be available");
                  }
              } finally {
                  restoreProperty(safeProperty, previousSafeValue);
                  restoreProperty(disabledProperty, previousDisabledValue);
              }
          }
  
          private static void restoreProperty(String name, String value) {
              if (value == null) {
                  System.clearProperty(name);
              } else {
                  System.setProperty(name, value);
              }
          }
      }
  
