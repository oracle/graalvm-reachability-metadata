(String.class.getName());\n\n        assertThat(loadedType).isSameAs(String.class);\n        assertThat(failingParent.getRequests()).containsExactly(String.class.getName());\n        assertThat(bootstrapParent.getRequests()).containsExactly(String.class.getName());\n    }\n\n    @Test\n    void returnsResourcesFromParentsBeforeDelegatingToOwnParent() throws Exception {\n        URL parentResource = new URL(\"file\", \"\", \"/parent-modelmapper-resource.class\");\n        ResourceClassLoader resourceParent = new ResourceClassLoader(\n                TEST_CLASS_RESOURCE,\n                parentResource);\n        MultipleParentClassLoader classLoader = new MultipleParentClassLoader(\n                getClass().getClassLoader(),\n                Collections.singletonList(resourceParent),\n                false);\n\n        assertThat(classLoader.getResource(TEST_CLASS_RESOURCE)).isEqualTo(parentResource);\n\n        List<URL> resources = Collections.list(classLoader.getResources(TEST_CLASS_RESOURCE));\n        assertThat(resources).isNotEmpty();\n        assertThat(resources.get(0)).isEqualTo(parentResource);\n        assertThat(resources).anySatisfy(resource -> assertThat(resource).isNotEqualTo(parentResource));\n    }\n\n    private static final class RecordingClassLoader extends ClassLoader {\n        private final List<String> requests = new ArrayList<>();\n        private final boolean failing;\n\n        private RecordingClassLoader(boolean failing) {\n            super(null);\n            this.failing = failing;\n        }\n\n        private static RecordingClassLoader failing() {\n            return new RecordingClassLoader(true);\n        }\n\n        private static RecordingClassLoader delegatingToBootstrap() {\n            return new RecordingClassLoader(false);\n        }\n\n        @Override\n        public Class<?> loadClass(String name) throws ClassNotFoundException {\n            requests.add(name);\n            if (failing) {\n                throw new ClassNotFoundException(name);\n            }\n            return super.loadClass(name);\n        }\n\n        private List<String> getRequests() {\n            return requests;\n        }\n    }\n\n    private static final class ResourceClassLoader extends ClassLoader {\n        private final String resourceName;\n        private final URL resource;\n\n        private ResourceClassLoader(String resourceName, URL resource) {\n            super(null);\n            this.resourceName = resourceName;\n            this.resource = resource;\n        }\n\n        @Override\n        public URL getResource(String name) {\n            if (resourceName.equals(name)) {\n                return resource;\n            }\n            return super.getResource(name);\n        }\n\n        @Override\n        public Enumeration<URL> getResources(String name) throws IOException {\n            if (resourceName.equals(name)) {\n                return Collections.enumeration(Collections.singleton(resource));\n            }\n            return super.getResources(name);\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778141032415}]}
