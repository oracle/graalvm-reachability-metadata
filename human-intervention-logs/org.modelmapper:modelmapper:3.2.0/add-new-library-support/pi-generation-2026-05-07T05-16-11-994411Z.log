                  ModuleLayer layer = ModuleLayer.boot().defineModulesWithOneLoader(
                          configuration,
                          ClassLoader.getPlatformClassLoader());
                  Callable<?> callable = ServiceLoader.load(layer, Callable.class)
                          .findFirst()
                          .orElseThrow();
  
                  assertThat(callable.call()).isEqualTo("resolved");
              } finally {
                  deleteRecursively(temporaryDirectory);
              }
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
      }
  
      private static void defineInstallerModule(Path temporaryDirectory)
              throws IOException, ClassNotFoundException {
