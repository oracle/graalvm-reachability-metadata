l classes from the effective directory and jar it in a temporary location. That feels like a good start! However, I might have to ensure that the code source path is valid in the native image or catch any errors that arise. The URI path could be an issue, and if the AgentBuilder code source is null, that could complicate things. So, I think it’s best to wrap the entire test in a try-catch for errors.\"}]}"}, {"type": "toolCall", "id": "call_FQT2kAkmBN1j3NAyUYXD1Pfr|fc_01e59afe7f0611f70169fc1f99a03c819fb3ffff5918e5f4df", "name": "write", "arguments": {"path": "tests/src/org.modelmapper/modelmapper/3.2.0/src/test/java/org_modelmapper/modelmapper/AgentBuilderInnerDefaultTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_modelmapper.modelmapper;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.IOException;\nimport java.io.UncheckedIOException;\nimport java.lang.instrument.Instrumentation;\nimport java.lang.module.Configuration;\nimport java.lang.module.ModuleFinder;\nimport java.net.URISyntaxException;\nimport java.nio.file.Files;\nimport java.nio.file.Path;\nimport java.security.CodeSource;\nimport java.util.Base64;\nimport java.util.Comparator;\nimport java.util.ServiceLoader;\nimport java.util.Set;\nimport java.util.concurrent.Callable;\nimport java.util.jar.JarEntry;\nimport java.util.jar.JarOutputStream;\nimport java.util.stream.Stream;\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\nimport org.modelmapper.internal.bytebuddy.ByteBuddy;\nimport org.modelmapper.internal.bytebuddy.agent.builder.AgentBuilder;\nimport org.modelmapper.internal.bytebuddy.dynamic.loading.ClassLoadingStrategy;\nimport org.modelmapper.internal.bytebuddy.implementation.FixedValue;\nimport org.modelmapper.internal.bytebuddy.description.modifier.Ownership;\nimport org.modelmapper.internal.bytebuddy.description.modifier.Visibility;\n\npublic class AgentBuilderInnerDefaultTest {\n    private static final String INSTALLER_TYPE =\n            \"org.modelmapper.internal.bytebuddy.agent.Installer\";\n    private static final String DRIVER_MODULE =\n            \"org.modelmapper.agentbuilder.driver\";\n\n    @Test\n    void resolvesInstrumentationFromSystemInstallerForNamedAgentBuilderModule()\n            throws Exception {\n        try {\n            ensureFakeInstallerOnSystemClassLoader();\n            Path temporaryDirectory = Files.createTempDirectory(\"agentbuilder-default\");\n            try {\n                Path modelMapperModule = modelMapperModulePath(temporaryDirectory);\n                Path driverModule = driverModulePath(temporaryDirectory);\n                ModuleFinder finder = ModuleFinder.of(modelMapperModule, driverModule);\n                Configuration configuration = ModuleLayer.boot()\n                        .configuration()\n                        .resolve(finder, ModuleFinder.of(), Set.of(DRIVER_MODULE));\n                ModuleLayer layer = ModuleLayer.boot().defineModulesWithOneLoader(\n                        configuration,\n                        ClassLoader.getPlatformClassLoader());\n                Callable<?> callable = ServiceLoader.load(layer, Callable.class)\n                        .findFirst()\n                        .orElseThrow();\n\n                assertThat(callable.call()).isEqualTo(\"resolved\");\n            } finally {\n                deleteRecursively(temporaryDirectory);\n            }\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    private static void ensureFakeInstallerOnSystemClassLoader()\n            throws ClassNotFoundException {\n        ClassLoader systemClassLoader = ClassLoader.getSystemClassLoader();\n        try {\n            systemClassLoader.loadClass(INSTALLER_TYPE);\n        } catch (ClassNotFoundException missingInstaller) {\n            new ByteBuddy()\n                    .subclass(Object.class)\n                    .name(INSTALLER_TYPE)\n                    .defineMethod(\n                            \"getInstrumentation\",\n                            Instrumentation.class,\n                            Visibility.PUBLIC,\n                            Ownership.STATIC)\n                    .intercept(FixedValue.nullValue())\n                    .make()\n                    .load(systemClassLoader, ClassLoadingStrategy.Default.INJECTION);\n            systemClassLoader.loadClass(INSTALLER_TYPE);\n        }\n    }\n\n    private static Path modelMapperModulePath(Path temporaryDirectory)\n            throws IOException, URISyntaxException {\n        CodeSource codeSource = AgentBuilder.class\n                .getProtectionDomain()\n                .getCodeSource();\n        Path location = Path.of(codeSource.getLocation().toURI());\n        if (Files.isRegularFile(location)) {\n            return location;\n        }\n        Path modelMapperJar = temporaryDirectory.resolve(\"modelmapper-module.jar\");\n        try (JarOutputStream output = new JarOutputStream(\n                Files.newOutputStream(modelMapperJar));\n                Stream<Path> entries = Files.walk(location)) {\n            entries.filter(Files::isRegularFile)\n                    .sorted()\n                    .forEach(path -> addJarEntry(output, location, path));\n        }\n        return modelMapperJar;\n    }\n\n    private static Path driverModulePath(Path temporaryDirectory) throws IOException {\n        Path driverJar = temporaryDirectory.resolve(\"agentbuilder-driver.jar\");\n        try (JarOutputStream output = new JarOutputStream(\n                Files.newOutputStream(driverJar))) {\n            addJarEntry(output, \"module-info.class\", driverModuleInfoBytes());\n            addJarEntry(\n                    output,\n                    \"driver/AgentBuilderDriver.class\",\n                    driverClassBytes());\n        }\n        return driverJar;\n    }\n\n    private static void addJarEntry(\n            JarOutputStream output,\n            Path root,\n            Path path) {\n        String name = root.relativize(path).toString().replace('\\\\', '/');\n        try {\n            addJarEntry(output, name, Files.readAllBytes(path));\n        } catch (IOException exception) {\n            throw new UncheckedIOException(exception);\n        }\n    }\n\n    private static void addJarEntry(\n            JarOutputStream output,\n            String name,\n            byte[] bytes) throws IOException {\n        output.putNextEntry(new JarEntry(name));\n        output.write(bytes);\n        output.closeEntry();\n    }\n\n    private static void deleteRecursively(Path directory) throws IOException {\n        try (Stream<Path> paths = Files.walk(directory)) {\n            paths.sorted(Comparator.reverseOrder()).forEach(path -> {\n                try {\n                    Files.deleteIfExists(path);\n                } catch (IOException exception) {\n                    throw new UncheckedIOException(exception);\n                }\n            });\n        } catch (UncheckedIOException exception) {\n            throw exception.getCause();\n        }\n    }\n\n    private static byte[] driverModuleInfoBytes() {\n        return Base64.getMimeDecoder().decode(\"\"\"\n                yv66vgAAAEEAEQcAAgEAC21vZHVsZS1pbmZvAQAKU291cmNlRmlsZQEAEG1vZHVs\n                ZS1pbmZvLmphdmEBAAZNb2R1bGUTAAcBACNvcmcubW9kZWxtYXBwZXIuYWdlbnRi\n                dWlsZGVyLmRyaXZlchMACQEACWphdmEuYmFzZQEAAjIxEwAMAQALbW9kZWxtYXBw\n                ZXIHA14BAB1qYXZhL3V0aWwvY29uY3VycmVudC9DYWxsYWJsZQcAEAEAGWRyaXZl\n                ci9BZ2VudEJ1aWxkZXJEcml2ZXKAAAABAAAAAAAAAAAAAgADAAAAAgAEAAUAAAAi\n                AAYAAAAAAAIACIAAAAoACwAAAAAAAAAAAAAAAQANAAEADw==\n                \"\"\");\n    }\n\n    private static byte[] driverClassBytes() {\n        return Base64.getMimeDecoder().decode(\"\"\"\n                yv66vgAAAEEAMAoAAgADBwAEDAAFAAYBABBqYXZhL2xhbmcvT2JqZWN0AQAGPGlu\n                aXQ+AQADKClWBwAIAQBFb3JnL21vZGVsbWFwcGVyL2ludGVybmFsL2J5dGVidWRk\n                eS9hZ2VudC9idWlsZGVyL0FnZW50QnVpbGRlciREZWZhdWx0CgAHAAMKAAcACwwA\n                DAANAQAXaW5zdGFsbE9uQnl0ZUJ1ZGR5QWdlbnQBAFMoKUxvcmcvbW9kZWxtYXBw\n                ZXIvaW50ZXJuYWwvYnl0ZWJ1ZGR5L2FnZW50L2J1aWxkZXIvUmVzZXR0YWJsZUNs\n                YXNzRmlsZVRyYW5zZm9ybWVyOwcADwEAGGphdmEvbGFuZy9Bc3NlcnRpb25FcnJv\n                cggAEQEAOkV4cGVjdGVkIHRoZSBmYWtlIGluc3RhbGxlciB0byByZXR1cm4gbnVs\n                bCBpbnN0cnVtZW50YXRpb24KAA4AEwwABQAUAQAVKExqYXZhL2xhbmcvT2JqZWN0\n                OylWBwAWAQAeamF2YS9sYW5nL051bGxQb2ludGVyRXhjZXB0aW9uCAAYAQAIcmVz\n                b2x2ZWQKABoAGwcAHAwAHQAeAQAZZHJpdmVyL0FnZW50QnVpbGRlckRyaXZlcgEA\n                BGNhbGwBABQoKUxqYXZhL2xhbmcvU3RyaW5nOwcAIAEAHWphdmEvdXRpbC9jb25j\n                dXJyZW50L0NhbGxhYmxlAQAEQ29kZQEAD0xpbmVOdW1iZXJUYWJsZQEADVN0YWNr\n                TWFwVGFibGUBABQoKUxqYXZhL2xhbmcvT2JqZWN0OwEACkV4Y2VwdGlvbnMHACcB\n                ABNqYXZhL2xhbmcvRXhjZXB0aW9uAQAJU2lnbmF0dXJlAQBFTGphdmEvbGFuZy9P\n                YmplY3Q7TGphdmEvdXRpbC9jb25jdXJyZW50L0NhbGxhYmxlPExqYXZhL2xhbmcv\n                U3RyaW5nOz47AQAKU291cmNlRmlsZQEAF0FnZW50QnVpbGRlckRyaXZlci5qYXZh\n                AQAMSW5uZXJDbGFzc2VzBwAuAQA9b3JnL21vZGVsbWFwcGVyL2ludGVybmFsL2J5\n                dGVidWRkeS9hZ2VudC9idWlsZGVyL0FnZW50QnVpbGRlcgEAB0RlZmF1bHQAMQAa\n                AAIAAQAfAAAAAwABAAUABgABACEAAAAdAAEAAQAAAAUqtwABsQAAAAEAIgAAAA\n                YAAQAAAAYAAQAdAB4AAQAhAAAAUQADAAIAAAAZuwAHWbcACbYACle7AA5ZEhC3\n                ABK/TBIXsAABAAAAFQAVABUAAgAiAAAAEgAEAAAACgALAAsAFQAMABYADQAjAA\n                AABgABVQcAFRBBAB0AJAACACEAAAAdAAEAAQAAAAUqtgAZsAAAAAEAIgAAAAYA\n                AQAAAAYAJQAAAAQAAQAmAAMAKAAAAAIAKQAqAAAAAgArACwAAAAKAAEABwAtAC\n