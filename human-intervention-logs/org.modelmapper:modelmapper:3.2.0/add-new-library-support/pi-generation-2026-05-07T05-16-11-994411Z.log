          ModuleFinder finder = ModuleFinder.of(installerModule);
          Configuration configuration = ModuleLayer.boot()
                  .configuration()
                  .resolve(finder, ModuleFinder.of(), Set.of(INSTALLER_MODULE));
          ModuleLayer.defineModulesWithOneLoader(
                  configuration,
                  List.of(ModuleLayer.boot()),
                  ClassLoader.getSystemClassLoader());
          ClassLoader.getSystemClassLoader().loadClass(INSTALLER_TYPE);
      }
  
