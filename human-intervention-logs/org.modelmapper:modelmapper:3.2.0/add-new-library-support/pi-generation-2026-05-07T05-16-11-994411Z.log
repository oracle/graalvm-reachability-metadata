  package org_modelmapper.modelmapper;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.security.ProtectionDomain;
  import java.util.Collections;
  import java.util.Map;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  import org.modelmapper.internal.bytebuddy.ByteBuddy;
  import org.modelmapper.internal.bytebuddy.dynamic.DynamicType;
  import org.modelmapper.internal.bytebuddy.dynamic.loading.ClassInjector.UsingUnsafe;
  import org.modelmapper.internal.bytebuddy.dynamic.scaffold.subclass.ConstructorStrategy;
  
  public class ClassInjectorInnerUsingUnsafeInnerDispatcherInnerCreationActionTest {
      private static final String BYTE_BUDDY_SAFE_PROPERTY =
              "org.modelmapper.internal.bytebuddy.safe";
  
      @Test
      void createsUnsafeDispatcherThroughCreationAction() {
          String previousValue = System.setProperty(BYTE_BUDDY_SAFE_PROPERTY, "false");
          try {
              UnsafeCreationActionAccess.runScenario();
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          } finally {
              if (previousValue == null) {
                  System.clearProperty(BYTE_BUDDY_SAFE_PROPERTY);
              } else {
                  System.setProperty(BYTE_BUDDY_SAFE_PROPERTY, previousValue);
              }
          }
      }
  
      static Map<String, byte[]> generatedType(String className) {
          DynamicType.Unloaded<?> unloaded = new ByteBuddy()
                  .subclass(Object.class, ConstructorStrategy.Default.NO_CONSTRUCTORS)
                  .name(className)
                  .make();
          return Collections.singletonMap(className, unloaded.getBytes());
      }
  }
  
  class UnsafeCreationActionAccess extends UsingUnsafe {
      private UnsafeCreationActionAccess(ClassLoader classLoader) {
          super(classLoader);
      }
  
      static void runScenario() {
          Dispatcher.Initializable initializable = Dispatcher.CreationAction.INSTANCE.run();
          assertThat(initializable).isNotNull();
          if (initializable.isAvailable()) {
              Dispatcher dispatcher = initializable.initialize();
              assertThat(dispatcher).isNotNull();
              assertThat(defineGeneratedType(dispatcher).getName())
                      .isEqualTo("org_modelmapper.modelmapper.unsafecreation.GeneratedType");
          } else {
              assertThat(initializable.getClass().getName()).contains("Unavailable");
          }
      }
  
      private static Class<?> defineGeneratedType(Dispatcher dispatcher) {
          ClassLoader classLoader = new ClassLoader(
                  ClassInjectorInnerUsingUnsafeInnerDispatcherInnerCreationActionTest
                          .class
                          .getClassLoader()) {
          };
          String className = "org_modelmapper.modelmapper.unsafecreation.GeneratedType";
          Map<String, byte[]> generatedType =
                  ClassInjectorInnerUsingUnsafeInnerDispatcherInnerCreationActionTest
                          .generatedType(className);
          return dispatcher.defineClass(
                  classLoader,
                  className,
                  generatedType.get(className),
                  (ProtectionDomain) null);
