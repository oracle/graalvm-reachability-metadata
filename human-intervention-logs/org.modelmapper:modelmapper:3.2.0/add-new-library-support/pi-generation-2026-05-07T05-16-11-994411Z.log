\n                    .forEach(path -> addJarEntry(output, location, path));\n        }\n        return modelMapperJar;\n    }\n\n    private static Optional<Path> originalModelMapperJarFromClassPath() {\n        return Arrays.stream(System.getProperty(\"java.class.path\", \"\")\n                        .split(File.pathSeparator))\n                .map(Path::of)\n                .filter(Files::isRegularFile)\n                .filter(path -> path.getFileName()\n                        .toString()\n                        .matches(\"modelmapper-[^-]+\\\\.jar\"))\n                .findFirst();\n    }\n","newText":"        try (JarOutputStream output = new JarOutputStream(\n                Files.newOutputStream(modelMapperJar));\n                Stream<Path> entries = Files.walk(location)) {\n            addJarEntry(output, \"module-info.class\", modelMapperModuleInfoBytes());\n            entries.filter(Files::isRegularFile)\n                    .filter(path -> !location.relativize(path)\n                            .toString()\n                            .replace('\\\\', '/')\n                            .equals(\"module-info.class\"))\n                    .sorted()\n                    .forEach(path -> addJarEntry(output, location, path));\n        }\n        return modelMapperJar;\n    }\n"}]}
