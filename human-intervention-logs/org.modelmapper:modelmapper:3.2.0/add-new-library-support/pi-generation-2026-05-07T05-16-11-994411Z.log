  package org_modelmapper.modelmapper;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.lang.instrument.ClassFileTransformer;
  import java.lang.instrument.IllegalClassFormatException;
  import java.security.ProtectionDomain;
  import java.util.Collection;
  import java.util.Collections;
  import java.util.List;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  import org.modelmapper.internal.bytebuddy.agent.builder.LambdaFactory;
  
  public class LambdaFactoryTest {
      @Test
      void registersDelegatesAndReleasesLambdaFactoryTransformer() {
          RecordingTransformer transformer = new RecordingTransformer();
          RecordingLambdaClassFactory factory = new RecordingLambdaClassFactory(new byte[] {1, 2, 3});
  
          boolean registered = false;
          try {
              LambdaFactory.register(transformer, factory);
              registered = true;
  
              byte[] generatedBytes = LambdaFactory.make(
                      LambdaFactoryTest.class,
                      "createdLambda",
                      "invoked-type",
                      "sam-method-type",
                      "impl-method",
                      "instantiated-method-type",
                      true,
                      Collections.singletonList(Runnable.class),
                      Collections.singletonList("bridge-method-type"));
  
              assertThat(generatedBytes).containsExactly(1, 2, 3);
              assertThat(factory.caller).isSameAs(LambdaFactoryTest.class);
              assertThat(factory.invokedName).isEqualTo("createdLambda");
              assertThat(factory.invokedType).isEqualTo("invoked-type");
              assertThat(factory.samMethodType).isEqualTo("sam-method-type");
              assertThat(factory.implMethod).isEqualTo("impl-method");
              assertThat(factory.instantiatedMethodType).isEqualTo("instantiated-method-type");
              assertThat(factory.serializable).isTrue();
              assertThat(factory.markerInterfaces).containsExactly(Runnable.class);
              assertThat(factory.additionalBridges).hasSize(1);
              assertThat(factory.additionalBridges.get(0)).isEqualTo("bridge-method-type");
              assertThat(factory.classFileTransformers).contains(transformer);
              assertThat(LambdaFactory.CLASS_FILE_TRANSFORMERS).containsKey(transformer);
              LambdaFactory.release(transformer);
              assertThat(LambdaFactory.CLASS_FILE_TRANSFORMERS).doesNotContainKey(transformer);
              registered = false;
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          } finally {
              if (registered) {
                  releaseAfterFailure(transformer);
              }
          }
      }
  
      private static void releaseAfterFailure(ClassFileTransformer transformer) {
          try {
              LambdaFactory.release(transformer);
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
      }
  
      public static final class RecordingLambdaClassFactory {
          private final byte[] generatedBytes;
          private Object caller;
          private String invokedName;
          private Object invokedType;
          private Object samMethodType;
          private Object implMethod;
          private Object instantiatedMethodType;
          private boolean serializable;
          private List<Class<?>> markerInterfaces;
          private List<?> additionalBridges;
          private Collection<ClassFileTransformer> classFileTransformers;
  
          private RecordingLambdaClassFactory(byte[] generatedBytes) {
              this.generatedBytes = generatedBytes;
          }
  
          public byte[] make(
                  Object caller,
                  String invokedName,
                  Object invokedType,
                  Object samMethodType,
                  Object implMethod,
                  Object instantiatedMethodType,
                  boolean serializable,
                  List<Class<?>> markerInterfaces,
                  List<?> additionalBridges,
                  Collection<ClassFileTransformer> classFileTransformers) {
              this.caller = caller;
              this.invokedName = invokedName;
              this.invokedType = invokedType;
              this.samMethodType = samMethodType;
              this.implMethod = implMethod;
              this.instantiatedMethodType = instantiatedMethodType;
              this.serializable = serializable;
              this.markerInterfaces = markerInterfaces;
              this.additionalBridges = additionalBridges;
              this.classFileTransformers = classFileTransformers;
              return generatedBytes;
          }
      }
  
      private static final class RecordingTransformer implements ClassFileTransformer {
          @Override
          public byte[] transform(
                  ClassLoader loader,
                  String className,
                  Class<?> classBeingRedefined,
                  ProtectionDomain protectionDomain,
                  byte[] classfileBuffer) throws IllegalClassFormatException {
              return null;
          }
      }
  }
