  package org_modelmapper.modelmapper;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.lang.instrument.ClassFileTransformer;
  import java.security.ProtectionDomain;
  import java.util.Collection;
  import java.util.List;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  import org.modelmapper.internal.bytebuddy.agent.builder.LambdaFactory;
  
  public class LambdaFactoryTest {
      private static final byte[] GENERATED_CLASS = new byte[] {1, 2, 3, 4};
  
      @Test
      void registeredFactoryDispatchesLambdaClassFileCreationAndCanBeReleased() {
          NoOpTransformer transformer = new NoOpTransformer();
          RecordingLambdaClassFileFactory factory = new RecordingLambdaClassFileFactory(
                  GENERATED_CLASS);
          boolean registered = false;
          try {
              LambdaFactory.register(transformer, factory);
              registered = true;
  
              Object caller = new Object();
              Object invokedType = new Object();
              Object samMethodType = new Object();
              Object implMethod = new Object();
              Object instantiatedMethodType = new Object();
              List<Class<?>> markerInterfaces = List.of(Runnable.class);
              List<Object> additionalBridges = List.of("bridge");
  
              byte[] generated = LambdaFactory.make(
                      caller,
                      "lambda$mapped$0",
                      invokedType,
                      samMethodType,
                      implMethod,
                      instantiatedMethodType,
                      true,
                      markerInterfaces,
                      additionalBridges);
  
              assertThat(generated).containsExactly(GENERATED_CLASS);
              assertThat(factory.invocationCount()).isEqualTo(1);
              assertThat(factory.lastCaller()).isSameAs(caller);
              assertThat(factory.lastInvokedName()).isEqualTo("lambda$mapped$0");
              assertThat(factory.lastInvokedType()).isSameAs(invokedType);
              assertThat(factory.lastSamMethodType()).isSameAs(samMethodType);
              assertThat(factory.lastImplMethod()).isSameAs(implMethod);
              assertThat(factory.lastInstantiatedMethodType()).isSameAs(instantiatedMethodType);
              assertThat(factory.lastSerializable()).isTrue();
              assertThat(factory.lastMarkerInterfaces()).isSameAs(markerInterfaces);
              assertThat(factory.lastAdditionalBridges()).isSameAs(additionalBridges);
              assertThat(factory.lastClassFileTransformers()).contains(transformer);
  
              registered = false;
              LambdaFactory.release(transformer);
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          } finally {
              if (registered) {
                  LambdaFactory.release(transformer);
              }
          }
      }
  
      private static final class NoOpTransformer implements ClassFileTransformer {
          @Override
          public byte[] transform(
                  ClassLoader loader,
                  String className,
                  Class<?> classBeingRedefined,
                  ProtectionDomain protectionDomain,
                  byte[] classfileBuffer) {
              return null;
          }
      }
  
      public static final class RecordingLambdaClassFileFactory {
          private final byte[] generatedClass;
          private int invocationCount;
          private Object lastCaller;
          private String lastInvokedName;
          private Object lastInvokedType;
          private Object lastSamMethodType;
          private Object lastImplMethod;
          private Object lastInstantiatedMethodType;
          private boolean lastSerializable;
          private List<Class<?>> lastMarkerInterfaces;
          private List<?> lastAdditionalBridges;
          private Collection<ClassFileTransformer> lastClassFileTransformers;
  
          public RecordingLambdaClassFileFactory(byte[] generatedClass) {
              this.generatedClass = generatedClass;
          }
  
          public byte[] make(
                  Object caller,
                  String invokedName,
                  Object invokedType,
                  Object samMethodType,
                  Object implMethod,
                  Object instantiatedMethodType,
                  boolean serializable,
                  List<Class<?>> markerInterfaces,
                  List<?> additionalBridges,
                  Collection<ClassFileTransformer> classFileTransformers) {
              invocationCount++;
              lastCaller = caller;
              lastInvokedName = invokedName;
              lastInvokedType = invokedType;
              lastSamMethodType = samMethodType;
              lastImplMethod = implMethod;
              lastInstantiatedMethodType = instantiatedMethodType;
              lastSerializable = serializable;
              lastMarkerInterfaces = markerInterfaces;
              lastAdditionalBridges = additionalBridges;
              lastClassFileTransformers = classFileTransformers;
              return generatedClass;
          }
  
          int invocationCount() {
              return invocationCount;
          }
  
          Object lastCaller() {
              return lastCaller;
          }
  
          String lastInvokedName() {
              return lastInvokedName;
          }
  
          Object lastInvokedType() {
              return lastInvokedType;
          }
  
          Object lastSamMethodType() {
              return lastSamMethodType;
          }
  
          Object lastImplMethod() {
              return lastImplMethod;
          }
  
          Object lastInstantiatedMethodType() {
              return lastInstantiatedMethodType;
          }
  
          boolean lastSerializable() {
              return lastSerializable;
          }
  
          List<Class<?>> lastMarkerInterfaces() {
              return lastMarkerInterfaces;
          }
  
          List<?> lastAdditionalBridges() {
              return lastAdditionalBridges;
          }
  
          Collection<ClassFileTransformer> lastClassFileTransformers() {
              return lastClassFileTransformers;
          }
      }
  }
