      assertThat(factory.getType()).isSameAs(org.objectweb.asm.ClassVisitor.class);\n\n            RecordingExternalClassVisitor externalVisitor = new RecordingExternalClassVisitor();\n            org.modelmapper.internal.asm.ClassVisitor unwrappedVisitor = factory.unwrap(externalVisitor);\n            unwrappedVisitor.visit(\n                    org.modelmapper.internal.asm.Opcodes.V1_8,\n                    org.modelmapper.internal.asm.Opcodes.ACC_PUBLIC,\n                    \"org/example/Source\",\n                    null,\n                    \"java/lang/Object\",\n                    new String[] {\"java/io/Serializable\"});\n\n            assertThat(externalVisitor.visited()).isTrue();\n            assertThat(externalVisitor.className()).isEqualTo(\"org/example/Source\");\n            assertThat(externalVisitor.superName()).isEqualTo(\"java/lang/Object\");\n            assertThat(externalVisitor.interfaces()).containsExactly(\"java/io/Serializable\");\n\n            RecordingInternalClassVisitor internalVisitor = new RecordingInternalClassVisitor();\n            org.objectweb.asm.ClassVisitor wrappedVisitor = factory.wrap(internalVisitor);\n            wrappedVisitor.visit(\n                    org.objectweb.asm.Opcodes.V1_8,\n                    org.objectweb.asm.Opcodes.ACC_PUBLIC,\n                    \"org/example/Target\",\n                    null,\n                    \"java/lang/Object\",\n                    new String[] {\"java/lang/Cloneable\"});\n\n            assertThat(internalVisitor.visited()).isTrue();\n            assertThat(internalVisitor.className()).isEqualTo(\"org/example/Target\");\n            assertThat(internalVisitor.superName()).isEqualTo(\"java/lang/Object\");\n            assertThat(internalVisitor.interfaces()).containsExactly(\"java/lang/Cloneable\");\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    private static final class RecordingExternalClassVisitor extends org.objectweb.asm.ClassVisitor {\n        private boolean visited;\n        private String className;\n        private String superName;\n        private String[] interfaces;\n\n        private RecordingExternalClassVisitor() {\n            super(org.objectweb.asm.Opcodes.ASM9);\n        }\n\n        @Override\n        public void visit(\n                int version,\n                int access,\n                String name,\n                String signature,\n                String superName,\n                String[] interfaces) {\n            visited = true;\n            className = name;\n            this.superName = superName;\n            this.interfaces = interfaces;\n        }\n\n        boolean visited() {\n            return visited;\n        }\n\n        String className() {\n            return className;\n        }\n\n        String superName() {\n            return superName;\n        }\n\n        String[] interfaces() {\n            return interfaces;\n        }\n    }\n\n    private static final class RecordingInternalClassVisitor extends org.modelmapper.internal.asm.ClassVisitor {\n        private boolean visited;\n        private String className;\n        private String superName;\n        private String[] interfaces;\n\n        private RecordingInternalClassVisitor() {\n            super(org.modelmapper.internal.asm.Opcodes.ASM9);\n        }\n\n        @Override\n        public void visit(\n                int version,\n                int access,\n                String name,\n                String signature,\n                String superName,\n                String[] interfaces) {\n            visited = true;\n            className = name;\n            this.superName = superName;\n            this.interfaces = interfaces;\n        }\n\n        boolean visited() {\n            return visited;\n        }\n\n        String className() {\n            return className;\n        }\n\n        String superName() {\n            return superName;\n        }\n\n        String[] interfaces() {\n            return interfaces;\n        }\n    }\n}\n"}, "partialJson": "{\"path\":\"tests/src/org.modelmapper/modelmapper/3.2.0/src/test/java/org_modelmapper/modelmapper/ClassVisitorFactoryInnerCreateClassVisitorFactoryTest.java\",\"content\":\"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage org_modelmapper.modelmapper;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\n\\nimport org.graalvm.internal.tck.NativeImageSupport;\\nimport org.junit.jupiter.api.Test;\\nimport org.modelmapper.internal.bytebuddy.asm.ClassVisitorFactory;\\n\\npublic class ClassVisitorFactoryInnerCreateClassVisitorFactoryTest {\\n    @Test\\n    void createsFactoryForExternalAsmNamespaceAndTranslatesVisitCalls() {\\n        try {\\n            ClassVisitorFactory<org.objectweb.asm.ClassVisitor> factory = ClassVisitorFactory.of(\\n                    org.objectweb.asm.ClassVisitor.class);\\n\\n            assertThat(factory.getType()).isSameAs(org.objectweb.asm.ClassVisitor.class);\\n\\n            RecordingExternalClassVisitor externalVisitor = new RecordingExternalClassVisitor();\\n            org.modelmapper.internal.asm.ClassVisitor unwrappedVisitor = factory.unwrap(externalVisitor);\\n            unwrappedVisitor.visit(\\n                    org.modelmapper.internal.asm.Opcodes.V1_8,\\n                    org.modelmapper.internal.asm.Opcodes.ACC_PUBLIC,\\n                    \\\"org/example/Source\\\",\\n                    null,\\n                    \\\"java/lang/Object\\\",\\n                    new String[] {\\\"java/io/Serializable\\\"});\\n\\n            assertThat(externalVisitor.visited()).isTrue();\\n            assertThat(externalVisitor.className()).isEqualTo(\\\"org/example/Source\\\");\\n            assertThat(externalVisitor.superName()).isEqualTo(\\\"java/lang/Object\\\");\\n            assertThat(externalVisitor.interfaces()).containsExactly(\\\"java/io/Serializable\\\");\\n\\n            RecordingInternalClassVisitor internalVisitor = new RecordingInternalClassVisitor();\\n            org.objectweb.asm.ClassVisitor wrappedVisitor = factory.wrap(internalVisitor);\\n            wrappedVisitor.visit(\\n                    org.objectweb.asm.Opcodes.V1_8,\\n                    org.objectweb.asm.Opcodes.ACC_PUBLIC,\\n                    \\\"org/example/Target\\\",\\n                    null,\\n                    \\\"java/lang/Object\\\",\\n                    new String[] {\\\"java/lang/Cloneable\\\"});\\n\\n            assertThat(internalVisitor.visited()).isTrue();\\n            assertThat(internalVisitor.className()).isEqualTo(\\\"org/example/Target\\\");\\n            assertThat(internalVisitor.superName()).isEqualTo(\\\"java/lang/Object\\\");\\n            assertThat(internalVisitor.interfaces()).containsExactly(\\\"java/lang/Cloneable\\\");\\n        } catch (Error error) {\\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\\n                throw error;\\n            }\\n        }\\n    }\\n\\n    private static final class RecordingExternalClassVisitor extends org.objectweb.asm.ClassVisitor {\\n        private boolean visited;\\n        private String className;\\n        private String superName;\\n        private String[] interfaces;\\n\\n        private RecordingExternalClassVisitor() {\\n            super(org.objectweb.asm.Opcodes.ASM9);\\n        }\\n\\n        @Override\\n        public void visit(\\n                int version,\\n                int access,\\n                String name,\\n                String signature,\\n                String superName,\\n                String[] interfaces) {\\n            visited = true;\\n            className = name;\\n            this.superName = superName;\\n         