], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1947, "output": 642, "cacheRead": 41472, "cacheWrite": 0, "totalTokens": 44061, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778127999207, "responseId": "resp_04bd19842fb743880169fc147fcfa881a19989a076bfa222c8"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_2Ov6oKgmbnmA2DPBupXkjeob|fc_04bd19842fb743880169fc148ad3fc81a1aa1eefda37ebaa84", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_modelmapper.modelmapper;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.IOException;\nimport java.lang.reflect.InvocationTargetException;\nimport java.net.JarURLConnection;\nimport java.net.URL;\nimport java.net.URLClassLoader;\nimport java.security.ProtectionDomain;\nimport java.util.Collections;\nimport java.util.Enumeration;\nimport java.util.Map;\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\nimport org.modelmapper.internal.asm.ClassWriter;\nimport org.modelmapper.internal.asm.MethodVisitor;\nimport org.modelmapper.internal.asm.Opcodes;\nimport org.modelmapper.internal.bytebuddy.ByteBuddy;\nimport org.modelmapper.internal.bytebuddy.dynamic.DynamicType;\nimport org.modelmapper.internal.bytebuddy.dynamic.loading.ClassInjector.UsingUnsafe;\nimport org.modelmapper.internal.bytebuddy.dynamic.scaffold.subclass.ConstructorStrategy;\n\npublic class ClassInjectorInnerUsingUnsafeInnerDispatcherInnerCreationActionTest {\n    private static final String BYTE_BUDDY_SAFE_PROPERTY =\n            \"org.modelmapper.internal.bytebuddy.safe\";\n\n    @Test\n    void createsUnsafeDispatcherThroughCreationAction() {\n        String previousValue = System.setProperty(BYTE_BUDDY_SAFE_PROPERTY, \"false\");\n        try {\n            UnsafeCreationActionAccess.runScenario();\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        } finally {\n            if (previousValue == null) {\n                System.clearProperty(BYTE_BUDDY_SAFE_PROPERTY);\n            } else {\n                System.setProperty(BYTE_BUDDY_SAFE_PROPERTY, previousValue);\n            }\n        }\n    }\n\n    @Test\n    void createsUnsafeDispatcherThroughInternalUnsafeFallback() throws Exception {\n        String previousValue = System.setProperty(BYTE_BUDDY_SAFE_PROPERTY, \"false\");\n        try {\n            runFallbackScenarioInIsolatedLoader();\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        } finally {\n            if (previousValue == null) {\n                System.clearProperty(BYTE_BUDDY_SAFE_PROPERTY);\n            } else {\n                System.setProperty(BYTE_BUDDY_SAFE_PROPERTY, previousValue);\n            }\n        }\n    }\n\n    private static void runFallbackScenarioInIsolatedLoader() throws Exception {\n        URL modelMapperUrl = modelMapperJarUrl();\n        URL testClassesUrl = ClassInjectorInnerUsingUnsafeInnerDispatcherInnerCreationActionTest\n                .class\n                .getProtectionDomain()\n                .getCodeSource()\n                .getLocation();\n        try (FallbackClassLoader classLoader = new FallbackClassLoader(\n                new URL[] {testClassesUrl, modelMapperUrl},\n                ClassLoader.getSystemClassLoader())) {\n            Class<?> scenarioClass = classLoader.loadClass(\n                    UnsafeCreationActionFallbackScenario.class.getName());\n            scenarioClass.getMethod(\"runScenario\").invoke(null);\n        } catch (InvocationTargetException exception) {\n            Throwable target = exception.getTargetException();\n            if (target instanceof Exception) {\n                throw (Exception) target;\n            }\n            if (target instanceof Error) {\n                throw (Error) target;\n            }\n            throw exception;\n        }\n    }\n\n    private static URL modelMapperJarUrl() throws IOException {\n        Enumeration<URL> resources = ClassLoader.getSystemResources(\n                \"org/modelmapper/ModelMapper.class\");\n        URL fallback = null;\n        while (resources.hasMoreElements()) {\n            URL resource = resources.nextElement();\n            URL rootUrl = resourceRootUrl(resource);\n            if (rootUrl.toString().contains(\"/build/jacoco/effective/\")) {\n                return rootUrl;\n            }\n            if (fallback == null) {\n                fallback = rootUrl;\n            }\n        }\n        assertThat(fallback).as(\"ModelMapper class resource\").isNotNull();\n        return fallback;\n    }\n\n    private static URL resourceRootUrl(URL resource) throws IOException {\n        if (\"jar\".equals(resource.getProtocol())) {\n            return ((JarURLConnection) resource.openConnection()).getJarFileURL();\n        }\n        String path = resource.toString();\n        String suffix = \"org/modelmapper/ModelMapper.class\";\n        assertThat(path).endsWith(suffix);\n        return new URL(path.substring(0, path.length() - suffix.length()));\n    }\n\n    static Map<String, byte[]> generatedType(String className) {\n        DynamicType.Unloaded<?> unloaded = new ByteBuddy()\n                .subclass(Object.class, ConstructorStrategy.Default.NO_CONSTRUCTORS)\n                .name(className)\n                .make();\n        return Collections.singletonMap(className, unloaded.getBytes());\n    }\n\n    public static final class UnsafeCreationActionFallbackScenario extends UsingUnsafe {\n        private UnsafeCreationActionFallbackScenario(ClassLoader classLoader) {\n            super(classLoader);\n        }\n\n        public static void runScenario() {\n            Dispatcher.Initializable initializable = Dispatcher.CreationAction.INSTANCE.run();\n            assertThat(initializable).isNotNull();\n            assertThat(initializable.isAvailable()).isFalse();\n            assertThat(initializable.getClass().getName()).contains(\"Unavailable\");\n        }\n    }\n\n    private static final class FallbackClassLoader extends URLClassLoader {\n        private static final String FAKE_UNSAFE_NAME = \"sun.misc.Unsafe\";\n\n        private FallbackClassLoader(URL[] urls, ClassLoader parent) {\n            super(urls, parent);\n        }\n\n        @Override\n        protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {\n            synchronized (getClassLoadingLock(name)) {\n                Class<?> loadedClass = findLoadedClass(name);\n                if (loadedClass == null && FAKE_UNSAFE_NAME.equals(name)) {\n                    byte[] bytes = fakeUnsafeBytes();\n                    loadedClass = defineClass(name, bytes, 0, bytes.length);\n                } else if (loadedClass == null && shouldLoadChildFirst(name)) {\n                    try {\n                        loadedClass = findClass(name);\n                    } catch (ClassNotFoundException ignored) {\n                        loadedClass = super.loadClass(name, false);\n                    }\n                } else if (loadedClass == null) {\n                    loadedClass = super.loadClass(name, false);\n                }\n                if (resolve) {\n                    resolveClass(loadedClass);\n                }\n                return loadedClass;\n            }\n        }\n\n        private static boolean shouldLoadChildFirst(String name) {\n            String testName = ClassInjectorInnerUsingUnsafeInnerDispatcherInnerCreationActionTest\n                    .class\n                    .getName();\n            return name.startsWith(\"org.modelmapper.\")\n                    || name.equals(testName)\n                    || name.startsWith(testName + Character.toString((char) 36));\n        }\n\n        private static byte[] fakeUnsafeBytes() {\n            ClassWriter writer = new ClassWriter(ClassWriter.COMPUTE_MAXS);\n            writer.visit(\n                    Opcodes.V1_8,\n                    Opcodes.ACC_PUBLIC | Opcodes.ACC_SUPER,\n                    \"sun/misc/Unsafe\",\n                    null,\n                    \"java/lang/Object\",\n                    null);\n            writer.visitField(\n                    Opcodes.ACC_PUBLIC | Opcodes.ACC_STATIC,\n                    \"theUnsafe\",\n                    \"Ljava/lang/Object;\",\n                    null,\n                    null).visitEnd();\n            writeConstructor(writer);\n            writeStaticInitializer(writer);\n            writeObjectFieldOffset(writer);\n            writePutBoolean(writer);\n            writer.visitEnd();\n            return writer.toByteArray();\n        }\n\n        private static void writeConstructor(ClassWriter writer) {\n            MethodVisitor method = writer.visitMethod(\n                    Opcodes.ACC_PUBLIC,\n                    \"<init>\",\n                    \"()V\",\n                    null,\n                    null);\n            method.visitCode();\n            method.visitVarInsn(Opcodes.ALOAD, 0);\n            method.visitMethodInsn(\n                    Opcodes.INVOKESPECIAL,\n                    \"java/lang/Object\",\n                    \"<init>\",\n                    \"()V\",\n                    false);\n            method.visitInsn(Opcodes.RETURN);\n            method.visitMaxs(0, 0);\n            method.visitEnd();\n        }\n\n        private static void writeStaticInitializer(ClassWriter writer) {\n            MethodVisitor method = writer.visitMethod(\n                    Opcodes.ACC_STATIC,\n                    \"<clinit>\",\n                    \"()V\",\n                    null,\n                    null);\n            method.visitCode();\n            method.visitTypeInsn(Opcodes.NEW, \"sun/misc/Unsafe\");\n            method.visitInsn(Opcodes.DUP);\n            method.visitMethodInsn(\n                    Opcodes.INVOKESPECIAL,\n                    \"sun/misc/Unsafe\",\n                    \"<init>\",\n                    \"()V\",\n                    false);\n            method.visitFieldInsn(\n                    Opcodes.PUTSTATIC,\n                    \"sun/misc/Unsafe\",\n                    \"theUnsafe\",\n                    \"Ljava/lang/Object;\");\n            method.visitInsn(Opcodes.RETURN);\n            method.visitMaxs(0, 0);\n            method.visitEnd();\n        }\n\n        private static void writeObjectFieldOffset(ClassWriter writer) {\n            MethodVisitor method = writer.visitMethod(\n                    Opcodes.ACC_PUBLIC,\n                    \"objectFieldOffset\",\n                    \"(Ljava/lang/reflect/Field;)J\",\n                    null,\n                    null);\n            method.visitCode();\n            method.visitLdcInsn(Long.valueOf(0));\n\n[56 more lines in file. Use offset=261 to continue.]"}], "isError": false, "timestamp": 1778128011321}]}
