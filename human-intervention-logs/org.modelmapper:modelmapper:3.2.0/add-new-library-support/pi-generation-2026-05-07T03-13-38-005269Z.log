er tests\",\n            \"ModelMapper test implementation\",\n            \"1\",\n            \"ModelMapper tests\",\n            null);\n\n    @Test\n    void injectsGeneratedClassesThroughUnsafeReflectionDispatcher() throws Exception {\n        runDynamicClassLoading(() -> {\n            ClassLoader parentClassLoader = getClass().getClassLoader();\n            injectGeneratedType(\n                    new ClassLoader(parentClassLoader) {\n                    },\n                    \"org_modelmapper.modelmapper.generated.UnsafeReflectionInjectedType\");\n            injectGeneratedType(\n                    new PackageDefinitionFailingClassLoader(parentClassLoader),\n                    \"org_modelmapper.modelmapper.fallback.UnsafeReflectionFallbackType\");\n        });\n    }\n\n    private static void injectGeneratedType(ClassLoader classLoader, String className) {\n        Map<String, Class<?>> loadedTypes = new UsingReflection(\n                classLoader,\n                (ProtectionDomain) null,\n                new AlwaysDefinedPackageStrategy(),\n                false).injectRaw(generatedType(className));\n\n        assertThat(loadedTypes).containsOnlyKeys(className);\n        assertThat(loadedTypes.get(className).getName()).isEqualTo(className);\n        assertThat(loadedTypes.get(className).getClassLoader()).isSameAs(classLoader);\n    }\n\n    private static Map<String, byte[]> generatedType(String className) {\n        DynamicType.Unloaded<?> unloaded = new ByteBuddy()\n                .subclass(Object.class, ConstructorStrategy.Default.NO_CONSTRUCTORS)\n                .name(className)\n                .make();\n        return Collections.singletonMap(className, unloaded.getBytes());\n    }\n\n    private static void runDynamicClassLoading(\n            DynamicClassLoadingOperation operation) throws Exception {\n        String previousValue = System.setProperty(BYTE_BUDDY_SAFE_PROPERTY, \"false\");\n        SecurityManager previousSecurityManager = System.getSecurityManager();\n        boolean securityManagerChanged = installPermissiveSecurityManager();\n        try {\n            operation.run();\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        } catch (UnsupportedOperationException exception) {\n            assertThat(exception.getMessage())\n                    .startsWith(\"Cannot \")\n                    .contains(\" using reflection: \");\n        } finally {\n            if (securityManagerChanged) {\n                System.setSecurityManager(previousSecurityManager);\n            }\n            if (previousValue == null) {\n                System.clearProperty(BYTE_BUDDY_SAFE_PROPERTY);\n            } else {\n                System.setProperty(BYTE_BUDDY_SAFE_PROPERTY, previousValue);\n            }\n        }\n    }\n\n    private static boolean installPermissiveSecurityManager() {\n        try {\n            SecurityManager securityManager = new PermissiveSecurityManager();\n            System.setSecurityManager(securityManager);\n            return System.getSecurityManager() == securityManager;\n        } catch (UnsupportedOperationException | SecurityException ignored) {\n            return false;\n        }\n    }\n\n    private static final class PermissiveSecurityManager extends SecurityManager {\n        @Override\n        public void checkPermission(Permission permission) {\n            // Allow all permissions so the dispatcher can exercise its security-manager path.\n        }\n    }\n\n    private static final class AlwaysDefinedPackageStrategy implements PackageDefinitionStrategy {\n        @Override\n        public Definition define(ClassLoader classLoader, String packageName, String typeName) {\n            return PACKAGE_DEFINITION;\n        }\n    }\n\n    private static final class PackageDefinitionFailingClassLoader extends ClassLoader {\n        private PackageDefinitionFailingClassLoader(ClassLoader parent) {\n            super(parent);\n        }\n\n        @Override\n        protected Package definePackage(\n                String name,\n                String specificationTitle,\n                String specificationVersion,\n                String specificationVendor,\n                String implementationTitle,\n                String implementationVersion,\n                String implementationVendor,\n                URL sealBase) {\n            throw new IllegalStateException(\"Package definition is intentionally unavailable\");\n        }\n\n        @Override\n        @SuppressWarnings(\"deprecation\")\n        protected Package getPackage(String name) {\n            return ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeInjectionTest\n                    .class\n                    .getPackage();\n        }\n    }\n\n    @FunctionalInterface\n    private interface DynamicClassLoadingOperation {\n        void run() throws Exception;\n    }\n}\n"}], "isError": false, "timestamp": 1778123485586}, {"role": "toolResult", "toolCallId": "call_GwJSA1hQJJsK5BII4aGsmILt|fc_0f93eb1a3b21746b0169fc02dd4e3881939a20a40679c216da", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_modelmapper.modelmapper;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.IOException;\nimport java.lang.reflect.InvocationTargetException;\nimport java.net.JarURLConnection;\nimport java.net.URL;\nimport java.net.URLClassLoader;\nimport java.security.Permission;\nimport java.security.ProtectionDomain;\nimport java.util.Collections;\nimport java.util.Enumeration;\nimport java.util.Map;\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Order;\nimport org.junit.jupiter.api.Test;\nimport org.modelmapper.internal.bytebuddy.ByteBuddy;\nimport org.modelmapper.internal.bytebuddy.dynamic.DynamicType;\nimport org.modelmapper.internal.bytebuddy.dynamic.loading.ClassInjector.UsingReflection;\nimport org.modelmapper.internal.bytebuddy.dynamic.loading.ClassInjector.UsingUnsafe;\nimport org.modelmapper.internal.bytebuddy.dynamic.loading.PackageDefinitionStrategy;\nimport org.modelmapper.internal.bytebuddy.dynamic.loading.PackageDefinitionStrategy.Definition;\nimport org.modelmapper.internal.bytebuddy.dynamic.scaffold.subclass.ConstructorStrategy;\n\n@Order(1)\npublic class ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeOverrideTest {\n    private static final String BYTE_BUDDY_SAFE_PROPERTY =\n            \"org.modelmapper.internal.bytebuddy.safe\";\n\n    @Test\n    void injectsGeneratedClassesThroughUnsafeOverrideDispatcher() throws Exception {\n        try {\n            if (!runThroughSystemLoader()) {\n                runInIsolatedModelMapperLoader();\n            }\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        } catch (UnsupportedOperationException exception) {\n            assertThat(exception.getMessage())\n                    .startsWith(\"Cannot \")\n                    .contains(\" using reflection: \");\n        }\n    }\n\n    private static boolean runThroughSystemLoader() {\n        String previousValue = System.setProperty(BYTE_BUDDY_SAFE_PROPERTY, \"true\");\n        SecurityManager previousSecurityManager = System.getSecurityManager();\n        boolean securityManagerChanged = false;\n        try {\n            if (UsingUnsafe.isAvailable()) {\n                return false;\n            }\n            System.setProperty(BYTE_BUDDY_SAFE_PROPERTY, \"false\");\n            securityManagerChanged =\n                    UnsafeOverrideDispatcherScenario.installPermissiveSecurityManager();\n            return UnsafeOverrideDispatcherAccess.runDispatcherScenario();\n        } finally {\n            if (securityManagerChanged) {\n                System.setSecurityManager(previousSecurityManager);\n            }\n            if (previousValue == null) {\n                System.clearProperty(BYTE_BUDDY_SAFE_PROPERTY);\n            } else {\n                System.setProperty(BYTE_BUDDY_SAFE_PROPERTY, previousValue);\n            }\n        }\n    }\n\n    private static void runInIsolatedModelMapperLoader() throws Exception {\n        URL modelMapperUrl = modelMapperJarUrl();\n        Class<?> testClass =\n                ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeOverrideTest.class;\n        URL testClassesUrl = testClass.getProtectionDomain().getCodeSource().getLocation();\n        try (ChildFirstClassLoader classLoader = new ChildFirstClassLoader(\n                new URL[] {testClassesUrl, modelMapperUrl},\n                ClassLoader.getSystemClassLoader())) {\n            Class<?> scenarioClass = classLoader.loadClass(\n                    UnsafeOverrideDispatcherScenario.class.getName());\n            Runnable scenario = (Runnable) scenarioClass.getConstructor().newInstance();\n            scenario.run();\n        } catch (InvocationTargetException exception) {\n            Throwable target = exception.getTargetException();\n            if (target instanceof Exception) {\n                throw (Exception) target;\n            }\n            if (target instanceof Error) {\n                throw (Error) target;\n            }\n            throw exception;\n        }\n    }\n\n    private static URL modelMapperJarUrl() throws IOException {\n        Enumeration<URL> resources = ClassLoader.getSystemResources(\n                \"org/modelmapper/ModelMapper.class\");\n        URL fallback = null;\n        while (resources.hasMoreElements()) {\n            URL resource = resources.nextElement();\n            URL rootUrl = resourceRootUrl(resource);\n            if (rootUrl.toString().contains(\"/build/jacoco/effective/\")) {\n                return rootUrl;\n            }\n            if (fallback == null) {\n                fallback = rootUrl;\n            }\n        }\n        assertThat(fallback).as(\"ModelMapper class resource\").isNotNull();\n        return fallback;\n    }\n\n    private static URL resourceRootUrl(URL resource) throws IOException {\n        if (\"jar\".equals(resource.getProtocol())) {\n            return ((JarURLConnection) resource.openConnection()).getJarFileURL();\n        }\n        String path = resource.toString();\n        String suffix = \"org/modelmapper/ModelMapper.class\";\n        assertThat(path).endsWith(suffix);\n        return new URL(path.substring(0, path.length() - suffix.length()));\n    }\n\n    public static final class UnsafeOverrideDispatcherScenario implements Runnable {\n        public static final Definition PACKAGE_DEFINITION = new Definition.Simple(\n                \"ModelMapper test specification\",\n                \"1\",\n                \"ModelMapper tests\",\n                \"ModelMapper test implementation\",\n                \"1\",\n                \"ModelMapper tests\",\n                null);\n\n        @Override\n        public void run() {\n            String previousValue = System.setProperty(BYTE_BUDDY_SAFE_PROPERTY, \"true\");\n            SecurityManager previousSecurityManager = System.getSecurityManager();\n            boolean securityManagerChanged = false;\n            try {\n                if (UsingUnsafe.isAvailable()) {\n                    throw new AssertionError(\n                            \"UsingUnsafe should be unavailable before override dispatcher setup\");\n                }\n                System.setProperty(BYTE_BUDDY_SAFE_PROPERTY, \"false\");\n                securityManagerChanged = installPermissiveSecurityManager();\n                ClassLoader parentClassLoader = getClass().getClassLoader();\n                injectGeneratedType(\n                        new ClassLoader(parentClassLoader) {\n                        },\n                        \"org_modelmapper.modelmapper.generated.UnsafeOverrideInjectedType\");\n                injectGeneratedType(\n                        new PackageDefinitionFailingClassLoader(parentClassLoader),\n                        \"org_modelmapper.modelmapper.fallback.UnsafeOverrideFallbackType\");\n            } finally {\n                if (securityManagerChanged) {\n                    System.setSecurityManager(previousSecurityManager);\n                }\n                if (previousValue == null) {\n                    System.clearProperty(BYTE_BUDDY_SAFE_PROPERTY);\n                } else {\n                    System.setProperty(BYTE_BUDDY_SAFE_PROPERTY, previousValue);\n                }\n            }\n        }\n\n        private static void injectGeneratedType(ClassLoader classLoader, String className) {\n            Map<String, Class<?>> loadedTypes = new UsingReflection(\n                    classLoader,\n                    (ProtectionDomain) null,\n                    new AlwaysDefinedPackageStrategy(),\n                    false).injectRaw(generatedType(className));\n\n            Class<?> loadedType = loadedTypes.get(className);\n            if (loadedTypes.size() != 1 || loadedType == null) {\n                throw new AssertionError(\"Unexpected loaded types: \" + loadedTypes);\n            }\n            if (!className.equals(loadedType.getName())) {\n                throw new AssertionError(\"Unexpected loaded type name: \" + loadedType.getName());\n            }\n            if (loadedType.getClassLoader() != classLoader) {\n                throw new AssertionError(\"Unexpected class loader: \" + loadedType.getClassLoader());\n            }\n        }\n\n        private static Map<String, byte[]> generatedType(String className) {\n            DynamicType.Unloaded<?> unloaded = new ByteBuddy()\n                    .subclass(Object.class, ConstructorStrategy.Default.NO_CONSTRUCTORS)\n                    .name(className)\n                    .make();\n            return Collections.singletonMap(className, unloaded.getBytes());\n        }\n\n        private static boolean installPermissiveSecurityManager() {\n            try {\n                SecurityManager securityManager = new PermissiveSecurityManager();\n                System.setSecurityManager(securityManager);\n                return System.getSecurityManager() == securityManager;\n            } catch (UnsupportedOperationException | SecurityException ignored) {\n                return false;\n            }\n        }\n\n        public static final class PermissiveSecurityManager extends SecurityManager {\n            public PermissiveSecurityManager() {\n            }\n\n            @Override\n            public void checkPermission(Permission permission) {\n                // Allow all permissions so the dispatcher can exercise its security-manager path.\n            }\n        }\n\n        public static final class AlwaysDefinedPackageStrategy\n                implements PackageDefinitionStrategy {\n            public AlwaysDefinedPackageStrategy() {\n            }\n\n            @Override\n            public Definition define(ClassLoader classLoader, String packageName, String typeName) {\n                return PACKAGE_DEFINITION;\n            }\n        }\n\n        public static final class PackageDefinitionFailingClassLoader extends ClassLoader {\n            public PackageDefinitionFailingClassLoader(ClassLoader parent) {\n                super(parent);\n            }\n\n            @Override\n            protected Package definePackage(\n                    String name,\n                    String specificationTitle,\n                    String specificationVersion,\n                    String specificationVendor,\n                    String implementationTitle,\n                    String implementationVersion,\n                    String implementationVendor,\n                    URL sealBase) {\n                throw new IllegalStateException(\"Package definition is intentionally unavailable\");\n            }\n\n            @Override\n            @SuppressWarnings(\"deprecation\")\n            protected Package getPackage(String name) {\n                return UnsafeOverrideDispatcherScenario.class.getPackage();\n            }\n        }\n    }\n\n    private static final class ChildFirstClassLoader extends URLClassLoader {\n        private ChildFirstClassLoader(URL[] urls, ClassLoader parent) {\n            super(urls, parent);\n        }\n\n        @Override\n        protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {\n            synchronized (getClassLoadingLock(name)) {\n                Class<?> loadedClass = findLoadedClass(name);\n                if (loadedClass == null && shouldLoadChildFirst(name)) {\n                    try {\n                        loadedClass = findClass(name);\n                    } catch (ClassNotFoundException ignored) {\n                        loadedClass = super.loadClass(name, false);\n                    }\n                } else if (loadedClass == null) {\n                    loadedClass = super.loadClass(name, false);\n                }\n                if (resolve) {\n                    resolveClass(loadedClass);\n                }\n                return loadedClass;\n            }\n        }\n\n        private static boolean shouldLoadChildFirst(String name) {\n            String scenarioName = UnsafeOverrideDispatcherScenario.class.getName();\n            return name.startsWith(\"org.modelmapper.\")\n                    || name.equals(scenarioName)\n                    || name.startsWith(scenarioName + Character.toString((char) 36));\n        }\n    }\n}\n\nclass UnsafeOverrideDispatcherAccess extends UsingReflection {\n    UnsafeOverrideDispatcherAccess(ClassLoader classLoader) {\n        super(classLoader);\n    }\n\n    static boolean runDispatcherScenario() {\n        Dispatcher.Initializable initializable = Dispatcher.CreationAction.INSTANCE.run();\n        if (!initializable.isAvailable()) {\n            return false;\n        }\n        assertThat(initializable.getClass().getName()).contains(\"UsingUnsafeOverride\");\n        Dispatcher dispatcher = initializable.initialize();\n        ClassLoader classLoader = new ClassLoader(\n                ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeOverrideTest\n                        .class\n                        .getClassLoader()) {\n        };\n        String packageName = \"org_modelmapper.modelmapper.systemoverride\";\n        String className = packageName + \".UnsafeOverrideSystemInjectedType\";\n        assertThat(dispatcher.findClass(classLoader, className)).isNull();\n        assertThat(dispatcher.getDefinedPackage(classLoader, packageName)).isNull();\n        dispatcher.definePackage(\n                classLoader,\n                packageName,\n                \"ModelMapper test specification\",\n                \"1\",\n                \"ModelMapper tests\",\n                \"ModelMapper test implementation\",\n                \"1\",\n                \"ModelMapper tests\",\n                null);\n        assertThat(dispatcher.getDefinedPackage(classLoader, packageName)).isNotNull();\n        assertThat(dispatcher.getPackage(classLoader, packageName)).isNotNull();\n        Class<?> loadedType = dispatcher.defineClass(\n                classLoader,\n                className,\n                ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeOverrideTest\n                        .UnsafeOverrideDispatcherScenario\n                        .generatedType(className)\n                        .get(className),\n                null);\n        assertThat(loadedType.getName()).isEqualTo(className);\n        assertThat(dispatcher.findClass(classLoader, className)).isSameAs(loadedType);\n        return true;\n    }\n}\n"}], "isError": false, "timestamp": 1778123485587}, {"role": "toolResult", "toolCallId": "call_cr2cAN1FF3YE9SEfWdTE4qxt|fc_0f93eb1a3b21746b0169fc02dd4e408193a3938a7f169802a8", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\nplugins {\n    id \"org.graalvm.internal.tck\"\n}\n\nString libraryVersion = tck.testedLibraryVersion.get()\n\ndependencies {\n    testImplementation \"org.modelmapper:modelmapper:$libraryVersion\"\n    testImplementation 'org.assertj:assertj-core:3.22.0'\n}\n\ngraalvmNative {\n    agent {\n        defaultMode = \"conditional\"\n        modes {\n            conditional {\n                userCodeFilterPath = \"user-code-filter.json\"\n            }\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778123485587}]}
