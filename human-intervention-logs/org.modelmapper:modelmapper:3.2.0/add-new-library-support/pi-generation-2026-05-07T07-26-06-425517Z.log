npublic class AnnotationDescriptionInnerForLoadedAnnotationTest {\n    @Test\n    void convertsLoadedAnnotationMembersIntoAnnotationValues() {\n        Container container = ContainerHolder.class.getAnnotation(Container.class);\n\n        AnnotationValue<?, ?> nestedValue = ForLoadedAnnotation.asValue(container.nested(), Nested.class);\n        Nested loadedNested = nestedValue.load(getClass().getClassLoader()).resolve(Nested.class);\n\n        assertThat(loadedNested.code()).isEqualTo(\"primary\");\n        assertThat(loadedNested.priority()).isEqualTo(11);\n    }\n\n    @Test\n    void readsValueForLatentMethodDescriptionByAnnotationPropertyName() {\n        Fixture fixture = FixtureHolder.class.getAnnotation(Fixture.class);\n        AnnotationDescription description = ForLoadedAnnotation.of(fixture);\n        TypeDescription annotationType = TypeDescription.ForLoadedType.of(Fixture.class);\n        MethodDescription.InDefinedShape latentLabelMethod = new MethodDescription.Latent(\n                annotationType,\n                new MethodDescription.Token(\n                        \"label\",\n                        Modifier.PUBLIC | Modifier.ABSTRACT,\n                        TypeDescription.Generic.OfNonGenericType.ForLoadedType.of(String.class)));\n\n        AnnotationValue<?, ?> labelValue = description.getValue(latentLabelMethod);\n\n        assertThat(labelValue.resolve(String.class)).isEqualTo(\"customer\");\n    }\n\n    @Retention(RetentionPolicy.RUNTIME)\n    public @interface Fixture {\n        String label();\n    }\n\n    @Fixture(label = \"customer\")\n    public static final class FixtureHolder {\n    }\n\n    @Retention(RetentionPolicy.RUNTIME)\n    public @interface Nested {\n        String code();\n\n        int priority();\n    }\n\n    @Retention(RetentionPolicy.RUNTIME)\n    public @interface Container {\n        Nested nested();\n    }\n\n    @Container(nested = @Nested(code = \"primary\", priority = 11))\n    public static final class ContainerHolder {\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 873, "output": 1175, "cacheRead": 39424, "cacheWrite": 0, "totalTokens": 41472, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778138737059, "responseId": "resp_0ba4e5643502301c0169fc3e71c9388194a61ee5b844741a7d"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_QbwW6TsQx7L3jWL5bThLLoSf|fc_0ba4e5643502301c0169fc3e797f708194b64b6f83073b2ffe", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2849 bytes to tests/src/org.modelmapper/modelmapper/3.2.0/src/test/java/org_modelmapper/modelmapper/AnnotationDescriptionInnerForLoadedAnnotationTest.java"}], "isError": false, "timestamp": 1778138750146}]}
