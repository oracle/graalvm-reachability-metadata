ixture);\n        TypeDescription annotationType = TypeDescription.ForLoadedType.of(Fixture.class);\n        MethodDescription.InDefinedShape latentLabelMethod = new MethodDescription.Latent(\n                annotationType,\n                new MethodDescription.Token(\n                        \"label\",\n                        Modifier.PUBLIC | Modifier.ABSTRACT,\n                        TypeDescription.Generic.OfNonGenericType.ForLoadedType.of(String.class)));\n\n        AnnotationValue<?, ?> labelValue = description.getValue(latentLabelMethod);\n\n        assertThat(labelValue.resolve(String.class)).isEqualTo(\"customer\");\n    }\n\n    @Retention(RetentionPolicy.RUNTIME)\n    public @interface Fixture {\n        String label();\n    }\n\n    @Fixture(label = \"customer\")\n    public static final class FixtureHolder {\n    }\n\n    @Retention(RetentionPolicy.RUNTIME)\n    public @interface Nested {\n        String code();\n\n        int priority();\n    }\n\n    @Retention(RetentionPolicy.RUNTIME)\n    public @interface Container {\n        Nested nested();\n    }\n\n    @Container(nested = @Nested(code = \"primary\", priority = 11))\n    public static final class ContainerHolder {\n    }\n}\n"}
