ublic String value() {\n            return value;\n        }\n\n        @Override\n        public int priority() {\n            return priority;\n        }\n\n        @Override\n        public Class<? extends Annotation> annotationType() {\n            return GeneratedAnnotation.class;\n        }\n\n        @Override\n        public boolean equals(Object other) {\n            if (!(other instanceof GeneratedAnnotation)) {\n                return false;\n            }\n            GeneratedAnnotation annotation = (GeneratedAnnotation) other;\n            return value.equals(annotation.value()) && priority == annotation.priority();\n        }\n\n        @Override\n        public int hashCode() {\n            return ((127 * \"value\".hashCode()) ^ value.hashCode())\n                + ((127 * \"priority\".hashCode()) ^ Integer.hashCode(priority));\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 2229, "output": 823, "cacheRead": 25600, "cacheWrite": 0, "totalTokens": 28652, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777437626240, "responseId": "resp_0beecbd0b67be1590169f18bbab60881969caca8c89e93108a"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_e69MPvLZAVPR1rIy0LYrRBQX|fc_0beecbd0b67be1590169f18bc0d23481968256c487ef36a921", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2571 bytes to tests/src/org.modelmapper/modelmapper/3.2.0/src/test/java/org_modelmapper/modelmapper/AnnotationDescriptionInnerAnnotationInvocationHandlerTest.java"}], "isError": false, "timestamp": 1777437635540}]}
