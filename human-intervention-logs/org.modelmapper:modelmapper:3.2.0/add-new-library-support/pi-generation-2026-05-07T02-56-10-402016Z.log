[tool-call] delta {"path":"tests/src/org.modelmapper/modelmapper/3.2.0/src/test/java/org_modelmapper/modelmapper/ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeOverrideTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_modelmapper.modelmapper;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.IOException;\nimport java.lang.reflect.InvocationTargetException;\nimport java.net.JarURLConnection;\nimport java.net.URL;\nimport java.net.URLClassLoader;\nimport java.security.Permission;\nimport java.security.ProtectionDomain;\nimport java.util.Collections;\nimport java.util.Map;\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\nimport org.modelmapper.internal.bytebuddy.ByteBuddy;\nimport org.modelmapper.internal.bytebuddy.dynamic.DynamicType;\nimport org.modelmapper.internal.bytebuddy.dynamic.loading.ClassInjector.UsingReflection;\nimport org.modelmapper.internal.bytebuddy.dynamic.loading.ClassInjector.UsingUnsafe;\nimport org.modelmapper.internal.bytebuddy.dynamic.loading.PackageDefinitionStrategy;\nimport org.modelmapper.internal.bytebuddy.dynamic.loading.PackageDefinitionStrategy.Definition;\nimport org.modelmapper.internal.bytebuddy.dynamic.scaffold.subclass.ConstructorStrategy;\n\npublic class ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeOverrideTest {\n    private static final String BYTE_BUDDY_SAFE_PROPERTY =\n            \"org.modelmapper.internal.bytebuddy.safe\";\n\n    @Test\n    void injectsGeneratedClassesThroughUnsafeOverrideDispatcher() throws Exception {\n        try {\n            runInIsolatedModelMapperLoader();\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        } catch (UnsupportedOperationException exception) {\n            assertThat(exception.getMessage())\n                    .startsWith(\"Cannot \")\n                    .contains(\" using reflection: \");\n        }\n    }\n\n    private static void runInIsolatedModelMapperLoader() throws Exception {\n        URL modelMapperUrl = modelMapperJarUrl();\n        URL testClassesUrl = ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeOverrideTest\n                .class\n                .getProtectionDomain()\n                .getCodeSource()\n                .getLocation();\n        try (ChildFirstClassLoader classLoader = new ChildFirstClassLoader(\n                new URL[] {testClassesUrl, modelMapperUrl},\n                ClassLoader.getSystemClassLoader())) {\n            Class<?> scenarioClass = classLoader.loadClass(UnsafeOverrideDispatcherScenario.class.getName());\n            Runnable scenario = (Runnable) scenarioClass.getDeclaredConstructor().newInstance();\n            scenario.run();\n        } catch (InvocationTargetException exception) {\n            Throwable target = exception.getTargetException();\n            if (target instanceof Exception) {\n                throw (Exception) target;\n            }\n            if (target instanceof Error) {\n                throw (Error) target;\n            }\n            throw exception;\n        }\n    }\n\n    private static URL modelMapperJarUrl() throws IOException {\n        URL resource = ClassLoader.getSystemResource(\"org/modelmapper/ModelMapper.class\");\n        assertThat(resource).as(\"ModelMapper class resource\").isNotNull();\n        if (\"jar\".equals(resource.getProtocol())) {\n            return ((JarURLConnection) resource.openConnection()).getJarFileURL();\n        }\n        String path = resource.toString();\n        String suffix = \"org/modelmapper/ModelMapper.class\";\n        assertThat(path).endsWith(suffix);\n        return new URL(path.substring(0, path.length() - suffix.length()));\n    }\n\n    public static final class UnsafeOverrideDispatcherScenario implements Runnable {\n        private static final Definition PACKAGE_DEFINITION = new Definition.Simple(\n                \"ModelMapper test specification\",\n                \"1\",\n                \"ModelMapper tests\",\n                \"ModelMapper test implementation\",\n                \"1\",\n                \"ModelMapper tests\",\n                null);\n\n        @Override\n        public void run() {\n            String previousValue = System.setProperty(BYTE_BUDDY_SAFE_PROPERTY, \"true\");\n            SecurityManager previousSecurityManager = System.getSecurityManager();\n            boolean securityManagerChanged = false;\n            try {\n                if (UsingUnsafe.isAvailable()) {\n                    throw new AssertionError(\"UsingUnsafe should be unavailable in the isolated loader\");\n                }\n                System.setProperty(BYTE_BUDDY_SAFE_PROPERTY, \"false\");\n                securityManagerChanged = installPermissiveSecurityManager();\n                ClassLoader parentClassLoader = getClass().getClassLoader();\n                injectGeneratedType(\n                        new ClassLoader(parentClassLoader) {\n                        },\n                        \"org_modelmapper.modelmapper.generated.UnsafeOverrideInjectedType\");\n                injectGeneratedType(\n                        new PackageDefinitionFailingClassLoader(parentClassLoader),\n                        \"org_modelmapper.modelmapper.fallback.UnsafeOverrideFallbackType\");\n            } finally {\n                if (securityManagerChanged) {\n                    System.setSecurityManager(previousSecurityManager);\n                }\n                if (previousValue == null) {\n                    System.clearProperty(BYTE_BUDDY_SAFE_PROPERTY);\n                } else {\n                    System.setProperty(BYTE_BUDDY_SAFE_PROPERTY, previousValue);\n                }\n            }\n        }\n\n        private static void injectGeneratedType(ClassLoader classLoader, String className) {\n            Map<String, Class<?>> loadedTypes = new UsingReflection(\n                    classLoader,\n                    (ProtectionDomain) null,\n                    new AlwaysDefinedPackageStrategy(),\n                    false).injectRaw(generatedType(className));\n\n            Class<?> loadedType = loadedTypes.get(className);\n            if (loadedTypes.size() != 1 || loadedType == null) {\n                throw new AssertionError(\"Unexpected loaded types: \" + loadedTypes);\n            }\n            if (!className.equals(loadedType.getName())) {\n                throw new AssertionError(\"Unexpected loaded type name: \" + loadedType.getName());\n            }\n            if (loadedType.getClassLoader() != classLoader) {\n                throw new AssertionError(\"Unexpected class loader: \" + loadedType.getClassLoader());\n            }\n        }\n\n        private static Map<String, byte[]> generatedType(String className) {\n            DynamicType.Unloaded<?> unloaded = new ByteBuddy()\n                    .subclass(Object.class, ConstructorStrategy.Default.NO_CONSTRUCTORS)\n                    .name(className)\n                    .make();\n            return Collections.singletonMap(className, unloaded.getBytes());\n        }\n\n        private static boolean installPermissiveSecurityManager() {\n            try {\n                SecurityManager securityManager = new PermissiveSecurityManager();\n                System.setSecurityManager(securityManager);\n                return System.getSecurityManager() == securityManager;\n            } catch (UnsupportedOperationException | SecurityException ignored) {\n                return false;\n            }\n        }\n\n        private static final class PermissiveSecurityManager extends SecurityManager {\n            @Override\n            public void checkPermission(Permission permission) {\n                // Allow all permissions so the dispatcher can exercise its security-manager path.\n            }\n        }\n\n        private static final class AlwaysDefinedPackageStrategy implements PackageDefinitionStrategy {\n            @Override\n            public Definition define(ClassLoader classLoader, String packageName, String typeName) {\n                return PACKAGE_DEFINITION;\n            }\n        }\n\n        private static final class PackageDefinitionFailingClassLoader extends ClassLoader {\n            private PackageDefinitionFailingClassLoader(ClassLoader parent) {\n                super(parent);\n            }\n\n            @Override\n            protected Package definePackage(\n                    String name,\n                    String specificationTitle,\n                    String specificationVersion,\n                    String specificationVendor,\n                    String implementationTitle,\n                    String implementationVersion,\n                    String implementationVendor,\n                    URL sealBase) {\n                throw new IllegalStateException(\"Package definition is intentionally unavailable\");\n            }\n\n            @Override\n            @SuppressWarnings(\"deprecation\")\n            protected Package getPackage(String name) {\n                return UnsafeOverrideDispatcherScenario.class.getPackage();\n            }\n        }\n    }\n\n    private static final class ChildFirstClassLoader extends URLClassLoader {\n        private ChildFirstClassLoader(URL[] urls, ClassLoader parent) {\n            super(urls, parent);\n        }\n\n        @Override\n        protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {\n            synchronized (getClassLoadingLock(name)) {\n                Class<?> loadedClass = findLoadedClass(name);\n                if (loadedClass == null && shouldLoadChildFirst(name)) {\n                    try {\n                        loadedClass = findClass(name);\n                    } catch (ClassNotFoundException ignored) {\n                        loadedClass = super.loadClass(name, false);\n                    }\n                } else if (loadedClass == null) {\n                    loadedClass = super.loadClass(name, false);\n                }\n                if (resolve) {\n                    resolveClass(loadedClass);\n                }\n                return loadedClass;\n            }\n        }\n\n        private static boolean shouldLoadChildFirst(String name) {\n            return name.startsWith(\"org.modelmapper.\")\n                    || name.equals(UnsafeOverrideDispatcherScenario.class.getName())\n                    || name.startsWith(UnsafeOverrideDispatcherScenario.class.getName() + \"$\");\n        }\n    }\n}\n"}
