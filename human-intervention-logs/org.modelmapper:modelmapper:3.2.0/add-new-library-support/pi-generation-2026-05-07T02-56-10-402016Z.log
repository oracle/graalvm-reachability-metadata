      private static final class ChildFirstClassLoader extends URLClassLoader {
          private ChildFirstClassLoader(URL[] urls, ClassLoader parent) {
              super(urls, parent);
          }
  
          @Override
          protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {
              synchronized (getClassLoadingLock(name)) {
                  Class<?> loadedClass = findLoadedClass(name);
                  if (loadedClass == null && shouldLoadChildFirst(name)) {
                      try {
                          loadedClass = findClass(name);
                      } catch (ClassNotFoundException ignored) {
                          loadedClass = super.loadClass(name, false);
                      }
                  } else if (loadedClass == null) {
                      loadedClass = super.loadClass(name, false);
                  }
                  if (resolve) {
                      resolveClass(loadedClass);
                  }
                  return loadedClass;
              }
          }
  
          private static boolean shouldLoadChildFirst(String name) {
              String scenarioName = UnsafeOverrideDispatcherScenario.class.getName();
              return name.startsWith("org.modelmapper.")
                      || name.equals(scenarioName)
                      || name.startsWith(scenarioName + Character.toString((char) 36));
          }
      }
  }
  
  class UnsafeOverrideDispatcherAccess extends UsingReflection {
      UnsafeOverrideDispatcherAccess(ClassLoader classLoader) {
          super(classLoader);
      }
  
      static boolean runDispatcherScenario() {
          Dispatcher.Initializable initializable = Dispatcher.CreationAction.INSTANCE.run();
          if (!initializable.isAvailable()) {
              return false;
          }
          assertThat(initializable.getClass().getName()).contains("UsingUnsafeOverride");
          Dispatcher dispatcher = initializable.initialize();
          ClassLoader classLoader = new ClassLoader(
                  ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeOverrideTest
                          .class
                          .getClassLoader()) {
          };
          String packageName = "org_modelmapper.modelmapper.systemoverride";
          String className = packageName + ".UnsafeOverrideSystemInjectedType";
          assertThat(dispatcher.findClass(classLoader, className)).isNull();
          assertThat(dispatcher.getDefinedPackage(classLoader, packageName)).isNull();
          dispatcher.definePackage(
                  classLoader,
                  packageName,
                  "ModelMapper test specification",
                  "1",
                  "ModelMapper tests",
                  "ModelMapper test implementation",
                  "1",
                  "ModelMapper tests",
                  null);
          assertThat(dispatcher.getDefinedPackage(classLoader, packageName)).isNotNull();
          assertThat(dispatcher.getPackage(classLoader, packageName)).isNotNull();
          Class<?> loadedType = dispatcher.defineClass(
                  classLoader,
                  className,
                  ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeOverrideTest
                          .UnsafeOverrideDispatcherScenario
                          .generatedType(className)
                          .get(className),
                  null);
          assertThat(loadedType.getName()).isEqualTo(className);
          assertThat(dispatcher.findClass(classLoader, className)).isSameAs(loadedType);
          return true;
      }
  }
