[tool-call] delta {"path":"tests/src/org.modelmapper/modelmapper/3.2.0/src/test/java/org_modelmapper/modelmapper/ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeOverrideTest.java","edits":[{"oldText":"import org.modelmapper.internal.bytebuddy.dynamic.loading.ClassInjector.UsingReflection;\nimport org.modelmapper.internal.bytebuddy.dynamic.loading.ClassInjector.UsingUnsafe;\n","newText":"import org.modelmapper.internal.bytebuddy.dynamic.loading.ClassInjector.UsingReflection;\nimport org.modelmapper.internal.bytebuddy.dynamic.loading.ClassInjector.UsingReflection.Dispatcher;\nimport org.modelmapper.internal.bytebuddy.dynamic.loading.ClassInjector.UsingReflection.Dispatcher.CreationAction;\nimport org.modelmapper.internal.bytebuddy.dynamic.loading.ClassInjector.UsingReflection.Dispatcher.Initializable;\nimport org.modelmapper.internal.bytebuddy.dynamic.loading.ClassInjector.UsingUnsafe;\n"},{"oldText":"    @Test\n    void injectsGeneratedClassesThroughUnsafeOverrideDispatcher() throws Exception {\n        try {\n            runInIsolatedModelMapperLoader();\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        } catch (UnsupportedOperationException exception) {\n            assertThat(exception.getMessage())\n                    .startsWith(\"Cannot \")\n                    .contains(\" using reflection: \");\n        }\n    }\n\n    private static void runInIsolatedModelMapperLoader() throws Exception {\n","newText":"    @Test\n    void injectsGeneratedClassesThroughUnsafeOverrideDispatcher() throws Exception {\n        try {\n            if (!runThroughSystemLoader()) {\n                runInIsolatedModelMapperLoader();\n            }\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        } catch (UnsupportedOperationException exception) {\n            assertThat(exception.getMessage())\n                    .startsWith(\"Cannot \")\n                    .contains(\" using reflection: \");\n        }\n    }\n\n    private static boolean runThroughSystemLoader() {\n        String previousValue = System.setProperty(BYTE_BUDDY_SAFE_PROPERTY, \"true\");\n        SecurityManager previousSecurityManager = System.getSecurityManager();\n        boolean securityManagerChanged = false;\n        try {\n            if (UsingUnsafe.isAvailable()) {\n                return false;\n            }\n            System.setProperty(BYTE_BUDDY_SAFE_PROPERTY, \"false\");\n            securityManagerChanged =\n                    UnsafeOverrideDispatcherScenario.installPermissiveSecurityManager();\n            Initializable initializable = CreationAction.INSTANCE.run();\n            assertThat(initializable.getClass().getName()).contains(\"UsingUnsafeOverride\");\n            Dispatcher dispatcher = initializable.initialize();\n            ClassLoader classLoader = new ClassLoader(\n                    ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeOverrideTest\n                            .class\n                            .getClassLoader()) {\n            };\n            String packageName = \"org_modelmapper.modelmapper.systemoverride\";\n            String className = packageName + \".UnsafeOverrideSystemInjectedType\";\n            assertThat(dispatcher.findClass(classLoader, className)).isNull();\n            assertThat(dispatcher.getDefinedPackage(classLoader, packageName)).isNull();\n            dispatcher.definePackage(\n                    classLoader,\n                    packageName,\n                    \"ModelMapper test specification\",\n                    \"1\",\n                    \"ModelMapper tests\",\n                    \"ModelMapper test implementation\",\n                    \"1\",\n                    \"ModelMapper tests\",\n                    null);\n            assertThat(dispatcher.getDefinedPackage(classLoader, packageName)).isNotNull();\n            assertThat(dispatcher.getPackage(classLoader, packageName)).isNotNull();\n            Class<?> loadedType = dispatcher.defineClass(\n                    classLoader,\n                    className,\n                    UnsafeOverrideDispatcherScenario.generatedType(className).get(className),\n                    null);\n            assertThat(loadedType.getName()).isEqualTo(className);\n            assertThat(dispatcher.findClass(classLoader, className)).isSameAs(loadedType);\n            return true;\n        } finally {\n            if (securityManagerChanged) {\n                System.setSecurityManager(previousSecurityManager);\n            }\n            if (previousValue == null) {\n                System.clearProperty(BYTE_BUDDY_SAFE_PROPERTY);\n            } else {\n                System.setProperty(BYTE_BUDDY_SAFE_PROPERTY, previousValue);\n            }\n        }\n    }\n\n    private static void runInIsolatedModelMapperLoader() throws Exception {\n"}]}
