n                throw error;\n            }\n        } catch (UnsupportedOperationException exception) {\n            assertThat(exception.getMessage())\n                    .startsWith(\"Cannot \")\n                    .contains(\" using reflection: \");\n        }\n    }\n\n    private static boolean runThroughSystemLoader() {\n        String previousValue = System.setProperty(BYTE_BUDDY_SAFE_PROPERTY, \"true\");\n        SecurityManager previousSecurityManager = System.getSecurityManager();\n        boolean securityManagerChanged = false;\n        try {\n            if (UsingUnsafe.isAvailable()) {\n                return false;\n            }\n            System.setProperty(BYTE_BUDDY_SAFE_PROPERTY, \"false\");\n            securityManagerChanged =\n                    UnsafeOverrideDispatcherScenario.installPermissiveSecurityManager();\n            Initializable initializable = CreationAction.INSTANCE.run();\n            assertThat(initializable.getClass().getName()).contains(\"UsingUnsafeOverride\");\n            Dispatcher dispatcher = initializable.initialize();\n            ClassLoader classLoader = new ClassLoader(\n                    ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeOverrideTest\n                            .class\n                            .getClassLoader()) {\n            };\n            String packageName = \"org_modelmapper.modelmapper.systemoverride\";\n            String className = packageName + \".UnsafeOverrideSystemInjectedType\";\n            assertThat(dispatcher.findClass(classLoader, className)).isNull();\n            assertThat(dispatcher.getDefinedPackage(classLoader, packageName)).isNull();\n            dispatcher.definePackage(\n                    classLoader,\n                    packageName,\n                    \"ModelMapper test specification\",\n                    \"1\",\n                    \"ModelMapper tests\",\n                    \"ModelMapper test implementation\",\n                    \"1\