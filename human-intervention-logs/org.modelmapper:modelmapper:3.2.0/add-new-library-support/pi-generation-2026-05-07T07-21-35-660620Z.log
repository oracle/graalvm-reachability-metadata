  package org_modelmapper.modelmapper;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  import org.modelmapper.internal.asm.ClassVisitor;
  import org.modelmapper.internal.asm.Opcodes;
  import org.modelmapper.internal.bytebuddy.asm.ClassVisitorFactory;
  
  public class ClassVisitorFactoryInnerCreateClassVisitorFactoryTest {
      @Test
      void createsFactoryForBundledAsmClassVisitor() {
          runDynamicClassLoading(() -> {
              ClassVisitorFactory<ClassVisitor> factory = ClassVisitorFactory.of(ClassVisitor.class);
  
              RecordingClassVisitor delegate = new RecordingClassVisitor();
              ClassVisitor wrapped = factory.wrap(delegate);
              wrapped.visit(
                      Opcodes.V17,
                      Opcodes.ACC_PUBLIC,
                      "org_modelmapper/modelmapper/generated/VisitedType",
                      null,
                      "java/lang/Object",
                      new String[0]);
              wrapped.visitEnd();
  
              assertThat(factory.getType()).isSameAs(ClassVisitor.class);
              assertThat(delegate.visitedName).isEqualTo(
                      "org_modelmapper/modelmapper/generated/VisitedType");
              assertThat(delegate.visitEndCount).isEqualTo(1);
  
              ClassVisitor unwrapped = factory.unwrap(delegate);
              unwrapped.visitEnd();
  
              assertThat(delegate.visitEndCount).isEqualTo(2);
          });
      }
  
      private static void runDynamicClassLoading(DynamicClassLoadingOperation operation) {
          try {
              operation.run();
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          } catch (IllegalArgumentException exception) {
              if (!containsUnsupportedFeatureError(exception)) {
                  throw exception;
              }
          }
      }
  
      private static boolean containsUnsupportedFeatureError(Throwable throwable) {
          Throwable current = throwable;
          while (current != null) {
              if (current instanceof Error error
                      && NativeImageSupport.isUnsupportedFeatureError(error)) {
                  return true;
              }
              current = current.getCause();
          }
          return false;
      }
  
      private static final class RecordingClassVisitor extends ClassVisitor {
          private String visitedName;
          private int visitEndCount;
  
          private RecordingClassVisitor() {
              super(Opcodes.ASM9);
          }
  
          @Override
          public void visit(
                  int version,
                  int access,
                  String name,
                  String signature,
                  String superName,
                  String[] interfaces) {
              visitedName = name;
          }
  
          @Override
          public void visitEnd() {
              visitEndCount++;
          }
      }
  
      @FunctionalInterface
      private interface DynamicClassLoadingOperation {
          void run();
      }
