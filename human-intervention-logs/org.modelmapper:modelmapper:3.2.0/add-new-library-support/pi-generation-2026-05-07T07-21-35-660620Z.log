  +/*
  + * Copyright and related rights waived via CC0
  + *
  + * You should have received a copy of the CC0 legalcode along with this
  + * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.
  + */
  +package org_modelmapper.modelmapper;
  +
  +import static org.assertj.core.api.Assertions.assertThat;
  +
  +import java.lang.annotation.Retention;
  +import java.lang.annotation.RetentionPolicy;
  +import org.junit.jupiter.api.Test;
  +import org.modelmapper.internal.bytebuddy.description.annotation.AnnotationDescription;
  +
  +public class AnnotationDescriptionInnerAnnotationInvocationHandlerTest {
  +    @Test
  +    void loadsAnnotationProxyAndComparesItWithRuntimeAnnotation() {
  +        AnnotationDescription description = AnnotationDescription.Builder
  +                .ofType(MappingMarker.class)
  +                .define("name", "customer")
  +                .build();
  +
  +        MappingMarker loadedMarker = description.prepare(MappingMarker.class).load();
  +        MappingMarker runtimeMarker = AnnotatedMapping.class.getAnnotation(MappingMarker.class);
  +
  +        assertThat(loadedMarker.annotationType()).isSameAs(MappingMarker.class);
  +        assertThat(loadedMarker.name()).isEqualTo("customer");
  +        assertThat(loadedMarker.priorities()).containsExactly(1, 3, 5);
  +        assertThat(runtimeMarker).isNotNull();
  +        assertThat(loadedMarker).isEqualTo(runtimeMarker);
  +        assertThat(loadedMarker.hashCode()).isEqualTo(runtimeMarker.hashCode());
  +        assertThat(loadedMarker.toString()).contains("customer");
  +    }
  +
  +    @Retention(RetentionPolicy.RUNTIME)
  +    public @interface MappingMarker {
  +        String name();
  +
  +        int[] priorities() default {1, 3, 5};
  +    }
  +
  +    @MappingMarker(name = "customer")
  +    public static final class AnnotatedMapping {
  +    }
  +}
