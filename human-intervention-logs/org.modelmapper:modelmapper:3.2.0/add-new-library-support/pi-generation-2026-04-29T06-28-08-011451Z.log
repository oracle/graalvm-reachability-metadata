  package org_modelmapper.modelmapper;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import org.junit.jupiter.api.Test;
  import org.modelmapper.internal.bytebuddy.ClassFileVersion;
  import org.modelmapper.internal.bytebuddy.ClassFileVersion.VersionLocator;
  import org.modelmapper.internal.bytebuddy.ClassFileVersion.VersionLocator.Resolver;
  
  public class ClassFileVersionInnerVersionLocatorInnerResolverTest {
      @Test
      void resolvesCurrentRuntimeFeatureVersion() {
          VersionLocator locator = Resolver.INSTANCE.run();
  
          ClassFileVersion classFileVersion = locator.resolve();
  
          assertThat(classFileVersion).isEqualTo(ClassFileVersion.ofJavaVersion(Runtime.version().feature()));
          assertThat(classFileVersion.getJavaVersion()).isEqualTo(Runtime.version().feature());
      }
  }
