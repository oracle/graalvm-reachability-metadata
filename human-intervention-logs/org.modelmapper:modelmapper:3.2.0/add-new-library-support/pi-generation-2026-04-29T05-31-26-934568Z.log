ng()).contains(MISMATCHED_VALUE);\n        assertThatThrownBy(loadedValue::resolve)\n            .isInstanceOf(AnnotationTypeMismatchException.class)\n            .hasMessageContaining(MISMATCHED_VALUE);\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 955, "output": 889, "cacheRead": 19968, "cacheWrite": 0, "totalTokens": 21812, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777440666260, "responseId": "resp_052abf82f80d70ca0169f1979abb2c819f84b98dfd55c3e4d1"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_2hj7ErW6qdAh6tZpokh12Q0s|fc_052abf82f80d70ca0169f197a072b0819f82dda71f6cc41342", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1707 bytes to tests/src/org.modelmapper/modelmapper/3.2.0/src/test/java/org_modelmapper/modelmapper/AnnotationValueInnerForMismatchedTypeTest.java"}], "isError": false, "timestamp": 1777440674710}]}
