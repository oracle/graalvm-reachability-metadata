oader.loadClass(typeName);\n\n        assertThat(definedType.getName()).isEqualTo(typeName);\n        assertThat(definedType.getClassLoader()).isSameAs(classLoader);\n        assertThat(resolvedType).isSameAs(definedType);\n    }\n\n    private static DynamicType.Unloaded<?> makeUnloadedType(String typeName) {\n        return new ByteBuddy()\n            .with(TypeValidation.DISABLED)\n            .subclass(Object.class, ConstructorStrategy.Default.NO_CONSTRUCTORS)\n            .name(typeName)\n            .make();\n    }\n\n    private static ClassLoader isolatedParent() {\n        return new IsolatedParentClassLoader(ByteArrayClassLoaderTest.class.getClassLoader());\n    }\n\n    private static final class IsolatedParentClassLoader extends ClassLoader {\n        IsolatedParentClassLoader(ClassLoader parent) {\n            super(parent);\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 2302, "output": 1005, "cacheRead": 31232, "cacheWrite": 0, "totalTokens": 34539, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777447971020, "responseId": "resp_0d28019913ff70780169f1b423c7c481a2bd4efb13b7719ecd"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_zlFpcthsFkcy3ljs3xfWekUT|fc_0d28019913ff70780169f1b42ba3a881a2ae7974d0d0a2ebee", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2301 bytes to tests/src/org.modelmapper/modelmapper/3.2.0/src/test/java/org_modelmapper/modelmapper/ByteArrayClassLoaderTest.java"}], "isError": false, "timestamp": 1777447982666}]}
