  package org_modelmapper.modelmapper;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import org.junit.jupiter.api.Test;
  import org.modelmapper.internal.bytebuddy.utility.dispatcher.JavaDispatcher;
  
  public class JavaDispatcherInnerDynamicClassLoaderInnerResolverInnerForModuleSystemTest {
      @Test
      void exportsNonExportedJdkPackageToDispatcherClassLoader() throws Exception {
          Class<?> target = ClassLoader.getPlatformClassLoader().loadClass("jdk.internal.misc.Unsafe");
          ExportingDispatcherClassLoader classLoader = new ExportingDispatcherClassLoader(target);
  
          assertThat(target.getModule().isExported(target.getPackageName(), classLoader.getUnnamedModule())).isTrue();
      }
  
      private static final class ExportingDispatcherClassLoader extends JavaDispatcher.DynamicClassLoader {
          private ExportingDispatcherClassLoader(Class<?> target) {
              super(target);
          }
      }
  }
