notationValue<Object, Object> annotationValue = new AnnotationValue.ForMissingValue<>(\n            TypeDescription.ForLoadedType.of(Deprecated.class),\n            MISSING_PROPERTY);\n\n        AnnotationValue.Loaded<Object> loadedValue = annotationValue.load(Deprecated.class.getClassLoader());\n\n        assertThat(annotationValue.getState()).isEqualTo(AnnotationValue.State.UNDEFINED);\n        assertThat(loadedValue.getState()).isEqualTo(AnnotationValue.State.UNDEFINED);\n        assertThat(loadedValue.represents(null)).isFalse();\n        assertThatThrownBy(loadedValue::resolve)\n            .isInstanceOf(IncompleteAnnotationException.class)\n            .hasMessageContaining(Deprecated.class.getName())\n            .hasMessageContaining(MISSING_PROPERTY);\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 621, "output": 635, "cacheRead": 21504, "cacheWrite": 0, "totalTokens": 22760, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777446575136, "responseId": "resp_0789842b232126a10169f1aeafac0c8194a4dfc6bbd762fc96"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_rIxWjJg6Jgd7ysqmfyibksXf|fc_0789842b232126a10169f1aeb41c78819499a705a480a55b54", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1581 bytes to tests/src/org.modelmapper/modelmapper/3.2.0/src/test/java/org_modelmapper/modelmapper/AnnotationValueInnerForMissingValueTest.java"}], "isError": false, "timestamp": 1777446581917}]}
