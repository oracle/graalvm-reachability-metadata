      16	package org.objenesis.instantiator.perc;
      17	
      18	import java.io.ObjectInputStream;
      19	import java.io.Serializable;
      20	import java.lang.reflect.InvocationTargetException;
      21	import java.lang.reflect.Method;
      22	
      23	import org.objenesis.ObjenesisException;
      24	import org.objenesis.instantiator.ObjectInstantiator;
      25	import org.objenesis.instantiator.annotations.Instantiator;
      26	import org.objenesis.instantiator.annotations.Typology;
      27	
      28	/**
      29	 * Instantiates a class by making a call to internal Perc private methods. It is only supposed to
      30	 * work on Perc JVMs. This instantiator will create classes in a way compatible with serialization,
      31	 * calling the first non-serializable superclass' no-arg constructor.
      32	 * <p>
      33	 * Based on code provided by Aonix but <b>doesn't work right now</b>
      34	 *
      35	 * @author Henri Tremblay
      36	 * @see org.objenesis.instantiator.ObjectInstantiator
      37	 */
      38	@Instantiator(Typology.SERIALIZATION)
      39	public class PercSerializationInstantiator<T> implements ObjectInstantiator<T> {
      40	
      41	   private final Object[] typeArgs;
      42	
      43	   private final Method newInstanceMethod;
      44	
      45	   public PercSerializationInstantiator(Class<T> type) {
      46	
      47	      // Find the first unserializable parent class
      48	      Class<? super T> unserializableType = type;
      49	
      50	      while(Serializable.class.isAssignableFrom(unserializableType)) {
      51	         unserializableType = unserializableType.getSuperclass();
      52	      }
      53	
      54	      try {
      55	         // Get the special Perc method to call
      56	         Class<?> percMethodClass = Class.forName("COM.newmonics.PercClassLoader.Method");
      57	
      58	         newInstanceMethod = ObjectInputStream.class.getDeclaredMethod("noArgConstruct",
      59	            Class.class, Object.class, percMethodClass);
      60	         newInstanceMethod.setAccessible(true);
      61	
      62	         // Create invoke params
      63	         Class<?> percClassClass = Class.forName("COM.newmonics.PercClassLoader.PercClass");
      64	         Method getPercClassMethod = percClassClass.getDeclaredMethod("getPercClass", Class.class);
      65	         Object someObject = getPercClassMethod.invoke(null, unserializableType);
      66	         Method findMethodMethod = someObject.getClass().getDeclaredMethod("findMethod",
      67	            String.class);
      68	         Object percMethod = findMethodMethod.invoke(someObject, "<init>()V");
      69	
      70	         typeArgs = new Object[] {unserializableType, type, percMethod};
      71	
      72	      }
      73	      catch(ClassNotFoundException | NoSuchMethodException | IllegalAccessException | InvocationTargetException e) {
      74	         throw new ObjenesisException(e);
      75	      }
      76	   }
      77	
      78	   @SuppressWarnings("unchecked")
      79	   public T newInstance() {
      80	      try {
      81	         return (T) newInstanceMethod.invoke(null, typeArgs);
      82	      }
      83	      catch(IllegalAccessException | InvocationTargetException e) {
      84	         throw new ObjenesisException(e);
      85	      }
      86	   }
      87	
      88	}
