          INJECTED_PACKAGE_NAME)).isNull();\n            assertThat(dispatcher.getPackage(targetClassLoader, INJECTED_PACKAGE_NAME)).isNull();\n\n            Package definedPackage = dispatcher.definePackage(\n                    targetClassLoader,\n                    INJECTED_PACKAGE_NAME,\n                    \"ModelMapper test specification\",\n                    \"1\",\n                    \"ModelMapper test vendor\",\n                    \"ModelMapper test implementation\",\n                    \"1\",\n                    \"ModelMapper test vendor\",\n                    null);\n            assertThat(definedPackage.getName()).isEqualTo(INJECTED_PACKAGE_NAME);\n            assertThat(dispatcher.getDefinedPackage(targetClassLoader, INJECTED_PACKAGE_NAME))\n                    .isSameAs(definedPackage);\n            assertThat(dispatcher.getPackage(targetClassLoader, INJECTED_PACKAGE_NAME))\n                    .isSameAs(definedPackage);\n\n            Class<?> injectedType = dispatcher.defineClass(\n                    targetClassLoader,\n                    INJECTED_TYPE_NAME,\n                    classBytes,\n                    testProtectionDomain());\n            assertThat(injectedType.getName()).isEqualTo(INJECTED_TYPE_NAME);\n            assertThat(injectedType.getClassLoader()).isSameAs(targetClassLoader);\n            assertThat(dispatcher.findClass(targetClassLoader, INJECTED_TYPE_NAME))\n                    .isSameAs(injectedType);\n        }\n    }\n\n    private static final class UnsafeOverrideDispatcherFactory\n            extends UnsafeOverrideAccess.Dispatcher.UsingUnsafeOverride {\n        private UnsafeOverrideDispatcherFactory() {\n            super(null, null, null, null, null);\n        }\n\n        static UnsafeOverrideAccess.Dispatcher.Initializable makeInitializable() throws Exception {\n            return make();\n        }\n    }\n}\n"}
