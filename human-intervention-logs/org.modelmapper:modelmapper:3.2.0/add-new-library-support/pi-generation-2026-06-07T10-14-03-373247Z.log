rt org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\nimport org.modelmapper.internal.bytebuddy.ByteBuddy;\nimport org.modelmapper.internal.bytebuddy.dynamic.DynamicType;\nimport org.modelmapper.internal.bytebuddy.dynamic.loading.ClassInjector.UsingReflection;\n\npublic class ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeOverrideTest {\n    private static final String SAFE_PROPERTY = \"org.modelmapper.internal.bytebuddy.safe\";\n    private static final String INJECTED_TYPE_NAME = \"org_modelmapper.modelmapper.generated.\"\n            + \"UnsafeOverrideInjectedType\";\n    private static final String INJECTED_PACKAGE_NAME = \"org_modelmapper.modelmapper.generated\";\n\n    @Test\n    void unsafeOverrideDispatcherDefinesPackageAndClass() throws Exception {\n        String originalSafeProperty = System.getProperty(SAFE_PROPERTY);\n        System.setProperty(SAFE_PROPERTY, Boolean.FALSE.toString());\n        try {\n            UnsafeOverrideAccess.exercise();\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        } finally {\n            restoreProperty(originalSafeProperty);\n        }\n    }\n\n    private static byte[] makeClassBytes() {\n        DynamicType.Unloaded<?> unloadedType = new ByteBuddy()\n                .subclass(Object.class)\n                .name(INJECTED_TYPE_NAME)\n                .make();\n        return unloadedType.getBytes();\n    }\n\n    private static ClassLoader testClassLoader() {\n        return ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeOverrideTest.class\n                .getClassLoader();\n    }\n\n    private static ProtectionDomain testProtectionDomain() {\n        return ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeOverrideTest.class\n                .getProtectionDomain();\n    }\n\n    private static void restoreProperty(String originalSafeProperty) {\n        if (originalSafeProperty == null) {\n            System.clearProperty(SAFE_PROPERTY);\n        } else {\n            System.setProperty(SAFE_PROPERTY, originalSafeProperty);\n        }\n    }\n\n    private static final class UnsafeOverrideAccess extends UsingReflection {\n        private UnsafeOverrideAccess() {\n            super(testClassLoader());\n        }\n\n        static void exercise() throws Exception {\n            Dispatcher.Initializable initializable = UnsafeOverrideDispatcherFactory.makeInitializable();\n            assertThat(initializable.isAvailable()).isTrue();\n            exerciseAvailableDispatcher(initializable.initialize());\n        }\n\n        private static void exerciseAvailableDispatcher(Dispatcher dispatcher) {\n            ClassLoader targetClassLoader = new ClassLoader(testClassLoader()) {\n            };\n            byte[] classBytes = makeClassBytes();\n\n            Object classLoadingLock = dispatcher.getClassLoadingLock(\n                    targetClassLoader,\n                    INJECTED_TYPE_NAME);\n            assertThat(classLoadingLock).isNotNull();\n            assertThat(dispatcher.findClass(targetClassLoader, INJECTED_TYPE_NAME)).isNull();\n            assertThat(dispatcher.getDefinedPackage(\n                    targetClassLoader,\n                    INJECTED_PACKAGE_NAME)).isNull();\n            assertThat(dispatcher.getPackage(targetClassLoader, INJECTED_PACKAGE_NAME)).isNull();\n\n            Package definedPackage = dispatcher.definePackage(\n                    targetClassLoader,\n                    INJECTED_PACKAGE_NAME,\n                    \"ModelMapper test specification\",\n                    \"1\",\n                    \"ModelMapper test vendor\",\n                    \"ModelMapper test implementation\",\n                    \"1\",\n                    \"ModelMapper test vendor\",\n                    null);\n            assertThat(definedPackage.getName()).isEqualTo(INJECTED_PACKAGE_NAME);\n            assertThat(dispatcher.getDefinedPackage(targetClassLoader, INJECTED_PACKAGE_NAME))\n                    .isSameAs(definedPackage);\n            assertThat(dispatcher.getPackage(targetClassLoader, INJECTED_PACKAGE_NAME))\n                    .isSameAs(definedPackage);\n\n            Class<?> injectedType = dispatcher.defineClass(\n                    targetClassLoader,\n                    INJECTED_TYPE_NAME,\n                    classBytes,\n                    testProtectionDomain());\n            assertThat(injectedType.getName()).isEqualTo(INJECTED_TYPE_NAME);\n            assertThat(injectedType.getClassLoader()).isSameAs(targetClassLoader);\n            assertThat(dispatcher.findClass(targetClassLoader, INJECTED_TYPE_NAME))\n                    .isSameAs(injectedType);\n        }\n    }\n\n    private static final class UnsafeOverrideDispatcherFactory\n            extends UnsafeOverrideAccess.Dispatcher.UsingUnsafeOverride {\n        private UnsafeOverrideDispatcherFactory() {\n            super(null, null, null, null, null);\n        }\n\n        static UnsafeOverrideAccess.Dispatcher.Initializable makeInitializable() throws Exception {\n            return make();\n        }\n    }\n}\n"}, "partialJson": "{\"path\":\"tests/src/org.modelmapper/modelmapper/3.2.0/src/test/java/org_modelmapper/modelmapper/ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeOverrideTest.java\",\"content\":\"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage org_modelmapper.modelmapper;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\n\\nimport java.security.ProtectionDomain;\\nimport org.graalvm.internal.tck.NativeImageSupport;\\nimport org.junit.jupiter.api.Test;\\nimport org.modelmapper.internal.bytebuddy.ByteBuddy;\\nimport org.modelmapper.internal.bytebuddy.dynamic.DynamicType;\\nimport org.modelmapper.internal.bytebuddy.dynamic.loading.ClassInjector.UsingReflection;\\n\\npublic class ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeOverrideTest {\\n    private static final String SAFE_PROPERTY = \\\"org.modelmapper.internal.bytebuddy.safe\\\";\\n    private static final String INJECTED_TYPE_NAME = \\\"org_modelmapper.modelmapper.generated.\\\"\\n            + \\\"UnsafeOverrideInjectedType\\\";\\n    private static final String INJECTED_PACKAGE_NAME = \\\"org_modelmapper.modelmapper.generated\\\";\\n\\n    @Test\\n    void unsafeOverrideDispatcherDefinesPackageAndClass() throws Exception {\\n        String originalSafeProperty = System.getProperty(SAFE_PROPERTY);\\n        System.setProperty(SAFE_PROPERTY, Boolean.FALSE.toString());\\n        try {\\n            UnsafeOverrideAccess.exercise();\\n        } catch (Error error) {\\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\\n                throw error;\\n            }\\n        } finally {\\n            restoreProperty(originalSafeProperty);\\n        }\\n    }\\n\\n    private static byte[] makeClassBytes() {\\n        DynamicType.Unloaded<?> unloadedType = new ByteBuddy()\\n                .subclass(Object.class)\\n                .name(INJECTED_TYPE_NAME)\\n                .make();\\n        return unloadedType.getBytes();\\n    }\\n\\n    private static ClassLoader testClassLoader() {\\n        return ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeOverrideTest.class\\n                .getClassLoader();\\n    }\\n\\n    private static ProtectionDomain testProtectionDomain() {\\n        return ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeOverrideTest.class\\n                .getProtectionDomain();\\n    }\\n\\n    private static void restoreProperty(String originalSafeProperty) {\\n        if (originalSafeProperty == null) {\\n            System.clearProperty(SAFE_PROPERTY);\\n        } else {\\n            System.setProperty(SAFE_PROPERTY, originalSafeProperty);\\n        }\\n    }\\n\\n    private static final class UnsafeOverrideAccess extends UsingReflection {\\n        private UnsafeOverrideAccess() {\\n            super(testClassLoader());\\n        }\\n\\n        static void exercise() throws Exception {\\n            Dispatcher.Initializable initializable = UnsafeOverrideDispatcherFactory.makeInitializable();\\n            assertThat(initializable.isAvailable()).isTrue();\\n            exerciseAvailableDispatcher(initializable.initialize());\\n        }\\n\\n        private static void exerciseAvailableDispatcher(Dispatcher dispatcher) {\\n            ClassLoader targetClassLoader = new ClassLoader(testClassLoader()) {\\n            };\\n            byte[] classBytes = makeClassBytes();\\n\\n            Object classLoadingLock = dispatcher.getClassLoadingLock(\\n                    targetClassLoader,\\n                    INJECTED_TYPE_NAME);\\n            assertThat(classLoadingLock).isNotNull();\\n            assertThat(dispatcher.findClass(targetClassLoader, INJECTED_TYPE_NAME)).isNull();\\n            assertThat(dispatcher.getDefinedPackage(\\n                    targetClassLoader,\\n                    INJECTED_PACKAGE_NAME)).isNull();\\n            assertThat(dispatcher.getPackage(targetClassLoader, INJECTED_PACKAGE_NAME)).isNull();\\n\\n            Package definedPackage = dispatcher.definePackage(\\n                    targetClassLoader,\\n                    INJECTED_PACKAGE_NAME,\\n                    \\\"ModelMapper test specification\\\",\\n                    \\\"1\\\",\\n                    \\\"ModelMapper test vendor\\\",\\n                    \\\"ModelMapper test implementation\\\",\\n                    \\\"1\\\",\\n                    \\\"ModelMapper test vendor\\\",\\n                    null);\\n            assertThat(definedPackage.getName()).isEqualTo(INJECTED_PACKAGE_NAME);\\n            assertThat(dispatcher.getDefinedPackage(targetClassLoader, INJECTED_PACKAGE_NAME))\\n                    .isSameAs(definedPackage);\\n            assertThat(dispatcher.getPackage(targetClassLoader, INJECTED_PACKAGE_NAME))\\n                    .isSameAs(definedPackage);\\n\\n            Class<?> injectedType = dispatcher.defineClass(\\n                    targetClassLoader,\\n                    INJECTED_TYPE_NAME,\\n                    classBytes,\\n                    testProtectionDomain());\\n            assertThat(injectedType.getName()).isEqualTo(INJECTED_TYPE_NAME);\\n            assertThat(injectedType.getClassLoader()).isSameAs(targetClassLoader);\\n            assertThat(dispatcher.findClass(targetClassLoader, INJECTED_TYPE_NAME))\\n                    .isSameAs(injectedType);\\n        }\\n    }\\n\\n    private static final class UnsafeOverrideDispatcherFactory\\n            extends UnsafeOverrideAccess.Dispatcher.UsingUnsafeOverride {\\n        private UnsafeOverrideDispatcherFactory() {\\n            super(null, null, null, null, null);\\n        }\\n\\n        static UnsafeOverrideAccess.Dispatcher.Initializable makeInitializable() throws Exception {\\n            return make();\\n        }\\n    }\\n}\\n\"}"}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1932, "output": 1727, "cacheRead": 35328, "cacheWrite": 0, "totalTokens": 38987, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780827113805, "responseId": "resp_0cf21e8b4f5fb699016a2543ea919881979786bf310c323e49"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_tUxlj4V0uBNmaSGIsAHd5O9p|fc_0cf21e8b4f5fb699016a2543f9bd18819781296ce2bc197d11", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 5440 bytes to tests/src/org.modelmapper/modelmapper/3.2.0/src/test/java/org_modelmapper/modelmapper/ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeOverrideTest.java"}], "isEr