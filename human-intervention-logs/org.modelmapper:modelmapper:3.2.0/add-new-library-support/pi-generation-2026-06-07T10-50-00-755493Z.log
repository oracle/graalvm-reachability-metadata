  plugins {
      id "org.graalvm.internal.tck"
  }
  
  String libraryVersion = tck.testedLibraryVersion.get()
  
  dependencies {
      testImplementation "org.modelmapper:modelmapper:$libraryVersion"
      testImplementation 'net.java.dev.jna:jna:5.8.0'
      testImplementation 'org.assertj:assertj-core:3.22.0'
  }
  
  tasks.named("test") {
      systemProperty "org.modelmapper.internal.bytebuddy.experimental", "true"
      if ((JavaVersion.current().majorVersion as int) < 24) {
          jvmArgs += ["-Djava.security.manager=allow"]
      }
  }
  
  tasks.named("nativeTest") {
