  package org_modelmapper.modelmapper;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.security.Permission;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  import org.modelmapper.internal.bytebuddy.utility.dispatcher.JavaDispatcher;
  import org.modelmapper.spi.ErrorMessage;
  import org.modelmapper.spi.Tokens;
  
  public class JavaDispatcherTest {
      private static final String MISSING_TYPE = "org.modelmapper.spi.MissingDispatcherTarget";
  
      @Test
      void proxyDispatcherUsesDefaultsWhenTargetTypeIsUnavailable() {
          MissingTargetDispatcher dispatcher = DispatcherAccess.create(
                  MissingTargetDispatcher.class,
                  false);
  
          assertThat(dispatcher.isMissingType("anything")).isFalse();
          assertThat(dispatcher.description()).isNull();
          assertThat(dispatcher.count()).isZero();
      }
  
      @Test
      void proxyDispatcherResolvesConstructorsMethodsContainersAndProxiedParameters() {
          ErrorMessageDispatcher errorMessages = DispatcherAccess.create(
                  ErrorMessageDispatcher.class,
                  false);
          ErrorMessage message = errorMessages.make("mapped error");
  
          assertThat(errorMessages.isErrorMessage(message)).isTrue();
          assertThat(errorMessages.isErrorMessage("mapped error")).isFalse();
          assertThat(errorMessages.getMessage(message)).isEqualTo("mapped error");
          assertThat(errorMessages.newArray(2))
                  .hasSize(2)
                  .containsOnlyNulls();
  
          TokensDispatcher tokens = DispatcherAccess.create(TokensDispatcher.class, false);
          Tokens resolved = tokens.of(new String[] {"source", "name"});
  
          assertThat(tokens.size(resolved)).isEqualTo(2);
          assertThat(tokens.token(resolved, 1)).isEqualTo("name");
      }
  
      @Test
      void generatedDispatcherResolvesTheSameSupportedOperationsWhenClassLoadingIsSupported() {
          try {
              MissingTargetDispatcher missing = DispatcherAccess.create(
                      MissingTargetDispatcher.class,
                      true);
              assertThat(missing.description()).isNull();
  
              ErrorMessageDispatcher errorMessages = DispatcherAccess.create(
                      ErrorMessageDispatcher.class,
                      true);
              ErrorMessage message = errorMessages.make("generated dispatcher");
              assertThat(errorMessages.getMessage(message)).isEqualTo("generated dispatcher");
  
              TokensDispatcher tokens = DispatcherAccess.create(TokensDispatcher.class, true);
              Tokens resolved = tokens.of(new String[] {"generated", "tokens"});
              assertThat(tokens.size(resolved)).isEqualTo(2);
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
      }
  
      @Test
      @SuppressWarnings("removal")
      void activeSecurityManagerChecksDispatcherCreationPermissionWhenSupported() {
          SecurityManager originalSecurityManager = System.getSecurityManager();
          RecordingSecurityManager securityManager = new RecordingSecurityManager();
          boolean securityManagerInstalled = false;
          try {
              System.setSecurityManager(securityManager);
              securityManagerInstalled = true;
              ErrorMessageDispatcher errorMessages = DispatcherAccess.create(
                      ErrorMessageDispatcher.class,
                      false);
              assertThat(errorMessages.getMessage(errorMessages.make("secure"))).isEqualTo("secure");
              assertThat(securityManager.dispatcherPermissionChecked()).isTrue();
          } catch (SecurityException | UnsupportedOperationException ignored) {
              ErrorMessageDispatcher errorMessages = DispatcherAccess.create(
                      ErrorMessageDispatcher.class,
                      false);
              assertThat(errorMessages.getMessage(errorMessages.make("secure"))).isEqualTo("secure");
          } finally {
              if (securityManagerInstalled) {
                  System.setSecurityManager(originalSecurityManager);
              }
          }
      }
  
      @JavaDispatcher.Proxied(MISSING_TYPE)
      @JavaDispatcher.Defaults
      public interface MissingTargetDispatcher {
          @JavaDispatcher.Instance
          boolean isMissingType(Object value);
  
          String description();
  
          int count();
      }
  
      @JavaDispatcher.Proxied("org.modelmapper.spi.ErrorMessage")
      public interface ErrorMessageDispatcher {
          @JavaDispatcher.IsConstructor
          ErrorMessage make(@JavaDispatcher.Proxied("java.lang.String") CharSequence message);
  
          String getMessage(ErrorMessage target);
  
          @JavaDispatcher.Instance
          boolean isErrorMessage(Object value);
  
          @JavaDispatcher.Container
          ErrorMessage[] newArray(int size);
      }
  
      @JavaDispatcher.Proxied("org.modelmapper.spi.Tokens")
      public interface TokensDispatcher {
          @JavaDispatcher.IsStatic
          @JavaDispatcher.Proxied("of")
          Tokens of(@JavaDispatcher.Proxied("java.lang.String") CharSequence[] values);
  
          int size(Tokens target);
  
          String token(Tokens target, int position);
      }
  
      private abstract static class DispatcherAccess extends JavaDispatcher<Object> {
          private DispatcherAccess() {
