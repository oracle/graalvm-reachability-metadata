aces,\n                    additionalBridges);\n\n            assertThat(generated).containsExactly(GENERATED_CLASS);\n            assertThat(factory.invocationCount()).isEqualTo(1);\n            assertThat(factory.lastCaller()).isSameAs(caller);\n            assertThat(factory.lastInvokedName()).isEqualTo(\"lambda$mapped$0\");\n            assertThat(factory.lastInvokedType()).isSameAs(invokedType);\n            assertThat(factory.lastSamMethodType()).isSameAs(samMethodType);\n            assertThat(factory.lastImplMethod()).isSameAs(implMethod);\n            assertThat(factory.lastInstantiatedMethodType()).isSameAs(instantiatedMethodType);\n            assertThat(factory.lastSerializable()).isTrue();\n            assertThat(factory.lastMarkerInterfaces()).isSameAs(markerInterfaces);\n            assertThat(factory.lastAdditionalBridges()).isSameAs(additionalBridges);\n            assertThat(factory.lastClassFileTransformers()).contains(transformer);\n\n            registered = false;\n            LambdaFactory.release(transformer);\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        } finally {\n            if (registered) {\n                LambdaFactory.release(transformer);\n            }\n        }\n    }\n\n    private static final class NoOpTransformer implements ClassFileTransformer {\n        @Override\n        public byte[] transform(\n                ClassLoader loader,\n                String className,\n                Class<?> classBeingRedefined,\n                ProtectionDomain protectionDomain,\n                byte[] classfileBuffer) {\n            return null;\n        }\n    }\n\n    public static final class RecordingLambdaClassFileFactory {\n        private final byte[] generatedClass;\n        private int invocationCount;\n        private Object lastCaller;\n        private String lastInvokedName;\n        private Object lastInvokedTyp