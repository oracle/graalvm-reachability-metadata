  package org_modelmapper.modelmapper;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.security.Permission;
  import java.security.PrivilegedAction;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  import org.modelmapper.internal.bytebuddy.utility.dispatcher.JavaDispatcher;
  import org.modelmapper.internal.bytebuddy.utility.dispatcher.JavaDispatcher.Defaults;
  import org.modelmapper.internal.bytebuddy.utility.dispatcher.JavaDispatcher.Instance;
  import org.modelmapper.internal.bytebuddy.utility.dispatcher.JavaDispatcher.Proxied;
  
  public class JavaDispatcherTest {
      @Test
      void createsJdkProxyForUnavailableTypeAndChecksSecurityManagerPermission() {
          SecurityManager previousSecurityManager = System.getSecurityManager();
          boolean securityManagerChanged = previousSecurityManager == null
                  && installPermissiveSecurityManager();
          if (Runtime.version().feature() < 24) {
              assertThat(System.getSecurityManager()).as("SecurityManager test setup").isNotNull();
          }
          PermissiveSecurityManager.reset();
          try {
              UnavailableTypeDefaults dispatcher = DispatcherAccess.of(
                      UnavailableTypeDefaults.class,
                      false).run();
  
              assertThat(dispatcher.text()).isNull();
              assertThat(dispatcher.number()).isZero();
              assertThat(dispatcher.available(new Object())).isFalse();
              if (System.getSecurityManager() instanceof PermissiveSecurityManager) {
                  assertThat(PermissiveSecurityManager.wasJavaDispatcherPermissionChecked())
                          .as("JavaDispatcher permission check")
                          .isTrue();
              }
          } finally {
              if (securityManagerChanged) {
                  System.setSecurityManager(previousSecurityManager);
              }
          }
      }
  
      @Test
      void generatesDispatcherForUnavailableTypeDefaultsWhenRequested() {
          try {
              UnavailableTypeDefaults dispatcher = DispatcherAccess.of(
                      UnavailableTypeDefaults.class,
                      true).run();
  
              assertThat(dispatcher.text()).isNull();
              assertThat(dispatcher.number()).isZero();
              assertThat(dispatcher.available(new Object())).isFalse();
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
      }
  
      private static boolean installPermissiveSecurityManager() {
          try {
              SecurityManager securityManager = new PermissiveSecurityManager();
              System.setSecurityManager(securityManager);
              return System.getSecurityManager() == securityManager;
          } catch (UnsupportedOperationException | SecurityException ignored) {
              return false;
          }
      }
  
      private static final class DispatcherAccess extends JavaDispatcher<Object> {
          private DispatcherAccess() {
              super(Object.class, null, false);
          }
  
          private static <T> PrivilegedAction<T> of(Class<T> type, boolean generate) {
              return DispatcherAccess.of(type, null, generate);
          }
      }
  
      @Defaults
      @Proxied("com.example.DoesNotExist")
      public interface UnavailableTypeDefaults {
          String text();
  
          int number();
  
          @Instance
          boolean available(Object value);
      }
  
      public static final class PermissiveSecurityManager extends SecurityManager {
          private static final String JAVA_DISPATCHER_PERMISSION =
                  "org.modelmapper.internal.bytebuddy.createJavaDispatcher";
  
          private static volatile boolean javaDispatcherPermissionChecked;
  
          private static void reset() {
              javaDispatcherPermissionChecked = false;
          }
  
          private static boolean wasJavaDispatcherPermissionChecked() {
              return javaDispatcherPermissionChecked;
          }
  
          @Override
          public void checkPermission(Permission permission) {
              if (JAVA_DISPATCHER_PERMISSION.equals(permission.getName())) {
                  javaDispatcherPermissionChecked = true;
              }
          }
      }
  }
