   try {\n            runSystemFallback();\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    @Test\n    @Order(2)\n    void createsDispatcherFromSystemLoadedNexusInNamedModuleFallback() throws Exception {\n        try {\n            runInNamedModelMapperModule();\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    @Test\n    @Order(3)\n    void createsDispatcherByInjectingNexusIntoSystemClassLoader() throws Exception {\n        try {\n            runInIsolatedModelMapperLoader();\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    private static void runSystemFallback() {\n        String previousSafeValue = System.setProperty(BYTE_BUDDY_SAFE_PROPERTY, \"true\");\n        String previousDisabledValue = System.clearProperty(NEXUS_DISABLED_PROPERTY);\n        try {\n            assertThat(CreationActionAccess.runCreationAction()).isTrue();\n        } finally {\n            restoreProperty(BYTE_BUDDY_SAFE_PROPERTY, previousSafeValue);\n            restoreProperty(NEXUS_DISABLED_PROPERTY, previousDisabledValue);\n        }\n    }\n\n    private static void runInIsolatedModelMapperLoader() throws Exception {\n        Class<?> testClass = NexusAccessorInnerDispatcherInnerCreationActionTest.class;\n        URL testClassesUrl = testClass.getProtectionDomain().getCodeSource().getLocation();\n        try (ChildFirstClassLoader classLoader = new ChildFirstClassLoader(\n                new URL[] {testClassesUrl, modelMapperCodeSourceUrl()},\n                ClassLoader.getSystemClassLoader(),\n                false)) {\n            Class<?> scenarioClass = classLoader.loadClass(SCENARIO_CLASS_NAME);\n           