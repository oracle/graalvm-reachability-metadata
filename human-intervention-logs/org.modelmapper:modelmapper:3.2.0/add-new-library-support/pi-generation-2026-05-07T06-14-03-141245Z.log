  @Order(0)
  @TestMethodOrder(OrderAnnotation.class)
  public class NexusAccessorInnerDispatcherInnerCreationActionTest {
      private static final String BYTE_BUDDY_SAFE_PROPERTY =
              "org.modelmapper.internal.bytebuddy.safe";
      private static final String NEXUS_DISABLED_PROPERTY =
              "org.modelmapper.internal.bytebuddy.nexus.disabled";
      private static final String CREATION_ACTION_CLASS_NAME =
              "org.modelmapper.internal.bytebuddy.dynamic.NexusAccessor$Dispatcher$CreationAction";
      private static final String NEXUS_RESOURCE =
              "org/modelmapper/internal/bytebuddy/dynamic/Nexus.class";
      private static final String TEST_CLASS_NAME =
              "org_modelmapper.modelmapper.NexusAccessorInnerDispatcherInnerCreationActionTest";
      private static final String SCENARIO_CLASS_NAME =
              TEST_CLASS_NAME + (char) 36 + "InjectionCreationActionScenario";
      private static final String FALLBACK_SCENARIO_CLASS_NAME =
              TEST_CLASS_NAME + (char) 36 + "FallbackCreationActionScenario";
  
      @Test
      @Order(1)
      void createsDispatcherFromSystemLoadedNexusFallback() throws Exception {
          try {
              runSystemFallback();
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
      }
  
      @Test
      @Order(2)
      void createsDispatcherFromSystemLoadedNexusInNamedModuleFallback() throws Exception {
          try {
              runInNamedModelMapperModule();
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
      }
  
      @Test
      @Order(3)
      void createsDispatcherByInjectingNexusIntoSystemClassLoader() throws Exception {
          try {
              runInIsolatedModelMapperLoader();
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
      }
  
      private static void runSystemFallback() {
          String previousSafeValue = System.setProperty(BYTE_BUDDY_SAFE_PROPERTY, "true");
          String previousDisabledValue = System.clearProperty(NEXUS_DISABLED_PROPERTY);
          try {
              assertThat(CreationActionAccess.runCreationAction()).isTrue();
          } finally {
              restoreProperty(BYTE_BUDDY_SAFE_PROPERTY, previousSafeValue);
              restoreProperty(NEXUS_DISABLED_PROPERTY, previousDisabledValue);
          }
      }
  
      private static void runInIsolatedModelMapperLoader() throws Exception {
          Class<?> testClass = NexusAccessorInnerDispatcherInnerCreationActionTest.class;
          URL testClassesUrl = testClass.getProtectionDomain().getCodeSource().getLocation();
          try (ChildFirstClassLoader classLoader = new ChildFirstClassLoader(
                  new URL[] {testClassesUrl, modelMapperCodeSourceUrl()},
                  ClassLoader.getSystemClassLoader(),
                  false)) {
              Class<?> scenarioClass = classLoader.loadClass(SCENARIO_CLASS_NAME);
              Runnable scenario = (Runnable) scenarioClass.getConstructor().newInstance();
              scenario.run();
          } catch (InvocationTargetException exception) {
              throw targetException(exception);
          }
      }
  
      private static void runInIsolatedFallbackModelMapperLoader() throws Exception {
          Class<?> testClass = NexusAccessorInnerDispatcherInnerCreationActionTest.class;
          URL testClassesUrl = testClass.getProtectionDomain().getCodeSource().getLocation();
          try (ChildFirstClassLoader classLoader = new ChildFirstClassLoader(
                  new URL[] {testClassesUrl, modelMapperCodeSourceUrl()},
                  ClassLoader.getSystemClassLoader(),
                  true)) {
              Class<?> scenarioClass = classLoader.loadClass(FALLBACK_SCENARIO_CLASS_NAME);
              Runnable scenario = (Runnable) scenarioClass.getConstructor().newInstance();
              scenario.run();
          } catch (InvocationTargetException exception) {
              throw targetException(exception);
          }
      }
  
      private static void runInNamedModelMapperModule() throws Exception {
          String previousSafeValue = System.setProperty(BYTE_BUDDY_SAFE_PROPERTY, "true");
          String previousDisabledValue = System.clearProperty(NEXUS_DISABLED_PROPERTY);
          try {
              ModuleFinder finder = modelMapperModuleFinder();
              ModuleReference moduleReference = finder.findAll().stream().findFirst().orElseThrow(
                      () -> new AssertionError("ModelMapper module was not found"));
              String moduleName = moduleReference.descriptor().name();
              ModuleLayer parentLayer = ModuleLayer.boot();
              Configuration configuration = parentLayer.configuration()
                      .resolve(finder, ModuleFinder.of(), Set.of(moduleName));
              ModuleLayer layer = parentLayer.defineModulesWithOneLoader(
                      configuration,
                      ClassLoader.getPlatformClassLoader());
              Class<?> actionClass = layer.findLoader(moduleName).loadClass(
                      CREATION_ACTION_CLASS_NAME);
              Object action = enumConstant(actionClass, "INSTANCE");
              Object dispatcher = actionClass.getMethod("run").invoke(action);
              Method isAlive = dispatcher.getClass().getMethod("isAlive");
              assertThat(isAlive.invoke(dispatcher)).isEqualTo(Boolean.TRUE);
          } catch (InvocationTargetException exception) {
              throw targetException(exception);
          } finally {
              restoreProperty(BYTE_BUDDY_SAFE_PROPERTY, previousSafeValue);
              restoreProperty(NEXUS_DISABLED_PROPERTY, previousDisabledValue);
          }
      }
  
      @SuppressWarnings({"rawtypes", "unchecked"})
      private static Object enumConstant(Class<?> enumClass, String name) {
          return Enum.valueOf((Class<? extends Enum>) enumClass.asSubclass(Enum.class), name);
      }
  
      private static Exception targetException(InvocationTargetException exception) throws Exception {
          Throwable target = exception.getTargetException();
          if (target instanceof Exception) {
              return (Exception) target;
          }
          if (target instanceof Error) {
              throw (Error) target;
          }
          return exception;
      }
  
      private static URL modelMapperCodeSourceUrl() throws IOException {
          Enumeration<URL> resources = ClassLoader.getSystemResources(
                  "org/modelmapper/ModelMapper.class");
          URL fallback = null;
          while (resources.hasMoreElements()) {
              URL resource = resources.nextElement();
              URL rootUrl = resourceRootUrl(resource);
              if (rootUrl.toString().contains("/build/jacoco/effective/")) {
                  return rootUrl;
              }
              if (fallback == null) {
                  fallback = rootUrl;
              }
          }
          assertThat(fallback).as("ModelMapper class resource").isNotNull();
          return fallback;
      }
  
      private static ModuleFinder modelMapperModuleFinder() throws IOException, URISyntaxException {
          URL codeSource = modelMapperCodeSourceUrl();
          if ("file".equals(codeSource.getProtocol())) {
              Path codeSourcePath = Paths.get(codeSource.toURI());
              if (Files.isDirectory(codeSourcePath)) {
                  return new ExplodedModelMapperModuleFinder(codeSourcePath, true);
              }
              if (Files.isRegularFile(codeSourcePath)) {
                  return ModuleFinder.of(codeSourcePath);
              }
          }
  
          for (String entry : System.getProperty("java.class.path", "")
                  .split(File.pathSeparator)) {
              if (!entry.isEmpty()) {
                  Path path = Paths.get(entry);
                  String fileName = path.getFileName() == null ? "" : path.getFileName().toString();
                  if (Files.isRegularFile(path)
                          && fileName.startsWith("modelmapper-")
                          && fileName.endsWith(".jar")) {
                      return ModuleFinder.of(path);
                  }
              }
          }
  
          Enumeration<URL> resources = ClassLoader.getSystemResources(
                  "org/modelmapper/ModelMapper.class");
          while (resources.hasMoreElements()) {
              URL resource = resources.nextElement();
              if ("jar".equals(resource.getProtocol())) {
                  URI uri = ((JarURLConnection) resource.openConnection()).getJarFileURL().toURI();
                  return ModuleFinder.of(Paths.get(uri));
              }
          }
          throw new AssertionError("ModelMapper jar was not found on the test class path");
      }
  
      private static URL resourceRootUrl(URL resource) throws IOException {
          if ("jar".equals(resource.getProtocol())) {
              return ((JarURLConnection) resource.openConnection()).getJarFileURL();
          }
          String path = resource.toString();
          String suffix = "org/modelmapper/ModelMapper.class";
          assertThat(path).endsWith(suffix);
          return new URL(path.substring(0, path.length() - suffix.length()));
      }
  
      private static void restoreProperty(String name, String value) {
          if (value == null) {
              System.clearProperty(name);
          } else {
              System.setProperty(name, value);
          }
      }
  
      private static URL invalidNexusResource() {
          try {
              Path resource = Files.createTempFile("invalid-nexus-", ".class");
              resource.toFile().deleteOnExit();
              Files.write(resource, new byte[] {0, 0, 0, 0});
              return resource.toUri().toURL();
          } catch (IOException exception) {
              throw new IllegalStateException(exception);
          }
      }
  
      public static final class InjectionCreationActionScenario implements Runnable {
          public InjectionCreationActionScenario() {
          }
  
          @Override
          public void run() {
              String safeProperty = "org.modelmapper.internal.bytebuddy.safe";
              String disabledProperty = "org.modelmapper.internal.bytebuddy.nexus.disabled";
              String previousSafeValue = System.setProperty(safeProperty, "false");
              String previousDisabledValue = System.clearProperty(disabledProperty);
              try {
                  if (!CreationActionAccess.runCreationAction()) {
                      throw new AssertionError("Nexus dispatcher should be available");
                  }
              } finally {
                  restoreProperty(safeProperty, previousSafeValue);
                  restoreProperty(disabledProperty, previousDisabledValue);
              }
          }
  
          private static void restoreProperty(String name, String value) {
              if (value == null) {
                  System.clearProperty(name);
              } else {
                  System.setProperty(name, value);
              }
          }
      }
  
      public static final class FallbackCreationActionScenario implements Runnable {
          public FallbackCreationActionScenario() {
          }
  
          @Override
          public void run() {
              String safeProperty = "org.modelmapper.internal.bytebuddy.safe";
              String disabledProperty = "org.modelmapper.internal.bytebuddy.nexus.disabled";
              String previousSafeValue = System.setProperty(safeProperty, "true");
              String previousDisabledValue = System.clearProperty(disabledProperty);
              try {
                  if (!CreationActionAccess.runCreationAction()) {
                      throw new AssertionError("Fallback Nexus dispatcher should be available");
                  }
              } finally {
                  restoreProperty(safeProperty, previousSafeValue);
                  restoreProperty(disabledProperty, previousDisabledValue);
              }
          }
  
          private static void restoreProperty(String name, String value) {
              if (value == null) {
                  System.clearProperty(name);
              } else {
                  System.setProperty(name, value);
              }
          }
      }
  
      private static class CreationActionAccess extends NexusAccessor {
          static boolean runCreationAction() {
              Dispatcher dispatcher = Dispatcher.CreationAction.INSTANCE.run();
              return dispatcher.isAlive();
          }
      }
  
      private static final class ExplodedModelMapperModuleFinder implements ModuleFinder {
          private static final String MODULE_NAME = "modelmapper.instrumented";
  
          private final ModuleReference moduleReference;
  
          private ExplodedModelMapperModuleFinder(
                  Path classesDirectory,
                  boolean corruptNexusResource) throws IOException {
              this.moduleReference = new ExplodedModelMapperModuleReference(
                      classesDirectory,
                      corruptNexusResource);
          }
  
          @Override
          public Optional<ModuleReference> find(String name) {
              if (MODULE_NAME.equals(name)) {
                  return Optional.of(moduleReference);
              }
              return Optional.empty();
          }
  
          @Override
          public Set<ModuleReference> findAll() {
              return Set.of(moduleReference);
          }
      }
  
      private static final class ExplodedModelMapperModuleReference extends ModuleReference {
          private final Path classesDirectory;
          private final boolean corruptNexusResource;
          private final Map<String, Integer> readCounts = new HashMap<>();
  
          private ExplodedModelMapperModuleReference(
                  Path classesDirectory,
                  boolean corruptNexusResource) throws IOException {
              super(moduleDescriptor(classesDirectory), classesDirectory.toUri());
              this.classesDirectory = classesDirectory;
              this.corruptNexusResource = corruptNexusResource;
          }
  
          @Override
          public ModuleReader open() {
              return new ExplodedModelMapperModuleReader(
                      classesDirectory,
                      corruptNexusResource,
                      readCounts);
          }
  
          private static ModuleDescriptor moduleDescriptor(Path classesDirectory)
                  throws IOException {
              Set<String> packages = packages(classesDirectory);
              ModuleDescriptor.Builder builder = ModuleDescriptor
                      .newModule(ExplodedModelMapperModuleFinder.MODULE_NAME);
              for (String packageName : packages) {
                  builder.exports(packageName);
              }
              return builder.packages(packages).build();
          }
  
          private static Set<String> packages(Path classesDirectory) throws IOException {
              Set<String> packages = new HashSet<>();
              try (Stream<Path> paths = Files.walk(classesDirectory)) {
                  for (Path path : paths.filter(Files::isRegularFile).toList()) {
                      String entryName = classesDirectory.relativize(path).toString()
                              .replace(File.separatorChar, '/');
                      if (entryName.endsWith(".class") && entryName.contains("/")) {
                          packages.add(entryName.substring(0, entryName.lastIndexOf('/'))
                                  .replace('/', '.'));
                      }
                  }
              }
              return packages;
          }
      }
  
      private static final class ExplodedModelMapperModuleReader implements ModuleReader {
          private final Path classesDirectory;
          private final boolean corruptNexusResource;
          private final Map<String, Integer> readCounts;
  
          private ExplodedModelMapperModuleReader(
                  Path classesDirectory,
                  boolean corruptNexusResource,
                  Map<String, Integer> readCounts) {
              this.classesDirectory = classesDirectory;
              this.corruptNexusResource = corruptNexusResource;
              this.readCounts = readCounts;
          }
  
          @Override
          public Optional<URI> find(String name) throws IOException {
              Path path = classesDirectory.resolve(name);
              if (!Files.isRegularFile(path)) {
                  return Optional.empty();
              }
              if (corruptNexusResource && NEXUS_RESOURCE.equals(name) && accessCount(name) > 1) {
                  return Optional.of(URI.create(invalidNexusResource().toString()));
              }
              return Optional.of(path.toUri());
          }
  
          @Override
          public Optional<ByteBuffer> read(String name) throws IOException {
              Path path = classesDirectory.resolve(name);
              if (!Files.isRegularFile(path)) {
                  return Optional.empty();
              }
              if (corruptNexusResource && NEXUS_RESOURCE.equals(name) && accessCount(name) > 1) {
                  return Optional.of(ByteBuffer.wrap(new byte[] {0, 0, 0, 0}));
              }
              return Optional.of(ByteBuffer.wrap(Files.readAllBytes(path)));
          }
  
          private int accessCount(String name) {
              synchronized (readCounts) {
                  int count = readCounts.getOrDefault(name, 0) + 1;
                  readCounts.put(name, count);
                  return count;
              }
          }
  
          @Override
          public void release(ByteBuffer byteBuffer) {
              // Heap buffers created from class bytes do not hold external resources.
          }
  
          @Override
          public Stream<String> list() throws IOException {
              return Files.walk(classesDirectory)
                      .filter(Files::isRegularFile)
                      .map(path -> classesDirectory.relativize(path).toString()
                              .replace(File.separatorChar, '/'));
          }
  
          @Override
          public void close() {
              // The reader opens a new file-system stream for each listing operation.
          }
      }
  
      private static final class ChildFirstClassLoader extends URLClassLoader {
          private final boolean corruptNexusResource;
  
          private ChildFirstClassLoader(
                  URL[] urls,
                  ClassLoader parent,
                  boolean corruptNexusResource) {
              super(urls, parent);
              this.corruptNexusResource = corruptNexusResource;
          }
  
          @Override
          public URL getResource(String name) {
              if (corruptNexusResource && NEXUS_RESOURCE.equals(name)) {
                  return invalidNexusResource();
              }
              return super.getResource(name);
          }
  
          @Override
          public Enumeration<URL> getResources(String name) throws IOException {
              if (corruptNexusResource && NEXUS_RESOURCE.equals(name)) {
                  Vector<URL> resources = new Vector<>();
                  resources.add(invalidNexusResource());
                  return resources.elements();
              }
              return super.getResources(name);
          }
  
          @Override
          protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {
              synchronized (getClassLoadingLock(name)) {
                  Class<?> loadedClass = findLoadedClass(name);
                  if (loadedClass == null && shouldLoadChildFirst(name)) {
                      try {
                          loadedClass = findClass(name);
                      } catch (ClassNotFoundException ignored) {
                          loadedClass = super.loadClass(name, false);
                      }
                  } else if (loadedClass == null) {
                      loadedClass = super.loadClass(name, false);
                  }
                  if (resolve) {
                      resolveClass(loadedClass);
                  }
                  return loadedClass;
              }
          }
  
          private static boolean shouldLoadChildFirst(String name) {
              return name.startsWith("org.modelmapper.")
                      || name.equals(TEST_CLASS_NAME)
                      || name.startsWith(TEST_CLASS_NAME + Character.toString((char) 36));
          }
