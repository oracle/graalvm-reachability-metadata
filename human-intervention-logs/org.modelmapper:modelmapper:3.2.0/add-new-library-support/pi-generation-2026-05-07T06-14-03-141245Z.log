  graalvmNative {
      agent {
          defaultMode = "conditional"
          modes {
              conditional {
                  userCodeFilterPath = "user-code-filter.json"
              }
          }
      }
  }
  
  String permissiveSecurityManager = "org_modelmapper.modelmapper.JavaDispatcherTest\$PermissiveSecurityManager"
  
  tasks.withType(Test).configureEach {
      if ((JavaVersion.current().majorVersion as int) < 24) {
          jvmArgs += ["-Djava.security.manager=${permissiveSecurityManager}"]
      }
  }
  
  tasks.named("nativeTest") {
      if ((JavaVersion.current().majorVersion as int) < 24) {
          runtimeArgs.add("-Djava.security.manager=${permissiveSecurityManager}")
      }
  }
