Defaults dispatcher = DispatcherAccess.of(\n                    UnavailableTypeDefaults.class,\n                    true).run();\n\n            assertThat(dispatcher.text()).isNull();\n            assertThat(dispatcher.number()).isZero();\n            assertThat(dispatcher.available(new Object())).isFalse();\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    private static boolean installPermissiveSecurityManager() {\n        try {\n            SecurityManager securityManager = new PermissiveSecurityManager();\n            System.setSecurityManager(securityManager);\n            return System.getSecurityManager() == securityManager;\n        } catch (UnsupportedOperationException | SecurityException ignored) {\n            return false;\n        }\n    }\n\n    private static final class DispatcherAccess extends JavaDispatcher<Object> {\n        private DispatcherAccess() {\n            super(Object.class, null, false);\n        }\n\n        private static <T> PrivilegedAction<T> of(Class<T> type, boolean generate) {\n            return JavaDispatcher.of(type, null, generate);\n        }\n    }\n\n    @Defaults\n    @Proxied(\"com.example.DoesNotExist\")\n    private interface UnavailableTypeDefaults {\n        String text();\n\n        int number();\n\n        @Instance\n        boolean available(Object value);\n    }\n\n    private static final class PermissiveSecurityManager extends SecurityManager {\n        @Override\n        public void checkPermission(Permission permission) {\n            // Allow JavaDispatcher to verify its runtime permission and continue dispatching.\n        }\n    }\n}\n"}
