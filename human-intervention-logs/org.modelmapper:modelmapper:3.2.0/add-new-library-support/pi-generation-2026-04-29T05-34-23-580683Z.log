e lookupMethod(String name) {\n        return TypeDescription.ForLoadedType.of(MethodTarget.class)\n            .getDeclaredMethods()\n            .filter(isMethod().and(named(name)))\n            .getOnly();\n    }\n\n    private static MethodDescription.InDefinedShape lookupConstructor(Class<?> type) {\n        return TypeDescription.ForLoadedType.of(type)\n            .getDeclaredMethods()\n            .filter(isConstructor())\n            .getOnly();\n    }\n\n    private static class MethodTarget {\n        public void publicMethod() {\n        }\n\n        private void privateMethod() {\n        }\n    }\n\n    private static class PublicConstructorTarget {\n        public PublicConstructorTarget() {\n        }\n    }\n\n    private static class PrivateConstructorTarget {\n        private PrivateConstructorTarget() {\n        }\n    }\n}\n"}
