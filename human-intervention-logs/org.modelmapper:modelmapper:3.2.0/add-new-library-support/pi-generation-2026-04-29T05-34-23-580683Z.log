[tool-call] delta {"path":"tests/src/org.modelmapper/modelmapper/3.2.0/src/test/java/org_modelmapper/modelmapper/PrivilegedMemberLookupActionTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_modelmapper.modelmapper;\n\nimport static org.assertj.core.api.Assertions.assertThat;\nimport static org.modelmapper.internal.bytebuddy.matcher.ElementMatchers.isConstructor;\nimport static org.modelmapper.internal.bytebuddy.matcher.ElementMatchers.isMethod;\nimport static org.modelmapper.internal.bytebuddy.matcher.ElementMatchers.named;\n\nimport org.junit.jupiter.api.Test;\nimport org.modelmapper.internal.bytebuddy.description.method.MethodDescription;\nimport org.modelmapper.internal.bytebuddy.description.type.TypeDescription;\nimport org.modelmapper.internal.bytebuddy.implementation.auxiliary.PrivilegedMemberLookupAction;\n\npublic class PrivilegedMemberLookupActionTest {\n    @Test\n    void selectsPrivilegedLookupActionsForLoadedMethodsAndConstructors() {\n        assertThat(PrivilegedMemberLookupAction.of(lookupMethod(\"publicMethod\")))\n            .isSameAs(PrivilegedMemberLookupAction.FOR_PUBLIC_METHOD);\n        assertThat(PrivilegedMemberLookupAction.of(lookupMethod(\"privateMethod\")))\n            .isSameAs(PrivilegedMemberLookupAction.FOR_DECLARED_METHOD);\n        assertThat(PrivilegedMemberLookupAction.of(lookupConstructor(PublicConstructorTarget.class)))\n            .isSameAs(PrivilegedMemberLookupAction.FOR_PUBLIC_CONSTRUCTOR);\n        assertThat(PrivilegedMemberLookupAction.of(lookupConstructor(PrivateConstructorTarget.class)))\n            .isSameAs(PrivilegedMemberLookupAction.FOR_DECLARED_CONSTRUCTOR);\n    }\n\n    private static MethodDescription.InDefinedShape lookupMethod(String name) {\n        return TypeDescription.ForLoadedType.of(MethodTarget.class)\n            .getDeclaredMethods()\n            .filter(isMethod().and(named(name)))\n            .getOnly();\n    }\n\n    private static MethodDescription.InDefinedShape lookupConstructor(Class<?> type) {\n        return TypeDescription.ForLoadedType.of(type)\n            .getDeclaredMethods()\n            .filter(isConstructor())\n            .getOnly();\n    }\n\n    private static class MethodTarget {\n        public void publicMethod() {\n        }\n\n        private void privateMethod() {\n        }\n    }\n\n    private static class PublicConstructorTarget {\n        public PublicConstructorTarget() {\n        }\n    }\n\n    private static class PrivateConstructorTarget {\n        private PrivateConstructorTarget() {\n        }\n    }\n}\n"}
