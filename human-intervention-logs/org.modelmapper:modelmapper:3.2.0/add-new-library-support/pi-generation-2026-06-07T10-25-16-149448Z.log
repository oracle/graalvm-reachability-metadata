  package org_modelmapper.modelmapper;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.security.ProtectionDomain;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  import org.modelmapper.internal.bytebuddy.ByteBuddy;
  import org.modelmapper.internal.bytebuddy.dynamic.DynamicType;
  import org.modelmapper.internal.bytebuddy.dynamic.loading.ClassInjector.UsingReflection;
  
  public class ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeInjectionTest {
      private static final String SAFE_PROPERTY = "org.modelmapper.internal.bytebuddy.safe";
      private static final String INJECTED_TYPE_NAME = "org_modelmapper.modelmapper.generated."
              + "UnsafeInjectedType";
      private static final String INJECTED_PACKAGE_NAME = "org_modelmapper.modelmapper.generated";
  
      @Test
      void unsafeReflectionDispatcherDefinesPackageAndClass() {
          String originalSafeProperty = System.getProperty(SAFE_PROPERTY);
          System.setProperty(SAFE_PROPERTY, Boolean.FALSE.toString());
          try {
              exerciseUnsafeDispatcher();
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          } finally {
              restoreProperty(originalSafeProperty);
          }
      }
  
      private static void exerciseUnsafeDispatcher() {
          DispatcherAccess.exercise();
      }
  
      private static byte[] makeClassBytes() {
          DynamicType.Unloaded<?> unloadedType = new ByteBuddy()
                  .subclass(Object.class)
                  .name(INJECTED_TYPE_NAME)
                  .make();
          return unloadedType.getBytes();
      }
  
      private static ClassLoader testClassLoader() {
          return ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeInjectionTest.class
                  .getClassLoader();
      }
  
      private static ProtectionDomain testProtectionDomain() {
          return ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeInjectionTest.class
                  .getProtectionDomain();
      }
  
      private static void restoreProperty(String originalSafeProperty) {
          if (originalSafeProperty == null) {
              System.clearProperty(SAFE_PROPERTY);
          } else {
              System.setProperty(SAFE_PROPERTY, originalSafeProperty);
          }
      }
  
      private static final class DispatcherAccess extends UsingReflection {
          static {
              java.lang.System.setProperty(SAFE_PROPERTY, Boolean.FALSE.toString());
          }
  
          private DispatcherAccess() {
              super(testClassLoader());
          }
  
          static void exercise() {
              Dispatcher.Initializable initializable = Dispatcher.CreationAction.INSTANCE.run();
              if (initializable.isAvailable()) {
                  exerciseAvailableDispatcher(initializable.initialize());
              } else {
                  assertThat(new DispatcherAccess().isAlive()).isFalse();
              }
          }
  
          private static void exerciseAvailableDispatcher(Dispatcher dispatcher) {
              ClassLoader targetClassLoader = new ClassLoader(testClassLoader()) {
              };
              byte[] classBytes = makeClassBytes();
  
              Object classLoadingLock = dispatcher.getClassLoadingLock(
                      targetClassLoader,
                      INJECTED_TYPE_NAME);
              assertThat(classLoadingLock).isNotNull();
              assertThat(dispatcher.findClass(targetClassLoader, INJECTED_TYPE_NAME)).isNull();
              assertThat(dispatcher.getDefinedPackage(
                      targetClassLoader,
                      INJECTED_PACKAGE_NAME)).isNull();
  
              Package definedPackage = dispatcher.definePackage(
                      targetClassLoader,
                      INJECTED_PACKAGE_NAME,
                      "ModelMapper test specification",
                      "1",
                      "ModelMapper test vendor",
                      "ModelMapper test implementation",
                      "1",
                      "ModelMapper test vendor",
                      null);
              assertThat(definedPackage.getName()).isEqualTo(INJECTED_PACKAGE_NAME);
              assertThat(dispatcher.getDefinedPackage(targetClassLoader, INJECTED_PACKAGE_NAME))
                      .isSameAs(definedPackage);
              assertThat(dispatcher.getPackage(targetClassLoader, INJECTED_PACKAGE_NAME))
                      .isSameAs(definedPackage);
  
              Class<?> injectedType = dispatcher.defineClass(
                      targetClassLoader,
                      INJECTED_TYPE_NAME,
                      classBytes,
                      testProtectionDomain());
              assertThat(injectedType.getName()).isEqualTo(INJECTED_TYPE_NAME);
              assertThat(injectedType.getClassLoader()).isSameAs(targetClassLoader);
              assertThat(dispatcher.findClass(targetClassLoader, INJECTED_TYPE_NAME))
                      .isSameAs(injectedType);
          }
      }
  }
