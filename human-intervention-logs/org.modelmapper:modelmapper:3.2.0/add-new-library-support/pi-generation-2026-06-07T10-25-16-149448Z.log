[tool-call] delta {"path":"tests/src/org.modelmapper/modelmapper/3.2.0/src/test/java/org_modelmapper/modelmapper/JavaDispatcherTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_modelmapper.modelmapper;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.security.Permission;\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\nimport org.modelmapper.internal.bytebuddy.utility.dispatcher.JavaDispatcher;\nimport org.modelmapper.spi.ErrorMessage;\nimport org.modelmapper.spi.Tokens;\n\npublic class JavaDispatcherTest {\n    private static final String MISSING_TYPE = \"org.modelmapper.spi.MissingDispatcherTarget\";\n\n    @Test\n    void proxyDispatcherUsesDefaultsWhenTargetTypeIsUnavailable() {\n        MissingTargetDispatcher dispatcher = DispatcherAccess.create(\n                MissingTargetDispatcher.class,\n                false);\n\n        assertThat(dispatcher.isMissingType(\"anything\")).isFalse();\n        assertThat(dispatcher.description()).isNull();\n        assertThat(dispatcher.count()).isZero();\n    }\n\n    @Test\n    void proxyDispatcherResolvesConstructorsMethodsContainersAndProxiedParameters() {\n        ErrorMessageDispatcher errorMessages = DispatcherAccess.create(\n                ErrorMessageDispatcher.class,\n                false);\n        ErrorMessage message = errorMessages.make(\"mapped error\");\n\n        assertThat(errorMessages.isErrorMessage(message)).isTrue();\n        assertThat(errorMessages.isErrorMessage(\"mapped error\")).isFalse();\n        assertThat(errorMessages.getMessage(message)).isEqualTo(\"mapped error\");\n        assertThat(errorMessages.newArray(2))\n                .hasSize(2)\n                .containsOnlyNulls();\n\n        TokensDispatcher tokens = DispatcherAccess.create(TokensDispatcher.class, false);\n        Tokens resolved = tokens.of(new String[] {\"source\", \"name\"});\n\n        assertThat(tokens.size(resolved)).isEqualTo(2);\n        assertThat(tokens.token(resolved, 1)).isEqualTo(\"name\");\n    }\n\n    @Test\n    void generatedDispatcherResolvesTheSameSupportedOperationsWhenClassLoadingIsSupported() {\n        try {\n            MissingTargetDispatcher missing = DispatcherAccess.create(\n                    MissingTargetDispatcher.class,\n                    true);\n            assertThat(missing.description()).isNull();\n\n            ErrorMessageDispatcher errorMessages = DispatcherAccess.create(\n                    ErrorMessageDispatcher.class,\n                    true);\n            ErrorMessage message = errorMessages.make(\"generated dispatcher\");\n            assertThat(errorMessages.getMessage(message)).isEqualTo(\"generated dispatcher\");\n\n            TokensDispatcher tokens = DispatcherAccess.create(TokensDispatcher.class, true);\n            Tokens resolved = tokens.of(new String[] {\"generated\", \"tokens\"});\n            assertThat(tokens.size(resolved)).isEqualTo(2);\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    @Test\n    @SuppressWarnings(\"removal\")\n    void activeSecurityManagerChecksDispatcherCreationPermissionWhenSupported() {\n        SecurityManager originalSecurityManager = System.getSecurityManager();\n        RecordingSecurityManager securityManager = new RecordingSecurityManager();\n        boolean securityManagerInstalled = false;\n        try {\n            System.setSecurityManager(securityManager);\n            securityManagerInstalled = true;\n            ErrorMessageDispatcher errorMessages = DispatcherAccess.create(\n                    ErrorMessageDispatcher.class,\n                    false);\n            assertThat(errorMessages.getMessage(errorMessages.make(\"secure\"))).isEqualTo(\"secure\");\n            assertThat(securityManager.dispatcherPermissionChecked()).isTrue();\n        } catch (SecurityException | UnsupportedOperationException ignored) {\n            ErrorMessageDispatcher errorMessages = DispatcherAccess.create(\n                    ErrorMessageDispatcher.class,\n                    false);\n            assertThat(errorMessages.getMessage(errorMessages.make(\"secure\"))).isEqualTo(\"secure\");\n        } finally {\n            if (securityManagerInstalled) {\n                System.setSecurityManager(originalSecurityManager);\n            }\n        }\n    }\n\n    @JavaDispatcher.Proxied(MISSING_TYPE)\n    @JavaDispatcher.Defaults\n    public interface MissingTargetDispatcher {\n        @JavaDispatcher.Instance\n        boolean isMissingType(Object value);\n\n        String description();\n\n        int count();\n    }\n\n    @JavaDispatcher.Proxied(\"org.modelmapper.spi.ErrorMessage\")\n    public interface ErrorMessageDispatcher {\n        @JavaDispatcher.IsConstructor\n        ErrorMessage make(@JavaDispatcher.Proxied(\"java.lang.String\") CharSequence message);\n\n        String getMessage(ErrorMessage target);\n\n        @JavaDispatcher.Instance\n        boolean isErrorMessage(Object value);\n\n        @JavaDispatcher.Container\n        ErrorMessage[] newArray(int size);\n    }\n\n    @JavaDispatcher.Proxied(\"org.modelmapper.spi.Tokens\")\n    public interface TokensDispatcher {\n        @JavaDispatcher.IsStatic\n        @JavaDispatcher.Proxied(\"of\")\n        Tokens of(@JavaDispatcher.Proxied(\"java.lang.String\") CharSequence[] values);\n\n        int size(Tokens target);\n\n        String token(Tokens target, int position);\n    }\n\n    private abstract static class DispatcherAccess extends JavaDispatcher<Object> {\n        private DispatcherAccess() {\n            super(Object.class, null, false);\n        }\n\n        static <T> T create(Class<T> proxy, boolean generate) {\n            return of(proxy, JavaDispatcherTest.class.getClassLoader(), generate).run();\n        }\n    }\n\n    @SuppressWarnings(\"removal\")\n    private static final class RecordingSecurityManager extends SecurityManager {\n        private boolean dispatcherPermissionChecked;\n\n        @Override\n        public void checkPermission(Permission permission) {\n            if (permission.getName().endsWith(\"createJavaDispatcher\")) {\n                dispatcherPermissionChecked = true;\n            }\n        }\n\n        boolean dispatcherPermissionChecked() {\n            return dispatcherPermissionChecked;\n        }\n    }\n}\n"}
