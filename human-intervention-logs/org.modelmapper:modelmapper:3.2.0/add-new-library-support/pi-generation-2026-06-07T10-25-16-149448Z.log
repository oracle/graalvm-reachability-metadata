ss() {\n            super(testClassLoader());\n        }\n\n        static void exercise() {\n            Dispatcher.Initializable initializable = Dispatcher.CreationAction.INSTANCE.run();\n            if (initializable.isAvailable()) {\n                exerciseAvailableDispatcher(initializable.initialize());\n            } else {\n                assertThat(new DispatcherAccess().isAlive()).isFalse();\n            }\n        }\n\n        private static void exerciseAvailableDispatcher(Dispatcher dispatcher) {\n            ClassLoader targetClassLoader = new ClassLoader(testClassLoader()) {\n            };\n            byte[] classBytes = makeClassBytes();\n\n            Object classLoadingLock = dispatcher.getClassLoadingLock(\n                    targetClassLoader,\n                    INJECTED_TYPE_NAME);\n            assertThat(classLoadingLock).isNotNull();\n            assertThat(dispatcher.findClass(targetClassLoader, INJECTED_TYPE_NAME)).isNull();\n            assertThat(dispatcher.getDefinedPackage(\n                    targetClassLoader,\n                    INJECTED_PACKAGE_NAME)).isNull();\n\n            Package definedPackage = dispatcher.definePackage(\n                    targetClassLoader,\n                    INJECTED_PACKAGE_NAME,\n                    \"ModelMapper test specification\",\n                    \"1\",\n                    \"ModelMapper test vendor\",\n                    \"ModelMapper test implementation\",\n                    \"1\",\n                    \"ModelMapper test vendor\",\n                    null);\n            assertThat(definedPackage.getName()).isEqualTo(INJECTED_PACKAGE_NAME);\n            assertThat(dispatcher.getDefinedPackage(targetClassLoader, INJECTED_PACKAGE_NAME))\n                    .isSameAs(definedPackage);\n            assertThat(dispatcher.getPackage(targetClassLoader, INJECTED_PACKAGE_NAME))\n                    .isSameAs(definedPackage);\n\n            Class<?> injectedType = dispatcher.defineClass(\n                    targetClassLoader,\n                    INJECTED_TYPE_NAME,\n                    classBytes,\n                    testProtectionDomain());\n            assertThat(injectedType.getName()).isEqualTo(INJECTED_TYPE_NAME);\n            assertThat(injectedType.getClassLoader()).isSameAs(targetClassLoader);\n            assertThat(dispatcher.findClass(targetClassLoader, INJECTED_TYPE_NAME))\n                    .isSameAs(injectedType);\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1780827709883}, {"role": "toolResult", "toolCallId": "call_otn67vUeJi13Bh70MDcZ1TXR|fc_0a026d27173957b2016a25463d869081949404ce54c686d9db", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_modelmapper.modelmapper;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.security.Permission;\nimport java.security.ProtectionDomain;\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\nimport org.modelmapper.internal.bytebuddy.ByteBuddy;\nimport org.modelmapper.internal.bytebuddy.dynamic.DynamicType;\nimport org.modelmapper.internal.bytebuddy.dynamic.loading.ClassInjector.UsingReflection;\n\npublic class ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeOverrideTest {\n    private static final String SAFE_PROPERTY = \"org.modelmapper.internal.bytebuddy.safe\";\n    private static final String EXPERIMENTAL_PROPERTY = \"org.modelmapper.internal.bytebuddy.experimental\";\n    private static final String INJECTED_TYPE_NAME = \"org_modelmapper.modelmapper.generated.\"\n            + \"UnsafeOverrideInjectedType\";\n    private static final String INJECTED_PACKAGE_NAME = \"org_modelmapper.modelmapper.generated\";\n\n    @Test\n    void unsafeOverrideDispatcherDefinesPackageAndClass() throws Exception {\n        String originalSafeProperty = System.getProperty(SAFE_PROPERTY);\n        String originalExperimentalProperty = System.getProperty(EXPERIMENTAL_PROPERTY);\n        System.setProperty(SAFE_PROPERTY, Boolean.FALSE.toString());\n        System.setProperty(EXPERIMENTAL_PROPERTY, Boolean.TRUE.toString());\n        try {\n            UnsafeOverrideAccess.exercise();\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        } finally {\n            restoreProperty(SAFE_PROPERTY, originalSafeProperty);\n            restoreProperty(EXPERIMENTAL_PROPERTY, originalExperimentalProperty);\n        }\n    }\n\n    private static byte[] makeClassBytes() {\n        DynamicType.Unloaded<?> unloadedType = new ByteBuddy()\n                .subclass(Object.class)\n                .name(INJECTED_TYPE_NAME)\n                .make();\n        return unloadedType.getBytes();\n    }\n\n    private static ClassLoader testClassLoader() {\n        return ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeOverrideTest.class\n                .getClassLoader();\n    }\n\n    private static ProtectionDomain testProtectionDomain() {\n        return ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeOverrideTest.class\n                .getProtectionDomain();\n    }\n\n    private static void restoreProperty(String propertyName, String originalValue) {\n        if (originalValue == null) {\n            System.clearProperty(propertyName);\n        } else {\n            System.setProperty(propertyName, originalValue);\n        }\n    }\n\n    private static final class UnsafeOverrideAccess extends UsingReflection {\n        private UnsafeOverrideAccess() {\n            super(testClassLoader());\n        }\n\n        static void exercise() throws Exception {\n            Dispatcher.Initializable initializable = UnsafeOverrideDispatcherFactory\n                    .makeInitializable();\n            assertThat(initializable.isAvailable()).isTrue();\n            exerciseAvailableDispatcher(initializeWithSecurityManager(initializable));\n        }\n\n        @SuppressWarnings(\"removal\")\n        private static Dispatcher initializeWithSecurityManager(\n                Dispatcher.Initializable initializable) {\n            SecurityManager originalSecurityManager = java.lang.System.getSecurityManager();\n            boolean securityManagerChanged = false;\n            try {\n                java.lang.System.setSecurityManager(new SecurityManager() {\n                    @Override\n                    public void checkPermission(Permission permission) {\n                    }\n                });\n                securityManagerChanged = true;\n                return initializable.initialize();\n            } catch (SecurityException | UnsupportedOperationException ignored) {\n                return initializable.initialize();\n            } finally {\n                if (securityManagerChanged) {\n                    java.lang.System.setSecurityManager(originalSecurityManager);\n                }\n            }\n        }\n\n        private static void exerciseAvailableDispatcher(Dispatcher dispatcher) {\n            ClassLoader targetClassLoader = new ClassLoader(testClassLoader()) {\n            };\n            byte[] classBytes = makeClassBytes();\n\n            Object classLoadingLock = dispatcher.getClassLoadingLock(\n                    targetClassLoader,\n                    INJECTED_TYPE_NAME);\n            assertThat(classLoadingLock).isNotNull();\n            assertThat(dispatcher.findClass(targetClassLoader, INJECTED_TYPE_NAME)).isNull();\n            assertThat(dispatcher.getDefinedPackage(\n                    targetClassLoader,\n                    INJECTED_PACKAGE_NAME)).isNull();\n            assertThat(dispatcher.getPackage(targetClassLoader, INJECTED_PACKAGE_NAME)).isNull();\n\n            Package definedPackage = dispatcher.definePackage(\n                    targetClassLoader,\n                    INJECTED_PACKAGE_NAME,\n                    \"ModelMapper test specification\",\n                    \"1\",\n                    \"ModelMapper test vendor\",\n                    \"ModelMapper test implementation\",\n                    \"1\",\n                    \"ModelMapper test vendor\",\n                    null);\n            assertThat(definedPackage.getName()).isEqualTo(INJECTED_PACKAGE_NAME);\n            assertThat(dispatcher.getDefinedPackage(targetClassLoader, INJECTED_PACKAGE_NAME))\n                    .isSameAs(definedPackage);\n            assertThat(dispatcher.getPackage(targetClassLoader, INJECTED_PACKAGE_NAME))\n                    .isSameAs(definedPackage);\n\n            Class<?> injectedType = dispatcher.defineClass(\n                    targetClassLoader,\n                    INJECTED_TYPE_NAME,\n                    classBytes,\n                    testProtectionDomain());\n            assertThat(injectedType.getName()).isEqualTo(INJECTED_TYPE_NAME);\n            assertThat(injectedType.getClassLoader()).isSameAs(targetClassLoader);\n            assertThat(dispatcher.findClass(targetClassLoader, INJECTED_TYPE_NAME))\n                    .isSameAs(injectedType);\n        }\n\n        private abstract static class UnsafeOverrideDispatcherFactory\n                extends Dispatcher.UsingUnsafeOverride {\n            private UnsafeOverrideDispatcherFactory() {\n                super(null, null, null, null, null);\n            }\n\n            static Dispatcher.Initializable makeInitializable() throws Exception {\n                return make();\n            }\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1780827709884}]}
