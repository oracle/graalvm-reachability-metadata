  package org_modelmapper.modelmapper;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.lang.reflect.GenericArrayType;
  import java.lang.reflect.Type;
  import org.junit.jupiter.api.Test;
  import org.modelmapper.internal.typetools.TypeResolver;
  
  public class TypeResolverTest {
      @Test
      void resolvesGenericArrayRawClassAndReifiesArrayType() throws Exception {
          Type valuesType = GenericArrayHolder.class.getField("values").getGenericType();
          assertThat(valuesType).isInstanceOf(GenericArrayType.class);
  
          assertThat(TypeResolver.resolveRawClass(valuesType, StringArrayHolder.class))
                  .isEqualTo(String[].class);
          assertThat(TypeResolver.reify(valuesType, StringArrayHolder.class))
                  .isEqualTo(String[].class);
      }
  
      @Test
      void resolvesLambdaArgumentsFromFunctionalInterface() {
          GenericConverter<String, Integer> converter = Integer::valueOf;
  
          Class<?>[] arguments = TypeResolver.resolveRawArguments(
                  GenericConverter.class,
                  converter.getClass());
  
          assertThat(arguments).satisfiesAnyOf(
                  resolved -> assertThat(resolved).containsExactly(String.class, Integer.class),
                  unresolved -> assertThat(unresolved).containsExactly(
                          TypeResolver.Unknown.class,
                          TypeResolver.Unknown.class));
      }
  
      public static class GenericArrayHolder<T> {
          public T[] values;
      }
  
      public static final class StringArrayHolder extends GenericArrayHolder<String> {
      }
  
      @FunctionalInterface
      private interface GenericConverter<S, T> {
          T convert(S value);
      }
  }
