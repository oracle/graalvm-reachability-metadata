          && type != Date.class
          && type != Calendar.class
          && !Primitives.isPrimitive(type)
          && !Iterables.isIterable(type)
          && !Types.isGroovyType(type);
    }
  
    public static boolean isInternalType(Class<?> type) {
      String packageName = type.getPackage().getName();
      return packageName.startsWith("java.");
    }
  }
