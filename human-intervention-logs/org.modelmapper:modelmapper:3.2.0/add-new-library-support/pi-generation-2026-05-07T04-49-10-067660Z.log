[tool-call] delta {"path":"tests/src/org.modelmapper/modelmapper/3.2.0/src/test/java/org_modelmapper/modelmapper/TypesTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_modelmapper.modelmapper;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.lang.reflect.GenericArrayType;\nimport org.junit.jupiter.api.Test;\nimport org.modelmapper.internal.asm.Type;\nimport org.modelmapper.internal.util.Types;\n\npublic class TypesTest {\n    @Test\n    void resolvesRawTypeForGenericArrayType() {\n        Class<?> rawType = Types.rawTypeFor(new GenericStringArrayType());\n\n        assertThat(rawType).isEqualTo(String[].class);\n    }\n\n    @Test\n    void resolvesArrayClassFromAsmDescriptor() throws ClassNotFoundException {\n        Type stringMatrixType = Type.getType(\"[[Ljava/lang/String;\");\n\n        Class<?> resolvedType = Types.classFor(\n                stringMatrixType,\n                Thread.currentThread().getContextClassLoader());\n\n        assertThat(resolvedType).isEqualTo(String[][].class);\n    }\n\n    @Test\n    void checksPlainClassAgainstAvailableJavassistProxySupport() {\n        assertThat(Types.isProxied(PlainDestination.class)).isFalse();\n    }\n\n    private static final class GenericStringArrayType implements GenericArrayType {\n        @Override\n        public java.lang.reflect.Type getGenericComponentType() {\n            return String.class;\n        }\n    }\n\n    private static final class PlainDestination {\n        private String value;\n\n        String getValue() {\n            return value;\n        }\n\n        void setValue(String value) {\n            this.value = value;\n        }\n    }\n}\n"}
