  diff --git 1/tests/src/org.modelmapper/modelmapper/3.2.0/src/test/java/org_modelmapper/modelmapper/JavaDispatcherTest.java 2/tests/src/org.modelmapper/modelmapper/3.2.0/src/test/java/org_modelmapper/modelmapper/JavaDispatcherTest.java
  new file mode 100644
  index 0000000000..75b059893f
  --- /dev/null
