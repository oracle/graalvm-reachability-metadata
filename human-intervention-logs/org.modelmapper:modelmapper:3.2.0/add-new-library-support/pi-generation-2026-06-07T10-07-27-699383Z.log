/modelmapper/3.2.0/src/test/java/org_modelmapper/modelmapper/ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeInjectionTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_modelmapper.modelmapper;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\nimport org.modelmapper.internal.bytebuddy.ByteBuddy;\nimport org.modelmapper.internal.bytebuddy.dynamic.DynamicType;\nimport org.modelmapper.internal.bytebuddy.dynamic.loading.ClassInjector.UsingReflection.Dispatcher;\nimport org.modelmapper.internal.bytebuddy.dynamic.loading.ClassInjector.UsingReflection.Dispatcher.CreationAction;\nimport org.modelmapper.internal.bytebuddy.dynamic.loading.ClassInjector.UsingReflection.Dispatcher.Initializable;\n\npublic class ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeInjectionTest {\n    private static final String SAFE_PROPERTY = \"org.modelmapper.internal.bytebuddy.safe\";\n    private static final String INJECTED_TYPE_NAME = \"org_modelmapper.modelmapper.generated.UnsafeInjectedType\";\n    private static final String INJECTED_PACKAGE_NAME = \"org_modelmapper.modelmapper.generated\";\n\n    @Test\n    void unsafeReflectionDispatcherDefinesPackageAndClass() {\n        String originalSafeProperty = System.getProperty(SAFE_PROPERTY);\n        System.setProperty(SAFE_PROPERTY, Boolean.FALSE.toString());\n        try {\n            exerciseUnsafeDispatcher();\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        } finally {\n            restoreProperty(originalSafeProperty);\n        }\n    }\n\n    private static void exerciseUnsafeDispatcher() {\n        Initializable initializable = CreationAction.INSTANCE.run();\n        assertThat(initializable.isAvailable()).isTrue();\n\n        Dispatcher dispatcher = initializable.initialize();\n        ClassLoader targetClassLoader = new ClassLoader(\n                ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeInjectionTest.class\n                        .getClassLoader()) {\n        };\n        byte[] classBytes = makeClassBytes();\n\n        Object classLoadingLock = dispatcher.getClassLoadingLock(targetClassLoader, INJECTED_TYPE_NAME);\n        assertThat(classLoadingLock).isNotNull();\n        assertThat(dispatcher.findClass(targetClassLoader, INJECTED_TYPE_NAME)).isNull();\n        assertThat(dispatcher.getDefinedPackage(targetClassLoader, INJECTED_PACKAGE_NAME)).isNull();\n\n        Package definedPackage = dispatcher.definePackage(\n                targetClassLoader,\n                INJECTED_PACKAGE_NAME,\n                \"ModelMapper test specification\",\n                \"1\",\n                \"ModelMapper test vendor\",\n                \"ModelMapper test implementation\",\n                \"1\",\n                \"ModelMapper test vendor\",\n                null);\n        assertThat(definedPackage.getName()).isEqualTo(INJECTED_PACKAGE_NAME);\n        assertThat(dispatcher.getDefinedPackage(targetClassLoader, INJECTED_PACKAGE_NAME))\n                .isSameAs(definedPackage);\n        assertThat(dispatcher.getPackage(targetClassLoader, INJECTED_PACKAGE_NAME))\n                .isSameAs(definedPackage);\n\n        Class<?> injectedType = dispatcher.defineClass(\n                targetClassLoader,\n                INJECTED_TYPE_NAME,\n                classBytes,\n                ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeInjectionTest.class\n                        .getProtectionDomain());\n        assertThat(injectedType.getName()).isEqualTo(INJECTED_TYPE_NAME);\n        assertThat(injectedType.getClassLoader()).isSameAs(targetClassLoader);\n        assertThat(dispatcher.findClass(targetClassLoader, INJECTED_TYPE_NAME))\n                .isSameAs(injectedType);\n    }\n\n    private static byte[] makeClassBytes() {\n        DynamicType.Unloaded<?> unloadedType = new ByteBuddy()\n                .subclass(Object.class)\n                .name(INJECTED_TYPE_NAME)\n                .make();\n        return unloadedType.getBytes();\n    }\n\n    private static void restoreProperty(String originalSafeProperty) {\n        if (originalSafeProperty == null) {\n            System.clearProperty(SAFE_PROPERTY);\n        } else {\n            System.setProperty(SAFE_PROPERTY, originalSafeProperty);\n        }\n    }\n}\n"}, "partialJson": "{\"path\":\"tests/src/org.modelmapper/modelmapper/3.2.0/src/test/java/org_modelmapper/modelmapper/ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeInjectionTest.java\",\"content\":\"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage org_modelmapper.modelmapper;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\n\\nimport org.graalvm.internal.tck.NativeImageSupport;\\nimport org.junit.jupiter.api.Test;\\nimport org.modelmapper.internal.bytebuddy.ByteBuddy;\\nimport org.modelmapper.internal.bytebuddy.dynamic.DynamicType;\\nimport org.modelmapper.internal.bytebuddy.dynamic.loading.ClassInjector.UsingReflection.Dispatcher;\\nimport org.modelmapper.internal.bytebuddy.dynamic.loading.ClassInjector.UsingReflection.Dispatcher.CreationAction;\\nimport org.modelmapper.internal.bytebuddy.dynamic.loading.ClassInjector.UsingReflection.Dispatcher.Initializable;\\n\\npublic class ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeInjectionTest {\\n    private static final String SAFE_PROPERTY = \\\"org.modelmapper.internal.bytebuddy.safe\\\";\\n    private static final String INJECTED_TYPE_NAME = \\\"org_modelmapper.modelmapper.generated.UnsafeInjectedType\\\";\\n    private static final String INJECTED_PACKAGE_NAME = \\\"org_modelmapper.modelmapper.generated\\\";\\n\\n    @Test\\n    void unsafeReflectionDispatcherDefinesPackageAndClass() {\\n        String originalSafeProperty = System.getProperty(SAFE_PROPERTY);\\n        System.setProperty(SAFE_PROPERTY, Boolean.FALSE.toString());\\n        try {\\n            exerciseUnsafeDispatcher();\\n        } catch (Error error) {\\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\\n                throw error;\\n            }\\n        } finally {\\n            restoreProperty(originalSafeProperty);\\n        }\\n    }\\n\\n    private static void exerciseUnsafeDispatcher() {\\n        Initializable initializable = CreationAction.INSTANCE.run();\\n        assertThat(initializable.isAvailable()).isTrue();\\n\\n        Dispatcher dispatcher = initializable.initialize();\\n        ClassLoader targetClassLoader = new ClassLoader(\\n                ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeInjectionTest.class\\n                        .getClassLoader()) {\\n        };\\n        byte[] classBytes = makeClassBytes();\\n\\n        Object classLoadingLock = dispatcher.getClassLoadingLock(targetClassLoader, INJECTED_TYPE_NAME);\\n        assertThat(classLoadingLock).isNotNull();\\n        assertThat(dispatcher.findClass(targetClassLoader, INJECTED_TYPE_NAME)).isNull();\\n        assertThat(dispatcher.getDefinedPackage(targetClassLoader, INJECTED_PACKAGE_NAME)).isNull();\\n\\n        Package definedPackage = dispatcher.definePackage(\\n                targetClassLoader,\\n                INJECTED_PACKAGE_NAME,\\n                \\\"ModelMapper test specification\\\",\\n                \\\"1\\\",\\n                \\\"ModelMapper test vendor\\\",\\n                \\\"ModelMapper test implementation\\\",\\n                \\\"1\\\",\\n                \\\"ModelMapper test vendor\\\",\\n                null);\\n        assertThat(definedPackage.getName()).isEqualTo(INJECTED_PACKAGE_NAME);\\n        assertThat(dispatcher.getDefinedPackage(targetClassLoader, INJECTED_PACKAGE_NAME))\\n                .isSameAs(definedPackage);\\n        assertThat(dispatcher.getPackage(targetClassLoader, INJECTED_PACKAGE_NAME))\\n                .isSameAs(definedPackage);\\n\\n        Class<?> injectedType = dispatcher.defineClass(\\n                targetClassLoader,\\n                INJECTED_TYPE_NAME,\\n                classBytes,\\n                ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeInjectionTest.class\\n                        .getProtectionDomain());\\n        assertThat(injectedType.getName()).isEqualTo(INJECTED_TYPE_NAME);\\n        assertThat(injectedType.getClassLoader()).isSameAs(targetClassLoader);\\n        assertThat(dispatcher.findClass(targetClassLoader, INJECTED_TYPE_NAME))\\n                .isSameAs(injectedType);\\n    }\\n\\n    private static byte[] makeClassBytes() {\\n        DynamicType.Unloaded<?> unloadedType = new ByteBuddy()\\n                .subclass(Object.class)\\n                .name(INJECTED_TYPE_NAME)\\n                .make();\\n        return unloadedType.getBytes();\\n    }\\n\\n    private static void restoreProperty(String originalSafeProperty) {\\n        if (originalSafeProperty == null) {\\n            System.clearProperty(SAFE_PROPERTY);\\n        } else {\\n            System.setProperty(SAFE_PROPERTY, originalSafeProperty);\\n        }\\n    }\\n}\\n\"}"}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1259, "output": 3702, "cacheRead": 57344, "cacheWrite": 0, "totalTokens": 62305, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780826621622, "responseId": "resp_0ff825844bade20d016a2541fe82788193869da33e980e9bff"}, "toolResults": [{"role": "toolResult"