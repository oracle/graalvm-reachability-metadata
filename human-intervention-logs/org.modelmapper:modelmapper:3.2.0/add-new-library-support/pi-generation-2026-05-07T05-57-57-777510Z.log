  @Order(0)
  @TestMethodOrder(OrderAnnotation.class)
  public class NexusAccessorInnerDispatcherInnerCreationActionTest {
      private static final String BYTE_BUDDY_SAFE_PROPERTY =
              "org.modelmapper.internal.bytebuddy.safe";
      private static final String NEXUS_DISABLED_PROPERTY =
              "org.modelmapper.internal.bytebuddy.nexus.disabled";
      private static final String CREATION_ACTION_CLASS_NAME =
              "org.modelmapper.internal.bytebuddy.dynamic.NexusAccessor$Dispatcher$CreationAction";
      private static final String NEXUS_RESOURCE =
              "org/modelmapper/internal/bytebuddy/dynamic/Nexus.class";
      private static final String TEST_CLASS_NAME =
              "org_modelmapper.modelmapper.NexusAccessorInnerDispatcherInnerCreationActionTest";
      private static final String SCENARIO_CLASS_NAME =
              TEST_CLASS_NAME + (char) 36 + "InjectionCreationActionScenario";
      private static final String FALLBACK_SCENARIO_CLASS_NAME =
              TEST_CLASS_NAME + (char) 36 + "FallbackCreationActionScenario";
  
      @Test
      @Order(1)
      void createsDispatcherFromSystemLoadedNexusFallback() throws Exception {
          try {
              runSystemFallback();
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
      }
  
      @Test
      @Order(2)
      void createsDispatcherFromSystemLoadedNexusInNamedModuleFallback() throws Exception {
          try {
              runInNamedModelMapperModule();
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
      }
  
      @Test
      @Order(3)
      void createsDispatcherByInjectingNexusIntoSystemClassLoader() throws Exception {
          try {
              runInIsolatedModelMapperLoader();
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
      }
  
      private static void runSystemFallback() {
          String previousSafeValue = System.setProperty(BYTE_BUDDY_SAFE_PROPERTY, "true");
          String previousDisabledValue = System.clearProperty(NEXUS_DISABLED_PROPERTY);
          try {
              assertThat(CreationActionAccess.runCreationAction()).isTrue();
          } finally {
              restoreProperty(BYTE_BUDDY_SAFE_PROPERTY, previousSafeValue);
              restoreProperty(NEXUS_DISABLED_PROPERTY, previousDisabledValue);
          }
      }
  
      private static void runInIsolatedModelMapperLoader() throws Exception {
          Class<?> testClass = NexusAccessorInnerDispatcherInnerCreationActionTest.class;
          URL testClassesUrl = testClass.getProtectionDomain().getCodeSource().getLocation();
          try (ChildFirstClassLoader classLoader = new ChildFirstClassLoader(
                  new URL[] {testClassesUrl, modelMapperCodeSourceUrl()},
                  ClassLoader.getSystemClassLoader(),
                  false)) {
              Class<?> scenarioClass = classLoader.loadClass(SCENARIO_CLASS_NAME);
              Runnable scenario = (Runnable) scenarioClass.getConstructor().newInstance();
              scenario.run();
          } catch (InvocationTargetException exception) {
              throw targetException(exception);
          }
      }
  
      private static void runInIsolatedFallbackModelMapperLoader() throws Exception {
          Class<?> testClass = NexusAccessorInnerDispatcherInnerCreationActionTest.class;
          URL testClassesUrl = testClass.getProtectionDomain().getCodeSource().getLocation();
          try (ChildFirstClassLoader classLoader = new ChildFirstClassLoader(
                  new URL[] {testClassesUrl, modelMapperCodeSourceUrl()},
                  ClassLoader.getSystemClassLoader(),
                  true)) {
              Class<?> scenarioClass = classLoader.loadClass(FALLBACK_SCENARIO_CLASS_NAME);
              Runnable scenario = (Runnable) scenarioClass.getConstructor().newInstance();
              scenario.run();
          } catch (InvocationTargetException exception) {
              throw targetException(exception);
          }
      }
  
      private static void runInNamedModelMapperModule() throws Exception {
          String previousSafeValue = System.setProperty(BYTE_BUDDY_SAFE_PROPERTY, "true");
          String previousDisabledValue = System.clearProperty(NEXUS_DISABLED_PROPERTY);
          try {
              ModuleFinder finder = modelMapperModuleFinder();
              ModuleReference moduleReference = finder.findAll().stream().findFirst().orElseThrow(
                      () -> new AssertionError("ModelMapper module was not found"));
              String moduleName = moduleReference.descriptor().name();
              ModuleLayer parentLayer = ModuleLayer.boot();
              Configuration configuration = parentLayer.configuration()
                      .resolve(finder, ModuleFinder.of(), Set.of(moduleName));
              ModuleLayer layer = parentLayer.defineModulesWithOneLoader(
                      configuration,
                      ClassLoader.getPlatformClassLoader());
              Class<?> actionClass = layer.findLoader(moduleName).loadClass(
