  import java.util.jar.JarEntry;
  import java.util.jar.JarOutputStream;
  import java.util.stream.Stream;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  import org.modelmapper.internal.bytebuddy.agent.builder.AgentBuilder;
  
  public class AgentBuilderInnerDefaultTest {
      private static final String INSTALLER_TYPE =
              "org.modelmapper.internal.bytebuddy.agent.Installer";
      private static final String DRIVER_MODULE =
              "org.modelmapper.agentbuilder.driver";
  
      @Test
      void resolvesInstrumentationFromSystemInstallerForNamedAgentBuilderModule()
              throws Exception {
          try {
              ensureFakeInstallerOnSystemClassLoader();
              Path temporaryDirectory = Files.createTempDirectory("agentbuilder-default");
              try {
                  Path modelMapperModule = modelMapperModulePath(temporaryDirectory);
                  Path driverModule = driverModulePath(temporaryDirectory);
                  ModuleFinder finder = ModuleFinder.of(modelMapperModule, driverModule);
                  Configuration configuration = ModuleLayer.boot()
                          .configuration()
                          .resolve(finder, ModuleFinder.of(), Set.of(DRIVER_MODULE));
                  ModuleLayer layer = ModuleLayer.boot().defineModulesWithOneLoader(
                          configuration,
                          ClassLoader.getPlatformClassLoader());
                  Callable<?> callable = ServiceLoader.load(layer, Callable.class)
                          .findFirst()
                          .orElseThrow();
  
                  assertThat(callable.call()).isEqualTo("resolved");
              } finally {
                  deleteRecursively(temporaryDirectory);
              }
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
      }
  
      private static void ensureFakeInstallerOnSystemClassLoader()
              throws ClassNotFoundException, IOException, URISyntaxException {
          ClassLoader systemClassLoader = ClassLoader.getSystemClassLoader();
          try {
              systemClassLoader.loadClass(INSTALLER_TYPE);
          } catch (ClassNotFoundException missingInstaller) {
              Path testClasses = Path.of(AgentBuilderInnerDefaultTest.class
                      .getProtectionDomain()
                      .getCodeSource()
                      .getLocation()
                      .toURI());
              if (Files.isDirectory(testClasses)) {
                  Path installerClass = testClasses.resolve(
                          "org/modelmapper/internal/bytebuddy/agent/Installer.class");
                  Files.createDirectories(installerClass.getParent());
                  Files.write(installerClass, installerClassBytes());
              }
              systemClassLoader.loadClass(INSTALLER_TYPE);
          }
      }
  
      private static Path modelMapperModulePath(Path temporaryDirectory)
              throws IOException, URISyntaxException {
          CodeSource codeSource = AgentBuilder.class
                  .getProtectionDomain()
                  .getCodeSource();
          Path location = Path.of(codeSource.getLocation().toURI());
          if (Files.isRegularFile(location)) {
              return location;
          }
          Optional<Path> classPathJar = originalModelMapperJarFromClassPath();
          if (classPathJar.isPresent()) {
              return classPathJar.get();
          }
          Path modelMapperJar = temporaryDirectory.resolve("modelmapper.jar");
          try (JarOutputStream output = new JarOutputStream(
                  Files.newOutputStream(modelMapperJar));
                  Stream<Path> entries = Files.walk(location)) {
              entries.filter(Files::isRegularFile)
                      .sorted()
                      .forEach(path -> addJarEntry(output, location, path));
          }
          return modelMapperJar;
      }
  
      private static Optional<Path> originalModelMapperJarFromClassPath() {
          return Arrays.stream(System.getProperty("java.class.path", "")
                          .split(File.pathSeparator))
                  .map(Path::of)
                  .filter(Files::isRegularFile)
                  .filter(path -> path.getFileName()
                          .toString()
                          .matches("modelmapper-[^-]+\\.jar"))
                  .findFirst();
      }
  
      private static Path driverModulePath(Path temporaryDirectory) throws IOException {
          Path driverJar = temporaryDirectory.resolve("agentbuilder-driver.jar");
          try (JarOutputStream output = new JarOutputStream(
                  Files.newOutputStream(driverJar))) {
              addJarEntry(output, "module-info.class", driverModuleInfoBytes());
              addJarEntry(
                      output,
                      "driver/AgentBuilderDriver.class",
                      driverClassBytes());
          }
          return driverJar;
      }
  
      private static void addJarEntry(
              JarOutputStream output,
              Path root,
              Path path) {
          String name = root.relativize(path).toString().replace('\\', '/');
          try {
              addJarEntry(output, name, Files.readAllBytes(path));
          } catch (IOException exception) {
              throw new UncheckedIOException(exception);
          }
      }
  
      private static void addJarEntry(
              JarOutputStream output,
              String name,
              byte[] bytes) throws IOException {
          output.putNextEntry(new JarEntry(name));
          output.write(bytes);
          output.closeEntry();
      }
  
      private static void deleteRecursively(Path directory) throws IOException {
          try (Stream<Path> paths = Files.walk(directory)) {
              paths.sorted(Comparator.reverseOrder()).forEach(path -> {
                  try {
                      Files.deleteIfExists(path);
                  } catch (IOException exception) {
                      throw new UncheckedIOException(exception);
                  }
              });
          } catch (UncheckedIOException exception) {
              throw exception.getCause();
          }
      }
  
