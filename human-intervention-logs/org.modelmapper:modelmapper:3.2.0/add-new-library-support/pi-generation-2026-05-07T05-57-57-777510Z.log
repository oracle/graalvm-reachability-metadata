[tool-call] delta {"path":"tests/src/org.modelmapper/modelmapper/3.2.0/src/test/java/org_modelmapper/modelmapper/ClassReloadingStrategyTest.java","edits":[{"oldText":"    private static void deleteRecursively(Path directory) throws IOException {\n        try (Stream<Path> paths = Files.walk(directory)) {\n            paths.sorted(Comparator.reverseOrder()).forEach(path -> {\n                try {\n                    Files.deleteIfExists(path);\n                } catch (IOException exception) {\n                    throw new UncheckedIOException(exception);\n                }\n            });\n        } catch (UncheckedIOException exception) {\n            throw exception.getCause();\n        }\n    }\n\n    private static byte[] installerClassBytes() {\n","newText":"    private static void deleteRecursively(Path directory) throws IOException {\n        try (Stream<Path> paths = Files.walk(directory)) {\n            paths.sorted(Comparator.reverseOrder()).forEach(path -> {\n                try {\n                    Files.deleteIfExists(path);\n                } catch (IOException exception) {\n                    throw new UncheckedIOException(exception);\n                }\n            });\n        } catch (UncheckedIOException exception) {\n            throw exception.getCause();\n        }\n    }\n\n    private static ModuleDescriptor moduleDescriptor(Set<String> packages) {\n        return ModuleDescriptor.newModule(\"modelmapper\")\n                .requires(\"java.instrument\")\n                .requires(\"java.management\")\n                .requires(\"java.naming\")\n                .requires(\"java.sql\")\n                .exports(\"org.modelmapper.internal.bytebuddy.dynamic.loading\")\n                .packages(packages)\n                .build();\n    }\n\n    private static String packageName(String entryName) {\n        return entryName.substring(0, entryName.lastIndexOf('/')).replace('/', '.');\n    }\n\n    private static final class CompositeModuleFinder implements ModuleFinder {\n        private final ModuleFinder first;\n        private final ModuleFinder second;\n\n        private CompositeModuleFinder(ModuleFinder first, ModuleFinder second) {\n            this.first = first;\n            this.second = second;\n        }\n\n        @Override\n        public Optional<ModuleReference> find(String name) {\n            return first.find(name).or(() -> second.find(name));\n        }\n\n        @Override\n        public Set<ModuleReference> findAll() {\n            Set<ModuleReference> references = new HashSet<>(first.findAll());\n            references.addAll(second.findAll());\n            return references;\n        }\n    }\n\n    private static final class ModelMapperModuleFinder implements ModuleFinder {\n        private final ModuleReference moduleReference;\n\n        private ModelMapperModuleFinder(ModuleReference moduleReference) {\n            this.moduleReference = moduleReference;\n        }\n\n        @Override\n        public Optional<ModuleReference> find(String name) {\n            if (\"modelmapper\".equals(name)) {\n                return Optional.of(moduleReference);\n            }\n            return Optional.empty();\n        }\n\n        @Override\n        public Set<ModuleReference> findAll() {\n            return Set.of(moduleReference);\n        }\n    }\n\n    private static final class ExplodedModelMapperModuleReference extends ModuleReference {\n        private final Path classesDirectory;\n\n        private ExplodedModelMapperModuleReference(Path classesDirectory) throws IOException {\n            super(moduleDescriptor(packages(classesDirectory)), classesDirectory.toUri());\n            this.classesDirectory = classesDirectory;\n        }\n\n        @Override\n        public ModuleReader open() {\n            return new ExplodedModelMapperModuleReader(classesDirectory);\n        }\n\n        private static Set<String> packages(Path classesDirectory) throws IOException {\n            Set<String> packages = new HashSet<>();\n            try (Stream<Path> paths = Files.walk(classesDirectory)) {\n                for (Path path : paths.filter(Files::isRegularFile).toList()) {\n                    String entryName = classesDirectory.relativize(path).toString()\n                            .replace('\\\\', '/');\n                    if (entryName.endsWith(\".class\") && entryName.contains(\"/\")) {\n                        packages.add(packageName(entryName));\n                    }\n                }\n            }\n            return packages;\n        }\n    }\n\n    private static final class ExplodedModelMapperModuleReader implements ModuleReader {\n        private final Path classesDirectory;\n\n        private ExplodedModelMapperModuleReader(Path classesDirectory) {\n            this.classesDirectory = classesDirectory;\n        }\n\n        @Override\n        public Optional<URI> find(String name) {\n            Path path = classesDirectory.resolve(name);\n            return Files.isRegularFile(path) ? Optional.of(path.toUri()) : Optional.empty();\n        }\n\n        @Override\n        public Optional<ByteBuffer> read(String name) throws IOException {\n            Path path = classesDirectory.resolve(name);\n            if (!Files.isRegularFile(path)) {\n                return Optional.empty();\n            }\n            return Optional.of(ByteBuffer.wrap(Files.readAllBytes(path)));\n        }\n\n        @Override\n        public void release(ByteBuffer byteBuffer) {\n            // Heap buffers created from class bytes do not hold external resources.\n        }\n\n        @Override\n        public Stream<String> list() throws IOException {\n            return Files.walk(classesDirectory)\n                    .filter(Files::isRegularFile)\n                    .map(path -> classesDirectory.relativize(path).toString()\n                            .replace('\\\\', '/'));\n        }\n\n        @Override\n        public void close() {\n            // The reader opens a new file-system stream for each listing operation.\n        }\n    }\n\n    private static final class JarModelMapperModuleReference extends ModuleReference {\n        private final Path jarFile;\n\n        private JarModelMapperModuleReference(Path jarFile) throws IOException {\n            super(moduleDescriptor(packages(jarFile)), jarFile.toUri());\n            this.jarFile = jarFile;\n        }\n\n        @Override\n        public ModuleReader open() throws IOException {\n            return new JarModelMapperModuleReader(new JarFile(jarFile.toFile()));\n        }\n\n        private static Set<String> packages(Path jarFile) throws IOException {\n            Set<String> packages = new HashSet<>();\n            try (JarFile input = new JarFile(jarFile.toFile())) {\n                Enumeration<JarEntry> entries = input.entries();\n                while (entries.hasMoreElements()) {\n                    JarEntry entry = entries.nextElement();\n                    String name = entry.getName();\n                    if (!entry.isDirectory() && name.endsWith(\".class\") && name.contains(\"/\")) {\n                        packages.add(packageName(name));\n                    }\n                }\n            }\n            return packages;\n        }\n    }\n\n    private static final class JarModelMapperModuleReader implements ModuleReader {\n        private final JarFile jarFile;\n\n        private JarModelMapperModuleReader(JarFile jarFile) {\n            this.jarFile = jarFile;\n        }\n\n        @Override\n        public Optional<URI> find(String name) {\n            JarEntry entry = jarFile.getJarEntry(name);\n            if (entry == null) {\n                return Optional.empty();\n            }\n            return Optional.of(URI.create(\"jar:\" + jarFilePath() + \"!/\" + name));\n        }\n\n        @Override\n        public Optional<ByteBuffer> read(String name) throws IOException {\n            JarEntry entry = jarFile.getJarEntry(name);\n            if (entry == null) {\n                return Optional.empty();\n            }\n            try (InputStream entryInput = jarFile.getInputStream(entry)) {\n                return Optional.of(ByteBuffer.wrap(entryInput.readAllBytes()));\n            }\n        }\n\n        @Override\n        public void release(ByteBuffer byteBuffer) {\n            // Heap buffers created from class bytes do not hold external resources.\n        }\n\n        @Override\n        public Stream<String> list() {\n            return jarFile.stream()\n                    .filter(entry -> !entry.isDirectory())\n                    .map(JarEntry::getName);\n        }\n\n        @Override\n        public void close() throws IOException {\n            jarFile.close();\n        }\n\n        private String jarFilePath() {\n            return jarFile.getName().replace(\"\\\\\", \"/\");\n        }\n    }\n\n    private static byte[] installerClassBytes() {\n"}]}
