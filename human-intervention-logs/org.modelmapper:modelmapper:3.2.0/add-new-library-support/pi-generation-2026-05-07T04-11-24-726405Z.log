  package org_modelmapper.modelmapper;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.lang.reflect.Method;
  import java.net.URL;
  import java.security.Permission;
  import java.security.ProtectionDomain;
  import java.util.Collections;
  import java.util.Map;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  import org.modelmapper.internal.bytebuddy.ByteBuddy;
  import org.modelmapper.internal.bytebuddy.dynamic.DynamicType;
  import org.modelmapper.internal.bytebuddy.dynamic.loading.ClassInjector.UsingReflection;
  import org.modelmapper.internal.bytebuddy.dynamic.scaffold.subclass.ConstructorStrategy;
  
  public class ClassInjectorInnerUsingReflectionInnerDispatcherInnerDirectTest {
      static final String PACKAGE_NAME = "org_modelmapper.modelmapper.direct.generated";
  
      @Test
      void directDispatcherInvokesClassLoaderReflectionMethods() throws Exception {
          try {
              DirectDispatcherAccess.runScenario();
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
      }
  
      static Map<String, byte[]> generatedType(String className) {
          DynamicType.Unloaded<?> unloaded = new ByteBuddy()
                  .subclass(Object.class, ConstructorStrategy.Default.NO_CONSTRUCTORS)
                  .name(className)
                  .make();
          return Collections.singletonMap(className, unloaded.getBytes());
      }
  }
  
  class DirectDispatcherAccess extends UsingReflection {
      private DirectDispatcherAccess(ClassLoader classLoader) {
          super(classLoader);
      }
  
      static void runScenario() throws Exception {
          DirectTestClassLoader classLoader = new DirectTestClassLoader(
                  ClassInjectorInnerUsingReflectionInnerDispatcherInnerDirectTest
                          .class
                          .getClassLoader());
          ManualDirectDispatcher dispatcher = new ManualDirectDispatcher(classLoader);
          SecurityManager previousSecurityManager = System.getSecurityManager();
          boolean securityManagerChanged = installPermissiveSecurityManager();
          try {
              assertThat(dispatcher.initialize()).isSameAs(dispatcher);
              String className = ClassInjectorInnerUsingReflectionInnerDispatcherInnerDirectTest
                      .PACKAGE_NAME + ".InjectedDirectType";
              assertThat(dispatcher.findClass(classLoader, className)).isNull();
              assertThat(dispatcher.getDefinedPackage(
                      classLoader,
                      ClassInjectorInnerUsingReflectionInnerDispatcherInnerDirectTest.PACKAGE_NAME))
                      .isNull();
  
              Package definedPackage = dispatcher.definePackage(
                      classLoader,
                      ClassInjectorInnerUsingReflectionInnerDispatcherInnerDirectTest.PACKAGE_NAME,
                      "ModelMapper direct dispatcher specification",
                      "1",
                      "ModelMapper tests",
                      "ModelMapper direct dispatcher implementation",
                      "1",
                      "ModelMapper tests",
                      null);
              assertThat(definedPackage.getName())
                      .isEqualTo(ClassInjectorInnerUsingReflectionInnerDispatcherInnerDirectTest
                              .PACKAGE_NAME);
              assertThat(dispatcher.getDefinedPackage(
                      classLoader,
                      ClassInjectorInnerUsingReflectionInnerDispatcherInnerDirectTest.PACKAGE_NAME))
                      .isSameAs(definedPackage);
              assertThat(dispatcher.getPackage(
                      classLoader,
                      ClassInjectorInnerUsingReflectionInnerDispatcherInnerDirectTest.PACKAGE_NAME))
                      .isSameAs(definedPackage);
  
              Map<String, byte[]> generatedType =
                      ClassInjectorInnerUsingReflectionInnerDispatcherInnerDirectTest
                              .generatedType(className);
              Class<?> loadedType = dispatcher.defineClass(
                      classLoader,
                      className,
                      generatedType.get(className),
                      (ProtectionDomain) null);
              assertThat(loadedType.getName()).isEqualTo(className);
              assertThat(loadedType.getClassLoader()).isSameAs(classLoader);
              assertThat(dispatcher.findClass(classLoader, className)).isSameAs(loadedType);
          } finally {
              if (securityManagerChanged) {
                  System.setSecurityManager(previousSecurityManager);
              }
          }
      }
  
      private static boolean installPermissiveSecurityManager() {
          try {
              SecurityManager securityManager = new PermissiveSecurityManager();
              System.setSecurityManager(securityManager);
              return System.getSecurityManager() == securityManager;
          } catch (UnsupportedOperationException | SecurityException ignored) {
              return false;
          }
      }
  
      public static final class ManualDirectDispatcher extends Dispatcher.Direct {
          ManualDirectDispatcher(DirectTestClassLoader classLoader) throws NoSuchMethodException {
              super(
                      method("findLoadedClassDirect", String.class),
                      method("defineClassDirect",
                              String.class,
                              byte[].class,
                              int.class,
                              int.class,
                              ProtectionDomain.class),
                      method("getDefinedPackageDirect", String.class),
                      method("getPackageDirect", String.class),
                      method("definePackageDirect",
                              String.class,
                              String.class,
                              String.class,
                              String.class,
                              String.class,
                              String.class,
                              String.class,
                              URL.class));
              assertThat(getClassLoadingLock(classLoader, "java.lang.Object")).isNotNull();
          }
  
          @Override
          public Object getClassLoadingLock(ClassLoader classLoader, String name) {
              return ((DirectTestClassLoader) classLoader).getClassLoadingLockDirect(name);
          }
  
          private static Method method(String name, Class<?>... parameterTypes)
                  throws NoSuchMethodException {
              return DirectTestClassLoader.class.getMethod(name, parameterTypes);
          }
      }
  
      public static final class DirectTestClassLoader extends ClassLoader {
          DirectTestClassLoader(ClassLoader parent) {
              super(parent);
          }
  
          public Object getClassLoadingLockDirect(String name) {
              return getClassLoadingLock(name);
          }
  
          public Class<?> findLoadedClassDirect(String name) {
              return findLoadedClass(name);
          }
  
          public Class<?> defineClassDirect(
                  String name,
                  byte[] bytes,
                  int offset,
                  int length,
                  ProtectionDomain protectionDomain) {
              return defineClass(name, bytes, offset, length, protectionDomain);
          }
  
          public Package getDefinedPackageDirect(String name) {
              return getDefinedPackage(name);
          }
  
          @SuppressWarnings("deprecation")
          public Package getPackageDirect(String name) {
              return getPackage(name);
          }
  
          public Package definePackageDirect(
                  String name,
                  String specificationTitle,
                  String specificationVersion,
                  String specificationVendor,
                  String implementationTitle,
                  String implementationVersion,
                  String implementationVendor,
                  URL sealBase) {
              return definePackage(
                      name,
                      specificationTitle,
                      specificationVersion,
                      specificationVendor,
                      implementationTitle,
                      implementationVersion,
                      implementationVendor,
                      sealBase);
          }
      }
  
      public static final class PermissiveSecurityManager extends SecurityManager {
          @Override
          public void checkPermission(Permission permission) {
              // Allow Direct.initialize to invoke SecurityManager#checkPermission successfully.
          }
      }
  }
