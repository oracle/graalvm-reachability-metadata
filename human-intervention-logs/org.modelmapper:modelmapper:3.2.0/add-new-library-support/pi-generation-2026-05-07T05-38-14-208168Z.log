ationTest.java", "edits": [{"oldText": "import java.util.Optional;\nimport java.util.ServiceLoader;", "newText": "import java.util.List;\nimport java.util.Optional;\nimport java.util.ServiceLoader;"}, {"oldText": "                Path modelMapperModule = explicitModelMapperModulePath(\n                        temporaryDirectory);\n                Path driverModule = driverModulePath(temporaryDirectory);\n                Optional<Path> installerModule = installerModulePathIfNeeded(\n                        temporaryDirectory);\n                ModuleFinder finder = installerModule\n                        .map(path -> ModuleFinder.of(\n                                modelMapperModule,\n                                driverModule,\n                                path))\n                        .orElseGet(() -> ModuleFinder.of(\n                                modelMapperModule,\n                                driverModule));\n                Set<String> roots = installerModule.isPresent()\n                        ? Set.of(DRIVER_MODULE, INSTALLER_MODULE)\n                        : Set.of(DRIVER_MODULE);\n                Configuration configuration = ModuleLayer.boot()\n                        .configuration()\n                        .resolve(finder, ModuleFinder.of(), roots);", "newText": "                ensureFakeInstallerModule(temporaryDirectory);\n                Path modelMapperModule = explicitModelMapperModulePath(\n                        temporaryDirectory);\n                Path driverModule = driverModulePath(temporaryDirectory);\n                ModuleFinder finder = ModuleFinder.of(modelMapperModule, driverModule);\n                Configuration configuration = ModuleLayer.boot()\n                        .configuration()\n                        .resolve(finder, ModuleFinder.of(), Set.of(DRIVER_MODULE));"}, {"oldText": "    private static Optional<Path> installerModulePathIfNeeded(\n            Path temporaryDirectory) throws IOException {\n        