ava.io.UncheckedIOException;\nimport java.lang.module.Configuration;\nimport java.lang.module.ModuleFinder;\nimport java.net.URISyntaxException;\nimport java.nio.file.Files;\nimport java.nio.file.Path;\nimport java.security.CodeSource;\nimport java.util.Arrays;\nimport java.util.Base64;\nimport java.util.Comparator;\nimport java.util.Optional;\nimport java.util.ServiceLoader;\nimport java.util.Set;\nimport java.util.concurrent.Callable;\nimport java.util.jar.JarEntry;\nimport java.util.jar.JarOutputStream;\nimport java.util.stream.Stream;\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\nimport org.modelmapper.internal.bytebuddy.agent.builder.AgentBuilder;\n\npublic class ClassFileLocatorInnerForInstrumentationTest {\n    private static final String DRIVER_MODULE =\n            \"org.modelmapper.classfilelocator.driver\";\n    private static final String INSTALLER_TYPE =\n            \"org.modelmapper.internal.bytebuddy.agent.Installer\";\n\n    @Test\n    void resolvesInstrumentationThroughSystemInstallerForNamedModelMapperModule()\n            throws Exception {\n        try {\n            ensureFakeInstallerOnSystemClassLoader();\n            Path temporaryDirectory = Files.createTempDirectory(\n                    \"classfilelocator-forinstrumentation\");\n            try {\n                Path modelMapperModule = modelMapperModulePath(temporaryDirectory);\n                Path driverModule = driverModulePath(temporaryDirectory);\n                ModuleFinder finder = ModuleFinder.of(modelMapperModule, driverModule);\n                Configuration configuration = ModuleLayer.boot()\n                        .configuration()\n                        .resolve(finder, ModuleFinder.of(), Set.of(DRIVER_MODULE));\n                ModuleLayer layer = ModuleLayer.boot().defineModulesWithOneLoader(\n                        configuration,\n                        ClassLoader.getPlatformClassLoader());\n                Callable<?> callable = ServiceLoader.load(layer, Callable.class)\n                        .findFirst()\n                        .orElseThrow();\n\n                assertThat(callable.call()).isEqualTo(\"resolved\");\n            } finally {\n                deleteRecursively(temporaryDirectory);\n            }\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    private static void ensureFakeInstallerOnSystemClassLoader()\n            throws ClassNotFoundException, IOException, URISyntaxException {\n        ClassLoader systemClassLoader = ClassLoader.getSystemClassLoader();\n        try {\n            systemClassLoader.loadClass(INSTALLER_TYPE);\n        } catch (ClassNotFoundException missingInstaller) {\n            Path testClasses = Path.of(ClassFileLocatorInnerForInstrumentationTest.class\n                    .getProtectionDomain()\n                    .getCodeSource()\n                    .getLocation()\n                    .toURI());\n            if (Files.isDirectory(testClasses)) {\n                Path installerClass = testClasses.resolve(\n                        \"org/modelmapper/internal/bytebuddy/agent/Installer.class\");\n                Files.createDirectories(installerClass.getParent());\n                Files.write(installerClass, installerClassBytes());\n            }\n            systemClassLoader.loadClass(INSTALLER_TYPE);\n        }\n    }\n\n    private static Path modelMapperModulePath(Path temporaryDirectory)\n            throws IOException, URISyntaxException {\n        CodeSource codeSource = AgentBuilder.class\n                .getProtectionDomain()\n                .getCodeSource();\n        Path location = Path.of(codeSource.getLocation().toURI());\n        if (Files.isRegularFile(location)) {\n            return location;\n        }\n        Optional<Path> classPathJar = originalModelMapperJarFromClassPath();\n        if (classPathJar.isPresent()) {\n            return classPathJar.get();\n        }\n        Path modelMapperJar = temporaryDirectory.resolve(\"modelmapper.jar\");\n        try (JarOutputStream output = new JarOutputStream(\n                Files.newOutputStream(modelMapperJar));\n                Stream<Path> entries = Files.walk(location)) {\n            entries.filter(Files::isRegularFile)\n                    .sorted()\n                    .forEach(path -> addJarEntry(output, location, path));\n        }\n        return modelMapperJar;\n    }\n\n    private static Optional<Path> originalModelMapperJarFromClassPath() {\n        return Arrays.stream(System.getProperty(\"java.class.path\", \"\")\n                        .split(File.pathSeparator))\n                .map(Path::of)\n                .filter(Files::isRegularFile)\n                .filter(path -> path.getFileName()\n                        .toString()\n                        .matches(\"modelmapper-[^-]+\\\\.jar\"))\n                .findFirst();\n    }\n\n    private static Path driverModulePath(Path temporaryDirectory) throws IOException {\n        Path driverJar = temporaryDirectory.resolve(\"classfilelocator-driver.jar\");\n        try (JarOutputStream output = new JarOutputStream(\n                Files.newOutputStream(driverJar))) {\n            addJarEntry(output, \"module-info.class\", driverModuleInfoBytes());\n            addJarEntry(\n                    output,\n                    \"driver/ClassFileLocatorDriver.class\",\n                    driverClassBytes());\n        }\n        return driverJar;\n    }\n\n    private static void addJarEntry(\n            JarOutputStream output,\n            Path root,\n            Path path) {\n        String name = root.relativize(path).toString().replace('\\\\', '/');\n        try {\n            addJarEntry(output, name, Files.readAllBytes(path));\n        } catch (IOException exception) {\n            throw new UncheckedIOException(exception);\n        }\n    }\n\n    private static void addJarEntry(\n            JarOutputStream output,\n            String name,\n            byte[] bytes) throws IOException {\n        output.putNextEntry(new JarEntry(name));\n        output.write(bytes);\n        output.closeEntry();\n    }\n\n    private static void deleteRecursively(Path directory) throws IOException {\n        try (Stream<Path> paths = Files.walk(directory)) {\n            paths.sorted(Comparator.reverseOrder()).forEach(path -> {\n                try {\n                    Files.deleteIfExists(path);\n                } catch (IOException exception) {\n                    throw new UncheckedIOException(exception);\n                }\n            });\n        } catch (UncheckedIOException exception) {\n            throw exception.getCause();\n        }\n    }\n\n    private static byte[] installerClassBytes() {\n        return Base64.getMimeDecoder().decode(\"\"\"\n                yv66vgAAAEEADwoAAgADBwAEDAAFAAYBABBqYXZhL2xhbmcvT2JqZWN0AQAGPGlu\n                aXQ+AQADKClWBwAIAQAyb3JnL21vZGVsbWFwcGVyL2ludGVybmFsL2J5dGVidWRk\n                eS9hZ2VudC9JbnN0YWxsZXIBAARDb2RlAQAPTGluZU51bWJlclRhYmxlAQASZ2V0\n                SW5zdHJ1bWVudGF0aW9uAQAoKClMamF2YS9sYW5nL2luc3RydW1lbnQvSW5zdHJ1\n                bWVudGF0aW9uOwEAClNvdXJjZUZpbGUBAA5JbnN0YWxsZXIuamF2YQAxAAcAAgAA\n                AAAAAgACAAUABgABAAkAAAAhAAEAAQAAAAUqtwABsQAAAAEACgAAAAoAAgAAAA\n                YABAAHAAkACwAMAAEACQAAABoAAQAAAAAAAgGwAAAAAQAKAAAABgABAAAACgAB\n                AA0AAAACAA4=\n                \"\"\");\n    }\n\n    private static byte[] driverModuleInfoBytes() {\n        return Base64.getMimeDecoder().decode(\"\"\"\n                yv66vgAAAEEAEQcAAgEAC21vZHVsZS1pbmZvAQAKU291cmNlRmlsZQEAEG1vZHVsZS1pbmZvLmph\n                dmEBAAZNb2R1bGUTAAcBACdvcmcubW9kZWxtYXBwZXIuY2xhc3NmaWxlbG9jYXRvci5kcml2ZXIT\n                AAkBAAlqYXZhLmJhc2UBAAIyMRMADAEAC21vZGVsbWFwcGVyBwAOAQAdamF2YS91dGlsL2NvbmN1\n                cnJlbnQvQ2FsbGFibGUHABABAB1kcml2ZXIvQ2xhc3NGaWxlTG9jYXRvckRyaXZlcoAAAAEAAAAA\n                AAAAAAACAAMAAAACAAQABQAAACIABgAAAAAAAgAIgAAACgALAAAAAAAAAAAAAAABAA0AAQAP\n                \"\"\");\n    }\n\n    private static byte[] driverClassBytes() {\n        return Base64.getMimeDecoder().decode(\"\"\"\n                yv66vgAAAEEALwoAAgADBwAEDAAFAAYBABBqYXZhL2xhbmcvT2JqZWN0AQAGPGluaXQ+AQADKClW\n                CgAIAAkHAAoMAAsADAEATm9yZy9tb2RlbG1hcHBlci9pbnRlcm5hbC9ieXRlYnVkZHkvZHluYW1p\n                Yy9DbGFzc0ZpbGVMb2NhdG9yJEZvckluc3RydW1lbnRhdGlvbgEAEmZyb21JbnN0YWxsZWRBZ2Vu\n                dAEAVihMamF2YS9sYW5nL0NsYXNzTG9hZGVyOylMb3JnL21vZGVsbWFwcGVyL2ludGVybmFsL2J5\n                dGVidWRkeS9keW5hbWljL0NsYXNzRmlsZUxvY2F0b3I7BwAOAQAYamF2YS9sYW5nL0Fzc2VydGlv\n                bkVycm9yCAAQAQA6RXhwZWN0ZWQgdGhlIGZha2UgaW5zdGFsbGVyIHRvIHJldHVybiBudWxsIGlu\n                c3RydW1lbnRhdGlvbgoADQASDAAFABMBABUoTGphdmEvbGFuZy9PYmplY3Q7KVYHABUBAB5qYXZh\n                L2xhbmcvTnVsbFBvaW50ZXJFeGNlcHRpb24IABcBAAhyZXNvbHZlZAoAGQAaBwAbDAAcAB0BAB1k\n                cml2ZXIvQ2xhc3NGaWxlTG9jYXRvckRyaXZlcgEABGNhbGwBABQoKUxqYXZhL2xhbmcvU3RyaW5n\n                OwcAHwEAHWphdmEvdXRpbC9jb25jdXJyZW50L0NhbGxhYmxlAQAEQ29kZQEAD0xpbmVOdW1iZXJU\n                YWJsZQEADVN0YWNrTWFwVGFibGUBABQoKUxqYXZhL2xhbmcvT2JqZWN0OwEACkV4Y2VwdGlvbnMH\n                ACYBABNqYXZhL2xhbmcvRXhjZXB0aW9uAQAJU2lnbmF0dXJlAQBFTGphdmEvbGFuZy9PYmplY3Q7\n                TGphdmEvdXRpbC9jb25jdXJyZW50L0NhbGxhYmxlPExqYXZhL2xhbmcvU3RyaW5nOz47AQAKU291\n                cmNlRmlsZQEAG0NsYXNzRmlsZUxvY2F0b3JEcml2ZXIuamF2YQEADElubmVyQ2xhc3NlcwcALQEA\n                O29yZy9tb2RlbG1hcHBlci9pbnRlcm5hbC9ieXRlYnVkZHkvZHluYW1pYy9DbGFzc0ZpbGVMb2Nh\n                dG9yAQASRm9ySW5zdHJ1bWVudGF0aW9uACEAGQACAAEAHgAAAAMAAQAFAAYAAQAgAAAAHQABAAEA\n                AAAFKrcAAbEAAAABACEAAAAGAAEAAAAGAAEAHAAdAAEAIAAAAEsAAwACAAAAEwG4AAdXuwANWRIP\n                twARv0wSFrAAAQAAAA8ADwAUAAIAIQAAABIABAAAAAoABQALAA8ADAAQAA0AIgAAAAYAAU8HABQQ\n                QQAcACMAAgAgAAAAHQABAAEAA