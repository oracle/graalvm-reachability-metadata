rModule, driverModule);\n                Configuration configuration = ModuleLayer.boot()\n                        .configuration()\n                        .resolve(finder, ModuleFinder.of(), Set.of(DRIVER_MODULE));\n                ModuleLayer layer = ModuleLayer.boot().defineModulesWithOneLoader(\n                        configuration,\n                        ClassLoader.getPlatformClassLoader());\n                Callable<?> callable = ServiceLoader.load(layer, Callable.class)\n                        .findFirst()\n                        .orElseThrow();\n\n                assertThat(callable.call()).isEqualTo(\"resolved\");\n            } finally {\n                deleteRecursively(temporaryDirectory);\n            }\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    private static void ensureFakeInstallerOnSystemClassLoader()\n            throws ClassNotFoundException, IOException, URISyntaxException {\n        ClassLoader systemClassLoader = ClassLoader.getSystemClassLoader();\n        try {\n            systemClassLoader.loadClass(INSTALLER_TYPE);\n        } catch (ClassNotFoundException missingInstaller) {\n            Path testClasses = Path.of(AgentBuilderInnerDefaultTest.class\n                    .getProtectionDomain()\n                    .getCodeSource()\n                    .getLocation()\n                    .toURI());\n            if (Files.isDirectory(testClasses)) {\n                Path installerClass = testClasses.resolve(\n                        \"org/modelmapper/internal/bytebuddy/agent/Installer.class\");\n                Files.createDirectories(installerClass.getParent());\n                Files.write(installerClass, installerClassBytes());\n            }\n            systemClassLoader.loadClass(INSTALLER_TYPE);\n        }\n    }\n\n    private static Path modelMapperModulePath(Path temporaryDirectory)\n            throws IOException, URISyntaxException {\n        CodeSource codeSource = AgentBuilder.class\n                .getProtectionDomain()\n                .getCodeSource();\n        Path location = Path.of(codeSource.getLocation().toURI());\n        if (Files.isRegularFile(location)) {\n            return location;\n        }\n        Optional<Path> classPathJar = originalModelMapperJarFromClassPath();\n        if (classPathJar.isPresent()) {\n            return classPathJar.get();\n        }\n        Path modelMapperJar = temporaryDirectory.resolve(\"modelmapper.jar\");\n        try (JarOutputStream output = new JarOutputStream(\n                Files.newOutputStream(modelMapperJar));\n                Stream<Path> entries = Files.walk(location)) {\n            entries.filter(Files::isRegularFile)\n                    .sorted()\n                    .forEach(path -> addJarEntry(output, location, path));\n        }\n        return modelMapperJar;\n    }\n\n    private static Optional<Path> originalModelMapperJarFromClassPath() {\n        return Arrays.stream(System.getProperty(\"java.class.path\", \"\")\n                        .split(File.pathSeparator))\n                .map(Path::of)\n                .filter(Files::isRegularFile)\n                .filter(path -> path.getFileName()\n                        .toString()\n                        .matches(\"modelmapper-[^-]+\\\\.jar\"))\n                .findFirst();\n    }\n\n    private static Path driverModulePath(Path temporaryDirectory) throws IOException {\n        Path driverJar = temporaryDirectory.resolve(\"agentbuilder-driver.jar\");\n        try (JarOutputStream output = new JarOutputStream(\n                Files.newOutputStream(driverJar))) {\n            addJarEntry(output, \"module-info.class\", driverModuleInfoBytes());\n            addJarEntry(\n                    output,\n                    \"driver/AgentBuilderDriver.class\",\n                    driverClassBytes());\n        }\n        return driverJar;\n    }\n\n    private static void addJarEntry(\n            JarOutputStream output,\n            Path root,\n            Path path) {\n        String name = root.relativize(path).toString().replace('\\\\', '/');\n        try {\n            addJarEntry(output, name, Files.readAllBytes(path));\n        } catch (IOException exception) {\n            throw new UncheckedIOException(exception);\n        }\n    }\n\n    private static void addJarEntry(\n            JarOutputStream output,\n            String name,\n            byte[] bytes) throws IOException {\n        output.putNextEntry(new JarEntry(name));\n        output.write(bytes);\n        output.closeEntry();\n    }\n\n    private static void deleteRecursively(Path directory) throws IOException {\n        try (Stream<Path> paths = Files.walk(directory)) {\n            paths.sorted(Comparator.reverseOrder()).forEach(path -> {\n                try {\n                    Files.deleteIfExists(path);\n                } catch (IOException exception) {\n                    throw new UncheckedIOException(exception);\n                }\n            });\n        } catch (UncheckedIOException exception) {\n            throw exception.getCause();\n        }\n    }\n\n    private static byte[] installerClassBytes() {\n        return Base64.getMimeDecoder().decode(\"\"\"\n                yv66vgAAAEEADwoAAgADBwAEDAAFAAYBABBqYXZhL2xhbmcvT2JqZWN0AQAGPGlu\n                aXQ+AQADKClWBwAIAQAyb3JnL21vZGVsbWFwcGVyL2ludGVybmFsL2J5dGVidWRk\n                eS9hZ2VudC9JbnN0YWxsZXIBAARDb2RlAQAPTGluZU51bWJlclRhYmxlAQASZ2V0\n                SW5zdHJ1bWVudGF0aW9uAQAoKClMamF2YS9sYW5nL2luc3RydW1lbnQvSW5zdHJ1\n                bWVudGF0aW9uOwEAClNvdXJjZUZpbGUBAA5JbnN0YWxsZXIuamF2YQAxAAcAAgAA\n                AAAAAgACAAUABgABAAkAAAAhAAEAAQAAAAUqtwABsQAAAAEACgAAAAoAAgAAAA\n                YABAAHAAkACwAMAAEACQAAABoAAQAAAAAAAgGwAAAAAQAKAAAABgABAAAACgAB\n                AA0AAAACAA4=\n                \"\"\");\n    }\n\n    private static byte[] driverModuleInfoBytes() {\n        return Base64.getMimeDecoder().decode(\"\"\"\n                yv66vgAAAEEAEQcAAgEAC21vZHVsZS1pbmZvAQAKU291cmNlRmlsZQEAEG1vZHVs\n                ZS1pbmZvLmphdmEBAAZNb2R1bGUTAAcBACNvcmcubW9kZWxtYXBwZXIuYWdlbnRi\n                dWlsZGVyLmRyaXZlchMACQEACWphdmEuYmFzZQEAAjIxEwAMAQALbW9kZWxtYXBw\n                ZXIHAA4BAB1qYXZhL3V0aWwvY29uY3VycmVudC9DYWxsYWJsZQcAEAEAGWRyaXZl\n                ci9BZ2VudEJ1aWxkZXJEcml2ZXKAAAABAAAAAAAAAAAAAgADAAAAAgAEAAUAAAAi\n                AAYAAAAAAAIACIAAAAoACwAAAAAAAAAAAAAAAQANAAEADw==\n                \"\"\");\n    }\n\n    private static byte[] driverClassBytes() {\n        return Base64.getMimeDecoder().decode(\"\"\"\n                yv66vgAAAEEAMAoAAgADBwAEDAAFAAYBABBqYXZhL2xhbmcvT2JqZWN0AQAGPGlu\n                aXQ+AQADKClWBwAIAQBFb3JnL21vZGVsbWFwcGVyL2ludGVybmFsL2J5dGVidWRk\n                eS9hZ2VudC9idWlsZGVyL0FnZW50QnVpbGRlciREZWZhdWx0CgAHAAMKAAcACwwA\n                DAANAQAXaW5zdGFsbE9uQnl0ZUJ1ZGR5QWdlbnQBAFMoKUxvcmcvbW9kZWxtYXBw\n                ZXIvaW50ZXJuYWwvYnl0ZWJ1ZGR5L2FnZW50L2J1aWxkZXIvUmVzZXR0YWJsZUNs\n                YXNzRmlsZVRyYW5zZm9ybWVyOwcADwEAGGphdmEvbGFuZy9Bc3NlcnRpb25FcnJv\n                cggAEQEAOkV4cGVjdGVkIHRoZSBmYWtlIGluc3RhbGxlciB0byByZXR1cm4gbnVs\n                bCBpbnN0cnVtZW50YXRpb24KAA4AEwwABQAUAQAVKExqYXZhL2xhbmcvT2JqZWN0\n                OylWBwAWAQAeamF2YS9sYW5nL051bGxQb2ludGVyRXhjZXB0aW9uCAAYAQAIcmVz\n                b2x2ZWQKABoAGwcAHAwAHQAeAQAZZHJpdmVyL0FnZW50QnVpbGRlckRyaXZlcgEA\n\n[18 more lines in file. Use offset=211 to continue.]"}], "isError": false, "timestamp": 1778132635313}]}
