Path(temporaryDirectory);\n                ModuleFinder finder = ModuleFinder.of(\n                        modelMapperModule,\n                        driverModule,\n                        installerModule);\n                Configuration configuration = ModuleLayer.boot()\n                        .configuration()\n                        .resolve(\n                                finder,\n                                ModuleFinder.of(),\n                                Set.of(DRIVER_MODULE, INSTALLER_MODULE));"}, {"oldText": "    private static void ensureFakeInstallerOnSystemClassLoader()\n            throws ClassNotFoundException, IOException, URISyntaxException {\n        ClassLoader systemClassLoader = ClassLoader.getSystemClassLoader();\n        try {\n            systemClassLoader.loadClass(INSTALLER_TYPE);\n        } catch (ClassNotFoundException missingInstaller) {\n            Path testClasses = Path.of(ClassFileLocatorInnerForInstrumentationTest.class\n                    .getProtectionDomain()\n                    .getCodeSource()\n                    .getLocation()\n                    .toURI());\n            if (Files.isDirectory(testClasses)) {\n                Path installerClass = testClasses.resolve(\n                        \"org/modelmapper/internal/bytebuddy/agent/Installer.class\");\n                Files.createDirectories(installerClass.getParent());\n                Files.write(installerClass, installerClassBytes());\n            }\n            systemClassLoader.loadClass(INSTALLER_TYPE);\n        }\n    }\n\n    private static Path modelMapperModulePath(Path temporaryDirectory)\n            throws IOException, URISyntaxException {\n        CodeSource codeSource = AgentBuilder.class\n                .getProtectionDomain()\n                .getCodeSource();\n        Path location = Path.of(codeSource.getLocation().toURI());\n        if (Files.isRegularFile(location)) {\n            return location;\n        }\n        Optional<Path> classPathJar = originalModelMapperJarFromClassPath();\n        if (classPathJar.isPresent()) {\n            return classPathJar.get();\n        }\n        Path modelMapperJar = temporaryDirectory.resolve(\"modelmapper.jar\");\n        try (JarOutputStream output = new JarOutputStream(\n                Files.newOutputStream(modelMapperJar));\n                Stream<Path> entries = Files.walk(location)) {\n            entries.filter(Files::isRegularFile)\n                    .sorted()\n                    .forEach(path -> addJarEntry(output, location, path));\n        }\n        return modelMapperJar;\n    }", "newText": "    private static Path explicitModelMapperModulePath(Path temporaryDirectory)\n            throws IOException, URISyntaxException {\n        CodeSource codeSource = AgentBuilder.class\n                .getProtectionDomain()\n                .getCodeSource();\n        Path location = Path.of(codeSource.getLocation().toURI());\n        Path modelMapperJar = temporaryDirectory.resolve(\"modelmapper-explicit.jar\");\n        try (JarOutputStream output = new JarOutputStream(\n                Files.newOutputStream(modelMapperJar))) {\n            addJarEntry(output, \"module-info.class\", modelMapperModuleInfoBytes());\n            if (Files.isRegularFile(location)) {\n                copyJarEntries(output, location);\n            } else {\n                Optional<Path> classPathJar = originalModelMapperJarFromClassPath();\n                if (classPathJar.isPresent()) {\n                    copyJarEntries(output, classPathJar.get());\n                } else {\n                    try (Stream<Path> entries = Files.walk(location)) {\n                        entries.filter(Files::isRegularFile)\n                                .sorted()\n                                .filter(path -> !\"module-info.class\".equals(\n                                        location.relativize(path)\n                                                .toString()\n                                                .replace('\\\\', '/')))\n                                .forEach(path -> addJarEntry(output, location, path));\n                    }\n                }\n            }\n        }\n        return modelMapperJar;\n    }"}, {"oldText": "    private static Path driverModulePath(Path temporaryDirectory) throws IOException {\n        Path driverJar = temporaryDirectory.resolve(\"classfilelocator-driver.jar\");\n        try (JarOutputStream output = new JarOutputStream(\n                Files.newOutputStream(driverJar))) {\n            addJarEntry(output, \"module-info.class\", driverModuleInfoBytes());\n            addJarEntry(\n                    output,\n                    \"driver/ClassFileLocatorDriver.class\",\n                    driverClassBytes());\n        }\n        return driverJar;\n    }", "newText": "    private static Path driverModulePath(Path temporaryDirectory) throws IOException {\n        Path driverJar = temporaryDirectory.resolve(\"classfilelocator-driver.jar\");\n        try (JarOutputStream output = new JarOutputStream(\n                Files.newOutputStream(driverJar))) {\n            addJarEntry(output, \"module-info.class\", driverModuleInfoBytes());\n            addJarEntry(\n                    output,\n                    \"driver/ClassFileLocatorDriver.class\",\n                    driverClassBytes());\n        }\n        return driverJar;\n    }\n\n    private static Path installerModulePath(Path temporaryDirectory) throws IOException {\n        Path installerJar = temporaryDirectory.resolve(\"fakeagent.jar\");\n        try (JarOutputStream output = new JarOutputStream(\n                Files.newOutputStream(installerJar))) {\n            addJarEntry(output, \"module-info.class\", fakeInstallerModuleInfoBytes());\n            addJarEntry(\n                    output,\n                    \"org/modelmapper/internal/bytebuddy/agent/Installer.class\",\n                    installerClassBytes());\n        }\n        return installerJar;\n    }\n\n    private static void copyJarEntries(JarOutputStream output, Path jar)\n            throws IOException {\n        try (JarFile jarFile = new JarFile(jar.toFile())) {\n            jarFile.stream()\n                    .filter(entry -> !entry.isDirectory())\n                    .filter(entry -> !\"module-info.class\".equals(entry.getName()))\n                    .forEach(entry -> copyJarEntry(output, jarFile, entry));\n        }\n    }"}, {"oldText": "    private static void addJarEntry(\n            JarOutputStream output,\n            String name,\n            byte[] bytes) throws IOException {\n        output.putNextEntry(new JarEntry(name));\n        output.write(bytes);\n        output.closeEntry();\n    }", "newText": "    private static void copyJarEntry(\n            JarOutputStream output,\n            JarFile jarFile,\n            JarEntry entry) {\n        try {\n            addJarEntry(output, entry.getName(), jarFile.getInputStream(entry)\n                    .readAllBytes());\n        } catch (IOException exception) {\n            throw new UncheckedIOException(exception);\n        }\n    }\n\n    private static void addJarEntry(\n            JarOutputStream output,\n            String name,\n            byte[] bytes) throws IOException {\n        output.putNextEntry(new JarEntry(name));\n        output.write(bytes);\n        output.closeEntry();\n    }"}]}
