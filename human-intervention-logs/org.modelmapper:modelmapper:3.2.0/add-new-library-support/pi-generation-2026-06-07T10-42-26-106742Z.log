[tool-call] delta {"path":"tests/src/org.modelmapper/modelmapper/3.2.0/src/test/java/org_modelmapper/modelmapper/TypeResolverTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_modelmapper.modelmapper;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.lang.reflect.Type;\nimport java.util.List;\nimport org.junit.jupiter.api.Test;\nimport org.modelmapper.TypeToken;\nimport org.modelmapper.internal.typetools.TypeResolver;\n\npublic class TypeResolverTest {\n    @Test\n    void resolvesLambdaFunctionalInterfaceArguments() {\n        TextMapper<String, Integer> mapper = value -> value.length();\n\n        Class<?>[] arguments = TypeResolver.resolveRawArguments(TextMapper.class, mapper.getClass());\n\n        assertThat(arguments).hasSize(2);\n        if (arguments[0] != TypeResolver.Unknown.class) {\n            assertThat(arguments).containsExactly(String.class, Integer.class);\n            assertThat(mapper.map(\"modelmapper\")).isEqualTo(11);\n        } else {\n            assertThat(arguments).containsOnly(TypeResolver.Unknown.class);\n        }\n    }\n\n    @Test\n    void resolvesGenericArrayRawClass() {\n        Type arrayType = new TypeToken<List<String>[]>() { }\n                .getType();\n\n        Class<?> rawClass = TypeResolver.resolveRawClass(arrayType, TypeResolverTest.class);\n\n        assertThat(rawClass).isEqualTo(List[].class);\n    }\n\n    @Test\n    void reifiesTypeVariableArrayToConcreteArrayClass() {\n        StringArrayHolder holder = new StringArrayHolder();\n\n        Type reified = TypeResolver.reify(holder.genericArrayType(), holder.getClass());\n\n        assertThat(reified).isEqualTo(String[].class);\n    }\n\n    @FunctionalInterface\n    public interface TextMapper<S, D> {\n        D map(S source);\n    }\n\n    private static class GenericArrayHolder<T> {\n        Type genericArrayType() {\n            return new TypeToken<T[]>() { }\n                    .getType();\n        }\n    }\n\n    private static final class StringArrayHolder extends GenericArrayHolder<String> {\n    }\n}\n"}
