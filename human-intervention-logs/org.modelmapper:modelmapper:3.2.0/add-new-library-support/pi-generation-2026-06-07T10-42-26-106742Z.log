onalInterface\n    public interface TextMapper<S, D> {\n        D map(S source);\n    }\n\n    private static class GenericArrayHolder<T> {\n        Type genericArrayType() {\n            return new TypeToken<T[]>() { }\n                    .getType();\n        }\n    }\n\n    private static final class StringArrayHolder extends GenericArrayHolder<String> {\n    }\n}\n"}
