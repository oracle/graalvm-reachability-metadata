rivate static final String DIRECT_LOADED_TYPE =\n            \"org_modelmapper.modelmapper.generated.ChildFirstDirectLoadedType\";\n    private static final String MANIFEST_RESOURCE_TYPE =\n            \"org_modelmapper.modelmapper.generated.ChildFirstManifestResourceType\";\n    private static final String PARENT_ONLY_RESOURCE = \"modelmapper-parent-only-resource.txt\";\n\n    @Test\n    void loadsGeneratedTypesThroughChildFirstStaticLoader() throws Exception {\n        runDynamicClassLoading(() -> {\n            DynamicType.Unloaded<?> unloadedType = generatedType(STATIC_LOADED_TYPE);\n            Map<TypeDescription, byte[]> types =\n                    Collections.singletonMap(unloadedType.getTypeDescription(), unloadedType.getBytes());\n\n            Map<TypeDescription, Class<?>> loadedTypes =\n                    ChildFirst.load(getClass().getClassLoader(), types);\n\n            assertThat(loadedTypes).containsOnlyKeys(unloadedType.getTypeDescription());\n            Class<?> loadedType = loadedTypes.get(unloadedType.getTypeDescription());\n            assertThat(loadedType.getName()).isEqualTo(STATIC_LOADED_TYPE);\n            assertThat(loadedType.getClassLoader()).isInstanceOf(ChildFirst.class);\n        });\n    }\n\n    @Test\n    void loadsPreviouslyDefinedTypeBeforeDelegatingToParent() throws Exception {\n        runDynamicClassLoading(() -> {\n            ChildFirst classLoader = new ChildFirst(\n                    getClass().getClassLoader(),\n                    generatedTypeByName(DIRECT_LOADED_TYPE));\n\n            Class<?> firstLoad = classLoader.loadClass(DIRECT_LOADED_TYPE);\n            Class<?> secondLoad = classLoader.loadClass(DIRECT_LOADED_TYPE);\n\n            assertThat(firstLoad).isSameAs(secondLoad);\n            assertThat(secondLoad.getClassLoader()).isSameAs(classLoader);\n        });\n    }\n\n    @Test\n    void resolvesParentResourcesAndClassFileShadowing() throws Exception {\n        runDynamicClassLoading(() -> {\n            URL parentResource = new URL(\"file\", \"\", \"/\" + PARENT_ONLY_RESOURCE);\n            ChildFirst classLoader = new ChildFirst(\n                    new ResourceClassLoader(getClass().getClassLoader(), parentResource),\n                    generatedTypeByName(DIRECT_LOADED_TYPE));\n\n            assertThat(classLoader.getResource(PARENT_ONLY_RESOURCE)).isEqualTo(parentResource);\n            assertThat(Collections.list(classLoader.getResources(PARENT_ONLY_RESOURCE)))\n                    .containsExactly(parentResource);\n\n            Class<?> loadedType = classLoader.loadClass(DIRECT_LOADED_TYPE);\n            assertThat(loadedType.getClassLoader()).isSameAs(classLoader);\n            assertThat(classLoader.getResource(classResourceName(DIRECT_LOADED_TYPE))).isNull();\n        });\n    }\n\n    @Test\n    void prependsManifestResourcesBeforeParentResources() throws Exception {\n        runDynamicClassLoading(() -> {\n            URL parentResource = new URL(\"file\", \"\", \"/parent-class-resource.class\");\n            ChildFirst classLoader = new ChildFirst(\n                    new ResourceClassLoader(getClass().getClassLoader(), parentResource),\n                    generatedTypeByName(MANIFEST_RESOURCE_TYPE),\n                    PersistenceHandler.MANIFEST);\n\n            Enumeration<URL> resources =\n                    classLoader.getResources(classResourceName(MANIFEST_RESOURCE_TYPE));\n\n            assertThat(resources.hasMoreElements()).isTrue();\n            URL childResource = resources.nextElement();\n            assertThat(childResource.toString()).startsWith(\"bytebuddy://\");\n            assertThat(Collections.list(resources)).containsExactly(parentResource);\n        });\n    }\n\n    private static DynamicType.Unloaded<?> generatedType(String className) {\n        return new ByteBuddy()\n                .subclass(Object.class, ConstructorStrategy.Default.NO_CONSTRUCTORS)\n                .name(className)\n                .make();\n    }\n\n    private static Map<String, byte[]> generatedTypeByName(String className) {\n        return Collections.singletonMap(className, generatedType(className).getBytes());\n    }\n\n    private static String classResourceName(String className) {\n        return className.replace('.', '/') + \".class\";\n    }\n\n    private static void runDynamicClassLoading(\n            DynamicClassLoadingOperation operation) throws Exception {\n        try {\n            operation.run();\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    @FunctionalInterface\n    private interface DynamicClassLoadingOperation {\n        void run() throws Exception;\n    }\n\n    private static final class ResourceClassLoader extends ClassLoader {\n        private final URL resource;\n\n        private ResourceClassLoader(ClassLoader parent, URL resource) {\n            super(parent);\n            this.resource = resource;\n        }\n\n        @Override\n        public URL getResource(String name) {\n            if (PARENT_ONLY_RESOURCE.equals(name) || name.endsWith(\".class\")) {\n                return resource;\n            }\n            return super.getResource(name);\n        }\n\n        @Override\n        public Enumeration<URL> getResources(String name) throws IOException {\n            if (PARENT_ONLY_RESOURCE.equals(name) || name.endsWith(\".class\")) {\n                return Collections.enumeration(Collections.singleton(resource));\n            }\n            return super.getResources(name);\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 492, "output": 2065, "cacheRead": 33280, "cacheWrite": 0, "totalTokens": 35837, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778124619411, "responseId": "resp_0cbef1bd11805f810169fc074c0c14