  package org_modelmapper.modelmapper;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.security.ProtectionDomain;
  import java.util.Collections;
  import java.util.Map;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  import org.modelmapper.internal.bytebuddy.ByteBuddy;
  import org.modelmapper.internal.bytebuddy.dynamic.DynamicType;
  import org.modelmapper.internal.bytebuddy.dynamic.loading.ClassInjector.UsingUnsafe;
  import org.modelmapper.internal.bytebuddy.dynamic.scaffold.subclass.ConstructorStrategy;
  
  public class ClassInjectorInnerUsingUnsafeTest {
      private static final String PREVIOUSLY_LOADED_TYPE =
              "org_modelmapper.modelmapper.usingunsafe.PreviouslyLoadedType";
      private static final String RUNTIME_EXCEPTION_TYPE =
              "org_modelmapper.modelmapper.usingunsafe.RuntimeExceptionType";
      private static final String ERROR_TYPE =
              "org_modelmapper.modelmapper.usingunsafe.ErrorType";
  
      @Test
      void injectRawReturnsPreviouslyLoadedClassWithoutCallingDispatcher() throws Exception {
          runDynamicClassLoading(() -> {
              GeneratedClassLoader classLoader = new GeneratedClassLoader(
                      getClass().getClassLoader(),
                      PREVIOUSLY_LOADED_TYPE,
                      generatedType(PREVIOUSLY_LOADED_TYPE),
                      false);
              Class<?> loadedClass = classLoader.loadClass(PREVIOUSLY_LOADED_TYPE);
              TestableUsingUnsafe injector = TestableUsingUnsafe.recording(classLoader);
  
              Map<String, Class<?>> injected = injector.injectRaw(Collections.singletonMap(
                      PREVIOUSLY_LOADED_TYPE,
                      generatedType(PREVIOUSLY_LOADED_TYPE)));
  
              assertThat(injected).containsEntry(PREVIOUSLY_LOADED_TYPE, loadedClass);
              assertThat(classLoader.getTargetLoadAttempts()).isEqualTo(1);
              assertThat(injector.getDefineClassCalls()).isZero();
          });
      }
  
      @Test
      void injectRawReturnsClassLoadedAfterRuntimeExceptionFromDispatcher() throws Exception {
          runDynamicClassLoading(() -> {
              GeneratedClassLoader classLoader = new GeneratedClassLoader(
                      getClass().getClassLoader(),
                      RUNTIME_EXCEPTION_TYPE,
                      generatedType(RUNTIME_EXCEPTION_TYPE),
                      true);
              TestableUsingUnsafe injector =
                      TestableUsingUnsafe.throwingRuntimeException(classLoader);
  
              Map<String, Class<?>> injected = injector.injectRaw(Collections.singletonMap(
                      RUNTIME_EXCEPTION_TYPE,
                      generatedType(RUNTIME_EXCEPTION_TYPE)));
  
              assertThat(injected.get(RUNTIME_EXCEPTION_TYPE).getName())
                      .isEqualTo(RUNTIME_EXCEPTION_TYPE);
              assertThat(classLoader.getTargetLoadAttempts()).isEqualTo(2);
          });
      }
  
      @Test
      void injectRawReturnsClassLoadedAfterErrorFromDispatcher() throws Exception {
          runDynamicClassLoading(() -> {
              GeneratedClassLoader classLoader = new GeneratedClassLoader(
                      getClass().getClassLoader(),
                      ERROR_TYPE,
                      generatedType(ERROR_TYPE),
                      true);
              TestableUsingUnsafe injector = TestableUsingUnsafe.throwingError(classLoader);
  
              Map<String, Class<?>> injected = injector.injectRaw(Collections.singletonMap(
                      ERROR_TYPE,
                      generatedType(ERROR_TYPE)));
  
              assertThat(injected.get(ERROR_TYPE).getName()).isEqualTo(ERROR_TYPE);
              assertThat(classLoader.getTargetLoadAttempts()).isEqualTo(2);
          });
      }
  
      private static byte[] generatedType(String className) {
          DynamicType.Unloaded<?> unloaded = new ByteBuddy()
                  .subclass(Object.class, ConstructorStrategy.Default.NO_CONSTRUCTORS)
                  .name(className)
                  .make();
          return unloaded.getBytes();
      }
  
      private static void runDynamicClassLoading(
              DynamicClassLoadingOperation operation) throws Exception {
          try {
              operation.run();
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
      }
  
      @FunctionalInterface
      private interface DynamicClassLoadingOperation {
          void run() throws Exception;
      }
  
      private static final class GeneratedClassLoader extends ClassLoader {
          private final String className;
          private final byte[] binaryRepresentation;
          private final boolean failFirstTargetLoad;
          private int targetLoadAttempts;
  
          private GeneratedClassLoader(
                  ClassLoader parent,
                  String className,
                  byte[] binaryRepresentation,
                  boolean failFirstTargetLoad) {
              super(parent);
              this.className = className;
              this.binaryRepresentation = binaryRepresentation;
              this.failFirstTargetLoad = failFirstTargetLoad;
          }
  
          @Override
          protected Class<?> loadClass(String name, boolean resolve)
                  throws ClassNotFoundException {
              if (!className.equals(name)) {
                  return super.loadClass(name, resolve);
              }
              synchronized (getClassLoadingLock(name)) {
                  targetLoadAttempts++;
                  if (failFirstTargetLoad && targetLoadAttempts == 1) {
                      throw new ClassNotFoundException(name);
                  }
                  Class<?> loadedClass = findLoadedClass(name);
                  if (loadedClass == null) {
                      loadedClass = defineClass(
                              name,
                              binaryRepresentation,
                              0,
                              binaryRepresentation.length);
                  }
                  if (resolve) {
                      resolveClass(loadedClass);
                  }
                  return loadedClass;
              }
          }
  
          private int getTargetLoadAttempts() {
              return targetLoadAttempts;
          }
      }
  }
  
  class TestableUsingUnsafe extends UsingUnsafe {
      private final RecordingDispatcher recordingDispatcher;
  
      private TestableUsingUnsafe(
              ClassLoader classLoader,
              Dispatcher dispatcher,
              RecordingDispatcher recordingDispatcher) {
          super(classLoader, (ProtectionDomain) null, new FixedInitializable(dispatcher));
          this.recordingDispatcher = recordingDispatcher;
      }
  
      static TestableUsingUnsafe recording(ClassLoader classLoader) {
          RecordingDispatcher dispatcher = new RecordingDispatcher();
          return new TestableUsingUnsafe(classLoader, dispatcher, dispatcher);
      }
  
      static TestableUsingUnsafe throwingRuntimeException(ClassLoader classLoader) {
          return new TestableUsingUnsafe(
                  classLoader,
                  ThrowingDispatcher.RUNTIME_EXCEPTION,
                  null);
      }
  
      static TestableUsingUnsafe throwingError(ClassLoader classLoader) {
          return new TestableUsingUnsafe(classLoader, ThrowingDispatcher.ERROR, null);
      }
  
      int getDefineClassCalls() {
          return recordingDispatcher.getDefineClassCalls();
      }
  
      private static final class FixedInitializable implements Dispatcher.Initializable {
          private final Dispatcher dispatcher;
  
          private FixedInitializable(Dispatcher dispatcher) {
              this.dispatcher = dispatcher;
          }
  
          @Override
          public boolean isAvailable() {
              return true;
          }
  
          @Override
          public Dispatcher initialize() {
              return dispatcher;
          }
      }
  
      private static final class RecordingDispatcher implements Dispatcher {
          private int defineClassCalls;
  
          @Override
          public Class<?> defineClass(
                  ClassLoader classLoader,
                  String name,
                  byte[] binaryRepresentation,
                  ProtectionDomain protectionDomain) {
              defineClassCalls++;
              throw new AssertionError("Dispatcher should not define an already loaded class");
          }
  
          private int getDefineClassCalls() {
              return defineClassCalls;
          }
      }
  
      private enum ThrowingDispatcher implements Dispatcher {
          RUNTIME_EXCEPTION {
              @Override
              public Class<?> defineClass(
                      ClassLoader classLoader,
                      String name,
                      byte[] binaryRepresentation,
                      ProtectionDomain protectionDomain) {
                  throw new IllegalStateException("Definition raced with another loader");
              }
          },
          ERROR {
              @Override
              public Class<?> defineClass(
                      ClassLoader classLoader,
                      String name,
                      byte[] binaryRepresentation,
                      ProtectionDomain protectionDomain) {
                  throw new LinkageError("Definition raced with another loader");
              }
          }
      }
  }
