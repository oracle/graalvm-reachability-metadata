  + *
  + * You should have received a copy of the CC0 legalcode along with this
  + * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.
  + */
  +package org_modelmapper.modelmapper;
  +
  +import static org.assertj.core.api.Assertions.assertThat;
  +
  +import java.lang.instrument.ClassDefinition;
  +import java.lang.instrument.ClassFileTransformer;
  +import java.lang.instrument.Instrumentation;
  +import java.lang.instrument.UnmodifiableClassException;
  +import java.util.List;
  +import java.util.Map;
  +import java.util.Set;
  +import java.util.jar.JarFile;
  +import org.graalvm.internal.tck.NativeImageSupport;
  +import org.junit.jupiter.api.Test;
  +import org.modelmapper.internal.bytebuddy.dynamic.loading.ClassInjector.UsingUnsafe.Factory;
  +import org.modelmapper.internal.bytebuddy.dynamic.loading.ClassInjector.UsingUnsafe.Factory.AccessResolver;
  +
  +public class ClassInjectorInnerUsingUnsafeInnerFactoryTest {
  +    private static final String BYTE_BUDDY_SAFE_PROPERTY =
  +            "org.modelmapper.internal.bytebuddy.safe";
  +
  +    @Test
  +    void resolvesFactoryWithUnavailableUnsafeDispatcher() {
  +        try {
  +            String previousValue = System.setProperty(
  +                    BYTE_BUDDY_SAFE_PROPERTY,
  +                    "true");
  +            try {
  +                Factory factory = new Factory(NoOpAccessResolver.INSTANCE);
  +                assertThat(factory.isAvailable()).isFalse();
  +
  +                Factory resolvedFactory = Factory.resolve(new NoOpInstrumentation(), false);
  +                assertThat(resolvedFactory).isNotNull();
  +            } finally {
  +                if (previousValue == null) {
  +                    System.clearProperty(BYTE_BUDDY_SAFE_PROPERTY);
  +                } else {
  +                    System.setProperty(BYTE_BUDDY_SAFE_PROPERTY, previousValue);
  +                }
  +            }
  +        } catch (Error error) {
  +            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
  +                throw error;
  +            }
  +        }
  +    }
  +
  +    private enum NoOpAccessResolver implements AccessResolver {
  +        INSTANCE;
  +
  +        @Override
  +        public void apply(java.lang.reflect.AccessibleObject accessibleObject) {
  +            // Intentionally leave the member inaccessible so Factory records
  +            // the unavailable dispatcher after attempting to read Unsafe.
  +        }
  +    }
  +
  +    private static final class NoOpInstrumentation implements Instrumentation {
  +        @Override
  +        public void addTransformer(
  +                ClassFileTransformer transformer,
  +                boolean canRetransform) {
  +        }
  +
  +        @Override
  +        public void addTransformer(ClassFileTransformer transformer) {
  +        }
  +
  +        @Override
  +        public boolean removeTransformer(ClassFileTransformer transformer) {
  +            return false;
  +        }
  +
  +        @Override
  +        public boolean isRetransformClassesSupported() {
  +            return false;
  +        }
  +
  +        @Override
  +        public void retransformClasses(Class<?>... classes)
  +                throws UnmodifiableClassException {
  +            throw new UnmodifiableClassException("Retransformation is not supported");
  +        }
  +
  +        @Override
  +        public boolean isRedefineClassesSupported() {
  +            return false;
  +        }
  +
  +        @Override
  +        public void redefineClasses(ClassDefinition... definitions)
