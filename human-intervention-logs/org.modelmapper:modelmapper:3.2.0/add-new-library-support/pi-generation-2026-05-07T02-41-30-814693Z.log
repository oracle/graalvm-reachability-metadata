[tool-call] delta {"path":"tests/src/org.modelmapper/modelmapper/3.2.0/src/test/java/org_modelmapper/modelmapper/ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeInjectionTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_modelmapper.modelmapper;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.net.URL;\nimport java.security.ProtectionDomain;\nimport java.util.Collections;\nimport java.util.Map;\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\nimport org.modelmapper.internal.bytebuddy.ByteBuddy;\nimport org.modelmapper.internal.bytebuddy.dynamic.DynamicType;\nimport org.modelmapper.internal.bytebuddy.dynamic.loading.ClassInjector.UsingReflection;\nimport org.modelmapper.internal.bytebuddy.dynamic.loading.PackageDefinitionStrategy;\nimport org.modelmapper.internal.bytebuddy.dynamic.loading.PackageDefinitionStrategy.Definition;\nimport org.modelmapper.internal.bytebuddy.dynamic.loading.PackageDefinitionStrategy.Definition.Simple;\nimport org.modelmapper.internal.bytebuddy.dynamic.scaffold.subclass.ConstructorStrategy;\n\npublic class ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeInjectionTest {\n    private static final Definition PACKAGE_DEFINITION = new Simple(\n            \"ModelMapper test specification\",\n            \"1\",\n            \"ModelMapper tests\",\n            \"ModelMapper test implementation\",\n            \"1\",\n            \"ModelMapper tests\",\n            null);\n\n    @Test\n    void injectsGeneratedClassAndDefinesPackageThroughUnsafeReflectionDispatcher() throws Exception {\n        runDynamicClassLoading(() -> {\n            ClassLoader classLoader = new ClassLoader(getClass().getClassLoader()) {\n            };\n            String className = \"org_modelmapper.modelmapper.generated.UnsafeReflectionInjectedType\";\n\n            Map<String, Class<?>> loadedTypes = new UsingReflection(\n                    classLoader,\n                    (ProtectionDomain) null,\n                    new AlwaysDefinedPackageStrategy(),\n                    false).injectRaw(generatedType(className));\n\n            assertThat(loadedTypes).containsOnlyKeys(className);\n            assertThat(loadedTypes.get(className).getName()).isEqualTo(className);\n            assertThat(loadedTypes.get(className).getClassLoader()).isSameAs(classLoader);\n        });\n    }\n\n    @Test\n    void fallsBackToLegacyPackageLookupWhenPackageDefinitionFails() throws Exception {\n        runDynamicClassLoading(() -> {\n            ClassLoader classLoader = new PackageDefinitionFailingClassLoader(getClass().getClassLoader());\n            String className = \"org_modelmapper.modelmapper.fallback.UnsafeReflectionFallbackType\";\n\n            Map<String, Class<?>> loadedTypes = new UsingReflection(\n                    classLoader,\n                    (ProtectionDomain) null,\n                    new AlwaysDefinedPackageStrategy(),\n                    false).injectRaw(generatedType(className));\n\n            assertThat(loadedTypes).containsOnlyKeys(className);\n            assertThat(loadedTypes.get(className).getName()).isEqualTo(className);\n            assertThat(loadedTypes.get(className).getClassLoader()).isSameAs(classLoader);\n        });\n    }\n\n    private static Map<String, byte[]> generatedType(String className) {\n        DynamicType.Unloaded<?> unloaded = new ByteBuddy()\n                .subclass(Object.class, ConstructorStrategy.Default.NO_CONSTRUCTORS)\n                .name(className)\n                .make();\n        return Collections.singletonMap(className, unloaded.getBytes());\n    }\n\n    private static void runDynamicClassLoading(DynamicClassLoadingOperation operation) throws Exception {\n        try {\n            operation.run();\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    private static final class AlwaysDefinedPackageStrategy implements PackageDefinitionStrategy {\n        @Override\n        public Definition define(ClassLoader classLoader, String packageName, String typeName) {\n            return PACKAGE_DEFINITION;\n        }\n    }\n\n    private static final class PackageDefinitionFailingClassLoader extends ClassLoader {\n        private PackageDefinitionFailingClassLoader(ClassLoader parent) {\n            super(parent);\n        }\n\n        @Override\n        protected Package definePackage(\n                String name,\n                String specificationTitle,\n                String specificationVersion,\n                String specificationVendor,\n                String implementationTitle,\n                String implementationVersion,\n                String implementationVendor,\n                URL sealBase) {\n            throw new IllegalStateException(\"Package definition is intentionally unavailable\");\n        }\n\n        @Override\n        @SuppressWarnings(\"deprecation\")\n        protected Package getPackage(String name) {\n            return Object.class.getPackage();\n        }\n    }\n\n    @FunctionalInterface\n    private interface DynamicClassLoadingOperation {\n        void run() throws Exception;\n    }\n}\n"}
