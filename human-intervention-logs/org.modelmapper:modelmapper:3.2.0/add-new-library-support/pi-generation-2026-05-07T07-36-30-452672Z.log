5fEI53eswI00UEOSf2XkBEOHC8pruGbpFw6vYhz0UDfXd7DCEWrG\",\"summary\":[]}"}, {"type": "toolCall", "id": "call_22FcBWS8emjsCND7O0Q5pbQR|fc_0c3a8ff0a47507760169fc40c833c081a3a335d42236161b25", "name": "write", "arguments": {"path": "tests/src/org.modelmapper/modelmapper/3.2.0/src/test/java/org_modelmapper/modelmapper/ClassInjectorInnerUsingUnsafeTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_modelmapper.modelmapper;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.security.ProtectionDomain;\nimport java.util.Collections;\nimport java.util.Map;\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\nimport org.modelmapper.internal.bytebuddy.ByteBuddy;\nimport org.modelmapper.internal.bytebuddy.dynamic.DynamicType;\nimport org.modelmapper.internal.bytebuddy.dynamic.loading.ClassInjector.UsingUnsafe;\nimport org.modelmapper.internal.bytebuddy.dynamic.loading.ClassInjector.UsingUnsafe.Dispatcher;\nimport org.modelmapper.internal.bytebuddy.dynamic.scaffold.subclass.ConstructorStrategy;\n\npublic class ClassInjectorInnerUsingUnsafeTest {\n    private static final String PREVIOUSLY_LOADED_TYPE =\n            \"org_modelmapper.modelmapper.usingunsafe.PreviouslyLoadedType\";\n    private static final String RUNTIME_EXCEPTION_TYPE =\n            \"org_modelmapper.modelmapper.usingunsafe.RuntimeExceptionType\";\n    private static final String ERROR_TYPE =\n            \"org_modelmapper.modelmapper.usingunsafe.ErrorType\";\n\n    @Test\n    void injectRawReturnsPreviouslyLoadedClassWithoutCallingDispatcher() throws Exception {\n        runDynamicClassLoading(() -> {\n            GeneratedClassLoader classLoader = new GeneratedClassLoader(\n                    getClass().getClassLoader(),\n                    PREVIOUSLY_LOADED_TYPE,\n                    generatedType(PREVIOUSLY_LOADED_TYPE),\n                    false);\n            Class<?> loadedClass = classLoader.loadClass(PREVIOUSLY_LOADED_TYPE);\n            TestableUsingUnsafe injector = new TestableUsingUnsafe(\n                    classLoader,\n                    FailingDispatcher.INSTANCE);\n\n            Map<String, Class<?>> injected = injector.injectRaw(Collections.singletonMap(\n                    PREVIOUSLY_LOADED_TYPE,\n                    generatedType(PREVIOUSLY_LOADED_TYPE)));\n\n            assertThat(injected).containsEntry(PREVIOUSLY_LOADED_TYPE, loadedClass);\n            assertThat(classLoader.getTargetLoadAttempts()).isEqualTo(2);\n        });\n    }\n\n    @Test\n    void injectRawReturnsClassLoadedAfterRuntimeExceptionFromDispatcher() throws Exception {\n        runDynamicClassLoading(() -> {\n            GeneratedClassLoader classLoader = new GeneratedClassLoader(\n                    getClass().getClassLoader(),\n                    RUNTIME_EXCEPTION_TYPE,\n                    generatedType(RUNTIME_EXCEPTION_TYPE),\n                    true);\n            TestableUsingUnsafe injector = new TestableUsingUnsafe(\n                    classLoader,\n                    ThrowingDispatcher.RUNTIME_EXCEPTION);\n\n            Map<String, Class<?>> injected = injector.injectRaw(Collections.singletonMap(\n                    RUNTIME_EXCEPTION_TYPE,\n                    generatedType(RUNTIME_EXCEPTION_TYPE)));\n\n            assertThat(injected.get(RUNTIME_EXCEPTION_TYPE).getName())\n                    .isEqualTo(RUNTIME_EXCEPTION_TYPE);\n            assertThat(classLoader.getTargetLoadAttempts()).isEqualTo(2);\n        });\n    }\n\n    @Test\n    void injectRawReturnsClassLoadedAfterErrorFromDispatcher() throws Exception {\n        runDynamicClassLoading(() -> {\n            GeneratedClassLoader classLoader = new GeneratedClassLoader(\n                    getClass().getClassLoader(),\n                    ERROR_TYPE,\n                    generatedType(ERROR_TYPE),\n                    true);\n            TestableUsingUnsafe injector = new TestableUsingUnsafe(\n                    classLoader,\n                    ThrowingDispatcher.ERROR);\n\n            Map<String, Class<?>> injected = injector.injectRaw(Collections.singletonMap(\n                    ERROR_TYPE,\n                    generatedType(ERROR_TYPE)));\n\n            assertThat(injected.get(ERROR_TYPE).getName()).isEqualTo(ERROR_TYPE);\n            assertThat(classLoader.getTargetLoadAttempts()).isEqualTo(2);\n        });\n    }\n\n    private static byte[] generatedType(String className) {\n        DynamicType.Unloaded<?> unloaded = new ByteBuddy()\n                .subclass(Object.class, ConstructorStrategy.Default.NO_CONSTRUCTORS)\n                .name(className)\n                .make();\n        return unloaded.getBytes();\n    }\n\n    private static void runDynamicClassLoading(\n            DynamicClassLoadingOperation operation) throws Exception {\n        try {\n            operation.run();\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    @FunctionalInterface\n    private interface DynamicClassLoadingOperation {\n        void run() throws Exception;\n    }\n\n    private static final class TestableUsingUnsafe extends UsingUnsafe {\n        private TestableUsingUnsafe(ClassLoader classLoader, Dispatcher dispatcher) {\n            super(classLoader, (ProtectionDomain) null, new FixedInitializable(dispatcher));\n        }\n    }\n\n    private static final class FixedInitializable implements Dispatcher.Initializable {\n        private final Dispatcher dispatcher;\n\n        private FixedInitializable(Dispatcher dispatcher) {\n            this.dispatcher = dispatcher;\n        }\n\n        @Override\n        public boolean isAvailable() {\n            return true;\n        }\n\n        @Override\n        public Dispatcher initialize() {\n            return dispatcher;\n        }\n    }\n\n    private enum FailingDispatcher implements Dispatcher {\n        INSTANCE;\n\n        @Override\n        public Class<?> defineClass(\n                ClassLoader classLoader,\n                String name,\n                byte[] binaryRepresentation,\n                ProtectionDomain protectionDomain) {\n            throw new AssertionError(\"Dispatcher should not define an already loaded class\");\n        }\n    }\n\n    private enum ThrowingDispatcher implements Dispatcher {\n        RUNTIME_EXCEPTION {\n            @Override\n            public Class<?> defineClass(\n                    ClassLoader classLoader,\n                    String name,\n                    byte[] binaryRepresentation,\n                    ProtectionDomain protectionDomain) {\n                throw new IllegalStateException(\"Definition raced with another loader\");\n            }\n        },\n        ERROR {\n            @Override\n            public Class<?> defineClass(\n                    ClassLoader classLoader,\n                    String name,\n                    byte[] binaryRepresentation,\n                    ProtectionDomain protectionDomain) {\n                throw new LinkageError(\"Definition raced with another loader\");\n            }\n        }\n    }\n\n    private static final class GeneratedClassLoader extends ClassLoader {\n        private final String className;\n        private final byte[] binaryRepresentation;\n        private final boolean failFirstTargetLoad;\n        private int targetLoadAttempts;\n\n        private GeneratedClassLoader(\n                ClassLoader parent,\n                String className,\n                byte[] binaryRepresentation,\n                boolean failFirstTargetLoad) {\n            super(parent);\n            this.className = className;\n            this.binaryRepresentation = binaryRepresentation;\n            this.failFirstTargetLoad = failFirstTargetLoad;\n        }\n\n        @Override\n        protected Class<?> loadClass(String name, boolean resolve)\n                throws ClassNotFoundException {\n            if (!className.equals(name)) {\n                return super.loadClass(name, resolve);\n            }\n            synchronized (getClassLoadingLock(name)) {\n                targetLoadAttempts++;\n                if (failFirstTargetLoad && targetLoadAttempts == 1) {\n                    throw new ClassNotFoundException(name);\n                }\n                Class<?> loadedClass = findLoadedClass(name);\n                if (loadedClass == null) {\n                    loadedClass = defineClass(\n                            name,\n                            binaryRepresentation,\n                            0,\n                            binaryRepresentation.length);\n                }\n                if (resolve) {\n                    resolveClass(loadedClass);\n                }\n                return loadedClass;\n            }\n        }\n\n        private int getTargetLoadAttempts() {\n            return targetLoadAttempts;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 2434, "output": 4058, "cacheRead": 26112, "cacheWrite": 0, "totalTokens": 32604, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778139305892, "responseId": "resp_0c3a8ff0a47507760169fc40aae05881a3b6e66979e713876e"}}
[tool-exec] start id=call_22FcBWS8emjsCND7O0Q5pbQR|fc_0c3a8ff0a47507760169fc40c833c081a3a335d42236161b25 name=write args={"path": "tests/src/org.modelmapper/modelmapper/3.2.0/src/test/java/org_modelmapper/modelmapper/ClassInjectorInnerUsingUnsafeTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_modelmapper.modelmapper;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.security.ProtectionDomain;\nimport java.util.Collections;\nimport java.util.Map;\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\nimport org.modelmapper.internal.bytebuddy.ByteBuddy;\nimport org.modelmapper.internal.bytebuddy.dynamic.DynamicType;\nimport org.modelmapper.internal.bytebuddy.dynamic.loading.ClassInjector.UsingUnsafe;\nimport org.modelmapper.internal.bytebuddy.dynamic.loading.ClassInjector.UsingUnsafe.Dispatcher;\nimport org.modelmapper.internal.bytebuddy.dynamic.scaffold.subclass.ConstructorStrategy;\n\npublic class ClassInjectorInnerUsingUnsafeTest {\n    private static final String PREVIOUSLY_LOADED_TYPE =\n            \"org_modelmapper.modelmapper.usingunsafe.PreviouslyLoadedType\";\n    private static final String RUNTIME_EXCEPTION_TYPE =\n            \"org_modelmapper.modelmapper.usingunsafe.RuntimeExceptionType\";\n    private static final String ERROR_TYPE =\n            \"org_modelmapper.modelmapper.usingunsafe.ErrorType\";\n\n    @Test\n    void injectRawReturnsPreviouslyLoadedClassWithoutCallingDispatcher() throws Exception {\n        runDynamicClassLoading(() -> {\n            GeneratedClassLoader classLoader = new GeneratedClassLoader(\n                    getClass().getClassLoader(),\n                    PREVIOUSLY_LOADED_TYPE,\n                    generatedType(PREVIOUSLY_LOADED_TYPE),\n                    false);\n            Class<?> loadedClass = classLoader.loadClass(PREVIOUSLY_LOADED_TYPE);\n            TestableUsingUnsafe injector = new TestableUsingUnsafe(\n                    classLoader,\n                    FailingDispatcher.INSTANCE);\n\n            Map<String, Class<?>> injected = injector.injectRaw(Collections.singletonMap(\n                    PREVIOUSLY_LOADED_TYPE,\n                    generatedType(PREVIOUSLY_LOADED_TYPE)));\n\n            assertThat(injected).containsEntry(PREVIOUSLY_LOADED_TYPE, loadedClass);\n            assertThat(classLoader.getTargetLoadAttempts()).isEqualTo(2);\n        });\n    }\n\n    @Test\n    void injectRawReturnsClassLoadedAfterRuntimeExceptionFromDispatcher() throws Exception {\n        runDynamicClassLoading(() -> {\n            GeneratedClassLoader classLoader = new GeneratedClassLoader(\n                    getClass().getClassLoader(),\n                    RUNTIME_EXCEPTION_TYPE,\n                    generatedType(RUNTIME_EXCEPTION_TYPE),\n                    true);\n            TestableUsingUnsafe injector = new TestableUsingUnsafe(\n                    classLoader,\n                    ThrowingDispatcher.RUNTIME_EXCEPTION);\n\n            Map<String, Class<?>> injected = injector.injectRaw(Collections.singletonMap(\n                    RUNTIME_EXCEPTION_TYPE,\n                    generatedType(RUNTIME_EXCEPTION_TYPE)));\n\n            assertThat(injected.get(RUNTIME_EXCEPTION_TYPE).getName())\n                    .isEqualTo(RUNTIME_EXCEPTION_TYPE);\n            assertThat(classLoader.getTargetLoadAttempts()).isEqualTo(2);\n        });\n    }\n\n    @Test\n    void injectRawReturnsClassLoadedAfterErrorFromDispatcher() throws Exception {\n        runDynamicClassLoading(() -> {\n            GeneratedClassLoader classLoader = new GeneratedClassLoader(\n                    getClass().getClassLoader(),\n                    ERROR_TYPE,\n                    generatedType(ERROR_TYPE),\n                    true);\n            TestableUsingUnsafe injector = new TestableUsingUnsafe(\n                    classLoader,\n                    ThrowingDispatcher.ERROR);\n\n            Map<String, Class<?>> injected = injector.injectRaw(Collections.singletonMap(\n                    ERROR_TYPE,\n                    generatedType(ERROR_TYPE)));\n\n            assertThat(injected.get(ERROR_TYPE).getName()).isEqualTo(ERROR_TYPE);\n            assertThat(classLoader.getTargetLoadAttempts()).isEqualTo(2);\n        });\n    }\n\n    private static byte[] generatedType(String className) {\n        DynamicType.Unloaded<?> unloaded = new ByteBuddy()\n                .subclass(Object.class, ConstructorStrategy.Default.NO_CONSTRUCTORS)\n                .name(className)\n                .make();\n        return unloaded.getBytes();\n    }\n\n    private static void runDynamicClassLoading(\n            DynamicClassLoadingOperation operation) throws Exception {\n        try {\n            operation.run();\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    @FunctionalInterface\n    private interface DynamicClassLoadingOperation {\n        void run() throws Exception;\n    }\n\n    private static final class TestableUsingUnsafe extends UsingUnsafe {\n        private TestableUsingUnsafe(ClassLoader classLoader, Dispatcher dispatcher) {\n            super(classLoader, (ProtectionDomain) null, new FixedInitializable(dispatcher));\n        }\n    }\n\n    private static final class FixedInitializable implements Dispatcher.Initializable {\n        private final Dispatcher dispatcher;\n\n        private FixedInitializable(Dispatcher dispatcher) {\n            this.dispatcher = dispatcher;\n        }\n\n        @Override\n        public boolean isAvailable() {\n            return true;\n        }\n\n        @Override\n        public Dispatcher initialize() {\n            return dispatcher;\n        }\n    }\n\n    private enum FailingDispatcher implements Dispatcher {\n        INSTANCE;\n\n        @Override\n        public Class<?> defineClass(\n                ClassLoader classLoader,\n                String name,\n                byte[] binaryRepresentation,\n                ProtectionDomain protectionDomain) {\n            throw new AssertionError(\"Dispatcher should not define an already loaded class\");\n        }\n    }\n\n    private enum ThrowingDispatcher implements Dispatcher {\n        RUNTIME_EXCEPTION {\n            @Override\n            public Class<?> defineClass(\n                    ClassLoader classLoader,\n                    String name,\n                    byte[] binaryRepresentation,\n                    ProtectionDomain protectionDomain) {\n                throw new IllegalStateException(\"Definition raced with another loader\");\n            }\n        },\n        ERROR {\n            @Override\n            public Class<?> defineClass(\n                    ClassLoader classLoader,\n                    String name,\n                    byte[] binaryRepresentation,\n                    ProtectionDomain protectionDomain) {\n                throw new LinkageError(\"Definition raced with another loader\");\n            }\n        }\n    }\n\n    private static final class GeneratedClassLoader extends ClassLoader {\n        private final String className;\n        private final byte[] binaryRepresentation;\n        private final boolean failFirstTargetLoad;\n        private int targetLoadAttempts;\n\n        private GeneratedClassLoader(\n                ClassLoader parent,\n                String className,\n                byte[] binaryRepresentation,\n                boolean failFirstTargetLoad) {\n            super(parent);\n            this.className = className;\n            this.binaryRepresentation = binaryRepresentation;\n            this.failFirstTargetLoad = failFirstTargetLoad;\n        }\n\n        @Override\n        protected Class<?> loadClass(String name, boolean resolve)\n                throws ClassNotFoundException {\n            if (!className.equals(name)) {\n                return super.loadClass(name, resolve);\n            }\n            synchronized (getClassLoadingLock(name)) {\n                targetLoadAttempts++;\n                if (failFirstTargetLoad && targetLoadAttempts == 1) {\n                    throw new ClassNotFoundException(name);\n                }\n                Class<?> loadedClass = findLoadedClass(name);\n                if (loadedClass == null) {\n                    loadedClass = defineClass(\n                            name,\n                            binaryRepresentation,\n                            0,\n                            binaryRepresentation.length);\n                }\n                if (resolve) {\n                    resolveClass(loadedClass);\n                }\n                return loadedClass;\n            }\n        }\n\n        private int getTargetLoadAttempts() {\n            return targetLoadAttempts;\n        }\n    }\n}\n"}
