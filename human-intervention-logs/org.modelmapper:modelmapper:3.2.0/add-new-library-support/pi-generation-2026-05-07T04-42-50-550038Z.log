  package org_modelmapper.modelmapper;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.IOException;
  import java.net.URL;
  import java.util.Collections;
  import java.util.Enumeration;
  import java.util.Map;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  import org.modelmapper.internal.bytebuddy.ByteBuddy;
  import org.modelmapper.internal.bytebuddy.description.type.TypeDescription;
  import org.modelmapper.internal.bytebuddy.dynamic.DynamicType;
  import org.modelmapper.internal.bytebuddy.dynamic.loading.ByteArrayClassLoader.ChildFirst;
  import org.modelmapper.internal.bytebuddy.dynamic.loading.ByteArrayClassLoader.PersistenceHandler;
  import org.modelmapper.internal.bytebuddy.dynamic.scaffold.subclass.ConstructorStrategy;
  
  public class ByteArrayClassLoaderInnerChildFirstTest {
      private static final String STATIC_LOADED_TYPE =
              "org_modelmapper.modelmapper.generated.ChildFirstStaticLoadedType";
      private static final String DIRECT_LOADED_TYPE =
              "org_modelmapper.modelmapper.generated.ChildFirstDirectLoadedType";
      private static final String MANIFEST_RESOURCE_TYPE =
              "org_modelmapper.modelmapper.generated.ChildFirstManifestResourceType";
      private static final String PARENT_ONLY_RESOURCE = "modelmapper-parent-only-resource.txt";
  
      @Test
      void loadsGeneratedTypesThroughChildFirstStaticLoader() throws Exception {
          runDynamicClassLoading(() -> {
              DynamicType.Unloaded<?> unloadedType = generatedType(STATIC_LOADED_TYPE);
              Map<TypeDescription, byte[]> types = Collections.singletonMap(
                      unloadedType.getTypeDescription(),
                      unloadedType.getBytes());
  
              Map<TypeDescription, Class<?>> loadedTypes =
                      ChildFirst.load(getClass().getClassLoader(), types);
  
              assertThat(loadedTypes).containsOnlyKeys(unloadedType.getTypeDescription());
              Class<?> loadedType = loadedTypes.get(unloadedType.getTypeDescription());
              assertThat(loadedType.getName()).isEqualTo(STATIC_LOADED_TYPE);
              assertThat(loadedType.getClassLoader()).isInstanceOf(ChildFirst.class);
          });
      }
  
      @Test
      void loadsPreviouslyDefinedTypeBeforeDelegatingToParent() throws Exception {
          runDynamicClassLoading(() -> {
              ChildFirst classLoader = new ChildFirst(
                      getClass().getClassLoader(),
                      generatedTypeByName(DIRECT_LOADED_TYPE));
  
              Class<?> firstLoad = classLoader.loadClass(DIRECT_LOADED_TYPE);
              Class<?> secondLoad = classLoader.loadClass(DIRECT_LOADED_TYPE);
  
              assertThat(firstLoad).isSameAs(secondLoad);
              assertThat(secondLoad.getClassLoader()).isSameAs(classLoader);
          });
      }
  
      @Test
      void resolvesParentResourcesAndClassFileShadowing() throws Exception {
          runDynamicClassLoading(() -> {
              URL parentResource = new URL("file", "", "/" + PARENT_ONLY_RESOURCE);
              ChildFirst classLoader = new ChildFirst(
                      new ResourceClassLoader(getClass().getClassLoader(), parentResource),
                      generatedTypeByName(DIRECT_LOADED_TYPE));
  
              assertThat(classLoader.getResource(PARENT_ONLY_RESOURCE)).isEqualTo(parentResource);
              assertThat(Collections.list(classLoader.getResources(PARENT_ONLY_RESOURCE)))
                      .containsExactly(parentResource);
  
              Class<?> loadedType = classLoader.loadClass(DIRECT_LOADED_TYPE);
              assertThat(loadedType.getClassLoader()).isSameAs(classLoader);
              assertThat(classLoader.getResource(classResourceName(DIRECT_LOADED_TYPE))).isNull();
          });
      }
  
      @Test
      void prependsManifestResourcesBeforeParentResources() throws Exception {
          runDynamicClassLoading(() -> {
              URL parentResource = new URL("file", "", "/parent-class-resource.class");
              ChildFirst classLoader = new ChildFirst(
                      new ResourceClassLoader(getClass().getClassLoader(), parentResource),
                      generatedTypeByName(MANIFEST_RESOURCE_TYPE),
                      PersistenceHandler.MANIFEST);
  
              Enumeration<URL> resources =
                      classLoader.getResources(classResourceName(MANIFEST_RESOURCE_TYPE));
  
              assertThat(resources.hasMoreElements()).isTrue();
              URL childResource = resources.nextElement();
              assertThat(childResource.toString()).startsWith("bytebuddy://");
              assertThat(Collections.list(resources)).containsExactly(parentResource);
          });
      }
  
      private static DynamicType.Unloaded<?> generatedType(String className) {
          return new ByteBuddy()
                  .subclass(Object.class, ConstructorStrategy.Default.NO_CONSTRUCTORS)
                  .name(className)
                  .make();
      }
  
      private static Map<String, byte[]> generatedTypeByName(String className) {
          return Collections.singletonMap(className, generatedType(className).getBytes());
      }
  
      private static String classResourceName(String className) {
          return className.replace('.', '/') + ".class";
      }
  
      private static void runDynamicClassLoading(
              DynamicClassLoadingOperation operation) throws Exception {
          try {
