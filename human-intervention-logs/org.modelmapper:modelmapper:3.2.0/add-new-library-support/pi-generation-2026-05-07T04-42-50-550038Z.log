[tool-call] delta {"path":"tests/src/org.modelmapper/modelmapper/3.2.0/src/test/java/org_modelmapper/modelmapper/MultipleParentClassLoaderTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_modelmapper.modelmapper;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.IOException;\nimport java.net.URL;\nimport java.util.ArrayList;\nimport java.util.Arrays;\nimport java.util.Collections;\nimport java.util.Enumeration;\nimport java.util.List;\nimport org.junit.jupiter.api.Test;\nimport org.modelmapper.internal.bytebuddy.dynamic.loading.MultipleParentClassLoader;\n\npublic class MultipleParentClassLoaderTest {\n    private static final String PARENT_ONLY_RESOURCE = \"modelmapper-multiple-parent-only-resource.txt\";\n    private static final String TEST_CLASS_RESOURCE = \"org_modelmapper/modelmapper/MultipleParentClassLoaderTest.class\";\n\n    @Test\n    void delegatesClassLoadingToFirstParentThatCanLoadType() throws Exception {\n        RecordingClassLoader failingParent = RecordingClassLoader.failing();\n        RecordingClassLoader bootstrapParent = RecordingClassLoader.delegatingToBootstrap();\n        MultipleParentClassLoader classLoader = new MultipleParentClassLoader(\n                getClass().getClassLoader(),\n                Arrays.asList(failingParent, bootstrapParent),\n                false);\n\n        Class<?> loadedType = classLoader.loadClass(String.class.getName());\n\n        assertThat(loadedType).isSameAs(String.class);\n        assertThat(failingParent.getRequests()).containsExactly(String.class.getName());\n        assertThat(bootstrapParent.getRequests()).containsExactly(String.class.getName());\n    }\n\n    @Test\n    void returnsResourcesFromParentsBeforeDelegatingToOwnParent() throws Exception {\n        URL parentResource = new URL(\"file\", \"\", \"/\" + PARENT_ONLY_RESOURCE);\n        ResourceClassLoader resourceParent = new ResourceClassLoader(parentResource);\n        MultipleParentClassLoader classLoader = new MultipleParentClassLoader(\n                getClass().getClassLoader(),\n                Collections.singletonList(resourceParent),\n                false);\n\n        assertThat(classLoader.getResource(PARENT_ONLY_RESOURCE)).isEqualTo(parentResource);\n\n        URL testClassResource = classLoader.getResource(TEST_CLASS_RESOURCE);\n        assertThat(testClassResource).isNotNull();\n        assertThat(testClassResource).isNotEqualTo(parentResource);\n\n        List<URL> resources = Collections.list(classLoader.getResources(TEST_CLASS_RESOURCE));\n        assertThat(resources).contains(parentResource, testClassResource);\n        assertThat(resources).startsWith(parentResource);\n    }\n\n    private static final class RecordingClassLoader extends ClassLoader {\n        private final List<String> requests = new ArrayList<>();\n        private final boolean failing;\n\n        private RecordingClassLoader(boolean failing) {\n            super(null);\n            this.failing = failing;\n        }\n\n        private static RecordingClassLoader failing() {\n            return new RecordingClassLoader(true);\n        }\n\n        private static RecordingClassLoader delegatingToBootstrap() {\n            return new RecordingClassLoader(false);\n        }\n\n        @Override\n        public Class<?> loadClass(String name) throws ClassNotFoundException {\n            requests.add(name);\n            if (failing) {\n                throw new ClassNotFoundException(name);\n            }\n            return super.loadClass(name);\n        }\n\n        private List<String> getRequests() {\n            return requests;\n        }\n    }\n\n    private static final class ResourceClassLoader extends ClassLoader {\n        private final URL resource;\n\n        private ResourceClassLoader(URL resource) {\n            super(null);\n            this.resource = resource;\n        }\n\n        @Override\n        public URL getResource(String name) {\n            if (PARENT_ONLY_RESOURCE.equals(name) || TEST_CLASS_RESOURCE.equals(name)) {\n                return resource;\n            }\n            return super.getResource(name);\n        }\n\n        @Override\n        public Enumeration<URL> getResources(String name) throws IOException {\n            if (PARENT_ONLY_RESOURCE.equals(name) || TEST_CLASS_RESOURCE.equals(name)) {\n                return Collections.enumeration(Collections.singleton(resource));\n            }\n            return super.getResources(name);\n        }\n    }\n}\n"}
