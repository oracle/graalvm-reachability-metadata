[tool-call] delta {"path":"tests/src/org.modelmapper/modelmapper/3.2.0/src/test/java/org_modelmapper/modelmapper/SunReflectionFactoryHelperTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_modelmapper.modelmapper;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport org.junit.jupiter.api.Test;\nimport org.modelmapper.internal.objenesis.instantiator.ObjectInstantiator;\nimport org.modelmapper.internal.objenesis.instantiator.sun.SunReflectionFactoryInstantiator;\n\npublic class SunReflectionFactoryHelperTest {\n    @Test\n    void createsObjectWithoutCallingItsConstructor() {\n        ConstructorGuard.reset();\n\n        ObjectInstantiator<ConstructorGuard> instantiator =\n                new SunReflectionFactoryInstantiator<>(ConstructorGuard.class);\n        ConstructorGuard instance = instantiator.newInstance();\n\n        assertThat(instance).isNotNull();\n        assertThat(ConstructorGuard.wasConstructorCalled()).isFalse();\n    }\n\n    private static final class ConstructorGuard {\n        private static boolean constructorCalled;\n\n        private ConstructorGuard() {\n            constructorCalled = true;\n            throw new AssertionError(\"ReflectionFactory instantiation must bypass this constructor\");\n        }\n\n        private static void reset() {\n            constructorCalled = false;\n        }\n\n        private static boolean wasConstructorCalled() {\n            return constructorCalled;\n        }\n    }\n}\n"}
