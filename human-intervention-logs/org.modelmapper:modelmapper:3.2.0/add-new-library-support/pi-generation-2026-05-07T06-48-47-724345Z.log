  }
  
  String libraryVersion = tck.testedLibraryVersion.get()
  String permissiveSecurityManager =
          "org_modelmapper.modelmapper.JavaDispatcherTest\$PermissiveSecurityManager"
  
  dependencies {
      testImplementation "org.modelmapper:modelmapper:$libraryVersion"
      testImplementation 'org.assertj:assertj-core:3.22.0'
      testRuntimeOnly 'javassist:javassist:3.12.1.GA'
  }
  
  graalvmNative {
      agent {
          defaultMode = "conditional"
          modes {
              conditional {
                  userCodeFilterPath = "user-code-filter.json"
              }
          }
      }
      binaries {
          test {
              if ((JavaVersion.current().majorVersion as int) < 24) {
                  buildArgs.add("-Djava.security.manager=${permissiveSecurityManager}")
              }
          }
      }
  }
  
  tasks.withType(Test).configureEach {
      if ((JavaVersion.current().majorVersion as int) < 24) {
          jvmArgs += ["-Djava.security.manager=${permissiveSecurityManager}"]
      }
  }
  
  tasks.named("nativeTest") {
