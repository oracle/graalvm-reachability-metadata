m.getProperty(SAFE_PROPERTY);\\n        System.setProperty(SAFE_PROPERTY, Boolean.FALSE.toString());\\n        try {\\n            exerciseUnsafeDispatcher();\\n        } catch (Error error) {\\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\\n                throw error;\\n            }\\n        } finally {\\n            restoreProperty(originalSafeProperty);\\n        }\\n    }\\n\\n    private static void exerciseUnsafeDispatcher() {\\n        DispatcherAccess.exercise();\\n    }\\n\\n    private static byte[] makeClassBytes() {\\n        DynamicType.Unloaded<?> unloadedType = new ByteBuddy()\\n                .subclass(Object.class)\\n                .name(INJECTED_TYPE_NAME)\\n                .make();\\n        return unloadedType.getBytes();\\n    }\\n\\n    private static ClassLoader testClassLoader() {\\n        return ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeInjectionTest.class\\n                .getClassLoader();\\n    }\\n\\n    private static ProtectionDomain testProtectionDomain() {\\n        return ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeInjectionTest.class\\n                .getProtectionDomain();\\n    }\\n\\n    private static void restoreProperty(String originalSafeProperty) {\\n        if (originalSafeProperty == null) {\\n            System.clearProperty(SAFE_PROPERTY);\\n        } else {\\n            System.setProperty(SAFE_PROPERTY, originalSafeProperty);\\n        }\\n    }\\n\\n    private static final class DispatcherAccess extends UsingReflection {\\n        static {\\n            java.lang.System.setProperty(SAFE_PROPERTY, Boolean.FALSE.toString());\\n        }\\n\\n        private DispatcherAccess() {\\n            super(testClassLoader());\\n        }\\n\\n        static void exercise() {\\n            Dispatcher.Initializable initializable = Dispatcher.CreationAction.INSTANCE.run();\\n            if (initializable.isAvailable()) {\\n                exerciseAvailab