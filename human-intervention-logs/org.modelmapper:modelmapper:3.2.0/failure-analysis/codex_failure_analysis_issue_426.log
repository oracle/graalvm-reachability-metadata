ertions.assertThat;\\n\\nimport java.io.IOException;\\nimport java.net.URL;\\nimport java.util.ArrayList;\\nimport java.util.Arrays;\\nimport java.util.Collections;\\nimport java.util.Enumeration;\\nimport java.util.List;\\nimport org.junit.jupiter.api.Test;\\nimport org.modelmapper.internal.bytebuddy.dynamic.loading.MultipleParentClassLoader;\\n\\npublic class MultipleParentClassLoaderTest {\\n    private static final String TEST_CLASS_RESOURCE =\\n            \\\"org/modelmapper/ModelMapper.class\\\";\\n\\n    @Test\\n    void delegatesClassLoadingToFirstParentThatCanLoadType() throws Exception {\\n        RecordingClassLoader failingParent = RecordingClassLoader.failing();\\n        RecordingClassLoader bootstrapParent = RecordingClassLoader.delegatingToBootstrap();\\n        MultipleParentClassLoader classLoader = new MultipleParentClassLoader(\\n                getClass().getClassLoader(),\\n                Arrays.asList(failingParent, bootstrapParent),\\n                false);\\n\\n        Class<?> loadedType = classLoader.loadClass(String.class.getName());\\n\\n        assertThat(loadedType).isSameAs(String.class);\\n        assertThat(failingParent.getRequests()).containsExactly(String.class.getName());\\n        assertThat(bootstrapParent.getRequests()).containsExactly(String.class.getName());\\n    }\\n\\n    @Test\\n    void returnsResourcesFromParentsBeforeDelegatingToOwnParent() throws Exception {\\n        URL parentResource = new URL(\\\"file\\\", \\\"\\\", \\\"/parent-modelmapper-resource.class\\\");\\n        ResourceClassLoader resourceParent = new ResourceClassLoader(\\n                TEST_CLASS_RESOURCE,\\n                parentResource);\\n        MultipleParentClassLoader classLoader = new MultipleParentClassLoader(\\n                getClass().getClassLoader(),\\n                Collections.singletonList(resourceParent),\\n                false);\\n\\n        assertThat(classLoader.getResource(TEST_CLASS_RESOURCE)).isEqualTo(parentResource);