  ### org/jgroups/logging/LogFactory.java
  001: package org.jgroups.logging;
  002: 
  003: import org.jgroups.Global;
  004: import org.jgroups.util.Util;
  005: 
  006: import java.lang.reflect.Constructor;
  007: 
  008: 
  009: /**
  010:  * Factory that creates {@link Log} instances.
  011:  *
  012:  * @author Manik Surtani
  013:  * @author Bela Ban
  014:  * @since 4.0
  015:  */
  016: public final class LogFactory {
  017: 
  018: 
  019:     public static final boolean                 IS_SLF4J_AVAILABLE;
  020:     public static final boolean                 IS_LOG4J2_AVAILABLE;  // log4j2 is the default logger
  021:     protected static boolean                    use_jdk_logger;
  022:     protected static CustomLogFactory           custom_log_factory=null;
  023:     protected static Constructor<? extends Log> ctor_class=null;
  024: 
  025: 	private LogFactory() {
  026: 		throw new InstantiationError( "Must not instantiate this class" );
  027: 	}
  028: 
  029:     static {
  030:         use_jdk_logger=isPropertySet(Global.USE_JDK_LOGGER);
  031: 
  032:         String classname=Util.getProperty(Global.LOG_CLASS);
  033:         if(classname != null) {
  034:             try {
  035:                 ctor_class=findConstructor(classname, Class.class);
  036:             }
  037:             catch(Exception e) {
  038:                 throw new IllegalArgumentException(String.format("failed loading logger %s", classname), e);
  039:             }
  040:         }
  041: 
  042:         if(use_jdk_logger || ctor_class != null)
  043:             IS_LOG4J2_AVAILABLE=IS_SLF4J_AVAILABLE=false;
  044:         else {
  045:             IS_LOG4J2_AVAILABLE=isAvailable("org.apache.logging.log4j.core.Logger");
  046:             IS_SLF4J_AVAILABLE=!IS_LOG4J2_AVAILABLE && isAvailable("org.slf4j.Logger");
  047:         }
  048:     }
  049: 
  050:     public static CustomLogFactory getCustomLogFactory()                         {return custom_log_factory;}
  051:     public static void             setCustomLogFactory(CustomLogFactory factory) {custom_log_factory=factory;}
  052:     public static boolean          useJdkLogger()                                {return use_jdk_logger;}
  053:     public static void             useJdkLogger(boolean flag)                    {use_jdk_logger=flag;}
  054: 
  055:     public static Log getLog(Class<?> clazz) {
  056:         if(custom_log_factory != null)
  057:             return custom_log_factory.getLog(clazz);
  058:         if(ctor_class != null) {
  059:             try {
  060:                 return ctor_class.newInstance(clazz);
  061:             }
  062:             catch(Throwable t) {
  063:                 throw new RuntimeException(t);
  064:             }
  065:         }
  066:         if(use_jdk_logger)
  067:             return new JDKLogImpl(clazz);
  068:         if(IS_LOG4J2_AVAILABLE)
  069:             return new Log4J2LogImpl(clazz);
  070:         if(IS_SLF4J_AVAILABLE)
  071:             return new Slf4jLogImpl(clazz);
  072:         return new JDKLogImpl(clazz);
  073:     }
  074: 
  075:     public static String loggerType() {
  076:         if(ctor_class != null)
  077:             return ctor_class.getDeclaringClass().getSimpleName();
  078:         if(use_jdk_logger)      return "jdk";
  079:         if(IS_LOG4J2_AVAILABLE) return "log4j2";
  080:         if(IS_SLF4J_AVAILABLE)  return "slf4j";
  081:         return "jdk";
  082:     }
  083: 
  084:     protected static boolean isAvailable(String classname) {
  085:         try {
  086:             return Class.forName(classname) != null;
  087:         }
  088:         catch(ClassNotFoundException cnfe) {
  089:             return false;
  090:         }
  091:     }
  092: 
  093:     protected static boolean isPropertySet(String property_name) {
  094:         try {
  095:             return Boolean.parseBoolean(System.getProperty(property_name));
  096:         }
  097:         catch(Throwable t) {
  098:             return false;
  099:         }
  100:     }
  101: 
  102: 
  103:     protected static Constructor<? extends Log> findConstructor(String classname, Class<?> arg) throws Exception {
  104:         Class<?> clazz=Util.loadClass(classname, (Class<?>)null);
  105:         return (Constructor<? extends Log>)clazz.getDeclaredConstructor(arg);
  106:     }
  107: }
  
