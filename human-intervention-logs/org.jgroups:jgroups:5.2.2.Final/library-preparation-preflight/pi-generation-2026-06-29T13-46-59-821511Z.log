  plugins {
      id "org.graalvm.internal.tck"
  }
  
  String libraryVersion = tck.testedLibraryVersion.get()
  String customLoggerClass = 'org_jgroups.jgroups.LogFactoryTest$ConfiguredLog'
  
  tasks.withType(Test).configureEach {
      forkEvery = 1
      systemProperty 'jgroups.bind_addr', '127.0.0.1'
      systemProperty 'java.net.preferIPv4Stack', 'true'
      systemProperty 'jgroups.log_class', customLoggerClass
  }
  
  tasks.named('nativeTest') {
      runtimeArgs.add('-Djgroups.bind_addr=127.0.0.1')
      runtimeArgs.add('-Djava.net.preferIPv4Stack=true')
      runtimeArgs.add("-Djgroups.log_class=${customLoggerClass}")
  }
  
  dependencies {
      testImplementation "org.jgroups:jgroups:$libraryVersion"
      testImplementation 'org.slf4j:slf4j-api:1.7.31'
      testRuntimeOnly('org.wildfly.openssl:wildfly-openssl:2.1.1.Final') {
          transitive = false
      }
      testImplementation 'org.assertj:assertj-core:3.22.0'
  }
  
  graalvmNative {
      agent {
          defaultMode = "conditional"
          modes {
              conditional {
                  userCodeFilterPath = "user-code-filter.json"
              }
          }
      }
  }
