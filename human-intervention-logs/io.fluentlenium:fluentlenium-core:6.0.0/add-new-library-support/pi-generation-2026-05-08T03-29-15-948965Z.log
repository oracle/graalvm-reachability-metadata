  package io_fluentlenium.fluentlenium_core;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import io.fluentlenium.core.conditions.Negation;
  import io.fluentlenium.core.conditions.message.Message;
  import io.fluentlenium.core.conditions.message.MessageBuilderCall;
  import io.fluentlenium.core.conditions.message.MessageContext;
  import io.fluentlenium.core.conditions.message.MessageProxy;
  import io.fluentlenium.core.conditions.message.NotMessage;
  import java.util.ArrayList;
  import java.util.List;
  import org.junit.jupiter.api.Test;
  
  public class MessageProxyTest {
      @Test
      void builderWithContextCreatesProxyThatRecordsAnnotatedCalls() {
          MessageCondition condition = MessageProxy.builder(MessageCondition.class, "field name");
  
          boolean result = condition.equalTo("value");
  
          assertThat(result).isFalse();
          assertThat(MessageProxy.message(condition)).isEqualTo("field name is not equal to value");
      }
  
      @Test
      void builderWithCallsCreatesProxyUsingExistingCallStack() {
          List<MessageBuilderCall> calls = new ArrayList<>();
          MessageBuilderCall initialCall = new MessageBuilderCall();
          initialCall.setContext("existing context");
          calls.add(initialCall);
          MessageCondition condition = MessageProxy.builder(MessageCondition.class, calls);
  
          MessageCondition contextualCondition = condition.withElementContext();
          contextualCondition.equalTo("item");
  
          assertThat(MessageProxy.message(contextualCondition))
                  .isEqualTo("existing context element is not equal to item");
          assertThat(calls).hasSize(3);
      }
  
      @Test
      void wrapWithContextCreatesProxyThatInvokesOriginalInstance() {
          RecordingCondition instance = new RecordingCondition(true);
          MessageCondition condition = MessageProxy.wrap(MessageCondition.class, instance, "wrapped field");
  
          boolean result = condition.equalTo("actual");
  
          assertThat(result).isTrue();
          assertThat(instance.comparedValue()).isEqualTo("actual");
          assertThat(MessageProxy.message(condition)).isEqualTo("wrapped field is not equal to actual");
      }
  
      @Test
      void wrapWithCallsCreatesProxyThatSharesRecordedCallsWithoutDelegatingToInstance() {
          List<MessageBuilderCall> calls = new ArrayList<>();
          MessageBuilderCall initialCall = new MessageBuilderCall();
          initialCall.setContext("shared context");
          calls.add(initialCall);
          RecordingCondition instance = new RecordingCondition(false);
          MessageCondition condition = MessageProxy.wrap(MessageCondition.class, instance, calls);
  
          MessageCondition negatedCondition = condition.not();
          boolean result = negatedCondition.equalTo("other");
  
          assertThat(result).isFalse();
          assertThat(instance.notCalls()).isZero();
          assertThat(instance.comparedValue()).isNull();
          assertThat(MessageProxy.message(negatedCondition)).isEqualTo("shared context is equal to other");
          assertThat(calls).hasSize(3);
      }
  
      public interface MessageCondition {
          @MessageContext("element")
          MessageCondition withElementContext();
  
          @Negation
          MessageCondition not();
  
          @Message("is equal to {0}")
          @NotMessage("is not equal to {0}")
          boolean equalTo(String value);
      }
  
      public static final class RecordingCondition implements MessageCondition {
          private final boolean comparisonResult;
          private String comparedValue;
          private int notCalls;
  
          RecordingCondition(boolean comparisonResult) {
              this.comparisonResult = comparisonResult;
          }
  
          @Override
          public MessageCondition withElementContext() {
              return this;
          }
  
          @Override
          public MessageCondition not() {
              notCalls++;
              return this;
          }
  
          @Override
          public boolean equalTo(String value) {
              comparedValue = value;
              return comparisonResult;
          }
  
          String comparedValue() {
              return comparedValue;
          }
  
          int notCalls() {
              return notCalls;
          }
      }
  }
[recv] {"type": "message_start", "message": {"role": "toolResult", "toolCallId": "call_XVgTbdQVxjgC1ucopcz1sWlg|fc_07000ab1e8113a830169fd58574e988196b8c71071ef77070c", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_fluentlenium.fluentlenium_core;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport io.fluentlenium.core.conditions.Negation;\nimport io.fluentlenium.core.conditions.message.Message;\nimport io.fluentlenium.core.conditions.message.MessageBuilderCall;\nimport io.fluentlenium.core.conditions.message.MessageContext;\nimport io.fluentlenium.core.conditions.message.MessageProxy;\nimport io.fluentlenium.core.conditions.message.NotMessage;\nimport java.util.ArrayList;\nimport java.util.List;\nimport org.junit.jupiter.api.Test;\n\npublic class MessageProxyTest {\n    @Test\n    void builderWithContextCreatesProxyThatRecordsAnnotatedCalls() {\n        MessageCondition condition = MessageProxy.builder(MessageCondition.class, \"field name\");\n\n        boolean result = condition.equalTo(\"value\");\n\n        assertThat(result).isFalse();\n        assertThat(MessageProxy.message(condition)).isEqualTo(\"field name is not equal to value\");\n    }\n\n    @Test\n    void builderWithCallsCreatesProxyUsingExistingCallStack() {\n        List<MessageBuilderCall> calls = new ArrayList<>();\n        MessageBuilderCall initialCall = new MessageBuilderCall();\n        initialCall.setContext(\"existing context\");\n        calls.add(initialCall);\n        MessageCondition condition = MessageProxy.builder(MessageCondition.class, calls);\n\n        MessageCondition contextualCondition = condition.withElementContext();\n        contextualCondition.equalTo(\"item\");\n\n        assertThat(MessageProxy.message(contextualCondition))\n                .isEqualTo(\"existing context element is not equal to item\");\n        assertThat(calls).hasSize(3);\n    }\n\n    @Test\n    void wrapWithContextCreatesProxyThatInvokesOriginalInstance() {\n        RecordingCondition instance = new RecordingCondition(true);\n        MessageCondition condition = MessageProxy.wrap(MessageCondition.class, instance, \"wrapped field\");\n\n        boolean result = condition.equalTo(\"actual\");\n\n        assertThat(result).isTrue();\n        assertThat(instance.comparedValue()).isEqualTo(\"actual\");\n        assertThat(MessageProxy.message(condition)).isEqualTo(\"wrapped field is not equal to actual\");\n    }\n\n    @Test\n    void wrapWithCallsCreatesProxyThatSharesRecordedCallsWithoutDelegatingToInstance() {\n        List<MessageBuilderCall> calls = new ArrayList<>();\n        MessageBuilderCall initialCall = new MessageBuilderCall();\n        initialCall.setContext(\"shared context\");\n        calls.add(initialCall);\n        RecordingCondition instance = new RecordingCondition(false);\n        MessageCondition condition = MessageProxy.wrap(MessageCondition.class, instance, calls);\n\n        MessageCondition negatedCondition = condition.not();\n        boolean result = negatedCondition.equalTo(\"other\");\n\n        assertThat(result).isFalse();\n        assertThat(instance.notCalls()).isZero();\n        assertThat(instance.comparedValue()).isNull();\n        assertThat(MessageProxy.message(negatedCondition)).isEqualTo(\"shared context is equal to other\");\n        assertThat(calls).hasSize(3);\n    }\n\n    public interface MessageCondition {\n        @MessageContext(\"element\")\n        MessageCondition withElementContext();\n\n        @Negation\n        MessageCondition not();\n\n        @Message(\"is equal to {0}\")\n        @NotMessage(\"is not equal to {0}\")\n        boolean equalTo(String value);\n    }\n\n    public static final class RecordingCondition implements MessageCondition {\n        private final boolean comparisonResult;\n        private String comparedValue;\n        private int notCalls;\n\n        RecordingCondition(boolean comparisonResult) {\n            this.comparisonResult = comparisonResult;\n        }\n\n        @Override\n        public MessageCondition withElementContext() {\n            return this;\n        }\n\n        @Override\n        public MessageCondition not() {\n            notCalls++;\n            return this;\n        }\n\n        @Override\n        public boolean equalTo(String value) {\n            comparedValue = value;\n            return comparisonResult;\n        }\n\n        String comparedValue() {\n            return comparedValue;\n        }\n\n        int notCalls() {\n            return notCalls;\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778210903828}}
