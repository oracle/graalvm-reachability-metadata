  import java.util.Collections;
  import org.junit.jupiter.api.Test;
  import org.openqa.selenium.WebDriver;
  
  public class WaitConditionProxyTest {
      @Test
      void elementCreatesFluentConditionsWaitProxy() {
          FluentWait wait = wait();
  
          FluentConditions conditions = WaitConditionProxy.element(wait, "element context", () -> null);
  
          assertThat(conditions).isNotNull();
          assertThat(conditions).isInstanceOf(FluentConditions.class);
      }
  
      @Test
      void listCreatesFluentListConditionsWaitProxy() {
          FluentWait wait = wait();
  
          FluentListConditions conditions = WaitConditionProxy.list(
                  wait,
                  "list context",
                  () -> new EachElementConditions(Collections.<FluentWebElement>emptyList()));
  
          assertThat(conditions).isNotNull();
          assertThat(conditions.size(0)).isTrue();
      }
  
      private static FluentWait wait() {
          return new FluentWait(new TestFluentControl())
                  .atMost(Duration.ofSeconds(1))
                  .pollingEvery(Duration.ofMillis(10));
      }
  
      public static final class TestFluentControl extends FluentControlImpl {
          @Override
          public FluentControl getFluentControl() {
              return this;
          }
  
  
