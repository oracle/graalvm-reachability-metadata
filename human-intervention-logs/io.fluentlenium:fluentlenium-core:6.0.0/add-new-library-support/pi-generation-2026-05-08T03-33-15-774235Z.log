  package io_fluentlenium.fluentlenium_core;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import io.fluentlenium.core.FluentControl;
  import io.fluentlenium.core.FluentControlImpl;
  import io.fluentlenium.core.conditions.EachElementConditions;
  import io.fluentlenium.core.conditions.FluentConditions;
  import io.fluentlenium.core.conditions.FluentListConditions;
  import io.fluentlenium.core.conditions.wait.WaitConditionProxy;
  import io.fluentlenium.core.domain.FluentWebElement;
  import io.fluentlenium.core.wait.FluentWait;
  import java.time.Duration;
  import java.util.Collections;
  import org.junit.jupiter.api.Test;
  import org.openqa.selenium.WebDriver;
  
  public class WaitConditionProxyTest {
      @Test
      void elementCreatesFluentConditionsWaitProxy() {
          FluentWait wait = newWait();
  
          FluentConditions conditions = WaitConditionProxy.element(wait, "element context", () -> null);
  
          assertThat(conditions).isNotNull();
          assertThat(conditions).isInstanceOf(FluentConditions.class);
      }
  
      @Test
      void listCreatesFluentListConditionsWaitProxy() {
          FluentWait wait = newWait();
  
          FluentListConditions conditions = WaitConditionProxy.list(
                  wait,
                  "list context",
                  () -> new EachElementConditions(Collections.<FluentWebElement>emptyList()));
  
          assertThat(conditions).isNotNull();
          assertThat(conditions.size(0)).isTrue();
      }
  
      private static FluentWait newWait() {
          return new FluentWait(new TestFluentControl())
                  .atMost(Duration.ofSeconds(1))
                  .pollingEvery(Duration.ofMillis(10));
      }
  
      public static final class TestFluentControl extends FluentControlImpl {
          @Override
          public FluentControl getFluentControl() {
              return this;
          }
  
          @Override
          public WebDriver getDriver() {
              return null;
          }
      }
  }
