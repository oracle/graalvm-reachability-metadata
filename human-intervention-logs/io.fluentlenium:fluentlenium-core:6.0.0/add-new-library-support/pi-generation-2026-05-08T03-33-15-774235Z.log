  package io_fluentlenium.fluentlenium_core;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import io.fluentlenium.core.domain.WrapsElements;
  import io.fluentlenium.core.proxy.LocatorProxies;
  import java.util.List;
  import org.junit.jupiter.api.Test;
  import org.openqa.selenium.WebElement;
  import org.openqa.selenium.WrapsElement;
  import org.openqa.selenium.remote.RemoteWebElement;
  
  public class LocatorProxiesTest {
      @Test
      void createWebElementWrapsExistingElementInLocatorProxy() {
          WebElement element = new StableWebElement("element");
  
          WebElement proxy = LocatorProxies.createWebElement(element);
  
          assertThat(proxy).isInstanceOf(WrapsElement.class);
          assertThat(LocatorProxies.getLocatorHandler(proxy)).isNotNull();
          assertThat(LocatorProxies.loaded(proxy)).isTrue();
          assertThat(LocatorProxies.getLocatorResult(proxy)).isSameAs(element);
          assertThat(((WrapsElement) proxy).getWrappedElement()).isSameAs(element);
      }
  
      @Test
      void createWebElementListWrapsExistingElementsInLocatorProxy() {
          WebElement firstElement = new StableWebElement("first");
          WebElement secondElement = new StableWebElement("second");
  
          List<WebElement> proxy = LocatorProxies.createWebElementList(List.of(firstElement, secondElement));
  
          assertThat(proxy).isInstanceOf(WrapsElements.class);
          assertThat(LocatorProxies.getLocatorHandler(proxy)).isNotNull();
          assertThat(LocatorProxies.loaded(proxy)).isTrue();
          assertThat(proxy).hasSize(2);
          assertThat(LocatorProxies.getLocatorResult(proxy)).hasSize(2);
          assertThat(((WrapsElement) proxy.get(0)).getWrappedElement()).isSameAs(firstElement);
          assertThat(((WrapsElement) proxy.get(1)).getWrappedElement()).isSameAs(secondElement);
      }
  
      private static final class StableWebElement extends RemoteWebElement {
          private final String name;
  
          private StableWebElement(String name) {
              this.name = name;
          }
  
          @Override
          public boolean isEnabled() {
              return true;
          }
  
          @Override
          public String toString() {
              return name;
          }
      }
  }
