  package io_fluentlenium.fluentlenium_core;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import io.fluentlenium.configuration.AbstractFactoryRegistryImpl;
  import io.fluentlenium.configuration.ConfigurationException;
  import io.fluentlenium.configuration.Factory;
  import io.fluentlenium.configuration.FactoryName;
  import io.fluentlenium.configuration.FactoryNames;
  import io.fluentlenium.configuration.IndexIgnore;
  import io.fluentlenium.configuration.ReflectiveFactory;
  import java.util.List;
  import org.atteo.classindex.IndexSubclasses;
  import org.junit.jupiter.api.Test;
  
  public class AbstractFactoryRegistryImplTest {
      @Test
      void instantiatesIndexedFactoriesWhenRegistryIsConstructed() {
          TestFactoryRegistry registry = new TestFactoryRegistry();
  
          TestFactory factory = registry.get("indexed");
  
          assertThat(factory.description()).isEqualTo("created through the public default constructor");
          assertThat(registry.get(null)).isSameAs(factory);
      }
  
      @IndexSubclasses
      public interface TestFactory extends Factory {
          String description();
      }
  
      @FactoryName("indexed")
      public static final class IndexedFactory implements TestFactory {
          private final String description;
  
          public IndexedFactory() {
              description = "created through the public default constructor";
          }
  
          @Override
          public String description() {
              return description;
          }
      }
  
      public static final class TestFactoryRegistry
              extends AbstractFactoryRegistryImpl<TestFactory, TestReflectiveFactory> {
          TestFactoryRegistry() {
              super(TestFactory.class, TestReflectiveFactory.class);
          }
  
          @Override
          protected TestFactory getDefault(List<TestFactory> filteredFactories) {
              assertThat(filteredFactories).isNotEmpty();
              return filteredFactories.get(0);
          }
  
          @Override
          protected void handleNoFactoryAvailable(String name) {
              throw new ConfigurationException("No test factory is available with this name: " + name);
          }
  
          @Override
          protected TestReflectiveFactory newReflectiveInstance(String name) {
              return new TestReflectiveFactory(name);
          }
      }
  
      @IndexIgnore
      public static final class TestReflectiveFactory implements TestFactory, ReflectiveFactory, FactoryNames {
          private final String name;
  
          TestReflectiveFactory(String name) {
              this.name = name;
          }
  
          @Override
          public boolean isAvailable() {
              return false;
          }
  
          @Override
          public String[] getNames() {
              return new String[] {name};
          }
  
          @Override
          public String description() {
              return "reflective " + name;
          }
      }
  }
