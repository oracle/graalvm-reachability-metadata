meUnit;\nimport java.util.concurrent.atomic.AtomicReference;\nimport org.junit.jupiter.api.Test;\nimport org.openqa.selenium.WebDriver;\nimport org.openqa.selenium.remote.DesiredCapabilities;\n\npublic class DefaultWebDriverFactoriesInnerRemoteWebDriverFactoryTest {\n    @Test\n    void createsRemoteWebDriverFromConfiguredRemoteUrl() throws Exception {\n        try (FakeSeleniumServer server = FakeSeleniumServer.start()) {\n            ProgrammaticConfiguration configuration = new ProgrammaticConfiguration();\n            configuration.setRemoteUrl(server.remoteUrl());\n            DesiredCapabilities capabilities = new DesiredCapabilities();\n            capabilities.setBrowserName(\"firefox\");\n\n            DefaultWebDriverFactories.RemoteWebDriverFactory factory =\n                    new DefaultWebDriverFactories.RemoteWebDriverFactory();\n            WebDriver driver = factory.newWebDriver(capabilities, configuration);\n\n            try {\n                assertThat(driver).isNotNull();\n                assertThat(server.awaitNewSessionRequest()).contains(\"firefox\");\n            } finally {\n                driver.quit();\n            }\n        }\n    }\n\n    private static final class FakeSeleniumServer implements AutoCloseable {\n        private static final Duration TIMEOUT = Duration.ofSeconds(10);\n\n        private final ServerSocket serverSocket;\n        private final ExecutorService executor;\n        private final AtomicReference<String> newSessionRequest = new AtomicReference<>();\n\n        private FakeSeleniumServer(ServerSocket serverSocket) {\n            this.serverSocket = serverSocket;\n            this.executor = Executors.newSingleThreadExecutor(runnable -> {\n                Thread thread = new Thread(runnable, \"fake-selenium-remote\");\n                thread.setDaemon(true);\n                return thread;\n            });\n        }\n\n        static FakeSeleniumServer start() throws IOException {\n            InetAddress loopbackAddress = InetAddress.getLoopbackAddress();\n            ServerSocket serverSocket = new ServerSocket(0, 50, loopbackAddress);\n            serverSocket.setSoTimeout((int) TIMEOUT.toMillis());\n            FakeSeleniumServer server = new FakeSeleniumServer(serverSocket);\n            server.executor.execute(server::serve);\n            return server;\n        }\n\n        String remoteUrl() {\n            return \"http://\" + serverSocket.getInetAddress().getHostAddress() + ':' + serverSocket.getLocalPort();\n        }\n\n        String awaitNewSessionRequest() throws InterruptedException {\n            long deadline = System.nanoTime() + TIMEOUT.toNanos();\n            while (System.nanoTime() < deadline) {\n                String request = newSessionRequest.get();\n                if (request != null) {\n                    return request;\n                }\n                TimeUnit.MILLISECONDS.sleep(10);\n            }\n            throw new AssertionError(\"Timed out waiting for a WebDriver new-session request\");\n        }\n\n        private void serve() {\n            while (!serverSocket.isClosed()) {\n                try (Socket socket = serverSocket.accept()) {\n                    handle(socket);\n                } catch (SocketException e) {\n                    if (!serverSocket.isClosed()) {\n                        throw new AssertionError(\"Fake Selenium server socket failed\", e);\n                    }\n                } catch (IOException e) {\n                    throw new AssertionError(\"Fake Selenium server failed\", e);\n                }\n            }\n        }\n\n        private void handle(Socket socket) throws IOException {\n            socket.setSoTimeout((int) TIMEOUT.toMillis());\n            BufferedReader reader = new BufferedReader(\n                    new InputStreamReader(socket.getInputStream(), StandardCharsets.UTF_8));\n            String requestLine = reader.readLine();\n            if (requestLine == null) {\n                return;\n            }\n\n            int contentLength = readContentLength(reader);\n            char[] body = new char[contentLength];\n            int offset = 0;\n            while (offset < body.length) {\n                int read = reader.read(body, offset, body.length - offset);\n                if (read < 0) {\n                    break;\n                }\n                offset += read;\n            }\n\n            String[] requestParts = requestLine.split(\" \");\n            String method = requestParts[0];\n            String path = requestParts[1];\n            String requestBody = new String(body, 0, offset);\n\n            if (\"GET\".equals(method) && \"/status\".equals(path)) {\n                writeJson(socket.getOutputStream(), \"{\\\"value\\\":{\\\"ready\\\":true,\\\"message\\\":\\\"ready\\\"}}\");\n            } else if (\"POST\".equals(method) && \"/session\".equals(path)) {\n                newSessionRequest.set(requestBody);\n                writeJson(socket.getOutputStream(), newSessionResponse());\n            } else if (\"DELETE\".equals(method) && path.startsWith(\"/session/\")) {\n                writeJson(socket.getOutputStream(), \"{\\\"value\\\":null}\");\n            } else {\n                writeJson(socket.getOutputStream(), \"{\\\"value\\\":null}\");\n            }\n        }\n\n        private int readContentLength(BufferedReader reader) throws IOException {\n            int contentLength = 0;\n            String line;\n            while ((line = reader.readLine()) != null && !line.isEmpty()) {\n                String lowerCaseLine = line.toLowerCase(Locale.ROOT);\n                if (lowerCaseLine.startsWith(\"content-length:\")) {\n                    contentLength = Integer.parseInt(line.substring(line.indexOf(':') + 1).trim());\n                }\n            }\n            return contentLength;\n        }\n\n        private String newSessionResponse() {\n            return \"\"\"\n                    {\n                      \"value\": {\n                        \"sessionId\": \"test-session\",\n                        \"capabilities\": {\n                          \"browserName\": \"firefox\",\n                          \"browserVersion\": \"1.0\",\n                          \"platformName\": \"linux\",\n                          \"acceptInsecureCerts\": false,\n                          \"pageLoadStrategy\": \"normal\",\n                          \"setWindowRect\": true,\n                          \"timeouts\": {\n                            \"implicit\": 0,\n                            \"pageLoad\": 300000,\n                            \"script\": 30000\n                          },\n                          \"unhandledPromptBehavior\": \"dismiss and notify\"\n                        }\n                      }\n                    }\n                    \"\"\";\n        }\n\n        private void writeJson(OutputStream outputStream, String json) throws IOException {\n            byte[] body = json.getBytes(StandardCharsets.UTF_8);\n            String headers = \"HTTP/1.1 200 OK\\r\\n\"\n                    + \"Content-Type: application/json; charset=utf-8\\r\\n\"\n                    + \"Content-Length: \" + body.length + \"\\r\\n\"\n                    + \"Connection: close\\r\\n\"\n                    + \"\\r\\n\";\n            outputStream.write(headers.getBytes(StandardCharsets.UTF_8));\n            outputStream.write(body);\n            outputStream.flush();\n        }\n\n        @Override\n        public void close() throws IOException, InterruptedException {\n            serverSocket.close();\n            executor.shutdownNow();\n            assertThat(executor.awaitTermination(TIMEOUT.toMillis(), TimeUnit.MILLISECONDS)).isTrue();\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778212110012}]}
