* You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\nplugins {\n    id \"org.graalvm.internal.tck\"\n}\n\nString libraryVersion = tck.testedLibraryVersion.get()\n\ndependencies {\n    testImplementation \"io.fluentlenium:fluentlenium-core:$libraryVersion\"\n    testImplementation 'org.assertj:assertj-core:3.22.0'\n    testAnnotationProcessor 'org.atteo.classindex:classindex:3.13'\n}\n\ngraalvmNative {\n    agent {\n        defaultMode = \"conditional\"\n        modes {\n            conditional {\n                userCodeFilterPath = \"user-code-filter.json\"\n            }\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778212000561}, {"role": "toolResult", "toolCallId": "call_8kdIYS4HQqO2WuP13oPiucWP|fc_00b0b265a43ee47b0169fd5ca03b6c81a09a1473c040094d8f", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_fluentlenium.fluentlenium_core;\n\nimport org.junit.jupiter.api.Test;\n\nclass Fluentlenium_coreTest {\n    @Test\n    void test() throws Exception {\n        System.out.println(\"This is just a placeholder, implement your test\");\n    }\n}\n"}], "isError": false, "timestamp": 1778212000561}, {"role": "toolResult", "toolCallId": "call_Teatrl47O39b116dZKm8ifuP|fc_00b0b265a43ee47b0169fd5ca03b7481a0ad7aefff3dd6b478", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_fluentlenium.fluentlenium_core;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport io.fluentlenium.configuration.AbstractFactoryRegistryImpl;\nimport io.fluentlenium.configuration.ConfigurationException;\nimport io.fluentlenium.configuration.Factory;\nimport io.fluentlenium.configuration.FactoryName;\nimport io.fluentlenium.configuration.FactoryNames;\nimport io.fluentlenium.configuration.IndexIgnore;\nimport io.fluentlenium.configuration.ReflectiveFactory;\nimport java.util.List;\nimport org.atteo.classindex.IndexSubclasses;\nimport org.junit.jupiter.api.Test;\n\npublic class AbstractFactoryRegistryImplTest {\n    @Test\n    void instantiatesIndexedFactoriesWhenRegistryIsConstructed() {\n        TestFactoryRegistry registry = new TestFactoryRegistry();\n\n        TestFactory factory = registry.get(\"indexed\");\n\n        assertThat(factory.description()).isEqualTo(\"created through the public default constructor\");\n        assertThat(registry.get(null)).isSameAs(factory);\n    }\n\n    @IndexSubclasses\n    public interface TestFactory extends Factory {\n        String description();\n    }\n\n    @FactoryName(\"indexed\")\n    public static final class IndexedFactory implements TestFactory {\n        private final String description;\n\n        public IndexedFactory() {\n            description = \"created through the public default constructor\";\n        }\n\n        @Override\n        public String description() {\n            return description;\n        }\n    }\n\n    public static final class TestFactoryRegistry\n            extends AbstractFactoryRegistryImpl<TestFactory, TestReflectiveFactory> {\n        TestFactoryRegistry() {\n            super(TestFactory.class, TestReflectiveFactory.class);\n        }\n\n        @Override\n        protected TestFactory getDefault(List<TestFactory> filteredFactories) {\n            assertThat(filteredFactories).isNotEmpty();\n            return filteredFactories.get(0);\n        }\n\n        @Override\n        protected void handleNoFactoryAvailable(String name) {\n            throw new ConfigurationException(\"No test factory is available with this name: \" + name);\n        }\n\n        @Override\n        protected TestReflectiveFactory newReflectiveInstance(String name) {\n            return new TestReflectiveFactory(name);\n        }\n    }\n\n    @IndexIgnore\n    public static final class TestReflectiveFactory implements TestFactory, ReflectiveFactory, FactoryNames {\n        private final String name;\n\n        TestReflectiveFactory(String name) {\n            this.name = name;\n        }\n\n        @Override\n        public boolean isAvailable() {\n            return false;\n        }\n\n        @Override\n        public String[] getNames() {\n            return new String[] {name};\n        }\n\n        @Override\n        public String description() {\n            return \"reflective \" + name;\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778212000562}, {"role": "toolResult", "toolCallId": "call_5CqphiMmjVZh1BnbDKWeEyDG|fc_00b0b265a43ee47b0169fd5ca03b7c81a0813fcdb8458005bc", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_fluentlenium.fluentlenium_core;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport io.fluentlenium.utils.ReflectionUtils;\nimport java.lang.reflect.Constructor;\nimport java.lang.reflect.Field;\nimport java.lang.reflect.Method;\nimport org.junit.jupiter.api.Test;\n\n@SuppressWarnings(\"deprecation\")\npublic class ReflectionUtilsTest {\n    @Test\n    void resolvesDeclaredConstructorsByDefaultExactAndAssignableArgumentTypes() throws Exception {\n        Constructor<ConstructorFixture> defaultConstructor = ReflectionUtils.getConstructor(ConstructorFixture.class);\n        Constructor<ConstructorFixture> exactConstructor = ReflectionUtils.getConstructor(ConstructorFixture.class,\n                String.class);\n        Constructor<ConstructorFixture> assignableConstructor = ReflectionUtils.getConstructor(ConstructorFixture.class,\n                Integer.class);\n\n        assertThat(defaultConstructor.getParameterTypes()).isEmpty();\n        assertThat(exactConstructor.getParameterTypes()).containsExactly(String.class);\n        assertThat(assignableConstructor.getParameterTypes()).containsExactly(int.class);\n    }\n\n    @Test\n    void createsInstancesAfterTemporarilyOpeningMatchingConstructors() throws Exception {\n        ConstructorFixture defaultFixture = ReflectionUtils.newInstance(ConstructorFixture.class);\n        ConstructorFixture exactFixture = ReflectionUtils.newInstance(ConstructorFixture.class, \"configured\");\n        ConstructorFixture assignableFixture = ReflectionUtils.newInstance(ConstructorFixture.class, 7);\n\n        assertThat(defaultFixture.value()).isEqualTo(\"default\");\n        assertThat(exactFixture.value()).isEqualTo(\"configured\");\n        assertThat(assignableFixture.value()).isEqualTo(\"7\");\n    }\n\n    @Test\n    void createsInstancesWithPreviouslyOpenedConstructors() throws Exception {\n        Constructor<PublicConstructorFixture> defaultConstructor = ReflectionUtils.getConstructor(\n                PublicConstructorFixture.class);\n        Constructor<PublicConstructorFixture> namedConstructor = ReflectionUtils.getConstructor(\n                PublicConstructorFixture.class, String.class);\n        defaultConstructor.setAccessible(true);\n        namedConstructor.setAccessible(true);\n        for (Constructor<?> constructor : PublicConstructorFixture.class.getDeclaredConstructors()) {\n            constructor.setAccessible(true);\n        }\n\n        PublicConstructorFixture defaultFixture = ReflectionUtils.newInstance(PublicConstructorFixture.class);\n        PublicConstructorFixture namedFixture = ReflectionUtils.newInstance(PublicConstructorFixture.class, \"public\");\n\n        assertThat(defaultFixture.value()).isEqualTo(\"public-default\");\n        assertThat(namedFixture.value()).isEqualTo(\"public\");\n    }\n\n    @Test\n    void createsInstancesWithPreviouslyOpenedAssignableConstructors() throws Exception {\n        Constructor<PreparedConstructorFixture> constructor = ReflectionUtils.getConstructor(\n                PreparedConstructorFixture.class, Integer.class);\n        constructor.setAccessible(true);\n        for (Constructor<?> declaredConstructor : PreparedConstructorFixture.class.getDeclaredConstructors()) {\n            declaredConstructor.setAccessible(true);\n        }\n\n        PreparedConstructorFixture fixture = ReflectionUtils.newInstance(PreparedConstructorFixture.class, 42);\n\n        assertThat(fixture.value()).isEqualTo(\"42\");\n    }\n\n    @Test\n    void getsPublicMethodsFromDeclaringClasses() {\n        Method method = ReflectionUtils.getMethod(MethodFixture.class, \"join\", String.class, int.class);\n\n        assertThat(method.getReturnType()).isEqualTo(String.class);\n        assertThat(method.getParameterTypes()).containsExactly(String.class, int.class);\n    }\n\n    @Test\n    void invokesMethodsThatAreAlreadyAccessibleOrNeedTemporaryAccess() throws Exception {\n        MethodFixture fixture = new MethodFixture(\"method\");\n        Method accessibleMethod = MethodFixture.class.getDeclaredMethod(\"hidden\", String.class);\n        Method inaccessibleMethod = MethodFixture.class.getDeclaredMethod(\"hiddenWithNumber\", String.class, int.class);\n        accessibleMethod.setAccessible(true);\n\n        Object accessibleResult = ReflectionUtils.invoke(accessibleMethod, fixture, \"open\");\n        Object inaccessibleResult = ReflectionUtils.invoke(inaccessibleMethod, fixture, \"closed\", 5);\n\n        assertThat(accessibleResult).isEqualTo(\"method:open\");\n        assertThat(inaccessibleResult).isEqualTo(\"method:closed:5\");\n        assertThat(accessibleMethod.isAccessible()).isTrue();\n        assertThat(inaccessibleMethod.isAccessible()).isFalse();\n    }\n\n    @Test\n    void readsFieldsThatAreAlreadyAccessibleOrNeedTemporaryAccess() throws Exception {\n        FieldFixture fixture = new FieldFixture(\"visible\", \"hidden\");\n        Field accessibleField = FieldFixture.class.getDeclaredField(\"accessibleValue\");\n        Field inaccessibleField = FieldFixture.class.getDeclaredField(\"inaccessibleValue\");\n        accessibleField.setAccessible(true);\n\n        Object accessibleValue = ReflectionUtils.get(accessibleField, fixture);\n        Object inaccessibleValue = ReflectionUtils.get(inaccessibleField, fixture);\n\n        assertThat(accessibleValue).isEqualTo(\"visible\");\n        assertThat(inaccessibleValue).isEqualTo(\"hidden\");\n        assertThat(accessibleField.isAccessible()).isTrue();\n        assertThat(inaccessibleField.isAccessible()).isFalse();\n    }\n\n    @Test\n    void writesFieldsThatAreAlreadyAccessibleOrNeedTemporaryAccess() throws Exception {\n        FieldFixture fixture = new FieldFixture(\"original\", \"original\");\n        Field accessibleField = FieldFixture.class.getDeclaredField(\"accessibleValue\");\n        Field inaccessibleField = FieldFixture.class.getDeclaredField(\"inaccessibleValue\");\n        accessibleField.setAccessible(true);\n\n        ReflectionUtils.set(accessibleField, fixture, \"opened\");\n        ReflectionUtils.set(inaccessibleField, fixture, \"temporarily-opened\");\n\n        assertThat(fixture.accessibleValue).isEqualTo(\"opened\");\n        assertThat(fixture.inaccessibleValue).isEqualTo(\"temporarily-opened\");\n        assertThat(accessibleField.isAccessible()).isTrue();\n        assertThat(inaccessibleField.isAccessible()).isFalse();\n    }\n\n    public static final class ConstructorFixture {\n        private final String value;\n\n        private ConstructorFixture() {\n            this.value = \"default\";\n        }\n\n        private ConstructorFixture(String value) {\n            this.value = value;\n        }\n\n        private ConstructorFixture(int value) {\n            this.value = String.valueOf(value);\n        }\n\n        String value() {\n            return value;\n        }\n    }\n\n    public static final class PublicConstructorFixture {\n        private final String value;\n\n        public PublicConstructorFixture() {\n            this.value = \"public-default\";\n        }\n\n        public PublicConstructorFixture(String value) {\n            this.value = value;\n        }\n\n        String value() {\n            return value;\n        }\n    }\n\n    public static final class PreparedConstructorFixture {\n        private final String value;\n\n        private PreparedConstructorFixture(int value) {\n            this.value = String.valueOf(value);\n        }\n\n        String value() {\n            return value;\n        }\n    }\n\n    public static final class MethodFixture {\n        private final String prefix;\n\n        MethodFixture(String prefix) {\n            this.prefix = prefix;\n        }\n\n        public String join(String value, int number) {\n            return prefix + ':' + value + ':' + number;\n        }\n\n        private String hidden(String value) {\n            return prefix + ':' + value;\n        }\n\n        private String hiddenWithNumber(String value, int number) {\n            return prefix + ':' + value + ':' + number;\n        }\n    }\n\n    public static final class FieldFixture {\n        private String accessibleValue;\n        private String inaccessibleValue;\n\n        FieldFixture(String accessibleValue, String inaccessibleValue) {\n            this.accessibleValue = accessibleValue;\n            this.inaccessibleValue = inaccessibleValue;\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778212000562}]}
