  package io_fluentlenium.fluentlenium_core;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import io.fluentlenium.utils.ReflectionUtils;
  import java.lang.reflect.Constructor;
  import java.lang.reflect.Field;
  import java.lang.reflect.Method;
  import org.junit.jupiter.api.Test;
  
  @SuppressWarnings("deprecation")
  public class ReflectionUtilsTest {
      @Test
      void resolvesDeclaredConstructorsByDefaultExactAndAssignableArgumentTypes() throws Exception {
          Constructor<ConstructorFixture> defaultConstructor = ReflectionUtils.getConstructor(ConstructorFixture.class);
          Constructor<ConstructorFixture> exactConstructor = ReflectionUtils.getConstructor(ConstructorFixture.class,
                  String.class);
          Constructor<ConstructorFixture> assignableConstructor = ReflectionUtils.getConstructor(ConstructorFixture.class,
                  Integer.class);
  
          assertThat(defaultConstructor.getParameterTypes()).isEmpty();
          assertThat(exactConstructor.getParameterTypes()).containsExactly(String.class);
          assertThat(assignableConstructor.getParameterTypes()).containsExactly(int.class);
      }
  
      @Test
      void createsInstancesAfterTemporarilyOpeningMatchingConstructors() throws Exception {
          ConstructorFixture defaultFixture = ReflectionUtils.newInstance(ConstructorFixture.class);
          ConstructorFixture exactFixture = ReflectionUtils.newInstance(ConstructorFixture.class, "configured");
          ConstructorFixture assignableFixture = ReflectionUtils.newInstance(ConstructorFixture.class, 7);
  
          assertThat(defaultFixture.value()).isEqualTo("default");
          assertThat(exactFixture.value()).isEqualTo("configured");
          assertThat(assignableFixture.value()).isEqualTo("7");
      }
  
      @Test
      void createsInstancesWithPreviouslyOpenedConstructors() throws Exception {
          Constructor<PublicConstructorFixture> defaultConstructor = ReflectionUtils.getConstructor(
                  PublicConstructorFixture.class);
          Constructor<PublicConstructorFixture> namedConstructor = ReflectionUtils.getConstructor(
                  PublicConstructorFixture.class, String.class);
          defaultConstructor.setAccessible(true);
          namedConstructor.setAccessible(true);
          for (Constructor<?> constructor : PublicConstructorFixture.class.getDeclaredConstructors()) {
              constructor.setAccessible(true);
          }
  
          PublicConstructorFixture defaultFixture = ReflectionUtils.newInstance(PublicConstructorFixture.class);
          PublicConstructorFixture namedFixture = ReflectionUtils.newInstance(PublicConstructorFixture.class, "public");
  
          assertThat(defaultFixture.value()).isEqualTo("public-default");
          assertThat(namedFixture.value()).isEqualTo("public");
      }
  
      @Test
      void createsInstancesWithPreviouslyOpenedAssignableConstructors() throws Exception {
          Constructor<PreparedConstructorFixture> constructor = ReflectionUtils.getConstructor(
                  PreparedConstructorFixture.class, Integer.class);
          constructor.setAccessible(true);
          for (Constructor<?> declaredConstructor : PreparedConstructorFixture.class.getDeclaredConstructors()) {
              declaredConstructor.setAccessible(true);
          }
  
          PreparedConstructorFixture fixture = ReflectionUtils.newInstance(PreparedConstructorFixture.class, 42);
  
          assertThat(fixture.value()).isEqualTo("42");
      }
  
      @Test
      void getsPublicMethodsFromDeclaringClasses() {
          Method method = ReflectionUtils.getMethod(MethodFixture.class, "join", String.class, int.class);
  
          assertThat(method.getReturnType()).isEqualTo(String.class);
          assertThat(method.getParameterTypes()).containsExactly(String.class, int.class);
      }
  
      @Test
      void invokesMethodsThatAreAlreadyAccessibleOrNeedTemporaryAccess() throws Exception {
          MethodFixture fixture = new MethodFixture("method");
          Method accessibleMethod = MethodFixture.class.getDeclaredMethod("hidden", String.class);
          Method inaccessibleMethod = MethodFixture.class.getDeclaredMethod("hiddenWithNumber", String.class, int.class);
          accessibleMethod.setAccessible(true);
  
          Object accessibleResult = ReflectionUtils.invoke(accessibleMethod, fixture, "open");
          Object inaccessibleResult = ReflectionUtils.invoke(inaccessibleMethod, fixture, "closed", 5);
  
          assertThat(accessibleResult).isEqualTo("method:open");
          assertThat(inaccessibleResult).isEqualTo("method:closed:5");
          assertThat(accessibleMethod.isAccessible()).isTrue();
          assertThat(inaccessibleMethod.isAccessible()).isFalse();
      }
  
      @Test
      void readsFieldsThatAreAlreadyAccessibleOrNeedTemporaryAccess() throws Exception {
          FieldFixture fixture = new FieldFixture("visible", "hidden");
          Field accessibleField = FieldFixture.class.getDeclaredField("accessibleValue");
          Field inaccessibleField = FieldFixture.class.getDeclaredField("inaccessibleValue");
          accessibleField.setAccessible(true);
  
          Object accessibleValue = ReflectionUtils.get(accessibleField, fixture);
          Object inaccessibleValue = ReflectionUtils.get(inaccessibleField, fixture);
  
          assertThat(accessibleValue).isEqualTo("visible");
          assertThat(inaccessibleValue).isEqualTo("hidden");
          assertThat(accessibleField.isAccessible()).isTrue();
          assertThat(inaccessibleField.isAccessible()).isFalse();
      }
  
      @Test
      void writesFieldsThatAreAlreadyAccessibleOrNeedTemporaryAccess() throws Exception {
          FieldFixture fixture = new FieldFixture("original", "original");
          Field accessibleField = FieldFixture.class.getDeclaredField("accessibleValue");
          Field inaccessibleField = FieldFixture.class.getDeclaredField("inaccessibleValue");
          accessibleField.setAccessible(true);
  
          ReflectionUtils.set(accessibleField, fixture, "opened");
          ReflectionUtils.set(inaccessibleField, fixture, "temporarily-opened");
  
          assertThat(fixture.accessibleValue).isEqualTo("opened");
          assertThat(fixture.inaccessibleValue).isEqualTo("temporarily-opened");
          assertThat(accessibleField.isAccessible()).isTrue();
          assertThat(inaccessibleField.isAccessible()).isFalse();
      }
  
      public static final class ConstructorFixture {
          private final String value;
  
          private ConstructorFixture() {
              this.value = "default";
          }
  
          private ConstructorFixture(String value) {
              this.value = value;
          }
  
          private ConstructorFixture(int value) {
              this.value = String.valueOf(value);
          }
  
          String value() {
              return value;
          }
      }
  
      public static final class PublicConstructorFixture {
          private final String value;
  
          public PublicConstructorFixture() {
              this.value = "public-default";
          }
  
          public PublicConstructorFixture(String value) {
              this.value = value;
          }
  
          String value() {
              return value;
          }
      }
  
      public static final class PreparedConstructorFixture {
          private final String value;
  
          private PreparedConstructorFixture(int value) {
              this.value = String.valueOf(value);
          }
  
          String value() {
              return value;
          }
      }
  
      public static final class MethodFixture {
          private final String prefix;
  
          MethodFixture(String prefix) {
              this.prefix = prefix;
          }
  
          public String join(String value, int number) {
              return prefix + ':' + value + ':' + number;
          }
  
          private String hidden(String value) {
              return prefix + ':' + value;
          }
  
          private String hiddenWithNumber(String value, int number) {
              return prefix + ':' + value + ':' + number;
          }
      }
  
      public static final class FieldFixture {
          private String accessibleValue;
          private String inaccessibleValue;
  
          FieldFixture(String accessibleValue, String inaccessibleValue) {
              this.accessibleValue = accessibleValue;
              this.inaccessibleValue = inaccessibleValue;
          }
      }
  }
