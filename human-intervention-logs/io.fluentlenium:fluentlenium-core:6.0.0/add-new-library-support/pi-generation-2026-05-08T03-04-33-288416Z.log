      @Test
      void wrapWithCallsCreatesProxyThatSharesRecordedCallsWithOriginalInstance() {
          List<MessageBuilderCall> calls = new ArrayList<>();
          MessageBuilderCall initialCall = new MessageBuilderCall();
          initialCall.setContext("shared context");
          calls.add(initialCall);
          RecordingCondition instance = new RecordingCondition(false);
          MessageCondition condition = MessageProxy.wrap(MessageCondition.class, instance, calls);
  
          MessageCondition negatedCondition = condition.not();
          boolean result = negatedCondition.equalTo("other");
  
          assertThat(result).isFalse();
          assertThat(instance.notCalls()).isEqualTo(1);
          assertThat(instance.comparedValue()).isEqualTo("other");
          assertThat(MessageProxy.message(negatedCondition)).isEqualTo("shared context is equal to other");
          assertThat(calls).hasSize(3);
      }
  
      public interface MessageCondition {
          @MessageContext("element")
          MessageCondition withElementContext();
  
          @Negation
          MessageCondition not();
  
