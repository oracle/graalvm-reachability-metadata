onUtils.newInstance(ConstructorFixture.class, 7);\n\n        assertThat(defaultFixture.value()).isEqualTo(\"default\");\n        assertThat(exactFixture.value()).isEqualTo(\"configured\");\n        assertThat(assignableFixture.value()).isEqualTo(\"7\");\n    }\n\n    @Test\n    void getsPublicMethodsFromDeclaringClasses() {\n        Method method = ReflectionUtils.getMethod(MethodFixture.class, \"join\", String.class, int.class);\n\n        assertThat(method.getReturnType()).isEqualTo(String.class);\n        assertThat(method.getParameterTypes()).containsExactly(String.class, int.class);\n    }\n\n    @Test\n    void invokesMethodsThatAreAlreadyAccessibleOrNeedTemporaryAccess() throws Exception {\n        MethodFixture fixture = new MethodFixture(\"method\");\n        Method accessibleMethod = MethodFixture.class.getDeclaredMethod(\"hidden\", String.class);\n        Method inaccessibleMethod = MethodFixture.class.getDeclaredMethod(\"hiddenWithNumber\", String.class, int.class);\n        accessibleMethod.setAccessible(true);\n\n        Object accessibleResult = ReflectionUtils.invoke(accessibleMethod, fixture, \"open\");\n        Object inaccessibleResult = ReflectionUtils.invoke(inaccessibleMethod, fixture, \"closed\", 5);\n\n        assertThat(accessibleResult).isEqualTo(\"method:open\");\n        assertThat(inaccessibleResult).isEqualTo(\"method:closed:5\");\n        assertThat(accessibleMethod.isAccessible()).isTrue();\n        assertThat(inaccessibleMethod.isAccessible()).isFalse();\n    }\n\n    @Test\n    void readsFieldsThatAreAlreadyAccessibleOrNeedTemporaryAccess() throws Exception {\n        FieldFixture fixture = new FieldFixture(\"visible\", \"hidden\");\n        Field accessibleField = FieldFixture.class.getDeclaredField(\"accessibleValue\");\n        Field inaccessibleField = FieldFixture.class.getDeclaredField(\"inaccessibleValue\");\n        accessibleField.setAccessible(true);\n\n        Object accessibleValue = ReflectionUtils.get(accessibleField, fixture);\n        Object inaccessibleValue = ReflectionUtils.get(inaccessibleField, fixture);\n\n        assertThat(accessibleValue).isEqualTo(\"visible\");\n        assertThat(inaccessibleValue).isEqualTo(\"hidden\");\n        assertThat(accessibleField.isAccessible()).isTrue();\n        assertThat(inaccessibleField.isAccessible()).isFalse();\n    }\n\n    @Test\n    void writesFieldsThatAreAlreadyAccessibleOrNeedTemporaryAccess() throws Exception {\n        FieldFixture fixture = new FieldFixture(\"original\", \"original\");\n        Field accessibleField = FieldFixture.class.getDeclaredField(\"accessibleValue\");\n        Field inaccessibleField = FieldFixture.class.getDeclaredField(\"inaccessibleValue\");\n        accessibleField.setAccessible(true);\n\n        ReflectionUtils.set(accessibleField, fixture, \"opened\");\n        ReflectionUtils.set(inaccessibleField, fixture, \"temporarily-opened\");\n\n        assertThat(fixture.accessibleValue).isEqualTo(\"opened\");\n        assertThat(fixture.inaccessibleValue).isEqualTo(\"temporarily-opened\");\n        assertThat(accessibleField.isAccessible()).isTrue();\n        assertThat(inaccessibleField.isAccessible()).isFalse();\n    }\n\n    public static final class ConstructorFixture {\n        private final String value;\n\n        private ConstructorFixture() {\n            this.value = \"default\";\n        }\n\n        private ConstructorFixture(String value) {\n            this.value = value;\n        }\n\n        private ConstructorFixture(int value) {\n            this.value = String.valueOf(value);\n        }\n\n        String value() {\n            return value;\n        }\n    }\n\n    public static final class MethodFixture {\n        private final String prefix;\n\n        MethodFixture(String prefix) {\n            this.prefix = prefix;\n        }\n\n        public String join(String value, int number) {\n            return prefix + ':' + value + ':' + number;\n        }\n\n        private String hidden(String value) {\n            return prefix + ':' + value;\n        }\n\n        private String hiddenWithNumber(String value, int number) {\n            return prefix + ':' + value + ':' + number;\n        }\n    }\n\n    public static final class FieldFixture {\n        private String accessibleValue;\n        private String inaccessibleValue;\n\n        FieldFixture(String accessibleValue, String inaccessibleValue) {\n            this.accessibleValue = accessibleValue;\n            this.inaccessibleValue = inaccessibleValue;\n        }\n    }\n}\n"}
