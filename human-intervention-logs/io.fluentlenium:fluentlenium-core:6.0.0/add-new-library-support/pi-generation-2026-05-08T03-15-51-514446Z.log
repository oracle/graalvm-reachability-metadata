       * "/abc/{param1}/def/{param2}"  + "/abc/param1val/def/param2val" + "param4" -&gt; null
       * "/abc{?/param1}/def/{param2}" + "/abc/param1val/def/param2val" + "param1" -&gt; "param1val"
