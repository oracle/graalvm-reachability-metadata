  public class UnshadowerTest {
      @Test
      void unshadowAllAnnotatedFieldsWritesFieldsOnPageObjects() {
          TestElement firstShadowElement = new TestElement("first-shadow-element");
          TestElement secondShadowElement = new TestElement("second-shadow-element");
          TestDriver driver = new TestDriver(List.of(firstShadowElement, secondShadowElement));
          ShadowPage page = new ShadowPage(new TestFluentControl());
  
          new Unshadower(driver, page).unshadowAllAnnotatedFields();
  
          assertThat(page.singleElement.getElement()).isSameAs(firstShadowElement);
          assertThat(page.elementList)
                  .extracting(FluentWebElement::getElement)
                  .containsExactly(firstShadowElement, secondShadowElement);
          assertThat(page.elementSet)
                  .extracting(FluentWebElement::getElement)
                  .containsExactlyInAnyOrder(firstShadowElement, secondShadowElement);
          assertThat(driver.scriptCalls()).isEqualTo(3);
      }
  
      @Test
      void unshadowAllAnnotatedFieldsWritesFieldsOnFluentWebElements() {
          TestElement firstShadowElement = new TestElement("first-component-shadow-element");
          TestElement secondShadowElement = new TestElement("second-component-shadow-element");
          TestDriver driver = new TestDriver(List.of(firstShadowElement, secondShadowElement));
          ShadowComponent component = new ShadowComponent(new TestElement("component-root"), new TestFluentControl());
  
          new Unshadower(driver, component).unshadowAllAnnotatedFields();
  
          assertThat(component.elementList)
                  .extracting(FluentWebElement::getElement)
                  .containsExactly(firstShadowElement, secondShadowElement);
          assertThat(driver.scriptCalls()).isOne();
      }
  
      public static final class ShadowPage extends FluentPage {
          @Unshadow(css = "shadow-host")
          private FluentWebElement singleElement;
  
          @Unshadow(css = "shadow-host")
          private List<FluentWebElement> elementList;
  
          @Unshadow(css = "shadow-host")
          private Set<FluentWebElement> elementSet;
  
          public ShadowPage(FluentControl control) {
              super(control);
          }
      }
  
      public static final class ShadowComponent extends FluentWebElement {
          @Unshadow(css = "shadow-host")
          private List<FluentWebElement> elementList;
  
          public ShadowComponent(WebElement element, FluentControl control) {
              super(element, control, control);
          }
      }
  
      public static final class TestFluentControl extends FluentControlImpl {
          @Override
          public FluentControl getFluentControl() {
              return this;
          }
  
          @Override
          public WebDriver getDriver() {
              return null;
          }
      }
  
      public static final class TestDriver implements WebDriver, JavascriptExecutor {
          private final TestElement documentRoot;
          private final TestSearchContext shadowRoot;
          private int scriptCalls;
  
          TestDriver(List<WebElement> shadowElements) {
              TestElement shadowHost = new TestElement("shadow-host");
              documentRoot = new TestElement("document-root", List.of(shadowHost));
              shadowRoot = new TestSearchContext(shadowElements);
          }
  
          @Override
          public WebElement findElement(By by) {
              return documentRoot;
          }
  
          @Override
          public List<WebElement> findElements(By by) {
              return List.of(documentRoot);
          }
  
          @Override
          public Object executeScript(String script, Object... args) {
              assertThat(script).isEqualTo("return arguments[0].shadowRoot");
              assertThat(args).hasSize(1);
              scriptCalls++;
              return shadowRoot;
          }
  
          @Override
          public Object executeAsyncScript(String script, Object... args) {
              throw new UnsupportedOperationException("Async scripts are not used by this test");
          }
  
          @Override
          public void get(String url) {
              throw new UnsupportedOperationException("Navigation is not used by this test");
          }
  
          @Override
          public String getCurrentUrl() {
              return "about:blank";
          }
  
          @Override
          public String getTitle() {
              return "";
          }
  
          @Override
          public String getPageSource() {
              return "";
          }
  
          @Override
          public void close() {
              // Nothing to close.
          }
  
          @Override
          public void quit() {
              // Nothing to quit.
          }
  
          @Override
          public Set<String> getWindowHandles() {
              return Collections.emptySet();
          }
  
          @Override
          public String getWindowHandle() {
              return "test-window";
          }
  
          @Override
          public WebDriver.TargetLocator switchTo() {
              throw new UnsupportedOperationException("Window switching is not used by this test");
          }
  
          @Override
          public WebDriver.Navigation navigate() {
              throw new UnsupportedOperationException("Navigation is not used by this test");
          }
  
          @Override
          public WebDriver.Options manage() {
              throw new UnsupportedOperationException("Options are not used by this test");
          }
  
          int scriptCalls() {
              return scriptCalls;
          }
      }
  
      public static final class TestSearchContext implements SearchContext {
          private final List<WebElement> elements;
  
          TestSearchContext(List<WebElement> elements) {
              this.elements = elements;
          }
  
          @Override
          public List<WebElement> findElements(By by) {
              return elements;
          }
  
          @Override
          public WebElement findElement(By by) {
              if (elements.isEmpty()) {
                  throw new NoSuchElementException("No test element available");
              }
              return elements.get(0);
          }
      }
  
      public static final class TestElement implements WebElement {
          private final String name;
