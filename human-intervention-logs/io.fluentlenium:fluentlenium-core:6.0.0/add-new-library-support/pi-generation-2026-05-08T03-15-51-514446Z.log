.stream.Collectors.toList;\n\npublic class Unshadower {\n    private static final Logger LOGGER = LoggerFactory.getLogger(Unshadower.class);\n\n    private final WebDriver webDriver;\n    private final FluentPage page;\n    private final FluentWebElement fluentWebElement;\n\n    public Unshadower(WebDriver webDriver, FluentPage page) {\n        this.webDriver = webDriver;\n        this.page = page;\n        this.fluentWebElement = null;\n    }\n\n    public Unshadower(WebDriver webDriver, FluentWebElement fluentWebElement) {\n        this.webDriver = webDriver;\n        this.page = null;\n        this.fluentWebElement = fluentWebElement;\n    }\n\n    public Object getContext() {\n        return (page != null) ? page : fluentWebElement;\n    }\n\n    public void unshadowAllAnnotatedFields() {\n        Arrays.stream(getContext().getClass().getDeclaredFields())\n                .filter(field -> field.isAnnotationPresent(Unshadow.class))\n                .forEach(this::unshadowField);\n    }\n\n    private void unshadowField(Field field) {\n        String[] cssSelectors = field.getAnnotation(Unshadow.class).css();\n        List<List<WebElement>> deepestShadowRoots = extractShadowRoots(cssSelectors);\n\n        setValue(field, convertToFluentWebElementList(deepestShadowRoots.get(deepestShadowRoots.size() - 1)));\n    }\n\n    private List<FluentWebElement> convertToFluentWebElementList(List<WebElement> lastShadowRoots) {\n        if (getContext() instanceof FluentPage) {\n            return lastShadowRoots.stream()\n                    .map(element -> new FluentWebElement(element, page.getFluentControl(), page.getFluentControl()))\n                    .collect(toList());\n        } else {\n            return lastShadowRoots.stream()\n                    .map(element -> new FluentWebElement(element, fluentWebElement.getFluentControl(), fluentWebElement.getFluentControl()))\n                    .collect(Collectors.toList());\n        }\n    }\n\n    private List<List<WebElement>> extractShadowRoots(String[] cssSelectors) {\n        WebElement domRoot = webDriver.findElement(By.xpath(\"/*\"));\n        List<List<WebElement>> currentShadowRootsInContext = singletonList(singletonList(domRoot));\n\n        if (cssSelectors.length == 1) {\n            currentShadowRootsInContext = extractElementsFromShadowRoot(currentShadowRootsInContext, cssSelectors[0], By.xpath(\"/*\"));\n        } else {\n            for (int i = 0; cssSelectors.length - 1 > i; i++) {\n                currentShadowRootsInContext = extractElementsFromShadowRoot(currentShadowRootsInContext, cssSelectors[i], By.cssSelector(cssSelectors[i + 1]));\n            }\n        }\n        return currentShadowRootsInContext;\n    }\n\n    private List<List<WebElement>> extractElementsFromShadowRoot(List<List<WebElement>> previousNodes,\n                                                                 String cssSelector, By selector) {\n        return previousNodes.stream()\n                .flatMap(Collection::stream)\n                .flatMap(webElement -> webElement.findElements(By.cssSelector(cssSelector)).stream())\n                .map(element -> unshadow(element, selector))\n                .collect(toList());\n    }\n\n    private List<WebElement> unshadow(WebElement element, By selector) {\n        JavascriptExecutor executor = (JavascriptExecutor) webDriver;\n        SearchContext shadowRoot = (SearchContext) executor.executeScript(\"return arguments[0].shadowRoot\", element);\n        return shadowRoot.findElements(selector);\n    }\n\n    private void setValue(Field field, List<FluentWebElement> elements) {\n        if (List.class.isAssignableFrom(field.getType())) {\n            setValueToField(field, elements);\n        } else if (Set.class.isAssignableFrom(field.getType())) {\n            setValueToField(field, ImmutableSet.copyOf(elements));\n        } else if (!elements.isEmpty()) {\n            setValueToField(field, elements.get(0));\n        }\n    }\n\n    private void setValueToField(Field field, Object value) {\n        boolean isAccessible = field.isAccessible();\n        try {\n            field.setAccessible(true);\n            if (getContext() instanceof FluentPage) {\n                field.set(page, value);\n            } else {\n                field.set(fluentWebElement, value);\n            }\n        } catch (IllegalAccessException e) {\n            LOGGER.error(\"Couldn't set value to field\", e);\n        } finally {\n            field.setAccessible(isAccessible);\n        }\n    }\n\n}\n\n"}], "isError": false, "timestamp": 1778210006823}, {"role": "toolResult", "toolCallId": "call_TcIrGNwfJ51GLGGC6eXd2dVb|fc_044206c8f8b7f8010169fd54d69c0c819799301c7a18b18adf", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_fluentlenium.fluentlenium_core;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport io.fluentlenium.core.conditions.Negation;\nimport io.fluentlenium.core.conditions.message.Message;\nimport io.fluentlenium.core.conditions.message.MessageBuilderCall;\nimport io.fluentlenium.core.conditions.message.MessageContext;\nimport io.fluentlenium.core.conditions.message.MessageProxy;\nimport io.fluentlenium.core.conditions.message.NotMessage;\nimport java.util.ArrayList;\nimport java.util.List;\nimport org.junit.jupiter.api.Test;\n\npublic class MessageProxyTest {\n    @Test\n    void builderWithContextCreatesProxyThatRecordsAnnotatedCalls() {\n        MessageCondition condition = MessageProxy.builder(MessageCondition.class, \"field name\");\n\n        boolean result = condition.equalTo(\"value\");\n\n        assertThat(result).isFalse();\n        assertThat(MessageProxy.message(condition)).isEqualTo(\"field name is not equal to value\");\n    }\n\n    @Test\n    void builderWithCallsCreatesProxyUsingExistingCallStack() {\n        List<MessageBuilderCall> calls = new ArrayList<>();\n        MessageBuilderCall initialCall = new MessageBuilderCall();\n        initialCall.setContext(\"existing context\");\n        calls.add(initialCall);\n        MessageCondition condition = MessageProxy.builder(MessageCondition.class, calls);\n\n        MessageCondition contextualCondition = condition.withElementContext();\n        contextualCondition.equalTo(\"item\");\n\n        assertThat(MessageProxy.message(contextualCondition))\n                .isEqualTo(\"existing context element is not equal to item\");\n        assertThat(calls).hasSize(3);\n    }\n\n    @Test\n    void wrapWithContextCreatesProxyThatInvokesOriginalInstance() {\n        RecordingCondition instance = new RecordingCondition(true);\n        MessageCondition condition = MessageProxy.wrap(MessageCondition.class, instance, \"wrapped field\");\n\n        boolean result = condition.equalTo(\"actual\");\n\n        assertThat(result).isTrue();\n        assertThat(instance.comparedValue()).isEqualTo(\"actual\");\n        assertThat(MessageProxy.message(condition)).isEqualTo(\"wrapped field is not equal to actual\");\n    }\n\n    @Test\n    void wrapWithCallsCreatesProxyThatSharesRecordedCallsWithoutDelegatingToInstance() {\n        List<MessageBuilderCall> calls = new ArrayList<>();\n        MessageBuilderCall initialCall = new MessageBuilderCall();\n        initialCall.setContext(\"shared context\");\n        calls.add(initialCall);\n        RecordingCondition instance = new RecordingCondition(false);\n        MessageCondition condition = MessageProxy.wrap(MessageCondition.class, instance, calls);\n\n        MessageCondition negatedCondition = condition.not();\n        boolean result = negatedCondition.equalTo(\"other\");\n\n        assertThat(result).isFalse();\n        assertThat(instance.notCalls()).isZero();\n        assertThat(instance.comparedValue()).isNull();\n        assertThat(MessageProxy.message(negatedCondition)).isEqualTo(\"shared context is equal to other\");\n        assertThat(calls).hasSize(3);\n    }\n\n    public interface MessageCondition {\n        @MessageContext(\"element\")\n        MessageCondition withElementContext();\n\n        @Negation\n        MessageCondition not();\n\n        @Message(\"is equal to {0}\")\n        @NotMessage(\"is not equal to {0}\")\n        boolean equalTo(String value);\n    }\n\n    public static final class RecordingCondition implements MessageCondition {\n        private final boolean comparisonResult;\n        private String comparedValue;\n        private int notCalls;\n\n        RecordingCondition(boolean comparisonResult) {\n            this.comparisonResult = comparisonResult;\n        }\n\n        @Override\n        public MessageCondition withElementContext() {\n            return this;\n        }\n\n        @Override\n        public MessageCondition not() {\n            notCalls++;\n            return this;\n        }\n\n        @Override\n        public boolean equalTo(String value) {\n            comparedValue = value;\n            return comparisonResult;\n        }\n\n        String comparedValue() {\n            return comparedValue;\n        }\n\n        int notCalls() {\n            return notCalls;\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778210006823}, {"role": "toolResult", "toolCallId": "call_wFXzb9qhaquMNWdc4sy3fEND|fc_044206c8f8b7f8010169fd54d69c108197816b282dc777114e", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_fluentlenium.fluentlenium_core;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport io.fluentlenium.utils.ReflectionUtils;\nimport java.lang.reflect.Constructor;\nimport java.lang.reflect.Field;\nimport java.lang.reflect.Method;\nimport org.junit.jupiter.api.Test;\n\n@SuppressWarnings(\"deprecation\")\npublic class ReflectionUtilsTest {\n    @Test\n    void resolvesDeclaredConstructorsByDefaultExactAndAssignableArgumentTypes() throws Exception {\n        Constructor<ConstructorFixture> defaultConstructor = ReflectionUtils.getConstructor(ConstructorFixture.class);\n        Constructor<ConstructorFixture> exactConstructor = ReflectionUtils.getConstructor(ConstructorFixture.class,\n                String.class);\n        Constructor<ConstructorFixture> assignableConstructor = ReflectionUtils.getConstructor(ConstructorFixture.class,\n                Integer.class);\n\n        assertThat(defaultConstructor.getParameterTypes()).isEmpty();\n        assertThat(exactConstructor.getParameterTypes()).containsExactly(String.class);\n        assertThat(assignableConstructor.getParameterTypes()).containsExactly(int.class);\n    }\n\n    @Test\n    void createsInstancesAfterTemporarilyOpeningMatchingConstructors() throws Exception {\n        ConstructorFixture defaultFixture = ReflectionUtils.newInstance(ConstructorFixture.class);\n        ConstructorFixture exactFixture = ReflectionUtils.newInstance(ConstructorFixture.class, \"configured\");\n        ConstructorFixture assignableFixture = ReflectionUtils.newInstance(ConstructorFixture.class, 7);\n\n        assertThat(defaultFixture.value()).isEqualTo(\"default\");\n        assertThat(exactFixture.value()).isEqualTo(\"configured\");\n        assertThat(assignableFixture.value()).isEqualTo(\"7\");\n    }\n\n    @Test\n    void createsInstancesWithPreviouslyOpenedConstructors() throws Exception {\n        Constructor<PublicConstructorFixture> defaultConstructor = ReflectionUtils.getConstructor(\n                PublicConstructorFixture.class);\n        Constructor<PublicConstructorFixture> namedConstructor = ReflectionUtils.getConstructor(\n                PublicConstructorFixture.class, String.class);\n        defaultConstructor.setAccessible(true);\n        namedConstructor.setAccessible(true);\n        for (Constructor<?> constructor : PublicConstructorFixture.class.getDeclaredConstructors()) {\n            constructor.setAccessible(true);\n        }\n\n        PublicConstructorFixture defaultFixture = ReflectionUtils.newInstance(PublicConstructorFixture.class);\n        PublicConstructorFixture namedFixture = ReflectionUtils.newInstance(PublicConstructorFixture.class, \"public\");\n\n        assertThat(defaultFixture.value()).isEqualTo(\"public-default\");\n        assertThat(namedFixture.value()).isEqualTo(\"public\");\n    }\n\n    @Test\n    void createsInstancesWithPreviouslyOpenedAssignableConstructors() throws Exception {\n        Constructor<PreparedConstructorFixture> constructor = ReflectionUtils.getConstructor(\n                PreparedConstructorFixture.class, Integer.class);\n        constructor.setAccessible(true);\n        for (Constructor<?> declaredConstructor : PreparedConstructorFixture.class.getDeclaredConstructors()) {\n            declaredConstructor.setAccessible(true);\n        }\n\n        PreparedConstructorFixture fixture = ReflectionUtils.newInstance(PreparedConstructorFixture.class, 42);\n\n        assertThat(fixture.value()).isEqualTo(\"42\");\n    }\n\n    @Test\n    void getsPublicMethodsFromDeclaringClasses() {\n        Method method = ReflectionUtils.getMethod(MethodFixture.class, \"join\", String.class, int.class);\n\n        assertThat(method.getReturnType()).isEqualTo(String.class);\n        assertThat(method.getParameterTypes()).containsExactly(String.class, int.class);\n    }\n\n    @Test\n    void invokesMethodsThatAreAlreadyAccessibleOrNeedTemporaryAccess() throws Exception {\n        MethodFixture fixture = new MethodFixture(\"method\");\n        Method accessibleMethod = MethodFixture.class.getDeclaredMethod(\"hidden\", String.class);\n        Method inaccessibleMethod = MethodFixture.class.getDeclaredMethod(\"hiddenWithNumber\", String.class, int.class);\n        accessibleMethod.setAccessible(true);\n\n        Object accessibleResult = ReflectionUtils.invoke(accessibleMethod, fixture, \"open\");\n        Object inaccessibleResult = ReflectionUtils.invoke(inaccessibleMethod, fixture, \"closed\", 5);\n\n        assertThat(accessibleResult).isEqualTo(\"method:open\");\n        assertThat(inaccessibleResult).isEqualTo(\"method:closed:5\");\n        assertThat(accessibleMethod.isAccessible()).isTrue();\n        assertThat(inaccessibleMethod.isAccessible()).isFalse();\n    }\n\n    @Test\n    void readsFieldsThatAreAlreadyAccessibleOrNeedTemporaryAccess() throws Exception {\n        FieldFixture fixture = new FieldFixture(\"visible\", \"hidden\");\n        Field accessibleField = FieldFixture.class.getDeclaredField(\"accessibleValue\");\n        Field inaccessibleField = FieldFixture.class.getDeclaredField(\"inaccessibleValue\");\n        accessibleField.setAccessible(true);\n\n        Object accessibleValue = ReflectionUtils.get(accessibleField, fixture);\n        Object inaccessibleValue = ReflectionUtils.get(inaccessibleField, fixture);\n\n        assertThat(accessibleValue).isEqualTo(\"visible\");\n        assertThat(inaccessibleValue).isEqualTo(\"hidden\");\n        assertThat(accessibleField.isAccessible()).isTrue();\n        assertThat(inaccessibleField.isAccessible()).isFalse();\n    }\n\n    @Test\n    void writesFieldsThatAreAlreadyAccessibleOrNeedTemporaryAccess() throws Exception {\n        FieldFixture fixture = new FieldFixture(\"original\", \"original\");\n        Field accessibleField = FieldFixture.class.getDeclaredField(\"accessibleValue\");\n        Field inaccessibleField = FieldFixture.class.getDeclaredField(\"inaccessibleValue\");\n        accessibleField.setAccessible(true);\n\n        ReflectionUtils.set(accessibleField, fixture, \"opened\");\n        ReflectionUtils.set(inaccessibleField, fixture, \"temporarily-opened\");\n\n        assertThat(fixture.accessibleValue).isEqualTo(\"opened\");\n        assertThat(fixture.inaccessibleValue).isEqualTo(\"temporarily-opened\");\n        assertThat(accessibleField.isAccessible()).isTrue();\n        assertThat(inaccessibleField.isAccessible()).isFalse();\n    }\n\n    public static final class ConstructorFixture {\n        private final String value;\n\n        private ConstructorFixture() {\n            this.value = \"default\";\n        }\n\n        private ConstructorFixture(String value) {\n            this.value = value;\n        }\n\n        private ConstructorFixture(int value) {\n            this.value = String.valueOf(value);\n        }\n\n        String value() {\n            return value;\n        }\n    }\n\n    public static final class PublicConstructorFixture {\n        private final String value;\n\n        public PublicConstructorFixture() {\n            this.value = \"public-default\";\n        }\n\n        public PublicConstructorFixture(String value) {\n            this.value = value;\n        }\n\n        String value() {\n            return value;\n        }\n    }\n\n    public static final class PreparedConstructorFixture {\n        private final String value;\n\n        private PreparedConstructorFixture(int value) {\n            this.value = String.valueOf(value);\n        }\n\n        String value() {\n            return value;\n        }\n    }\n\n    public static final class MethodFixture {\n        private final String prefix;\n\n        MethodFixture(String prefix) {\n            this.prefix = prefix;\n        }\n\n        public String join(String value, int number) {\n            return prefix + ':' + value + ':' + number;\n        }\n\n        private String hidden(String value) {\n            return prefix + ':' + value;\n        }\n\n        private String hiddenWithNumber(String value, int number) {\n            return prefix + ':' + value + ':' + number;\n        }\n    }\n\n    public static final class FieldFixture {\n        private String accessibleVa