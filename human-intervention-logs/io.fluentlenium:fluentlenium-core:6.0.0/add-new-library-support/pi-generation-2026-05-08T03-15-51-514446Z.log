  package io_fluentlenium.fluentlenium_core;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import io.fluentlenium.core.FluentControl;
  import io.fluentlenium.core.FluentControlImpl;
  import io.fluentlenium.core.conditions.Conditions;
  import io.fluentlenium.core.conditions.Negation;
  import io.fluentlenium.core.conditions.message.Message;
  import io.fluentlenium.core.conditions.message.MessageContext;
  import io.fluentlenium.core.conditions.wait.WaitConditionProxy;
  import io.fluentlenium.core.wait.FluentWait;
  import java.time.Duration;
  import java.util.function.Predicate;
  import org.junit.jupiter.api.Test;
  import org.openqa.selenium.WebDriver;
  
  public class WaitConditionInvocationHandlerTest {
      @Test
      void childConditionProxyWaitsForBooleanCondition() {
          RecordingParentCondition parentCondition = new RecordingParentCondition("actual-value");
          FluentWait wait = new FluentWait(new TestFluentControl())
                  .atMost(Duration.ofSeconds(1))
                  .pollingEvery(Duration.ofMillis(10));
          ParentCondition waitCondition = WaitConditionProxy.custom(
                  ParentCondition.class,
                  wait,
                  "field",
                  () -> parentCondition);
  
          boolean result = waitCondition.child("name").equalTo("actual-value");
  
          assertThat(result).isTrue();
          assertThat(parentCondition.childNames()).isEqualTo("name");
          assertThat(parentCondition.childCondition().comparedValue()).isEqualTo("actual-value");
      }
  
      public interface ParentCondition extends Conditions<Object> {
          @MessageContext("child {0}")
          ChildCondition child(String name);
  
          @Override
          @Negation
          ParentCondition not();
      }
  
      public interface ChildCondition extends Conditions<String> {
          @Message("is equal to {0}")
          boolean equalTo(String expectedValue);
  
          @Override
          @Negation
          ChildCondition not();
      }
  
      public static final class RecordingParentCondition implements ParentCondition {
          private final RecordingChildCondition childCondition;
          private String childNames;
  
          public RecordingParentCondition(String actualValue) {
              this.childCondition = new RecordingChildCondition(actualValue);
          }
  
          @Override
          public ChildCondition child(String name) {
              childNames = name;
              return childCondition;
          }
  
          @Override
          public ParentCondition not() {
              childCondition.negate();
              return this;
          }
  
          @Override
          public boolean verify(Predicate<Object> predicate) {
              return predicate.test(this);
          }
  
          String childNames() {
              return childNames;
          }
  
          RecordingChildCondition childCondition() {
              return childCondition;
          }
      }
  
      public static final class RecordingChildCondition implements ChildCondition {
          private final String actualValue;
          private boolean negated;
          private String comparedValue;
  
          public RecordingChildCondition(String actualValue) {
              this.actualValue = actualValue;
          }
  
          @Override
          public boolean equalTo(String expectedValue) {
              comparedValue = expectedValue;
              boolean matches = actualValue.equals(expectedValue);
              return negated != matches;
          }
  
          @Override
          public ChildCondition not() {
              negate();
              return this;
          }
  
          @Override
          public boolean verify(Predicate<String> predicate) {
              return predicate.test(actualValue);
          }
  
          void negate() {
              negated = !negated;
          }
  
          String comparedValue() {
              return comparedValue;
          }
      }
  
      public static final class TestFluentControl extends FluentControlImpl {
          @Override
          public FluentControl getFluentControl() {
              return this;
          }
  
          @Override
          public WebDriver getDriver() {
              return null;
          }
      }
  }
