      ParentCondition.class,\n                wait,\n                \"field\",\n                () -> parentCondition);\n\n        boolean result = waitCondition.child(\"name\").equalTo(\"actual-value\");\n\n        assertThat(result).isTrue();\n        assertThat(parentCondition.childNames()).isEqualTo(\"name\");\n        assertThat(parentCondition.childCondition().comparedValue()).isEqualTo(\"actual-value\");\n    }\n\n    public interface ParentCondition extends Conditions<Object> {\n        @MessageContext(\"child {0}\")\n        ChildCondition child(String name);\n\n        @Override\n        @Negation\n        ParentCondition not();\n    }\n\n    public interface ChildCondition extends Conditions<String> {\n        @Message(\"is equal to {0}\")\n        boolean equalTo(String expectedValue);\n\n        @Override\n        @Negation\n        ChildCondition not();\n    }\n\n    public static final class RecordingParentCondition implements ParentCondition {\n        private final RecordingChildCondition childCondition;\n        private String childNames;\n\n        public RecordingParentCondition(String actualValue) {\n            this.childCondition = new RecordingChildCondition(actualValue);\n        }\n\n        @Override\n        public ChildCondition child(String name) {\n            childNames = name;\n            return childCondition;\n        }\n\n        @Override\n        public ParentCondition not() {\n            childCondition.negate();\n            return this;\n        }\n\n        @Override\n        public boolean verify(Predicate<Object> predicate) {\n            return predicate.test(this);\n        }\n\n        String childNames() {\n            return childNames;\n        }\n\n        RecordingChildCondition childCondition() {\n            return childCondition;\n        }\n    }\n\n    public static final class RecordingChildCondition implements ChildCondition {\n        private final String actualValue;\n        private boolean negated;\n  