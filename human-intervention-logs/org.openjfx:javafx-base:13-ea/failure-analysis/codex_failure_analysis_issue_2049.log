ns.assertThat;\\n\\nimport com.sun.javafx.property.JavaBeanAccessHelper;\\nimport java.beans.PropertyChangeListener;\\nimport java.beans.PropertyChangeSupport;\\nimport java.util.ArrayList;\\nimport java.util.List;\\nimport javafx.beans.property.adapter.ReadOnlyJavaBeanObjectProperty;\\nimport org.junit.jupiter.api.Test;\\n\\npublic class JavaBeanAccessHelperTest {\\n\\n    @Test\\n    void createReadOnlyJavaBeanPropertyUsesTheQuickAccessorPath() throws Exception {\\n        QuickAccessBean bean = new QuickAccessBean(\\\"before\\\");\\n        @SuppressWarnings(\\\"unchecked\\\")\\n        ReadOnlyJavaBeanObjectProperty<String> property =\\n                (ReadOnlyJavaBeanObjectProperty<String>) JavaBeanAccessHelper.createReadOnlyJavaBeanProperty(bean, \\\"value\\\");\\n        List<String> observedValues = new ArrayList<>();\\n        property.addListener((observable, oldValue, newValue) -> observedValues.add(oldValue + \\\"->\\\" + newValue));\\n\\n        try {\\n            assertThat(property.getBean()).isSameAs(bean);\\n            assertThat(property.getName()).isEqualTo(\\\"value\\\");\\n            assertThat(property.get()).isEqualTo(\\\"before\\\");\\n            assertThat(bean.getterCalls()).isGreaterThanOrEqualTo(1);\\n            assertThat(bean.addedListeners).hasSize(1);\\n            assertThat(bean.removedListeners).isEmpty();\\n\\n            bean.setValue(\\\"after\\\");\\n\\n            assertThat(property.get()).isEqualTo(\\\"after\\\");\\n            assertThat(observedValues).containsExactly(\\\"before->after\\\");\\n        } finally {\\n            property.dispose();\\n        }\\n\\n        assertThat(bean.removedListeners).containsExactly(bean.addedListeners.get(0));\\n    }\\n\\n    public static final class QuickAccessBean {\\n        private final List<PropertyChangeListener> addedListeners = new ArrayList<>();\\n        private final List<PropertyChangeListener> removedListeners = new ArrayList<>();\\n        private final PropertyChangeSupport propertyChangeSupport = new PropertyChangeSupport(this);\\n        private String value;\\n        private int getterCalls;\\n\\n        public QuickAccessBean(String value) {\\n            this.value = value;\\n        }\\n\\n        public String getValue() {\\n            getterCalls++;\\n            return value;\\n        }\\n\\n        public void setValue(String value) {\\n            String oldValue = this.value;\\n            this.value = value;\\n            propertyChangeSupport.firePropertyChange(\\\"value\\\", oldValue, value);\\n        }\\n\\n        public void addPropertyChangeListener(PropertyChangeListener listener) {\\n            addedListeners.add(listener);\\n            propertyChangeSupport.addPropertyChangeListener(listener);\\n        }\\n\\n        public void removePropertyChangeListener(PropertyChangeListener listener) {\\n            removedListeners.add(listener);\\n            propertyChangeSupport.removePropertyChangeListener(listener);\\n        }\\n\\n        public int getterCalls() {\\n            return getterCalls;\\n        }\\n    }\\n}\\n\"}}], \"api\": \"openai-responses\", \"provider\": \"OCA\", \"model\": \"oca/gpt-5.4\", \"usage\": {\"input\": 3918, \"output\": 1752, \"cacheRead\": 35712, \"cacheWrite\": 0, \"totalTokens\": 41382, \"cost\": {\"input\": 0, \"output\": 0, \"cacheRead\": 0, \"cacheWrite\": 0, \"total\": 0}}, \"stopReason\": \"toolUse\", \"timestamp\": 1777379894525, \"responseId\": \"resp_064a42178e280c330169f0aa36fae4819fa601233da96ebe00\"}}\n4551:[recv] {\"type\": \"turn_end\", \"message\": {\"role\": \"assistant\", \"content\": [{\"type\": \"thinking\", \"thinking\": \"\", \"thinkingSignature\": \"{\\\"id\\\":\\\"rs_064a42178e280c330169f0aa379f80819fb41a1cbf7e66b119\\\",\\\"type\\\":\\\"reasoning\\\",\\\"encrypted_content\\\":\\\"gAAAAABp8KpE9P3dahzS-ZzLBTI9KoMzCix6o8vlrGyZhcB4iuscwRsXsGXa4flkAVhjLIv9szTBmFtSmRyab-wKdxiZmDf58T7q9XoUQok4_FLLGMIgNbR_ot0sI8wGFaH-moVUmrAViJKxzmBMWCrkW4RrQ5HLoF