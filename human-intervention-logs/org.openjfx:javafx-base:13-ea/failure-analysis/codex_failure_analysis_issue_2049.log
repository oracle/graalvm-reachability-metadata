t/TEST-org_openjfx.javafx_base.Javafx_baseTest.xml\\ntests/src/org.openjfx/javafx-base/13-ea/build/test-results/test/TEST-org_openjfx.javafx_base.MethodUtilTest.xml\\ntests/src/org.openjfx/javafx-base/13-ea/build/test-results/test/TEST-org_openjfx.javafx_base.PropertyDescriptorTest.xml\\ntests/src/org.openjfx/javafx-base/13-ea/build/test-results/test/TEST-org_openjfx.javafx_base.PropertyReferenceTest.xml\\ntests/src/org.openjfx/javafx-base/13-ea/build/test-results/test/TEST-org_openjfx.javafx_base.PulseLoggerTest.xml\\ntests/src/org.openjfx/javafx-base/13-ea/build/test-results/test/TEST-org_openjfx.javafx_base.ReadOnlyJavaBeanPropertyBuilderHelperTest.xml\\ntests/src/org.openjfx/javafx-base/13-ea/build/test-results/test/TEST-org_openjfx.javafx_base.ReadOnlyPropertyDescriptorTest.xml\\ntests/src/org.openjfx/javafx-base/13-ea/build/test-results/test/TEST-org_openjfx.javafx_base.SortHelperTest.xml\\ntests/src/org.openjfx/javafx-base/13-ea/build/tmp/compileTestJava/previous-compilation-data.bin\\ntests/src/org.openjfx/javafx-base/13-ea/build/tmp/jar/MANIFEST.MF\\ntests/src/org.openjfx/javafx-base/13-ea/.gitignore\\ntests/src/org.openjfx/javafx-base/13-ea/.gradle/9.1.0/checksums/checksums.lock\\ntests/src/org.openjfx/javafx-base/13-ea/.gradle/9.1.0/checksums/md5-checksums.bin\\ntests/src/org.openjfx/javafx-base/13-ea/.gradle/9.1.0/checksums/sha1-checksums.bin\\ntests/src/org.openjfx/javafx-base/13-ea/.gradle/9.1.0/executionHistory/executionHistory.bin\\ntests/src/org.openjfx/javafx-base/13-ea/.gradle/9.1.0/executionHistory/executionHistory.lock\\ntests/src/org.openjfx/javafx-base/13-ea/.gradle/9.1.0/expanded/expanded.lock\\ntests/src/org.openjfx/javafx-base/13-ea/.gradle/9.1.0/fileChanges/last-build.bin\\ntests/src/org.openjfx/javafx-base/13-ea/.gradle/9.1.0/fileHashes/fileHashes.bin\\ntests/src/org.openjfx/javafx-base/13-ea/.gradle/9.1.0/fileHashes/fileHashes.lock\\ntests/src/org.openjfx/javafx-base/13-ea/.gradle/9.1.0/fileHashes/resourceHashesCache.bin\\ntests/src/org.