  package org_openjfx.javafx_base;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import com.sun.javafx.reflect.ConstructorUtil;
  import java.lang.reflect.Constructor;
  import java.util.Arrays;
  import java.util.List;
  import org.junit.jupiter.api.Test;
  
  public class ConstructorUtilTest {
  
      @Test
      void getConstructorFindsMatchingPublicConstructor() throws Exception {
          Constructor<?> constructor = ConstructorUtil.getConstructor(
                  ConstructorUtilSample.class,
                  new Class<?>[] {String.class, int.class});
  
          assertThat(constructor.getDeclaringClass()).isEqualTo(ConstructorUtilSample.class);
          assertThat(constructor.getParameterTypes()).containsExactly(String.class, int.class);
      }
  
      @Test
      void getConstructorsReturnsAllPublicConstructors() {
          Constructor<?>[] constructors = ConstructorUtil.getConstructors(ConstructorUtilSample.class);
  
          List<List<Class<?>>> parameterTypes = Arrays.stream(constructors)
                  .map(Constructor::getParameterTypes)
                  .map(Arrays::asList)
                  .toList();
  
          assertThat(parameterTypes)
                  .containsExactlyInAnyOrder(
                          List.of(),
                          List.of(String.class),
                          List.of(String.class, int.class));
      }
  }
  
  final class ConstructorUtilSample {
  
      public ConstructorUtilSample() {}
  
      public ConstructorUtilSample(String name) {}
  
      public ConstructorUtilSample(String name, int priority) {}
  
      ConstructorUtilSample(int hidden) {}
  }
