  package org_openjfx.javafx_base;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.beans.PropertyChangeListener;
  import java.beans.PropertyChangeSupport;
  import java.util.ArrayList;
  import java.util.List;
  import javafx.beans.property.adapter.ReadOnlyJavaBeanBooleanProperty;
  import javafx.beans.property.adapter.ReadOnlyJavaBeanBooleanPropertyBuilder;
  import javafx.beans.property.adapter.ReadOnlyJavaBeanStringProperty;
  import javafx.beans.property.adapter.ReadOnlyJavaBeanStringPropertyBuilder;
  import org.junit.jupiter.api.Test;
  
  public class ReadOnlyJavaBeanPropertyBuilderHelperTest {
  
      @Test
      void usesAnExplicitGetterNameWhenConfigured() throws Exception {
          ExplicitGetterBean bean = new ExplicitGetterBean("before");
          ReadOnlyJavaBeanStringProperty property = ReadOnlyJavaBeanStringPropertyBuilder.create()
                  .bean(bean)
                  .name("value")
                  .getter("readValue")
                  .build();
          List<String> observedValues = new ArrayList<>();
          property.addListener((observable, oldValue, newValue) -> observedValues.add(oldValue + "->" + newValue));
  
          try {
              assertThat(property.get()).isEqualTo("before");
              assertThat(bean.getterCalls()).isGreaterThanOrEqualTo(1);
              assertThat(bean.addedListeners).hasSize(1);
              assertThat(bean.removedListeners).isEmpty();
  
              bean.setValue("after");
  
              assertThat(property.get()).isEqualTo("after");
              assertThat(observedValues).containsExactly("before->after");
          } finally {
              property.dispose();
          }
  
          assertThat(bean.removedListeners).containsExactly(bean.addedListeners.get(0));
      }
  
      @Test
      void fallsBackToBooleanIsGetterWhenNoGetAccessorExists() throws Exception {
          BooleanReadOnlyBean bean = new BooleanReadOnlyBean(true);
          ReadOnlyJavaBeanBooleanProperty property = ReadOnlyJavaBeanBooleanPropertyBuilder.create()
                  .bean(bean)
                  .name("active")
                  .build();
          List<String> observedValues = new ArrayList<>();
          property.addListener((observable, oldValue, newValue) -> observedValues.add(oldValue + "->" + newValue));
  
          try {
              assertThat(property.get()).isTrue();
              assertThat(bean.getterCalls()).isGreaterThanOrEqualTo(1);
              assertThat(bean.addedListeners).hasSize(1);
              assertThat(bean.removedListeners).isEmpty();
  
              bean.setActive(false);
  
              assertThat(property.get()).isFalse();
              assertThat(observedValues).containsExactly("true->false");
          } finally {
              property.dispose();
          }
  
          assertThat(bean.removedListeners).containsExactly(bean.addedListeners.get(0));
      }
  
      public static final class ExplicitGetterBean {
          private final List<PropertyChangeListener> addedListeners = new ArrayList<>();
          private final List<PropertyChangeListener> removedListeners = new ArrayList<>();
          private final PropertyChangeSupport propertyChangeSupport = new PropertyChangeSupport(this);
          private String value;
          private int getterCalls;
  
          public ExplicitGetterBean(String value) {
              this.value = value;
          }
  
          public String readValue() {
              getterCalls++;
              return value;
          }
  
          public void setValue(String value) {
              String oldValue = this.value;
              this.value = value;
              propertyChangeSupport.firePropertyChange("value", oldValue, value);
          }
  
          public void addPropertyChangeListener(PropertyChangeListener listener) {
              addedListeners.add(listener);
              propertyChangeSupport.addPropertyChangeListener(listener);
          }
  
          public void removePropertyChangeListener(PropertyChangeListener listener) {
              removedListeners.add(listener);
              propertyChangeSupport.removePropertyChangeListener(listener);
          }
  
          public int getterCalls() {
              return getterCalls;
          }
      }
  
      public static final class BooleanReadOnlyBean {
          private final List<PropertyChangeListener> addedListeners = new ArrayList<>();
          private final List<PropertyChangeListener> removedListeners = new ArrayList<>();
          private final PropertyChangeSupport propertyChangeSupport = new PropertyChangeSupport(this);
          private boolean active;
          private int getterCalls;
  
          public BooleanReadOnlyBean(boolean active) {
              this.active = active;
          }
  
          public boolean isActive() {
              getterCalls++;
              return active;
          }
  
          public void setActive(boolean active) {
              boolean oldValue = this.active;
              this.active = active;
              propertyChangeSupport.firePropertyChange("active", oldValue, active);
          }
  
          public void addPropertyChangeListener(PropertyChangeListener listener) {
              addedListeners.add(listener);
              propertyChangeSupport.addPropertyChangeListener(listener);
          }
  
          public void removePropertyChangeListener(PropertyChangeListener listener) {
              removedListeners.add(listener);
              propertyChangeSupport.removePropertyChangeListener(listener);
          }
  
          public int getterCalls() {
              return getterCalls;
          }
      }
  }
