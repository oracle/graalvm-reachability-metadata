pe()).isEqualTo(String.class);\n        assertThat(reference.isReadable()).isFalse();\n        assertThat(reference.isWritable()).isTrue();\n        assertThat(reference.hasProperty()).isFalse();\n    }\n\n    public static final class ConventionalPropertyBean {\n        private final StringProperty value = new SimpleStringProperty(this, \"value\", \"before\");\n\n        public String getValue() {\n            return value.get();\n        }\n\n        public void setValue(String value) {\n            this.value.set(value);\n        }\n\n        public StringProperty valueProperty() {\n            return value;\n        }\n    }\n\n    public static final class BooleanPropertyBean {\n        private final BooleanProperty active = new SimpleBooleanProperty(this, \"active\", true);\n\n        public boolean isActive() {\n            return active.get();\n        }\n\n        public void setActive(boolean active) {\n            this.active.set(active);\n        }\n\n        public BooleanProperty activeProperty() {\n            return active;\n        }\n    }\n\n    public static final class SetterOnlyPropertyBean {\n        private String value;\n\n        public void setValue(String value) {\n            this.value = value;\n        }\n\n        public String currentValue() {\n            return value;\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777380047840}, {"role": "toolResult", "toolCallId": "call_FAQSR1su9KdHi0YzjdDFx0I1|fc_08cc2260157aeb9a0169f0aacf8268819ea1b04da68f364634", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_openjfx.javafx_base;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport javafx.beans.property.adapter.JavaBeanBooleanProperty;\nimport javafx.beans.property.adapter.JavaBeanBooleanPropertyBuilder;\nimport javafx.beans.property.adapter.JavaBeanStringProperty;\nimport javafx.beans.property.adapter.JavaBeanStringPropertyBuilder;\nimport org.junit.jupiter.api.Test;\n\npublic class JavaBeanPropertyBuilderHelperTest {\n\n    @Test\n    void usesDefaultGetterAndSetterNamesDerivedFromThePropertyName() throws Exception {\n        DefaultAccessorBean bean = new DefaultAccessorBean(\"before\");\n        JavaBeanStringProperty property = JavaBeanStringPropertyBuilder.create()\n                .bean(bean)\n                .name(\"value\")\n                .build();\n\n        try {\n            assertThat(property.get()).isEqualTo(\"before\");\n\n            property.set(\"after\");\n\n            assertThat(bean.valueSnapshot()).isEqualTo(\"after\");\n            assertThat(bean.getterCalls()).isGreaterThanOrEqualTo(1);\n            assertThat(bean.setterCalls()).isEqualTo(1);\n        } finally {\n            property.dispose();\n        }\n    }\n\n    @Test\n    void usesBooleanIsGetterNamesDerivedFromThePropertyName() throws Exception {\n        BooleanAccessorBean bean = new BooleanAccessorBean(true);\n        JavaBeanBooleanProperty property = JavaBeanBooleanPropertyBuilder.create()\n                .bean(bean)\n                .name(\"active\")\n                .build();\n\n        try {\n            assertThat(property.get()).isTrue();\n\n            property.set(false);\n\n            assertThat(bean.activeSnapshot()).isFalse();\n            assertThat(bean.getterCalls()).isGreaterThanOrEqualTo(1);\n            assertThat(bean.setterCalls()).isEqualTo(1);\n        } finally {\n            property.dispose();\n        }\n    }\n\n    @Test\n    void usesAnExplicitGetterNameWhenConfigured() throws Exception {\n        ExplicitGetterBean bean = new ExplicitGetterBean(\"before\");\n        JavaBeanStringProperty property = JavaBeanStringPropertyBuilder.create()\n                .bean(bean)\n                .name(\"value\")\n                .getter(\"readValue\")\n                .build();\n\n        try {\n            assertThat(property.get()).isEqualTo(\"before\");\n\n            property.set(\"after\");\n\n            assertThat(bean.valueSnapshot()).isEqualTo(\"after\");\n            assertThat(bean.getterCalls()).isGreaterThanOrEqualTo(1);\n            assertThat(bean.setterCalls()).isEqualTo(1);\n        } finally {\n            property.dispose();\n        }\n    }\n\n    @Test\n    void usesAnExplicitSetterNameWhenConfigured() throws Exception {\n        ExplicitSetterBean bean = new ExplicitSetterBean(\"before\");\n        JavaBeanStringProperty property = JavaBeanStringPropertyBuilder.create()\n                .bean(bean)\n                .name(\"value\")\n                .setter(\"writeValue\")\n                .build();\n\n        try {\n            assertThat(property.get()).isEqualTo(\"before\");\n\n            property.set(\"after\");\n\n            assertThat(bean.valueSnapshot()).isEqualTo(\"after\");\n            assertThat(bean.getterCalls()).isGreaterThanOrEqualTo(1);\n            assertThat(bean.setterCalls()).isEqualTo(1);\n        } finally {\n            property.dispose();\n        }\n    }\n\n    public static final class DefaultAccessorBean {\n        private String value;\n        private int getterCalls;\n        private int setterCalls;\n\n        public DefaultAccessorBean(String value) {\n            this.value = value;\n        }\n\n        public String getValue() {\n            getterCalls++;\n            return value;\n        }\n\n        public void setValue(String value) {\n            setterCalls++;\n            this.value = value;\n        }\n\n        public String valueSnapshot() {\n            return value;\n        }\n\n        public int getterCalls() {\n            return getterCalls;\n        }\n\n        public int setterCalls() {\n            return setterCalls;\n        }\n    }\n\n    public static final class BooleanAccessorBean {\n        private boolean active;\n        private int getterCalls;\n        private int setterCalls;\n\n        public BooleanAccessorBean(boolean active) {\n            this.active = active;\n        }\n\n        public boolean isActive() {\n            getterCalls++;\n            return active;\n        }\n\n        public void setActive(boolean active) {\n            setterCalls++;\n            this.active = active;\n        }\n\n        public boolean activeSnapshot() {\n            return active;\n        }\n\n        public int getterCalls() {\n            return getterCalls;\n        }\n\n        public int setterCalls() {\n            return setterCalls;\n        }\n    }\n\n    public static final class ExplicitGetterBean {\n        private String value;\n        private int getterCalls;\n        private int setterCalls;\n\n        public ExplicitGetterBean(String value) {\n            this.value = value;\n        }\n\n        public String readValue() {\n            getterCalls++;\n            return value;\n        }\n\n        public void setValue(String value) {\n            setterCalls++;\n            this.value = value;\n        }\n\n        public String valueSnapshot() {\n            return value;\n        }\n\n        public int getterCalls() {\n            return getterCalls;\n        }\n\n        public int setterCalls() {\n            return setterCalls;\n        }\n    }\n\n    public static final class ExplicitSetterBean {\n        private String value;\n        private int getterCalls;\n        private int setterCalls;\n\n        public ExplicitSetterBean(String value) {\n            this.value = value;\n        }\n\n        public String getValue() {\n            getterCalls++;\n            return value;\n        }\n\n        public void writeValue(String value) {\n            setterCalls++;\n            this.value = value;\n        }\n\n        public String valueSnapshot() {\n            return value;\n        }\n\n        public int getterCalls() {\n            return getterCalls;\n        }\n\n        public int setterCalls() {\n            return setterCalls;\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777380047840}, {"role": "toolResult", "toolCallId": "call_xcnPZ3KvvJF4npoexJ9FcyuO|fc_08cc2260157aeb9a0169f0aacf8274819e85fbdb40f5502fa9", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_openjfx.javafx_base;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.beans.PropertyChangeListener;\nimport java.beans.PropertyChangeSupport;\nimport java.util.ArrayList;\nimport java.util.List;\nimport javafx.beans.property.adapter.ReadOnlyJavaBeanBooleanProperty;\nimport javafx.beans.property.adapter.ReadOnlyJavaBeanBooleanPropertyBuilder;\nimport javafx.beans.property.adapter.ReadOnlyJavaBeanStringProperty;\nimport javafx.beans.property.adapter.ReadOnlyJavaBeanStringPropertyBuilder;\nimport org.junit.jupiter.api.Test;\n\npublic class ReadOnlyJavaBeanPropertyBuilderHelperTest {\n\n    @Test\n    void usesAnExplicitGetterNameWhenConfigured() throws Exception {\n        ExplicitGetterBean bean = new ExplicitGetterBean(\"before\");\n        ReadOnlyJavaBeanStringProperty property = ReadOnlyJavaBeanStringPropertyBuilder.create()\n                .bean(bean)\n                .name(\"value\")\n                .getter(\"readValue\")\n                .build();\n        List<String> observedValues = new ArrayList<>();\n        property.addListener((observable, oldValue, newValue) -> observedValues.add(oldValue + \"->\" + newValue));\n\n        try {\n            assertThat(property.get()).isEqualTo(\"before\");\n            assertThat(bean.getterCalls()).isGreaterThanOrEqualTo(1);\n            assertThat(bean.addedListeners).hasSize(1);\n            assertThat(bean.removedListeners).isEmpty();\n\n            bean.setValue(\"after\");\n\n            assertThat(property.get()).isEqualTo(\"after\");\n            assertThat(observedValues).containsExactly(\"before->after\");\n        } finally {\n            property.dispose();\n        }\n\n        assertThat(bean.removedListeners).containsExactly(bean.addedListeners.get(0));\n    }\n\n    @Test\n    void fallsBackToBooleanIsGetterWhenNoGetAccessorExists() throws Exception {\n        BooleanReadOnlyBean bean = new BooleanReadOnlyBean(true);\n        ReadOnlyJavaBeanBooleanProperty property = ReadOnlyJavaBeanBooleanPropertyBuilder.create()\n                .bean(bean)\n                .name(\"active\")\n                .build();\n        List<String> observedValues = new ArrayList<>();\n        property.addListener((observable, oldValue, newValue) -> observedValues.add(oldValue + \"->\" + newValue));\n\n        try {\n            assertThat(property.get()).isTrue();\n            assertThat(bean.getterCalls()).isGreaterThanOrEqualTo(1);\n            assertThat(bean.addedListeners).hasSize(1);\n            assertThat(bean.removedListeners).isEmpty();\n\n            bean.setActive(false);\n\n            assertThat(property.get()).isFalse();\n            assertThat(observedValues).containsExactly(\"true->false\");\n        } finally {\n            property.dispose();\n        }\n\n        assertThat(bean.removedListeners).containsExactly(bean.addedListeners.get(0));\n    }\n\n    public static final class ExplicitGetterBean {\n        private final List<PropertyChangeListener> addedListeners = new ArrayList<>();\n        private final List<PropertyChangeListener> removedListeners = new ArrayList<>();\n        private final PropertyChangeSupport propertyChangeSupport = new PropertyChangeSupport(this);\n        private String value;\n        private int getterCalls;\n\n        public ExplicitGetterBean(String value) {\n            this.value = value;\n        }\n\n        public String readValue() {\n            getterCalls++;\n            return value;\n        }\n\n        public void setValue(String value) {\n            String oldValue = this.value;\n            this.value = value;\n            propertyChangeSupport.firePropertyChange(\"value\", oldValue, value);\n        }\n\n        public void addPropertyChangeListener(PropertyChangeListener listener) {\n            addedListeners.add(listener);\n            propertyChangeSupport.addPropertyChangeListener(listener);\n        }\n\n        public void removePropertyChangeListener(PropertyChangeListener listener) {\n            removedListeners.add(listener);\n            propertyChangeSupport.removePropertyChangeListener(listener);\n        }\n\n        public int getterCalls() {\n            return getterCalls;\n        }\n    }\n\n    public static final class BooleanReadOnlyBean {\n        private final List<PropertyChangeListener> addedListeners = new ArrayList<>();\n        private final List<PropertyChangeListener> removedListeners = new ArrayList<>();\n        private final PropertyChangeSupport propertyChangeSupport = new PropertyChangeSupport(this);\n        private boolean active;\n        private int getterCalls;\n\n        public BooleanReadOnlyBean(boolean active) {\n            this.active = active;\n        }\n\n        public boolean isActive() {\n            getterCalls++;\n            return active;\n        }\n\n        public void setActive(boolean active) {\n            boolean oldValue = this.active;\n            this.active = active;\n            propertyChangeSupport.firePropertyChange(\"active\", oldValue, active);\n        }\n\n        public void addPropertyChangeListener(PropertyChangeListener listener) {\n            addedListeners.add(listener);\n            propertyChangeSupport.addPropertyChangeListener(listener);\n        }\n\n        public void removePropertyChangeListener(PropertyChangeListener listener) {\n            removedListeners.add(listener);\n            propertyChangeSupport.removePropertyChangeListener(listener);\n        }\n\n        public int getterCalls() {\n            return getterCalls;\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777380047840}, {"role": "toolResult", "toolCallId": "call_mx3XQ5jvliVYhRmN2WkI9NBl|fc_08cc2260157aeb9a0169f0aacf827c819eaafd31bea5f312f0", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_openjfx.javafx_base;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport com.sun.javafx.property.JavaBeanAccessHelper;\nimport java.beans.PropertyChangeListener;\nimport java.beans.PropertyChangeSupport;\nimport java.util.ArrayList;\nimport java.util.List;\nimport javafx.beans.property.adapter.ReadOnlyJavaBeanObjectProperty;\nimport org.junit.jupiter.api.Test;\n\npublic class JavaBeanAccessHelperTest {\n\n    @Test\n    void createReadOnlyJavaBeanPropertyUsesTheQuickAccessorPath() throws Exception {\n        QuickAccessBean bean = new QuickAccessBean(\"before\");\n        ReadOnlyJavaBeanObjectProperty<?> property =\n                (ReadOnlyJavaBeanObjectProperty<?>) JavaBeanAccessHelper.createReadOnlyJavaBeanProperty(bean, \"value\");\n        List<String> observedValues = new ArrayList<>();\n        property.addListener((observable, oldValue, newValue) -> observedValues.add(oldValue + \"->\" + newValue));\n\n        try {\n            assertThat(property.getBean()).isSameAs(bean);\n            assertThat(property.getName()).isEqualTo(\"value\");\n            assertThat(property.get()).isEqualTo(\"before\");\n            assertThat(bean.getterCalls()).isGreaterThanOrEqualTo(1);\n            assertThat(bean.addedListeners).hasSize(1);\n            assertThat(bean.removedListeners).isEmpty();\n\n            bean.setValue(\"after\");\n\n            assertThat(property.get()).isEqualTo(\"after\");\n            assertThat(observedValues).containsExactly(\"before->after\");\n        } finally {\n            property.dispose();\n        }\n\n        assertThat(bean.removedListeners).containsExactly(bean.addedListeners.get(0));\n    }\n\n    public static final class QuickAccessBean {\n        private final List<PropertyChangeListener> addedListeners = new ArrayList<>();\n        private final List<PropertyChangeListener> removedListeners = new ArrayList<>();\n        private final PropertyChangeSupport propertyChangeSupport = new PropertyChangeSupport(this);\n        private String value;\n        private int getterCalls;\n\n        public QuickAccessBean(String value) {\n            this.value = value;\n        }\n\n        public String getValue() {\n            getterCalls++;\n            return value;\n        }\n\n        public void setValue(String value) {\n            String oldValue = this.value;\n            this.value = value;\n            propertyChangeSupport.firePropertyChange(\"value\", oldValue, value);\n        }\n\n        public void addPropertyChangeListener(PropertyChangeListener listener) {\n            addedListeners.add(listener);\n            propertyChangeSupport.addPropertyChangeListener(listener);\n        }\n\n        public void removePropertyChangeListener(PropertyChangeListener listener) {\n            removedListeners.add(listener);\n            propertyChangeSupport.removePropertyChangeListener(listener);\n        }\n\n        public int getterCalls() {\n            return getterCalls;\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777380047841}]}
