port java.util.HashMap;\nimport java.util.List;\nimport java.util.Map;\nimport org.junit.jupiter.api.Test;\n\npublic class MethodUtilTest {\n\n    @Test\n    void getMethodFindsInheritedPublicMethods() throws Exception {\n        Method method = MethodUtil.getMethod(PublicChild.class, \"inheritedValue\", new Class<?>[0]);\n\n        assertThat(method.getName()).isEqualTo(\"inheritedValue\");\n        assertThat(method.getDeclaringClass()).isEqualTo(PublicChild.class);\n    }\n\n    @Test\n    void getMethodsReturnsDeclaredAndInheritedPublicMethods() {\n        Method[] methods = MethodUtil.getMethods(PublicChild.class);\n\n        assertThat(methodNames(Arrays.asList(methods))).contains(\"declaredValue\", \"inheritedValue\");\n    }\n\n    @Test\n    void getPublicMethodsFallsBackToClassGetMethodsWhenNoSecurityManagerIsInstalled() throws Throwable {\n        Method[] methods = invokeGetPublicMethods(PublicChild.class);\n\n        assertThat(methodNames(Arrays.asList(methods))).contains(\"declaredValue\", \"inheritedValue\");\n    }\n\n    @Test\n    void getInternalPublicMethodsCollectsPublicMethodsReturnedByClassGetMethods() throws Throwable {\n        Map<Object, Method> collectedMethods = new HashMap<>();\n\n        boolean allMethodsPublic = invokeGetInternalPublicMethods(PublicChild.class, collectedMethods);\n\n        assertThat(allMethodsPublic).isTrue();\n        assertThat(methodNames(collectedMethods.values())).contains(\"declaredValue\", \"inheritedValue\");\n        assertThat(findMethodByName(collectedMethods.values(), \"declaredValue\").getDeclaringClass())\n                .isEqualTo(PublicChild.class);\n        assertThat(findMethodByName(collectedMethods.values(), \"inheritedValue\").getDeclaringClass())\n                .isEqualTo(PublicChild.class);\n    }\n\n    private static Method[] invokeGetPublicMethods(Class<?> type) throws Throwable {\n        MethodHandle methodHandle = MethodHandles.privateLookupIn(MethodUtil.class, MethodHandles.lookup())\n                .findStatic(MethodUtil.class, \"getPublicMethods\", MethodType.methodType(Method[].class, Class.class));\n        return (Method[]) methodHandle.invoke(type);\n    }\n\n    private static boolean invokeGetInternalPublicMethods(Class<?> type, Map<Object, Method> collectedMethods)\n            throws Throwable {\n        MethodHandle methodHandle = MethodHandles.privateLookupIn(MethodUtil.class, MethodHandles.lookup())\n                .findStatic(\n                        MethodUtil.class,\n                        \"getInternalPublicMethods\",\n                        MethodType.methodType(boolean.class, Class.class, Map.class));\n        return (boolean) methodHandle.invoke(type, collectedMethods);\n    }\n\n    private static Method findMethodByName(Collection<Method> methods, String name) {\n        return methods.stream()\n                .filter(method -> method.getName().equals(name))\n                .findFirst()\n                .orElseThrow();\n    }\n\n    private static List<String> methodNames(Collection<Method> methods) {\n        return methods.stream()\n                .map(Method::getName)\n                .toList();\n    }\n\n    static class PackagePrivateBase {\n        public String inheritedValue() {\n            return \"base\";\n        }\n    }\n\n    public static final class PublicChild extends PackagePrivateBase {\n        public String declaredValue() {\n            return \"child\";\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777379594956}, {"role": "toolResult", "toolCallId": "call_z04frDAgElPDBjCoVcVUcCAB|fc_00f4ec312b4d188a0169f0a90ab7e881a2be00cf554510fac6", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_openjfx.javafx_base;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport com.sun.javafx.property.PropertyReference;\nimport javafx.beans.property.BooleanProperty;\nimport javafx.beans.property.SimpleBooleanProperty;\nimport javafx.beans.property.SimpleStringProperty;\nimport javafx.beans.property.StringProperty;\nimport org.junit.jupiter.api.Test;\n\npublic class PropertyReferenceTest {\n\n    @Test\n    void conventionalGetterSetterAndPropertyMethodsAreDiscovered() {\n        PropertyReference<String> reference = new PropertyReference<>(ConventionalPropertyBean.class, \"value\");\n\n        assertThat(reference.getType()).isEqualTo(String.class);\n        assertThat(reference.isReadable()).isTrue();\n        assertThat(reference.isWritable()).isTrue();\n        assertThat(reference.hasProperty()).isTrue();\n    }\n\n    @Test\n    void booleanPropertiesFallBackToIsGetterNaming() {\n        PropertyReference<Boolean> reference = new PropertyReference<>(BooleanPropertyBean.class, \"active\");\n\n        assertThat(reference.getType()).isEqualTo(Boolean.TYPE);\n        assertThat(reference.isReadable()).isTrue();\n        assertThat(reference.isWritable()).isTrue();\n        assertThat(reference.hasProperty()).isTrue();\n    }\n\n    @Test\n    void setterOnlyPropertiesFallBackToScanningPublicMethods() {\n        PropertyReference<String> reference = new PropertyReference<>(SetterOnlyPropertyBean.class, \"value\");\n\n        assertThat(reference.getType()).isEqualTo(String.class);\n        assertThat(reference.isReadable()).isFalse();\n        assertThat(reference.isWritable()).isTrue();\n        assertThat(reference.hasProperty()).isFalse();\n    }\n\n    public static final class ConventionalPropertyBean {\n        private final StringProperty value = new SimpleStringProperty(this, \"value\", \"before\");\n\n        public String getValue() {\n            return value.get();\n        }\n\n        public void setValue(String value) {\n            this.value.set(value);\n        }\n\n        public StringProperty valueProperty() {\n            return value;\n        }\n    }\n\n    public static final class BooleanPropertyBean {\n        private final BooleanProperty active = new SimpleBooleanProperty(this, \"active\", true);\n\n        public boolean isActive() {\n            return active.get();\n        }\n\n        public void setActive(boolean active) {\n            this.active.set(active);\n        }\n\n        public BooleanProperty activeProperty() {\n            return active;\n        }\n    }\n\n    public static final class SetterOnlyPropertyBean {\n        private String value;\n\n        public void setValue(String value) {\n            this.value = value;\n        }\n\n        public String currentValue() {\n            return value;\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777379594956}, {"role": "toolResult", "toolCallId": "call_5TueZqWnwVFsTKAkxFwBvw7h|fc_00f4ec312b4d188a0169f0a90ab7f081a29407297216144ddd", "toolName": "read", "content": [{"type": "text", "text": "{\n  \"classes\" : [ {\n    \"callSites\" : [ {\n      \"covered\" : false,\n      \"frame\" : \"com.sun.javafx.reflect.ConstructorUtil.getConstructor(ConstructorUtil.java:38)\",\n      \"line\" : 38,\n      \"metadataType\" : \"reflection\",\n      \"trackedApi\" : \"java.lang.Class#getConstructor(java.lang.Class[])\"\n    }, {\n      \"covered\" : false,\n      \"frame\" : \"com.sun.javafx.reflect.ConstructorUtil.getConstructors(ConstructorUtil.java:43)\",\n      \"line\" : 43,\n      \"metadataType\" : \"reflection\",\n      \"trackedApi\" : \"java.lang.Class#getConstructors()\"\n    } ],\n    \"className\" : \"com.sun.javafx.reflect.ConstructorUtil\",\n    \"coveredCalls\" : 0,\n    \"sourceFile\" : \"ConstructorUtil.java\",\n    \"totalCalls\" : 2\n  }, {\n    \"callSites\" : [ {\n      \"covered\" : true,\n      \"frame\" : \"com.sun.javafx.collections.SortHelper.copyOfRange(SortHelper.java:143)\",\n      \"line\" : 143,\n      \"metadataType\" : \"reflection\",\n      \"trac