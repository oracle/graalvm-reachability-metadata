[tool-call] delta {"path":"tests/src/org.openjfx/javafx-base/13-ea/src/test/java/org_openjfx/javafx_base/FXCollectionsInnerCheckedObservableListTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_openjfx.javafx_base;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.util.ArrayList;\nimport java.util.List;\nimport javafx.collections.FXCollections;\nimport javafx.collections.ListChangeListener;\nimport javafx.collections.ObservableList;\nimport org.junit.jupiter.api.Test;\n\npublic class FXCollectionsInnerCheckedObservableListTest {\n\n    @Test\n    void addAllOverloadsAcceptMatchingElementsAndPreserveObservableListUpdates() {\n        ObservableList<String> checkedValues = FXCollections.checkedObservableList(\n                FXCollections.observableArrayList(\"alpha\"),\n                String.class);\n        List<List<String>> snapshots = new ArrayList<>();\n\n        checkedValues.addListener((ListChangeListener<String>) change -> {\n            while (change.next()) {\n                // exhaust change details before capturing the visible list state\n            }\n            snapshots.add(List.copyOf(checkedValues));\n        });\n\n        boolean addedAtIndex = checkedValues.addAll(1, List.of(\"bravo\", \"charlie\"));\n        boolean addedCollection = checkedValues.addAll(List.of(\"delta\", \"echo\"));\n        boolean addedVarargs = checkedValues.addAll(\"foxtrot\", \"golf\");\n\n        assertThat(addedAtIndex).isTrue();\n        assertThat(addedCollection).isTrue();\n        assertThat(addedVarargs).isTrue();\n        assertThat(checkedValues).containsExactly(\"alpha\", \"bravo\", \"charlie\", \"delta\", \"echo\", \"foxtrot\", \"golf\");\n        assertThat(snapshots).containsExactly(\n                List.of(\"alpha\", \"bravo\", \"charlie\"),\n                List.of(\"alpha\", \"bravo\", \"charlie\", \"delta\", \"echo\"),\n                List.of(\"alpha\", \"bravo\", \"charlie\", \"delta\", \"echo\", \"foxtrot\", \"golf\"));\n    }\n\n    @Test\n    void setAllOverloadsReplaceContentsWithCheckedElements() {\n        ObservableList<String> checkedValues = FXCollections.checkedObservableList(\n                FXCollections.observableArrayList(\"alpha\", \"bravo\", \"charlie\"),\n                String.class);\n        List<List<String>> snapshots = new ArrayList<>();\n\n        checkedValues.addListener((ListChangeListener<String>) change -> {\n            while (change.next()) {\n                // exhaust change details before capturing the visible list state\n            }\n            snapshots.add(List.copyOf(checkedValues));\n        });\n\n        boolean replacedWithVarargs = checkedValues.setAll(\"delta\", \"echo\");\n        boolean replacedWithCollection = checkedValues.setAll(List.of(\"foxtrot\", \"golf\", \"hotel\"));\n\n        assertThat(replacedWithVarargs).isTrue();\n        assertThat(replacedWithCollection).isTrue();\n        assertThat(checkedValues).containsExactly(\"foxtrot\", \"golf\", \"hotel\");\n        assertThat(snapshots).containsExactly(\n                List.of(\"delta\", \"echo\"),\n                List.of(\"foxtrot\", \"golf\", \"hotel\"));\n    }\n}\n"}
[tool-call] end id=call_xjfOSlcOeMgJEKl3R8zuYodC|fc_0c9aab6992b26a130169f0a4f527c48194906fb1077fc9a194 name=write args={"path": "tests/src/org.openjfx/javafx-base/13-ea/src/test/java/org_openjfx/javafx_base/FXCollectionsInnerCheckedObservableListTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_openjfx.javafx_base;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.util.ArrayList;\nimport java.util.List;\nimport javafx.collections.FXCollections;\nimport javafx.collections.ListChangeListener;\nimport javafx.collections.ObservableList;\nimport org.junit.jupiter.api.Test;\n\npublic class FXCollectionsInnerCheckedObservableListTest {\n\n    @Test\n    void addAllOverloadsAcceptMatchingElementsAndPreserveObservableListUpdates() {\n        ObservableList<String> checkedValues = FXCollections.checkedObservableList(\n                FXCollections.observableArrayList(\"alpha\"),\n                String.class);\n        List<List<String>> snapshots = new ArrayList<>();\n\n        checkedValues.addListener((ListChangeListener<String>) change -> {\n            while (change.next()) {\n                // exhaust change details before capturing the visible list state\n            }\n            snapshots.add(List.copyOf(checkedValues));\n        });\n\n        boolean addedAtIndex = checkedValues.addAll(1, List.of(\"bravo\", \"charlie\"));\n        boolean addedCollection = checkedValues.addAll(List.of(\"delta\", \"echo\"));\n        boolean addedVarargs = checkedValues.addAll(\"foxtrot\", \"golf\");\n\n        assertThat(addedAtIndex).isTrue();\n        assertThat(addedCollection).isTrue();\n        assertThat(addedVarargs).isTrue();\n        assertThat(checkedValues).containsExactly(\"alpha\", \"bravo\", \"charlie\", \"delta\", \"echo\", \"foxtrot\", \"golf\");\n        assertThat(snapshots).containsExactly(\n                List.of(\"alpha\", \"bravo\", \"charlie\"),\n                List.of(\"alpha\", \"bravo\", \"charlie\", \"delta\", \"echo\"),\n                List.of(\"alpha\", \"bravo\", \"charlie\", \"delta\", \"echo\", \"foxtrot\", \"golf\"));\n    }\n\n    @Test\n    void setAllOverloadsReplaceContentsWithCheckedElements() {\n        ObservableList<String> checkedValues = FXCollections.checkedObservableList(\n                FXCollections.observableArrayList(\"alpha\", \"bravo\", \"charlie\"),\n                String.class);\n        List<List<String>> snapshots = new ArrayList<>();\n\n        checkedValues.addListener((ListChangeListener<String>) change -> {\n            while (change.next()) {\n                // exhaust change details before capturing the visible list state\n            }\n            snapshots.add(List.copyOf(checkedValues));\n        });\n\n        boolean replacedWithVarargs = checkedValues.setAll(\"delta\", \"echo\");\n        boolean replacedWithCollection = checkedValues.setAll(List.of(\"foxtrot\", \"golf\", \"hotel\"));\n\n        assertThat(replacedWithVarargs).isTrue();\n        assertThat(replacedWithCollection).isTrue();\n        assertThat(checkedValues).containsExactly(\"foxtrot\", \"golf\", \"hotel\");\n        assertThat(snapshots).containsExactly(\n                List.of(\"delta\", \"echo\"),\n                List.of(\"foxtrot\", \"golf\", \"hotel\"));\n    }\n}\n"}
