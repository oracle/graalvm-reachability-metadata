[tool-call] delta {"path":"tests/src/org.openjfx/javafx-base/13-ea/src/test/java/org_openjfx/javafx_base/FXCollectionsInnerCheckedObservableSetTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_openjfx.javafx_base;\n\nimport static org.assertj.core.api.Assertions.assertThat;\nimport static org.assertj.core.api.Assertions.assertThatThrownBy;\n\nimport java.util.ArrayList;\nimport java.util.Collection;\nimport java.util.LinkedHashSet;\nimport java.util.List;\nimport javafx.collections.FXCollections;\nimport javafx.collections.ObservableSet;\nimport javafx.collections.SetChangeListener;\nimport org.junit.jupiter.api.Test;\n\npublic class FXCollectionsInnerCheckedObservableSetTest {\n\n    @Test\n    void addAllAcceptsMatchingElementsAndPublishesSetChanges() {\n        ObservableSet<String> checkedValues = FXCollections.checkedObservableSet(\n                FXCollections.observableSet(new LinkedHashSet<>(List.of(\"alpha\"))),\n                String.class);\n        List<String> events = new ArrayList<>();\n\n        checkedValues.addListener((SetChangeListener<String>) change -> {\n            if (change.wasAdded()) {\n                events.add(\"added \" + change.getElementAdded());\n            }\n            if (change.wasRemoved()) {\n                events.add(\"removed \" + change.getElementRemoved());\n            }\n        });\n\n        boolean changed = checkedValues.addAll(List.of(\"bravo\", \"charlie\"));\n\n        assertThat(changed).isTrue();\n        assertThat(new ArrayList<>(checkedValues)).containsExactly(\"alpha\", \"bravo\", \"charlie\");\n        assertThat(events).containsExactly(\"added bravo\", \"added charlie\");\n    }\n\n    @SuppressWarnings({\"rawtypes\", \"unchecked\"})\n    @Test\n    void addAllRejectsCollectionsContainingIncompatibleElements() {\n        ObservableSet<String> checkedValues = FXCollections.checkedObservableSet(\n                FXCollections.observableSet(new LinkedHashSet<>(List.of(\"alpha\"))),\n                String.class);\n        Collection incompatibleValues = List.of(\"bravo\", 7);\n\n        assertThatThrownBy(() -> checkedValues.addAll((Collection<? extends String>) incompatibleValues))\n                .isInstanceOf(ClassCastException.class);\n        assertThat(new ArrayList<>(checkedValues)).containsExactly(\"alpha\");\n    }\n}\n"}
