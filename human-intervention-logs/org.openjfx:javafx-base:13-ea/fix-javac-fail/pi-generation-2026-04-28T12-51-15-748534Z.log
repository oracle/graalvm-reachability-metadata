  package org_openjfx.javafx_base;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.util.ArrayList;
  import java.util.List;
  import javafx.collections.FXCollections;
  import javafx.collections.ListChangeListener;
  import javafx.collections.ObservableList;
  import org.junit.jupiter.api.Test;
  
  public class FXCollectionsInnerCheckedObservableListTest {
  
      @Test
      void addAllOverloadsAcceptMatchingElementsAndPreserveObservableListUpdates() {
          ObservableList<String> checkedValues = FXCollections.checkedObservableList(
                  FXCollections.observableArrayList("alpha"),
                  String.class);
          List<List<String>> snapshots = new ArrayList<>();
  
          checkedValues.addListener((ListChangeListener<String>) change -> {
              while (change.next()) {
                  // exhaust change details before capturing the visible list state
              }
              snapshots.add(List.copyOf(checkedValues));
          });
  
          boolean addedAtIndex = checkedValues.addAll(1, List.of("bravo", "charlie"));
          boolean addedCollection = checkedValues.addAll(List.of("delta", "echo"));
          boolean addedVarargs = checkedValues.addAll("foxtrot", "golf");
  
          assertThat(addedAtIndex).isTrue();
          assertThat(addedCollection).isTrue();
          assertThat(addedVarargs).isTrue();
          assertThat(checkedValues)
                  .containsExactly("alpha", "bravo", "charlie", "delta", "echo", "foxtrot", "golf");
          assertThat(snapshots).containsExactly(
                  List.of("alpha", "bravo", "charlie"),
                  List.of("alpha", "bravo", "charlie", "delta", "echo"),
                  List.of("alpha", "bravo", "charlie", "delta", "echo", "foxtrot", "golf"));
      }
  
      @Test
      void setAllOverloadsReplaceContentsWithCheckedElements() {
          ObservableList<String> checkedValues = FXCollections.checkedObservableList(
                  FXCollections.observableArrayList("alpha", "bravo", "charlie"),
                  String.class);
          List<List<String>> snapshots = new ArrayList<>();
  
          checkedValues.addListener((ListChangeListener<String>) change -> {
              while (change.next()) {
                  // exhaust change details before capturing the visible list state
              }
              snapshots.add(List.copyOf(checkedValues));
          });
  
          boolean replacedWithVarargs = checkedValues.setAll("delta", "echo");
          boolean replacedWithCollection = checkedValues.setAll(
                  List.of("foxtrot", "golf", "hotel"));
  
          assertThat(replacedWithVarargs).isTrue();
          assertThat(replacedWithCollection).isTrue();
          assertThat(checkedValues).containsExactly("foxtrot", "golf", "hotel");
          assertThat(snapshots).containsExactly(
                  List.of("delta", "echo"),
                  List.of("foxtrot", "golf", "hotel"));
      }
  }
