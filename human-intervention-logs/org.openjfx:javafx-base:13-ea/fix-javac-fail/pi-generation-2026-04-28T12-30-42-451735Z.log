[tool-call] delta {"path":"tests/src/org.openjfx/javafx-base/13-ea/src/test/java/org_openjfx/javafx_base/ReadOnlyJavaBeanPropertyBuilderHelperTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_openjfx.javafx_base;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.beans.PropertyChangeListener;\nimport java.beans.PropertyChangeSupport;\nimport java.util.ArrayList;\nimport java.util.List;\nimport javafx.beans.property.adapter.ReadOnlyJavaBeanBooleanProperty;\nimport javafx.beans.property.adapter.ReadOnlyJavaBeanBooleanPropertyBuilder;\nimport org.junit.jupiter.api.Test;\n\npublic class ReadOnlyJavaBeanPropertyBuilderHelperTest {\n\n    @Test\n    void fallsBackToBooleanIsGetterWhenNoGetAccessorExists() throws Exception {\n        BooleanReadOnlyBean bean = new BooleanReadOnlyBean(true);\n        ReadOnlyJavaBeanBooleanProperty property = ReadOnlyJavaBeanBooleanPropertyBuilder.create()\n                .bean(bean)\n                .name(\"active\")\n                .build();\n        List<String> observedValues = new ArrayList<>();\n        property.addListener((observable, oldValue, newValue) -> observedValues.add(oldValue + \"->\" + newValue));\n\n        try {\n            assertThat(property.get()).isTrue();\n            assertThat(bean.getterCalls()).isGreaterThanOrEqualTo(1);\n            assertThat(bean.addedListeners).hasSize(1);\n            assertThat(bean.removedListeners).isEmpty();\n\n            bean.setActive(false);\n\n            assertThat(property.get()).isFalse();\n            assertThat(observedValues).containsExactly(\"true->false\");\n        } finally {\n            property.dispose();\n        }\n\n        assertThat(bean.removedListeners).containsExactly(bean.addedListeners.get(0));\n    }\n\n    public static final class BooleanReadOnlyBean {\n        private final List<PropertyChangeListener> addedListeners = new ArrayList<>();\n        private final List<PropertyChangeListener> removedListeners = new ArrayList<>();\n        private final PropertyChangeSupport propertyChangeSupport = new PropertyChangeSupport(this);\n        private boolean active;\n        private int getterCalls;\n\n        public BooleanReadOnlyBean(boolean active) {\n            this.active = active;\n        }\n\n        public boolean isActive() {\n            getterCalls++;\n            return active;\n        }\n\n        public void setActive(boolean active) {\n            boolean oldValue = this.active;\n            this.active = active;\n            propertyChangeSupport.firePropertyChange(\"active\", oldValue, active);\n        }\n\n        public void addPropertyChangeListener(PropertyChangeListener listener) {\n            addedListeners.add(listener);\n            propertyChangeSupport.addPropertyChangeListener(listener);\n        }\n\n        public void removePropertyChangeListener(PropertyChangeListener listener) {\n            removedListeners.add(listener);\n            propertyChangeSupport.removePropertyChangeListener(listener);\n        }\n\n        public int getterCalls() {\n            return getterCalls;\n        }\n    }\n}\n"}
[tool-call] end id=call_GuGF7Anf0UaTQcyhxwGBTzNl|fc_035ed9840a6f2aba0169f0a86099788195b065b92daea27a69 name=write args={"path": "tests/src/org.openjfx/javafx-base/13-ea/src/test/java/org_openjfx/javafx_base/ReadOnlyJavaBeanPropertyBuilderHelperTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_openjfx.javafx_base;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.beans.PropertyChangeListener;\nimport java.beans.PropertyChangeSupport;\nimport java.util.ArrayList;\nimport java.util.List;\nimport javafx.beans.property.adapter.ReadOnlyJavaBeanBooleanProperty;\nimport javafx.beans.property.adapter.ReadOnlyJavaBeanBooleanPropertyBuilder;\nimport org.junit.jupiter.api.Test;\n\npublic class ReadOnlyJavaBeanPropertyBuilderHelperTest {\n\n    @Test\n    void fallsBackToBooleanIsGetterWhenNoGetAccessorExists() throws Exception {\n        BooleanReadOnlyBean bean = new BooleanReadOnlyBean(true);\n        ReadOnlyJavaBeanBooleanProperty property = ReadOnlyJavaBeanBooleanPropertyBuilder.create()\n                .bean(bean)\n                .name(\"active\")\n                .build();\n        List<String> observedValues = new ArrayList<>();\n        property.addListener((observable, oldValue, newValue) -> observedValues.add(oldValue + \"->\" + newValue));\n\n        try {\n            assertThat(property.get()).isTrue();\n            assertThat(bean.getterCalls()).isGreaterThanOrEqualTo(1);\n            assertThat(bean.addedListeners).hasSize(1);\n            assertThat(bean.removedListeners).isEmpty();\n\n            bean.setActive(false);\n\n            assertThat(property.get()).isFalse();\n            assertThat(observedValues).containsExactly(\"true->false\");\n        } finally {\n            property.dispose();\n        }\n\n        assertThat(bean.removedListeners).containsExactly(bean.addedListeners.get(0));\n    }\n\n    public static final class BooleanReadOnlyBean {\n        private final List<PropertyChangeListener> addedListeners = new ArrayList<>();\n        private final List<PropertyChangeListener> removedListeners = new ArrayList<>();\n        private final PropertyChangeSupport propertyChangeSupport = new PropertyChangeSupport(this);\n        private boolean active;\n        private int getterCalls;\n\n        public BooleanReadOnlyBean(boolean active) {\n            this.active = active;\n        }\n\n        public boolean isActive() {\n            getterCalls++;\n            return active;\n        }\n\n        public void setActive(boolean active) {\n            boolean oldValue = this.active;\n            this.active = active;\n            propertyChangeSupport.firePropertyChange(\"active\", oldValue, active);\n        }\n\n        public void addPropertyChangeListener(PropertyChangeListener listener) {\n            addedListeners.add(listener);\n            propertyChangeSupport.addPropertyChangeListener(listener);\n        }\n\n        public void removePropertyChangeListener(PropertyChangeListener listener) {\n            removedListeners.add(listener);\n            propertyChangeSupport.removePropertyChangeListener(listener);\n        }\n\n        public int getterCalls() {\n            return getterCalls;\n        }\n    }\n}\n"}
