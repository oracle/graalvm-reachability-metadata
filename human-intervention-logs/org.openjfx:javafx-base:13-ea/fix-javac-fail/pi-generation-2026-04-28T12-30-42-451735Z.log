  package org_openjfx.javafx_base;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import javafx.beans.property.adapter.JavaBeanBooleanProperty;
  import javafx.beans.property.adapter.JavaBeanBooleanPropertyBuilder;
  import javafx.beans.property.adapter.JavaBeanStringProperty;
  import javafx.beans.property.adapter.JavaBeanStringPropertyBuilder;
  import org.junit.jupiter.api.Test;
  
  public class JavaBeanPropertyBuilderHelperTest {
  
      @Test
      void usesDefaultGetterAndSetterNamesDerivedFromThePropertyName() throws Exception {
          DefaultAccessorBean bean = new DefaultAccessorBean("before");
          JavaBeanStringProperty property = JavaBeanStringPropertyBuilder.create()
                  .bean(bean)
                  .name("value")
                  .build();
  
          try {
              assertThat(property.get()).isEqualTo("before");
  
              property.set("after");
  
              assertThat(bean.valueSnapshot()).isEqualTo("after");
              assertThat(bean.getterCalls()).isGreaterThanOrEqualTo(1);
              assertThat(bean.setterCalls()).isEqualTo(1);
          } finally {
              property.dispose();
          }
      }
  
      @Test
      void usesBooleanIsGetterNamesDerivedFromThePropertyName() throws Exception {
          BooleanAccessorBean bean = new BooleanAccessorBean(true);
          JavaBeanBooleanProperty property = JavaBeanBooleanPropertyBuilder.create()
                  .bean(bean)
                  .name("active")
                  .build();
  
          try {
              assertThat(property.get()).isTrue();
  
              property.set(false);
  
              assertThat(bean.activeSnapshot()).isFalse();
              assertThat(bean.getterCalls()).isGreaterThanOrEqualTo(1);
              assertThat(bean.setterCalls()).isEqualTo(1);
          } finally {
              property.dispose();
          }
      }
  
      @Test
      void usesAnExplicitGetterNameWhenConfigured() throws Exception {
          ExplicitGetterBean bean = new ExplicitGetterBean("before");
          JavaBeanStringProperty property = JavaBeanStringPropertyBuilder.create()
                  .bean(bean)
                  .name("value")
                  .getter("readValue")
                  .build();
  
          try {
              assertThat(property.get()).isEqualTo("before");
  
              property.set("after");
  
              assertThat(bean.valueSnapshot()).isEqualTo("after");
              assertThat(bean.getterCalls()).isGreaterThanOrEqualTo(1);
              assertThat(bean.setterCalls()).isEqualTo(1);
          } finally {
              property.dispose();
          }
      }
  
      @Test
      void usesAnExplicitSetterNameWhenConfigured() throws Exception {
          ExplicitSetterBean bean = new ExplicitSetterBean("before");
          JavaBeanStringProperty property = JavaBeanStringPropertyBuilder.create()
                  .bean(bean)
                  .name("value")
                  .setter("writeValue")
                  .build();
  
          try {
              assertThat(property.get()).isEqualTo("before");
  
              property.set("after");
  
              assertThat(bean.valueSnapshot()).isEqualTo("after");
              assertThat(bean.getterCalls()).isGreaterThanOrEqualTo(1);
              assertThat(bean.setterCalls()).isEqualTo(1);
          } finally {
              property.dispose();
          }
      }
  
      public static final class DefaultAccessorBean {
          private String value;
          private int getterCalls;
          private int setterCalls;
  
          public DefaultAccessorBean(String value) {
              this.value = value;
          }
  
          public String getValue() {
              getterCalls++;
              return value;
          }
  
          public void setValue(String value) {
              setterCalls++;
              this.value = value;
          }
  
          public String valueSnapshot() {
              return value;
          }
  
          public int getterCalls() {
              return getterCalls;
          }
  
          public int setterCalls() {
              return setterCalls;
          }
      }
  
      public static final class BooleanAccessorBean {
          private boolean active;
          private int getterCalls;
          private int setterCalls;
  
          public BooleanAccessorBean(boolean active) {
              this.active = active;
          }
  
          public boolean isActive() {
              getterCalls++;
              return active;
          }
  
          public void setActive(boolean active) {
              setterCalls++;
              this.active = active;
          }
  
          public boolean activeSnapshot() {
              return active;
          }
  
          public int getterCalls() {
              return getterCalls;
          }
  
          public int setterCalls() {
              return setterCalls;
          }
      }
  
      public static final class ExplicitGetterBean {
          private String value;
          private int getterCalls;
          private int setterCalls;
  
          public ExplicitGetterBean(String value) {
              this.value = value;
          }
  
          public String readValue() {
              getterCalls++;
              return value;
          }
  
          public void setValue(String value) {
              setterCalls++;
              this.value = value;
          }
  
          public String valueSnapshot() {
              return value;
          }
  
          public int getterCalls() {
              return getterCalls;
          }
  
          public int setterCalls() {
              return setterCalls;
          }
      }
  
      public static final class ExplicitSetterBean {
          private String value;
          private int getterCalls;
          private int setterCalls;
  
          public ExplicitSetterBean(String value) {
              this.value = value;
          }
  
          public String getValue() {
              getterCalls++;
              return value;
          }
  
          public void writeValue(String value) {
              setterCalls++;
              this.value = value;
          }
  
          public String valueSnapshot() {
              return value;
          }
  
          public int getterCalls() {
              return getterCalls;
          }
  
          public int setterCalls() {
              return setterCalls;
          }
