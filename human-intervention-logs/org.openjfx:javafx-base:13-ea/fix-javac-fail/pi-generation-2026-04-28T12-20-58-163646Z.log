  public class PropertyDescriptorTest {
  
      @Test
      void registersAndRemovesNamedVetoableListeners() throws Exception {
          NamedVetoableListenerBean bean = new NamedVetoableListenerBean();
          JavaBeanStringProperty property = JavaBeanStringPropertyBuilder.create()
                  .bean(bean)
                  .name("value")
                  .build();
  
          try {
              assertThat(bean.addedPropertyNames).containsExactly("value");
              assertThat(bean.addedListeners).hasSize(1);
              assertThat(bean.removedPropertyNames).isEmpty();
              assertThat(bean.removedListeners).isEmpty();
          } finally {
              property.dispose();
          }
  
          assertThat(bean.removedPropertyNames).containsExactly("value");
          assertThat(bean.removedListeners).containsExactly(bean.addedListeners.get(0));
      }
  
      @Test
      void registersAndRemovesUnnamedVetoableListeners() throws Exception {
          UnnamedVetoableListenerBean bean = new UnnamedVetoableListenerBean();
          JavaBeanStringProperty property = JavaBeanStringPropertyBuilder.create()
                  .bean(bean)
                  .name("value")
                  .build();
  
          try {
              assertThat(bean.addedListeners).hasSize(1);
              assertThat(bean.removedListeners).isEmpty();
          } finally {
              property.dispose();
          }
  
          assertThat(bean.removedListeners).containsExactly(bean.addedListeners.get(0));
      }
  
      @Test
      void registersAndRemovesPropertySpecificVetoableListeners() throws Exception {
          PropertySpecificVetoableListenerBean bean = new PropertySpecificVetoableListenerBean();
          JavaBeanStringProperty property = JavaBeanStringPropertyBuilder.create()
                  .bean(bean)
                  .name("value")
                  .build();
  
          try {
              assertThat(bean.addedListeners).hasSize(1);
              assertThat(bean.removedListeners).isEmpty();
          } finally {
              property.dispose();
          }
  
          assertThat(bean.removedListeners).containsExactly(bean.addedListeners.get(0));
      }
  
      public static final class NamedVetoableListenerBean {
          private final List<String> addedPropertyNames = new ArrayList<>();
          private final List<VetoableChangeListener> addedListeners = new ArrayList<>();
          private final List<String> removedPropertyNames = new ArrayList<>();
          private final List<VetoableChangeListener> removedListeners = new ArrayList<>();
          private String value = "before";
  
          public String getValue() {
              return value;
          }
  
          public void setValue(String value) {
              this.value = value;
          }
  
          public void addVetoableChangeListener(String propertyName, VetoableChangeListener listener) {
              addedPropertyNames.add(propertyName);
              addedListeners.add(listener);
          }
  
          public void removeVetoableChangeListener(String propertyName, VetoableChangeListener listener) {
              removedPropertyNames.add(propertyName);
              removedListeners.add(listener);
          }
      }
  
      public static final class UnnamedVetoableListenerBean {
          private final List<VetoableChangeListener> addedListeners = new ArrayList<>();
          private final List<VetoableChangeListener> removedListeners = new ArrayList<>();
          private String value = "before";
  
          public String getValue() {
              return value;
          }
  
          public void setValue(String value) throws PropertyVetoException {
              this.value = value;
          }
  
          public void addVetoableChangeListener(VetoableChangeListener listener) {
              addedListeners.add(listener);
          }
  
          public void removeVetoableChangeListener(VetoableChangeListener listener) {
              removedListeners.add(listener);
          }
      }
  
      public static final class PropertySpecificVetoableListenerBean {
          private final List<VetoableChangeListener> addedListeners = new ArrayList<>();
          private final List<VetoableChangeListener> removedListeners = new ArrayList<>();
          private String value = "before";
  
          public String getValue() {
              return value;
          }
  
          public void setValue(String value) {
              this.value = value;
          }
  
          public void addValueListener(VetoableChangeListener listener) {
              addedListeners.add(listener);
          }
  
          public void removeValueListener(VetoableChangeListener listener) {
              removedListeners.add(listener);
          }
      }
  }
