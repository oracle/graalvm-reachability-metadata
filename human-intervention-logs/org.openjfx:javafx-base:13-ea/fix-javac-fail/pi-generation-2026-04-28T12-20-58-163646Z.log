  package org_openjfx.javafx_base;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import com.sun.javafx.property.PropertyReference;
  import javafx.beans.property.BooleanProperty;
  import javafx.beans.property.SimpleBooleanProperty;
  import javafx.beans.property.SimpleStringProperty;
  import javafx.beans.property.StringProperty;
  import org.junit.jupiter.api.Test;
  
  public class PropertyReferenceTest {
  
      @Test
      void conventionalGetterSetterAndPropertyMethodsAreDiscovered() {
          PropertyReference<String> reference = new PropertyReference<>(ConventionalPropertyBean.class, "value");
  
          assertThat(reference.getType()).isEqualTo(String.class);
          assertThat(reference.isReadable()).isTrue();
          assertThat(reference.isWritable()).isTrue();
          assertThat(reference.hasProperty()).isTrue();
      }
  
      @Test
      void booleanPropertiesFallBackToIsGetterNaming() {
          PropertyReference<Boolean> reference = new PropertyReference<>(BooleanPropertyBean.class, "active");
  
          assertThat(reference.getType()).isEqualTo(Boolean.TYPE);
          assertThat(reference.isReadable()).isTrue();
          assertThat(reference.isWritable()).isTrue();
          assertThat(reference.hasProperty()).isTrue();
      }
  
      @Test
      void setterOnlyPropertiesFallBackToScanningPublicMethods() {
          PropertyReference<String> reference = new PropertyReference<>(SetterOnlyPropertyBean.class, "value");
  
          assertThat(reference.getType()).isEqualTo(String.class);
          assertThat(reference.isReadable()).isFalse();
          assertThat(reference.isWritable()).isTrue();
          assertThat(reference.hasProperty()).isFalse();
      }
  
      public static final class ConventionalPropertyBean {
          private final StringProperty value = new SimpleStringProperty(this, "value", "before");
  
          public String getValue() {
              return value.get();
          }
  
          public void setValue(String value) {
              this.value.set(value);
          }
  
          public StringProperty valueProperty() {
              return value;
          }
      }
  
      public static final class BooleanPropertyBean {
          private final BooleanProperty active = new SimpleBooleanProperty(this, "active", true);
  
          public boolean isActive() {
              return active.get();
          }
  
          public void setActive(boolean active) {
              this.active.set(active);
          }
  
          public BooleanProperty activeProperty() {
              return active;
          }
      }
  
      public static final class SetterOnlyPropertyBean {
          private String value;
  
          public void setValue(String value) {
              this.value = value;
          }
  
          public String currentValue() {
              return value;
          }
      }
  }
