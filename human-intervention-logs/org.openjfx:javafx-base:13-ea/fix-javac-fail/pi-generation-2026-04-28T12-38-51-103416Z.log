-base/13-ea/src/test/java/org_openjfx/javafx_base/MethodUtilTest.java:11:import com.sun.javafx.reflect.MethodUtil;\ntests/src/org.openjfx/javafx-base/13-ea/src/test/java/org_openjfx/javafx_base/PulseLoggerTest.java:11:import com.sun.javafx.logging.PulseLogger;\n"}], "isError": false, "timestamp": 1777379883427}, {"role": "toolResult", "toolCallId": "call_wcnVnlPKrCrzfZdcVXtrTNsQ|fc_064a42178e280c330169f0aa2b1230819fb01ed0babc89e793", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_openjfx.javafx_base;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport com.sun.javafx.reflect.MethodUtil;\nimport java.lang.invoke.MethodHandle;\nimport java.lang.invoke.MethodHandles;\nimport java.lang.invoke.MethodType;\nimport java.lang.reflect.Method;\nimport java.util.Arrays;\nimport java.util.Collection;\nimport java.util.HashMap;\nimport java.util.List;\nimport java.util.Map;\nimport org.junit.jupiter.api.Test;\n\npublic class MethodUtilTest {\n\n    @Test\n    void getMethodFindsInheritedPublicMethods() throws Exception {\n        Method method = MethodUtil.getMethod(PublicChild.class, \"inheritedValue\", new Class<?>[0]);\n\n        assertThat(method.getName()).isEqualTo(\"inheritedValue\");\n        assertThat(method.getDeclaringClass()).isEqualTo(PublicChild.class);\n    }\n\n    @Test\n    void getMethodsReturnsDeclaredAndInheritedPublicMethods() {\n        Method[] methods = MethodUtil.getMethods(PublicChild.class);\n\n        assertThat(methodNames(Arrays.asList(methods))).contains(\"declaredValue\", \"inheritedValue\");\n    }\n\n    @Test\n    void getPublicMethodsFallsBackToClassGetMethodsWhenNoSecurityManagerIsInstalled() throws Throwable {\n        Method[] methods = invokeGetPublicMethods(PublicChild.class);\n\n        assertThat(methodNames(Arrays.asList(methods))).contains(\"declaredValue\", \"inheritedValue\");\n    }\n\n    @Test\n    void getInternalPublicMethodsCollectsPublicMethodsReturnedByClassGetMethods() throws Throwable {\n        Map<Object, Method> collectedMethods = new HashMap<>();\n\n        boolean allMethodsPublic = invokeGetInternalPublicMethods(PublicChild.class, collectedMethods);\n\n        assertThat(allMethodsPublic).isTrue();\n        assertThat(methodNames(collectedMethods.values())).contains(\"declaredValue\", \"inheritedValue\");\n        assertThat(findMethodByName(collectedMethods.values(), \"declaredValue\").getDeclaringClass())\n                .isEqualTo(PublicChild.class);\n        assertThat(findMethodByName(collectedMethods.values(), \"inheritedValue\").getDeclaringClass())\n                .isEqualTo(PublicChild.class);\n    }\n\n    private static Method[] invokeGetPublicMethods(Class<?> type) throws Throwable {\n        MethodHandle methodHandle = MethodHandles.privateLookupIn(MethodUtil.class, MethodHandles.lookup())\n                .findStatic(MethodUtil.class, \"getPublicMethods\", MethodType.methodType(Method[].class, Class.class));\n        return (Method[]) methodHandle.invoke(type);\n    }\n\n    private static boolean invokeGetInternalPublicMethods(Class<?> type, Map<Object, Method> collectedMethods)\n            throws Throwable {\n        MethodHandle methodHandle = MethodHandles.privateLookupIn(MethodUtil.class, MethodHandles.lookup())\n                .findStatic(\n                        MethodUtil.class,\n                        \"getInternalPublicMethods\",\n                        MethodType.methodType(boolean.class, Class.class, Map.class));\n        return (boolean) methodHandle.invoke(type, collectedMethods);\n    }\n\n    private static Method findMethodByName(Collection<Method> methods, String name) {\n        return methods.stream()\n                .filter(method -> method.getName().equals(name))\n                .findFirst()\n                .orElseThrow();\n    }\n\n    private static List<String> methodNames(Collection<Method> methods) {\n        return methods.stream()\n                .map(Method::getName)\n                .toList();\n    }\n\n    static class PackagePrivateBase {\n        public String inheritedValue() {\n            return \"base\";\n        }\n    }\n\n    public static final class PublicChild extends PackagePrivateBase {\n        public String declaredValue() {\n            return \"child\";\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777379883427}, {"role": "toolResult", "toolCallId": "call_zNcvoeE7qpMFOFFT2hCPDfAB|fc_064a42178e280c330169f0aa2b1238819fa5c6c2538a89a285", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_openjfx.javafx_base;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport com.sun.javafx.reflect.ConstructorUtil;\nimport java.lang.reflect.Constructor;\nimport java.util.Arrays;\nimport java.util.List;\nimport org.junit.jupiter.api.Test;\n\npublic class ConstructorUtilTest {\n\n    @Test\n    void getConstructorFindsMatchingPublicConstructor() throws Exception {\n        Constructor<?> constructor = ConstructorUtil.getConstructor(\n                ConstructorUtilSample.class,\n                new Class<?>[] {String.class, int.class});\n\n        assertThat(constructor.getDeclaringClass()).isEqualTo(ConstructorUtilSample.class);\n        assertThat(constructor.getParameterTypes()).containsExactly(String.class, int.class);\n    }\n\n    @Test\n    void getConstructorsReturnsAllPublicConstructors() {\n        Constructor<?>[] constructors = ConstructorUtil.getConstructors(ConstructorUtilSample.class);\n\n        List<List<Class<?>>> parameterTypes = Arrays.stream(constructors)\n                .map(Constructor::getParameterTypes)\n                .map(Arrays::asList)\n                .toList();\n\n        assertThat(parameterTypes)\n                .containsExactlyInAnyOrder(\n                        List.of(),\n                        List.of(String.class),\n                        List.of(String.class, int.class));\n    }\n}\n\nfinal class ConstructorUtilSample {\n\n    public ConstructorUtilSample() {}\n\n    public ConstructorUtilSample(String name) {}\n\n    public ConstructorUtilSample(String name, int priority) {}\n\n    ConstructorUtilSample(int hidden) {}\n}\n"}], "isError": false, "timestamp": 1777379883428}]}
