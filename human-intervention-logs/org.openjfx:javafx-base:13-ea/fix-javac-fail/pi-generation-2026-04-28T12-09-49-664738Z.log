, "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_openjfx.javafx_base;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.beans.PropertyChangeListener;\nimport java.beans.PropertyChangeSupport;\nimport java.util.ArrayList;\nimport java.util.List;\nimport javafx.beans.property.adapter.ReadOnlyJavaBeanStringProperty;\nimport javafx.beans.property.adapter.ReadOnlyJavaBeanStringPropertyBuilder;\nimport org.junit.jupiter.api.Test;\n\npublic class ReadOnlyPropertyDescriptorTest {\n\n    @Test\n    void usesNamedPropertyChangeListenerMethodsWhenAvailable() throws Exception {\n        NamedPropertyChangeBean bean = new NamedPropertyChangeBean();\n        ReadOnlyJavaBeanStringProperty property = ReadOnlyJavaBeanStringPropertyBuilder.create()\n                .bean(bean)\n                .name(\"value\")\n                .build();\n        List<String> observedValues = new ArrayList<>();\n        property.addListener((observable, oldValue, newValue) -> observedValues.add(oldValue + \"->\" + newValue));\n\n        try {\n            assertThat(property.get()).isEqualTo(\"before\");\n            assertThat(bean.addedPropertyNames).containsExactly(\"value\");\n            assertThat(bean.addedListeners).hasSize(1);\n            assertThat(bean.removedPropertyNames).isEmpty();\n            assertThat(bean.removedListeners).isEmpty();\n\n            bean.setValue(\"after\");\n\n            assertThat(property.get()).isEqualTo(\"after\");\n            assertThat(observedValues).containsExactly(\"before->after\");\n        } finally {\n            property.dispose();\n        }\n\n        assertThat(bean.removedPropertyNames).containsExactly(\"value\");\n        assertThat(bean.removedListeners).containsExactly(bean.addedListeners.get(0));\n    }\n\n    @Test\n    void fallsBackToUnnamedPropertyChangeListenerMethods() throws Exception {\n        UnnamedPropertyChangeBean bean = new UnnamedPropertyChangeBean();\n        ReadOnlyJavaBeanStringProperty property = ReadOnlyJavaBeanStringPropertyBuilder.create()\n                .bean(bean)\n                .name(\"value\")\n                .build();\n        List<String> observedValues = new ArrayList<>();\n        property.addListener((observable, oldValue, newValue) -> observedValues.add(oldValue + \"->\" + newValue));\n\n        try {\n            assertThat(property.get()).isEqualTo(\"before\");\n            assertThat(bean.addedListeners).hasSize(1);\n            assertThat(bean.removedListeners).isEmpty();\n\n            bean.setValue(\"after\");\n\n            assertThat(property.get()).isEqualTo(\"after\");\n            assertThat(observedValues).containsExactly(\"before->after\");\n        } finally {\n            property.dispose();\n        }\n\n        assertThat(bean.removedListeners).containsExactly(bean.addedListeners.get(0));\n    }\n\n    public static final class NamedPropertyChangeBean {\n        private final List<String> addedPropertyNames = new ArrayList<>();\n        private final List<PropertyChangeListener> addedListeners = new ArrayList<>();\n        private final List<String> removedPropertyNames = new ArrayList<>();\n        private final List<PropertyChangeListener> removedListeners = new ArrayList<>();\n        private final PropertyChangeSupport propertyChangeSupport = new PropertyChangeSupport(this);\n        private String value = \"before\";\n\n        public String getValue() {\n            return value;\n        }\n\n        public void setValue(String value) {\n            String oldValue = this.value;\n            this.value = value;\n            propertyChangeSupport.firePropertyChange(\"value\", oldValue, value);\n        }\n\n        public void addPropertyChangeListener(String propertyName, PropertyChangeListener listener) {\n            addedPropertyNames.add(propertyName);\n            addedListeners.add(listener);\n            propertyChangeSupport.addPropertyChangeListener(propertyName, listener);\n        }\n\n        public void removePropertyChangeListener(String propertyName, PropertyChangeListener listener) {\n            removedPropertyNames.add(propertyName);\n            removedListeners.add(listener);\n            propertyChangeSupport.removePropertyChangeListener(propertyName, listener);\n        }\n    }\n\n    public static final class UnnamedPropertyChangeBean {\n        private final List<PropertyChangeListener> addedListeners = new ArrayList<>();\n        private final List<PropertyChangeListener> removedListeners = new ArrayList<>();\n        private final PropertyChangeSupport propertyChangeSupport = new PropertyChangeSupport(this);\n        private String value = \"before\";\n\n        public String getValue() {\n            return value;\n        }\n\n        public void setValue(String value) {\n            String oldValue = this.value;\n            this.value = value;\n            propertyChangeSupport.firePropertyChange(\"value\", oldValue, value);\n        }\n\n        public void addPropertyChangeListener(PropertyChangeListener listener) {\n            addedListeners.add(listener);\n            propertyChangeSupport.addPropertyChangeListener(listener);\n        }\n\n        public void removePropertyChangeListener(PropertyChangeListener listener) {\n            removedListeners.add(listener);\n            propertyChangeSupport.removePropertyChangeListener(listener);\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.4", "usage": {"input": 253, "output": 1953, "cacheRead": 33408, "cacheWrite": 0, "totalTokens": 35614, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777378154764, "responseId": "resp_075cc84c847df3090169f0a36b37dc81929f513c9ff3a3804d"}, "toolResults": [{"ro