  public class DHParameter
      extends ASN1Object
  {
      ASN1Integer      p, g, l;
  
      public DHParameter(
          BigInteger  p,
          BigInteger  g,
          int         l)
      {
          this.p = new ASN1Integer(p);
          this.g = new ASN1Integer(g);
  
          if (l != 0)
          {
              this.l = new ASN1Integer(l);
          }
