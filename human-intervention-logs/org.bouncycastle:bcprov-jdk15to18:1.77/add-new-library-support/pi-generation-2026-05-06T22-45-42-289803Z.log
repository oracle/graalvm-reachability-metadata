  import org.junit.jupiter.api.Test;
  
  public class JournaledAlgorithmTest {
      private static final ASN1ObjectIdentifier TEST_ALGORITHM = new ASN1ObjectIdentifier("1.2.840.113549.3.7");
  
      @Test
      public void serializesAndDeserializesJournaledAlgorithmState() throws Exception {
          AlgorithmIdentifier algorithmIdentifier = new AlgorithmIdentifier(TEST_ALGORITHM);
          JournalingSecureRandom journaling = new JournalingSecureRandom(new CountingSecureRandom());
          byte[] generatedBytes = new byte[32];
          journaling.nextBytes(generatedBytes);
          JournaledAlgorithm journaledAlgorithm = new JournaledAlgorithm(algorithmIdentifier, journaling);
  
          SerializationResult serialized = serialize(journaledAlgorithm);
          DeserializationResult deserialized = deserialize(serialized.bytes());
          JournaledAlgorithm restored = deserialized.journaledAlgorithm();
  
          assertThat(serialized.encodedState()).isEqualTo(journaledAlgorithm.getEncoded());
          assertThat(deserialized.encodedState()).isEqualTo(journaledAlgorithm.getEncoded());
          assertThat(restored.getAlgorithmIdentifier().getEncoded()).isEqualTo(algorithmIdentifier.getEncoded());
          assertThat(restored.getEncoded()).isEqualTo(journaledAlgorithm.getEncoded());
          byte[] replayedBytes = new byte[generatedBytes.length];
          restored.getJournalingSecureRandom().nextBytes(replayedBytes);
          assertThat(replayedBytes).isEqualTo(generatedBytes);
      }
  
      private static SerializationResult serialize(JournaledAlgorithm journaledAlgorithm) throws IOException {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (RecordingObjectOutputStream out = new RecordingObjectOutputStream(bytes)) {
