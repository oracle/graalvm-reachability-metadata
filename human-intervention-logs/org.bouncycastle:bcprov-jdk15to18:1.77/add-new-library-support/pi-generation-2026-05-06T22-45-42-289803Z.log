      private record SerializationResult(byte[] bytes, byte[] encodedState) {
      }
  
      private record DeserializationResult(JournaledAlgorithm journaledAlgorithm, byte[] encodedState) {
      }
  
      private static final class RecordingObjectOutputStream extends ObjectOutputStream {
          private byte[] encodedState;
  
          private RecordingObjectOutputStream(ByteArrayOutputStream out) throws IOException {
              super(out);
              enableReplaceObject(true);
          }
  
          @Override
          protected Object replaceObject(Object object) throws IOException {
              if (object instanceof byte[] bytes) {
