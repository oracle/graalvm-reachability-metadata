          }
      }
  
      private static final class RecordingObjectInputStream extends ObjectInputStream {
          private byte[] encodedState;
  
          private RecordingObjectInputStream(ByteArrayInputStream in) throws IOException {
              super(in);
              enableResolveObject(true);
          }
  
