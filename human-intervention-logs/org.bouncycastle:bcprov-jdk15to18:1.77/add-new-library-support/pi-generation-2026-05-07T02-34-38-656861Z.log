ncycastle.crypto.util.JournaledAlgorithm;\nimport org.bouncycastle.crypto.util.JournalingSecureRandom;\nimport org.junit.jupiter.api.Test;\n\npublic class JournaledAlgorithmTest {\n    private static final ASN1ObjectIdentifier TEST_ALGORITHM = new ASN1ObjectIdentifier(\"1.2.840.113549.3.7\");\n\n    @Test\n    public void serializesAndDeserializesJournaledAlgorithmState() throws Exception {\n        AlgorithmIdentifier algorithmIdentifier = new AlgorithmIdentifier(TEST_ALGORITHM);\n        JournalingSecureRandom journaling = new JournalingSecureRandom(new CountingSecureRandom());\n        byte[] generatedBytes = new byte[32];\n        journaling.nextBytes(generatedBytes);\n        JournaledAlgorithm journaledAlgorithm = new JournaledAlgorithm(algorithmIdentifier, journaling);\n\n        SerializationResult serialized = serialize(journaledAlgorithm);\n        DeserializationResult deserialized = deserialize(serialized.bytes());\n        JournaledAlgorithm restored = deserialized.journaledAlgorithm();\n\n        assertThat(serialized.encodedState()).isEqualTo(journaledAlgorithm.getEncoded());\n        assertThat(deserialized.encodedState()).isEqualTo(journaledAlgorithm.getEncoded());\n        assertThat(restored.getAlgorithmIdentifier().getEncoded()).isEqualTo(algorithmIdentifier.getEncoded());\n        assertThat(restored.getEncoded()).isEqualTo(journaledAlgorithm.getEncoded());\n        byte[] replayedBytes = new byte[generatedBytes.length];\n        restored.getJournalingSecureRandom().nextBytes(replayedBytes);\n        assertThat(replayedBytes).isEqualTo(generatedBytes);\n    }\n\n    private static SerializationResult serialize(JournaledAlgorithm journaledAlgorithm) throws IOException {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (RecordingObjectOutputStream out = new RecordingObjectOutputStream(bytes)) {\n            out.writeObject(journaledAlgorithm);\n            out.flush();\n            return new SerializationResult(bytes.toByteArray(), out.getEncodedState());\n        }\n    }\n\n    private static DeserializationResult deserialize(byte[] bytes) throws IOException, ClassNotFoundException {\n        try (RecordingObjectInputStream in = new RecordingObjectInputStream(new ByteArrayInputStream(bytes))) {\n            JournaledAlgorithm journaledAlgorithm = (JournaledAlgorithm) in.readObject();\n            return new DeserializationResult(journaledAlgorithm, in.getEncodedState());\n        }\n    }\n\n    private record SerializationResult(byte[] bytes, byte[] encodedState) {\n    }\n\n    private record DeserializationResult(JournaledAlgorithm journaledAlgorithm, byte[] encodedState) {\n    }\n\n    private static final class RecordingObjectOutputStream extends ObjectOutputStream {\n        private byte[] encodedState;\n\n        private RecordingObjectOutputStream(ByteArrayOutputStream out) throws IOException {\n            super(out);\n            enableReplaceObject(true);\n        }\n\n        @Override\n        protected Object replaceObject(Object object) throws IOException {\n            if (object instanceof byte[] bytes) {\n                encodedState = bytes.clone();\n            }\n            return super.replaceObject(object);\n        }\n\n        private byte[] getEncodedState() {\n            return encodedState == null ? null : encodedState.clone();\n        }\n    }\n\n    private static final class RecordingObjectInputStream extends ObjectInputStream {\n        private byte[] encodedState;\n\n        private RecordingObjectInputStream(ByteArrayInputStream in) throws IOException {\n            super(in);\n            enableResolveObject(true);\n        }\n\n        @Override\n        protected Object resolveObject(Object object) throws IOException {\n            if (object instanceof byte[] bytes) {\n                encodedState = bytes.clone();\n            }\n            return super.resolveObject(object);\n        }\n\n        private byte[] getEncodedState() {\n            return encodedState == null ? null : encodedState.clone();\n        }\n    }\n\n    private static final class CountingSecureRandom extends SecureRandom {\n        private static final long serialVersionUID = 1L;\n\n        private int nextByte;\n\n        @Override\n        public void nextBytes(byte[] bytes) {\n            for (int i = 0; i < bytes.length; i++) {\n                bytes[i] = (byte) nextByte++;\n            }\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778121249100}]}
