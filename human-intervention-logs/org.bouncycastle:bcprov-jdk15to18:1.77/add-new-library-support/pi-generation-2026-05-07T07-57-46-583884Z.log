  package org_bouncycastle.bcprov_jdk15to18;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.security.spec.AlgorithmParameterSpec;
  
  import org.bouncycastle.pqc.jcajce.provider.util.SpecUtil;
  import org.junit.jupiter.api.Test;
  
  public class SpecUtilAnonymous1Test {
      @Test
      public void returnsNameFromParameterSpecPublicAccessor() {
          NamedParameterSpec parameterSpec = new NamedParameterSpec("Falcon-512");
  
          String name = SpecUtil.getNameFrom(parameterSpec);
  
          assertThat(name).isEqualTo("Falcon-512");
      }
  
      public static final class NamedParameterSpec implements AlgorithmParameterSpec {
          private final String name;
  
          public NamedParameterSpec(String name) {
              this.name = name;
          }
  
          public String getName() {
              return name;
          }
