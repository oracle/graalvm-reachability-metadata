  package org_bouncycastle.bcprov_jdk15to18;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  
  import org.bouncycastle.pqc.crypto.sphincsplus.SPHINCSPlusParameters;
  import org.bouncycastle.pqc.crypto.sphincsplus.SPHINCSPlusPrivateKeyParameters;
  import org.bouncycastle.pqc.jcajce.provider.sphincsplus.BCSPHINCSPlusPrivateKey;
  import org.junit.jupiter.api.Test;
  
  public class BCSPHINCSPlusPrivateKeyTest {
      private static final int N = 16;
  
      @Test
      public void serializesAndDeserializesShake128fPrivateKey() throws Exception {
          BCSPHINCSPlusPrivateKey privateKey = createShake128fPrivateKey();
  
          byte[] serializedKey = serialize(privateKey);
          BCSPHINCSPlusPrivateKey restoredKey = deserialize(serializedKey);
  
          assertThat(restoredKey).isEqualTo(privateKey);
          assertThat(restoredKey.hashCode()).isEqualTo(privateKey.hashCode());
          assertThat(restoredKey.getAlgorithm()).isEqualTo("SPHINCS+");
          assertThat(restoredKey.getFormat()).isEqualTo("PKCS#8");
          assertThat(restoredKey.getEncoded()).isEqualTo(privateKey.getEncoded());
          assertThat(restoredKey.getPublicKey().getEncoded()).isEqualTo(privateKey.getPublicKey().getEncoded());
          assertThat(restoredKey.getParameterSpec().getName()).isEqualTo(SPHINCSPlusParameters.shake_128f.getName());
      }
  
      private static BCSPHINCSPlusPrivateKey createShake128fPrivateKey() {
          SPHINCSPlusPrivateKeyParameters keyParameters = new SPHINCSPlusPrivateKeyParameters(
                  SPHINCSPlusParameters.shake_128f,
                  createBytes(N, 1),
                  createBytes(N, 29),
                  createBytes(N, 61),
                  createBytes(N, 113));
          return new BCSPHINCSPlusPrivateKey(keyParameters);
      }
  
      private static byte[] createBytes(int size, int offset) {
          byte[] bytes = new byte[size];
          for (int index = 0; index < bytes.length; index++) {
              bytes[index] = (byte) (index + offset);
          }
          return bytes;
      }
  
      private static byte[] serialize(BCSPHINCSPlusPrivateKey privateKey) throws Exception {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {
              out.writeObject(privateKey);
          }
          return bytes.toByteArray();
      }
  
      private static BCSPHINCSPlusPrivateKey deserialize(byte[] serializedKey) throws Exception {
          try (ObjectInputStream in = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {
              return (BCSPHINCSPlusPrivateKey) in.readObject();
          }
      }
  }
