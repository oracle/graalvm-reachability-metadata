[tool-call] delta {"path":"tests/src/org.bouncycastle/bcprov-jdk15to18/1.77/src/test/java/org_bouncycastle/bcprov_jdk15to18/BCNTRULPRimePrivateKeyTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk15to18;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\n\nimport org.bouncycastle.pqc.crypto.ntruprime.NTRULPRimeParameters;\nimport org.bouncycastle.pqc.crypto.ntruprime.NTRULPRimePrivateKeyParameters;\nimport org.bouncycastle.pqc.jcajce.provider.ntruprime.BCNTRULPRimePrivateKey;\nimport org.bouncycastle.pqc.jcajce.spec.NTRULPRimeParameterSpec;\nimport org.junit.jupiter.api.Test;\n\npublic class BCNTRULPRimePrivateKeyTest {\n    private static final int NTRULPR_653_ENCA_SIZE = (653 + 3) / 4;\n    private static final int NTRULPR_653_PUBLIC_KEY_SIZE = 897;\n    private static final int NTRULPR_653_RHO_SIZE = 32;\n    private static final int NTRULPR_653_HASH_SIZE = 32;\n\n    @Test\n    public void serializesAndDeserializesNtrulprime653PrivateKey() throws Exception {\n        BCNTRULPRimePrivateKey privateKey = createNtrulprime653PrivateKey();\n\n        byte[] serializedKey = serialize(privateKey);\n        BCNTRULPRimePrivateKey restoredKey = deserialize(serializedKey);\n\n        assertThat(restoredKey).isEqualTo(privateKey);\n        assertThat(restoredKey.hashCode()).isEqualTo(privateKey.hashCode());\n        assertThat(restoredKey.getAlgorithm()).isEqualTo(\"NTRULPRime\");\n        assertThat(restoredKey.getFormat()).isEqualTo(\"PKCS#8\");\n        assertThat(restoredKey.getEncoded()).isEqualTo(privateKey.getEncoded());\n        assertThat(restoredKey.getParameterSpec().getName()).isEqualTo(NTRU