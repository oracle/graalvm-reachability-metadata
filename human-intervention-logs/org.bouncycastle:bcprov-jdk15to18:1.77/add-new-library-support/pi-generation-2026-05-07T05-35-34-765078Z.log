dKey.hashCode()).isEqualTo(privateKey.hashCode());\n        assertThat(restoredKey.getAlgorithm()).isEqualTo(\"NTRULPRime\");\n        assertThat(restoredKey.getFormat()).isEqualTo(\"PKCS#8\");\n        assertThat(restoredKey.getEncoded()).isEqualTo(privateKey.getEncoded());\n        assertThat(restoredKey.getParameterSpec().getName()).isEqualTo(NTRULPRimeParameterSpec.ntrulpr653.getName());\n    }\n\n    private static BCNTRULPRimePrivateKey createNtrulprime653PrivateKey() {\n        NTRULPRimePrivateKeyParameters keyParameters = new NTRULPRimePrivateKeyParameters(\n                NTRULPRimeParameters.ntrulpr653,\n                createBytes(NTRULPR_653_ENCA_SIZE, 1),\n                createBytes(NTRULPR_653_PUBLIC_KEY_SIZE, 17),\n                createBytes(NTRULPR_653_RHO_SIZE, 31),\n                createBytes(NTRULPR_653_HASH_SIZE, 47));\n        return new BCNTRULPRimePrivateKey(keyParameters);\n    }\n\n    private static byte[] createBytes(int size, int offset) {\n        byte[] bytes = new byte[size];\n        for (int index = 0; index < bytes.length; index++) {\n            bytes[index] = (byte) (index + offset);\n        }\n        return bytes;\n    }\n\n    private static byte[] serialize(BCNTRULPRimePrivateKey privateKey) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {\n            out.writeObject(privateKey);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static BCNTRULPRimePrivateKey deserialize(byte[] serializedKey) throws Exception {\n        try (ObjectInputStream in = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {\n            return (BCNTRULPRimePrivateKey) in.readObject();\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 563, "output": 1117, "cacheRead": 20480, "cacheWrite": 0, "totalTokens": 22160, "cost": {"input": 0, "output": 