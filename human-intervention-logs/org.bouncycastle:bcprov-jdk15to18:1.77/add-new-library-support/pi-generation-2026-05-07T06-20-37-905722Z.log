 not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk15to18;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\n\nimport org.bouncycastle.pqc.crypto.rainbow.RainbowParameters;\nimport org.bouncycastle.pqc.crypto.rainbow.RainbowPublicKeyParameters;\nimport org.bouncycastle.pqc.jcajce.provider.rainbow.BCRainbowPublicKey;\nimport org.bouncycastle.pqc.jcajce.spec.RainbowParameterSpec;\nimport org.junit.jupiter.api.Test;\n\npublic class BCRainbowPublicKeyTest {\n    private static final int RAINBOW_III_CLASSIC_PUBLIC_KEY_SIZE = 882_080;\n\n    @Test\n    public void serializesAndDeserializesRainbowIIIClassicPublicKey() throws Exception {\n        BCRainbowPublicKey publicKey = createRainbowIIIClassicPublicKey();\n\n        byte[] serializedKey = serialize(publicKey);\n        BCRainbowPublicKey restoredKey = deserialize(serializedKey);\n\n        assertThat(restoredKey).isEqualTo(publicKey);\n        assertThat(restoredKey.hashCode()).isEqualTo(publicKey.hashCode());\n        assertThat(restoredKey.getAlgorithm()).isEqualTo(\"RAINBOW-III-CLASSIC\");\n        assertThat(restoredKey.getFormat()).isEqualTo(\"X.509\");\n        assertThat(restoredKey.getEncoded()).isEqualTo(publicKey.getEncoded());\n        assertThat(restoredKey.getParameterSpec().getName())\n                .isEqualTo(RainbowParameterSpec.rainbowIIIclassic.getName());\n    }\n\n    private static BCRainbowPublicKey createRainbowIIIClassicPublicKey() {\n        RainbowPublicKeyParameters keyParameters = new RainbowPublicKeyParameters(\n                RainbowParameters.rainbowIIIclassic,\n                createBytes(RAINBOW_III_CLASSIC_PUBLIC_KEY_SIZE, 1));\n        return new BCRainbowPublicKey(keyParameters);\n    }\n\n    private static byte[] createBytes(int size, int offset) {\n        byte[] bytes = new byte[size];\n        for (int index = 0; index < bytes.length; index++) {\n            bytes[index] = (byte) (index + offset);\n        }\n        return bytes;\n    }\n\n    private static byte[] serialize(BCRainbowPublicKey publicKey) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {\n            out.writeObject(publicKey);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static BCRainbowPublicKey deserialize(byte[] serializedKey) throws Exception {\n        try (ObjectInputStream in = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {\n            return (BCRainbowPublicKey) in.readObject();\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1423, "output": 1170, "cacheRead": 23552, "cacheWrite": 0, "totalTokens": 26145, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778134795057, "responseId": "resp_0462bef3afae75050169fc2f0b8c308192b1819ed4b1c1de0d"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_hPFzcwA20pkHfCaj67Eap9bN|fc_0462bef3afae75050169fc2f122d68819280f3f9d217dbd256", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2847 bytes to tests/src/org.bouncycastle/bcprov-jdk15to18/1.77/src/test/java/org_bouncycastle/bcprov_jdk15to18/BCRainbowPublicKeyTest.java"}], "isError": false, "timestamp": 1778134806353}]}
