pySource get(int bitsRequired) {\n            REQUESTS.incrementAndGet();\n            return new FixedEntropySource(bitsRequired);\n        }\n\n        private static final class FixedEntropySource implements EntropySource {\n            private final int bitsRequired;\n\n            private FixedEntropySource(int bitsRequired) {\n                this.bitsRequired = bitsRequired;\n            }\n\n            @Override\n            public boolean isPredictionResistant() {\n                return true;\n            }\n\n            @Override\n            public byte[] getEntropy() {\n                int call = ENTROPY_CALLS.incrementAndGet();\n                byte[] entropy = new byte[(bitsRequired + 7) / 8];\n                for (int i = 0; i < entropy.length; i++) {\n                    entropy[i] = (byte)(call + i);\n                }\n                return entropy;\n            }\n\n            @Override\n            public int entropySize() {\n                return bitsRequired;\n            }\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778140157241}}
