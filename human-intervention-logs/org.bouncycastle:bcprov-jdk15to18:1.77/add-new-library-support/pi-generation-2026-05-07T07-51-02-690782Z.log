[tool-call] delta {"path":"tests/src/org.bouncycastle/bcprov-jdk15to18/1.77/src/test/java/org_bouncycastle/bcprov_jdk15to18/DRBGAnonymous4Test.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk15to18;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.security.Provider;\nimport java.security.SecureRandom;\nimport java.security.Security;\n\nimport org.bouncycastle.jce.provider.BouncyCastleProvider;\nimport org.junit.jupiter.api.Test;\n\npublic class DRBGAnonymous4Test {\n    private static final String SECURE_RANDOM_SOURCE = \"securerandom.source\";\n    private static final String STRONG_ALGORITHMS = \"securerandom.strongAlgorithms\";\n\n    @Test\n    public void createsDefaultSecureRandomThroughStrongInstanceLookup() throws Exception {\n        String originalSource = Security.getProperty(SECURE_RANDOM_SOURCE);\n        String originalStrongAlgorithms = Security.getProperty(STRONG_ALGORITHMS);\n\n        try {\n            Security.setProperty(SECURE_RANDOM_SOURCE, \"not-a-valid-url\");\n            Security.setProperty(STRONG_ALGORITHMS, \"UnavailableSecureRandom:UnavailableProvider\");\n\n            Provider provider = new BouncyCastleProvider();\n            SecureRandom random = SecureRandom.getInstance(\"DEFAULT\", provider);\n\n            byte[] generated = new byte[32];\n            random.nextBytes(generated);\n\n            assertThat(generated).hasSize(32);\n            assertThat(random.generateSeed(16)).hasSize(16);\n        } finally {\n            restoreSecurityProperty(SECURE_RANDOM_SOURCE, originalSource);\n            restoreSecurityProperty(STRONG_ALGORITHMS, originalStrongAlgorithms);\n        }\n    }\n\n    private static void restoreSecurityProperty(String name, String value) {\n        if (value == null) {\