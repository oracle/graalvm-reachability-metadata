  package org_bouncycastle.bcprov_jdk15to18;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.security.Provider;
  import java.security.SecureRandom;
  import java.security.Security;
  import java.util.concurrent.atomic.AtomicInteger;
  
  import org.bouncycastle.crypto.prng.EntropySource;
  import org.bouncycastle.crypto.prng.EntropySourceProvider;
  import org.bouncycastle.jce.provider.BouncyCastleProvider;
  import org.junit.jupiter.api.Test;
  
  public class DRBGAnonymous6Test {
      private static final String ENTROPY_SOURCE_PROPERTY = "org.bouncycastle.drbg.entropysource";
  
      @Test
      public void createsSecureRandomFromConfiguredEntropySourceProvider() throws Exception {
          String originalSystemProperty = System.getProperty(ENTROPY_SOURCE_PROPERTY);
          String originalSecurityProperty = Security.getProperty(ENTROPY_SOURCE_PROPERTY);
  
          CountingEntropySourceProvider.reset();
          try {
              setEntropySourceProviderProperty(originalSecurityProperty);
  
              Provider provider = new BouncyCastleProvider();
              assertGeneratesBytes(SecureRandom.getInstance("DEFAULT", provider));
              assertGeneratesBytes(SecureRandom.getInstance("NONCEANDIV", provider));
  
              assertThat(CountingEntropySourceProvider.instanceCount()).isPositive();
              assertThat(CountingEntropySourceProvider.requestCount()).isPositive();
          } finally {
              restoreEntropySourceProviderProperty(originalSystemProperty, originalSecurityProperty);
          }
      }
  
      private static void setEntropySourceProviderProperty(String originalSecurityProperty) {
          String providerClassName = CountingEntropySourceProvider.class.getName();
          if (originalSecurityProperty == null) {
              System.setProperty(ENTROPY_SOURCE_PROPERTY, providerClassName);
          } else {
              Security.setProperty(ENTROPY_SOURCE_PROPERTY, providerClassName);
          }
      }
  
      private static void restoreEntropySourceProviderProperty(
          String originalSystemProperty,
          String originalSecurityProperty) {
          if (originalSystemProperty == null) {
              System.clearProperty(ENTROPY_SOURCE_PROPERTY);
          } else {
              System.setProperty(ENTROPY_SOURCE_PROPERTY, originalSystemProperty);
          }
  
          if (originalSecurityProperty != null) {
              Security.setProperty(ENTROPY_SOURCE_PROPERTY, originalSecurityProperty);
          }
      }
  
      private static void assertGeneratesBytes(SecureRandom random) {
          byte[] generated = new byte[32];
          random.nextBytes(generated);
  
          assertThat(generated).hasSize(32);
          assertThat(random.generateSeed(16)).hasSize(16);
      }
  
      public static final class CountingEntropySourceProvider implements EntropySourceProvider {
          private static final AtomicInteger INSTANCES = new AtomicInteger();
          private static final AtomicInteger REQUESTS = new AtomicInteger();
          private static final AtomicInteger ENTROPY_CALLS = new AtomicInteger();
  
          public CountingEntropySourceProvider() {
              INSTANCES.incrementAndGet();
          }
  
          static void reset() {
              INSTANCES.set(0);
              REQUESTS.set(0);
              ENTROPY_CALLS.set(0);
          }
  
          static int instanceCount() {
              return INSTANCES.get();
          }
  
          static int requestCount() {
              return REQUESTS.get();
          }
  
          @Override
          public EntropySource get(int bitsRequired) {
              REQUESTS.incrementAndGet();
              return new FixedEntropySource(bitsRequired);
          }
  
          private static final class FixedEntropySource implements EntropySource {
              private final int bitsRequired;
  
              private FixedEntropySource(int bitsRequired) {
                  this.bitsRequired = bitsRequired;
              }
  
              @Override
              public boolean isPredictionResistant() {
                  return true;
              }
  
              @Override
              public byte[] getEntropy() {
                  int call = ENTROPY_CALLS.incrementAndGet();
                  byte[] entropy = new byte[(bitsRequired + 7) / 8];
                  for (int i = 0; i < entropy.length; i++) {
                      entropy[i] = (byte)(call + i);
                  }
                  return entropy;
              }
  
              @Override
              public int entropySize() {
                  return bitsRequired;
              }
          }
      }
  }
