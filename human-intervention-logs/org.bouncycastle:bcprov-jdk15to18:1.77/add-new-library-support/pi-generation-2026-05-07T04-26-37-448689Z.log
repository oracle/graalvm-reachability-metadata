  diff --git 1/tests/src/org.bouncycastle/bcprov-jdk15to18/1.77/src/test/java/org_bouncycastle/bcprov_jdk15to18/BCLMSPublicKeyTest.java 2/tests/src/org.bouncycastle/bcprov-jdk15to18/1.77/src/test/java/org_bouncycastle/bcprov_jdk15to18/BCLMSPublicKeyTest.java
  new file mode 100644
  index 0000000000..afd803ca9f
  --- /dev/null
  +++ 2/tests/src/org.bouncycastle/bcprov-jdk15to18/1.77/src/test/java/org_bouncycastle/bcprov_jdk15to18/BCLMSPublicKeyTest.java
  @@ -0,0 +1,72 @@
  +/*
  + * Copyright and related rights waived via CC0
  + *
  + * You should have received a copy of the CC0 legalcode along with this
  + * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.
  + */
  +package org_bouncycastle.bcprov_jdk15to18;
  +
  +import static org.assertj.core.api.Assertions.assertThat;
  +
  +import java.io.ByteArrayInputStream;
  +import java.io.ByteArrayOutputStream;
  +import java.io.ObjectInputStream;
  +import java.io.ObjectOutputStream;
  +
  +import org.bouncycastle.pqc.crypto.lms.LMOtsParameters;
  +import org.bouncycastle.pqc.crypto.lms.LMSPublicKeyParameters;
  +import org.bouncycastle.pqc.crypto.lms.LMSigParameters;
  +import org.bouncycastle.pqc.jcajce.provider.lms.BCLMSPublicKey;
  +import org.junit.jupiter.api.Test;
  +
  +public class BCLMSPublicKeyTest {
  +    private static final int LMS_IDENTIFIER_SIZE = 16;
  +    private static final int LMS_SHA256_N24_PUBLIC_KEY_ROOT_SIZE = 24;
  +
  +    @Test
  +    public void serializesAndDeserializesSha256N24H5PublicKey() throws Exception {
  +        BCLMSPublicKey publicKey = createSha256N24H5PublicKey();
  +
  +        byte[] serializedKey = serialize(publicKey);
  +        BCLMSPublicKey restoredKey = deserialize(serializedKey);
  +
  +        assertThat(restoredKey).isEqualTo(publicKey);
  +        assertThat(restoredKey.hashCode()).isEqualTo(publicKey.hashCode());
  +        assertThat(restoredKey.getAlgorithm()).isEqualTo("LMS");
  +        assertThat(restoredKey.getFormat()).isEqualTo("X.509");
  +        assertThat(restoredKey.getEncoded()).isEqualTo(publicKey.getEncoded());
  +        assertThat(restoredKey.getLevels()).isEqualTo(1);
  +    }
  +
  +    private static BCLMSPublicKey createSha256N24H5PublicKey() {
  +        LMSPublicKeyParameters keyParameters = new LMSPublicKeyParameters(
  +                LMSigParameters.lms_sha256_n24_h5,
  +                LMOtsParameters.sha256_n24_w8,
  +                createBytes(LMS_SHA256_N24_PUBLIC_KEY_ROOT_SIZE, 37),
  +                createBytes(LMS_IDENTIFIER_SIZE, 83));
  +        return new BCLMSPublicKey(keyParameters);
  +    }
  +
  +    private static byte[] createBytes(int size, int offset) {
  +        byte[] bytes = new byte[size];
  +        for (int index = 0; index < bytes.length; index++) {
  +            bytes[index] = (byte) (index + offset);
  +        }
  +        return bytes;
  +    }
  +
  +    private static byte[] serialize(BCLMSPublicKey publicKey) throws Exception {
  +        ByteArrayOutputStream bytes = new ByteArrayOutputStream();
  +        try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {
  +            out.writeObject(publicKey);
  +        }
  +        return bytes.toByteArray();
  +    }
  +
  +    private static BCLMSPublicKey deserialize(byte[] serializedKey) throws Exception {
  +        ByteArrayInputStream bytes = new ByteArrayInputStream(serializedKey);
  +        try (ObjectInputStream in = new ObjectInputStream(bytes)) {
  +            return (BCLMSPublicKey) in.readObject();
  +        }
  +    }
  +}
