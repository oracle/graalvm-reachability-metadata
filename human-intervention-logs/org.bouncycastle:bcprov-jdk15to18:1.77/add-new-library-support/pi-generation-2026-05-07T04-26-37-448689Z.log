          assertThat(restoredKey.getEncoded()).isEqualTo(publicKey.getEncoded());
          assertThat(restoredKey.getParameterSpec().getName())
                  .isEqualTo(FrodoParameterSpec.frodokem640aes.getName());
      }
  
      private static BCFrodoPublicKey createFrodoKem640AesPublicKey() {
          FrodoPublicKeyParameters keyParameters = new FrodoPublicKeyParameters(
