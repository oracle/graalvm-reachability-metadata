  import org.junit.jupiter.api.Test;
  
  public class BCFrodoPublicKeyTest {
      @Test
      public void serializesAndDeserializesFrodoKem640AesPublicKey() throws Exception {
          BCFrodoPublicKey publicKey = createFrodoKem640AesPublicKey();
  
          byte[] serializedKey = serialize(publicKey);
