      SecureRandom random = null;
      boolean initialised = false;
  
      public KeyPairGeneratorSpi()
      {
          super("DSTU4145");
      }
  
      public void initialize(
          int strength,
          SecureRandom random)
      {
          this.random = random;
  
          if (ecParams != null)
          {
              try
              {
                  initialize((ECGenParameterSpec)ecParams, random);
              }
