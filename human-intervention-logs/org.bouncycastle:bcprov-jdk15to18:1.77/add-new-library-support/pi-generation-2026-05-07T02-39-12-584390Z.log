[tool-call] delta {"path":"tests/src/org.bouncycastle/bcprov-jdk15to18/1.77/src/test/java/org_bouncycastle/bcprov_jdk15to18/BouncyCastlePQCProviderTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk15to18;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.security.Provider;\n\nimport org.bouncycastle.pqc.jcajce.provider.BouncyCastlePQCProvider;\nimport org.junit.jupiter.api.Test;\n\npublic class BouncyCastlePQCProviderTest {\n    @Test\n    public void loadsPostQuantumAlgorithmMappingsDuringConstruction() {\n        BouncyCastlePQCProvider provider = new BouncyCastlePQCProvider();\n\n        assertThat(provider.getName()).isEqualTo(BouncyCastlePQCProvider.PROVIDER_NAME);\n        assertThat(provider.getVersion()).isGreaterThan(0.0);\n        assertThat(provider.hasAlgorithm(\"KeyFactory\", \"KYBER\")).isTrue();\n        assertThat(provider.hasAlgorithm(\"KeyPairGenerator\", \"DILITHIUM\")).isTrue();\n        assertThat(provider.hasAlgorithm(\"Signature\", \"SPHINCSPLUS\")).isTrue();\n        assertThat(provider.getService(\"KeyFactory\", \"KYBER\")).isNotNull();\n        assertThat(provider.getService(\"Cipher\", \"KYBER\")).isNotNull();\n    }\n\n    @Test\n    public void exposesLoadedServicesThroughProviderApi() {\n        Provider provider = new BouncyCastlePQCProvider();\n\n        assertThat(provider.getServices())\n                .extracting(Provider.Service::getAlgorithm)\n                .contains(\"KYBER\", \"DILITHIUM\", \"FALCON\", \"SPHINCSPLUS\");\n    }\n}\n"}
