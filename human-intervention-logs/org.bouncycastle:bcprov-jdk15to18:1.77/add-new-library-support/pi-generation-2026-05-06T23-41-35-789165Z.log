VATE_VALUE);\n        assertThat(restoredKey.getEncoded()).isEqualTo(privateKey.getEncoded());\n        assertThat(restoredKey.getParameters()).isInstanceOf(ECNamedCurveParameterSpec.class);\n        assertThat(restoredKey.getParameters().getN()).isEqualTo(privateKey.getParameters().getN());\n        assertThat(restoredKey.getParameters().getH()).isEqualTo(privateKey.getParameters().getH());\n        assertThat(((ECNamedCurveSpec) restoredKey.getParams()).getName())\n                .isEqualTo(((ECNamedCurveSpec) privateKey.getParams()).getName());\n    }\n\n    private static BCECGOST3410PrivateKey createPrivateKey() {\n        ECNamedCurveParameterSpec curveSpec = ECGOST3410NamedCurveTable.getParameterSpec(CURVE_NAME);\n        assertThat(curveSpec).isNotNull();\n        return new BCECGOST3410PrivateKey(new ECPrivateKeySpec(PRIVATE_VALUE, curveSpec));\n    }\n\n    private static byte[] serialize(BCECGOST3410PrivateKey privateKey) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {\n            out.writeObject(privateKey);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static BCECGOST3410PrivateKey deserialize(byte[] serializedKey) throws Exception {\n        try (ObjectInputStream in = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {\n            return (BCECGOST3410PrivateKey) in.readObject();\n        }\n    }\n}\n"}
