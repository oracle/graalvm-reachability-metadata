rt org.bouncycastle.jce.spec.ECNamedCurveSpec;\nimport org.bouncycastle.jce.spec.ECPrivateKeySpec;\nimport org.junit.jupiter.api.Test;\n\npublic class BCDSTU4145PrivateKeyTest {\n    private static final BigInteger PRIVATE_VALUE = BigInteger.valueOf(42);\n\n    @Test\n    public void serializesAndDeserializesDstu4145PrivateKey() throws Exception {\n        BCDSTU4145PrivateKey privateKey = createPrivateKey();\n\n        byte[] serializedKey = serialize(privateKey);\n        BCDSTU4145PrivateKey restoredKey = deserialize(serializedKey);\n\n        assertThat(restoredKey.getAlgorithm()).isEqualTo(\"DSTU4145\");\n        assertThat(restoredKey.getFormat()).isEqualTo(\"PKCS#8\");\n        assertThat(restoredKey.getD()).isEqualTo(PRIVATE_VALUE);\n        assertThat(restoredKey.getS()).isEqualTo(PRIVATE_VALUE);\n        assertThat(restoredKey.getEncoded()).isEqualTo(privateKey.getEncoded());\n        assertThat(restoredKey.getParams().getOrder()).isEqualTo(privateKey.getParams().getOrder());\n        assertThat(restoredKey.getParams().getCofactor()).isEqualTo(privateKey.getParams().getCofactor());\n        assertThat(((ECNamedCurveSpec) restoredKey.getParams()).getName())\n                .isEqualTo(((ECNamedCurveSpec) privateKey.getParams()).getName());\n    }\n\n    private static BCDSTU4145PrivateKey createPrivateKey() {\n        ASN1ObjectIdentifier curveOid = DSTU4145NamedCurves.getOIDs()[0];\n        ECDomainParameters domainParameters = DSTU4145NamedCurves.getByOID(curveOid);\n        ECNamedCurveParameterSpec curveSpec = new ECNamedCurveParameterSpec(\n                curveOid.getId(),\n                domainParameters.getCurve(),\n                domainParameters.getG(),\n                domainParameters.getN(),\n                domainParameters.getH(),\n                domainParameters.getSeed());\n        return new BCDSTU4145PrivateKey(new ECPrivateKeySpec(PRIVATE_VALUE, curveSpec));\n    }\n\n    private static byte[] serialize(BCDSTU4145PrivateKey privateKey