toredKey.getX()).isEqualTo(privateKey.getX());\n        assertThat(restoredKey.getEncoded()).isEqualTo(privateKey.getEncoded());\n        assertThat(restoredKey.getParameters().getPublicKeyParamSetOID()).isEqualTo(PARAMETER_SET_OID);\n        assertThat(restoredKey.getParameters().getDigestParamSetOID())\n                .isEqualTo(privateKey.getParameters().getDigestParamSetOID());\n        assertThat(restoredKey.getParameters().getEncryptionParamSetOID())\n                .isEqualTo(privateKey.getParameters().getEncryptionParamSetOID());\n        assertGostParametersMatch(restoredKey.getParameters(), privateKey.getParameters());\n    }\n\n    private static BCGOST3410PrivateKey createPrivateKey() throws Exception {\n        KeyPairGenerator keyPairGenerator = KeyPairGenerator.getInstance(ALGORITHM, new BouncyCastleProvider());\n        keyPairGenerator.initialize(new GOST3410ParameterSpec(PARAMETER_SET_OID), new SecureRandom(new byte[] {1, 2, 3, 4}));\n        KeyPair keyPair = keyPairGenerator.generateKeyPair();\n        assertThat(keyPair.getPrivate()).isInstanceOf(BCGOST3410PrivateKey.class);\n        return (BCGOST3410PrivateKey)keyPair.getPrivate();\n    }\n\n    private static byte[] serialize(BCGOST3410PrivateKey privateKey) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {\n            out.writeObject(privateKey);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static BCGOST3410PrivateKey deserialize(byte[] serializedKey) throws Exception {\n        try (ObjectInputStream in = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {\n            return (BCGOST3410PrivateKey)in.readObject();\n        }\n    }\n\n    private static void assertGostParametersMatch(GOST3410Params actual, GOST3410Params expected) {\n        assertThat(actual.getPublicKeyParameters().getP()).isEqualTo(expected.getPublicKeyParameters().getP());\n        assertThat(actual.getPublicKeyParameters().getQ()).isEqualTo(expected.getPublicKeyParameters().getQ());\n        assertThat(actual.getPublicKeyParameters().getA()).isEqualTo(expected.getPublicKeyParameters().getA());\n    }\n}\n"}
