  package org_bouncycastle.bcprov_jdk15to18;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.IOException;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.security.SecureRandom;
  
  import org.bouncycastle.asn1.ASN1ObjectIdentifier;
  import org.bouncycastle.asn1.x509.AlgorithmIdentifier;
  import org.bouncycastle.crypto.util.JournaledAlgorithm;
  import org.bouncycastle.crypto.util.JournalingSecureRandom;
  import org.junit.jupiter.api.Test;
  
  public class JournaledAlgorithmTest {
      private static final ASN1ObjectIdentifier TEST_ALGORITHM = new ASN1ObjectIdentifier("1.2.840.113549.3.7");
  
      @Test
      public void serializesAndDeserializesJournaledAlgorithmState() throws Exception {
          AlgorithmIdentifier algorithmIdentifier = new AlgorithmIdentifier(TEST_ALGORITHM);
          JournalingSecureRandom journaling = new JournalingSecureRandom(new CountingSecureRandom());
          byte[] generatedBytes = new byte[32];
          journaling.nextBytes(generatedBytes);
          JournaledAlgorithm journaledAlgorithm = new JournaledAlgorithm(algorithmIdentifier, journaling);
  
          SerializationResult serialized = serialize(journaledAlgorithm);
          DeserializationResult deserialized = deserialize(serialized.bytes());
          JournaledAlgorithm restored = deserialized.journaledAlgorithm();
  
          assertThat(serialized.encodedState()).isEqualTo(journaledAlgorithm.getEncoded());
          assertThat(deserialized.encodedState()).isEqualTo(journaledAlgorithm.getEncoded());
          assertThat(restored.getAlgorithmIdentifier().getEncoded()).isEqualTo(algorithmIdentifier.getEncoded());
          assertThat(restored.getEncoded()).isEqualTo(journaledAlgorithm.getEncoded());
          byte[] replayedBytes = new byte[generatedBytes.length];
          restored.getJournalingSecureRandom().nextBytes(replayedBytes);
          assertThat(replayedBytes).isEqualTo(generatedBytes);
      }
  
      private static SerializationResult serialize(JournaledAlgorithm journaledAlgorithm) throws IOException {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (RecordingObjectOutputStream out = new RecordingObjectOutputStream(bytes)) {
              out.writeObject(journaledAlgorithm);
              out.flush();
              return new SerializationResult(bytes.toByteArray(), out.getEncodedState());
          }
      }
  
      private static DeserializationResult deserialize(byte[] bytes) throws IOException, ClassNotFoundException {
          try (RecordingObjectInputStream in = new RecordingObjectInputStream(new ByteArrayInputStream(bytes))) {
              JournaledAlgorithm journaledAlgorithm = (JournaledAlgorithm) in.readObject();
              return new DeserializationResult(journaledAlgorithm, in.getEncodedState());
          }
      }
  
      private record SerializationResult(byte[] bytes, byte[] encodedState) {
      }
  
      private record DeserializationResult(JournaledAlgorithm journaledAlgorithm, byte[] encodedState) {
      }
  
      private static final class RecordingObjectOutputStream extends ObjectOutputStream {
          private byte[] encodedState;
  
          private RecordingObjectOutputStream(ByteArrayOutputStream out) throws IOException {
              super(out);
              enableReplaceObject(true);
          }
  
          @Override
          protected Object replaceObject(Object object) throws IOException {
              if (object instanceof byte[] bytes) {
                  encodedState = bytes.clone();
              }
              return super.replaceObject(object);
          }
  
          private byte[] getEncodedState() {
              return encodedState == null ? null : encodedState.clone();
          }
      }
  
      private static final class RecordingObjectInputStream extends ObjectInputStream {
          private byte[] encodedState;
  
          private RecordingObjectInputStream(ByteArrayInputStream in) throws IOException {
              super(in);
              enableResolveObject(true);
          }
  
          @Override
          protected Object resolveObject(Object object) throws IOException {
              if (object instanceof byte[] bytes) {
                  encodedState = bytes.clone();
              }
              return super.resolveObject(object);
          }
  
          private byte[] getEncodedState() {
              return encodedState == null ? null : encodedState.clone();
          }
      }
  
      private static final class CountingSecureRandom extends SecureRandom {
          private static final long serialVersionUID = 1L;
  
          private int nextByte;
  
          @Override
          public void nextBytes(byte[] bytes) {
              for (int i = 0; i < bytes.length; i++) {
                  bytes[i] = (byte) nextByte++;
              }
          }
      }
  }
