[tool-call] delta {"path":"tests/src/org.bouncycastle/bcprov-jdk15to18/1.77/src/test/java/org_bouncycastle/bcprov_jdk15to18/LocalizedMessageTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk15to18;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.util.Locale;\nimport java.util.TimeZone;\n\nimport org.bouncycastle.i18n.LocalizedMessage;\nimport org.junit.jupiter.api.Test;\n\npublic class LocalizedMessageTest {\n    private static final String BUNDLE_NAME = \"org_bouncycastle.bcprov_jdk15to18.LocalizedMessageMessages\";\n    private static final Locale LOCALE = Locale.ROOT;\n    private static final TimeZone UTC = TimeZone.getTimeZone(\"UTC\");\n\n    @Test\n    public void loadsResourceBundleWithDefaultClassLoader() throws Exception {\n        LocalizedMessage message = new LocalizedMessage(BUNDLE_NAME, \"greeting\", new Object[] {\"Forge\"});\n\n        assertThat(message.getEntry(null, LOCALE, UTC)).isEqualTo(\"Hello Forge\");\n    }\n\n    @Test\n    public void loadsResourceBundleWithExplicitClassLoader() throws Exception {\n        LocalizedMessage message = new LocalizedMessage(BUNDLE_NAME, \"message\");\n        message.setClassLoader(getClass().getClassLoader());\n\n        assertThat(message.getEntry(\"body\", LOCALE, UTC)).isEqualTo(\"Loaded with explicit class loader\");\n    }\n}\n"}
