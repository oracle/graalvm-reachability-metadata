[tool-call] delta {"path":"tests/src/org.bouncycastle/bcprov-jdk15to18/1.77/src/test/java/org_bouncycastle/bcprov_jdk15to18/BCDilithiumPublicKeyTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk15to18;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\n\nimport org.bouncycastle.pqc.crypto.crystals.dilithium.DilithiumParameters;\nimport org.bouncycastle.pqc.crypto.crystals.dilithium.DilithiumPublicKeyParameters;\nimport org.bouncycastle.pqc.jcajce.provider.dilithium.BCDilithiumPublicKey;\nimport org.bouncycastle.pqc.jcajce.spec.DilithiumParameterSpec;\nimport org.junit.jupiter.api.Test;\n\npublic class BCDilithiumPublicKeyTest {\n    private static final int RHO_SIZE = 32;\n    private static final int DILITHIUM2_T1_SIZE = 1280;\n\n    @Test\n    public void serializesAndDeserializesDilithium2PublicKey() throws Exception {\n        BCDilithiumPublicKey publicKey = createDilithium2PublicKey();\n\n        byte[] serializedKey = serialize(publicKey);\n        BCDilithiumPublicKey restoredKey = deserialize(serializedKey);\n\n        assertThat(restoredKey).isEqualTo(publicKey);\n        assertThat(restoredKey.hashCode()).isEqualTo(publicKey.hashCode());\n        assertThat(restoredKey.getAlgorithm()).isEqualTo(\"DILITHIUM2\");\n        assertThat(restoredKey.getFormat()).isEqualTo(\"X.509\");\n        assertThat(restoredKey.getEncoded()).isEqualTo(publicKey.getEncoded());\n        assertThat(restoredKey.getParameterSpec().getName()).isEqualTo(DilithiumParameterSpec.dilithium2.getName());\n    }\n\n    private static BCDilithiumPublicKey createDilithium2PublicKey() {\n        DilithiumPublicKeyParameters keyParameters = new DilithiumPublicKeyParameters(\n                DilithiumParameters.dilithium2,\n                createBytes(RHO_SIZE, 1),\n                createBytes(DILITHIUM2_T1_SIZE, 47));\n        return new BCDilithiumPublicKey(keyParameters);\n    }\n\n    private static byte[] createBytes(int size, int offset) {\n        byte[] bytes = new byte[size];\n        for (int index = 0; index < bytes.length; index++) {\n            bytes[index] = (byte) (index + offset);\n        }\n        return bytes;\n    }\n\n    private static byte[] serialize(BCDilithiumPublicKey publicKey) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {\n            out.writeObject(publicKey);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static BCDilithiumPublicKey deserialize(byte[] serializedKey) throws Exception {\n        try (ObjectInputStream in = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {\n            return (BCDilithiumPublicKey) in.readObject();\n        }\n    }\n}\n"}
