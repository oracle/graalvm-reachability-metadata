[tool-call] delta {"path":"tests/src/org.bouncycastle/bcprov-jdk15to18/1.77/src/test/java/org_bouncycastle/bcprov_jdk15to18/BCXMSSPrivateKeyTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk15to18;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\n\nimport org.bouncycastle.asn1.nist.NISTObjectIdentifiers;\nimport org.bouncycastle.pqc.crypto.xmss.XMSSParameters;\nimport org.bouncycastle.pqc.crypto.xmss.XMSSPrivateKeyParameters;\nimport org.bouncycastle.pqc.jcajce.provider.xmss.BCXMSSPrivateKey;\nimport org.bouncycastle.pqc.jcajce.spec.XMSSParameterSpec;\nimport org.junit.jupiter.api.Test;\n\npublic class BCXMSSPrivateKeyTest {\n    private static final int HEIGHT = 4;\n    private static final int SHA256_DIGEST_SIZE = 32;\n\n    @Test\n    public void serializesAndDeserializesSha256PrivateKey() throws Exception {\n        BCXMSSPrivateKey privateKey = createSha256PrivateKey();\n\n        byte[] serializedKey = serialize(privateKey);\n        BCXMSSPrivateKey restoredKey = deserialize(serializedKey);\n\n        assertThat(restoredKey).isEqualTo(privateKey);\n        assertThat(restoredKey.hashCode()).isEqualTo(privateKey.hashCode());\n        assertThat(restoredKey.getAlgorithm()).isEqualTo(\"XMSS\");\n        assertThat(restoredKey.getFormat()).isEqualTo(\"PKCS#8\");\n        assertThat(restoredKey.getEncoded()).isEqualTo(privateKey.getEncoded());\n        assertThat(restoredKey.getIndex()).isEqualTo(privateKey.getIndex());\n        assertThat(restoredKey.getUsagesRemaining()).isEqualTo(privateKey.getUsagesRemaining());\n        assertThat(restoredKey.getHeight()).isEqualTo(HEIGHT);\n        assertThat(restoredKey.getTreeDigest()).isEqualTo(XMSSParameterSpec.SHA256);\n    }\n\n    private static BCXMSSPrivateKey createSha256PrivateKey() {\n        XMSSParameters parameters = new XMSSParameters(HEIGHT, NISTObjectIdentifiers.id_sha256);\n        XMSSPrivateKeyParameters keyParameters = new XMSSPrivateKeyParameters.Builder(parameters)\n                .withSecretKeySeed(createBytes(SHA256_DIGEST_SIZE, 17))\n                .withSecretKeyPRF(createBytes(SHA256_DIGEST_SIZE, 47))\n                .withPublicSeed(createBytes(SHA256_DIGEST_SIZE, 83))\n                .withRoot(createBytes(SHA256_DIGEST_SIZE, 131))\n                .build();\n        return new BCXMSSPrivateKey(NISTObjectIdentifiers.id_sha256, keyParameters);\n    }\n\n    private static byte[] createBytes(int size, int offset) {\n        byte[] bytes = new byte[size];\n        for (int index = 0; index < bytes.length; index++) {\n            bytes[index] = (byte) (index + offset);\n        }\n        return bytes;\n    }\n\n    private static byte[] serialize(BCXMSSPrivateKey privateKey) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {\n            out.writeObject(privateKey);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static BCXMSSPrivateKey deserialize(byte[] serializedKey) throws Exception {\n        try (ObjectInputStream in = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {\n            return (BCXMSSPrivateKey) in.readObject();\n        }\n    }\n}\n"}
