  package org_bouncycastle.bcprov_jdk15to18;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  
  import org.bouncycastle.asn1.nist.NISTObjectIdentifiers;
  import org.bouncycastle.pqc.crypto.xmss.XMSSMTParameters;
  import org.bouncycastle.pqc.crypto.xmss.XMSSMTPrivateKeyParameters;
  import org.bouncycastle.pqc.jcajce.provider.xmss.BCXMSSMTPrivateKey;
  import org.bouncycastle.pqc.jcajce.spec.XMSSParameterSpec;
  import org.junit.jupiter.api.Test;
  
  public class BCXMSSMTPrivateKeyTest {
      private static final int HEIGHT = 4;
      private static final int LAYERS = 2;
      private static final int SHA256_DIGEST_SIZE = 32;
  
      @Test
      public void serializesAndDeserializesSha256PrivateKey() throws Exception {
          BCXMSSMTPrivateKey privateKey = createSha256PrivateKey();
  
          byte[] serializedKey = serialize(privateKey);
          BCXMSSMTPrivateKey restoredKey = deserialize(serializedKey);
  
          assertThat(restoredKey).isEqualTo(privateKey);
          assertThat(restoredKey.hashCode()).isEqualTo(privateKey.hashCode());
          assertThat(restoredKey.getAlgorithm()).isEqualTo("XMSSMT");
          assertThat(restoredKey.getFormat()).isEqualTo("PKCS#8");
          assertThat(restoredKey.getEncoded()).isEqualTo(privateKey.getEncoded());
          assertThat(restoredKey.getIndex()).isEqualTo(privateKey.getIndex());
          assertThat(restoredKey.getUsagesRemaining()).isEqualTo(privateKey.getUsagesRemaining());
          assertThat(restoredKey.getHeight()).isEqualTo(HEIGHT);
          assertThat(restoredKey.getLayers()).isEqualTo(LAYERS);
          assertThat(restoredKey.getTreeDigest()).isEqualTo(XMSSParameterSpec.SHA256);
      }
  
      private static BCXMSSMTPrivateKey createSha256PrivateKey() {
          XMSSMTParameters parameters = new XMSSMTParameters(HEIGHT, LAYERS, NISTObjectIdentifiers.id_sha256);
          XMSSMTPrivateKeyParameters keyParameters = new XMSSMTPrivateKeyParameters.Builder(parameters)
                  .withSecretKeySeed(createBytes(SHA256_DIGEST_SIZE, 11))
                  .withSecretKeyPRF(createBytes(SHA256_DIGEST_SIZE, 43))
                  .withPublicSeed(createBytes(SHA256_DIGEST_SIZE, 79))
                  .withRoot(createBytes(SHA256_DIGEST_SIZE, 127))
                  .build();
          return new BCXMSSMTPrivateKey(NISTObjectIdentifiers.id_sha256, keyParameters);
      }
  
      private static byte[] createBytes(int size, int offset) {
          byte[] bytes = new byte[size];
          for (int index = 0; index < bytes.length; index++) {
              bytes[index] = (byte) (index + offset);
          }
          return bytes;
      }
  
      private static byte[] serialize(BCXMSSMTPrivateKey privateKey) throws Exception {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {
              out.writeObject(privateKey);
          }
          return bytes.toByteArray();
      }
  
      private static BCXMSSMTPrivateKey deserialize(byte[] serializedKey) throws Exception {
          try (ObjectInputStream in = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {
              return (BCXMSSMTPrivateKey) in.readObject();
          }
      }
  }
