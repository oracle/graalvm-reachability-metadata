  package org_bouncycastle.bcprov_jdk15to18;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  
  import org.bouncycastle.asn1.nist.NISTObjectIdentifiers;
  import org.bouncycastle.pqc.crypto.xmss.XMSSMTParameters;
  import org.bouncycastle.pqc.crypto.xmss.XMSSMTPublicKeyParameters;
  import org.bouncycastle.pqc.jcajce.provider.xmss.BCXMSSMTPublicKey;
  import org.bouncycastle.pqc.jcajce.spec.XMSSParameterSpec;
  import org.junit.jupiter.api.Test;
  
  public class BCXMSSMTPublicKeyTest {
      private static final int HEIGHT = 4;
      private static final int LAYERS = 2;
      private static final int SHA256_DIGEST_SIZE = 32;
  
      @Test
      public void serializesAndDeserializesSha256PublicKey() throws Exception {
          BCXMSSMTPublicKey publicKey = createSha256PublicKey();
  
          byte[] serializedKey = serialize(publicKey);
          BCXMSSMTPublicKey restoredKey = deserialize(serializedKey);
  
          assertThat(restoredKey).isEqualTo(publicKey);
          assertThat(restoredKey.hashCode()).isEqualTo(publicKey.hashCode());
          assertThat(restoredKey.getAlgorithm()).isEqualTo("XMSSMT");
          assertThat(restoredKey.getFormat()).isEqualTo("X.509");
          assertThat(restoredKey.getEncoded()).isEqualTo(publicKey.getEncoded());
          assertThat(restoredKey.getHeight()).isEqualTo(HEIGHT);
          assertThat(restoredKey.getLayers()).isEqualTo(LAYERS);
          assertThat(restoredKey.getTreeDigest()).isEqualTo(XMSSParameterSpec.SHA256);
      }
  
      private static BCXMSSMTPublicKey createSha256PublicKey() {
          XMSSMTParameters parameters = new XMSSMTParameters(HEIGHT, LAYERS, NISTObjectIdentifiers.id_sha256);
          XMSSMTPublicKeyParameters keyParameters = new XMSSMTPublicKeyParameters.Builder(parameters)
                  .withRoot(createBytes(SHA256_DIGEST_SIZE, 17))
                  .withPublicSeed(createBytes(SHA256_DIGEST_SIZE, 61))
                  .build();
          return new BCXMSSMTPublicKey(NISTObjectIdentifiers.id_sha256, keyParameters);
      }
  
      private static byte[] createBytes(int size, int offset) {
          byte[] bytes = new byte[size];
          for (int index = 0; index < bytes.length; index++) {
              bytes[index] = (byte) (index + offset);
          }
          return bytes;
      }
  
      private static byte[] serialize(BCXMSSMTPublicKey publicKey) throws Exception {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {
              out.writeObject(publicKey);
          }
          return bytes.toByteArray();
      }
  
      private static BCXMSSMTPublicKey deserialize(byte[] serializedKey) throws Exception {
          try (ObjectInputStream in = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {
              return (BCXMSSMTPublicKey) in.readObject();
          }
      }
  }
