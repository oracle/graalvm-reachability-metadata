  package org_bouncycastle.bcprov_jdk15to18;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  
  import org.bouncycastle.asn1.nist.NISTObjectIdentifiers;
  import org.bouncycastle.pqc.crypto.xmss.XMSSParameters;
  import org.bouncycastle.pqc.crypto.xmss.XMSSPrivateKeyParameters;
  import org.bouncycastle.pqc.jcajce.provider.xmss.BCXMSSPrivateKey;
  import org.bouncycastle.pqc.jcajce.spec.XMSSParameterSpec;
  import org.junit.jupiter.api.Test;
  
  public class BCXMSSPrivateKeyTest {
      private static final int HEIGHT = 4;
      private static final int SHA256_DIGEST_SIZE = 32;
  
      @Test
      public void serializesAndDeserializesSha256PrivateKey() throws Exception {
          BCXMSSPrivateKey privateKey = createSha256PrivateKey();
  
          byte[] serializedKey = serialize(privateKey);
          BCXMSSPrivateKey restoredKey = deserialize(serializedKey);
  
          assertThat(restoredKey).isEqualTo(privateKey);
          assertThat(restoredKey.hashCode()).isEqualTo(privateKey.hashCode());
          assertThat(restoredKey.getAlgorithm()).isEqualTo("XMSS");
          assertThat(restoredKey.getFormat()).isEqualTo("PKCS#8");
          assertThat(restoredKey.getEncoded()).isEqualTo(privateKey.getEncoded());
          assertThat(restoredKey.getIndex()).isEqualTo(privateKey.getIndex());
          assertThat(restoredKey.getUsagesRemaining()).isEqualTo(privateKey.getUsagesRemaining());
          assertThat(restoredKey.getHeight()).isEqualTo(HEIGHT);
          assertThat(restoredKey.getTreeDigest()).isEqualTo(XMSSParameterSpec.SHA256);
      }
  
      private static BCXMSSPrivateKey createSha256PrivateKey() {
          XMSSParameters parameters = new XMSSParameters(HEIGHT, NISTObjectIdentifiers.id_sha256);
          XMSSPrivateKeyParameters keyParameters = new XMSSPrivateKeyParameters.Builder(parameters)
                  .withSecretKeySeed(createBytes(SHA256_DIGEST_SIZE, 17))
                  .withSecretKeyPRF(createBytes(SHA256_DIGEST_SIZE, 47))
                  .withPublicSeed(createBytes(SHA256_DIGEST_SIZE, 83))
                  .withRoot(createBytes(SHA256_DIGEST_SIZE, 131))
                  .build();
          return new BCXMSSPrivateKey(NISTObjectIdentifiers.id_sha256, keyParameters);
      }
  
      private static byte[] createBytes(int size, int offset) {
          byte[] bytes = new byte[size];
          for (int index = 0; index < bytes.length; index++) {
              bytes[index] = (byte) (index + offset);
          }
          return bytes;
      }
  
      private static byte[] serialize(BCXMSSPrivateKey privateKey) throws Exception {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {
              out.writeObject(privateKey);
          }
          return bytes.toByteArray();
      }
  
      private static BCXMSSPrivateKey deserialize(byte[] serializedKey) throws Exception {
          try (ObjectInputStream in = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {
              return (BCXMSSPrivateKey) in.readObject();
          }
      }
  }
