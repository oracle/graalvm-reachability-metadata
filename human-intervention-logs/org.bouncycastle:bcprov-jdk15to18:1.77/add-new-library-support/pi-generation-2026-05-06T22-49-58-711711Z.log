[tool-call] delta {"path":"tests/src/org.bouncycastle/bcprov-jdk15to18/1.77/src/test/java/org_bouncycastle/bcprov_jdk15to18/BCDHPublicKeyTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk15to18;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.math.BigInteger;\n\nimport javax.crypto.spec.DHParameterSpec;\n\nimport org.bouncycastle.asn1.ASN1Encoding;\nimport org.bouncycastle.asn1.ASN1Integer;\nimport org.bouncycastle.asn1.pkcs.DHParameter;\nimport org.bouncycastle.asn1.pkcs.PKCSObjectIdentifiers;\nimport org.bouncycastle.asn1.x509.AlgorithmIdentifier;\nimport org.bouncycastle.asn1.x509.SubjectPublicKeyInfo;\nimport org.bouncycastle.jcajce.provider.asymmetric.dh.BCDHPublicKey;\nimport org.junit.jupiter.api.Test;\n\npublic class BCDHPublicKeyTest {\n    private static final BigInteger PUBLIC_VALUE = BigInteger.valueOf(8);\n    private static final BigInteger PRIME = BigInteger.valueOf(23);\n    private static final BigInteger GENERATOR = BigInteger.valueOf(5);\n    private static final int PRIVATE_VALUE_LENGTH = 5;\n\n    @Test\n    public void serializesAndDeserializesDiffieHellmanPublicKey() throws Exception {\n        BCDHPublicKey publicKey = createPublicKey();\n\n        byte[] serializedKey = serialize(publicKey);\n        BCDHPublicKey restoredKey = deserialize(serializedKey);\n\n        assertThat(restoredKey).isEqualTo(publicKey);\n        assertThat(restoredKey.getAlgorithm()).isEqualTo(\"DH\");\n        assertThat(restoredKey.getFormat()).isEqualTo(\"X.509\");\n        assertThat(restoredKey.getY()).isEqualTo(PUBLIC_VALUE);\n        assertThat(restoredKey.getParams().getP()).isEqualTo(PRIME);\n        assertThat(restoredKey.getParams().getG()).isEqualTo(GENERATOR);\n        assertThat(restoredKey.getParams().getL()).isEqualTo(PRIVATE_VALUE_LENGTH);\n        assertThat(restoredKey.getEncoded()).isEqualTo(publicKey.getEncoded());\n    }\n\n    private static BCDHPublicKey createPublicKey() throws Exception {\n        DHParameterSpec parameters = new DHParameterSpec(PRIME, GENERATOR, PRIVATE_VALUE_LENGTH);\n        AlgorithmIdentifier algorithmIdentifier = new AlgorithmIdentifier(\n                PKCSObjectIdentifiers.dhKeyAgreement,\n                new DHParameter(parameters.getP(), parameters.getG(), parameters.getL()).toASN1Primitive());\n        SubjectPublicKeyInfo publicKeyInfo = new SubjectPublicKeyInfo(\n                algorithmIdentifier,\n                new ASN1Integer(PUBLIC_VALUE));\n        return new BCDHPublicKey(SubjectPublicKeyInfo.getInstance(publicKeyInfo.getEncoded(ASN1Encoding.DER)));\n    }\n\n    private static byte[] serialize(BCDHPublicKey publicKey) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {\n            out.writeObject(publicKey);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static BCDHPublicKey deserialize(byte[] serializedKey) throws Exception {\n        try (ObjectInputStream in = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {\n            return (BCDHPublicKey) in.readObject();\n        }\n    }\n}\n"}
