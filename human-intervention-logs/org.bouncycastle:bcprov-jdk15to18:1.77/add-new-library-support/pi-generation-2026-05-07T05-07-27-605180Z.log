HuL3Bj5Qhpy4Z6B1TIZhF4RWjoArMxUuXsRYxszz6jTtgFvvb40EWurotINN-JzZWHOiuEg==\",\"summary\":[]}"}, {"type": "toolCall", "id": "call_VPoo547N4DbfBkni4Gr9Czrh|fc_0cef92c9226f18120169fc1e0195388195b80947a677a0dc9d", "name": "write", "arguments": {"path": "tests/src/org.bouncycastle/bcprov-jdk15to18/1.77/src/test/java/org_bouncycastle/bcprov_jdk15to18/BCNTRUPrivateKeyTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk15to18;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\n\nimport org.bouncycastle.pqc.crypto.ntru.NTRUParameters;\nimport org.bouncycastle.pqc.crypto.ntru.NTRUPrivateKeyParameters;\nimport org.bouncycastle.pqc.jcajce.provider.ntru.BCNTRUPrivateKey;\nimport org.bouncycastle.pqc.jcajce.spec.NTRUParameterSpec;\nimport org.junit.jupiter.api.Test;\n\npublic class BCNTRUPrivateKeyTest {\n    @Test\n    public void serializesAndDeserializesNtruHps2048509PrivateKey() throws Exception {\n        BCNTRUPrivateKey privateKey = createNtruHps2048509PrivateKey();\n\n        byte[] serializedKey = serialize(privateKey);\n        BCNTRUPrivateKey restoredKey = deserialize(serializedKey);\n\n        assertThat(restoredKey).isEqualTo(privateKey);\n        assertThat(restoredKey.hashCode()).isEqualTo(privateKey.hashCode());\n        assertThat(restoredKey.getAlgorithm()).isEqualTo(\"NTRU\");\n        assertThat(restoredKey.getFormat()).isEqualTo(\"PKCS#8\");\n        assertThat(restoredKey.getEncoded()).isEqualTo(privateKey.getEncoded());\n        assertThat(restoredKey.getParameterSpec().getName())\n                .isEqualTo(NTRUParameterSpec.ntruhps2048509.getName());\n    }\n\n    private static BCNTRUPrivateKey createNtruHps2048509PrivateKey() {\n        NTRUPrivateKeyParameters keyParameters = new NTRUPrivateKeyParameters(\n                NTRUParameters.ntruhps2048509,\n                createBytes(935, 11));\n        return new BCNTRUPrivateKey(keyParameters);\n    }\n\n    private static byte[] createBytes(int size, int offset) {\n        byte[] bytes = new byte[size];\n        for (int index = 0; index < bytes.length; index++) {\n            bytes[index] = (byte) (index + offset);\n        }\n        return bytes;\n    }\n\n    private static byte[] serialize(BCNTRUPrivateKey privateKey) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {\n            out.writeObject(privateKey);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static BCNTRUPrivateKey deserialize(byte[] serializedKey) throws Exception {\n        try (ObjectInputStream in = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {\n            return (BCNTRUPrivateKey) in.readObject();\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 880, "output": 909, "cacheRead": 29696, "cacheWrite": 0, "totalTokens": 31485, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778130430307, "responseId": "resp_0cef92c9226f18120169fc1dfed6988195b76cacbfb71e327a"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_VPoo547N4DbfBkni4Gr9Czrh|fc_0cef92c9226f18120169fc1e0195388195b80947a677a0dc9d", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2675 bytes to tests/src/org.bouncycastle/bcprov-jdk15to18/1.77/src/test/java/org_bouncycastle/bcprov_jdk15to18/BCNTRUPrivateKeyTest.java"}], "isError": false, "timestamp": 1778130441645}]}
