  package org_bouncycastle.bcprov_jdk15to18;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  
  import org.bouncycastle.pqc.crypto.hqc.HQCParameters;
  import org.bouncycastle.pqc.crypto.hqc.HQCPrivateKeyParameters;
  import org.bouncycastle.pqc.jcajce.provider.hqc.BCHQCPrivateKey;
  import org.junit.jupiter.api.Test;
  
  public class BCHQCPrivateKeyTest {
      private static final int HQC128_N = 17669;
      private static final int HQC128_PRIVATE_KEY_SIZE = 40 + 40 + ((HQC128_N + 7) / 8);
  
      @Test
      public void serializesAndDeserializesHqc128PrivateKey() throws Exception {
          BCHQCPrivateKey privateKey = createHqc128PrivateKey();
  
          byte[] serializedKey = serialize(privateKey);
          BCHQCPrivateKey restoredKey = deserialize(serializedKey);
  
          assertThat(restoredKey).isEqualTo(privateKey);
          assertThat(restoredKey.hashCode()).isEqualTo(privateKey.hashCode());
          assertThat(restoredKey.getAlgorithm()).isEqualTo("HQC-128");
          assertThat(restoredKey.getFormat()).isEqualTo("PKCS#8");
          assertThat(restoredKey.getEncoded()).isEqualTo(privateKey.getEncoded());
