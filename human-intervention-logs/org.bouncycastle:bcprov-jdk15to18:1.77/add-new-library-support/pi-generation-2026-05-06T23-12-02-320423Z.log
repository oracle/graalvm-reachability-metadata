 assertThat(restoredKey.getParams().getP()).isEqualTo(PRIME);\n        assertThat(restoredKey.getParams().getQ()).isEqualTo(SUBPRIME);\n        assertThat(restoredKey.getParams().getG()).isEqualTo(GENERATOR);\n        assertThat(restoredKey.getEncoded()).isEqualTo(publicKey.getEncoded());\n    }\n\n    private static BCDSAPublicKey createPublicKey() throws Exception {\n        DSAParameter parameters = new DSAParameter(PRIME, SUBPRIME, GENERATOR);\n        AlgorithmIdentifier algorithmIdentifier = new AlgorithmIdentifier(\n                X9ObjectIdentifiers.id_dsa,\n                parameters.toASN1Primitive());\n        SubjectPublicKeyInfo publicKeyInfo = new SubjectPublicKeyInfo(\n                algorithmIdentifier,\n                new ASN1Integer(PUBLIC_VALUE));\n        return new BCDSAPublicKey(SubjectPublicKeyInfo.getInstance(publicKeyInfo.getEncoded(ASN1Encoding.DER)));\n    }\n\n    private static byte[] serialize(BCDSAPublicKey publicKey) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {\n            out.writeObject(publicKey);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static BCDSAPublicKey deserialize(byte[] serializedKey) throws Exception {\n        try (ObjectInputStream in = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {\n            return (BCDSAPublicKey) in.readObject();\n        }\n    }\n}\n"}
