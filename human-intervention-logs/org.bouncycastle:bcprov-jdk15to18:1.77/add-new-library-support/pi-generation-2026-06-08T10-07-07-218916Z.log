[tool-call] delta {"path":"tests/src/org.bouncycastle/bcprov-jdk15to18/1.77/src/test/java/org_bouncycastle/bcprov_jdk15to18/GcmSpecUtilAnonymous4Test.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk15to18;\n\nimport static org.junit.jupiter.api.Assertions.assertArrayEquals;\nimport static org.junit.jupiter.api.Assertions.assertEquals;\n\nimport java.security.AlgorithmParameters;\nimport java.security.Provider;\n\nimport javax.crypto.spec.GCMParameterSpec;\n\nimport org.bouncycastle.jce.provider.BouncyCastleProvider;\nimport org.junit.jupiter.api.Test;\n\npublic class GcmSpecUtilAnonymous4Test {\n    private static final byte[] NONCE = new byte[] {\n        0x41, 0x42, 0x43, 0x44,\n        0x45, 0x46, 0x47, 0x48,\n        0x49, 0x4a, 0x4b, 0x4c\n    };\n\n    @Test\n    void gcmAlgorithmParametersEncodeJdkGcmParameterSpec() throws Exception {\n        AlgorithmParameters parameters = AlgorithmParameters.getInstance(\"GCM\", provider());\n\n        parameters.init(new GCMParameterSpec(120, NONCE));\n        byte[] encoded = parameters.getEncoded(\"ASN.1\");\n\n        AlgorithmParameters decodedParameters = AlgorithmParameters.getInstance(\"GCM\", provider());\n        decodedParameters.init(encoded, \"ASN.1\");\n        GCMParameterSpec decodedSpec = decodedParameters.getParameterSpec(GCMParameterSpec.class);\n\n        assertEquals(120, decodedSpec.getTLen());\n        assertArrayEquals(NONCE, decodedSpec.getIV());\n    }\n\n    private static Provider provider() {\n        return new BouncyCastleProvider();\n    }\n}\n"}
