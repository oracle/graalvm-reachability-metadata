sionUID = 1L;\n\n        private int nextValue = 1;\n\n        @Override\n        public void nextBytes(byte[] bytes) {\n            for (int i = 0; i < bytes.length; i++) {\n                bytes[i] = (byte)nextValue;\n                nextValue++;\n            }\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 521, "output": 1078, "cacheRead": 30208, "cacheWrite": 0, "totalTokens": 31807, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780893121252, "responseId": "resp_0567a982c05be488016a2645c1e1a481959134d16585c17bec"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_D7HDgBxkIpBhjeSpZ66gqqnv|fc_0567a982c05be488016a2645ca87dc8195b1511aa5dd9b37cb", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 3375 bytes to tests/src/org.bouncycastle/bcprov-jdk15to18/1.77/src/test/java/org_bouncycastle/bcprov_jdk15to18/BCNTRUPublicKeyTest.java"}], "isError": false, "timestamp": 1780893138417}]}
