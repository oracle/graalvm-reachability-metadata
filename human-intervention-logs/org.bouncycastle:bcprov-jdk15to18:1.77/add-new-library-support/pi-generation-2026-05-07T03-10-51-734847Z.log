oredKey).isEqualTo(privateKey);\n        assertThat(restoredKey.hashCode()).isEqualTo(privateKey.hashCode());\n        assertThat(restoredKey.getAlgorithm()).isEqualTo(\"MCELIECE348864\");\n        assertThat(restoredKey.getFormat()).isEqualTo(\"PKCS#8\");\n        assertThat(restoredKey.getEncoded()).isEqualTo(privateKey.getEncoded());\n        assertThat(restoredKey.getParameterSpec().getName()).isEqualTo(CMCEParameterSpec.mceliece348864.getName());\n    }\n\n    private static BCCMCEPrivateKey createMceliece348864PrivateKey() {\n        CMCEParameters parameters = CMCEParameters.mceliece348864r3;\n        CMCEPrivateKeyParameters keyParameters = new CMCEPrivateKeyParameters(\n                parameters,\n                createBytes(DELTA_SIZE, 1),\n                createBytes(C_SIZE, 41),\n                createBytes(parameters.getT() * 2, 53),\n                createBytes(alphaSize(parameters), 97),\n                createBytes(S_SIZE, 113));\n        return new BCCMCEPrivateKey(keyParameters);\n    }\n\n    private static int alphaSize(CMCEParameters parameters) {\n        return (1 << (parameters.getM() - 4)) * (2 * parameters.getM() - 1);\n    }\n\n    private static byte[] createBytes(int size, int offset) {\n        byte[] bytes = new byte[size];\n        for (int index = 0; index < bytes.length; index++) {\n            bytes[index] = (byte) (index + offset);\n        }\n        return bytes;\n    }\n\n    private static byte[] serialize(BCCMCEPrivateKey privateKey) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {\n            out.writeObject(privateKey);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static BCCMCEPrivateKey deserialize(byte[] serializedKey) throws Exception {\n        try (ObjectInputStream in = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {\n            return (BCCMCEPrivateKey) in.readObject();\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778123420755}, {"role": "toolResult", "toolCallId": "call_mVZMY91vi2ATbu8XRCE1iA9E|fc_0e33ea06d03f5ed50169fc029c768c819281119473e8b16f95", "toolName": "read", "content": [{"type": "text", "text": "ENOENT: no such file or directory, access '/home/vjovanov/c/forge/forge1/graalvm-reachability-metadata/forge/local_repositories/forge_worktrees/1497-47cd89db/local_repositories/source_context/org.bouncycastle/bcprov-jdk15to18/1.77/main/extracted/org/bouncycastle/pqc/jcajce/provider/cmce/BCCMCEPublicKey.java'"}], "details": {}, "isError": true, "timestamp": 1778123420756}, {"role": "toolResult", "toolCallId": "call_PwepOPFN5PZbig7qzAkICBtR|fc_0e33ea06d03f5ed50169fc029c76948192a70d668c03374ecb", "toolName": "read", "content": [{"type": "text", "text": "ENOENT: no such file or directory, access '/home/vjovanov/c/forge/forge1/graalvm-reachability-metadata/forge/local_repositories/forge_worktrees/1497-47cd89db/local_repositories/source_context/org.bouncycastle/bcprov-jdk15to18/1.77/main/extracted/org/bouncycastle/pqc/jcajce/provider/cmce/BCCMCEPrivateKey.java'"}], "details": {}, "isError": true, "timestamp": 1778123420756}]}
