;\n\n        byte[] serializedKey = serialize(publicKey);\n        BCCMCEPublicKey restoredKey = deserialize(serializedKey);\n\n        assertThat(restoredKey).isEqualTo(publicKey);\n        assertThat(restoredKey.hashCode()).isEqualTo(publicKey.hashCode());\n        assertThat(restoredKey.getAlgorithm()).isEqualTo(\"MCELIECE348864\");\n        assertThat(restoredKey.getFormat()).isEqualTo(\"X.509\");\n        assertThat(restoredKey.getEncoded()).isEqualTo(publicKey.getEncoded());\n        assertThat(restoredKey.getParameterSpec().getName()).isEqualTo(CMCEParameterSpec.mceliece348864.getName());\n    }\n\n    private static BCCMCEPublicKey createMceliece348864PublicKey() {\n        CMCEParameters parameters = CMCEParameters.mceliece348864r3;\n        CMCEPublicKeyParameters keyParameters = new CMCEPublicKeyParameters(parameters, createBytes(64, 17));\n        return new BCCMCEPublicKey(keyParameters);\n    }\n\n    private static byte[] createBytes(int size, int offset) {\n        byte[] bytes = new byte[size];\n        for (int index = 0; index < bytes.length; index++) {\n            bytes[index] = (byte) (index + offset);\n        }\n        return bytes;\n    }\n\n    private static byte[] serialize(BCCMCEPublicKey publicKey) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {\n            out.writeObject(publicKey);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static BCCMCEPublicKey deserialize(byte[] serializedKey) throws Exception {\n        try (ObjectInputStream in = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {\n            return (BCCMCEPublicKey) in.readObject();\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 746, "output": 1012, "cacheRead": 16384, "cacheWrite": 0, "totalTokens": 18142, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cac