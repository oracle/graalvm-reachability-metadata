      private static final BigInteger GENERATOR = BigInteger.valueOf(5);
  
      @Test
      public void serializesAndDeserializesElGamalPublicKey() throws Exception {
          BCElGamalPublicKey publicKey = createPublicKey();
  
          byte[] serializedKey = serialize(publicKey);
          BCElGamalPublicKey restoredKey = deserialize(serializedKey);
  
          assertThat(restoredKey).isEqualTo(publicKey);
          assertThat(restoredKey.getAlgorithm()).isEqualTo("ElGamal");
          assertThat(restoredKey.getFormat()).isEqualTo("X.509");
          assertThat(restoredKey.getY()).isEqualTo(PUBLIC_VALUE);
          assertThat(restoredKey.getParameters().getP()).isEqualTo(PRIME);
          assertThat(restoredKey.getParameters().getG()).isEqualTo(GENERATOR);
          assertThat(restoredKey.getParams().getP()).isEqualTo(PRIME);
          assertThat(restoredKey.getParams().getG()).isEqualTo(GENERATOR);
          assertThat(restoredKey.getEncoded()).isEqualTo(publicKey.getEncoded());
      }
  
      private static BCElGamalPublicKey createPublicKey() throws Exception {
          ElGamalParameterSpec parameters = new ElGamalParameterSpec(PRIME, GENERATOR);
          ElGamalPublicKeySpec keySpec = new ElGamalPublicKeySpec(PUBLIC_VALUE, parameters);
          KeyFactory keyFactory = KeyFactory.getInstance("ElGamal", new BouncyCastleProvider());
          ElGamalPublicKey publicKey = (ElGamalPublicKey) keyFactory.generatePublic(keySpec);
  
          assertThat(publicKey).isInstanceOf(BCElGamalPublicKey.class);
          return (BCElGamalPublicKey) publicKey;
      }
  
      private static byte[] serialize(BCElGamalPublicKey publicKey) throws Exception {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {
              out.writeObject(publicKey);
          }
          return bytes.toByteArray();
      }
  
      private static BCElGamalPublicKey deserialize(byte[] serializedKey) throws Exception {
          try (ObjectInputStream in = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {
              return (BCElGamalPublicKey) in.readObject();
          }
      }
  }
