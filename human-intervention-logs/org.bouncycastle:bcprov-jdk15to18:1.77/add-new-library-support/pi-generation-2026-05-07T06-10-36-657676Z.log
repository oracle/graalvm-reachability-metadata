ed via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk15to18;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\n\nimport org.bouncycastle.pqc.crypto.picnic.PicnicParameters;\nimport org.bouncycastle.pqc.crypto.picnic.PicnicPublicKeyParameters;\nimport org.bouncycastle.pqc.jcajce.provider.picnic.BCPicnicPublicKey;\nimport org.bouncycastle.pqc.jcajce.spec.PicnicParameterSpec;\nimport org.junit.jupiter.api.Test;\n\npublic class BCPicnicPublicKeyTest {\n    @Test\n    public void serializesAndDeserializesPicnicL1FsPublicKey() throws Exception {\n        BCPicnicPublicKey publicKey = createPicnicL1FsPublicKey();\n\n        byte[] serializedKey = serialize(publicKey);\n        BCPicnicPublicKey restoredKey = deserialize(serializedKey);\n\n        assertThat(restoredKey).isEqualTo(publicKey);\n        assertThat(restoredKey.hashCode()).isEqualTo(publicKey.hashCode());\n        assertThat(restoredKey.getAlgorithm()).isEqualTo(\"Picnic\");\n        assertThat(restoredKey.getFormat()).isEqualTo(\"X.509\");\n        assertThat(restoredKey.getEncoded()).isEqualTo(publicKey.getEncoded());\n        assertThat(restoredKey.getParameterSpec().getName()).isEqualTo(PicnicParameterSpec.picnicl1fs.getName());\n    }\n\n    private static BCPicnicPublicKey createPicnicL1FsPublicKey() {\n        PicnicParameters parameters = PicnicParameters.picnicl1fs;\n        PicnicPublicKeyParameters keyParameters = new PicnicPublicKeyParameters(parameters, createBytes(64));\n        return new BCPicnicPublicKey(keyParameters);\n    }\n\n    private static byte[] createBytes(int size) {\n        byte[] bytes = new byte[size];\n        for (int index = 0; index < bytes.length; index++) {\n            bytes[index] = (byte) (index + 1);\n        }\n        return bytes;\n    }\n\n    private static byte[] serialize(BCPicnicPublicKey publicKey) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {\n            out.writeObject(publicKey);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static BCPicnicPublicKey deserialize(byte[] serializedKey) throws Exception {\n        try (ObjectInputStream in = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {\n            return (BCPicnicPublicKey) in.readObject();\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 733, "output": 959, "cacheRead": 15360, "cacheWrite": 0, "totalTokens": 17052, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778134210959, "responseId": "resp_0069b594cc1ba5010169fc2cc353888194b359483b4d5e63ab"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_ULjrHP7l02qXDVypkEaGfSxi|fc_0069b594cc1ba5010169fc2ccaacf48194a3e04f77d110232a", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2650 bytes to tests/src/org.bouncycastle/bcprov-jdk15to18/1.77/src/test/java/org_bouncycastle/bcprov_jdk15to18/BCPicnicPublicKeyTest.java"}], "isError": false, "timestamp": 1778134223597}]}
