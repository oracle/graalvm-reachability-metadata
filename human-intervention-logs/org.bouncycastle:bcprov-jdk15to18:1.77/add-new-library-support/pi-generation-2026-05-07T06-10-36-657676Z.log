  package org_bouncycastle.bcprov_jdk15to18;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  
  import org.bouncycastle.pqc.crypto.picnic.PicnicParameters;
  import org.bouncycastle.pqc.crypto.picnic.PicnicPrivateKeyParameters;
  import org.bouncycastle.pqc.jcajce.provider.picnic.BCPicnicPrivateKey;
  import org.bouncycastle.pqc.jcajce.spec.PicnicParameterSpec;
  import org.junit.jupiter.api.Test;
  
  public class BCPicnicPrivateKeyTest {
      @Test
      public void serializesAndDeserializesPicnicL1FsPrivateKey() throws Exception {
          BCPicnicPrivateKey privateKey = createPicnicL1FsPrivateKey();
  
          byte[] serializedKey = serialize(privateKey);
          BCPicnicPrivateKey restoredKey = deserialize(serializedKey);
  
          assertThat(restoredKey).isEqualTo(privateKey);
          assertThat(restoredKey.hashCode()).isEqualTo(privateKey.hashCode());
          assertThat(restoredKey.getAlgorithm()).isEqualTo("Picnic");
          assertThat(restoredKey.getFormat()).isEqualTo("PKCS#8");
          assertThat(restoredKey.getEncoded()).isEqualTo(privateKey.getEncoded());
          assertThat(restoredKey.getParameterSpec().getName()).isEqualTo(PicnicParameterSpec.picnicl1fs.getName());
      }
  
      private static BCPicnicPrivateKey createPicnicL1FsPrivateKey() {
          PicnicParameters parameters = PicnicParameters.picnicl1fs;
          PicnicPrivateKeyParameters keyParameters = new PicnicPrivateKeyParameters(parameters, createBytes(64));
          return new BCPicnicPrivateKey(keyParameters);
      }
  
      private static byte[] createBytes(int size) {
          byte[] bytes = new byte[size];
          for (int index = 0; index < bytes.length; index++) {
              bytes[index] = (byte) (index + 1);
          }
          return bytes;
      }
  
      private static byte[] serialize(BCPicnicPrivateKey privateKey) throws Exception {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {
