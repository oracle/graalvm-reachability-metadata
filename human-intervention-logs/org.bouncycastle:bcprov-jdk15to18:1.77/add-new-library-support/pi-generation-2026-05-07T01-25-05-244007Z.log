  public class JCEDHPrivateKey
      implements DHPrivateKey, PKCS12BagAttributeCarrier
  {
      static final long serialVersionUID = 311058815616901812L;
      
      BigInteger      x;
  
      private DHParameterSpec dhSpec;
      private PrivateKeyInfo  info;
  
