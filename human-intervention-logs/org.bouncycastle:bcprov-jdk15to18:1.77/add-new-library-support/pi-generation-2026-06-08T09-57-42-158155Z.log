rException {\n            engineInit(opmode, key, params, null);\n        }\n\n        byte[] doFinal(byte[] input) throws IllegalBlockSizeException, BadPaddingException {\n            return engineDoFinal(input, 0, input.length);\n        }\n\n        AlgorithmParameters parameters() {\n            return engineGetParameters();\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 635, "output": 1240, "cacheRead": 24576, "cacheWrite": 0, "totalTokens": 26451, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780912563418, "responseId": "resp_085542921ecccea2016a2691b3fe648193af609767916adaaa"}}
