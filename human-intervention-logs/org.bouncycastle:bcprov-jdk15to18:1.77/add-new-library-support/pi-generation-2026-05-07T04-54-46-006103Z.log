  package org_bouncycastle.bcprov_jdk15to18;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.security.SecureRandom;
  
  import org.bouncycastle.pqc.jcajce.provider.mceliece.BCMcElieceCCA2PrivateKey;
  import org.bouncycastle.pqc.legacy.crypto.mceliece.McElieceCCA2PrivateKeyParameters;
  import org.bouncycastle.pqc.legacy.math.linearalgebra.GF2mField;
  import org.bouncycastle.pqc.legacy.math.linearalgebra.Permutation;
  import org.bouncycastle.pqc.legacy.math.linearalgebra.PolynomialGF2mSmallM;
  import org.bouncycastle.pqc.legacy.math.linearalgebra.PolynomialRingGF2;
  import org.junit.jupiter.api.Test;
  
  public class BCMcElieceCCA2PrivateKeyTest {
      private static final int FIELD_DEGREE = 4;
      private static final int CODE_LENGTH = 1 << FIELD_DEGREE;
      private static final int ERROR_CORRECTION_CAPABILITY = 2;
      private static final int CODE_DIMENSION = CODE_LENGTH - FIELD_DEGREE * ERROR_CORRECTION_CAPABILITY;
  
      @Test
      public void serializesAndDeserializesCca2PrivateKey() throws Exception {
          BCMcElieceCCA2PrivateKey privateKey = createPrivateKey();
  
          byte[] serializedKey = serialize(privateKey);
          BCMcElieceCCA2PrivateKey restoredKey = deserialize(serializedKey);
  
          assertThat(restoredKey).isEqualTo(privateKey);
          assertThat(restoredKey.hashCode()).isEqualTo(privateKey.hashCode());
          assertThat(restoredKey.getAlgorithm()).isEqualTo("McEliece-CCA2");
          assertThat(restoredKey.getFormat()).isEqualTo("PKCS#8");
          assertThat(restoredKey.getEncoded()).isEqualTo(privateKey.getEncoded());
          assertThat(restoredKey.getN()).isEqualTo(privateKey.getN());
          assertThat(restoredKey.getK()).isEqualTo(privateKey.getK());
          assertThat(restoredKey.getT()).isEqualTo(privateKey.getT());
          assertThat(restoredKey.getField()).isEqualTo(privateKey.getField());
          assertThat(restoredKey.getGoppaPoly()).isEqualTo(privateKey.getGoppaPoly());
          assertThat(restoredKey.getP()).isEqualTo(privateKey.getP());
