[tool-call] delta {"path":"tests/src/org.bouncycastle/bcprov-jdk15to18/1.77/src/test/java/org_bouncycastle/bcprov_jdk15to18/BCHQCPublicKeyTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk15to18;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\n\nimport org.bouncycastle.pqc.crypto.hqc.HQCParameters;\nimport org.bouncycastle.pqc.crypto.hqc.HQCPublicKeyParameters;\nimport org.bouncycastle.pqc.jcajce.provider.hqc.BCHQCPublicKey;\nimport org.junit.jupiter.api.Test;\n\npublic class BCHQCPublicKeyTest {\n    private static final int HQC128_N = 17669;\n    private static final int HQC128_PUBLIC_KEY_SIZE = 40 + ((HQC128_N + 7) / 8);\n\n    @Test\n    public void serializesAndDeserializesHqc128PublicKey() throws Exception {\n        BCHQCPublicKey publicKey = createHqc128PublicKey();\n\n        byte[] serializedKey = serialize(publicKey);\n        BCHQCPublicKey restoredKey = deserialize(serializedKey);\n\n        assertThat(restoredKey).isEqualTo(publicKey);\n        assertThat(restoredKey.hashCode()).isEqualTo(publicKey.hashCode());\n        assertThat(restoredKey.getAlgorithm()).isEqualTo(\"HQC-128\");\n        assertThat(restoredKey.getFormat()).isEqualTo(\"X.509\");\n        assertThat(restoredKey.getEncoded()).isEqualTo(publicKey.getEncoded());\n    }\n\n    private static BCHQCPublicKey createHqc128PublicKey() {\n        HQCPublicKeyParameters keyParameters = new HQCPublicKeyParameters(\n                HQCParameters.hqc128,\n                createBytes(HQC128_PUBLIC_KEY_SIZE, 1));\n        return new BCHQCPublicKey(keyParameters);\n    }\n\n    private static byte[] createBytes(int size, int offset) {\n        byte[] bytes = new byte[size];\n        for (int index = 0; index < bytes.length; index++) {\n            bytes[index] = (byte) (index + offset);\n        }\n        return bytes;\n    }\n\n    private static byte[] serialize(BCHQCPublicKey publicKey) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {\n            out.writeObject(publicKey);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static BCHQCPublicKey deserialize(byte[] serializedKey) throws Exception {\n        try (ObjectInputStream in = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {\n            return (BCHQCPublicKey) in.readObject();\n        }\n    }\n}\n"}
