  package org_bouncycastle.bcprov_jdk15to18;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  
  import org.bouncycastle.pqc.crypto.bike.BIKEParameters;
  import org.bouncycastle.pqc.crypto.bike.BIKEPublicKeyParameters;
  import org.bouncycastle.pqc.jcajce.provider.bike.BCBIKEPublicKey;
  import org.bouncycastle.pqc.jcajce.spec.BIKEParameterSpec;
  import org.junit.jupiter.api.Test;
  
  public class BCBIKEPublicKeyTest {
      @Test
      public void serializesAndDeserializesBike128PublicKey() throws Exception {
          BCBIKEPublicKey publicKey = createBike128PublicKey();
  
          byte[] serializedKey = serialize(publicKey);
          BCBIKEPublicKey restoredKey = deserialize(serializedKey);
  
          assertThat(restoredKey).isEqualTo(publicKey);
          assertThat(restoredKey.hashCode()).isEqualTo(publicKey.hashCode());
          assertThat(restoredKey.getAlgorithm()).isEqualTo("BIKE128");
          assertThat(restoredKey.getFormat()).isEqualTo("X.509");
          assertThat(restoredKey.getEncoded()).isEqualTo(publicKey.getEncoded());
          assertThat(restoredKey.getParameterSpec().getName()).isEqualTo(BIKEParameterSpec.bike128.getName());
      }
  
      private static BCBIKEPublicKey createBike128PublicKey() {
          BIKEParameters parameters = BIKEParameters.bike128;
          BIKEPublicKeyParameters keyParameters = new BIKEPublicKeyParameters(
                  parameters,
                  createBytes(parameters.getRByte(), 1));
          return new BCBIKEPublicKey(keyParameters);
      }
  
      private static byte[] createBytes(int size, int offset) {
          byte[] bytes = new byte[size];
          for (int index = 0; index < bytes.length; index++) {
              bytes[index] = (byte) (index + offset);
          }
          return bytes;
      }
  
      private static byte[] serialize(BCBIKEPublicKey publicKey) throws Exception {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {
              out.writeObject(publicKey);
          }
          return bytes.toByteArray();
      }
  
      private static BCBIKEPublicKey deserialize(byte[] serializedKey) throws Exception {
          try (ObjectInputStream in = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {
              return (BCBIKEPublicKey) in.readObject();
          }
      }
