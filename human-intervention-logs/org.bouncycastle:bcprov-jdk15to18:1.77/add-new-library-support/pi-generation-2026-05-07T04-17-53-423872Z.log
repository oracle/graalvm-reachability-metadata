[tool-call] delta {"path":"tests/src/org.bouncycastle/bcprov-jdk15to18/1.77/src/test/java/org_bouncycastle/bcprov_jdk15to18/BCKyberPublicKeyTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk15to18;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\n\nimport org.bouncycastle.pqc.crypto.crystals.kyber.KyberParameters;\nimport org.bouncycastle.pqc.crypto.crystals.kyber.KyberPublicKeyParameters;\nimport org.bouncycastle.pqc.jcajce.provider.kyber.BCKyberPublicKey;\nimport org.bouncycastle.pqc.jcajce.spec.KyberParameterSpec;\nimport org.junit.jupiter.api.Test;\n\npublic class BCKyberPublicKeyTest {\n    private static final int KYBER512_T_SIZE = 768;\n    private static final int SEED_SIZE = 32;\n\n    @Test\n    public void serializesAndDeserializesKyber512PublicKey() throws Exception {\n        BCKyberPublicKey publicKey = createKyber512PublicKey();\n\n        byte[] serializedKey = serialize(publicKey);\n        BCKyberPublicKey restoredKey = deserialize(serializedKey);\n\n        assertThat(restoredKey).isEqualTo(publicKey);\n        assertThat(restoredKey.hashCode()).isEqualTo(publicKey.hashCode());\n        assertThat(restoredKey.getAlgorithm()).isEqualTo(\"KYBER512\");\n        assertThat(restoredKey.getFormat()).isEqualTo(\"X.509\");\n        assertThat(restoredKey.getEncoded()).isEqualTo(publicKey.getEncoded());\n        assertThat(restoredKey.getParameterSpec().getName()).isEqualTo(KyberParameterSpec.kyber512.getName());\n    }\n\n    private static BCKyberPublicKey createKyber512PublicKey() {\n        KyberPublicKeyParameters keyParameters = new KyberPublicKeyParameters(\n                KyberParameters.kyber512,\n                createBytes(KYBER512_T_SIZE, 17),\n                createBytes(SEED_SIZE, 91));\n        return new BCKyberPublicKey(keyParameters);\n    }\n\n    private static byte[] createBytes(int size, int offset) {\n        byte[] bytes = new byte[size];\n        for (int index = 0; index < bytes.length; index++) {\n            bytes[index] = (byte) (index + offset);\n        }\n        return bytes;\n    }\n\n    private static byte[] serialize(BCKyberPublicKey publicKey) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {\n            out.writeObject(publicKey);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static BCKyberPublicKey deserialize(byte[] serializedKey) throws Exception {\n        try (ObjectInputStream in = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {\n            return (BCKyberPublicKey) in.readObject();\n        }\n    }\n}\n"}
