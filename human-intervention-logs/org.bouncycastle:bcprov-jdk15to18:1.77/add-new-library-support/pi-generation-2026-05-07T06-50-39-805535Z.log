[tool-call] delta {"path":"tests/src/org.bouncycastle/bcprov-jdk15to18/1.77/src/test/java/org_bouncycastle/bcprov_jdk15to18/BCSPHINCSPlusPublicKeyTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk15to18;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\n\nimport org.bouncycastle.pqc.crypto.sphincsplus.SPHINCSPlusParameters;\nimport org.bouncycastle.pqc.crypto.sphincsplus.SPHINCSPlusPublicKeyParameters;\nimport org.bouncycastle.pqc.jcajce.provider.sphincsplus.BCSPHINCSPlusPublicKey;\nimport org.junit.jupiter.api.Test;\n\npublic class BCSPHINCSPlusPublicKeyTest {\n    private static final int SHAKE_128F_PUBLIC_KEY_SIZE = 32;\n\n    @Test\n    public void serializesAndDeserializesShake128fPublicKey() throws Exception {\n        BCSPHINCSPlusPublicKey publicKey = createShake128fPublicKey();\n\n        byte[] serializedKey = serialize(publicKey);\n        BCSPHINCSPlusPublicKey restoredKey = deserialize(serializedKey);\n\n        assertThat(restoredKey).isEqualTo(publicKey);\n        assertThat(restoredKey.hashCode()).isEqualTo(publicKey.hashCode());\n        assertThat(restoredKey.getAlgorithm()).isEqualTo(\"SPHINCS+-SHAKE-128F\");\n        assertThat(restoredKey.getFormat()).isEqualTo(\"X.509\");\n        assertThat(restoredKey.getEncoded()).isEqualTo(publicKey.getEncoded());\n        assertThat(restoredKey.getParameterSpec().getName()).isEqualTo(SPHINCSPlusParameters.shake_128f.getName());\n    }\n\n    private static BCSPHINCSPlusPublicKey createShake128fPublicKey() {\n        SPHINCSPlusPublicKeyParameters keyParameters = new SPHINCSPlusPublicKeyParameters(\n                SPHINCSPlusParameters.shake_128f,\n                createBytes(SHAKE_128F_PUBLIC_KEY_SIZE, 41));\n        return new BCSPHINCSPlusPublicKey(keyParameters);\n    }\n\n    private static byte[] createBytes(int size, int offset) {\n        byte[] bytes = new byte[size];\n        for (int index = 0; index < bytes.length; index++) {\n            bytes[index] = (byte) (index + offset);\n        }\n        return bytes;\n    }\n\n    private static byte[] serialize(BCSPHINCSPlusPublicKey publicKey) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {\n            out.writeObject(publicKey);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static BCSPHINCSPlusPublicKey deserialize(byte[] serializedKey) throws Exception {\n        try (ObjectInputStream in = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {\n            return (BCSPHINCSPlusPublicKey) in.readObject();\n        }\n    }\n}\n"}
