  package org_bouncycastle.bcprov_jdk15to18;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  
  import org.bouncycastle.pqc.crypto.falcon.FalconParameters;
  import org.bouncycastle.pqc.crypto.falcon.FalconPublicKeyParameters;
  import org.bouncycastle.pqc.jcajce.provider.falcon.BCFalconPublicKey;
  import org.bouncycastle.pqc.jcajce.spec.FalconParameterSpec;
  import org.junit.jupiter.api.Test;
  
  public class BCFalconPublicKeyTest {
      private static final int FALCON_512_PUBLIC_KEY_SIZE = 897;
  
      @Test
      public void serializesAndDeserializesFalcon512PublicKey() throws Exception {
          BCFalconPublicKey publicKey = createFalcon512PublicKey();
  
          byte[] serializedKey = serialize(publicKey);
          BCFalconPublicKey restoredKey = deserialize(serializedKey);
  
          assertThat(restoredKey).isEqualTo(publicKey);
          assertThat(restoredKey.hashCode()).isEqualTo(publicKey.hashCode());
          assertThat(restoredKey.getAlgorithm()).isEqualTo("FALCON-512");
          assertThat(restoredKey.getFormat()).isEqualTo("X.509");
          assertThat(restoredKey.getEncoded()).isEqualTo(publicKey.getEncoded());
          assertThat(restoredKey.getParameterSpec().getName()).isEqualTo(FalconParameterSpec.falcon_512.getName());
      }
  
      private static BCFalconPublicKey createFalcon512PublicKey() {
          FalconPublicKeyParameters keyParameters = new FalconPublicKeyParameters(
                  FalconParameters.falcon_512,
                  createBytes(FALCON_512_PUBLIC_KEY_SIZE, 53));
          return new BCFalconPublicKey(keyParameters);
      }
  
      private static byte[] createBytes(int size, int offset) {
          byte[] bytes = new byte[size];
          for (int index = 0; index < bytes.length; index++) {
              bytes[index] = (byte) (index + offset);
          }
          return bytes;
      }
  
      private static byte[] serialize(BCFalconPublicKey publicKey) throws Exception {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {
              out.writeObject(publicKey);
          }
          return bytes.toByteArray();
      }
  
      private static BCFalconPublicKey deserialize(byte[] serializedKey) throws Exception {
          try (ObjectInputStream in = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {
              return (BCFalconPublicKey) in.readObject();
          }
      }
  }
