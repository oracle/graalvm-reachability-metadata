  package org_bouncycastle.bcprov_jdk15to18;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  
  import org.bouncycastle.pqc.crypto.crystals.dilithium.DilithiumParameters;
  import org.bouncycastle.pqc.crypto.crystals.dilithium.DilithiumPrivateKeyParameters;
  import org.bouncycastle.pqc.jcajce.provider.dilithium.BCDilithiumPrivateKey;
  import org.bouncycastle.pqc.jcajce.spec.DilithiumParameterSpec;
  import org.junit.jupiter.api.Test;
  
  public class BCDilithiumPrivateKeyTest {
      private static final int SEED_SIZE = 32;
      private static final int TR_SIZE = 64;
      private static final int DILITHIUM2_S1_SIZE = 384;
      private static final int DILITHIUM2_S2_SIZE = 384;
      private static final int DILITHIUM2_T0_SIZE = 1664;
      private static final int DILITHIUM2_T1_SIZE = 1280;
  
      @Test
      public void serializesAndDeserializesDilithium2PrivateKey() throws Exception {
          BCDilithiumPrivateKey privateKey = createDilithium2PrivateKey();
  
          byte[] serializedKey = serialize(privateKey);
          BCDilithiumPrivateKey restoredKey = deserialize(serializedKey);
  
          assertThat(restoredKey).isEqualTo(privateKey);
          assertThat(restoredKey.hashCode()).isEqualTo(privateKey.hashCode());
          assertThat(restoredKey.getAlgorithm()).isEqualTo("DILITHIUM2");
          assertThat(restoredKey.getFormat()).isEqualTo("PKCS#8");
          assertThat(restoredKey.getEncoded()).isEqualTo(privateKey.getEncoded());
          assertThat(restoredKey.getPublicKey().getEncoded()).isEqualTo(privateKey.getPublicKey().getEncoded());
          assertThat(restoredKey.getParameterSpec().getName()).isEqualTo(DilithiumParameterSpec.dilithium2.getName());
      }
  
      private static BCDilithiumPrivateKey createDilithium2PrivateKey() {
          DilithiumPrivateKeyParameters keyParameters = new DilithiumPrivateKeyParameters(
                  DilithiumParameters.dilithium2,
                  createBytes(SEED_SIZE, 1),
                  createBytes(SEED_SIZE, 41),
                  createBytes(TR_SIZE, 73),
                  createBytes(DILITHIUM2_S1_SIZE, 139),
                  createBytes(DILITHIUM2_S2_SIZE, 23),
                  createBytes(DILITHIUM2_T0_SIZE, 191),
                  createBytes(DILITHIUM2_T1_SIZE, 109));
          return new BCDilithiumPrivateKey(keyParameters);
      }
  
