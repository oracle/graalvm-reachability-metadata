putStream(bytes)) {\n            out.writeObject(privateKey);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static BCKyberPrivateKey deserialize(byte[] serializedKey) throws Exception {\n        try (ObjectInputStream in = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {\n            return (BCKyberPrivateKey) in.readObject();\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1112, "output": 776, "cacheRead": 46592, "cacheWrite": 0, "totalTokens": 48480, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778127184173, "responseId": "resp_0073e79e5d89ee120169fc1150b44c81958d9948110039e429"}}
