  package org_bouncycastle.bcprov_jdk15to18;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  
  import org.bouncycastle.pqc.crypto.newhope.NHPrivateKeyParameters;
  import org.bouncycastle.pqc.jcajce.provider.newhope.BCNHPrivateKey;
  import org.junit.jupiter.api.Test;
  
  public class BCNHPrivateKeyTest {
      private static final int NEWHOPE_POLY_SIZE = 1024;
  
      @Test
      public void serializesAndDeserializesNewHopePrivateKey() throws Exception {
          BCNHPrivateKey privateKey = createNewHopePrivateKey();
  
          byte[] serializedKey = serialize(privateKey);
          BCNHPrivateKey restoredKey = deserialize(serializedKey);
  
          assertThat(restoredKey).isEqualTo(privateKey);
          assertThat(restoredKey.hashCode()).isEqualTo(privateKey.hashCode());
          assertThat(restoredKey.getAlgorithm()).isEqualTo("NH");
          assertThat(restoredKey.getFormat()).isEqualTo("PKCS#8");
          assertThat(restoredKey.getEncoded()).isEqualTo(privateKey.getEncoded());
          assertThat(restoredKey.getSecretData()).isEqualTo(privateKey.getSecretData());
      }
  
      private static BCNHPrivateKey createNewHopePrivateKey() {
          return new BCNHPrivateKey(new NHPrivateKeyParameters(createSecretData()));
      }
  
      private static short[] createSecretData() {
          short[] secretData = new short[NEWHOPE_POLY_SIZE];
          for (int index = 0; index < secretData.length; index++) {
              secretData[index] = (short) (index + 1);
          }
          return secretData;
      }
  
      private static byte[] serialize(BCNHPrivateKey privateKey) throws Exception {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {
              out.writeObject(privateKey);
          }
          return bytes.toByteArray();
      }
  
      private static BCNHPrivateKey deserialize(byte[] serializedKey) throws Exception {
          try (ObjectInputStream in = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {
              return (BCNHPrivateKey) in.readObject();
          }
      }
  }
