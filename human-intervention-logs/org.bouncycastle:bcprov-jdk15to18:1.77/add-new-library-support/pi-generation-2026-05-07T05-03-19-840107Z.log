[tool-call] delta {"path":"tests/src/org.bouncycastle/bcprov-jdk15to18/1.77/src/test/java/org_bouncycastle/bcprov_jdk15to18/BCNHPublicKeyTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk15to18;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\n\nimport org.bouncycastle.pqc.crypto.newhope.NHPublicKeyParameters;\nimport org.bouncycastle.pqc.jcajce.provider.newhope.BCNHPublicKey;\nimport org.junit.jupiter.api.Test;\n\npublic class BCNHPublicKeyTest {\n    private static final int NEWHOPE_PUBLIC_KEY_SIZE = 1824;\n\n    @Test\n    public void serializesAndDeserializesNewHopePublicKey() throws Exception {\n        BCNHPublicKey publicKey = createNewHopePublicKey();\n\n        byte[] serializedKey = serialize(publicKey);\n        BCNHPublicKey restoredKey = deserialize(serializedKey);\n\n        assertThat(restoredKey).isEqualTo(publicKey);\n        assertThat(restoredKey.hashCode()).isEqualTo(publicKey.hashCode());\n        assertThat(restoredKey.getAlgorithm()).isEqualTo(\"NH\");\n        assertThat(restoredKey.getFormat()).isEqualTo(\"X.509\");\n        assertThat(restoredKey.getEncoded()).isEqualTo(publicKey.getEncoded());\n        assertThat(restoredKey.getPublicData()).isEqualTo(publicKey.getPublicData());\n    }\n\n    private static BCNHPublicKey createNewHopePublicKey() {\n        return new BCNHPublicKey(new NHPublicKeyParameters(createPublicData()));\n    }\n\n    private static byte[] createPublicData() {\n        byte[] publicData = new byte[NEWHOPE_PUBLIC_KEY_SIZE];\n        for (int index = 0; index < publicData.length; index++) {\n            publicData[index] = (byte) (index + 1);\n        }\n        return publicData;\n    }\n\n    private static byte[] serialize(BCNHPublicKey publicKey) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {\n            out.writeObject(publicKey);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static BCNHPublicKey deserialize(byte[] serializedKey) throws Exception {\n        try (ObjectInputStream in = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {\n            return (BCNHPublicKey) in.readObject();\n        }\n    }\n}\n"}
