dKey = deserialize(serializedKey);\n\n        assertThat(restoredKey).isEqualTo(privateKey);\n        assertThat(restoredKey.hashCode()).isEqualTo(privateKey.hashCode());\n        assertThat(restoredKey.getAlgorithm()).isEqualTo(\"DILITHIUM2\");\n        assertThat(restoredKey.getFormat()).isEqualTo(\"PKCS#8\");\n        assertThat(restoredKey.getEncoded()).isEqualTo(privateKey.getEncoded());\n        assertThat(restoredKey.getPublicKey().getEncoded()).isEqualTo(privateKey.getPublicKey().getEncoded());\n        assertThat(restoredKey.getParameterSpec().getName()).isEqualTo(DilithiumParameterSpec.dilithium2.getName());\n    }\n\n    private static BCDilithiumPrivateKey createDilithium2PrivateKey() {\n        DilithiumPrivateKeyParameters keyParameters = new DilithiumPrivateKeyParameters(\n                DilithiumParameters.dilithium2,\n                createBytes(SEED_SIZE, 1),\n                createBytes(SEED_SIZE, 41),\n                createBytes(TR_SIZE, 73),\n                createBytes(DILITHIUM2_S1_SIZE, 139),\n                createBytes(DILITHIUM2_S2_SIZE, 23),\n                createBytes(DILITHIUM2_T0_SIZE, 191),\n                createBytes(DILITHIUM2_T1_SIZE, 109));\n        return new BCDilithiumPrivateKey(keyParameters);\n    }\n\n    private static byte[] createBytes(int size, int offset) {\n        byte[] bytes = new byte[size];\n        for (int index = 0; index < bytes.length; index++) {\n            bytes[index] = (byte) (index + offset);\n        }\n        return bytes;\n    }\n\n    private static byte[] serialize(BCDilithiumPrivateKey privateKey) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {\n            out.writeObject(privateKey);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static BCDilithiumPrivateKey deserialize(byte[] serializedKey) throws Exception {\n        try (ObjectInputStream in = new ObjectIn