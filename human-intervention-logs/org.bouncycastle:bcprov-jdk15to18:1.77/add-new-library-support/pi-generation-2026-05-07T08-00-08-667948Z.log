  package org_bouncycastle.bcprov_jdk15to18;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.security.spec.AlgorithmParameterSpec;
  
  import javax.crypto.spec.GCMParameterSpec;
  
  import org.bouncycastle.asn1.ASN1Primitive;
  import org.bouncycastle.internal.asn1.cms.GCMParameters;
  import org.bouncycastle.jcajce.provider.symmetric.util.GcmSpecUtil;
  import org.junit.jupiter.api.Test;
  
  public class GcmSpecUtilTest {
      private static final byte[] NONCE = new byte[] {
          0x01, 0x02, 0x03, 0x04,
          0x05, 0x06, 0x07, 0x08,
          0x09, 0x0a, 0x0b, 0x0c
      };
  
      @Test
      public void createsJdkGcmParameterSpecFromAsn1GcmParameters() throws Exception {
          ASN1Primitive primitive = new GCMParameters(NONCE, 16).toASN1Primitive();
  
          AlgorithmParameterSpec parameterSpec = GcmSpecUtil.extractGcmSpec(primitive);
  
          assertThat(parameterSpec).isInstanceOf(GCMParameterSpec.class);
          GCMParameterSpec gcmParameterSpec = (GCMParameterSpec)parameterSpec;
          assertThat(gcmParameterSpec.getTLen()).isEqualTo(128);
          assertThat(gcmParameterSpec.getIV()).containsExactly(NONCE);
      }
