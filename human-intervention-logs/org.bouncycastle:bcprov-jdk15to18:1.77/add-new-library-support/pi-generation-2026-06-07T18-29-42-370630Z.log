rows Exception {\n        KeyFactory keyFactory = KeyFactory.getInstance(\"DSA\", new BouncyCastleProvider());\n        SubjectPublicKeyInfo publicKeyInfo = new SubjectPublicKeyInfo(\n            new AlgorithmIdentifier(X9ObjectIdentifiers.id_dsa),\n            new ASN1Integer(Y));\n        PublicKey publicKey = keyFactory.generatePublic(\n            new X509EncodedKeySpec(publicKeyInfo.getEncoded()));\n        return (DSAPublicKey)publicKey;\n    }\n"}]}
