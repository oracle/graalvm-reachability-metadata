  package org_bouncycastle.bcprov_jdk15to18;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.security.Provider;
  import java.security.SecureRandom;
  import java.security.Security;
  
  import org.bouncycastle.jce.provider.BouncyCastleProvider;
  import org.junit.jupiter.api.Test;
  
  public class DRBGTest {
      private static final String SECURE_RANDOM_SOURCE = "securerandom.source";
      private static final String STRONG_ALGORITHMS = "securerandom.strongAlgorithms";
  
      @Test
      public void createsSecureRandomFromFallbackInitialEntropySource() throws Exception {
          String originalSource = Security.getProperty(SECURE_RANDOM_SOURCE);
          String originalStrongAlgorithms = Security.getProperty(STRONG_ALGORITHMS);
  
          try {
              Security.setProperty(SECURE_RANDOM_SOURCE, "not-a-valid-url");
              Security.setProperty(STRONG_ALGORITHMS, "UnavailableSecureRandom:UnavailableProvider");
  
              Provider provider = new BouncyCastleProvider();
              assertGeneratesBytes(SecureRandom.getInstance("DEFAULT", provider));
              assertGeneratesBytes(SecureRandom.getInstance("NONCEANDIV", provider));
          } finally {
              restoreSecurityProperty(SECURE_RANDOM_SOURCE, originalSource);
              restoreSecurityProperty(STRONG_ALGORITHMS, originalStrongAlgorithms);
          }
      }
  
      private static void assertGeneratesBytes(SecureRandom random) {
          byte[] generated = new byte[32];
          random.nextBytes(generated);
  
          assertThat(generated).hasSize(32);
          assertThat(random.generateSeed(16)).hasSize(16);
      }
  
      private static void restoreSecurityProperty(String name, String value) {
          if (value == null) {
              Security.setProperty(name, "");
          } else {
              Security.setProperty(name, value);
          }
      }
  }
