ginalSecurityProperty);\n        }\n    }\n\n    private static void setEntropySourceProviderProperty(String originalSecurityProperty) {\n        String providerClassName = CountingEntropySourceProvider.class.getName();\n        if (originalSecurityProperty == null) {\n            System.setProperty(ENTROPY_SOURCE_PROPERTY, providerClassName);\n        } else {\n            Security.setProperty(ENTROPY_SOURCE_PROPERTY, providerClassName);\n        }\n    }\n\n    private static void restoreEntropySourceProviderProperty(String originalSystemProperty, String originalSecurityProperty) {\n        if (originalSystemProperty == null) {\n            System.clearProperty(ENTROPY_SOURCE_PROPERTY);\n        } else {\n            System.setProperty(ENTROPY_SOURCE_PROPERTY, originalSystemProperty);\n        }\n\n        if (originalSecurityProperty != null) {\n            Security.setProperty(ENTROPY_SOURCE_PROPERTY, originalSecurityProperty);\n        }\n    }\n\n    private static void assertGeneratesBytes(SecureRandom random) {\n        byte[] generated = new byte[32];\n        random.nextBytes(generated);\n\n        assertThat(generated).hasSize(32);\n        assertThat(random.generateSeed(16)).hasSize(16);\n    }\n\n    public static final class CountingEntropySourceProvider implements EntropySourceProvider {\n        private static final AtomicInteger INSTANCES = new AtomicInteger();\n        private static final AtomicInteger REQUESTS = new AtomicInteger();\n        private static final AtomicInteger ENTROPY_CALLS = new AtomicInteger();\n\n        public CountingEntropySourceProvider() {\n            INSTANCES.incrementAndGet();\n        }\n\n        static void reset() {\n            INSTANCES.set(0);\n            REQUESTS.set(0);\n            ENTROPY_CALLS.set(0);\n        }\n\n        static int instanceCount() {\n            return INSTANCES.get();\n        }\n\n        static int requestCount() {\n            return REQUESTS.get();\n        }\n\n        public EntropySource get(int bitsRequired) {\n            REQUESTS.incrementAndGet();\n            return new FixedEntropySource(bitsRequired);\n        }\n\n        private static final class FixedEntropySource implements EntropySource {\n            private final int bitsRequired;\n\n            private FixedEntropySource(int bitsRequired) {\n                this.bitsRequired = bitsRequired;\n            }\n\n            public boolean isPredictionResistant() {\n                return true;\n            }\n\n            public byte[] getEntropy() {\n                int call = ENTROPY_CALLS.incrementAndGet();\n                byte[] entropy = new byte[(bitsRequired + 7) / 8];\n                for (int i = 0; i < entropy.length; i++) {\n                    entropy[i] = (byte)(call + i);\n                }\n                return entropy;\n            }\n\n            public int entropySize() {\n                return bitsRequired;\n            }\n        }\n    }\n}\n"}
