ls(\"BC\", MessageDigest.getInstance(\"SHA-256\", provider).getProvider().getName());\n    }\n\n    @Test\n    void loadClassUsesLibraryClassLoaderForAlgorithmMappingClass() {\n        Class<?> loadedClass = ClassUtil.loadClass(BouncyCastleProvider.class, AES_MAPPINGS_CLASS);\n\n        assertNotNull(loadedClass);\n        assertEquals(AES_MAPPINGS_CLASS, loadedClass.getName());\n    }\n}\n"}]}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 534, "output": 1993, "cacheRead": 43520, "cacheWrite": 0, "totalTokens": 46047, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780909789735, "responseId": "resp_01a67ab516ed9015016a2686de4b5081969685a9036d97b515"}}
