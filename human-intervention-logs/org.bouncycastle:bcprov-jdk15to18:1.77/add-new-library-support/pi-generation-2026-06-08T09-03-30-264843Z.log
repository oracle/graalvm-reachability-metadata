  public class ClassUtil
  {
      public static Class loadClass(Class sourceClass, final String className)
      {
          try
          {
              ClassLoader loader = sourceClass.getClassLoader();
  
              if (loader != null)
              {
                  return loader.loadClass(className);
              }
