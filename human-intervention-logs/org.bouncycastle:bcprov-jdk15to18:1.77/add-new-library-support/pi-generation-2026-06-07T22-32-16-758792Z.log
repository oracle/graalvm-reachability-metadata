PrivateKey restored = deserialize(serialized);\n\n        assertEquals(\"DH\", restored.getAlgorithm());\n        assertEquals(\"PKCS#8\", restored.getFormat());\n        assertEquals(X, restored.inheritedX());\n        assertEquals(P, restored.inheritedParams().getP());\n        assertEquals(G, restored.inheritedParams().getG());\n        assertEquals(L, restored.inheritedParams().getL());\n    }\n\n    private static byte[] serialize(SerializableJceDhPrivateKey privateKey) throws Exception {\n        ByteArrayOutputStream byteOutputStream = new ByteArrayOutputStream();\n        try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(byteOutputStream)) {\n            objectOutputStream.writeObject(privateKey);\n        }\n        return byteOutputStream.toByteArray();\n    }\n\n    private static SerializableJceDhPrivateKey deserialize(byte[] serialized) throws Exception {\n        try (ObjectInputStream objectInputStream = new ObjectInputStream(new ByteArrayInputStream(serialized))) {\n            return (SerializableJceDhPrivateKey)objectInputStream.readObject();\n        }\n    }\n\n    private static final class SerializableJceDhPrivateKey extends JCEDHPrivateKey {\n        private final BigInteger serializableX;\n        private final DHParameterSpec serializableParams;\n\n        private SerializableJceDhPrivateKey(BigInteger x, DHParameterSpec params) {\n            this.serializableX = x;\n            this.serializableParams = params;\n        }\n\n        @Override\n        public BigInteger getX() {\n            return serializableX;\n        }\n\n        @Override\n        public DHParameterSpec getParams() {\n            return serializableParams;\n        }\n\n        private BigInteger inheritedX() {\n            return super.getX();\n        }\n\n        private DHParameterSpec inheritedParams() {\n            return super.getParams();\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage