[tool-call] delta {"path":"tests/src/org.bouncycastle/bcprov-jdk15to18/1.77/src/test/java/org_bouncycastle/bcprov_jdk15to18/BCDSTU4145PublicKeyTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk15to18;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.security.spec.ECPublicKeySpec;\n\nimport org.bouncycastle.asn1.ASN1ObjectIdentifier;\nimport org.bouncycastle.asn1.ua.DSTU4145NamedCurves;\nimport org.bouncycastle.crypto.params.ECDomainParameters;\nimport org.bouncycastle.jcajce.provider.asymmetric.dstu.BCDSTU4145PublicKey;\nimport org.bouncycastle.jce.spec.ECNamedCurveSpec;\nimport org.junit.jupiter.api.Test;\n\npublic class BCDSTU4145PublicKeyTest {\n    @Test\n    public void serializesAndDeserializesDstu4145PublicKey() throws Exception {\n        BCDSTU4145PublicKey publicKey = createPublicKey();\n\n        byte[] serializedKey = serialize(publicKey);\n        BCDSTU4145PublicKey restoredKey = deserialize(serializedKey);\n\n        assertThat(restoredKey.getAlgorithm()).isEqualTo(\"DSTU4145\");\n        assertThat(restoredKey.getFormat()).isEqualTo(\"X.509\");\n        assertThat(restoredKey.getW()).isEqualTo(publicKey.getW());\n        assertThat(restoredKey.getQ()).isEqualTo(publicKey.getQ());\n        assertThat(restoredKey.getEncoded()).isEqualTo(publicKey.getEncoded());\n        assertThat(restoredKey.getSbox()).isEqualTo(publicKey.getSbox());\n        assertThat(restoredKey.getParams().getOrder()).isEqualTo(publicKey.getParams().getOrder());\n        assertThat(restoredKey.getParams().getCofactor()).isEqualTo(publicKey.getParams().getCofactor());\n        assertThat(((ECNamedCurveSpec) restoredKey.getParams()).getName())\n                .isEqualTo(((ECNamedCurveSpec) publicKey.getParams()).getName());\n    }\n\n    private static BCDSTU4145PublicKey createPublicKey() {\n        ASN1ObjectIdentifier curveOid = DSTU4145NamedCurves.getOIDs()[0];\n        ECDomainParameters domainParameters = DSTU4145NamedCurves.getByOID(curveOid);\n        ECNamedCurveSpec curveSpec = new ECNamedCurveSpec(\n                curveOid.getId(),\n                domainParameters.getCurve(),\n                domainParameters.getG(),\n                domainParameters.getN(),\n                domainParameters.getH(),\n                domainParameters.getSeed());\n        return new BCDSTU4145PublicKey(new ECPublicKeySpec(curveSpec.getGenerator(), curveSpec));\n    }\n\n    private static byte[] serialize(BCDSTU4145PublicKey publicKey) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {\n            out.writeObject(publicKey);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static BCDSTU4145PublicKey deserialize(byte[] serializedKey) throws Exception {\n        try (ObjectInputStream in = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {\n            return (BCDSTU4145PublicKey) in.readObject();\n        }\n    }\n}\n"}
