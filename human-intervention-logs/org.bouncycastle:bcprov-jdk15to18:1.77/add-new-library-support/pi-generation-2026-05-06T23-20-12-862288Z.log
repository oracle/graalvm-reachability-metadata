  package org_bouncycastle.bcprov_jdk15to18;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.math.BigInteger;
  
  import javax.crypto.spec.DHParameterSpec;
  
  import org.bouncycastle.asn1.ASN1Encoding;
  import org.bouncycastle.asn1.ASN1Integer;
  import org.bouncycastle.asn1.pkcs.DHParameter;
  import org.bouncycastle.asn1.pkcs.PKCSObjectIdentifiers;
  import org.bouncycastle.asn1.x509.AlgorithmIdentifier;
  import org.bouncycastle.asn1.x509.SubjectPublicKeyInfo;
  import org.bouncycastle.jcajce.provider.asymmetric.dh.BCDHPublicKey;
  import org.junit.jupiter.api.Test;
  
  public class BCDHPublicKeyTest {
      private static final BigInteger PUBLIC_VALUE = BigInteger.valueOf(8);
      private static final BigInteger PRIME = BigInteger.valueOf(23);
      private static final BigInteger GENERATOR = BigInteger.valueOf(5);
      private static final int PRIVATE_VALUE_LENGTH = 5;
  
      @Test
      public void serializesAndDeserializesDiffieHellmanPublicKey() throws Exception {
          BCDHPublicKey publicKey = createPublicKey();
  
          byte[] serializedKey = serialize(publicKey);
          BCDHPublicKey restoredKey = deserialize(serializedKey);
  
          assertThat(restoredKey).isEqualTo(publicKey);
          assertThat(restoredKey.getAlgorithm()).isEqualTo("DH");
          assertThat(restoredKey.getFormat()).isEqualTo("X.509");
          assertThat(restoredKey.getY()).isEqualTo(PUBLIC_VALUE);
          assertThat(restoredKey.getParams().getP()).isEqualTo(PRIME);
          assertThat(restoredKey.getParams().getG()).isEqualTo(GENERATOR);
          assertThat(restoredKey.getParams().getL()).isEqualTo(PRIVATE_VALUE_LENGTH);
          assertThat(restoredKey.getEncoded()).isEqualTo(publicKey.getEncoded());
      }
  
      private static BCDHPublicKey createPublicKey() throws Exception {
          DHParameterSpec parameters = new DHParameterSpec(PRIME, GENERATOR, PRIVATE_VALUE_LENGTH);
          AlgorithmIdentifier algorithmIdentifier = new AlgorithmIdentifier(
                  PKCSObjectIdentifiers.dhKeyAgreement,
                  new DHParameter(parameters.getP(), parameters.getG(), parameters.getL()).toASN1Primitive());
          SubjectPublicKeyInfo publicKeyInfo = new SubjectPublicKeyInfo(
                  algorithmIdentifier,
                  new ASN1Integer(PUBLIC_VALUE));
          return new BCDHPublicKey(SubjectPublicKeyInfo.getInstance(publicKeyInfo.getEncoded(ASN1Encoding.DER)));
      }
  
      private static byte[] serialize(BCDHPublicKey publicKey) throws Exception {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {
              out.writeObject(publicKey);
          }
          return bytes.toByteArray();
      }
  
      private static BCDHPublicKey deserialize(byte[] serializedKey) throws Exception {
          try (ObjectInputStream in = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {
              return (BCDHPublicKey) in.readObject();
          }
      }
  }
