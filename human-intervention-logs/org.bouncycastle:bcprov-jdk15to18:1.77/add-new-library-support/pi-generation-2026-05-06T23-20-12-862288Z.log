  package org_bouncycastle.bcprov_jdk15to18;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.math.BigInteger;
  
  import org.bouncycastle.asn1.ASN1Encoding;
  import org.bouncycastle.asn1.ASN1Integer;
  import org.bouncycastle.asn1.x509.AlgorithmIdentifier;
  import org.bouncycastle.asn1.x509.DSAParameter;
  import org.bouncycastle.asn1.x509.SubjectPublicKeyInfo;
  import org.bouncycastle.asn1.x9.X9ObjectIdentifiers;
  import org.bouncycastle.jcajce.provider.asymmetric.dsa.BCDSAPublicKey;
  import org.junit.jupiter.api.Test;
  
  public class BCDSAPublicKeyTest {
      private static final BigInteger PUBLIC_VALUE = BigInteger.valueOf(16);
      private static final BigInteger PRIME = BigInteger.valueOf(47);
      private static final BigInteger SUBPRIME = BigInteger.valueOf(23);
      private static final BigInteger GENERATOR = BigInteger.valueOf(4);
  
      @Test
      public void serializesAndDeserializesDsaPublicKey() throws Exception {
          BCDSAPublicKey publicKey = createPublicKey();
  
          byte[] serializedKey = serialize(publicKey);
          BCDSAPublicKey restoredKey = deserialize(serializedKey);
  
          assertThat(restoredKey).isEqualTo(publicKey);
          assertThat(restoredKey.hashCode()).isEqualTo(publicKey.hashCode());
          assertThat(restoredKey.getAlgorithm()).isEqualTo("DSA");
          assertThat(restoredKey.getFormat()).isEqualTo("X.509");
          assertThat(restoredKey.getY()).isEqualTo(PUBLIC_VALUE);
          assertThat(restoredKey.getParams().getP()).isEqualTo(PRIME);
          assertThat(restoredKey.getParams().getQ()).isEqualTo(SUBPRIME);
          assertThat(restoredKey.getParams().getG()).isEqualTo(GENERATOR);
          assertThat(restoredKey.getEncoded()).isEqualTo(publicKey.getEncoded());
      }
  
      private static BCDSAPublicKey createPublicKey() throws Exception {
          DSAParameter parameters = new DSAParameter(PRIME, SUBPRIME, GENERATOR);
          AlgorithmIdentifier algorithmIdentifier = new AlgorithmIdentifier(
                  X9ObjectIdentifiers.id_dsa,
                  parameters.toASN1Primitive());
          SubjectPublicKeyInfo publicKeyInfo = new SubjectPublicKeyInfo(
                  algorithmIdentifier,
                  new ASN1Integer(PUBLIC_VALUE));
          return new BCDSAPublicKey(SubjectPublicKeyInfo.getInstance(publicKeyInfo.getEncoded(ASN1Encoding.DER)));
      }
  
      private static byte[] serialize(BCDSAPublicKey publicKey) throws Exception {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {
              out.writeObject(publicKey);
          }
          return bytes.toByteArray();
      }
  
      private static BCDSAPublicKey deserialize(byte[] serializedKey) throws Exception {
          try (ObjectInputStream in = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {
              return (BCDSAPublicKey) in.readObject();
          }
      }
  }
