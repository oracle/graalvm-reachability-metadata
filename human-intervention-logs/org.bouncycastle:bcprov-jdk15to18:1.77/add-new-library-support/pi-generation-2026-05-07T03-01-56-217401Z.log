isEqualTo(publicKey.hashCode());\n        assertThat(restoredKey.getAlgorithm()).isEqualTo(\"BIKE128\");\n        assertThat(restoredKey.getFormat()).isEqualTo(\"X.509\");\n        assertThat(restoredKey.getEncoded()).isEqualTo(publicKey.getEncoded());\n        assertThat(restoredKey.getParameterSpec().getName()).isEqualTo(BIKEParameterSpec.bike128.getName());\n    }\n\n    private static BCBIKEPublicKey createBike128PublicKey() {\n        BIKEParameters parameters = BIKEParameters.bike128;\n        BIKEPublicKeyParameters keyParameters = new BIKEPublicKeyParameters(\n                parameters,\n                createBytes(parameters.getRByte(), 1));\n        return new BCBIKEPublicKey(keyParameters);\n    }\n\n    private static byte[] createBytes(int size, int offset) {\n        byte[] bytes = new byte[size];\n        for (int index = 0; index < bytes.length; index++) {\n            bytes[index] = (byte) (index + offset);\n        }\n        return bytes;\n    }\n\n    private static byte[] serialize(BCBIKEPublicKey publicKey) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {\n            out.writeObject(publicKey);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static BCBIKEPublicKey deserialize(byte[] serializedKey) throws Exception {\n        try (ObjectInputStream in = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {\n            return (BCBIKEPublicKey) in.readObject();\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 967, "output": 930, "cacheRead": 14336, "cacheWrite": 0, "totalTokens": 16233, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778122892350, "responseId": "resp_0435b9a1d037c3750169fc008cbae88194a689a6b9755e1fd2"}, "toolResults": [{"role": "toolResult", "toolCallId