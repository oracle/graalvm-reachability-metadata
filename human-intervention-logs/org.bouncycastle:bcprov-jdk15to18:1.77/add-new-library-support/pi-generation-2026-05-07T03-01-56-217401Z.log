   }\n\n    public int getSessionKeySize()\n    {\n        return defaultKeySize;\n    }\n\n    BIKEEngine getEngine()\n    {\n        return bikeEngine;\n    }\n}\n"}], "isError": false, "timestamp": 1778122883296}]}
