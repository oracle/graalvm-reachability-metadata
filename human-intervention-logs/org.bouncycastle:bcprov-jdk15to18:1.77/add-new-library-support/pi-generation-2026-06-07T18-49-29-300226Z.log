          populateFromPubKeyInfo(SubjectPublicKeyInfo.getInstance(ASN1Primitive.fromByteArray(enc)));
      }
  
      private void writeObject(
          ObjectOutputStream out)
          throws IOException
      {
          out.defaultWriteObject();
  
          out.writeObject(this.getEncoded());
      }
