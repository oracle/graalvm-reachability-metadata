  private final byte[] encoded;\n\n        private BCDSTU4145PublicKeyEncodedKey(byte[] encoded) {\n            this.encoded = encoded.clone();\n        }\n\n        private Object readResolve() throws ObjectStreamException {\n            return encoded.clone();\n        }\n    }\n}", "newText": "        try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(byteOutputStream)) {\n            objectOutputStream.writeObject(publicKey);\n        }\n        return byteOutputStream.toByteArray();\n    }\n\n    private static ECPublicKey deserialize(byte[] serialized) throws Exception {\n        try (ObjectInputStream objectInputStream = new ObjectInputStream(\n                new ByteArrayInputStream(serialized))) {\n            return (ECPublicKey)objectInputStream.readObject();\n        }\n    }\n}"}]}
