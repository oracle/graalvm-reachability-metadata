  package org_bouncycastle.bcprov_jdk15to18;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  
  import org.bouncycastle.pqc.crypto.frodo.FrodoParameters;
  import org.bouncycastle.pqc.crypto.frodo.FrodoPrivateKeyParameters;
  import org.bouncycastle.pqc.jcajce.provider.frodo.BCFrodoPrivateKey;
  import org.bouncycastle.pqc.jcajce.spec.FrodoParameterSpec;
  import org.junit.jupiter.api.Test;
  
  public class BCFrodoPrivateKeyTest {
      @Test
      public void serializesAndDeserializesFrodoKem640AesPrivateKey() throws Exception {
          BCFrodoPrivateKey privateKey = createFrodoKem640AesPrivateKey();
  
          byte[] serializedKey = serialize(privateKey);
          BCFrodoPrivateKey restoredKey = deserialize(serializedKey);
  
          assertThat(restoredKey).isEqualTo(privateKey);
          assertThat(restoredKey.hashCode()).isEqualTo(privateKey.hashCode());
          assertThat(restoredKey.getAlgorithm()).isEqualTo("Frodo");
          assertThat(restoredKey.getFormat()).isEqualTo("PKCS#8");
          assertThat(restoredKey.getEncoded()).isEqualTo(privateKey.getEncoded());
          assertThat(restoredKey.getParameterSpec().getName()).isEqualTo(FrodoParameterSpec.frodokem640aes.getName());
      }
  
      private static BCFrodoPrivateKey createFrodoKem640AesPrivateKey() {
          return new BCFrodoPrivateKey(new FrodoPrivateKeyParameters(FrodoParameters.frodokem640aes, createBytes(32, 7)));
      }
  
      private static byte[] createBytes(int size, int offset) {
          byte[] bytes = new byte[size];
          for (int index = 0; index < bytes.length; index++) {
              bytes[index] = (byte) (index + offset);
          }
          return bytes;
      }
  
      private static byte[] serialize(BCFrodoPrivateKey privateKey) throws Exception {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {
              out.writeObject(privateKey);
          }
          return bytes.toByteArray();
      }
  
      private static BCFrodoPrivateKey deserialize(byte[] serializedKey) throws Exception {
          try (ObjectInputStream in = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {
              return (BCFrodoPrivateKey) in.readObject();
          }
      }
