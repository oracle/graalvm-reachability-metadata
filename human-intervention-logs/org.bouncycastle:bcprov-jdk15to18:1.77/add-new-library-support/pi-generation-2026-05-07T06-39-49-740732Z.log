vateKey restoredKey = deserialize(serializedKey);\n\n        assertThat(restoredKey).isEqualTo(privateKey);\n        assertThat(restoredKey.hashCode()).isEqualTo(privateKey.hashCode());\n        assertThat(restoredKey.getAlgorithm()).isEqualTo(\"SPHINCS-256\");\n        assertThat(restoredKey.getFormat()).isEqualTo(\"PKCS#8\");\n        assertThat(restoredKey.getEncoded()).isEqualTo(privateKey.getEncoded());\n        assertThat(restoredKey.getKeyData()).isEqualTo(privateKey.getKeyData());\n    }\n\n    private static BCSphincs256PrivateKey createSphincs256PrivateKey() {\n        SPHINCSPrivateKeyParameters keyParameters = new SPHINCSPrivateKeyParameters(\n                createBytes(SPHINCS_256_PRIVATE_KEY_SIZE),\n                SPHINCSKeyParameters.SHA512_256);\n        return new BCSphincs256PrivateKey(NISTObjectIdentifiers.id_sha512_256, keyParameters);\n    }\n\n    private static byte[] createBytes(int size) {\n        byte[] bytes = new byte[size];\n        for (int index = 0; index < bytes.length; index++) {\n            bytes[index] = (byte) (index * 31 + 17);\n        }\n        return bytes;\n    }\n\n    private static byte[] serialize(BCSphincs256PrivateKey privateKey) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {\n            out.writeObject(privateKey);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static BCSphincs256PrivateKey deserialize(byte[] serializedKey) throws Exception {\n        try (ObjectInputStream in = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {\n            return (BCSphincs256PrivateKey) in.readObject();\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 687, "output": 1055, "cacheRead": 38912, "cacheWrite": 0, "totalTokens": 40654, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopR