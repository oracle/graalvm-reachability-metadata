[tool-call] delta {"path":"tests/src/org.bouncycastle/bcprov-jdk15to18/1.77/src/test/java/org_bouncycastle/bcprov_jdk15to18/BCHQCPrivateKeyTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk15to18;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\n\nimport org.bouncycastle.pqc.crypto.hqc.HQCParameters;\nimport org.bouncycastle.pqc.crypto.hqc.HQCPrivateKeyParameters;\nimport org.bouncycastle.pqc.jcajce.provider.hqc.BCHQCPrivateKey;\nimport org.junit.jupiter.api.Test;\n\npublic class BCHQCPrivateKeyTest {\n    private static final int HQC128_N = 17669;\n    private static final int HQC128_PRIVATE_KEY_SIZE = 40 + 40 + ((HQC128_N + 7) / 8);\n\n    @Test\n    public void serializesAndDeserializesHqc128PrivateKey() throws Exception {\n        BCHQCPrivateKey privateKey = createHqc128PrivateKey();\n\n        byte[] serializedKey = serialize(privateKey);\n        BCHQCPrivateKey restoredKey = deserialize(serializedKey);\n\n        assertThat(restoredKey).isEqualTo(privateKey);\n        assertThat(restoredKey.hashCode()).isEqualTo(privateKey.hashCode());\n        assertThat(restoredKey.getAlgorithm()).isEqualTo(\"HQC-128\");\n        assertThat(restoredKey.getFormat()).isEqualTo(\"PKCS#8\");\n        assertThat(restoredKey.getEncoded()).isEqualTo(privateKey.getEncoded());\n    }\n\n    private static BCHQCPrivateKey createHqc128PrivateKey() {\n        HQCPrivateKeyParameters keyParameters = new HQCPrivateKeyParameters(\n                HQCParameters.hqc128,\n                createBytes(HQC128_PRIVATE_KEY_SIZE, 1));\n        return new BCHQCPrivateKey(keyParameters);\n    }\n\n    private static byte[] createBytes(int size, int offset) {\n        byte[] bytes = new byte[size];\n        for (int index = 0; index < bytes.length; index++) {\n            bytes[index] = (byte) (index + offset);\n        }\n        return bytes;\n    }\n\n    private static byte[] serialize(BCHQCPrivateKey privateKey) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {\n            out.writeObject(privateKey);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static BCHQCPrivateKey deserialize(byte[] serializedKey) throws Exception {\n        try (ObjectInputStream in = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {\n            return (BCHQCPrivateKey) in.readObject();\n        }\n    }\n}\n"}
