(parameters.toASN1Primitive());\n\n        GCMParameterSpec gcmSpec = (GCMParameterSpec)extracted;\n        assertGcmSpec(gcmSpec, 96);\n    }\n\n    private static void assertGcmSpec(GCMParameterSpec spec, int expectedTagLength) {\n        assertEquals(expectedTagLength, spec.getTLen());\n        assertArrayEquals(NONCE, spec.getIV());\n    }\n"}]}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 1356, "output": 841, "cacheRead": 41472, "cacheWrite": 0, "totalTokens": 43669, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780910743801, "responseId": "resp_0fd0aa56a7d488b6016a268a988980819782e184d167873526"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_JJ04ypjsu4aQPfDUuztpSpL5|fc_0fd0aa56a7d488b6016a268aa27e7081978fcf22e91c3edf87", "toolName": "edit", "content": [{"type": "text", "text": "Successfully replaced 2 block(s) in tests/src/org.bouncycastle/bcprov-jdk15to18/1.77/src/test/java/org_bouncycastle/bcprov_jdk15to18/GcmSpecUtilTest.java."}], "details": {"diff": "    ...\n  9 import static org.junit.jupiter.api.Assertions.assertArrayEquals;\n 10 import static org.junit.jupiter.api.Assertions.assertEquals;\n 11 \n 12 import java.security.AlgorithmParameters;\n+13 import java.security.spec.AlgorithmParameterSpec;\n 13 \n 14 import javax.crypto.spec.GCMParameterSpec;\n 15 \n+17 import org.bouncycastle.internal.asn1.cms.GCMParameters;\n+18 import org.bouncycastle.jcajce.provider.symmetric.util.GcmSpecUtil;\n 16 import org.bouncycastle.jce.provider.BouncyCastleProvider;\n 17 import org.junit.jupiter.api.Test;\n 18 \n 19 public class GcmSpecUtilTest {\n    ...\n 29         parameters.init(new GCMParameterSpec(96, NONCE));\n 30 \n 31         GCMParameterSpec extracted = parameters.getParameterSpec(GCMParameterSpec.class);\n 32 \n-33         assertEquals(96, extracted.getTLen());\n-34         assertArrayEquals(NONCE, extracted.getIV());\n+36   