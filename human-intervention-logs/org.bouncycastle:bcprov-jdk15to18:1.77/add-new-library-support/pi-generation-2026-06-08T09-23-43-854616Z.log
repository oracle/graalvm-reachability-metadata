     aes-nonce        OCTET STRING, -- recommended size is 12 octets
     aes-ICVlen       AES-GCM-ICVlen DEFAULT 12 }
   * </pre>
   */
  public class GCMParameters
      extends ASN1Object
  {
      private byte[] nonce;
      private int icvLen;
  
      /**
       * Return an GCMParameters object from the given object.
       * <p>
       * Accepted inputs:
