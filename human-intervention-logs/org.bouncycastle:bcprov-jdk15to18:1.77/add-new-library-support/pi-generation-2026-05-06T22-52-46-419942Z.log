[tool-call] delta {"path":"tests/src/org.bouncycastle/bcprov-jdk15to18/1.77/src/test/java/org_bouncycastle/bcprov_jdk15to18/BCDSAPrivateKeyTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk15to18;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.math.BigInteger;\n\nimport org.bouncycastle.asn1.ASN1Encoding;\nimport org.bouncycastle.asn1.ASN1Integer;\nimport org.bouncycastle.asn1.pkcs.PrivateKeyInfo;\nimport org.bouncycastle.asn1.x509.AlgorithmIdentifier;\nimport org.bouncycastle.asn1.x509.DSAParameter;\nimport org.bouncycastle.asn1.x9.X9ObjectIdentifiers;\nimport org.bouncycastle.jcajce.provider.asymmetric.dsa.BCDSAPrivateKey;\nimport org.junit.jupiter.api.Test;\n\npublic class BCDSAPrivateKeyTest {\n    private static final BigInteger PRIVATE_VALUE = BigInteger.valueOf(7);\n    private static final BigInteger PRIME = BigInteger.valueOf(47);\n    private static final BigInteger SUBPRIME = BigInteger.valueOf(23);\n    private static final BigInteger GENERATOR = BigInteger.valueOf(4);\n\n    @Test\n    public void serializesAndDeserializesDsaPrivateKey() throws Exception {\n        BCDSAPrivateKey privateKey = createPrivateKey();\n\n        byte[] serializedKey = serialize(privateKey);\n        BCDSAPrivateKey restoredKey = deserialize(serializedKey);\n\n        assertThat(restoredKey).isEqualTo(privateKey);\n        assertThat(restoredKey.hashCode()).isEqualTo(privateKey.hashCode());\n        assertThat(restoredKey.getAlgorithm()).isEqualTo(\"DSA\");\n        assertThat(restoredKey.getFormat()).isEqualTo(\"PKCS#8\");\n        assertThat(restoredKey.getX()).isEqualTo(PRIVATE_VALUE);\n        assertThat(restoredKey.getParams().getP()).isEqualTo(PRIME);\n        assertThat(restoredKey.getParams().getQ()).isEqualTo(SUBPRIME);\n        assertThat(restoredKey.getParams().getG()).isEqualTo(GENERATOR);\n        assertThat(restoredKey.getEncoded()).isEqualTo(privateKey.getEncoded());\n    }\n\n    private static BCDSAPrivateKey createPrivateKey() throws Exception {\n        DSAParameter parameters = new DSAParameter(PRIME, SUBPRIME, GENERATOR);\n        AlgorithmIdentifier algorithmIdentifier = new AlgorithmIdentifier(\n                X9ObjectIdentifiers.id_dsa,\n                parameters.toASN1Primitive());\n        PrivateKeyInfo privateKeyInfo = new PrivateKeyInfo(algorithmIdentifier, new ASN1Integer(PRIVATE_VALUE));\n        return new BCDSAPrivateKey(PrivateKeyInfo.getInstance(privateKeyInfo.getEncoded(ASN1Encoding.DER)));\n    }\n\n    private static byte[] serialize(BCDSAPrivateKey privateKey) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {\n            out.writeObject(privateKey);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static BCDSAPrivateKey deserialize(byte[] serializedKey) throws Exception {\n        try (ObjectInputStream in = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {\n            return (BCDSAPrivateKey) in.readObject();\n        }\n    }\n}\n"}
