[tool-call] delta {"path":"tests/src/org.bouncycastle/bcprov-jdk15to18/1.77/src/test/java/org_bouncycastle/bcprov_jdk15to18/BCElGamalPrivateKeyTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk15to18;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.math.BigInteger;\nimport java.security.KeyFactory;\n\nimport org.bouncycastle.jcajce.provider.asymmetric.elgamal.BCElGamalPrivateKey;\nimport org.bouncycastle.jce.interfaces.ElGamalPrivateKey;\nimport org.bouncycastle.jce.provider.BouncyCastleProvider;\nimport org.bouncycastle.jce.spec.ElGamalParameterSpec;\nimport org.bouncycastle.jce.spec.ElGamalPrivateKeySpec;\nimport org.junit.jupiter.api.Test;\n\npublic class BCElGamalPrivateKeyTest {\n    private static final BigInteger PRIVATE_VALUE = BigInteger.valueOf(11);\n    private static final BigInteger PRIME = BigInteger.valueOf(23);\n    private static final BigInteger GENERATOR = BigInteger.valueOf(5);\n\n    @Test\n    public void serializesAndDeserializesElGamalPrivateKey() throws Exception {\n        BCElGamalPrivateKey privateKey = createPrivateKey();\n\n        byte[] serializedKey = serialize(privateKey);\n        BCElGamalPrivateKey restoredKey = deserialize(serializedKey);\n\n        assertThat(restoredKey).isEqualTo(privateKey);\n        assertThat(restoredKey.getAlgorithm()).isEqualTo(\"ElGamal\");\n        assertThat(restoredKey.getFormat()).isEqualTo(\"PKCS#8\");\n        assertThat(restoredKey.getX()).isEqualTo(PRIVATE_VALUE);\n        assertThat(restoredKey.getParameters().getP()).isEqualTo(PRIME);\n        assertThat(restoredKey.getParameters().getG()).isEqualTo(GENERATOR);\n        assertThat(restoredKey.getParams().getP()).isEqualTo(PRIME);\n        assertThat(restoredKey.getParams().getG()).isEqualTo(GENERATOR);\n        assertThat(restoredKey.getEncoded()).isEqualTo(privateKey.getEncoded());\n    }\n\n    private static BCElGamalPrivateKey createPrivateKey() throws Exception {\n        ElGamalParameterSpec parameters = new ElGamalParameterSpec(PRIME, GENERATOR);\n        ElGamalPrivateKeySpec keySpec = new ElGamalPrivateKeySpec(PRIVATE_VALUE, parameters);\n        KeyFactory keyFactory = KeyFactory.getInstance(\"ElGamal\", new BouncyCastleProvider());\n        ElGamalPrivateKey privateKey = (ElGamalPrivateKey) keyFactory.generatePrivate(keySpec);\n\n        assertThat(privateKey).isInstanceOf(BCElGamalPrivateKey.class);\n        return (BCElGamalPrivateKey) privateKey;\n    }\n\n    private static byte[] serialize(BCElGamalPrivateKey privateKey) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {\n            out.writeObject(privateKey);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static BCElGamalPrivateKey deserialize(byte[] serializedKey) throws Exception {\n        try (ObjectInputStream in = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {\n            return (BCElGamalPrivateKey) in.readObject();\n        }\n    }\n}\n"}
