rc/org.bouncycastle/bcprov-jdk15to18/1.77/src/test/java/org_bouncycastle/bcprov_jdk15to18/BCNTRUPublicKeyTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk15to18;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\n\nimport org.bouncycastle.pqc.crypto.ntru.NTRUParameters;\nimport org.bouncycastle.pqc.crypto.ntru.NTRUPublicKeyParameters;\nimport org.bouncycastle.pqc.jcajce.provider.ntru.BCNTRUPublicKey;\nimport org.bouncycastle.pqc.jcajce.spec.NTRUParameterSpec;\nimport org.junit.jupiter.api.Test;\n\npublic class BCNTRUPublicKeyTest {\n    @Test\n    public void serializesAndDeserializesNtruHps2048509PublicKey() throws Exception {\n        BCNTRUPublicKey publicKey = createNtruHps2048509PublicKey();\n\n        byte[] serializedKey = serialize(publicKey);\n        BCNTRUPublicKey restoredKey = deserialize(serializedKey);\n\n        assertThat(restoredKey).isEqualTo(publicKey);\n        assertThat(restoredKey.hashCode()).isEqualTo(publicKey.hashCode());\n        assertThat(restoredKey.getAlgorithm()).isEqualTo(\"NTRU\");\n        assertThat(restoredKey.getFormat()).isEqualTo(\"X.509\");\n        assertThat(restoredKey.getEncoded()).isEqualTo(publicKey.getEncoded());\n        assertThat(restoredKey.getParameterSpec().getName())\n                .isEqualTo(NTRUParameterSpec.ntruhps2048509.getName());\n    }\n\n    private static BCNTRUPublicKey createNtruHps2048509PublicKey() {\n        NTRUPublicKeyParameters keyParameters = new NTRUPublicKeyParameters(\n                NTRUParameters.ntruhps2048509,\n                createBytes(699, 23));\n        return new BCNTRUPublicKey(keyParameters);\n    }\n\n    private static byte[] createBytes(int size, int offset) {\n        byte[] bytes = new byte[size];\n        for (int index = 0; index < bytes.length; index++) {\n            bytes[index] = (byte) (index + offset);\n        }\n        return bytes;\n    }\n\n    private static byte[] serialize(BCNTRUPublicKey publicKey) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {\n            out.writeObject(publicKey);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static BCNTRUPublicKey deserialize(byte[] serializedKey) throws Exception {\n        try (ObjectInputStream in = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {\n            return (BCNTRUPublicKey) in.readObject();\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 446, "output": 868, "cacheRead": 19968, "cacheWrite": 0, "totalTokens": 21282, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778131861949, "responseId": "resp_0e33821d8e7277f00169fc239789308197a8a66b1c67ea3538"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_RrNuyOtNio6GTbprnrmgv7Pe|fc_0e33821d8e7277f00169fc239bc2dc8197aae1735a25f976a2", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2652 bytes to tests/src/org.bouncycastle/bcprov-jdk15to18/1.77/src/test/java/org_bouncycastle/bcprov_jdk15to18/BCNTRUPublicKeyTest.java"}], "isError": false, "timestamp": 1778131872590}]}
