          attrCarrier.readObject(in);
      }
  
      private void writeObject(
          ObjectOutputStream out)
          throws IOException
      {
          out.writeObject(x);
          out.writeObject(dsaSpec.getP());
          out.writeObject(dsaSpec.getQ());
          out.writeObject(dsaSpec.getG());
  
          attrCarrier.writeObject(out);
      }
  }
