hat(restoredKey.getParams().getP()).isEqualTo(PRIME);\n        assertThat(restoredKey.getParams().getQ()).isEqualTo(SUBPRIME);\n        assertThat(restoredKey.getParams().getG()).isEqualTo(GENERATOR);\n        assertThat(restoredKey.getBagAttributeKeys().hasMoreElements()).isFalse();\n        assertThat(restoredKey.getEncoded()).isEqualTo(privateKey.getEncoded());\n    }\n\n    private static byte[] serializationBytesForJdkDsaPrivateKey() throws Exception {\n        byte[] serializedProxy = serialize(new SerializedJdkDsaPrivateKeyProxy());\n        return replaceSerializedClassName(\n                serializedProxy,\n                SerializedJdkDsaPrivateKeyProxy.class.getName(),\n                JDKDSAPrivateKey.class.getName());\n    }\n\n    private static byte[] replaceSerializedClassName(byte[] serializedObject, String originalName, String replacementName)\n            throws IOException {\n        byte[] originalNameBytes = originalName.getBytes(StandardCharsets.UTF_8);\n        byte[] replacementNameBytes = replacementName.getBytes(StandardCharsets.UTF_8);\n        int nameIndex = findSerializedClassName(serializedObject, originalNameBytes);\n\n        ByteArrayOutputStream patchedObject = new ByteArrayOutputStream();\n        patchedObject.write(serializedObject, 0, nameIndex - 2);\n        patchedObject.write((replacementNameBytes.length >>> 8) & 0xff);\n        patchedObject.write(replacementNameBytes.length & 0xff);\n        patchedObject.write(replacementNameBytes);\n        patchedObject.write(\n                serializedObject,\n                nameIndex + originalNameBytes.length,\n                serializedObject.length - nameIndex - originalNameBytes.length);\n        return patchedObject.toByteArray();\n    }\n\n    private static int findSerializedClassName(byte[] serializedObject, byte[] classNameBytes) {\n        int foundIndex = -1;\n        for (int index = 2; index <= serializedObject.length - classNameBytes.length; index++) {\n            if (hasSerializedUtfLength(serializedObject, index, classNameBytes.length)\n                    && matchesBytes(serializedObject, index, classNameBytes)) {\n                assertThat(foundIndex).isEqualTo(-1);\n                foundIndex = index;\n            }\n        }\n        assertThat(foundIndex).isNotEqualTo(-1);\n        return foundIndex;\n    }\n\n    private static boolean hasSerializedUtfLength(byte[] serializedObject, int valueIndex, int expectedLength) {\n        int actualLength = ((serializedObject[valueIndex - 2] & 0xff) << 8) | (serializedObject[valueIndex - 1] & 0xff);\n        return actualLength == expectedLength;\n    }\n\n    private static boolean matchesBytes(byte[] serializedObject, int offset, byte[] expectedBytes) {\n        for (int index = 0; index < expectedBytes.length; index++) {\n            if (serializedObject[offset + index] != expectedBytes[index]) {\n                return false;\n            }\n        }\n        return true;\n    }\n\n    private static byte[] serialize(Object object) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {\n            out.writeObject(object);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static JDKDSAPrivateKey deserialize(byte[] serializedKey) throws Exception {\n        try (ObjectInputStream in = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {\n            return (JDKDSAPrivateKey) in.readObject();\n        }\n    }\n\n    private static final class SerializedJdkDsaPrivateKeyProxy implements Serializable {\n        private static final long serialVersionUID = -4677259546958385734L;\n\n        private void writeObject(ObjectOutputStream out) throws IOException {\n            out.writeObject(PRIVATE_VALUE);\n            out.writeObject(PRIME);\n            out.writeObject(SUBPRIME);\n            out.writeObject(GENERATOR);\n            out.writeObject(new Hashtable<>());\n            out.writeObject(new Vector<>());\n        }\n    }\n}\n"}
