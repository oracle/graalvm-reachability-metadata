ymmetric.ec.BCECPrivateKey;\nimport org.bouncycastle.jce.ECNamedCurveTable;\nimport org.bouncycastle.jce.provider.BouncyCastleProvider;\nimport org.bouncycastle.jce.spec.ECNamedCurveParameterSpec;\nimport org.bouncycastle.jce.spec.ECPrivateKeySpec;\nimport org.junit.jupiter.api.Test;\n\npublic class BCECPrivateKeyTest {\n    private static final BigInteger PRIVATE_VALUE = BigInteger.valueOf(29);\n    private static final String CURVE_NAME = \"secp256r1\";\n\n    @Test\n    public void serializesAndDeserializesEcPrivateKey() throws Exception {\n        BCECPrivateKey privateKey = createPrivateKey();\n\n        byte[] serializedKey = serialize(privateKey);\n        BCECPrivateKey restoredKey = deserialize(serializedKey);\n\n        assertThat(restoredKey).isEqualTo(privateKey);\n        assertThat(restoredKey.hashCode()).isEqualTo(privateKey.hashCode());\n        assertThat(restoredKey.getAlgorithm()).isEqualTo(\"EC\");\n        assertThat(restoredKey.getFormat()).isEqualTo(\"PKCS#8\");\n        assertThat(restoredKey.getD()).isEqualTo(PRIVATE_VALUE);\n        assertThat(restoredKey.getS()).isEqualTo(PRIVATE_VALUE);\n        assertThat(restoredKey.getEncoded()).isEqualTo(privateKey.getEncoded());\n        assertThat(restoredKey.getParameters()).isInstanceOf(ECNamedCurveParameterSpec.class);\n        assertThat(restoredKey.getParameters().getN()).isEqualTo(privateKey.getParameters().getN());\n        assertThat(restoredKey.getParameters().getH()).isEqualTo(privateKey.getParameters().getH());\n    }\n\n    private static BCECPrivateKey createPrivateKey() {\n        ECNamedCurveParameterSpec curveSpec = ECNamedCurveTable.getParameterSpec(CURVE_NAME);\n        assertThat(curveSpec).isNotNull();\n        return new BCECPrivateKey(\n                \"EC\",\n                new ECPrivateKeySpec(PRIVATE_VALUE, curveSpec),\n                BouncyCastleProvider.CONFIGURATION);\n    }\n\n    private static byte[] serialize(BCECPrivateKey privateKey) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {\n            out.writeObject(privateKey);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static BCECPrivateKey deserialize(byte[] serializedKey) throws Exception {\n        try (ObjectInputStream in = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {\n            return (BCECPrivateKey) in.readObject();\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778111667274}, {"role": "toolResult", "toolCallId": "call_TAvl2fL68A5TEv7Ustw4eCcO|fc_06da26dfdab61b7c0169fbd4b31538819fa9aeea3b666bdf38", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk15to18;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.math.BigInteger;\n\nimport org.bouncycastle.asn1.ASN1Encoding;\nimport org.bouncycastle.asn1.ASN1Integer;\nimport org.bouncycastle.asn1.pkcs.PrivateKeyInfo;\nimport org.bouncycastle.asn1.x509.AlgorithmIdentifier;\nimport org.bouncycastle.asn1.x509.DSAParameter;\nimport org.bouncycastle.asn1.x9.X9ObjectIdentifiers;\nimport org.bouncycastle.jcajce.provider.asymmetric.dsa.BCDSAPrivateKey;\nimport org.junit.jupiter.api.Test;\n\npublic class BCDSAPrivateKeyTest {\n    private static final BigInteger PRIVATE_VALUE = BigInteger.valueOf(7);\n    private static final BigInteger PRIME = BigInteger.valueOf(47);\n    private static final BigInteger SUBPRIME = BigInteger.valueOf(23);\n    private static final BigInteger GENERATOR = BigInteger.valueOf(4);\n\n    @Test\n    public void serializesAndDeserializesDsaPrivateKey() throws Exception {\n        BCDSAPrivateKey privateKey = createPrivateKey();\n\n        byte[] serializedKey = serialize(privateKey);\n        BCDSAPrivateKey restoredKey = deserialize(serializedKey);\n\n        assertThat(restoredKey).isEqualTo(privateKey);\n        assertThat(restoredKey.hashCode()).isEqualTo(privateKey.hashCode());\n        assertThat(restoredKey.getAlgorithm()).isEqualTo(\"DSA\");\n        assertThat(restoredKey.getFormat()).isEqualTo(\"PKCS#8\");\n        assertThat(restoredKey.getX()).isEqualTo(PRIVATE_VALUE);\n        assertThat(restoredKey.getParams().getP()).isEqualTo(PRIME);\n        assertThat(restoredKey.getParams().getQ()).isEqualTo(SUBPRIME);\n        assertThat(restoredKey.getParams().getG()).isEqualTo(GENERATOR);\n        assertThat(restoredKey.getEncoded()).isEqualTo(privateKey.getEncoded());\n    }\n\n    private static BCDSAPrivateKey createPrivateKey() throws Exception {\n        DSAParameter parameters = new DSAParameter(PRIME, SUBPRIME, GENERATOR);\n        AlgorithmIdentifier algorithmIdentifier = new AlgorithmIdentifier(\n                X9ObjectIdentifiers.id_dsa,\n                parameters.toASN1Primitive());\n        PrivateKeyInfo privateKeyInfo = new PrivateKeyInfo(algorithmIdentifier, new ASN1Integer(PRIVATE_VALUE));\n        return new BCDSAPrivateKey(PrivateKeyInfo.getInstance(privateKeyInfo.getEncoded(ASN1Encoding.DER)));\n    }\n\n    private static byte[] serialize(BCDSAPrivateKey privateKey) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {\n            out.writeObject(privateKey);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static BCDSAPrivateKey deserialize(byte[] serializedKey) throws Exception {\n        try (ObjectInputStream in = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {\n            return (BCDSAPrivateKey) in.readObject();\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778111667274}, {"role": "toolResult", "toolCallId": "call_B6LKaWGpo5Spl80YofMns9dy|fc_06da26dfdab61b7c0169fbd4b31564819fa46e35c945e7457b", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\nplugins {\n    id \"org.graalvm.internal.tck\"\n}\n\nString libraryVersion = tck.testedLibraryVersion.get()\n\ndependencies {\n    testImplementation \"org.bouncycastle:bcprov-jdk15to18:$libraryVersion\"\n    testImplementation 'org.assertj:assertj-core:3.22.0'\n}\n\ngraalvmNative {\n    agent {\n        defaultMode = \"conditional\"\n        modes {\n            conditional {\n                userCodeFilterPath = \"user-code-filter.json\"\n            }\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778111667274}]}
