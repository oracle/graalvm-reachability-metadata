              eddsaPrivateKey = new Ed448PrivateKeyParameters(encoding);
              eddsaPublicKey = ((Ed448PrivateKeyParameters)eddsaPrivateKey).generatePublicKey();
          }
          else
          {
              eddsaPrivateKey = new Ed25519PrivateKeyParameters(encoding);
