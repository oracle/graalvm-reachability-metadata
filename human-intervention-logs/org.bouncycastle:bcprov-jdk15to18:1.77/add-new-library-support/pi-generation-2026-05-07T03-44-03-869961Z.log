[tool-call] delta {"path":"tests/src/org.bouncycastle/bcprov-jdk15to18/1.77/src/test/java/org_bouncycastle/bcprov_jdk15to18/BCFalconPublicKeyTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk15to18;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\n\nimport org.bouncycastle.pqc.crypto.falcon.FalconParameters;\nimport org.bouncycastle.pqc.crypto.falcon.FalconPublicKeyParameters;\nimport org.bouncycastle.pqc.jcajce.provider.falcon.BCFalconPublicKey;\nimport org.bouncycastle.pqc.jcajce.spec.FalconParameterSpec;\nimport org.junit.jupiter.api.Test;\n\npublic class BCFalconPublicKeyTest {\n    private static final int FALCON_512_PUBLIC_KEY_SIZE = 897;\n\n    @Test\n    public void serializesAndDeserializesFalcon512PublicKey() throws Exception {\n        BCFalconPublicKey publicKey = createFalcon512PublicKey();\n\n        byte[] serializedKey = serialize(publicKey);\n        BCFalconPublicKey restoredKey = deserialize(serializedKey);\n\n        assertThat(restoredKey).isEqualTo(publicKey);\n        assertThat(restoredKey.hashCode()).isEqualTo(publicKey.hashCode());\n        assertThat(restoredKey.getAlgorithm()).isEqualTo(\"FALCON-512\");\n        assertThat(restoredKey.getFormat()).isEqualTo(\"X.509\");\n        assertThat(restoredKey.getEncoded()).isEqualTo(publicKey.getEncoded());\n        assertThat(restoredKey.getParameterSpec().getName()).isEqualTo(FalconParameterSpec.falcon_512.getName());\n    }\n\n    private static BCFalconPublicKey createFalcon512PublicKey() {\n        FalconPublicKeyParameters keyParameters = new FalconPublicKeyParameters(\n                FalconParameters.falcon_512,\n                createBytes(FALCON_512_PUBLIC_KEY_SIZE, 53));\n        return new BCFalconPublicKey(keyParameters);\n    }\n\n    private static byte[] createBytes(int size, int offset) {\n        byte[] bytes = new byte[size];\n        for (int index = 0; index < bytes.length; index++) {\n            bytes[index] = (byte) (index + offset);\n        }\n        return bytes;\n    }\n\n    private static byte[] serialize(BCFalconPublicKey publicKey) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {\n            out.writeObject(publicKey);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static BCFalconPublicKey deserialize(byte[] serializedKey) throws Exception {\n        try (ObjectInputStream in = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {\n            return (BCFalconPublicKey) in.readObject();\n        }\n    }\n}\n"}
