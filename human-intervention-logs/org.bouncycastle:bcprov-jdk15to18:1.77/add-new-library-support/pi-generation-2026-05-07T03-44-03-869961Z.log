c.crypto.falcon.FalconPublicKeyParameters;\nimport org.bouncycastle.pqc.crypto.util.PublicKeyFactory;\nimport org.bouncycastle.pqc.jcajce.interfaces.FalconPublicKey;\nimport org.bouncycastle.pqc.jcajce.provider.util.KeyUtil;\nimport org.bouncycastle.pqc.jcajce.spec.FalconParameterSpec;\nimport org.bouncycastle.util.Arrays;\nimport org.bouncycastle.util.Strings;\n\npublic class BCFalconPublicKey\n    implements FalconPublicKey\n{\n    private static final long serialVersionUID = 1L;\n\n    private transient FalconPublicKeyParameters params;\n    private transient String algorithm;\n    private transient byte[] encoding;\n\n    public BCFalconPublicKey(\n        FalconPublicKeyParameters params)\n    {\n        init(params);\n    }\n\n    public BCFalconPublicKey(SubjectPublicKeyInfo keyInfo)\n        throws IOException\n    {\n        init(keyInfo);\n    }\n\n    private void init(SubjectPublicKeyInfo keyInfo)\n        throws IOException\n    {\n        init((FalconPublicKeyParameters)PublicKeyFactory.createKey(keyInfo));\n    }\n    private void init(FalconPublicKeyParameters params)\n    {\n        this.params = params;\n        this.algorithm = Strings.toUpperCase(params.getParameters().getName());\n    }\n\n\n    /**\n     * Compare this Falcon public key with another object.\n     *\n     * @param o the other object\n     * @return the result of the comparison\n     */\n    public boolean equals(Object o)\n    {\n        if (o == this)\n        {\n            return true;\n        }\n\n        if (o instanceof BCFalconPublicKey)\n        {\n            BCFalconPublicKey otherKey = (BCFalconPublicKey)o;\n\n            return Arrays.areEqual(this.getEncoded(), otherKey.getEncoded());\n        }\n\n        return false;\n    }\n\n    public int hashCode()\n    {\n        return Arrays.hashCode(getEncoded());\n    }\n\n    /**\n     * @return name of the algorithm - \"FALCON-512 or FALCON-1024\"\n     */\n    public final String getAlgorithm()\n    {\n        return algorithm;\n    }\n\n    public byte[] getEncoded()\n    {\n        if (encoding == null)\n        {\n            encoding = KeyUtil.getEncodedSubjectPublicKeyInfo(params);\n        }\n\n        return Arrays.clone(encoding);\n    }\n\n    public String getFormat()\n    {\n        return \"X.509\";\n    }\n\n    public FalconParameterSpec getParameterSpec()\n    {\n        return FalconParameterSpec.fromName(params.getParameters().getName());\n    }\n\n    FalconPublicKeyParameters getKeyParams()\n    {\n        return params;\n    }\n\n    private void readObject(\n        ObjectInputStream in)\n        throws IOException, ClassNotFoundException\n    {\n        in.defaultReadObject();\n\n        byte[] enc = (byte[])in.readObject();\n\n        init(SubjectPublicKeyInfo.getInstance(enc));\n    }\n\n    private void writeObject(\n        ObjectOutputStream out)\n        throws IOException\n    {\n        out.defaultWriteObject();\n\n        out.writeObject(this.getEncoded());\n    }\n}\n"}], "isError": false, "timestamp": 1778125416957}, {"role": "toolResult", "toolCallId": "call_6VO7j3G3EG36zw6jK6AtjF7K|fc_007c4a31d0d4733a0169fc0a68c67081a299a4eb1b51605096", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk15to18;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\n\nimport org.bouncycastle.pqc.crypto.falcon.FalconParameters;\nimport org.bouncycastle.pqc.crypto.falcon.FalconPrivateKeyParameters;\nimport org.bouncycastle.pqc.jcajce.provider.falcon.BCFalconPrivateKey;\nimport org.bouncycastle.pqc.jcajce.spec.FalconParameterSpec;\nimport org.junit.jupiter.api.Test;\n\npublic class BCFalconPrivateKeyTest {\n    private static final int FALCON_512_SECRET_POLYNOMIAL_SIZE = 512;\n    private static final int FALCON_512_PUBLIC_KEY_SIZE = 897;\n\n    @Test\n    public void serializesAndDeserializesFalcon512PrivateKey() throws Exception {\n        BCFalconPrivateKey privateKey = createFalcon512PrivateKey();\n\n        byte[] serializedKey = serialize(privateKey);\n        BCFalconPrivateKey restoredKey = deserialize(serializedKey);\n\n        assertThat(restoredKey).isEqualTo(privateKey);\n        assertThat(restoredKey.hashCode()).isEqualTo(privateKey.hashCode());\n        assertThat(restoredKey.getAlgorithm()).isEqualTo(\"FALCON-512\");\n        assertThat(restoredKey.getFormat()).isEqualTo(\"PKCS#8\");\n        assertThat(restoredKey.getEncoded()).isEqualTo(privateKey.getEncoded());\n        assertThat(restoredKey.getPublicKey().getEncoded()).isEqualTo(privateKey.getPublicKey().getEncoded());\n        assertThat(restoredKey.getParameterSpec().getName()).isEqualTo(FalconParameterSpec.falcon_512.getName());\n    }\n\n    private static BCFalconPrivateKey createFalcon512PrivateKey() {\n        FalconPrivateKeyParameters keyParameters = new FalconPrivateKeyParameters(\n                FalconParameters.falcon_512,\n                createBytes(FALCON_512_SECRET_POLYNOMIAL_SIZE, 1),\n                createBytes(FALCON_512_SECRET_POLYNOMIAL_SIZE, 19),\n                createBytes(FALCON_512_SECRET_POLYNOMIAL_SIZE, 37),\n                createBytes(FALCON_512_PUBLIC_KEY_SIZE, 53));\n        return new BCFalconPrivateKey(keyParameters);\n    }\n\n    private static byte[] createBytes(int size, int offset) {\n        byte[] bytes = new byte[size];\n        for (int index = 0; index < bytes.length; index++) {\n            bytes[index] = (byte) (index + offset);\n        }\n        return bytes;\n    }\n\n    private static byte[] serialize(BCFalconPrivateKey privateKey) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {\n            out.writeObject(privateKey);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static BCFalconPrivateKey deserialize(byte[] serializedKey) throws Exception {\n        try (ObjectInputStream in = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {\n            return (BCFalconPrivateKey) in.readObject();\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778125416957}, {"role": "toolResult", "toolCallId": "call_fJk9GLA4JNuJibOHD9UZChz4|fc_007c4a31d0d4733a0169fc0a68c67881a2801e9698ee2377dc", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk15to18;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\n\nimport org.bouncycastle.pqc.crypto.crystals.dilithium.DilithiumParameters;\nimport org.bouncycastle.pqc.crypto.crystals.dilithium.DilithiumPublicKeyParameters;\nimport org.bouncycastle.pqc.jcajce.provider.dilithium.BCDilithiumPublicKey;\nimport org.bouncycastle.pqc.jcajce.spec.DilithiumParameterSpec;\nimport org.junit.jupiter.api.Test;\n\npublic class BCDilithiumPublicKeyTest {\n    private static final int RHO_SIZE = 32;\n    private static final int DILITHIUM2_T1_SIZE = 1280;\n\n    @Test\n    public void serializesAndDeserializesDilithium2PublicKey() throws Exception {\n        BCDilithiumPublicKey publicKey = createDilithium2PublicKey();\n\n        byte[] serializedKey = serialize(publicKey);\n        BCDilithiumPublicKey restoredKey = deserialize(serializedKey);\n\n        assertThat(restoredKey).isEqualTo(publicKey);\n        assertThat(restoredKey.hashCode()).isEqualTo(publicKey.hashCode());\n        assertThat(restoredKey.getAlgorithm()).isEqualTo(\"DILITHIUM2\");\n        assertThat(restoredKey.getFormat()).isEqualTo(\"X.509\");\n        assertThat(restoredKey.getEncoded()).isEqualTo(publicKey.getEncoded());\n        assertThat(restoredKey.getParameterSpec().getName()).isEqualTo(DilithiumParameterSpec.dilithium2.getName());\n    }\n\n    private static BCDilithiumPublicKey createDilithium2PublicKey() {\n        DilithiumPublicKeyParameters keyParameters = new DilithiumPublicKeyParameters(\n                DilithiumParameters.dilithium2,\n                createBytes(RHO_SIZE, 1),\n                createBytes(DILITHIUM2_T1_SIZE, 47));\n        return new BCDilithiumPublicKey(keyParameters);\n    }\n\n    private static byte[] createBytes(int size, int offset) {\n        byte[] bytes = new byte[size];\n        for (int index = 0; index < bytes.length; index++) {\n            bytes[index] = (byte) (index + offset);\n        }\n        return bytes;\n    }\n\n    private static byte[] serialize(BCDilithiumPublicKey publicKey) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {\n            out.writeObject(publicKey);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static BCDilithiumPublicKey deserialize(byte[] serializedKey) throws Exception {\n        try (ObjectInputStream in = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {\n            return (BCDilithiumPublicKey) in.readObject();\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778125416957}]}
