      {
          if (o instanceof CMCEPrivateKey)
          {
              return (CMCEPrivateKey)o;
          }
          else if (o != null)
          {
              return new CMCEPrivateKey(ASN1Sequence.getInstance(o));
          }
  
          return null;
      }
  }
