.bouncycastle.pqc.crypto.cmce.CMCEPrivateKeyParameters;\nimport org.bouncycastle.pqc.crypto.util.PrivateKeyFactory;\nimport org.bouncycastle.pqc.crypto.util.PrivateKeyInfoFactory;\nimport org.bouncycastle.pqc.jcajce.interfaces.CMCEKey;\nimport org.bouncycastle.pqc.jcajce.spec.CMCEParameterSpec;\nimport org.bouncycastle.util.Arrays;\nimport org.bouncycastle.util.Strings;\n\npublic class BCCMCEPrivateKey\n    implements PrivateKey, CMCEKey\n{\n    private static final long serialVersionUID = 1L;\n\n    private transient CMCEPrivateKeyParameters params;\n    private transient ASN1Set attributes;\n\n    public BCCMCEPrivateKey(\n        CMCEPrivateKeyParameters params)\n    {\n        this.params = params;\n    }\n\n    public BCCMCEPrivateKey(PrivateKeyInfo keyInfo)\n        throws IOException\n    {\n        init(keyInfo);\n    }\n\n    private void init(PrivateKeyInfo keyInfo)\n        throws IOException\n    {\n        this.attributes = keyInfo.getAttributes();\n        this.params = (CMCEPrivateKeyParameters)PrivateKeyFactory.createKey(keyInfo);\n    }\n\n    /**\n     * Compare this SPHINCS-256 private key with another object.\n     *\n     * @param o the other object\n     * @return the result of the comparison\n     */\n    public boolean equals(Object o)\n    {\n        if (o == this)\n        {\n            return true;\n        }\n\n        if (o instanceof BCCMCEPrivateKey)\n        {\n            BCCMCEPrivateKey otherKey = (BCCMCEPrivateKey)o;\n\n            return Arrays.areEqual(params.getEncoded(), otherKey.params.getEncoded());\n        }\n\n        return false;\n    }\n\n    public int hashCode()\n    {\n        return Arrays.hashCode(params.getEncoded());\n    }\n\n    /**\n     * @return name of the algorithm - \"CMCE\"\n     */\n    public final String getAlgorithm()\n    {\n        return Strings.toUpperCase(params.getParameters().getName());\n    }\n\n    public byte[] getEncoded()\n    {\n\n        try\n        {\n            PrivateKeyInfo pki = PrivateKeyInfoFactory.createPrivateKeyInfo(params, attributes);\n\n            return pki.getEncoded();\n        }\n        catch (IOException e)\n        {\n            return null;\n        }\n    }\n\n    public CMCEParameterSpec getParameterSpec()\n    {\n        return CMCEParameterSpec.fromName(params.getParameters().getName());\n    }\n\n    public String getFormat()\n    {\n        return \"PKCS#8\";\n    }\n\n    CMCEPrivateKeyParameters getKeyParams()\n    {\n        return params;\n    }\n\n    private void readObject(\n        ObjectInputStream in)\n        throws IOException, ClassNotFoundException\n    {\n        in.defaultReadObject();\n\n        byte[] enc = (byte[])in.readObject();\n\n        init(PrivateKeyInfo.getInstance(enc));\n    }\n\n    private void writeObject(\n        ObjectOutputStream out)\n        throws IOException\n    {\n        out.defaultWriteObject();\n\n        out.writeObject(this.getEncoded());\n    }\n}\n"}], "isError": false, "timestamp": 1778123133625}, {"role": "toolResult", "toolCallId": "call_cPoWhrB9xqDrv8BGdZbw5F8c|fc_0d3f3592d585515c0169fc017d6d98819494fbea8135562a24", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk15to18;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\n\nimport org.bouncycastle.pqc.crypto.bike.BIKEParameters;\nimport org.bouncycastle.pqc.crypto.bike.BIKEPrivateKeyParameters;\nimport org.bouncycastle.pqc.jcajce.provider.bike.BCBIKEPrivateKey;\nimport org.bouncycastle.pqc.jcajce.spec.BIKEParameterSpec;\nimport org.junit.jupiter.api.Test;\n\npublic class BCBIKEPrivateKeyTest {\n    @Test\n    public void serializesAndDeserializesBike128PrivateKey() throws Exception {\n        BCBIKEPrivateKey privateKey = createBike128PrivateKey();\n\n        byte[] serializedKey = serialize(privateKey);\n        BCBIKEPrivateKey restoredKey = deserialize(serializedKey);\n\n        assertThat(restoredKey).isEqualTo(privateKey);\n        assertThat(restoredKey.hashCode()).isEqualTo(privateKey.hashCode());\n        assertThat(restoredKey.getAlgorithm()).isEqualTo(\"BIKE128\");\n        assertThat(restoredKey.getFormat()).isEqualTo(\"PKCS#8\");\n        assertThat(restoredKey.getEncoded()).isEqualTo(privateKey.getEncoded());\n        assertThat(restoredKey.getParameterSpec().getName()).isEqualTo(BIKEParameterSpec.bike128.getName());\n    }\n\n    private static BCBIKEPrivateKey createBike128PrivateKey() {\n        BIKEParameters parameters = BIKEParameters.bike128;\n        BIKEPrivateKeyParameters keyParameters = new BIKEPrivateKeyParameters(\n                parameters,\n                createBytes(parameters.getRByte(), 1),\n                createBytes(parameters.getRByte(), 17),\n                createBytes(parameters.getLByte(), 33));\n        return new BCBIKEPrivateKey(keyParameters);\n    }\n\n    private static byte[] createBytes(int size, int offset) {\n        byte[] bytes = new byte[size];\n        for (int index = 0; index < bytes.length; index++) {\n            bytes[index] = (byte) (index + offset);\n        }\n        return bytes;\n    }\n\n    private static byte[] serialize(BCBIKEPrivateKey privateKey) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {\n            out.writeObject(privateKey);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static BCBIKEPrivateKey deserialize(byte[] serializedKey) throws Exception {\n        try (ObjectInputStream in = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {\n            return (BCBIKEPrivateKey) in.readObject();\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778123133625}, {"role": "toolResult", "toolCallId": "call_9KHdvGliXRUuSXmP8PtZBq99|fc_0d3f3592d585515c0169fc017d6da88194a0a98cb39bf6b6a9", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk15to18;\n\nimport org.junit.jupiter.api.Test;\n\npublic class Bcprov_jdk15to18Test {\n    @Test\n    void test() throws Exception {\n        System.out.println(\"This is just a placeholder, implement your test\");\n    }\n}\n"}], "isError": false, "timestamp": 1778123133625}]}
