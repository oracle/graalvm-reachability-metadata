  package org_bouncycastle.bcprov_jdk15to18;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.security.Provider;
  
  import org.bouncycastle.pqc.jcajce.provider.BouncyCastlePQCProvider;
  import org.junit.jupiter.api.Test;
  
  public class BouncyCastlePQCProviderTest {
      @Test
      public void loadsPostQuantumAlgorithmMappingsDuringConstruction() {
          BouncyCastlePQCProvider provider = new BouncyCastlePQCProvider();
  
          assertThat(provider.getName()).isEqualTo(BouncyCastlePQCProvider.PROVIDER_NAME);
          assertThat(provider.getVersion()).isGreaterThan(0.0);
          assertThat(provider.hasAlgorithm("KeyFactory", "KYBER")).isTrue();
          assertThat(provider.hasAlgorithm("KeyPairGenerator", "DILITHIUM")).isTrue();
          assertThat(provider.hasAlgorithm("Signature", "SPHINCSPLUS")).isTrue();
          assertThat(provider.getService("KeyFactory", "KYBER")).isNotNull();
          assertThat(provider.getService("Cipher", "KYBER")).isNotNull();
      }
  
      @Test
      public void exposesLoadedServicesThroughProviderApi() {
          Provider provider = new BouncyCastlePQCProvider();
  
          assertThat(provider.getServices())
                  .extracting(Provider.Service::getAlgorithm)
                  .contains("KYBER", "DILITHIUM", "FALCON", "SPHINCSPLUS");
      }
  }
