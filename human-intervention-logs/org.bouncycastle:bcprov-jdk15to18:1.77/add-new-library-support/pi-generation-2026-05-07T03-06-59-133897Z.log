      public int getCondBytes()
      {
          return COND_BYTES;
      }
  
      public int getPrivateKeySize()
      {
          return COND_BYTES + IRR_BYTES + SYS_N / 8 + 40;
      }
  
      public int getPublicKeySize()
      {
          if (usePadding)
          {
