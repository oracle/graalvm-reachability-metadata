ored.getIndex());\n        assertArrayEquals(secretKeySeed, restored.getSecretKeySeed());\n        assertArrayEquals(secretKeyPrf, restored.getSecretKeyPRF());\n        assertArrayEquals(publicSeed, restored.getPublicSeed());\n        assertArrayEquals(root, restored.getRoot());\n    }\n\n    private static byte[] sequence(int size, int start) {\n        byte[] bytes = new byte[size];\n        for (int i = 0; i < bytes.length; i++) {\n            bytes[i] = (byte)(start + i);\n        }\n        return bytes;\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 959, "output": 601, "cacheRead": 24576, "cacheWrite": 0, "totalTokens": 26136, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780914724148, "responseId": "resp_0c01685d88b6eaee016a269a33b9f48197b5b24ef567e7d1f0"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_iQyryCwobCqgkEAwQXxTrvKK|fc_0c01685d88b6eaee016a269a3529c0819798c7c52c6d5e6bdd", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2099 bytes to tests/src/org.bouncycastle/bcprov-jdk15to18/1.77/src/test/java/org_bouncycastle/bcprov_jdk15to18/XMSSUtilInnerCheckingStreamTest.java"}], "isError": false, "timestamp": 1780914750279}]}
