[tool-call] delta {"path":"tests/src/org.bouncycastle/bcprov-jdk15to18/1.77/src/test/java/org_bouncycastle/bcprov_jdk15to18/XMSSUtilInnerCheckingStreamTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk15to18;\n\nimport static org.junit.jupiter.api.Assertions.assertArrayEquals;\nimport static org.junit.jupiter.api.Assertions.assertEquals;\n\nimport org.bouncycastle.asn1.nist.NISTObjectIdentifiers;\nimport org.bouncycastle.pqc.crypto.xmss.XMSSParameters;\nimport org.bouncycastle.pqc.crypto.xmss.XMSSPrivateKeyParameters;\nimport org.junit.jupiter.api.Test;\n\npublic class XMSSUtilInnerCheckingStreamTest {\n    @Test\n    void xmssPrivateKeyImportDeserializesSerializedBdsState() throws Exception {\n        XMSSParameters parameters = new XMSSParameters(2, NISTObjectIdentifiers.id_sha256);\n        int digestSize = parameters.getTreeDigestSize();\n        byte[] secretKeySeed = sequence(digestSize, 0x11);\n        byte[] secretKeyPrf = sequence(digestSize, 0x31);\n        byte[] publicSeed = sequence(digestSize, 0x51);\n        byte[] root = sequence(digestSize, 0x71);\n\n        XMSSPrivateKeyParameters original = new XMSSPrivateKeyParameters.Builder(parameters)\n            .withSecretKeySeed(secretKeySeed)\n            .withSecretKeyPRF(secretKeyPrf)\n            .withPublicSeed(publicSeed)\n            .withRoot(root)\n            .build();\n\n        XMSSPrivateKeyParameters restored = new XMSSPrivateKeyParameters.Builder(parameters)\n            .withPrivateKey(original.getEncoded())\n            .build();\n\n        assertEquals(original.getIndex(), restored.getIndex());\n        assertArrayEquals(secretKeySeed, restored.getSecretKeySeed());\n        assertArrayEquals(secretKeyPrf, restored.getSecretKeyPRF());\n        assertArrayEquals(publicSeed, restored.getPublicSeed());\n        assertArrayEquals(root, restored.getRoot());\n    }\n\n    private static byte[] sequence(int size, int start) {\n        byte[] bytes = new byte[size];\n        for (int i = 0; i < bytes.length; i++) {\n            bytes[i] = (byte)(start + i);\n        }\n        return bytes;\n    }\n}\n"}
