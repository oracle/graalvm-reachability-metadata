[tool-call] delta {"path":"tests/src/org.bouncycastle/bcprov-jdk15to18/1.77/src/test/java/org_bouncycastle/bcprov_jdk15to18/BCNHPrivateKeyTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk15to18;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\n\nimport org.bouncycastle.pqc.crypto.newhope.NHPrivateKeyParameters;\nimport org.bouncycastle.pqc.jcajce.provider.newhope.BCNHPrivateKey;\nimport org.junit.jupiter.api.Test;\n\npublic class BCNHPrivateKeyTest {\n    private static final int NEWHOPE_POLY_SIZE = 1024;\n\n    @Test\n    public void serializesAndDeserializesNewHopePrivateKey() throws Exception {\n        BCNHPrivateKey privateKey = createNewHopePrivateKey();\n\n        byte[] serializedKey = serialize(privateKey);\n        BCNHPrivateKey restoredKey = deserialize(serializedKey);\n\n        assertThat(restoredKey).isEqualTo(privateKey);\n        assertThat(restoredKey.hashCode()).isEqualTo(privateKey.hashCode());\n        assertThat(restoredKey.getAlgorithm()).isEqualTo(\"NH\");\n        assertThat(restoredKey.getFormat()).isEqualTo(\"PKCS#8\");\n        assertThat(restoredKey.getEncoded()).isEqualTo(privateKey.getEncoded());\n        assertThat(restoredKey.getSecretData()).isEqualTo(privateKey.getSecretData());\n    }\n\n    private static BCNHPrivateKey createNewHopePrivateKey() {\n        return new BCNHPrivateKey(new NHPrivateKeyParameters(createSecretData()));\n    }\n\n    private static short[] createSecretData() {\n        short[] secretData = new short[NEWHOPE_POLY_SIZE];\n        for (int index = 0; index < secretData.length; index++) {\n            secretData[index] = (short) (index + 1);\n        }\n        return secretData;\n    }\n\n    private static byte[] serialize(BCNHPrivateKey privateKey) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {\n            out.writeObject(privateKey);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static BCNHPrivateKey deserialize(byte[] serializedKey) throws Exception {\n        try (ObjectInputStream in = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {\n            return (BCNHPrivateKey) in.readObject();\n        }\n    }\n}\n"}
