  package org_bouncycastle.bcprov_jdk15to18;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  
  import org.bouncycastle.pqc.crypto.crystals.kyber.KyberParameters;
  import org.bouncycastle.pqc.crypto.crystals.kyber.KyberPrivateKeyParameters;
  import org.bouncycastle.pqc.jcajce.provider.kyber.BCKyberPrivateKey;
  import org.bouncycastle.pqc.jcajce.spec.KyberParameterSpec;
  import org.junit.jupiter.api.Test;
  
  public class BCKyberPrivateKeyTest {
      private static final int KYBER512_S_SIZE = 768;
      private static final int KYBER512_T_SIZE = 768;
      private static final int SEED_SIZE = 32;
  
      @Test
      public void serializesAndDeserializesKyber512PrivateKey() throws Exception {
          BCKyberPrivateKey privateKey = createKyber512PrivateKey();
  
          byte[] serializedKey = serialize(privateKey);
          BCKyberPrivateKey restoredKey = deserialize(serializedKey);
  
          assertThat(restoredKey).isEqualTo(privateKey);
          assertThat(restoredKey.hashCode()).isEqualTo(privateKey.hashCode());
          assertThat(restoredKey.getAlgorithm()).isEqualTo("KYBER512");
          assertThat(restoredKey.getFormat()).isEqualTo("PKCS#8");
          assertThat(restoredKey.getEncoded()).isEqualTo(privateKey.getEncoded());
          assertThat(restoredKey.getPublicKey().getEncoded()).isEqualTo(privateKey.getPublicKey().getEncoded());
          assertThat(restoredKey.getParameterSpec().getName()).isEqualTo(KyberParameterSpec.kyber512.getName());
      }
  
      private static BCKyberPrivateKey createKyber512PrivateKey() {
          KyberPrivateKeyParameters keyParameters = new KyberPrivateKeyParameters(
                  KyberParameters.kyber512,
                  createBytes(KYBER512_S_SIZE, 1),
                  createBytes(SEED_SIZE, 41),
                  createBytes(SEED_SIZE, 73),
                  createBytes(KYBER512_T_SIZE, 139),
                  createBytes(SEED_SIZE, 23));
          return new BCKyberPrivateKey(keyParameters);
      }
  
      private static byte[] createBytes(int size, int offset) {
          byte[] bytes = new byte[size];
          for (int index = 0; index < bytes.length; index++) {
              bytes[index] = (byte) (index + offset);
          }
          return bytes;
      }
  
      private static byte[] serialize(BCKyberPrivateKey privateKey) throws Exception {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {
              out.writeObject(privateKey);
          }
          return bytes.toByteArray();
      }
  
      private static BCKyberPrivateKey deserialize(byte[] serializedKey) throws Exception {
          try (ObjectInputStream in = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {
              return (BCKyberPrivateKey) in.readObject();
          }
      }
  }
