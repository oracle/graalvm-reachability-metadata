[tool-call] delta {"path":"tests/src/org.bouncycastle/bcprov-jdk15to18/1.77/src/test/java/org_bouncycastle/bcprov_jdk15to18/BCGOST3410PublicKeyTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk15to18;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.security.KeyPair;\nimport java.security.KeyPairGenerator;\nimport java.security.SecureRandom;\n\nimport org.bouncycastle.asn1.cryptopro.CryptoProObjectIdentifiers;\nimport org.bouncycastle.jcajce.provider.asymmetric.gost.BCGOST3410PublicKey;\nimport org.bouncycastle.jce.interfaces.GOST3410Params;\nimport org.bouncycastle.jce.provider.BouncyCastleProvider;\nimport org.bouncycastle.jce.spec.GOST3410ParameterSpec;\nimport org.junit.jupiter.api.Test;\n\npublic class BCGOST3410PublicKeyTest {\n    private static final String ALGORITHM = \"GOST3410\";\n    private static final String PARAMETER_SET_OID = CryptoProObjectIdentifiers.gostR3410_94_CryptoPro_A.getId();\n\n    @Test\n    public void serializesAndDeserializesGost3410PublicKey() throws Exception {\n        BCGOST3410PublicKey publicKey = createPublicKey();\n\n        byte[] serializedKey = serialize(publicKey);\n        BCGOST3410PublicKey restoredKey = deserialize(serializedKey);\n\n        assertThat(restoredKey).isEqualTo(publicKey);\n        assertThat(restoredKey.hashCode()).isEqualTo(publicKey.hashCode());\n        assertThat(restoredKey.getAlgorithm()).isEqualTo(ALGORITHM);\n        assertThat(restoredKey.getFormat()).isEqualTo(\"X.509\");\n        assertThat(restoredKey.getY()).isEqualTo(publicKey.getY());\n        assertThat(restoredKey.getEncoded()).isEqualTo(publicKey.getEncoded());\n        assertThat(restoredKey.getParameters().getPublicKeyParamSetOID()).isEqualTo(PARAMETER_SET_OID);\n        assertThat(restoredKey.getParameters().getDigestParamSetOID())\n                .isEqualTo(publicKey.getParameters().getDigestParamSetOID());\n        assertThat(restoredKey.getParameters().getEncryptionParamSetOID())\n                .isEqualTo(publicKey.getParameters().getEncryptionParamSetOID());\n        assertGostParametersMatch(restoredKey.getParameters(), publicKey.getParameters());\n    }\n\n    private static BCGOST3410PublicKey createPublicKey() throws Exception {\n        KeyPairGenerator keyPairGenerator = KeyPairGenerator.getInstance(ALGORITHM, new BouncyCastleProvider());\n        keyPairGenerator.initialize(\n                new GOST3410ParameterSpec(PARAMETER_SET_OID),\n                new SecureRandom(new byte[] {1, 2, 3, 4}));\n        KeyPair keyPair = keyPairGenerator.generateKeyPair();\n        assertThat(keyPair.getPublic()).isInstanceOf(BCGOST3410PublicKey.class);\n        return (BCGOST3410PublicKey)keyPair.getPublic();\n    }\n\n    private static byte[] serialize(BCGOST3410PublicKey publicKey) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {\n            out.writeObject(publicKey);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static BCGOST3410PublicKey deserialize(byte[] serializedKey) throws Exception {\n        try (ObjectInputStream in = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {\n            return (BCGOST3410PublicKey)in.readObject();\n        }\n    }\n\n    private static void assertGostParametersMatch(GOST3410Params actual, GOST3410Params expected) {\n        assertThat(actual.getPublicKeyParameters().getP()).isEqualTo(expected.getPublicKeyParameters().getP());\n        assertThat(actual.getPublicKeyParameters().getQ()).isEqualTo(expected.getPublicKeyParameters().getQ());\n        assertThat(actual.getPublicKeyParameters().getA()).isEqualTo(expected.getPublicKeyParameters().getA());\n    }\n}\n"}
