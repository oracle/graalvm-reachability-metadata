              }
              else
              {
                  resCoeff[n] = field.getRandomElement(sr);
              }
          }
          return resCoeff;
      }
  
      /**
       * Construct a monomial of the given degree over the finite field GF(2^m).
       *
       * @param field  the finite field GF(2^m)
       * @param degree the degree of the monomial
