[tool-call] delta {"path":"tests/src/org.bouncycastle/bcprov-jdk15to18/1.77/src/test/java/org_bouncycastle/bcprov_jdk15to18/BCMcElieceCCA2PrivateKeyTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk15to18;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.security.SecureRandom;\n\nimport org.bouncycastle.pqc.jcajce.provider.mceliece.BCMcElieceCCA2PrivateKey;\nimport org.bouncycastle.pqc.legacy.crypto.mceliece.McElieceCCA2PrivateKeyParameters;\nimport org.bouncycastle.pqc.legacy.math.linearalgebra.GF2mField;\nimport org.bouncycastle.pqc.legacy.math.linearalgebra.Permutation;\nimport org.bouncycastle.pqc.legacy.math.linearalgebra.PolynomialGF2mSmallM;\nimport org.bouncycastle.pqc.legacy.math.linearalgebra.PolynomialRingGF2;\nimport org.junit.jupiter.api.Test;\n\npublic class BCMcElieceCCA2PrivateKeyTest {\n    private static final int FIELD_DEGREE = 4;\n    private static final int CODE_LENGTH = 1 << FIELD_DEGREE;\n    private static final int ERROR_CORRECTION_CAPABILITY = 2;\n    private static final int CODE_DIMENSION = CODE_LENGTH - FIELD_DEGREE * ERROR_CORRECTION_CAPABILITY;\n\n    @Test\n    public void serializesAndDeserializesCca2PrivateKey() throws Exception {\n        BCMcElieceCCA2PrivateKey privateKey = createPrivateKey();\n\n        byte[] serializedKey = serialize(privateKey);\n        BCMcElieceCCA2PrivateKey restoredKey = deserialize(serializedKey);\n\n        assertThat(restoredKey).isEqualTo(privateKey);\n        assertThat(restoredKey.hashCode()).isEqualTo(privateKey.hashCode());\n        assertThat(restoredKey.getAlgorithm()).isEqualTo(\"McEliece-CCA2\");\n        assertThat(restoredKey.getFormat()).isEqualTo(\"PKCS#8\");\n        assertThat(restoredKey.getEncoded()).isEqualTo(privateKey.getEncoded());\n        assertThat(restoredKey.getN()).isEqualTo(privateKey.getN());\n        assertThat(restoredKey.getK()).isEqualTo(privateKey.getK());\n        assertThat(restoredKey.getT()).isEqualTo(privateKey.getT());\n        assertThat(restoredKey.getField()).isEqualTo(privateKey.getField());\n        assertThat(restoredKey.getGoppaPoly()).isEqualTo(privateKey.getGoppaPoly());\n        assertThat(restoredKey.getP()).isEqualTo(privateKey.getP());\n        assertThat(restoredKey.getH()).isEqualTo(privateKey.getH());\n    }\n\n    private static BCMcElieceCCA2PrivateKey createPrivateKey() {\n        GF2mField field = new GF2mField(FIELD_DEGREE, PolynomialRingGF2.getIrreduciblePolynomial(FIELD_DEGREE));\n        PolynomialGF2mSmallM goppaPoly = new PolynomialGF2mSmallM(\n                field,\n                ERROR_CORRECTION_CAPABILITY,\n                PolynomialGF2mSmallM.RANDOM_IRREDUCIBLE_POLYNOMIAL,\n                new SecureRandom(new byte[] {1, 2, 3, 4}));\n        Permutation permutation = new Permutation(CODE_LENGTH);\n        McElieceCCA2PrivateKeyParameters keyParameters = new McElieceCCA2PrivateKeyParameters(\n                CODE_LENGTH,\n                CODE_DIMENSION,\n                field,\n                goppaPoly,\n                permutation,\n                \"SHA-256\");\n        return new BCMcElieceCCA2PrivateKey(keyParameters);\n    }\n\n    private static byte[] serialize(BCMcElieceCCA2PrivateKey privateKey) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {\n            out.writeObject(privateKey);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static BCMcElieceCCA2PrivateKey deserialize(byte[] serializedKey) throws Exception {\n        try (ObjectInputStream in = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {\n            return (BCMcElieceCCA2PrivateKey) in.readObject();\n        }\n    }\n}\n"}
