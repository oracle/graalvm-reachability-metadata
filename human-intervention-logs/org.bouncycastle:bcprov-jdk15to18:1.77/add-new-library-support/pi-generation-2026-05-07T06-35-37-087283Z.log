  package org_bouncycastle.bcprov_jdk15to18;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  
  import org.bouncycastle.pqc.crypto.crystals.kyber.KyberParameters;
  import org.bouncycastle.pqc.crypto.crystals.kyber.KyberPublicKeyParameters;
  import org.bouncycastle.pqc.jcajce.provider.kyber.BCKyberPublicKey;
  import org.bouncycastle.pqc.jcajce.spec.KyberParameterSpec;
  import org.junit.jupiter.api.Test;
  
  public class BCKyberPublicKeyTest {
      private static final int KYBER512_T_SIZE = 768;
      private static final int SEED_SIZE = 32;
  
      @Test
      public void serializesAndDeserializesKyber512PublicKey() throws Exception {
          BCKyberPublicKey publicKey = createKyber512PublicKey();
  
          byte[] serializedKey = serialize(publicKey);
          BCKyberPublicKey restoredKey = deserialize(serializedKey);
  
          assertThat(restoredKey).isEqualTo(publicKey);
          assertThat(restoredKey.hashCode()).isEqualTo(publicKey.hashCode());
          assertThat(restoredKey.getAlgorithm()).isEqualTo("KYBER512");
          assertThat(restoredKey.getFormat()).isEqualTo("X.509");
          assertThat(restoredKey.getEncoded()).isEqualTo(publicKey.getEncoded());
          assertThat(restoredKey.getParameterSpec().getName()).isEqualTo(KyberParameterSpec.kyber512.getName());
      }
  
      private static BCKyberPublicKey createKyber512PublicKey() {
          KyberPublicKeyParameters keyParameters = new KyberPublicKeyParameters(
                  KyberParameters.kyber512,
                  createBytes(KYBER512_T_SIZE, 17),
                  createBytes(SEED_SIZE, 91));
          return new BCKyberPublicKey(keyParameters);
      }
  
      private static byte[] createBytes(int size, int offset) {
          byte[] bytes = new byte[size];
          for (int index = 0; index < bytes.length; index++) {
              bytes[index] = (byte) (index + offset);
          }
          return bytes;
      }
  
      private static byte[] serialize(BCKyberPublicKey publicKey) throws Exception {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {
              out.writeObject(publicKey);
          }
          return bytes.toByteArray();
      }
  
      private static BCKyberPublicKey deserialize(byte[] serializedKey) throws Exception {
          try (ObjectInputStream in = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {
              return (BCKyberPublicKey) in.readObject();
          }
      }
  }
