c/test/java/org_bouncycastle/bcprov_jdk15to18/BCSABERPublicKeyTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk15to18;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\n\nimport org.bouncycastle.pqc.crypto.saber.SABERParameters;\nimport org.bouncycastle.pqc.crypto.saber.SABERPublicKeyParameters;\nimport org.bouncycastle.pqc.jcajce.provider.saber.BCSABERPublicKey;\nimport org.junit.jupiter.api.Test;\n\npublic class BCSABERPublicKeyTest {\n    private static final int LIGHTSABER_PUBLIC_KEY_SIZE = 672;\n\n    @Test\n    public void serializesAndDeserializesLightsaberPublicKey() throws Exception {\n        BCSABERPublicKey publicKey = createLightsaberPublicKey();\n\n        byte[] serializedKey = serialize(publicKey);\n        BCSABERPublicKey restoredKey = deserialize(serializedKey);\n\n        assertThat(restoredKey).isEqualTo(publicKey);\n        assertThat(restoredKey.hashCode()).isEqualTo(publicKey.hashCode());\n        assertThat(restoredKey.getAlgorithm()).isEqualTo(\"SABER\");\n        assertThat(restoredKey.getFormat()).isEqualTo(\"X.509\");\n        assertThat(restoredKey.getEncoded()).isEqualTo(publicKey.getEncoded());\n    }\n\n    private static BCSABERPublicKey createLightsaberPublicKey() {\n        SABERPublicKeyParameters keyParameters = new SABERPublicKeyParameters(\n                SABERParameters.lightsaberkem128r3,\n                createBytes(LIGHTSABER_PUBLIC_KEY_SIZE, 29));\n        return new BCSABERPublicKey(keyParameters);\n    }\n\n    private static byte[] createBytes(int size, int offset) {\n        byte[] bytes = new byte[size];\n        for (int index = 0; index < bytes.length; index++) {\n            bytes[index] = (byte) (index + offset);\n        }\n        return bytes;\n    }\n\n    private static byte[] serialize(BCSABERPublicKey publicKey) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {\n            out.writeObject(publicKey);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static BCSABERPublicKey deserialize(byte[] serializedKey) throws Exception {\n        try (ObjectInputStream in = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {\n            return (BCSABERPublicKey) in.readObject();\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 753, "output": 813, "cacheRead": 26112, "cacheWrite": 0, "totalTokens": 27678, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778135714592, "responseId": "resp_072d976c9b13b56d0169fc32a3536481938b121b6f9a3d01e8"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_kTxbTlpNV5ADyuzzjpdNwC8L|fc_072d976c9b13b56d0169fc32a62ef48193a792014c57b093fe", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2557 bytes to tests/src/org.bouncycastle/bcprov-jdk15to18/1.77/src/test/java/org_bouncycastle/bcprov_jdk15to18/BCSABERPublicKeyTest.java"}], "isError": false, "timestamp": 1778135722330}]}
