  package org_bouncycastle.bcprov_jdk15to18;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  
  import org.bouncycastle.pqc.crypto.saber.SABERParameters;
  import org.bouncycastle.pqc.crypto.saber.SABERPrivateKeyParameters;
  import org.bouncycastle.pqc.jcajce.provider.saber.BCSABERPrivateKey;
  import org.junit.jupiter.api.Test;
  
  public class BCSABERPrivateKeyTest {
      private static final int LIGHTSABER_PRIVATE_KEY_SIZE = 1568;
  
      @Test
      public void serializesAndDeserializesLightsaberPrivateKey() throws Exception {
          BCSABERPrivateKey privateKey = createLightsaberPrivateKey();
  
          byte[] serializedKey = serialize(privateKey);
          BCSABERPrivateKey restoredKey = deserialize(serializedKey);
  
          assertThat(restoredKey).isEqualTo(privateKey);
          assertThat(restoredKey.hashCode()).isEqualTo(privateKey.hashCode());
          assertThat(restoredKey.getAlgorithm()).isEqualTo("SABER");
          assertThat(restoredKey.getFormat()).isEqualTo("PKCS#8");
          assertThat(restoredKey.getEncoded()).isEqualTo(privateKey.getEncoded());
      }
  
      private static BCSABERPrivateKey createLightsaberPrivateKey() {
          SABERPrivateKeyParameters keyParameters = new SABERPrivateKeyParameters(
                  SABERParameters.lightsaberkem128r3,
                  createBytes(LIGHTSABER_PRIVATE_KEY_SIZE, 11));
          return new BCSABERPrivateKey(keyParameters);
      }
  
      private static byte[] createBytes(int size, int offset) {
          byte[] bytes = new byte[size];
          for (int index = 0; index < bytes.length; index++) {
              bytes[index] = (byte) (index + offset);
          }
          return bytes;
      }
  
      private static byte[] serialize(BCSABERPrivateKey privateKey) throws Exception {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {
              out.writeObject(privateKey);
          }
          return bytes.toByteArray();
      }
  
      private static BCSABERPrivateKey deserialize(byte[] serializedKey) throws Exception {
          try (ObjectInputStream in = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {
              return (BCSABERPrivateKey) in.readObject();
          }
