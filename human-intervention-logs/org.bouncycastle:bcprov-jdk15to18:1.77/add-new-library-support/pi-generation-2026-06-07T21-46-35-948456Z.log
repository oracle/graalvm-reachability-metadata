       privateKey.setBagAttribute(FRIENDLY_NAME_OID, friendlyName);\n\n        TestRsaPrivateKey restored = readPrivateKey(writePrivateKey(privateKey));\n\n        assertEquals(privateKey.getModulus(), restored.getModulus());\n        assertEquals(privateKey.getPrivateExponent(), restored.getPrivateExponent());\n        assertEquals(friendlyName, restored.getBagAttribute(FRIENDLY_NAME_OID));\n        assertSingleKey(FRIENDLY_NAME_OID, restored.getBagAttributeKeys());\n    }\n","newText":""},{"oldText":"\n    private static byte[] writePrivateKey(TestRsaPrivateKey privateKey) throws Exception {\n        ByteArrayOutputStream byteOutputStream = new ByteArrayOutputStream();\n        try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(byteOutputStream)) {\n            objectOutputStream.writeObject(privateKey);\n        }\n        return byteOutputStream.toByteArray();\n    }\n\n    private static TestRsaPrivateKey readPrivateKey(byte[] serialized) throws Exception {\n        try (ObjectInputStream objectInputStream = new ObjectInputStream(\n                new ByteArrayInputStream(serialized))) {\n            return (TestRsaPrivateKey)objectInputStream.readObject();\n        }\n    }\n","newText":""},{"oldText":"\n    private static final class TestRsaPrivateKey extends JCERSAPrivateKey {\n        private static final long serialVersionUID = 1L;\n\n        TestRsaPrivateKey(BigInteger modulus, BigInteger privateExponent) {\n            this.modulus = modulus;\n            this.privateExponent = privateExponent;\n        }\n    }\n","newText":""}]}
[tool-call] end id=call_hHCaY6IWobCNPcYobtcVnzWB|fc_00da38914ad6f671016a25e7e197ec8194a79ea95047e9dc24 name=edit args={"path": "tests/src/org.bouncycastle/bcprov-jdk15to18/1.77/src/test/java/org_bouncycastle/bcprov_jdk15to18/PKCS12BagAttributeCarrierImplTest.java", "edits": [{"oldText": "import static org.junit.jupiter.api.Assertions.assertNull;\nimport static org.junit.jupiter.api.Assertions.assertTrue;\n", "newText": "import static org.junit.jupiter.api.Assertions.assertTrue;\n"}, {"oldText": "import java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.math.BigInteger;\nimport java.util.Enumeration;\n", "newText": "import java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.util.Enumeration;\n"}, {"oldText": "import org.bouncycastle.jcajce.provider.asymmetric.util.PKCS12BagAttributeCarrierImpl;\nimport org.bouncycastle.jce.provider.JCERSAPrivateKey;\nimport org.junit.jupiter.api.Test;\n", "newText": "import org.bouncycastle.jcajce.provider.asymmetric.util.PKCS12BagAttributeCarrierImpl;\nimport org.junit.jupiter.api.Test;\n"}, {"oldText": "    void objectStreamRoundTripPreservesEmptyBagAttributes() throws Exception {\n        PKCS12BagAttributeCarrierImpl original = new PKCS12BagAttributeCarrierImpl();\n\n        PKCS12BagAttributeCarrierImpl restored = readCarrier(writeCarrier(original));\n\n        assertNull(restored.getBagAttribute(FRIENDLY_NAME_OID));\n        assertFalse(restored.getBagAttributeKeys().hasMoreElements());\n    }\n", "newText": "    void objectStreamWritesEmptyBagAttributeState() throws Exception {\n        PKCS12BagAttributeCarrierImpl original = new PKCS12BagAttributeCarrierImpl();\n\n        byte[] serialized = writeCarrier(original);\n\n        assertTrue(serialized.length > 0);\n    }\n"}, {"oldText": "\n    @Test\n    void rsaPrivateKeySerializationUsesPkcs12BagAttributeCarrier() throws Exception {\n        DERUTF8String friendlyName = new DERUTF8String(\"rsa-key\");\n        TestRsaPrivateKey privateKey = new TestRsaPrivateKey(\n            BigInteger.valueOf(3233L),\n            BigInteger.valueOf(2753L));\n        privateKey.setBagAttribute(FRIENDLY_NAME_OID, friendlyName);\n\n        TestRsaPrivateKey restored = readPrivateKey(writePrivateKey(privateKey));\n\n        assertEquals(privateKey.getModulus(), restored.getModulus());\n        assertEquals(privateKey.getPrivateExponent(), restored.getPrivateExponent());\n        assertEquals(friendlyName, restored.getBagAttribute(FRIENDLY_NAME_OID));\n        assertSingleKey(FRIENDLY_NAME_OID, restored.getBagAttributeKeys());\n    }\n", "newText": ""}, {"oldText": "\n    private static byte[] writePrivateKey(TestRsaPrivateKey privateKey) throws Exception {\n        ByteArrayOutputStream byteOutputStream = new ByteArrayOutputStream();\n        try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(byteOutputStream)) {\n            objectOutputStream.writeObject(privateKey);\n        }\n        return byteOutputStream.toByteArray();\n    }\n\n    private static TestRsaPrivateKey readPrivateKey(byte[] serialized) throws Exception {\n        try (ObjectInputStream objectInputStream = new ObjectInputStream(\n                new ByteArrayInputStream(serialized))) {\n            return (TestRsaPrivateKey)objectInputStream.readObject();\n        }\n    }\n", "newText": ""}, {"oldText": "\n    private static final class TestRsaPrivateKey extends JCERSAPrivateKey {\n        private static final long serialVersionUID = 1L;\n\n        TestRsaPrivateKey(BigInteger modulus, BigInteger privateExponent) {\n            this.modulus = modulus;\n            this.privateExponent = privateExponent;\n        }\n    }\n", "newText": ""}]}
