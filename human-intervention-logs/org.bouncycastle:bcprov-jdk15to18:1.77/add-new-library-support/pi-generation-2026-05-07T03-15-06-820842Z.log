      {
          this.name = name;
          this.k = k;
          this.usingAES = usingAES;
      }
  
      DilithiumEngine getEngine(SecureRandom random)
      {
          return new DilithiumEngine(k, random, usingAES);
      }
  
      public String getName()
      {
          return name;
      }
  }
