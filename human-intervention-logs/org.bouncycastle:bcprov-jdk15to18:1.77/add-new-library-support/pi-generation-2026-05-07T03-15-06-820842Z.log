  package org_bouncycastle.bcprov_jdk15to18;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  
  import org.bouncycastle.pqc.crypto.cmce.CMCEParameters;
  import org.bouncycastle.pqc.crypto.cmce.CMCEPrivateKeyParameters;
  import org.bouncycastle.pqc.jcajce.provider.cmce.BCCMCEPrivateKey;
  import org.bouncycastle.pqc.jcajce.spec.CMCEParameterSpec;
  import org.junit.jupiter.api.Test;
  
  public class BCCMCEPrivateKeyTest {
      private static final int DELTA_SIZE = 32;
      private static final int C_SIZE = 8;
      private static final int S_SIZE = 32;
  
      @Test
      public void serializesAndDeserializesMceliece348864PrivateKey() throws Exception {
          BCCMCEPrivateKey privateKey = createMceliece348864PrivateKey();
  
          byte[] serializedKey = serialize(privateKey);
          BCCMCEPrivateKey restoredKey = deserialize(serializedKey);
  
          assertThat(restoredKey).isEqualTo(privateKey);
          assertThat(restoredKey.hashCode()).isEqualTo(privateKey.hashCode());
          assertThat(restoredKey.getAlgorithm()).isEqualTo("MCELIECE348864");
          assertThat(restoredKey.getFormat()).isEqualTo("PKCS#8");
          assertThat(restoredKey.getEncoded()).isEqualTo(privateKey.getEncoded());
          assertThat(restoredKey.getParameterSpec().getName()).isEqualTo(CMCEParameterSpec.mceliece348864.getName());
      }
  
      private static BCCMCEPrivateKey createMceliece348864PrivateKey() {
          CMCEParameters parameters = CMCEParameters.mceliece348864r3;
          CMCEPrivateKeyParameters keyParameters = new CMCEPrivateKeyParameters(
                  parameters,
                  createBytes(DELTA_SIZE, 1),
                  createBytes(C_SIZE, 41),
                  createBytes(parameters.getT() * 2, 53),
                  createBytes(alphaSize(parameters), 97),
                  createBytes(S_SIZE, 113));
          return new BCCMCEPrivateKey(keyParameters);
      }
  
      private static int alphaSize(CMCEParameters parameters) {
          return (1 << (parameters.getM() - 4)) * (2 * parameters.getM() - 1);
      }
  
      private static byte[] createBytes(int size, int offset) {
          byte[] bytes = new byte[size];
