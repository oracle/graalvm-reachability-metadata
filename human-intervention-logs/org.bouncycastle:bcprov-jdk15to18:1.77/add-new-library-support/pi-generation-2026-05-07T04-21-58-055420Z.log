ncycastle.bcprov_jdk15to18;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\n\nimport org.bouncycastle.pqc.crypto.falcon.FalconParameters;\nimport org.bouncycastle.pqc.crypto.falcon.FalconPrivateKeyParameters;\nimport org.bouncycastle.pqc.jcajce.provider.falcon.BCFalconPrivateKey;\nimport org.bouncycastle.pqc.jcajce.spec.FalconParameterSpec;\nimport org.junit.jupiter.api.Test;\n\npublic class BCFalconPrivateKeyTest {\n    private static final int FALCON_512_SECRET_POLYNOMIAL_SIZE = 512;\n    private static final int FALCON_512_PUBLIC_KEY_SIZE = 897;\n\n    @Test\n    public void serializesAndDeserializesFalcon512PrivateKey() throws Exception {\n        BCFalconPrivateKey privateKey = createFalcon512PrivateKey();\n\n        byte[] serializedKey = serialize(privateKey);\n        BCFalconPrivateKey restoredKey = deserialize(serializedKey);\n\n        assertThat(restoredKey).isEqualTo(privateKey);\n        assertThat(restoredKey.hashCode()).isEqualTo(privateKey.hashCode());\n        assertThat(restoredKey.getAlgorithm()).isEqualTo(\"FALCON-512\");\n        assertThat(restoredKey.getFormat()).isEqualTo(\"PKCS#8\");\n        assertThat(restoredKey.getEncoded()).isEqualTo(privateKey.getEncoded());\n        assertThat(restoredKey.getPublicKey().getEncoded()).isEqualTo(privateKey.getPublicKey().getEncoded());\n        assertThat(restoredKey.getParameterSpec().getName()).isEqualTo(FalconParameterSpec.falcon_512.getName());\n    }\n\n    private static BCFalconPrivateKey createFalcon512PrivateKey() {\n        FalconPrivateKeyParameters keyParameters = new FalconPrivateKeyParameters(\n                FalconParameters.falcon_512,\n                createBytes(FALCON_512_SECRET_POLYNOMIAL_SIZE, 1),\n                createBytes(FALCON_512_SECRET_POLYNOMIAL_SIZE, 19),\n                createBytes(FALCON_512_SECRET_POLYNOMIAL_SIZE, 37),\n                createBytes(FALCON_512_PUBLIC_KEY_SIZE, 53));\n        return new BCFalconPrivateKey(keyParameters);\n    }\n\n    private static byte[] createBytes(int size, int offset) {\n        byte[] bytes = new byte[size];\n        for (int index = 0; index < bytes.length; index++) {\n            bytes[index] = (byte) (index + offset);\n        }\n        return bytes;\n    }\n\n    private static byte[] serialize(BCFalconPrivateKey privateKey) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {\n            out.writeObject(privateKey);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static BCFalconPrivateKey deserialize(byte[] serializedKey) throws Exception {\n        try (ObjectInputStream in = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {\n            return (BCFalconPrivateKey) in.readObject();\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778127680757}, {"role": "toolResult", "toolCallId": "call_AHk3WXIWlkdaWb5UQnuVAAVd|fc_0a7fc66197a7ef3d0169fc134086e8819cb916622092fdcb3b", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk15to18;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\n\nimport org.bouncycastle.pqc.crypto.crystals.kyber.KyberParameters;\nimport org.bouncycastle.pqc.crypto.crystals.kyber.KyberPrivateKeyParameters;\nimport org.bouncycastle.pqc.jcajce.provider.kyber.BCKyberPrivateKey;\nimport org.bouncycastle.pqc.jcajce.spec.KyberParameterSpec;\nimport org.junit.jupiter.api.Test;\n\npublic class BCKyberPrivateKeyTest {\n    private static final int KYBER512_S_SIZE = 768;\n    private static final int KYBER512_T_SIZE = 768;\n    private static final int SEED_SIZE = 32;\n\n    @Test\n    public void serializesAndDeserializesKyber512PrivateKey() throws Exception {\n        BCKyberPrivateKey privateKey = createKyber512PrivateKey();\n\n        byte[] serializedKey = serialize(privateKey);\n        BCKyberPrivateKey restoredKey = deserialize(serializedKey);\n\n        assertThat(restoredKey).isEqualTo(privateKey);\n        assertThat(restoredKey.hashCode()).isEqualTo(privateKey.hashCode());\n        assertThat(restoredKey.getAlgorithm()).isEqualTo(\"KYBER512\");\n        assertThat(restoredKey.getFormat()).isEqualTo(\"PKCS#8\");\n        assertThat(restoredKey.getEncoded()).isEqualTo(privateKey.getEncoded());\n        assertThat(restoredKey.getPublicKey().getEncoded()).isEqualTo(privateKey.getPublicKey().getEncoded());\n        assertThat(restoredKey.getParameterSpec().getName()).isEqualTo(KyberParameterSpec.kyber512.getName());\n    }\n\n    private static BCKyberPrivateKey createKyber512PrivateKey() {\n        KyberPrivateKeyParameters keyParameters = new KyberPrivateKeyParameters(\n                KyberParameters.kyber512,\n                createBytes(KYBER512_S_SIZE, 1),\n                createBytes(SEED_SIZE, 41),\n                createBytes(SEED_SIZE, 73),\n                createBytes(KYBER512_T_SIZE, 139),\n                createBytes(SEED_SIZE, 23));\n        return new BCKyberPrivateKey(keyParameters);\n    }\n\n    private static byte[] createBytes(int size, int offset) {\n        byte[] bytes = new byte[size];\n        for (int index = 0; index < bytes.length; index++) {\n            bytes[index] = (byte) (index + offset);\n        }\n        return bytes;\n    }\n\n    private static byte[] serialize(BCKyberPrivateKey privateKey) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {\n            out.writeObject(privateKey);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static BCKyberPrivateKey deserialize(byte[] serializedKey) throws Exception {\n        try (ObjectInputStream in = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {\n            return (BCKyberPrivateKey) in.readObject();\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778127680758}, {"role": "toolResult", "toolCallId": "call_CvlGmNTZ9VnTgGKsr9jL933N|fc_0a7fc66197a7ef3d0169fc134086f0819c91c5225e50fdda1d", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\nplugins {\n    id \"org.graalvm.internal.tck\"\n}\n\nString libraryVersion = tck.testedLibraryVersion.get()\n\ndependencies {\n    testImplementation \"org.bouncycastle:bcprov-jdk15to18:$libraryVersion\"\n    testImplementation 'org.assertj:assertj-core:3.22.0'\n}\n\ngraalvmNative {\n    agent {\n        defaultMode = \"conditional\"\n        modes {\n            conditional {\n                userCodeFilterPath = \"user-code-filter.json\"\n            }\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778127680758}]}
