      {
          in.defaultReadObject();
  
          byte[] enc = (byte[])in.readObject();
  
          init(PrivateKeyInfo.getInstance(enc));
      }
  
      private void writeObject(
          ObjectOutputStream out)
          throws IOException
      {
          out.defaultWriteObject();
  
          out.writeObject(this.getEncoded());
      }
  }
