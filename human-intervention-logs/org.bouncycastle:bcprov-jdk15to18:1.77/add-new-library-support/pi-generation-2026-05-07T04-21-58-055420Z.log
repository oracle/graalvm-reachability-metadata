ry\n            {\n                return Arrays.areEqual(keyParams.getEncoded(), otherKey.keyParams.getEncoded());\n            }\n            catch (IOException e)\n            {\n                throw new IllegalStateException(\"unable to perform equals\");     // should never happen.\n            }\n        }\n\n        return false;\n    }\n\n    public int hashCode()\n    {\n        try\n        {\n            return Arrays.hashCode(keyParams.getEncoded());\n        }\n        catch (IOException e)\n        {\n            throw new IllegalStateException(\"unable to calculate hashCode\");     // should never happen.\n        }\n    }\n\n    CipherParameters getKeyParams()\n    {\n        return keyParams;\n    }\n\n    public int getLevels()\n    {\n        if (keyParams instanceof LMSPrivateKeyParameters)\n        {\n            return 1;\n        }\n        else\n        {\n            return ((HSSPrivateKeyParameters)keyParams).getL();\n        }\n    }\n\n    private void readObject(\n        ObjectInputStream in)\n        throws IOException, ClassNotFoundException\n    {\n        in.defaultReadObject();\n\n        byte[] enc = (byte[])in.readObject();\n\n        init(PrivateKeyInfo.getInstance(enc));\n    }\n\n    private void writeObject(\n        ObjectOutputStream out)\n        throws IOException\n    {\n        out.defaultWriteObject();\n\n        out.writeObject(this.getEncoded());\n    }\n}\n"}], "isError": false, "timestamp": 1778127676872}, {"role": "toolResult", "toolCallId": "call_vYdPEiuoWXUazmuc1vbfi6Jl|fc_0a7fc66197a7ef3d0169fc133ca3a8819ca0fad95ec96dd533", "toolName": "bash", "content": [{"type": "text", "text": "tests/src/org.bouncycastle/bcprov-jdk15to18/1.77/src/test/java/org_bouncycastle/bcprov_jdk15to18/BCECGOST3410_2012PublicKeyTest.java\ntests/src/org.bouncycastle/bcprov-jdk15to18/1.77/src/test/java/org_bouncycastle/bcprov_jdk15to18/BCECGOST3410PrivateKeyTest.java\ntests/src/org.bouncycastle/bcprov-jdk15to18/1.77/src/test/java/org_boun