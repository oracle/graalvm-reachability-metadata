[tool-call] delta {"path":"tests/src/org.bouncycastle/bcprov-jdk15to18/1.77/src/test/java/org_bouncycastle/bcprov_jdk15to18/BCDilithiumPrivateKeyTest.java","edits":[{"oldText":"import java.security.KeyPairGenerator;\nimport java.security.SecureRandom;\n\nimport org.bouncycastle.pqc.jcajce.provider.BouncyCastlePQCProvider;\nimport org.bouncycastle.pqc.jcajce.provider.dilithium.BCDilithiumPrivateKey;\nimport org.bouncycastle.pqc.jcajce.spec.DilithiumParameterSpec;\n","newText":"import org.bouncycastle.pqc.crypto.crystals.dilithium.DilithiumParameters;\nimport org.bouncycastle.pqc.crypto.crystals.dilithium.DilithiumPrivateKeyParameters;\nimport org.bouncycastle.pqc.jcajce.provider.dilithium.BCDilithiumPrivateKey;\n"},{"oldText":"    private static BCDilithiumPrivateKey createPrivateKey() throws Exception {\n        KeyPairGenerator generator = KeyPairGenerator.getInstance(\n                \"DILITHIUM2\", new BouncyCastlePQCProvider());\n        generator.initialize(DilithiumParameterSpec.dilithium2, new SecureRandom(new byte[] { 1, 2, 3, 4 }));\n        return assertInstanceOf(BCDilithiumPrivateKey.class, generator.generateKeyPair().getPrivate());\n    }\n","newText":"    private static BCDilithiumPrivateKey createPrivateKey() {\n        DilithiumParameters parameters = DilithiumParameters.dilithium2;\n        return assertInstanceOf(BCDilithiumPrivateKey.class,\n                new BCDilithiumPrivateKey(new DilithiumPrivateKeyParameters(\n                        parameters,\n                        sequence(32, 1),\n                        sequence(32, 33),\n                        sequence(64, 65),\n                        sequence(384, 129),\n                        sequence(384, 3),\n                        sequence(1664, 11),\n                        sequence(1280, 19))));\n    }\n\n    private static byte[] sequence(int length, int firstValue) {\n        byte[] values = new byte[length];\n        for (int i = 0; i < values.length; i++) {\n            values[i] = (byte)(firstValue + i);\n        }\n        return values;\n    }\n"}]}
