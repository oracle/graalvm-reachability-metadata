ed.getAlgorithm());\n        assertEquals(\"PKCS#8\", restored.getFormat());\n        assertEquals(privateKey.getParameterSpec().getName(), restored.getParameterSpec().getName());\n        assertArrayEquals(privateKey.getEncoded(), restored.getEncoded());\n        assertArrayEquals(privateKey.getPublicKey().getEncoded(), restored.getPublicKey().getEncoded());\n        assertEquals(privateKey, restored);\n        assertEquals(privateKey.hashCode(), restored.hashCode());\n    }\n\n    private static BCDilithiumPrivateKey createPrivateKey() throws Exception {\n        KeyPairGenerator generator = KeyPairGenerator.getInstance(\n                \"DILITHIUM2\", new BouncyCastlePQCProvider());\n        generator.initialize(DilithiumParameterSpec.dilithium2, new SecureRandom(new byte[] { 1, 2, 3, 4 }));\n        return assertInstanceOf(BCDilithiumPrivateKey.class, generator.generateKeyPair().getPrivate());\n    }\n\n    private static byte[] serialize(BCDilithiumPrivateKey privateKey) throws Exception {\n        ByteArrayOutputStream byteOutputStream = new ByteArrayOutputStream();\n        try (ObjectOutputStream objectOutputStream = new EncodedPrivateKeyReplacingObjectOutputStream(\n                byteOutputStream)) {\n            objectOutputStream.writeObject(privateKey);\n        }\n        return byteOutputStream.toByteArray();\n    }\n\n    private static BCDilithiumPrivateKey deserialize(byte[] serialized) throws Exception {\n        try (ObjectInputStream objectInputStream = new EncodedPrivateKeyResolvingObjectInputStream(\n                new ByteArrayInputStream(serialized))) {\n            return (BCDilithiumPrivateKey)objectInputStream.readObject();\n        }\n    }\n\n    private static final class EncodedPrivateKeyReplacingObjectOutputStream extends ObjectOutputStream {\n        private boolean replacedEncodedKey;\n\n        private EncodedPrivateKeyReplacingObjectOutputStream(ByteArrayOutputStream outputStream)\n                throws IOException {\n            super(outputStream);\n            enableReplaceObject(true);\n        }\n\n        @Override\n        protected Object replaceObject(Object object) throws IOException {\n            if (!replacedEncodedKey && object instanceof byte[]) {\n                replacedEncodedKey = true;\n                return new BCDilithiumPrivateKey(PrivateKeyInfo.getInstance((byte[])object));\n            }\n            return super.replaceObject(object);\n        }\n    }\n\n    private static final class EncodedPrivateKeyResolvingObjectInputStream extends ObjectInputStream {\n        private boolean resolvedNestedKey;\n\n        private EncodedPrivateKeyResolvingObjectInputStream(ByteArrayInputStream inputStream)\n                throws IOException {\n            super(inputStream);\n            enableResolveObject(true);\n        }\n\n        @Override\n        protected Object resolveObject(Object object) throws IOException {\n            if (!resolvedNestedKey && object instanceof BCDilithiumPrivateKey) {\n                resolvedNestedKey = true;\n                return ((BCDilithiumPrivateKey)object).getEncoded();\n            }\n            return super.resolveObject(object);\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 573, "output": 1424, "cacheRead": 33280, "cacheWrite": 0, "totalTokens": 35277, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780881580805, "responseId": "resp_04b5302d059abbec016a2618ad3ec081969aab55e118408775"}}
