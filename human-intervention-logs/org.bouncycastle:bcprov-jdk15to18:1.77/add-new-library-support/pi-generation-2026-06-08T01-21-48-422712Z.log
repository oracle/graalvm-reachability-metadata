      {
          this.params = params;
      }
  
      public BCBIKEPrivateKey(PrivateKeyInfo keyInfo)
              throws IOException
      {
          init(keyInfo);
      }
  
      private void init(PrivateKeyInfo keyInfo)
              throws IOException
      {
          this.attributes = keyInfo.getAttributes();
          this.params = (BIKEPrivateKeyParameters) PrivateKeyFactory.createKey(keyInfo);
      }
  
      /**
