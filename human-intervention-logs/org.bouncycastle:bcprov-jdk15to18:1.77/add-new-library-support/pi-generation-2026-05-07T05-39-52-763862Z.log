  package org_bouncycastle.bcprov_jdk15to18;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  
  import org.bouncycastle.pqc.crypto.ntru.NTRUParameters;
  import org.bouncycastle.pqc.crypto.ntru.NTRUPublicKeyParameters;
  import org.bouncycastle.pqc.jcajce.provider.ntru.BCNTRUPublicKey;
  import org.bouncycastle.pqc.jcajce.spec.NTRUParameterSpec;
  import org.junit.jupiter.api.Test;
  
  public class BCNTRUPublicKeyTest {
      @Test
      public void serializesAndDeserializesNtruHps2048509PublicKey() throws Exception {
          BCNTRUPublicKey publicKey = createNtruHps2048509PublicKey();
  
          byte[] serializedKey = serialize(publicKey);
          BCNTRUPublicKey restoredKey = deserialize(serializedKey);
  
          assertThat(restoredKey).isEqualTo(publicKey);
          assertThat(restoredKey.hashCode()).isEqualTo(publicKey.hashCode());
          assertThat(restoredKey.getAlgorithm()).isEqualTo("NTRU");
          assertThat(restoredKey.getFormat()).isEqualTo("X.509");
          assertThat(restoredKey.getEncoded()).isEqualTo(publicKey.getEncoded());
          assertThat(restoredKey.getParameterSpec().getName())
                  .isEqualTo(NTRUParameterSpec.ntruhps2048509.getName());
      }
  
      private static BCNTRUPublicKey createNtruHps2048509PublicKey() {
          NTRUPublicKeyParameters keyParameters = new NTRUPublicKeyParameters(
                  NTRUParameters.ntruhps2048509,
                  createBytes(699, 23));
          return new BCNTRUPublicKey(keyParameters);
      }
  
      private static byte[] createBytes(int size, int offset) {
          byte[] bytes = new byte[size];
          for (int index = 0; index < bytes.length; index++) {
              bytes[index] = (byte) (index + offset);
          }
          return bytes;
      }
  
      private static byte[] serialize(BCNTRUPublicKey publicKey) throws Exception {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {
              out.writeObject(publicKey);
          }
          return bytes.toByteArray();
      }
  
      private static BCNTRUPublicKey deserialize(byte[] serializedKey) throws Exception {
          try (ObjectInputStream in = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {
              return (BCNTRUPublicKey) in.readObject();
          }
      }
  }
