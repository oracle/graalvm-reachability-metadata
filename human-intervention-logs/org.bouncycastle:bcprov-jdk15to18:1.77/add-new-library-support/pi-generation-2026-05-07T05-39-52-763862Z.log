  package org_bouncycastle.bcprov_jdk15to18;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  
  import org.bouncycastle.pqc.crypto.ntruprime.NTRULPRimeParameters;
  import org.bouncycastle.pqc.crypto.ntruprime.NTRULPRimePrivateKeyParameters;
  import org.bouncycastle.pqc.jcajce.provider.ntruprime.BCNTRULPRimePrivateKey;
  import org.bouncycastle.pqc.jcajce.spec.NTRULPRimeParameterSpec;
  import org.junit.jupiter.api.Test;
  
  public class BCNTRULPRimePrivateKeyTest {
      private static final int NTRULPR_653_ENCA_SIZE = (653 + 3) / 4;
      private static final int NTRULPR_653_PUBLIC_KEY_SIZE = 897;
      private static final int NTRULPR_653_RHO_SIZE = 32;
      private static final int NTRULPR_653_HASH_SIZE = 32;
  
      @Test
      public void serializesAndDeserializesNtrulprime653PrivateKey() throws Exception {
          BCNTRULPRimePrivateKey privateKey = createNtrulprime653PrivateKey();
  
          byte[] serializedKey = serialize(privateKey);
          BCNTRULPRimePrivateKey restoredKey = deserialize(serializedKey);
  
          assertThat(restoredKey).isEqualTo(privateKey);
          assertThat(restoredKey.hashCode()).isEqualTo(privateKey.hashCode());
          assertThat(restoredKey.getAlgorithm()).isEqualTo("NTRULPRime");
          assertThat(restoredKey.getFormat()).isEqualTo("PKCS#8");
          assertThat(restoredKey.getEncoded()).isEqualTo(privateKey.getEncoded());
          assertThat(restoredKey.getParameterSpec().getName()).isEqualTo(NTRULPRimeParameterSpec.ntrulpr653.getName());
      }
  
      private static BCNTRULPRimePrivateKey createNtrulprime653PrivateKey() {
          NTRULPRimePrivateKeyParameters keyParameters = new NTRULPRimePrivateKeyParameters(
                  NTRULPRimeParameters.ntrulpr653,
                  createBytes(NTRULPR_653_ENCA_SIZE, 1),
                  createBytes(NTRULPR_653_PUBLIC_KEY_SIZE, 17),
                  createBytes(NTRULPR_653_RHO_SIZE, 31),
                  createBytes(NTRULPR_653_HASH_SIZE, 47));
          return new BCNTRULPRimePrivateKey(keyParameters);
      }
  
      private static byte[] createBytes(int size, int offset) {
          byte[] bytes = new byte[size];
          for (int index = 0; index < bytes.length; index++) {
              bytes[index] = (byte) (index + offset);
          }
          return bytes;
      }
  
      private static byte[] serialize(BCNTRULPRimePrivateKey privateKey) throws Exception {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {
              out.writeObject(privateKey);
          }
          return bytes.toByteArray();
      }
  
      private static BCNTRULPRimePrivateKey deserialize(byte[] serializedKey) throws Exception {
          try (ObjectInputStream in = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {
              return (BCNTRULPRimePrivateKey) in.readObject();
          }
      }
