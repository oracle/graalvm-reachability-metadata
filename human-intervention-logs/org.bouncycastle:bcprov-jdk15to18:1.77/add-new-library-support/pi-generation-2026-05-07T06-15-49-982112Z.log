received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk15to18;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\n\nimport org.bouncycastle.pqc.crypto.rainbow.RainbowParameters;\nimport org.bouncycastle.pqc.crypto.rainbow.RainbowPrivateKeyParameters;\nimport org.bouncycastle.pqc.jcajce.provider.rainbow.BCRainbowPrivateKey;\nimport org.bouncycastle.pqc.jcajce.spec.RainbowParameterSpec;\nimport org.junit.jupiter.api.Test;\n\npublic class BCRainbowPrivateKeyTest {\n    private static final int RAINBOW_III_CLASSIC_PRIVATE_KEY_SIZE = 626_048;\n\n    @Test\n    public void serializesAndDeserializesRainbowIIIClassicPrivateKey() throws Exception {\n        BCRainbowPrivateKey privateKey = createRainbowIIIClassicPrivateKey();\n\n        byte[] serializedKey = serialize(privateKey);\n        BCRainbowPrivateKey restoredKey = deserialize(serializedKey);\n\n        assertThat(restoredKey).isEqualTo(privateKey);\n        assertThat(restoredKey.hashCode()).isEqualTo(privateKey.hashCode());\n        assertThat(restoredKey.getAlgorithm()).isEqualTo(\"RAINBOW-III-CLASSIC\");\n        assertThat(restoredKey.getFormat()).isEqualTo(\"PKCS#8\");\n        assertThat(restoredKey.getEncoded()).isEqualTo(privateKey.getEncoded());\n        assertThat(restoredKey.getParameterSpec().getName())\n                .isEqualTo(RainbowParameterSpec.rainbowIIIclassic.getName());\n    }\n\n    private static BCRainbowPrivateKey createRainbowIIIClassicPrivateKey() {\n        RainbowPrivateKeyParameters keyParameters = new RainbowPrivateKeyParameters(\n                RainbowParameters.rainbowIIIclassic,\n                createBytes(RAINBOW_III_CLASSIC_PRIVATE_KEY_SIZE, 1));\n        return new BCRainbowPrivateKey(keyParameters);\n    }\n\n    private static byte[] createBytes(int size, int offset) {\n        byte[] bytes = new byte[size];\n        for (int index = 0; index < bytes.length; index++) {\n            bytes[index] = (byte) (index + offset);\n        }\n        return bytes;\n    }\n\n    private static byte[] serialize(BCRainbowPrivateKey privateKey) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {\n            out.writeObject(privateKey);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static BCRainbowPrivateKey deserialize(byte[] serializedKey) throws Exception {\n        try (ObjectInputStream in = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {\n            return (BCRainbowPrivateKey) in.readObject();\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1140, "output": 1312, "cacheRead": 24576, "cacheWrite": 0, "totalTokens": 27028, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778134516098, "responseId": "resp_07dd49eeb4e49b670169fc2df4a4ac8196963f483a95cff93b"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_eAtVYZ5Yx6gvI2FJTGVlnNhC|fc_07dd49eeb4e49b670169fc2dfc307481969309589ec04b0710", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2872 bytes to tests/src/org.bouncycastle/bcprov-jdk15to18/1.77/src/test/java/org_bouncycastle/bcprov_jdk15to18/BCRainbowPrivateKeyTest.java"}], "isError": false, "timestamp": 1778134528399}]}
