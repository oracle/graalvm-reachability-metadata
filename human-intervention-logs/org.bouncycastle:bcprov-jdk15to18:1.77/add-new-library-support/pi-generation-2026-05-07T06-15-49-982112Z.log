  package org_bouncycastle.bcprov_jdk15to18;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  
  import org.bouncycastle.pqc.crypto.hqc.HQCParameters;
  import org.bouncycastle.pqc.crypto.hqc.HQCPrivateKeyParameters;
  import org.bouncycastle.pqc.jcajce.provider.hqc.BCHQCPrivateKey;
  import org.junit.jupiter.api.Test;
  
  public class BCHQCPrivateKeyTest {
      private static final int HQC128_N = 17669;
      private static final int HQC128_PRIVATE_KEY_SIZE = 40 + 40 + ((HQC128_N + 7) / 8);
  
      @Test
      public void serializesAndDeserializesHqc128PrivateKey() throws Exception {
          BCHQCPrivateKey privateKey = createHqc128PrivateKey();
  
          byte[] serializedKey = serialize(privateKey);
          BCHQCPrivateKey restoredKey = deserialize(serializedKey);
  
          assertThat(restoredKey).isEqualTo(privateKey);
          assertThat(restoredKey.hashCode()).isEqualTo(privateKey.hashCode());
          assertThat(restoredKey.getAlgorithm()).isEqualTo("HQC-128");
          assertThat(restoredKey.getFormat()).isEqualTo("PKCS#8");
          assertThat(restoredKey.getEncoded()).isEqualTo(privateKey.getEncoded());
      }
  
      private static BCHQCPrivateKey createHqc128PrivateKey() {
          HQCPrivateKeyParameters keyParameters = new HQCPrivateKeyParameters(
                  HQCParameters.hqc128,
                  createBytes(HQC128_PRIVATE_KEY_SIZE, 1));
          return new BCHQCPrivateKey(keyParameters);
      }
  
      private static byte[] createBytes(int size, int offset) {
          byte[] bytes = new byte[size];
          for (int index = 0; index < bytes.length; index++) {
              bytes[index] = (byte) (index + offset);
          }
          return bytes;
      }
  
      private static byte[] serialize(BCHQCPrivateKey privateKey) throws Exception {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {
              out.writeObject(privateKey);
          }
          return bytes.toByteArray();
      }
  
      private static BCHQCPrivateKey deserialize(byte[] serializedKey) throws Exception {
          try (ObjectInputStream in = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {
              return (BCHQCPrivateKey) in.readObject();
          }
      }
  }
