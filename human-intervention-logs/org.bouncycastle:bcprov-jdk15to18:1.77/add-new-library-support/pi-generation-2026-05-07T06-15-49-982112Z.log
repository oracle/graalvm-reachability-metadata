  package org_bouncycastle.bcprov_jdk15to18;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  
  import org.bouncycastle.pqc.crypto.falcon.FalconParameters;
  import org.bouncycastle.pqc.crypto.falcon.FalconPrivateKeyParameters;
  import org.bouncycastle.pqc.jcajce.provider.falcon.BCFalconPrivateKey;
  import org.bouncycastle.pqc.jcajce.spec.FalconParameterSpec;
  import org.junit.jupiter.api.Test;
  
  public class BCFalconPrivateKeyTest {
      private static final int FALCON_512_SECRET_POLYNOMIAL_SIZE = 512;
      private static final int FALCON_512_PUBLIC_KEY_SIZE = 897;
  
      @Test
      public void serializesAndDeserializesFalcon512PrivateKey() throws Exception {
          BCFalconPrivateKey privateKey = createFalcon512PrivateKey();
  
          byte[] serializedKey = serialize(privateKey);
          BCFalconPrivateKey restoredKey = deserialize(serializedKey);
  
          assertThat(restoredKey).isEqualTo(privateKey);
          assertThat(restoredKey.hashCode()).isEqualTo(privateKey.hashCode());
          assertThat(restoredKey.getAlgorithm()).isEqualTo("FALCON-512");
          assertThat(restoredKey.getFormat()).isEqualTo("PKCS#8");
          assertThat(restoredKey.getEncoded()).isEqualTo(privateKey.getEncoded());
          assertThat(restoredKey.getPublicKey().getEncoded()).isEqualTo(privateKey.getPublicKey().getEncoded());
          assertThat(restoredKey.getParameterSpec().getName()).isEqualTo(FalconParameterSpec.falcon_512.getName());
      }
  
      private static BCFalconPrivateKey createFalcon512PrivateKey() {
          FalconPrivateKeyParameters keyParameters = new FalconPrivateKeyParameters(
                  FalconParameters.falcon_512,
                  createBytes(FALCON_512_SECRET_POLYNOMIAL_SIZE, 1),
                  createBytes(FALCON_512_SECRET_POLYNOMIAL_SIZE, 19),
                  createBytes(FALCON_512_SECRET_POLYNOMIAL_SIZE, 37),
                  createBytes(FALCON_512_PUBLIC_KEY_SIZE, 53));
          return new BCFalconPrivateKey(keyParameters);
      }
  
      private static byte[] createBytes(int size, int offset) {
          byte[] bytes = new byte[size];
          for (int index = 0; index < bytes.length; index++) {
              bytes[index] = (byte) (index + offset);
          }
          return bytes;
      }
  
      private static byte[] serialize(BCFalconPrivateKey privateKey) throws Exception {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {
              out.writeObject(privateKey);
          }
          return bytes.toByteArray();
      }
  
      private static BCFalconPrivateKey deserialize(byte[] serializedKey) throws Exception {
          try (ObjectInputStream in = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {
              return (BCFalconPrivateKey) in.readObject();
          }
