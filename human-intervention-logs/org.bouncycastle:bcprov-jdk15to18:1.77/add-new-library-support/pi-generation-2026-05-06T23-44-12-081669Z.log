nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.math.BigInteger;\n\nimport org.bouncycastle.jcajce.provider.asymmetric.ecgost.BCECGOST3410PrivateKey;\nimport org.bouncycastle.jce.ECGOST3410NamedCurveTable;\nimport org.bouncycastle.jce.spec.ECNamedCurveParameterSpec;\nimport org.bouncycastle.jce.spec.ECNamedCurveSpec;\nimport org.bouncycastle.jce.spec.ECPrivateKeySpec;\nimport org.junit.jupiter.api.Test;\n\npublic class BCECGOST3410PrivateKeyTest {\n    private static final BigInteger PRIVATE_VALUE = BigInteger.valueOf(37);\n    private static final String CURVE_NAME = \"GostR3410-2001-CryptoPro-A\";\n\n    @Test\n    public void serializesAndDeserializesEcGost3410PrivateKey() throws Exception {\n        BCECGOST3410PrivateKey privateKey = createPrivateKey();\n\n        byte[] serializedKey = serialize(privateKey);\n        BCECGOST3410PrivateKey restoredKey = deserialize(serializedKey);\n\n        assertThat(restoredKey).isEqualTo(privateKey);\n        assertThat(restoredKey.hashCode()).isEqualTo(privateKey.hashCode());\n        assertThat(restoredKey.getAlgorithm()).isEqualTo(\"ECGOST3410\");\n        assertThat(restoredKey.getFormat()).isEqualTo(\"PKCS#8\");\n        assertThat(restoredKey.getD()).isEqualTo(PRIVATE_VALUE);\n        assertThat(restoredKey.getS()).isEqualTo(PRIVATE_VALUE);\n        assertThat(restoredKey.getEncoded()).isEqualTo(privateKey.getEncoded());\n        assertThat(restoredKey.getParameters()).isInstanceOf(ECNamedCurveParameterSpec.class);\n        assertThat(restoredKey.getParameters().getN()).isEqualTo(privateKey.getParameters().getN());\n        assertThat(restoredKey.getParameters().getH()).isEqualTo(privateKey.getParameters().getH());\n        assertThat(((ECNamedCurveSpec) restoredKey.getParams()).getName())\n                .isEqualTo(((ECNamedCurveSpec) privateKey.getParams()).getName());\n    }\n\n    private static BCECGOST3410PrivateKey createPrivateKey() {\n        ECNamedCurveParameterSpec curveSpec = ECGOST3410NamedCurveTable.getParameterSpec(CURVE_NAME);\n        assertThat(curveSpec).isNotNull();\n        return new BCECGOST3410PrivateKey(new ECPrivateKeySpec(PRIVATE_VALUE, curveSpec));\n    }\n\n    private static byte[] serialize(BCECGOST3410PrivateKey privateKey) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {\n            out.writeObject(privateKey);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static BCECGOST3410PrivateKey deserialize(byte[] serializedKey) throws Exception {\n        try (ObjectInputStream in = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {\n            return (BCECGOST3410PrivateKey) in.readObject();\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778111028964}, {"role": "toolResult", "toolCallId": "call_CvhpKv64B2DLpyQdaidPL541|fc_05133fd4322e95520169fbd234a1dc819ca1c3366cb4b359bf", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk15to18;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.math.BigInteger;\n\nimport org.bouncycastle.jcajce.provider.asymmetric.ec.BCECPublicKey;\nimport org.bouncycastle.jce.ECNamedCurveTable;\nimport org.bouncycastle.jce.provider.BouncyCastleProvider;\nimport org.bouncycastle.jce.spec.ECNamedCurveParameterSpec;\nimport org.bouncycastle.jce.spec.ECPublicKeySpec;\nimport org.bouncycastle.math.ec.ECPoint;\nimport org.junit.jupiter.api.Test;\n\npublic class BCECPublicKeyTest {\n    private static final BigInteger PRIVATE_VALUE = BigInteger.valueOf(29);\n    private static final String CURVE_NAME = \"secp256r1\";\n\n    @Test\n    public void serializesAndDeserializesEcPublicKey() throws Exception {\n        BCECPublicKey publicKey = createPublicKey();\n\n        byte[] serializedKey = serialize(publicKey);\n        BCECPublicKey restoredKey = deserialize(serializedKey);\n\n        assertThat(restoredKey).isEqualTo(publicKey);\n        assertThat(restoredKey.hashCode()).isEqualTo(publicKey.hashCode());\n        assertThat(restoredKey.getAlgorithm()).isEqualTo(\"EC\");\n        assertThat(restoredKey.getFormat()).isEqualTo(\"X.509\");\n        assertThat(restoredKey.getW()).isEqualTo(publicKey.getW());\n        assertThat(restoredKey.getQ()).isEqualTo(publicKey.getQ());\n        assertThat(restoredKey.getEncoded()).isEqualTo(publicKey.getEncoded());\n        assertThat(restoredKey.getParameters()).isInstanceOf(ECNamedCurveParameterSpec.class);\n        assertThat(restoredKey.getParameters().getN()).isEqualTo(publicKey.getParameters().getN());\n        assertThat(restoredKey.getParameters().getH()).isEqualTo(publicKey.getParameters().getH());\n    }\n\n    private static BCECPublicKey createPublicKey() {\n        ECNamedCurveParameterSpec curveSpec = ECNamedCurveTable.getParameterSpec(CURVE_NAME);\n        assertThat(curveSpec).isNotNull();\n        ECPoint publicPoint = curveSpec.getG().multiply(PRIVATE_VALUE).normalize();\n        return new BCECPublicKey(\n                \"EC\",\n                new ECPublicKeySpec(publicPoint, curveSpec),\n                BouncyCastleProvider.CONFIGURATION);\n    }\n\n    private static byte[] serialize(BCECPublicKey publicKey) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {\n            out.writeObject(publicKey);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static BCECPublicKey deserialize(byte[] serializedKey) throws Exception {\n        try (ObjectInputStream in = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {\n            return (BCECPublicKey) in.readObject();\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778111028965}, {"role": "toolResult", "toolCallId": "call_FrlfPMzXjLpQ0P2ZTSsOKyT7|fc_05133fd4322e95520169fbd234a1e4819ca25f1a123c36d3a4", "toolName": "read", "content": [{"type": "text", "text": "ENOENT: no such file or directory, access '/home/vjovanov/c/forge/forge1/graalvm-reachability-metadata/forge/local_repositories/forge_worktrees/1497-47cd89db/local_repositories/source_context/org.bouncycastle/bcprov-jdk15to18/1.77/main/extracted/org/bouncycastle/jcajce/provider/asymmetric/ecgost/BCECGOST3410PublicKey.java'"}], "details": {}, "isError": true, "timestamp": 1778111028965}]}
