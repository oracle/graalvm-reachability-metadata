  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.math.BigInteger;
  
  import org.bouncycastle.jcajce.provider.asymmetric.ecgost.BCECGOST3410PrivateKey;
  import org.bouncycastle.jce.ECGOST3410NamedCurveTable;
  import org.bouncycastle.jce.spec.ECNamedCurveParameterSpec;
  import org.bouncycastle.jce.spec.ECNamedCurveSpec;
  import org.bouncycastle.jce.spec.ECPrivateKeySpec;
  import org.junit.jupiter.api.Test;
  
  public class BCECGOST3410PrivateKeyTest {
      private static final BigInteger PRIVATE_VALUE = BigInteger.valueOf(37);
      private static final String CURVE_NAME = "GostR3410-2001-CryptoPro-A";
  
      @Test
      public void serializesAndDeserializesEcGost3410PrivateKey() throws Exception {
          BCECGOST3410PrivateKey privateKey = createPrivateKey();
  
          byte[] serializedKey = serialize(privateKey);
          BCECGOST3410PrivateKey restoredKey = deserialize(serializedKey);
  
          assertThat(restoredKey).isEqualTo(privateKey);
          assertThat(restoredKey.hashCode()).isEqualTo(privateKey.hashCode());
          assertThat(restoredKey.getAlgorithm()).isEqualTo("ECGOST3410");
          assertThat(restoredKey.getFormat()).isEqualTo("PKCS#8");
          assertThat(restoredKey.getD()).isEqualTo(PRIVATE_VALUE);
          assertThat(restoredKey.getS()).isEqualTo(PRIVATE_VALUE);
          assertThat(restoredKey.getEncoded()).isEqualTo(privateKey.getEncoded());
          assertThat(restoredKey.getParameters()).isInstanceOf(ECNamedCurveParameterSpec.class);
          assertThat(restoredKey.getParameters().getN()).isEqualTo(privateKey.getParameters().getN());
          assertThat(restoredKey.getParameters().getH()).isEqualTo(privateKey.getParameters().getH());
          assertThat(((ECNamedCurveSpec) restoredKey.getParams()).getName())
                  .isEqualTo(((ECNamedCurveSpec) privateKey.getParams()).getName());
      }
  
      private static BCECGOST3410PrivateKey createPrivateKey() {
          ECNamedCurveParameterSpec curveSpec = ECGOST3410NamedCurveTable.getParameterSpec(CURVE_NAME);
          assertThat(curveSpec).isNotNull();
          return new BCECGOST3410PrivateKey(new ECPrivateKeySpec(PRIVATE_VALUE, curveSpec));
      }
  
      private static byte[] serialize(BCECGOST3410PrivateKey privateKey) throws Exception {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {
              out.writeObject(privateKey);
          }
          return bytes.toByteArray();
      }
  
      private static BCECGOST3410PrivateKey deserialize(byte[] serializedKey) throws Exception {
          try (ObjectInputStream in = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {
              return (BCECGOST3410PrivateKey) in.readObject();
          }
      }
  }
