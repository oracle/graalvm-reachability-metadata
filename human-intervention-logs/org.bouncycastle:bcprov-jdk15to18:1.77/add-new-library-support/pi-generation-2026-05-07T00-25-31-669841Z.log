  package org_bouncycastle.bcprov_jdk15to18;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.math.BigInteger;
  import java.security.KeyFactory;
  
  import org.bouncycastle.jcajce.provider.asymmetric.elgamal.BCElGamalPrivateKey;
  import org.bouncycastle.jce.interfaces.ElGamalPrivateKey;
  import org.bouncycastle.jce.provider.BouncyCastleProvider;
  import org.bouncycastle.jce.spec.ElGamalParameterSpec;
  import org.bouncycastle.jce.spec.ElGamalPrivateKeySpec;
  import org.junit.jupiter.api.Test;
  
  public class BCElGamalPrivateKeyTest {
      private static final BigInteger PRIVATE_VALUE = BigInteger.valueOf(11);
      private static final BigInteger PRIME = BigInteger.valueOf(23);
      private static final BigInteger GENERATOR = BigInteger.valueOf(5);
  
      @Test
      public void serializesAndDeserializesElGamalPrivateKey() throws Exception {
          BCElGamalPrivateKey privateKey = createPrivateKey();
  
          byte[] serializedKey = serialize(privateKey);
          BCElGamalPrivateKey restoredKey = deserialize(serializedKey);
  
          assertThat(restoredKey).isEqualTo(privateKey);
          assertThat(restoredKey.getAlgorithm()).isEqualTo("ElGamal");
          assertThat(restoredKey.getFormat()).isEqualTo("PKCS#8");
          assertThat(restoredKey.getX()).isEqualTo(PRIVATE_VALUE);
          assertThat(restoredKey.getParameters().getP()).isEqualTo(PRIME);
          assertThat(restoredKey.getParameters().getG()).isEqualTo(GENERATOR);
          assertThat(restoredKey.getParams().getP()).isEqualTo(PRIME);
          assertThat(restoredKey.getParams().getG()).isEqualTo(GENERATOR);
          assertThat(restoredKey.getEncoded()).isEqualTo(privateKey.getEncoded());
      }
  
      private static BCElGamalPrivateKey createPrivateKey() throws Exception {
          ElGamalParameterSpec parameters = new ElGamalParameterSpec(PRIME, GENERATOR);
          ElGamalPrivateKeySpec keySpec = new ElGamalPrivateKeySpec(PRIVATE_VALUE, parameters);
          KeyFactory keyFactory = KeyFactory.getInstance("ElGamal", new BouncyCastleProvider());
          ElGamalPrivateKey privateKey = (ElGamalPrivateKey) keyFactory.generatePrivate(keySpec);
  
          assertThat(privateKey).isInstanceOf(BCElGamalPrivateKey.class);
          return (BCElGamalPrivateKey) privateKey;
      }
  
      private static byte[] serialize(BCElGamalPrivateKey privateKey) throws Exception {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {
              out.writeObject(privateKey);
          }
          return bytes.toByteArray();
      }
  
      private static BCElGamalPrivateKey deserialize(byte[] serializedKey) throws Exception {
          try (ObjectInputStream in = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {
              return (BCElGamalPrivateKey) in.readObject();
          }
      }
  }
