ertThat(restoredKey.getParams().getP()).isEqualTo(PRIME);\n        assertThat(restoredKey.getParams().getG()).isEqualTo(GENERATOR);\n        assertThat(restoredKey.getEncoded()).isEqualTo(publicKey.getEncoded());\n    }\n\n    private static BCElGamalPublicKey createPublicKey() throws Exception {\n        ElGamalParameterSpec parameters = new ElGamalParameterSpec(PRIME, GENERATOR);\n        ElGamalPublicKeySpec keySpec = new ElGamalPublicKeySpec(PUBLIC_VALUE, parameters);\n        KeyFactory keyFactory = KeyFactory.getInstance(\"ElGamal\", new BouncyCastleProvider());\n        ElGamalPublicKey publicKey = (ElGamalPublicKey) keyFactory.generatePublic(keySpec);\n\n        assertThat(publicKey).isInstanceOf(BCElGamalPublicKey.class);\n        return (BCElGamalPublicKey) publicKey;\n    }\n\n    private static byte[] serialize(BCElGamalPublicKey publicKey) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {\n            out.writeObject(publicKey);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static BCElGamalPublicKey deserialize(byte[] serializedKey) throws Exception {\n        try (ObjectInputStream in = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {\n            return (BCElGamalPublicKey) in.readObject();\n        }\n    }\n}\n"}
