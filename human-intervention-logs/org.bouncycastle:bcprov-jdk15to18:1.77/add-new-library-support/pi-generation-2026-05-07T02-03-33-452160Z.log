  package org_bouncycastle.bcprov_jdk15to18;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.math.BigInteger;
  import java.security.KeyFactory;
  import java.security.KeyPair;
  import java.security.KeyPairGenerator;
  import java.security.Provider;
  import java.security.interfaces.RSAPublicKey;
  import java.security.spec.RSAKeyGenParameterSpec;
  import java.security.spec.X509EncodedKeySpec;
  
  import org.bouncycastle.asn1.ASN1Encoding;
  import org.bouncycastle.asn1.DERNull;
  import org.bouncycastle.asn1.pkcs.PKCSObjectIdentifiers;
  import org.bouncycastle.asn1.x509.AlgorithmIdentifier;
  import org.bouncycastle.asn1.x509.SubjectPublicKeyInfo;
  import org.bouncycastle.jcajce.provider.asymmetric.rsa.BCRSAPublicKey;
  import org.bouncycastle.jce.provider.BouncyCastleProvider;
  import org.junit.jupiter.api.Test;
  
  public class BCRSAPublicKeyTest {
      private static final BigInteger PUBLIC_EXPONENT = BigInteger.valueOf(65537);
  
      @Test
      public void serializesAndDeserializesRsassaPssPublicKey() throws Exception {
          BCRSAPublicKey publicKey = createRsassaPssPublicKey();
  
          byte[] serializedKey = serialize(publicKey);
          BCRSAPublicKey restoredKey = deserialize(serializedKey);
  
          assertThat(restoredKey).isEqualTo(publicKey);
          assertThat(restoredKey.hashCode()).isEqualTo(publicKey.hashCode());
          assertThat(restoredKey.getAlgorithm()).isEqualTo("RSASSA-PSS");
          assertThat(restoredKey.getFormat()).isEqualTo("X.509");
          assertThat(restoredKey.getModulus()).isEqualTo(publicKey.getModulus());
          assertThat(restoredKey.getPublicExponent()).isEqualTo(PUBLIC_EXPONENT);
          assertThat(restoredKey.getEncoded()).isEqualTo(publicKey.getEncoded());
      }
  
      private static BCRSAPublicKey createRsassaPssPublicKey() throws Exception {
          RSAPublicKey generatedKey = generateJdkRsaPublicKey();
          org.bouncycastle.asn1.pkcs.RSAPublicKey rsaPublicKey = new org.bouncycastle.asn1.pkcs.RSAPublicKey(
                  generatedKey.getModulus(),
                  generatedKey.getPublicExponent());
          AlgorithmIdentifier algorithmIdentifier = new AlgorithmIdentifier(
                  PKCSObjectIdentifiers.id_RSASSA_PSS,
                  DERNull.INSTANCE);
          SubjectPublicKeyInfo publicKeyInfo = new SubjectPublicKeyInfo(algorithmIdentifier, rsaPublicKey);
          Provider provider = new BouncyCastleProvider();
          KeyFactory keyFactory = KeyFactory.getInstance("RSA", provider);
  
          Object publicKey = keyFactory.generatePublic(
                  new X509EncodedKeySpec(publicKeyInfo.getEncoded(ASN1Encoding.DER)));
  
          assertThat(publicKey).isInstanceOf(BCRSAPublicKey.class);
          return (BCRSAPublicKey) publicKey;
      }
  
      private static RSAPublicKey generateJdkRsaPublicKey() throws Exception {
          KeyPairGenerator generator = KeyPairGenerator.getInstance("RSA");
          generator.initialize(new RSAKeyGenParameterSpec(512, PUBLIC_EXPONENT));
          KeyPair keyPair = generator.generateKeyPair();
          return (RSAPublicKey) keyPair.getPublic();
      }
  
      private static byte[] serialize(BCRSAPublicKey publicKey) throws Exception {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {
              out.writeObject(publicKey);
          }
          return bytes.toByteArray();
      }
  
      private static BCRSAPublicKey deserialize(byte[] serializedKey) throws Exception {
          try (ObjectInputStream in = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {
              return (BCRSAPublicKey) in.readObject();
          }
      }
  }
