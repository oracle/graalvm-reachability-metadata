[tool-call] delta {"path":"tests/src/org.bouncycastle/bcprov-jdk15to18/1.77/src/test/java/org_bouncycastle/bcprov_jdk15to18/JCERSAPrivateKeyTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk15to18;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.math.BigInteger;\nimport java.util.ArrayList;\nimport java.util.Enumeration;\nimport java.util.List;\n\nimport org.bouncycastle.asn1.ASN1ObjectIdentifier;\nimport org.bouncycastle.asn1.DERUTF8String;\nimport org.bouncycastle.asn1.pkcs.PKCSObjectIdentifiers;\nimport org.bouncycastle.jce.provider.JCERSAPrivateKey;\nimport org.junit.jupiter.api.Test;\n\npublic class JCERSAPrivateKeyTest {\n    private static final BigInteger MODULUS = new BigInteger(\"c4f3b29a7b0e8d65f1\", 16);\n    private static final BigInteger PRIVATE_EXPONENT = new BigInteger(\"71d5c8e922f1a3b\", 16);\n    private static final ASN1ObjectIdentifier FRIENDLY_NAME_OID = PKCSObjectIdentifiers.pkcs_9_at_friendlyName;\n\n    @Test\n    public void serializesAndDeserializesPrivateKeyState() throws Exception {\n        SerializableJCERSAPrivateKey privateKey = new SerializableJCERSAPrivateKey(MODULUS, PRIVATE_EXPONENT);\n        DERUTF8String friendlyName = new DERUTF8String(\"legacy rsa private key\");\n        privateKey.setBagAttribute(FRIENDLY_NAME_OID, friendlyName);\n\n        byte[] serializedKey = serialize(privateKey);\n        SerializableJCERSAPrivateKey restoredKey = deserialize(serializedKey);\n\n        assertThat(restoredKey).isEqualTo(privateKey);\n        assertThat(restoredKey.hashCode()).isEqualTo(privateKey.hashCode());\n        assertThat(restoredKey.getAlgorithm()).isEqualTo(\"RSA\");\n        assertThat(restoredKey.getFormat()).isEqualTo(\"PKCS#8\");\n        assertThat(restoredKey.getModulus()).isEqualTo(MODULUS);\n        assertThat(restoredKey.getPrivateExponent()).isEqualTo(PRIVATE_EXPONENT);\n        assertThat(toOidList(restoredKey.getBagAttributeKeys())).containsExactly(FRIENDLY_NAME_OID);\n        assertThat(restoredKey.getBagAttribute(FRIENDLY_NAME_OID).toASN1Primitive().getEncoded())\n                .isEqualTo(friendlyName.toASN1Primitive().getEncoded());\n    }\n\n    private static byte[] serialize(SerializableJCERSAPrivateKey privateKey) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {\n            out.writeObject(privateKey);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static SerializableJCERSAPrivateKey deserialize(byte[] serializedKey) throws Exception {\n        try (ObjectInputStream in = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {\n            return (SerializableJCERSAPrivateKey) in.readObject();\n        }\n    }\n\n    private static List<ASN1ObjectIdentifier> toOidList(Enumeration<?> keys) {\n        List<ASN1ObjectIdentifier> oids = new ArrayList<>();\n        while (keys.hasMoreElements()) {\n            oids.add(ASN1ObjectIdentifier.getInstance(keys.nextElement()));\n        }\n        return oids;\n    }\n}\n\nfinal class SerializableJCERSAPrivateKey extends JCERSAPrivateKey {\n    private static final long serialVersionUID = 1L;\n\n    SerializableJCERSAPrivateKey(BigInteger modulus, BigInteger privateExponent) {\n        this.modulus = modulus;\n        this.privateExponent = privateExponent;\n    }\n}\n"}
