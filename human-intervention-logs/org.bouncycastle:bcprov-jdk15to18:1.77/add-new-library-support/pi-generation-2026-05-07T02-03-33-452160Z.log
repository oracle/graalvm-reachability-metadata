  package org_bouncycastle.bcprov_jdk15to18;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.util.ArrayList;
  import java.util.Enumeration;
  import java.util.List;
  
  import org.bouncycastle.asn1.ASN1ObjectIdentifier;
  import org.bouncycastle.asn1.DERUTF8String;
  import org.bouncycastle.jcajce.provider.asymmetric.util.PKCS12BagAttributeCarrierImpl;
  import org.junit.jupiter.api.Test;
  
  public class PKCS12BagAttributeCarrierImplTest {
      private static final ASN1ObjectIdentifier FRIENDLY_NAME_OID = new ASN1ObjectIdentifier("1.2.840.113549.1.9.20");
      private static final ASN1ObjectIdentifier LOCAL_KEY_ID_OID = new ASN1ObjectIdentifier("1.2.840.113549.1.9.21");
  
      @Test
      public void writeObjectAndReadObjectRoundTripEncodedAttributes() throws Exception {
          PKCS12BagAttributeCarrierImpl carrier = new PKCS12BagAttributeCarrierImpl();
          DERUTF8String friendlyName = new DERUTF8String("friendly key");
          DERUTF8String localKeyId = new DERUTF8String("local id");
          carrier.setBagAttribute(FRIENDLY_NAME_OID, friendlyName);
          carrier.setBagAttribute(LOCAL_KEY_ID_OID, localKeyId);
  
          byte[] serializedCarrierState = writeCarrierState(carrier);
          PKCS12BagAttributeCarrierImpl restored = readCarrierState(serializedCarrierState);
  
          assertThat(toOidList(restored.getBagAttributeKeys())).containsExactly(FRIENDLY_NAME_OID, LOCAL_KEY_ID_OID);
          assertThat(restored.getBagAttribute(FRIENDLY_NAME_OID).toASN1Primitive().getEncoded())
                  .isEqualTo(friendlyName.toASN1Primitive().getEncoded());
          assertThat(restored.getBagAttribute(LOCAL_KEY_ID_OID).toASN1Primitive().getEncoded())
                  .isEqualTo(localKeyId.toASN1Primitive().getEncoded());
      }
  
      @Test
      public void writeObjectAndReadObjectRoundTripEmptyAttributeState() throws Exception {
          byte[] serializedCarrierState = writeCarrierState(new PKCS12BagAttributeCarrierImpl());
          PKCS12BagAttributeCarrierImpl restored = readCarrierState(serializedCarrierState);
  
          assertThat(restored.getBagAttributeKeys().hasMoreElements()).isFalse();
          assertThat(restored.getBagAttribute(FRIENDLY_NAME_OID)).isNull();
      }
  
      private static byte[] writeCarrierState(PKCS12BagAttributeCarrierImpl carrier) throws Exception {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {
              carrier.writeObject(out);
          }
          return bytes.toByteArray();
      }
  
      private static PKCS12BagAttributeCarrierImpl readCarrierState(byte[] carrierState) throws Exception {
          PKCS12BagAttributeCarrierImpl restored = new PKCS12BagAttributeCarrierImpl();
          try (ObjectInputStream in = new ObjectInputStream(new ByteArrayInputStream(carrierState))) {
              restored.readObject(in);
          }
          return restored;
      }
  
      private static List<ASN1ObjectIdentifier> toOidList(Enumeration<?> keys) {
          List<ASN1ObjectIdentifier> oids = new ArrayList<>();
          while (keys.hasMoreElements()) {
              oids.add(ASN1ObjectIdentifier.getInstance(keys.nextElement()));
          }
          return oids;
      }
  }
