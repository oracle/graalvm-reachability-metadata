  /*
   * Copyright and related rights waived via CC0
   *
   * You should have received a copy of the CC0 legalcode along with this
   * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.
   */
  package org_bouncycastle.bcprov_jdk15to18;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  
  import org.bouncycastle.pqc.crypto.newhope.NHPublicKeyParameters;
  import org.bouncycastle.pqc.jcajce.provider.newhope.BCNHPublicKey;
  import org.junit.jupiter.api.Test;
  
  public class BCNHPublicKeyTest {
      private static final int NEWHOPE_PUBLIC_KEY_SIZE = 1824;
  
      @Test
      public void serializesAndDeserializesNewHopePublicKey() throws Exception {
          BCNHPublicKey publicKey = createNewHopePublicKey();
  
          byte[] serializedKey = serialize(publicKey);
          BCNHPublicKey restoredKey = deserialize(serializedKey);
  
          assertThat(restoredKey).isEqualTo(publicKey);
          assertThat(restoredKey.hashCode()).isEqualTo(publicKey.hashCode());
          assertThat(restoredKey.getAlgorithm()).isEqualTo("NH");
          assertThat(restoredKey.getFormat()).isEqualTo("X.509");
          assertThat(restoredKey.getEncoded()).isEqualTo(publicKey.getEncoded());
          assertThat(restoredKey.getPublicData()).isEqualTo(publicKey.getPublicData());
      }
  
      private static BCNHPublicKey createNewHopePublicKey() {
          return new BCNHPublicKey(new NHPublicKeyParameters(createPublicData()));
      }
  
      private static byte[] createPublicData() {
          byte[] publicData = new byte[NEWHOPE_PUBLIC_KEY_SIZE];
          for (int index = 0; index < publicData.length; index++) {
              publicData[index] = (byte) (index + 1);
          }
          return publicData;
      }
  
      private static byte[] serialize(BCNHPublicKey publicKey) throws Exception {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {
              out.writeObject(publicKey);
          }
          return bytes.toByteArray();
      }
  
      private static BCNHPublicKey deserialize(byte[] serializedKey) throws Exception {
          try (ObjectInputStream in = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {
              return (BCNHPublicKey) in.readObject();
          }
      }
  }
