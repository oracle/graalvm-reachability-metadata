  --- /dev/null
  +++ 2/tests/src/org.bouncycastle/bcprov-jdk15to18/1.77/src/test/java/org_bouncycastle/bcprov_jdk15to18/BCSphincs256PublicKeyTest.java
  @@ -0,0 +1,68 @@
  +/*
  + * Copyright and related rights waived via CC0
  + *
  + * You should have received a copy of the CC0 legalcode along with this
  + * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.
  + */
  +package org_bouncycastle.bcprov_jdk15to18;
  +
  +import static org.assertj.core.api.Assertions.assertThat;
  +
  +import java.io.ByteArrayInputStream;
  +import java.io.ByteArrayOutputStream;
  +import java.io.ObjectInputStream;
  +import java.io.ObjectOutputStream;
  +
  +import org.bouncycastle.asn1.nist.NISTObjectIdentifiers;
  +import org.bouncycastle.pqc.crypto.sphincs.SPHINCSKeyParameters;
  +import org.bouncycastle.pqc.crypto.sphincs.SPHINCSPublicKeyParameters;
  +import org.bouncycastle.pqc.jcajce.provider.sphincs.BCSphincs256PublicKey;
  +import org.junit.jupiter.api.Test;
  +
  +public class BCSphincs256PublicKeyTest {
  +    private static final int SPHINCS_256_PUBLIC_KEY_SIZE = 1056;
  +
  +    @Test
  +    public void serializesAndDeserializesSphincs256PublicKey() throws Exception {
  +        BCSphincs256PublicKey publicKey = createSphincs256PublicKey();
  +
  +        byte[] serializedKey = serialize(publicKey);
  +        BCSphincs256PublicKey restoredKey = deserialize(serializedKey);
  +
  +        assertThat(restoredKey).isEqualTo(publicKey);
  +        assertThat(restoredKey.hashCode()).isEqualTo(publicKey.hashCode());
  +        assertThat(restoredKey.getAlgorithm()).isEqualTo("SPHINCS-256");
  +        assertThat(restoredKey.getFormat()).isEqualTo("X.509");
  +        assertThat(restoredKey.getEncoded()).isEqualTo(publicKey.getEncoded());
  +        assertThat(restoredKey.getKeyData()).isEqualTo(publicKey.getKeyData());
  +    }
  +
  +    private static BCSphincs256PublicKey createSphincs256PublicKey() {
  +        SPHINCSPublicKeyParameters keyParameters = new SPHINCSPublicKeyParameters(
  +                createBytes(SPHINCS_256_PUBLIC_KEY_SIZE),
  +                SPHINCSKeyParameters.SHA512_256);
  +        return new BCSphincs256PublicKey(NISTObjectIdentifiers.id_sha512_256, keyParameters);
  +    }
  +
  +    private static byte[] createBytes(int size) {
  +        byte[] bytes = new byte[size];
  +        for (int index = 0; index < bytes.length; index++) {
  +            bytes[index] = (byte) (index * 29 + 11);
  +        }
  +        return bytes;
  +    }
  +
  +    private static byte[] serialize(BCSphincs256PublicKey publicKey) throws Exception {
  +        ByteArrayOutputStream bytes = new ByteArrayOutputStream();
  +        try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {
  +            out.writeObject(publicKey);
  +        }
  +        return bytes.toByteArray();
  +    }
  +
  +    private static BCSphincs256PublicKey deserialize(byte[] serializedKey) throws Exception {
  +        try (ObjectInputStream in = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {
  +            return (BCSphincs256PublicKey) in.readObject();
  +        }
  +    }
  +}
