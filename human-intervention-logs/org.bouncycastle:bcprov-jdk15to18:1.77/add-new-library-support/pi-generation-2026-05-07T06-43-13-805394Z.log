  package org_bouncycastle.bcprov_jdk15to18;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  
  import org.bouncycastle.asn1.nist.NISTObjectIdentifiers;
  import org.bouncycastle.pqc.crypto.sphincs.SPHINCSKeyParameters;
  import org.bouncycastle.pqc.crypto.sphincs.SPHINCSPrivateKeyParameters;
  import org.bouncycastle.pqc.jcajce.provider.sphincs.BCSphincs256PrivateKey;
  import org.junit.jupiter.api.Test;
  
  public class BCSphincs256PrivateKeyTest {
      private static final int SPHINCS_256_PRIVATE_KEY_SIZE = 1088;
  
      @Test
      public void serializesAndDeserializesSphincs256PrivateKey() throws Exception {
          BCSphincs256PrivateKey privateKey = createSphincs256PrivateKey();
  
          byte[] serializedKey = serialize(privateKey);
          BCSphincs256PrivateKey restoredKey = deserialize(serializedKey);
  
          assertThat(restoredKey).isEqualTo(privateKey);
          assertThat(restoredKey.hashCode()).isEqualTo(privateKey.hashCode());
          assertThat(restoredKey.getAlgorithm()).isEqualTo("SPHINCS-256");
          assertThat(restoredKey.getFormat()).isEqualTo("PKCS#8");
          assertThat(restoredKey.getEncoded()).isEqualTo(privateKey.getEncoded());
          assertThat(restoredKey.getKeyData()).isEqualTo(privateKey.getKeyData());
      }
  
      private static BCSphincs256PrivateKey createSphincs256PrivateKey() {
          SPHINCSPrivateKeyParameters keyParameters = new SPHINCSPrivateKeyParameters(
                  createBytes(SPHINCS_256_PRIVATE_KEY_SIZE),
                  SPHINCSKeyParameters.SHA512_256);
          return new BCSphincs256PrivateKey(NISTObjectIdentifiers.id_sha512_256, keyParameters);
      }
  
      private static byte[] createBytes(int size) {
          byte[] bytes = new byte[size];
          for (int index = 0; index < bytes.length; index++) {
              bytes[index] = (byte) (index * 31 + 17);
          }
          return bytes;
      }
  
      private static byte[] serialize(BCSphincs256PrivateKey privateKey) throws Exception {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {
              out.writeObject(privateKey);
          }
          return bytes.toByteArray();
      }
  
      private static BCSphincs256PrivateKey deserialize(byte[] serializedKey) throws Exception {
          try (ObjectInputStream in = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {
              return (BCSphincs256PrivateKey) in.readObject();
          }
      }
