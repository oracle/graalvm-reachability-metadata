2c0bbf4", "name": "write", "arguments": {"path": "tests/src/org.bouncycastle/bcprov-jdk15to18/1.77/src/test/java/org_bouncycastle/bcprov_jdk15to18/JCEDHPublicKeyTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk15to18;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.DataOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.io.ObjectStreamClass;\nimport java.io.ObjectStreamField;\nimport java.math.BigInteger;\n\nimport org.bouncycastle.jce.provider.JCEDHPublicKey;\nimport org.junit.jupiter.api.Test;\n\npublic class JCEDHPublicKeyTest {\n    private static final int STREAM_MAGIC = 0xaced;\n    private static final int STREAM_VERSION = 5;\n    private static final int TC_OBJECT = 0x73;\n    private static final int TC_CLASSDESC = 0x72;\n    private static final int TC_STRING = 0x74;\n    private static final int TC_BLOCKDATA = 0x77;\n    private static final int TC_ENDBLOCKDATA = 0x78;\n    private static final int TC_NULL = 0x70;\n    private static final int SC_WRITE_METHOD = 0x01;\n    private static final int SC_SERIALIZABLE = 0x02;\n\n    private static final BigInteger PUBLIC_VALUE = BigInteger.valueOf(8);\n    private static final BigInteger PRIME = BigInteger.valueOf(23);\n    private static final BigInteger GENERATOR = BigInteger.valueOf(5);\n    private static final int PRIVATE_VALUE_LENGTH = 5;\n\n    @Test\n    public void serializesAndDeserializesDiffieHellmanPublicKey() throws Exception {\n        JCEDHPublicKey publicKey = deserialize(createSerializedPublicKey());\n\n        assertPublicKey(publicKey);\n\n        byte[] serializedKey = serialize(publicKey);\n        JCEDHPublicKey restoredKey = deserialize(serializedKey);\n\n        assertPublicKey(restoredKey);\n        assertThat(restoredKey.getEncoded()).isEqualTo(publicKey.getEncoded());\n    }\n\n    private static byte[] createSerializedPublicKey() throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        DataOutputStream out = new DataOutputStream(bytes);\n\n        out.writeShort(STREAM_MAGIC);\n        out.writeShort(STREAM_VERSION);\n        out.writeByte(TC_OBJECT);\n        writeClassDescription(out);\n        writeSerializedObject(out, PUBLIC_VALUE);\n        writeSerializedObject(out, PRIME);\n        writeSerializedObject(out, GENERATOR);\n        out.writeByte(TC_BLOCKDATA);\n        out.writeByte(Integer.BYTES);\n        out.writeInt(PRIVATE_VALUE_LENGTH);\n        out.writeByte(TC_ENDBLOCKDATA);\n        out.flush();\n\n        return bytes.toByteArray();\n    }\n\n    private static void writeClassDescription(DataOutputStream out) throws Exception {\n        ObjectStreamClass streamClass = ObjectStreamClass.lookup(JCEDHPublicKey.class);\n\n        out.writeByte(TC_CLASSDESC);\n        out.writeUTF(JCEDHPublicKey.class.getName());\n        out.writeLong(streamClass.getSerialVersionUID());\n        out.writeByte(SC_WRITE_METHOD | SC_SERIALIZABLE);\n        ObjectStreamField[] fields = streamClass.getFields();\n        out.writeShort(fields.length);\n        for (ObjectStreamField field : fields) {\n            out.writeByte(field.getTypeCode());\n            out.writeUTF(field.getName());\n            String typeString = field.getTypeString();\n            if (typeString != null) {\n                out.writeByte(TC_STRING);\n                out.writeUTF(typeString);\n            }\n        }\n        out.writeByte(TC_ENDBLOCKDATA);\n        out.writeByte(TC_NULL);\n    }\n\n    private static void writeSerializedObject(DataOutputStream out, Object value) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream objectOut = new ObjectOutputStream(bytes)) {\n            objectOut.writeObject(value);\n        }\n        byte[] serializedObject = bytes.toByteArray();\n        out.write(serializedObject, 4, serializedObject.length - 4);\n    }\n\n    private static byte[] serialize(JCEDHPublicKey publicKey) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {\n            out.writeObject(publicKey);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static JCEDHPublicKey deserialize(byte[] serializedKey) throws Exception {\n        try (ObjectInputStream in = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {\n            return (JCEDHPublicKey) in.readObject();\n        }\n    }\n\n    private static void assertPublicKey(JCEDHPublicKey publicKey) {\n        assertThat(publicKey.getAlgorithm()).isEqualTo(\"DH\");\n        assertThat(publicKey.getFormat()).isEqualTo(\"X.509\");\n        assertThat(publicKey.getY()).isEqualTo(PUBLIC_VALUE);\n        assertThat(publicKey.getParams().getP()).isEqualTo(PRIME);\n        assertThat(publicKey.getParams().getG()).isEqualTo(GENERATOR);\n        assertThat(publicKey.getParams().getL()).isEqualTo(PRIVATE_VALUE_LENGTH);\n        assertThat(publicKey.getEncoded()).isNotEmpty();\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 727, "output": 1553, "cacheRead": 21504, "cacheWrite": 0, "totalTokens": 23784, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778117267177, "responseId": "resp_008f89de770ae9a40169fbea93ac348196b12d74f673fa3a7f"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_pNqNhb71o74aPWQBMPAq0DvF|fc_008f89de770ae9a40169fbea99184081969cd867d602c0bbf4", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 5082 