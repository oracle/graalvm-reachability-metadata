th this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk15to18;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.IOException;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.io.Serializable;\nimport java.math.BigInteger;\nimport java.nio.charset.StandardCharsets;\n\nimport org.bouncycastle.jce.provider.JDKDSAPublicKey;\nimport org.junit.jupiter.api.Test;\n\npublic class JDKDSAPublicKeyTest {\n    private static final BigInteger PUBLIC_VALUE = BigInteger.valueOf(16);\n    private static final BigInteger PRIME = BigInteger.valueOf(47);\n    private static final BigInteger SUBPRIME = BigInteger.valueOf(23);\n    private static final BigInteger GENERATOR = BigInteger.valueOf(4);\n\n    @Test\n    public void serializesAndDeserializesDsaPublicKey() throws Exception {\n        JDKDSAPublicKey publicKey = deserialize(serializationBytesForJdkDsaPublicKey());\n\n        byte[] serializedKey = serialize(publicKey);\n        JDKDSAPublicKey restoredKey = deserialize(serializedKey);\n\n        assertThat(restoredKey).isEqualTo(publicKey);\n        assertThat(restoredKey.hashCode()).isEqualTo(publicKey.hashCode());\n        assertThat(restoredKey.getAlgorithm()).isEqualTo(\"DSA\");\n        assertThat(restoredKey.getFormat()).isEqualTo(\"X.509\");\n        assertThat(restoredKey.getY()).isEqualTo(PUBLIC_VALUE);\n        assertThat(restoredKey.getParams().getP()).isEqualTo(PRIME);\n        assertThat(restoredKey.getParams().getQ()).isEqualTo(SUBPRIME);\n        assertThat(restoredKey.getParams().getG()).isEqualTo(GENERATOR);\n        assertThat(restoredKey.getEncoded()).isEqualTo(publicKey.getEncoded());\n        assertThat(restoredKey.toString()).contains(\"DSA Public Key\");\n    }\n\n    private static byte[] serializationBytesForJdkDsaPublicKey() throws Exception {\n        byte[] serializedProxy = serialize(new SerializedJdkDsaPublicKeyProxy());\n        return replaceSerializedClassName(\n                serializedProxy,\n                SerializedJdkDsaPublicKeyProxy.class.getName(),\n                JDKDSAPublicKey.class.getName());\n    }\n\n    private static byte[] replaceSerializedClassName(\n            byte[] serializedObject,\n            String originalName,\n            String replacementName) throws IOException {\n        byte[] originalNameBytes = originalName.getBytes(StandardCharsets.UTF_8);\n        byte[] replacementNameBytes = replacementName.getBytes(StandardCharsets.UTF_8);\n        int nameIndex = findSerializedClassName(serializedObject, originalNameBytes);\n\n        ByteArrayOutputStream patchedObject = new ByteArrayOutputStream();\n        patchedObject.write(serializedObject, 0, nameIndex - 2);\n        patchedObject.write((replacementNameBytes.length >>> 8) & 0xff);\n        patchedObject.write(replacementNameBytes.length & 0xff);\n        patchedObject.write(replacementNameBytes);\n        patchedObject.write(\n                serializedObject,\n                nameIndex + originalNameBytes.length,\n                serializedObject.length - nameIndex - originalNameBytes.length);\n        return patchedObject.toByteArray();\n    }\n\n    private static int findSerializedClassName(byte[] serializedObject, byte[] classNameBytes) {\n        int foundIndex = -1;\n        for (int index = 2; index <= serializedObject.length - classNameBytes.length; index++) {\n            if (hasSerializedUtfLength(serializedObject, index, classNameBytes.length)\n                    && matchesBytes(serializedObject, index, classNameBytes)) {\n                assertThat(foundIndex).isEqualTo(-1);\n                foundIndex = index;\n            }\n        }\n        assertThat(foundIndex).isNotEqualTo(-1);\n        return foundIndex;\n    }\n\n    private static boolean hasSerializedUtfLength(byte[] serializedObject, int valueIndex, int expectedLength) {\n        int actualLength = ((serializedObject[valueIndex - 2] & 0xff) << 8) | (serializedObject[valueIndex - 1] & 0xff);\n        return actualLength == expectedLength;\n    }\n\n    private static boolean matchesBytes(byte[] serializedObject, int offset, byte[] expectedBytes) {\n        for (int index = 0; index < expectedBytes.length; index++) {\n            if (serializedObject[offset + index] != expectedBytes[index]) {\n                return false;\n            }\n        }\n        return true;\n    }\n\n    private static byte[] serialize(Object object) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {\n            out.writeObject(object);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static JDKDSAPublicKey deserialize(byte[] serializedKey) throws Exception {\n        try (ObjectInputStream in = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {\n            return (JDKDSAPublicKey) in.readObject();\n        }\n    }\n\n    private static final class SerializedJdkDsaPublicKeyProxy implements Serializable {\n        private static final long serialVersionUID = 1752452449903495175L;\n\n        private void writeObject(ObjectOutputStream out) throws IOException {\n            out.writeObject(PUBLIC_VALUE);\n            out.writeObject(PRIME);\n            out.writeObject(SUBPRIME);\n            out.writeObject(GENERATOR);\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 337, "output": 1740, "cacheRead": 18432, "cacheWrite": 0, "totalTokens": 20509, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778121004827, "responseId": "resp_0db7de46848c01a00169fbf92d4fa8819793704c3f2c929e8d"}}
