  package org_bouncycastle.bcprov_jdk15to18;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.security.KeyPairGenerator;
  import java.security.PrivateKey;
  import java.security.Provider;
  import java.security.SecureRandom;
  
  import org.bouncycastle.jcajce.provider.asymmetric.edec.BCXDHPrivateKey;
  import org.bouncycastle.jce.provider.BouncyCastleProvider;
  import org.junit.jupiter.api.Test;
  
  public class BCXDHPrivateKeyTest {
      private static final Provider PROVIDER = new BouncyCastleProvider();
      private static final byte[] RANDOM_SEED = new byte[] {8, 7, 6, 5, 4, 3, 2, 1};
  
      @Test
      public void serializesAndDeserializesX25519PrivateKey() throws Exception {
          BCXDHPrivateKey privateKey = createPrivateKey("X25519", 256);
  
          byte[] serializedKey = serialize(privateKey);
          BCXDHPrivateKey restoredKey = deserialize(serializedKey);
  
          assertRestoredKey(restoredKey, privateKey, "X25519");
      }
  
      @Test
      public void serializesAndDeserializesX448PrivateKey() throws Exception {
          BCXDHPrivateKey privateKey = createPrivateKey("X448", 448);
  
          byte[] serializedKey = serialize(privateKey);
          BCXDHPrivateKey restoredKey = deserialize(serializedKey);
  
          assertRestoredKey(restoredKey, privateKey, "X448");
      }
  
      private static BCXDHPrivateKey createPrivateKey(String algorithm, int strength) throws Exception {
          KeyPairGenerator keyPairGenerator = KeyPairGenerator.getInstance(algorithm, PROVIDER);
          keyPairGenerator.initialize(strength, new SecureRandom(RANDOM_SEED));
          PrivateKey privateKey = keyPairGenerator.generateKeyPair().getPrivate();
          assertThat(privateKey).isInstanceOf(BCXDHPrivateKey.class);
          return (BCXDHPrivateKey) privateKey;
      }
  
      private static void assertRestoredKey(
              BCXDHPrivateKey restoredKey,
              BCXDHPrivateKey privateKey,
              String algorithm) {
          assertThat(restoredKey).isEqualTo(privateKey);
          assertThat(restoredKey.hashCode()).isEqualTo(privateKey.hashCode());
          assertThat(restoredKey.getAlgorithm()).isEqualTo(algorithm);
          assertThat(restoredKey.getFormat()).isEqualTo("PKCS#8");
          assertThat(restoredKey.getEncoded()).isEqualTo(privateKey.getEncoded());
          assertThat(restoredKey.getPublicKey().getAlgorithm()).isEqualTo(algorithm);
          assertThat(restoredKey.toString()).contains(algorithm);
      }
  
      private static byte[] serialize(BCXDHPrivateKey privateKey) throws Exception {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {
              out.writeObject(privateKey);
          }
          return bytes.toByteArray();
      }
  
      private static BCXDHPrivateKey deserialize(byte[] serializedKey) throws Exception {
          try (ObjectInputStream in = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {
              return (BCXDHPrivateKey) in.readObject();
          }
      }
  }
