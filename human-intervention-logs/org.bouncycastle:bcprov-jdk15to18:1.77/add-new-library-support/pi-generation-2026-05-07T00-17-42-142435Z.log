  package org_bouncycastle.bcprov_jdk15to18;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.security.KeyPairGenerator;
  import java.security.Provider;
  import java.security.PublicKey;
  import java.security.SecureRandom;
  
  import org.bouncycastle.jcajce.provider.asymmetric.edec.BCEdDSAPublicKey;
  import org.bouncycastle.jce.provider.BouncyCastleProvider;
  import org.junit.jupiter.api.Test;
  
  public class BCEdDSAPublicKeyTest {
      private static final Provider PROVIDER = new BouncyCastleProvider();
      private static final byte[] RANDOM_SEED = new byte[] {1, 2, 3, 4, 5, 6, 7, 8};
  
      @Test
      public void serializesAndDeserializesEd25519PublicKey() throws Exception {
          BCEdDSAPublicKey publicKey = createEd25519PublicKey();
  
          byte[] serializedKey = serialize(publicKey);
          BCEdDSAPublicKey restoredKey = deserialize(serializedKey);
  
          assertRestoredKey(restoredKey, publicKey, "Ed25519");
      }
  
      @Test
      public void serializesAndDeserializesEd448PublicKey() throws Exception {
          BCEdDSAPublicKey publicKey = createEd448PublicKey();
  
          byte[] serializedKey = serialize(publicKey);
          BCEdDSAPublicKey restoredKey = deserialize(serializedKey);
  
          assertRestoredKey(restoredKey, publicKey, "Ed448");
      }
  
      private static BCEdDSAPublicKey createEd25519PublicKey() throws Exception {
          return generatePublicKey("Ed25519", 255);
      }
  
      private static BCEdDSAPublicKey createEd448PublicKey() throws Exception {
          return generatePublicKey("Ed448", 448);
      }
  
      private static BCEdDSAPublicKey generatePublicKey(String algorithm, int strength) throws Exception {
          KeyPairGenerator keyPairGenerator = KeyPairGenerator.getInstance(algorithm, PROVIDER);
          keyPairGenerator.initialize(strength, new SecureRandom(RANDOM_SEED));
          PublicKey publicKey = keyPairGenerator.generateKeyPair().getPublic();
          assertThat(publicKey).isInstanceOf(BCEdDSAPublicKey.class);
          return (BCEdDSAPublicKey) publicKey;
      }
  
      private static void assertRestoredKey(
              BCEdDSAPublicKey restoredKey,
              BCEdDSAPublicKey publicKey,
              String algorithm) {
          assertThat(restoredKey).isEqualTo(publicKey);
          assertThat(restoredKey.hashCode()).isEqualTo(publicKey.hashCode());
          assertThat(restoredKey.getAlgorithm()).isEqualTo(algorithm);
          assertThat(restoredKey.getFormat()).isEqualTo("X.509");
          assertThat(restoredKey.getPointEncoding()).isEqualTo(publicKey.getPointEncoding());
          assertThat(restoredKey.getEncoded()).isEqualTo(publicKey.getEncoded());
          assertThat(restoredKey.toString()).contains(algorithm);
      }
  
      private static byte[] serialize(BCEdDSAPublicKey publicKey) throws Exception {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {
              out.writeObject(publicKey);
          }
          return bytes.toByteArray();
      }
  
      private static BCEdDSAPublicKey deserialize(byte[] serializedKey) throws Exception {
          try (ObjectInputStream in = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {
              return (BCEdDSAPublicKey) in.readObject();
          }
      }
  }
