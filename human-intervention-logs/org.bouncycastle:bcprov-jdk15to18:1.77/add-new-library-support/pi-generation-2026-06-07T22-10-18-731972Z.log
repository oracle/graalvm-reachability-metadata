[tool-call] delta {"path":"tests/src/org.bouncycastle/bcprov-jdk15to18/1.77/src/test/java/org_bouncycastle/bcprov_jdk15to18/BaseBlockCipherInnerAEADGenericBlockCipherTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk15to18;\n\nimport static org.junit.jupiter.api.Assertions.assertArrayEquals;\nimport static org.junit.jupiter.api.Assertions.assertThrows;\n\nimport java.security.Provider;\n\nimport javax.crypto.AEADBadTagException;\nimport javax.crypto.Cipher;\nimport javax.crypto.spec.GCMParameterSpec;\nimport javax.crypto.spec.SecretKeySpec;\n\nimport org.bouncycastle.jce.provider.BouncyCastleProvider;\nimport org.junit.jupiter.api.Test;\n\npublic class BaseBlockCipherInnerAEADGenericBlockCipherTest {\n    private static final byte[] KEY_BYTES = new byte[] {\n        0x00, 0x01, 0x02, 0x03,\n        0x04, 0x05, 0x06, 0x07,\n        0x08, 0x09, 0x0a, 0x0b,\n        0x0c, 0x0d, 0x0e, 0x0f\n    };\n    private static final byte[] IV_BYTES = new byte[] {\n        0x10, 0x11, 0x12, 0x13,\n        0x14, 0x15, 0x16, 0x17,\n        0x18, 0x19, 0x1a, 0x1b\n    };\n    private static final byte[] AAD_BYTES = new byte[] {\n        0x20, 0x21, 0x22, 0x23,\n        0x24, 0x25, 0x26, 0x27\n    };\n    private static final byte[] PLAINTEXT_BYTES = new byte[] {\n        0x30, 0x31, 0x32, 0x33,\n        0x34, 0x35, 0x36, 0x37,\n        0x38, 0x39, 0x3a, 0x3b,\n        0x3c, 0x3d, 0x3e, 0x3f\n    };\n\n    @Test\n    void gcmBadAuthenticationTagIsReportedAsAeadBadTagException() throws Exception {\n        Provider provider = new BouncyCastleProvider();\n        byte[] ciphertextWithTag = encrypt(provider);\n        ciphertextWithTag[ciphertextWithTag.length - 1] ^= 0x01;\n\n        Cipher decryptCipher = Cipher.getInstance(\"AES/GCM/NoPadding\", provider);\n        decryptCipher.init(Cipher.DECRYPT_MODE, keySpec(), gcmSpec());\n        decryptCipher.updateAAD(AAD_BYTES);\n\n        assertThrows(AEADBadTagException.class, () -> decryptCipher.doFinal(ciphertextWithTag));\n    }\n\n    @Test\n    void gcmRoundTripUsesProviderAeadCipher() throws Exception {\n        Provider provider = new BouncyCastleProvider();\n        byte[] ciphertextWithTag = encrypt(provider);\n\n        Cipher decryptCipher = Cipher.getInstance(\"AES/GCM/NoPadding\", provider);\n        decryptCipher.init(Cipher.DECRYPT_MODE, keySpec(), gcmSpec());\n        decryptCipher.updateAAD(AAD_BYTES);\n\n        assertArrayEquals(PLAINTEXT_BYTES, decryptCipher.doFinal(ciphertextWithTag));\n    }\n\n    private static byte[] encrypt(Provider provider) throws Exception {\n        Cipher encryptCipher = Cipher.getInstance(\"AES/GCM/NoPadding\", provider);\n        encryptCipher.init(Cipher.ENCRYPT_MODE, keySpec(), gcmSpec());\n        encryptCipher.updateAAD(AAD_BYTES);\n        return encryptCipher.doFinal(PLAINTEXT_BYTES);\n    }\n\n    private static SecretKeySpec keySpec() {\n        return new SecretKeySpec(KEY_BYTES, \"AES\");\n    }\n\n    private static GCMParameterSpec gcmSpec() {\n        return new GCMParameterSpec(128, IV_BYTES);\n    }\n}\n"}
