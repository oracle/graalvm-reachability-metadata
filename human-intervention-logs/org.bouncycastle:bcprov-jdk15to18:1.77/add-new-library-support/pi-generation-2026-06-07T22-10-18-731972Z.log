ion {\n        Provider provider = new BouncyCastleProvider();\n        byte[] ciphertextWithTag = encrypt(provider);\n        ciphertextWithTag[ciphertextWithTag.length - 1] ^= 0x01;\n\n        Cipher decryptCipher = Cipher.getInstance(\"AES/GCM/NoPadding\", provider);\n        decryptCipher.init(Cipher.DECRYPT_MODE, keySpec(), gcmSpec());\n        decryptCipher.updateAAD(AAD_BYTES);\n\n        assertThrows(AEADBadTagException.class, () -> decryptCipher.doFinal(ciphertextWithTag));\n    }\n\n    @Test\n    void gcmRoundTripUsesProviderAeadCipher() throws Exception {\n        Provider provider = new BouncyCastleProvider();\n        byte[] ciphertextWithTag = encrypt(provider);\n\n        Cipher decryptCipher = Cipher.getInstance(\"AES/GCM/NoPadding\", provider);\n        decryptCipher.init(Cipher.DECRYPT_MODE, keySpec(), gcmSpec());\n        decryptCipher.updateAAD(AAD_BYTES);\n\n        assertArrayEquals(PLAINTEXT_BYTES, decryptCipher.doFinal(ciphertextWithTag));\n    }\n\n    private static byte[] encrypt(Provider provider) throws Exception {\n        Cipher encryptCipher = Cipher.getInstance(\"AES/GCM/NoPadding\", provider);\n        encryptCipher.init(Cipher.ENCRYPT_MODE, keySpec(), gcmSpec());\n        encryptCipher.updateAAD(AAD_BYTES);\n        return encryptCipher.doFinal(PLAINTEXT_BYTES);\n    }\n\n    private static SecretKeySpec keySpec() {\n        return new SecretKeySpec(KEY_BYTES, \"AES\");\n    }\n\n    private static GCMParameterSpec gcmSpec() {\n        return new GCMParameterSpec(128, IV_BYTES);\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 336, "output": 1465, "cacheRead": 19456, "cacheWrite": 0, "totalTokens": 21257, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780870164113, "responseId": "resp_0bed3fa8694c3411016a25ec147474819480d754f099ed298f"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_uHEA6qD