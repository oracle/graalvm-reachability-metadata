      protected void engineInit(
          int opmode,
          Key key,
          AlgorithmParameters params,
          SecureRandom random)
          throws InvalidKeyException, InvalidAlgorithmParameterException
      {
          AlgorithmParameterSpec paramSpec = null;
  
