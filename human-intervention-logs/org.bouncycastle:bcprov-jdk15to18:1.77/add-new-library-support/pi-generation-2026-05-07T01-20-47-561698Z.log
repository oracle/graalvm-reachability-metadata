x1e, 0x1f\n        };\n        Provider provider = new BouncyCastleProvider();\n        SecretKeyFactory factory = SecretKeyFactory.getInstance(\"AES\", provider);\n        SecretKey key = new SecretKeySpec(keyBytes, \"AES\");\n\n        EncodedKeySpec spec = factory.getKeySpec(key, EncodedKeySpec.class);\n\n        assertThat(spec.getEncoded()).containsExactly(keyBytes);\n    }\n\n    public static final class EncodedKeySpec implements KeySpec {\n        private final byte[] encoded;\n\n        public EncodedKeySpec(byte[] encoded) {\n            this.encoded = encoded.clone();\n        }\n\n        public byte[] getEncoded() {\n            return encoded.clone();\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 481, "output": 753, "cacheRead": 20480, "cacheWrite": 0, "totalTokens": 21714, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778116824701, "responseId": "resp_00252f1752eafcb10169fbe8d95ce8819594b39d329ab9b0f1"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_jK0cjt2QjF0pWyHRt2Q2Gcmw|fc_00252f1752eafcb10169fbe8dcb91c8195b7dacc2ca8782268", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1548 bytes to tests/src/org.bouncycastle/bcprov-jdk15to18/1.77/src/test/java/org_bouncycastle/bcprov_jdk15to18/BaseSecretKeyFactoryTest.java"}], "isError": false, "timestamp": 1778116831547}]}
