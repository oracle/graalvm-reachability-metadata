  package org_bouncycastle.bcprov_jdk15to18;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.security.spec.ECPublicKeySpec;
  
  import org.bouncycastle.asn1.ASN1ObjectIdentifier;
  import org.bouncycastle.asn1.ua.DSTU4145NamedCurves;
  import org.bouncycastle.crypto.params.ECDomainParameters;
  import org.bouncycastle.jcajce.provider.asymmetric.dstu.BCDSTU4145PublicKey;
  import org.bouncycastle.jce.spec.ECNamedCurveSpec;
  import org.junit.jupiter.api.Test;
  
  public class BCDSTU4145PublicKeyTest {
      @Test
      public void serializesAndDeserializesDstu4145PublicKey() throws Exception {
          BCDSTU4145PublicKey publicKey = createPublicKey();
  
          byte[] serializedKey = serialize(publicKey);
          BCDSTU4145PublicKey restoredKey = deserialize(serializedKey);
  
          assertThat(restoredKey.getAlgorithm()).isEqualTo("DSTU4145");
          assertThat(restoredKey.getFormat()).isEqualTo("X.509");
          assertThat(restoredKey.getW()).isEqualTo(publicKey.getW());
          assertThat(restoredKey.getQ()).isEqualTo(publicKey.getQ());
          assertThat(restoredKey.getEncoded()).isEqualTo(publicKey.getEncoded());
          assertThat(restoredKey.getSbox()).isEqualTo(publicKey.getSbox());
          assertThat(restoredKey.getParams().getOrder()).isEqualTo(publicKey.getParams().getOrder());
          assertThat(restoredKey.getParams().getCofactor()).isEqualTo(publicKey.getParams().getCofactor());
          assertThat(((ECNamedCurveSpec) restoredKey.getParams()).getName())
                  .isEqualTo(((ECNamedCurveSpec) publicKey.getParams()).getName());
      }
  
      private static BCDSTU4145PublicKey createPublicKey() {
          ASN1ObjectIdentifier curveOid = DSTU4145NamedCurves.getOIDs()[0];
          ECDomainParameters domainParameters = DSTU4145NamedCurves.getByOID(curveOid);
          ECNamedCurveSpec curveSpec = new ECNamedCurveSpec(
                  curveOid.getId(),
                  domainParameters.getCurve(),
                  domainParameters.getG(),
                  domainParameters.getN(),
                  domainParameters.getH(),
                  domainParameters.getSeed());
          return new BCDSTU4145PublicKey(new ECPublicKeySpec(curveSpec.getGenerator(), curveSpec));
      }
  
      private static byte[] serialize(BCDSTU4145PublicKey publicKey) throws Exception {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {
              out.writeObject(publicKey);
