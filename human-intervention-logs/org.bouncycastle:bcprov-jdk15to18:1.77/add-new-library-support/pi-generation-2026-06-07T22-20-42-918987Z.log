  package org_bouncycastle.bcprov_jdk15to18;
  
  import static org.junit.jupiter.api.Assertions.assertArrayEquals;
  import static org.junit.jupiter.api.Assertions.assertEquals;
  
  import javax.crypto.SecretKeyFactory;
  import javax.crypto.spec.SecretKeySpec;
  
  import org.bouncycastle.jcajce.spec.RawEncodedKeySpec;
  import org.bouncycastle.jce.provider.BouncyCastleProvider;
  import org.junit.jupiter.api.Test;
  
  public class BaseSecretKeyFactoryTest {
      private static final byte[] AES_KEY_BYTES = new byte[] {
          0x00, 0x01, 0x02, 0x03,
          0x04, 0x05, 0x06, 0x07,
          0x08, 0x09, 0x0a, 0x0b,
          0x0c, 0x0d, 0x0e, 0x0f
      };
  
      @Test
      void getKeySpecInstantiatesRequestedByteArrayKeySpec() throws Exception {
          SecretKeyFactory keyFactory = SecretKeyFactory.getInstance("AES", new BouncyCastleProvider());
          SecretKeySpec secretKey = new SecretKeySpec(AES_KEY_BYTES, "AES");
  
          RawEncodedKeySpec keySpec = (RawEncodedKeySpec)keyFactory.getKeySpec(secretKey, RawEncodedKeySpec.class);
  
          assertEquals("RAW", keySpec.getFormat());
          assertArrayEquals(AES_KEY_BYTES, keySpec.getEncoded());
      }
  }
