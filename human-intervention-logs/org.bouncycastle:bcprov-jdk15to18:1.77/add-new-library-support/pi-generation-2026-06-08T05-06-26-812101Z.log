          sign = f[0];
          for (i = 0; i < p; i++)
              ginv[i] = (byte)(sign * v[p - 1 - i]);
  
          return (delta == 0);
      }
  
      protected static void minmax(int[] L, int x, int y)
      {
          int xi = L[x];
          int yi = L[y];
          int xy = xi ^ yi;
          int c = yi - xi;
