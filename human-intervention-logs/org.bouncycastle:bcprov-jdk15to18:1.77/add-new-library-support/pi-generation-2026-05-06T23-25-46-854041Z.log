          if (name == null)
          {
              name = ANSSINamedCurves.getName(oid);
          }
  
          if (name == null)
          {
              name = ECGOST3410NamedCurves.getName(oid);
          }
  
          if (name == null)
          {
              name = GMNamedCurves.getName(oid);
          }
  
          if (name == null)
          {
              name = CustomNamedCurves.getName(oid);
          }
  
          return name;
      }
  
