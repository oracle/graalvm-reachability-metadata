      public static String getName(
          ASN1ObjectIdentifier oid)
      {
          String name = X962NamedCurves.getName(oid);
  
          if (name == null)
          {
              name = SECNamedCurves.getName(oid);
          }
  
          if (name == null)
          {
              name = NISTNamedCurves.getName(oid);
          }
  
          if (name == null)
