  package org_bouncycastle.bcprov_jdk15to18;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.math.BigInteger;
  
  import org.bouncycastle.asn1.ASN1Encoding;
  import org.bouncycastle.asn1.ASN1Integer;
  import org.bouncycastle.asn1.pkcs.PrivateKeyInfo;
  import org.bouncycastle.asn1.x509.AlgorithmIdentifier;
  import org.bouncycastle.asn1.x509.DSAParameter;
  import org.bouncycastle.asn1.x9.X9ObjectIdentifiers;
  import org.bouncycastle.jcajce.provider.asymmetric.dsa.BCDSAPrivateKey;
  import org.junit.jupiter.api.Test;
  
  public class BCDSAPrivateKeyTest {
      private static final BigInteger PRIVATE_VALUE = BigInteger.valueOf(7);
      private static final BigInteger PRIME = BigInteger.valueOf(47);
      private static final BigInteger SUBPRIME = BigInteger.valueOf(23);
      private static final BigInteger GENERATOR = BigInteger.valueOf(4);
  
      @Test
      public void serializesAndDeserializesDsaPrivateKey() throws Exception {
          BCDSAPrivateKey privateKey = createPrivateKey();
  
          byte[] serializedKey = serialize(privateKey);
          BCDSAPrivateKey restoredKey = deserialize(serializedKey);
  
          assertThat(restoredKey).isEqualTo(privateKey);
          assertThat(restoredKey.hashCode()).isEqualTo(privateKey.hashCode());
          assertThat(restoredKey.getAlgorithm()).isEqualTo("DSA");
          assertThat(restoredKey.getFormat()).isEqualTo("PKCS#8");
          assertThat(restoredKey.getX()).isEqualTo(PRIVATE_VALUE);
          assertThat(restoredKey.getParams().getP()).isEqualTo(PRIME);
          assertThat(restoredKey.getParams().getQ()).isEqualTo(SUBPRIME);
          assertThat(restoredKey.getParams().getG()).isEqualTo(GENERATOR);
          assertThat(restoredKey.getEncoded()).isEqualTo(privateKey.getEncoded());
      }
  
      private static BCDSAPrivateKey createPrivateKey() throws Exception {
          DSAParameter parameters = new DSAParameter(PRIME, SUBPRIME, GENERATOR);
          AlgorithmIdentifier algorithmIdentifier = new AlgorithmIdentifier(
                  X9ObjectIdentifiers.id_dsa,
                  parameters.toASN1Primitive());
          PrivateKeyInfo privateKeyInfo = new PrivateKeyInfo(algorithmIdentifier, new ASN1Integer(PRIVATE_VALUE));
          return new BCDSAPrivateKey(PrivateKeyInfo.getInstance(privateKeyInfo.getEncoded(ASN1Encoding.DER)));
      }
  
      private static byte[] serialize(BCDSAPrivateKey privateKey) throws Exception {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {
              out.writeObject(privateKey);
          }
          return bytes.toByteArray();
      }
  
      private static BCDSAPrivateKey deserialize(byte[] serializedKey) throws Exception {
          try (ObjectInputStream in = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {
              return (BCDSAPrivateKey) in.readObject();
          }
      }
  }
