bject)\"", "timeout": 10}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 2430, "output": 960, "cacheRead": 47616, "cacheWrite": 0, "totalTokens": 51006, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780858955266, "responseId": "resp_088581f93fd82826016a25c04bf0f0819695c430c4abff2c84"}}
