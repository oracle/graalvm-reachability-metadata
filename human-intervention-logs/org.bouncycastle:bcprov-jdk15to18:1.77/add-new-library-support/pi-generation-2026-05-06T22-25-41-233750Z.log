s JournaledAlgorithmTest {\n    private static final ASN1ObjectIdentifier TEST_ALGORITHM = new ASN1ObjectIdentifier(\"1.2.840.113549.3.7\");\n\n    @Test\n    public void serializesAndDeserializesJournaledAlgorithmState() throws Exception {\n        AlgorithmIdentifier algorithmIdentifier = new AlgorithmIdentifier(TEST_ALGORITHM);\n        JournalingSecureRandom journaling = new JournalingSecureRandom(new CountingSecureRandom());\n        byte[] generatedBytes = new byte[32];\n        journaling.nextBytes(generatedBytes);\n        JournaledAlgorithm journaledAlgorithm = new JournaledAlgorithm(algorithmIdentifier, journaling);\n\n        byte[] serialized = serialize(journaledAlgorithm);\n        JournaledAlgorithm restored = deserialize(serialized);\n\n        assertThat(restored.getAlgorithmIdentifier().getEncoded()).isEqualTo(algorithmIdentifier.getEncoded());\n        assertThat(restored.getEncoded()).isEqualTo(journaledAlgorithm.getEncoded());\n        byte[] replayedBytes = new byte[generatedBytes.length];\n        restored.getJournalingSecureRandom().nextBytes(replayedBytes);\n        assertThat(replayedBytes).isEqualTo(generatedBytes);\n    }\n\n    private static byte[] serialize(Serializable value) throws IOException {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {\n            out.writeObject(value);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static JournaledAlgorithm deserialize(byte[] bytes) throws IOException, ClassNotFoundException {\n        try (ObjectInputStream in = new ObjectInputStream(new ByteArrayInputStream(bytes))) {\n            return (JournaledAlgorithm)in.readObject();\n        }\n    }\n\n    private static final class CountingSecureRandom extends SecureRandom {\n        private int nextByte;\n\n        @Override\n        public void nextBytes(byte[] bytes) {\n            for (int i = 0; i < bytes.length; i++) {\n                bytes[i] = (byte)nextByte++;\n            }\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 798, "output": 1511, "cacheRead": 25088, "cacheWrite": 0, "totalTokens": 27397, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778106291355, "responseId": "resp_0a14f91078024ab10169fbbfb41fac819281dad6e04f09d89c"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_K9FMFdtBAFBD1VvgTuOBYuuH|fc_0a14f91078024ab10169fbbfbdfa308192a90e609aa77dfdfc", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2840 bytes to tests/src/org.bouncycastle/bcprov-jdk15to18/1.77/src/test/java/org_bouncycastle/bcprov_jdk15to18/JournaledAlgorithmTest.java"}], "isError": false, "timestamp": 1778106306193}]}
