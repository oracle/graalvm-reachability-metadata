      private static final String X509_STORE_PREFIX = "X509Store.";
      private static final String X509_STREAM_PARSER_PREFIX = "X509StreamParser.";
      private static final String CERTIFICATE_ALGORITHM = "CERTIFICATE";
      private static final String COLLECTION_ALGORITHM = "CERTIFICATE/COLLECTION";
      private static final String CLASS_FOR_NAME_ALGORITHM = "FORGEBCPROVCOLLECTION";
      private static final String PARSER_CLASS_FOR_NAME_ALGORITHM = "FORGEBCPROVPARSER";
      private static final String PROVIDER_SEARCH_ALGORITHM = "FORGEPROVIDERSEARCH";
      private static final String CERTIFICATE_PARSER_SPI = "org.bouncycastle.jce.provider.X509CertParser";
      private static final String COLLECTION_STORE_SPI = "org.bouncycastle.jce.provider.X509StoreCertCollection";
  
      @Test
      public void createsStoreSpiWithApplicationProviderClassLoader() throws Exception {
          String marker = "loadClass path";
          Provider provider = new BouncyCastleProvider();
  
          X509Store store = X509Store.getInstance(COLLECTION_ALGORITHM, parametersWith(marker), provider);
  
          assertThat(store.getProvider()).isSameAs(provider);
          assertThat(store.getMatches(null)).containsExactly(marker);
      }
  
      @Test
      public void createsStoreSpiWithBootstrapProviderClassLoader() throws Exception {
          String marker = "classForName path";
          Provider provider = bootstrapLoadedProvider();
          String propertyName = X509_STORE_PREFIX + CLASS_FOR_NAME_ALGORITHM;
          Object previousValue = provider.put(propertyName, COLLECTION_STORE_SPI);
  
          try {
              X509Store store = X509Store.getInstance(CLASS_FOR_NAME_ALGORITHM, parametersWith(marker), provider);
  
              assertThat(store.getProvider()).isSameAs(provider);
              assertThat(store.getMatches(null)).containsExactly(marker);
          } finally {
              restoreProperty(provider, propertyName, previousValue);
          }
      }
  
      @Test
      public void createsStoreSpiWhenSearchingInstalledProviders() throws Exception {
          String marker = "provider search path";
          Provider provider = new TestProvider("ForgeX509UtilProvider" + System.nanoTime());
          provider.put(X509_STORE_PREFIX + PROVIDER_SEARCH_ALGORITHM, COLLECTION_STORE_SPI);
          assertThat(Security.insertProviderAt(provider, 1)).isGreaterThan(0);
  
          try {
              X509Store store = X509Store.getInstance(PROVIDER_SEARCH_ALGORITHM, parametersWith(marker));
  
              assertThat(store.getProvider()).isSameAs(provider);
              assertThat(store.getMatches(null)).containsExactly(marker);
          } finally {
              Security.removeProvider(provider.getName());
          }
      }
  
      @Test
      public void createsStreamParserSpiWithApplicationProviderClassLoader() throws Exception {
          Provider provider = new BouncyCastleProvider();
  
          X509StreamParser parser = X509StreamParser.getInstance(CERTIFICATE_ALGORITHM, provider);
  
          parser.init(new ByteArrayInputStream(new byte[0]));
          assertThat(parser.getProvider()).isSameAs(provider);
          assertThat(parser.read()).isNull();
      }
  
      @Test
      public void createsStreamParserSpiWithBootstrapProviderClassLoader() throws Exception {
          Provider provider = bootstrapLoadedProvider();
          String propertyName = X509_STREAM_PARSER_PREFIX + PARSER_CLASS_FOR_NAME_ALGORITHM;
          Object previousValue = provider.put(propertyName, CERTIFICATE_PARSER_SPI);
  
          try {
              X509StreamParser parser = X509StreamParser.getInstance(PARSER_CLASS_FOR_NAME_ALGORITHM, provider);
  
              parser.init(new ByteArrayInputStream(new byte[0]));
              assertThat(parser.getProvider()).isSameAs(provider);
              assertThat(parser.read()).isNull();
          } finally {
              restoreProperty(provider, propertyName, previousValue);
          }
      }
  
      private static Provider bootstrapLoadedProvider() {
          return Arrays.stream(Security.getProviders())
                  .filter(candidate -> candidate.getClass().getClassLoader() == null)
                  .findFirst()
                  .orElseThrow(() -> new IllegalStateException("No bootstrap-loaded security provider is available"));
      }
  
      private static void restoreProperty(Provider provider, String propertyName, Object previousValue) {
          if (previousValue == null) {
              provider.remove(propertyName);
          } else {
              provider.put(propertyName, previousValue);
          }
      }
  
      private static X509CollectionStoreParameters parametersWith(String marker) {
          return new X509CollectionStoreParameters(Collections.singletonList(marker));
      }
  
      private static final class TestProvider extends Provider {
          private TestProvider(String name) {
              super(name, 1.0, "Provider for X509Util dynamic-access tests");
          }
      }
  }
