                  </report>
                  """,
                  StandardCharsets.UTF_8
          );
  
          LibraryStatsModels.VersionStats versionStats = LibraryStatsSupport.buildVersionStats(
                  "com.example:demo:1.0.0",
                  List.of(libraryJar),
                  dynamicAccessDir,
                  jacocoReport
  
