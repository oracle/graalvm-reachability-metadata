                  }
                  """,
                  StandardCharsets.UTF_8
          );
          Files.writeString(
                  dynamicAccessDir.resolve("demo").resolve("resource-calls.json"),
                  """
                  {
                    "java.lang.Class#getResource(java.lang.String)": [
                      "com.example.Bar.lookup(Bar.java:20)"
                    ]
                  }
                  """,
                  StandardCharsets.UTF_8
          );
  
