\"}]}"}, {"type": "toolCall", "id": "call_4yn1aGkGpwYe5HxhcPLWvfJ8|fc_0b36a48590bbef99016a267fc6259c81959dd795da8f3a152f", "name": "write", "arguments": {"path": "tests/src/org.bouncycastle/bcprov-jdk15to18/1.77/src/test/java/org_bouncycastle/bcprov_jdk15to18/DRBGAnonymous4Test.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk15to18;\n\nimport static org.junit.jupiter.api.Assertions.assertEquals;\nimport static org.junit.jupiter.api.Assertions.assertNotEquals;\nimport static org.junit.jupiter.api.Assertions.assertNotNull;\n\nimport java.security.Provider;\nimport java.security.SecureRandom;\nimport java.security.Security;\n\nimport org.bouncycastle.jcajce.provider.drbg.DRBG;\nimport org.junit.jupiter.api.Test;\n\npublic class DRBGAnonymous4Test {\n    private static final String ENTROPY_SOURCE_PROPERTY = \"org.bouncycastle.drbg.entropysource\";\n    private static final String SECURITY_RANDOM_SOURCE_PROPERTY = \"securerandom.source\";\n    private static final String STRONG_ALGORITHMS_PROPERTY = \"securerandom.strongAlgorithms\";\n\n    @Test\n    void nonceAndIvSecureRandomSpiUsesStrongPlatformEntropySource() throws Exception {\n        String previousEntropySource = System.getProperty(ENTROPY_SOURCE_PROPERTY);\n        String previousRandomSource = Security.getProperty(SECURITY_RANDOM_SOURCE_PROPERTY);\n        String previousStrongAlgorithms = Security.getProperty(STRONG_ALGORITHMS_PROPERTY);\n        String strongAlgorithm = firstAvailableStrongSecureRandomAlgorithm();\n\n        System.clearProperty(ENTROPY_SOURCE_PROPERTY);\n        Security.setProperty(SECURITY_RANDOM_SOURCE_PROPERTY, \"not-a-url\");\n        Security.setProperty(STRONG_ALGORITHMS_PROPERTY, strongAlgorithm);\n\n        try {\n            DRBG.NonceAndIV nonceAndIv = new DRBG.NonceAndIV();\n            byte[] first = new byte[32];\n            byte[] second = new byte[32];\n\n            nonceAndIv.engineNextBytes(first);\n            nonceAndIv.engineNextBytes(second);\n\n            assertEquals(32, first.length);\n            assertEquals(32, second.length);\n            assertNotEquals(toHex(first), toHex(second));\n        } finally {\n            restoreSystemProperty(ENTROPY_SOURCE_PROPERTY, previousEntropySource);\n            restoreSecurityProperty(SECURITY_RANDOM_SOURCE_PROPERTY, previousRandomSource);\n            restoreSecurityProperty(STRONG_ALGORITHMS_PROPERTY, previousStrongAlgorithms);\n        }\n    }\n\n    private static String firstAvailableStrongSecureRandomAlgorithm() throws Exception {\n        for (Provider provider : Security.getProviders()) {\n            for (Provider.Service service : provider.getServices()) {\n                if (\"SecureRandom\".equals(service.getType())) {\n                    SecureRandom random = SecureRandom.getInstance(service.getAlgorithm(), provider);\n                    assertNotNull(random);\n                    return service.getAlgorithm() + \":\" + provider.getName();\n                }\n            }\n        }\n        throw new IllegalStateException(\"No SecureRandom provider is available\");\n    }\n\n    private static String toHex(byte[] bytes) {\n        StringBuilder hex = new StringBuilder(bytes.length * 2);\n        for (byte value : bytes) {\n            hex.append(String.format(\"%02x\", value & 0xff));\n        }\n        return hex.toString();\n    }\n\n    private static void restoreSystemProperty(String name, String previousValue) {\n        if (previousValue == null) {\n            System.clearProperty(name);\n        } else {\n            System.setProperty(name, previousValue);\n        }\n    }\n\n    private static void restoreSecurityProperty(String name, String previousValue) {\n        if (previousValue != null) {\n            Security.setProperty(name, previousValue);\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 966, "output": 1403, "cacheRead": 28672, "cacheWrite": 0, "totalTokens": 31041, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780907956602, "responseId": "resp_0b36a48590bbef99016a267fb50b9c81959fa38fc9e1f61afb"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_4yn1aGkGpwYe5HxhcPLWvfJ8|fc_0b36a48590bbef99016a267fc6259c81959dd795da8f3a152f", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 3631 bytes to tests/src/org.bouncycastle/bcprov-jdk15to18/1.77/src/test/java/org_bouncycastle/bcprov_jdk15to18/DRBGAnonymous4Test.java"}], "isError": false, "timestamp": 1780907979822}]}
