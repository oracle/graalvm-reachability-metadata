                      drbg.reseed(additionalInput);
                  }
                  else
                  {
                      entropySource.schedule();
                  }
              }
  
              drbg.nextBytes(entropy);
  
              return entropy;
          }
  
          public int entropySize()
          {
              return bytesRequired * 8;
          }
  
