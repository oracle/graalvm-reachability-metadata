56);\n    }\n\n    private static BCXMSSMTPublicKey createSha256PublicKey() {\n        XMSSMTParameters parameters = new XMSSMTParameters(HEIGHT, LAYERS, NISTObjectIdentifiers.id_sha256);\n        XMSSMTPublicKeyParameters keyParameters = new XMSSMTPublicKeyParameters.Builder(parameters)\n                .withRoot(createBytes(SHA256_DIGEST_SIZE, 17))\n                .withPublicSeed(createBytes(SHA256_DIGEST_SIZE, 61))\n                .build();\n        return new BCXMSSMTPublicKey(NISTObjectIdentifiers.id_sha256, keyParameters);\n    }\n\n    private static byte[] createBytes(int size, int offset) {\n        byte[] bytes = new byte[size];\n        for (int index = 0; index < bytes.length; index++) {\n            bytes[index] = (byte) (index + offset);\n        }\n        return bytes;\n    }\n\n    private static byte[] serialize(BCXMSSMTPublicKey publicKey) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {\n            out.writeObject(publicKey);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static BCXMSSMTPublicKey deserialize(byte[] serializedKey) throws Exception {\n        try (ObjectInputStream in = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {\n            return (BCXMSSMTPublicKey) in.readObject();\n        }\n    }\n}\n"}
