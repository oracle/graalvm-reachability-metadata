KeyTest {\n    private static final int HEIGHT = 4;\n    private static final int LAYERS = 2;\n    private static final int SHA256_DIGEST_SIZE = 32;\n\n    @Test\n    public void serializesAndDeserializesSha256PublicKey() throws Exception {\n        BCXMSSMTPublicKey publicKey = createSha256PublicKey();\n\n        byte[] serializedKey = serialize(publicKey);\n        BCXMSSMTPublicKey restoredKey = deserialize(serializedKey);\n\n        assertThat(restoredKey).isEqualTo(publicKey);\n        assertThat(restoredKey.hashCode()).isEqualTo(publicKey.hashCode());\n        assertThat(restoredKey.getAlgorithm()).isEqualTo(\"XMSSMT\");\n        assertThat(restoredKey.getFormat()).isEqualTo(\"X.509\");\n        assertThat(restoredKey.getEncoded()).isEqualTo(publicKey.getEncoded());\n        assertThat(restoredKey.getHeight()).isEqualTo(HEIGHT);\n        assertThat(restoredKey.getLayers()).isEqualTo(LAYERS);\n        assertThat(restoredKey.getTreeDigest()).isEqualTo(XMSSParameterSpec.SHA256);\n    }\n\n    private static BCXMSSMTPublicKey createSha256PublicKey() {\n        XMSSMTParameters parameters = new XMSSMTParameters(HEIGHT, LAYERS, NISTObjectIdentifiers.id_sha256);\n        XMSSMTPublicKeyParameters keyParameters = new XMSSMTPublicKeyParameters.Builder(parameters)\n                .withRoot(createBytes(SHA256_DIGEST_SIZE, 17))\n                .withPublicSeed(createBytes(SHA256_DIGEST_SIZE, 61))\n                .build();\n        return new BCXMSSMTPublicKey(NISTObjectIdentifiers.id_sha256, keyParameters);\n    }\n\n    private static byte[] createBytes(int size, int offset) {\n        byte[] bytes = new byte[size];\n        for (int index = 0; index < bytes.length; index++) {\n            bytes[index] = (byte) (index + offset);\n        }\n        return bytes;\n    }\n\n    private static byte[] serialize(BCXMSSMTPublicKey publicKey) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {\n            out.writeObject(publicKey);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static BCXMSSMTPublicKey deserialize(byte[] serializedKey) throws Exception {\n        try (ObjectInputStream in = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {\n            return (BCXMSSMTPublicKey) in.readObject();\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1053, "output": 1162, "cacheRead": 19968, "cacheWrite": 0, "totalTokens": 22183, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778138070680, "responseId": "resp_0d08d527653e6a4a0169fc3bd73c14819e856d8373fb0cd34e"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_8H6IFR4L51h6R2jFFz8B6cnR|fc_0d08d527653e6a4a0169fc3bdbc028819e86982008c154fe14", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 3161 bytes to tests/src/org.bouncycastle/bcprov-jdk15to18/1.77/src/test/java/org_bouncycastle/bcprov_jdk15to18/BCXMSSMTPublicKeyTest.java"}], "isError": false, "timestamp": 1778138082079}]}
