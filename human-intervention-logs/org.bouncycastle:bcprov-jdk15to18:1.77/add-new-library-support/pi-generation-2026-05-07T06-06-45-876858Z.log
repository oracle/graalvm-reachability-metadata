  package org_bouncycastle.bcprov_jdk15to18;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  
  import org.bouncycastle.pqc.crypto.bike.BIKEParameters;
  import org.bouncycastle.pqc.crypto.bike.BIKEPrivateKeyParameters;
  import org.bouncycastle.pqc.jcajce.provider.bike.BCBIKEPrivateKey;
  import org.bouncycastle.pqc.jcajce.spec.BIKEParameterSpec;
  import org.junit.jupiter.api.Test;
  
  public class BCBIKEPrivateKeyTest {
      @Test
      public void serializesAndDeserializesBike128PrivateKey() throws Exception {
          BCBIKEPrivateKey privateKey = createBike128PrivateKey();
  
          byte[] serializedKey = serialize(privateKey);
          BCBIKEPrivateKey restoredKey = deserialize(serializedKey);
  
          assertThat(restoredKey).isEqualTo(privateKey);
          assertThat(restoredKey.hashCode()).isEqualTo(privateKey.hashCode());
          assertThat(restoredKey.getAlgorithm()).isEqualTo("BIKE128");
          assertThat(restoredKey.getFormat()).isEqualTo("PKCS#8");
          assertThat(restoredKey.getEncoded()).isEqualTo(privateKey.getEncoded());
          assertThat(restoredKey.getParameterSpec().getName()).isEqualTo(BIKEParameterSpec.bike128.getName());
      }
  
      private static BCBIKEPrivateKey createBike128PrivateKey() {
          BIKEParameters parameters = BIKEParameters.bike128;
          BIKEPrivateKeyParameters keyParameters = new BIKEPrivateKeyParameters(
                  parameters,
                  createBytes(parameters.getRByte(), 1),
                  createBytes(parameters.getRByte(), 17),
                  createBytes(parameters.getLByte(), 33));
          return new BCBIKEPrivateKey(keyParameters);
      }
  
      private static byte[] createBytes(int size, int offset) {
          byte[] bytes = new byte[size];
          for (int index = 0; index < bytes.length; index++) {
              bytes[index] = (byte) (index + offset);
          }
          return bytes;
      }
  
      private static byte[] serialize(BCBIKEPrivateKey privateKey) throws Exception {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {
              out.writeObject(privateKey);
          }
          return bytes.toByteArray();
      }
  
      private static BCBIKEPrivateKey deserialize(byte[] serializedKey) throws Exception {
          try (ObjectInputStream in = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {
              return (BCBIKEPrivateKey) in.readObject();
          }
      }
  }
