[tool-call] delta {"path":"tests/src/org.bouncycastle/bcprov-jdk15to18/1.77/src/test/java/org_bouncycastle/bcprov_jdk15to18/BCPicnicPrivateKeyTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk15to18;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\n\nimport org.bouncycastle.pqc.crypto.picnic.PicnicParameters;\nimport org.bouncycastle.pqc.crypto.picnic.PicnicPrivateKeyParameters;\nimport org.bouncycastle.pqc.jcajce.provider.picnic.BCPicnicPrivateKey;\nimport org.bouncycastle.pqc.jcajce.spec.PicnicParameterSpec;\nimport org.junit.jupiter.api.Test;\n\npublic class BCPicnicPrivateKeyTest {\n    @Test\n    public void serializesAndDeserializesPicnicL1FsPrivateKey() throws Exception {\n        BCPicnicPrivateKey privateKey = createPicnicL1FsPrivateKey();\n\n        byte[] serializedKey = serialize(privateKey);\n        BCPicnicPrivateKey restoredKey = deserialize(serializedKey);\n\n        assertThat(restoredKey).isEqualTo(privateKey);\n        assertThat(restoredKey.hashCode()).isEqualTo(privateKey.hashCode());\n        assertThat(restoredKey.getAlgorithm()).isEqualTo(\"Picnic\");\n        assertThat(restoredKey.getFormat()).isEqualTo(\"PKCS#8\");\n        assertThat(restoredKey.getEncoded()).isEqualTo(privateKey.getEncoded());\n        assertThat(restoredKey.getParameterSpec().getName()).isEqualTo(PicnicParameterSpec.picnicl1fs.getName());\n    }\n\n    private static BCPicnicPrivateKey createPicnicL1FsPrivateKey() {\n        PicnicParameters parameters = PicnicParameters.picnicl1fs;\n        PicnicPrivateKeyParameters keyParameters = new PicnicPrivateKeyParameters(parameters, createBytes(64));\n        return new BCPicnicPrivateKey(keyParameters);\n    }\n\n    private static byte[] createBytes(int size) {\n        byte[] bytes = new byte[size];\n        for (int index = 0; index < bytes.length; index++) {\n            bytes[index] = (byte) (index + 1);\n        }\n        return bytes;\n    }\n\n    private static byte[] serialize(BCPicnicPrivateKey privateKey) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {\n            out.writeObject(privateKey);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static BCPicnicPrivateKey deserialize(byte[] serializedKey) throws Exception {\n        try (ObjectInputStream in = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {\n            return (BCPicnicPrivateKey) in.readObject();\n        }\n    }\n}\n"}
