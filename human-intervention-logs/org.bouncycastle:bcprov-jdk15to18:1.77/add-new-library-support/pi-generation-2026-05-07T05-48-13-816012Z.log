  import org.bouncycastle.pqc.jcajce.spec.NTRULPRimeParameterSpec;
  import org.junit.jupiter.api.Test;
  
  public class BCNTRULPRimePublicKeyTest {
      private static final int NTRULPR_653_PUBLIC_KEY_SIZE = 897;
  
      @Test
      public void serializesAndDeserializesNtrulprime653PublicKey() throws Exception {
          BCNTRULPRimePublicKey publicKey = createNtrulprime653PublicKey();
  
          byte[] serializedKey = serialize(publicKey);
          BCNTRULPRimePublicKey restoredKey = deserialize(serializedKey);
  
          assertThat(restoredKey).isEqualTo(publicKey);
          assertThat(restoredKey.hashCode()).isEqualTo(publicKey.hashCode());
          assertThat(restoredKey.getAlgorithm()).isEqualTo("NTRULPRime");
          assertThat(restoredKey.getFormat()).isEqualTo("X.509");
          assertThat(restoredKey.getEncoded()).isEqualTo(publicKey.getEncoded());
          assertThat(restoredKey.getParameterSpec().getName())
                  .isEqualTo(NTRULPRimeParameterSpec.ntrulpr653.getName());
      }
  
      private static BCNTRULPRimePublicKey createNtrulprime653PublicKey() {
          NTRULPRimePublicKeyParameters keyParameters = new NTRULPRimePublicKeyParameters(
                  NTRULPRimeParameters.ntrulpr653,
                  createBytes(NTRULPR_653_PUBLIC_KEY_SIZE, 23));
          return new BCNTRULPRimePublicKey(keyParameters);
      }
  
      private static byte[] createBytes(int size, int offset) {
          byte[] bytes = new byte[size];
          for (int index = 0; index < bytes.length; index++) {
              bytes[index] = (byte) (index + offset);
          }
          return bytes;
      }
  
      private static byte[] serialize(BCNTRULPRimePublicKey publicKey) throws Exception {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {
              out.writeObject(publicKey);
          }
          return bytes.toByteArray();
      }
  
      private static BCNTRULPRimePublicKey deserialize(byte[] serializedKey) throws Exception {
          try (ObjectInputStream in = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {
              return (BCNTRULPRimePublicKey) in.readObject();
          }
      }
  }
