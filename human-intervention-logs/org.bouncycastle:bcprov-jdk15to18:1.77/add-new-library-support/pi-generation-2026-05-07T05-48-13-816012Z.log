  import org.bouncycastle.pqc.jcajce.provider.ntruprime.BCSNTRUPrimePrivateKey;
  import org.bouncycastle.pqc.jcajce.spec.SNTRUPrimeParameterSpec;
  import org.junit.jupiter.api.Test;
  
  public class BCSNTRUPrimePrivateKeyTest {
      private static final int SNTRUP_653_ENCODED_SMALL_POLYNOMIAL_SIZE = (653 + 3) / 4;
      private static final int SNTRUP_653_PUBLIC_KEY_SIZE = 994;
      private static final int SNTRUP_653_RHO_SIZE = (653 + 3) / 4;
      private static final int SNTRUP_653_HASH_SIZE = 32;
  
      @Test
      public void serializesAndDeserializesSntruprime653PrivateKey() throws Exception {
          BCSNTRUPrimePrivateKey privateKey = createSntruprime653PrivateKey();
  
          byte[] serializedKey = serialize(privateKey);
          BCSNTRUPrimePrivateKey restoredKey = deserialize(serializedKey);
  
          assertThat(restoredKey).isEqualTo(privateKey);
          assertThat(restoredKey.hashCode()).isEqualTo(privateKey.hashCode());
          assertThat(restoredKey.getAlgorithm()).isEqualTo("NTRULPRime");
          assertThat(restoredKey.getFormat()).isEqualTo("PKCS#8");
          assertThat(restoredKey.getEncoded()).isEqualTo(privateKey.getEncoded());
          assertThat(restoredKey.getParameterSpec().getName()).isEqualTo(SNTRUPrimeParameterSpec.sntrup653.getName());
      }
  
      private static BCSNTRUPrimePrivateKey createSntruprime653PrivateKey() {
          SNTRUPrimePrivateKeyParameters keyParameters = new SNTRUPrimePrivateKeyParameters(
                  SNTRUPrimeParameters.sntrup653,
                  createBytes(SNTRUP_653_ENCODED_SMALL_POLYNOMIAL_SIZE, 1),
                  createBytes(SNTRUP_653_ENCODED_SMALL_POLYNOMIAL_SIZE, 17),
                  createBytes(SNTRUP_653_PUBLIC_KEY_SIZE, 31),
                  createBytes(SNTRUP_653_RHO_SIZE, 47),
                  createBytes(SNTRUP_653_HASH_SIZE, 63));
          return new BCSNTRUPrimePrivateKey(keyParameters);
      }
  
      private static byte[] createBytes(int size, int offset) {
          byte[] bytes = new byte[size];
          for (int index = 0; index < bytes.length; index++) {
              bytes[index] = (byte) (index + offset);
          }
          return bytes;
      }
  
      private static byte[] serialize(BCSNTRUPrimePrivateKey privateKey) throws Exception {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {
              out.writeObject(privateKey);
          }
          return bytes.toByteArray();
      }
  
      private static BCSNTRUPrimePrivateKey deserialize(byte[] serializedKey) throws Exception {
          try (ObjectInputStream in = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {
              return (BCSNTRUPrimePrivateKey) in.readObject();
          }
      }
  }
