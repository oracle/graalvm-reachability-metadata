ed a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk15to18;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\n\nimport org.bouncycastle.pqc.crypto.ntruprime.SNTRUPrimeParameters;\nimport org.bouncycastle.pqc.crypto.ntruprime.SNTRUPrimePublicKeyParameters;\nimport org.bouncycastle.pqc.jcajce.provider.ntruprime.BCSNTRUPrimePublicKey;\nimport org.bouncycastle.pqc.jcajce.spec.SNTRUPrimeParameterSpec;\nimport org.junit.jupiter.api.Test;\n\npublic class BCSNTRUPrimePublicKeyTest {\n    private static final int SNTRUP_653_PUBLIC_KEY_SIZE = 994;\n\n    @Test\n    public void serializesAndDeserializesSntruprime653PublicKey() throws Exception {\n        BCSNTRUPrimePublicKey publicKey = createSntruprime653PublicKey();\n\n        byte[] serializedKey = serialize(publicKey);\n        BCSNTRUPrimePublicKey restoredKey = deserialize(serializedKey);\n\n        assertThat(restoredKey).isEqualTo(publicKey);\n        assertThat(restoredKey.hashCode()).isEqualTo(publicKey.hashCode());\n        assertThat(restoredKey.getAlgorithm()).isEqualTo(\"NTRULPRime\");\n        assertThat(restoredKey.getFormat()).isEqualTo(\"X.509\");\n        assertThat(restoredKey.getEncoded()).isEqualTo(publicKey.getEncoded());\n        assertThat(restoredKey.getParameterSpec().getName()).isEqualTo(SNTRUPrimeParameterSpec.sntrup653.getName());\n    }\n\n    private static BCSNTRUPrimePublicKey createSntruprime653PublicKey() {\n        SNTRUPrimePublicKeyParameters keyParameters = new SNTRUPrimePublicKeyParameters(\n                SNTRUPrimeParameters.sntrup653,\n                createBytes(SNTRUP_653_PUBLIC_KEY_SIZE, 23));\n        return new BCSNTRUPrimePublicKey(keyParameters);\n    }\n\n    private static byte[] createBytes(int size, int offset) {\n        byte[] bytes = new byte[size];\n        for (int index = 0; index < bytes.length; index++) {\n            bytes[index] = (byte) (index + offset);\n        }\n        return bytes;\n    }\n\n    private static byte[] serialize(BCSNTRUPrimePublicKey publicKey) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {\n            out.writeObject(publicKey);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static BCSNTRUPrimePublicKey deserialize(byte[] serializedKey) throws Exception {\n        try (ObjectInputStream in = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {\n            return (BCSNTRUPrimePublicKey) in.readObject();\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1716, "output": 890, "cacheRead": 14336, "cacheWrite": 0, "totalTokens": 16942, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778132864506, "responseId": "resp_0c11f4980f53fda70169fc2780dd8881a28965ee6a3f73c0ef"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_g7WVLziAO2iZByB2bwm9Ac4u|fc_0c11f4980f53fda70169fc2782a48c81a299b496088c22afe2", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2826 bytes to tests/src/org.bouncycastle/bcprov-jdk15to18/1.77/src/test/java/org_bouncycastle/bcprov_jdk15to18/BCSNTRUPrimePublicKeyTest.java"}], "isError": false, "timestamp": 1778132877469}]}
