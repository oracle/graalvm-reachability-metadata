                      b <<= 1;
                      b |= (inv[j + 4] >>> k) & 1;
                      b <<= 1;
                      b |= (inv[j + 3] >>> k) & 1;
                      b <<= 1;
                      b |= (inv[j + 2] >>> k) & 1;
                      b <<= 1;
                      b |= (inv[j + 1] >>> k) & 1;
                      b <<= 1;
                      b |= (inv[j + 0] >>> k) & 1;
  
