          CoreSecureRandom(Object[] initialEntropySourceAndSpi)
          {
              super((SecureRandomSpi)initialEntropySourceAndSpi[1], (Provider)initialEntropySourceAndSpi[0]);
          }
      }
  
      private static void sleep(long ms)
          throws InterruptedException
      {
          if (ms != 0)
          {
              Thread.sleep(ms);
          }
      }
  
