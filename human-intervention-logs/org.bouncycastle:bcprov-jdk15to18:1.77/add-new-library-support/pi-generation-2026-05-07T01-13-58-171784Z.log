  package org_bouncycastle.bcprov_jdk15to18;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.security.KeyPair;
  import java.security.KeyPairGenerator;
  import java.security.SecureRandom;
  
  import org.bouncycastle.asn1.cryptopro.CryptoProObjectIdentifiers;
  import org.bouncycastle.jcajce.provider.asymmetric.gost.BCGOST3410PrivateKey;
  import org.bouncycastle.jce.interfaces.GOST3410Params;
  import org.bouncycastle.jce.provider.BouncyCastleProvider;
  import org.bouncycastle.jce.spec.GOST3410ParameterSpec;
  import org.junit.jupiter.api.Test;
  
  public class BCGOST3410PrivateKeyTest {
      private static final String ALGORITHM = "GOST3410";
      private static final String PARAMETER_SET_OID = CryptoProObjectIdentifiers.gostR3410_94_CryptoPro_A.getId();
  
      @Test
      public void serializesAndDeserializesGost3410PrivateKey() throws Exception {
          BCGOST3410PrivateKey privateKey = createPrivateKey();
  
          byte[] serializedKey = serialize(privateKey);
          BCGOST3410PrivateKey restoredKey = deserialize(serializedKey);
  
          assertThat(restoredKey).isEqualTo(privateKey);
          assertThat(restoredKey.hashCode()).isEqualTo(privateKey.hashCode());
          assertThat(restoredKey.getAlgorithm()).isEqualTo(ALGORITHM);
          assertThat(restoredKey.getFormat()).isEqualTo("PKCS#8");
          assertThat(restoredKey.getX()).isEqualTo(privateKey.getX());
          assertThat(restoredKey.getEncoded()).isEqualTo(privateKey.getEncoded());
          assertThat(restoredKey.getParameters().getPublicKeyParamSetOID()).isEqualTo(PARAMETER_SET_OID);
          assertThat(restoredKey.getParameters().getDigestParamSetOID())
                  .isEqualTo(privateKey.getParameters().getDigestParamSetOID());
          assertThat(restoredKey.getParameters().getEncryptionParamSetOID())
                  .isEqualTo(privateKey.getParameters().getEncryptionParamSetOID());
          assertGostParametersMatch(restoredKey.getParameters(), privateKey.getParameters());
      }
  
      private static BCGOST3410PrivateKey createPrivateKey() throws Exception {
          KeyPairGenerator keyPairGenerator = KeyPairGenerator.getInstance(ALGORITHM, new BouncyCastleProvider());
          keyPairGenerator.initialize(
                  new GOST3410ParameterSpec(PARAMETER_SET_OID),
                  new SecureRandom(new byte[] {1, 2, 3, 4}));
          KeyPair keyPair = keyPairGenerator.generateKeyPair();
          assertThat(keyPair.getPrivate()).isInstanceOf(BCGOST3410PrivateKey.class);
          return (BCGOST3410PrivateKey)keyPair.getPrivate();
      }
  
      private static byte[] serialize(BCGOST3410PrivateKey privateKey) throws Exception {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {
              out.writeObject(privateKey);
          }
          return bytes.toByteArray();
      }
  
      private static BCGOST3410PrivateKey deserialize(byte[] serializedKey) throws Exception {
          try (ObjectInputStream in = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {
              return (BCGOST3410PrivateKey)in.readObject();
          }
      }
  
      private static void assertGostParametersMatch(GOST3410Params actual, GOST3410Params expected) {
          assertThat(actual.getPublicKeyParameters().getP()).isEqualTo(expected.getPublicKeyParameters().getP());
          assertThat(actual.getPublicKeyParameters().getQ()).isEqualTo(expected.getPublicKeyParameters().getQ());
          assertThat(actual.getPublicKeyParameters().getA()).isEqualTo(expected.getPublicKeyParameters().getA());
      }
  }
