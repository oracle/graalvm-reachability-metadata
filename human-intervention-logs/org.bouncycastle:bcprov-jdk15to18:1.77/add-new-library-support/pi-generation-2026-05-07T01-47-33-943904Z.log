[tool-call] delta {"path":"tests/src/org.bouncycastle/bcprov-jdk15to18/1.77/src/test/java/org_bouncycastle/bcprov_jdk15to18/JCEECPrivateKeyTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk15to18;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.math.BigInteger;\nimport java.util.ArrayList;\nimport java.util.Enumeration;\nimport java.util.List;\n\nimport org.bouncycastle.asn1.ASN1ObjectIdentifier;\nimport org.bouncycastle.asn1.DERUTF8String;\nimport org.bouncycastle.jce.ECNamedCurveTable;\nimport org.bouncycastle.jce.provider.JCEECPrivateKey;\nimport org.bouncycastle.jce.spec.ECNamedCurveParameterSpec;\nimport org.bouncycastle.jce.spec.ECPrivateKeySpec;\nimport org.junit.jupiter.api.Test;\n\npublic class JCEECPrivateKeyTest {\n    private static final BigInteger PRIVATE_VALUE = BigInteger.valueOf(37);\n    private static final String CURVE_NAME = \"secp256r1\";\n    private static final ASN1ObjectIdentifier FRIENDLY_NAME_OID = new ASN1ObjectIdentifier(\"1.2.840.113549.1.9.20\");\n\n    @Test\n    public void serializesAndDeserializesEcPrivateKey() throws Exception {\n        JCEECPrivateKey privateKey = createPrivateKey();\n        DERUTF8String friendlyName = new DERUTF8String(\"jce ec private key\");\n        privateKey.setBagAttribute(FRIENDLY_NAME_OID, friendlyName);\n        privateKey.setPointFormat(\"COMPRESSED\");\n\n        byte[] serializedKey = serialize(privateKey);\n        JCEECPrivateKey restoredKey = deserialize(serializedKey);\n\n        assertThat(restoredKey).isEqualTo(privateKey);\n        assertThat(restoredKey.hashCode()).isEqualTo(privateKey.hashCode());\n        assertThat(restoredKey.getAlgorithm()).isEqualTo(\"EC\");\n        assertThat(restoredKey.getFormat()).isEqualTo(\"PKCS#8\");\n        assertThat(restoredKey.getD()).isEqualTo(PRIVATE_VALUE);\n        assertThat(restoredKey.getS()).isEqualTo(PRIVATE_VALUE);\n        assertThat(restoredKey.getEncoded()).isEqualTo(privateKey.getEncoded());\n        assertThat(restoredKey.getParameters()).isInstanceOf(ECNamedCurveParameterSpec.class);\n        assertThat(restoredKey.getParameters().getN()).isEqualTo(privateKey.getParameters().getN());\n        assertThat(restoredKey.getParameters().getH()).isEqualTo(privateKey.getParameters().getH());\n        assertThat(toOidList(restoredKey.getBagAttributeKeys())).containsExactly(FRIENDLY_NAME_OID);\n        assertThat(restoredKey.getBagAttribute(FRIENDLY_NAME_OID).toASN1Primitive().getEncoded())\n                .isEqualTo(friendlyName.toASN1Primitive().getEncoded());\n    }\n\n    private static JCEECPrivateKey createPrivateKey() {\n        ECNamedCurveParameterSpec curveSpec = ECNamedCurveTable.getParameterSpec(CURVE_NAME);\n        assertThat(curveSpec).isNotNull();\n        return new JCEECPrivateKey(\"EC\", new ECPrivateKeySpec(PRIVATE_VALUE, curveSpec));\n    }\n\n    private static byte[] serialize(JCEECPrivateKey privateKey) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {\n            out.writeObject(privateKey);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static JCEECPrivateKey deserialize(byte[] serializedKey) throws Exception {\n        try (ObjectInputStream in = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {\n            return (JCEECPrivateKey) in.readObject();\n        }\n    }\n\n    private static List<ASN1ObjectIdentifier> toOidList(Enumeration<?> keys) {\n        List<ASN1ObjectIdentifier> oids = new ArrayList<>();\n        while (keys.hasMoreElements()) {\