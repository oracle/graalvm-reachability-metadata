  package org_bouncycastle.bcprov_jdk15to18;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.DataOutputStream;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.io.ObjectStreamClass;
  import java.io.ObjectStreamField;
  import java.math.BigInteger;
  
  import org.bouncycastle.jce.provider.JCEDHPrivateKey;
  import org.junit.jupiter.api.Test;
  
  public class JCEDHPrivateKeyTest {
      private static final int STREAM_MAGIC = 0xaced;
      private static final int STREAM_VERSION = 5;
      private static final int TC_OBJECT = 0x73;
      private static final int TC_CLASSDESC = 0x72;
      private static final int TC_STRING = 0x74;
      private static final int TC_BLOCKDATA = 0x77;
      private static final int TC_ENDBLOCKDATA = 0x78;
      private static final int TC_NULL = 0x70;
      private static final int SC_WRITE_METHOD = 0x01;
      private static final int SC_SERIALIZABLE = 0x02;
  
      private static final BigInteger PRIVATE_VALUE = BigInteger.valueOf(11);
      private static final BigInteger PRIME = BigInteger.valueOf(23);
      private static final BigInteger GENERATOR = BigInteger.valueOf(5);
      private static final int PRIVATE_VALUE_LENGTH = 5;
  
      @Test
      public void serializesAndDeserializesDiffieHellmanPrivateKey() throws Exception {
          JCEDHPrivateKey privateKey = deserialize(createSerializedPrivateKey());
  
          assertPrivateKey(privateKey);
  
          byte[] serializedKey = serialize(privateKey);
          JCEDHPrivateKey restoredKey = deserialize(serializedKey);
  
          assertPrivateKey(restoredKey);
          assertThat(restoredKey.getEncoded()).isEqualTo(privateKey.getEncoded());
      }
  
      private static byte[] createSerializedPrivateKey() throws Exception {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          DataOutputStream out = new DataOutputStream(bytes);
  
          out.writeShort(STREAM_MAGIC);
          out.writeShort(STREAM_VERSION);
          out.writeByte(TC_OBJECT);
          writeClassDescription(out);
          writeSerializedObject(out, PRIVATE_VALUE);
          writeSerializedObject(out, PRIME);
          writeSerializedObject(out, GENERATOR);
          out.writeByte(TC_BLOCKDATA);
          out.writeByte(Integer.BYTES);
          out.writeInt(PRIVATE_VALUE_LENGTH);
          out.writeByte(TC_ENDBLOCKDATA);
          out.flush();
  
          return bytes.toByteArray();
      }
  
      private static void writeClassDescription(DataOutputStream out) throws Exception {
          ObjectStreamClass streamClass = ObjectStreamClass.lookup(JCEDHPrivateKey.class);
  
          out.writeByte(TC_CLASSDESC);
          out.writeUTF(JCEDHPrivateKey.class.getName());
          out.writeLong(streamClass.getSerialVersionUID());
          out.writeByte(SC_WRITE_METHOD | SC_SERIALIZABLE);
          ObjectStreamField[] fields = streamClass.getFields();
          out.writeShort(fields.length);
          for (ObjectStreamField field : fields) {
              out.writeByte(field.getTypeCode());
              out.writeUTF(field.getName());
              String typeString = field.getTypeString();
              if (typeString != null) {
                  out.writeByte(TC_STRING);
                  out.writeUTF(typeString);
              }
          }
          out.writeByte(TC_ENDBLOCKDATA);
          out.writeByte(TC_NULL);
      }
  
      private static void writeSerializedObject(DataOutputStream out, Object value) throws Exception {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream objectOut = new ObjectOutputStream(bytes)) {
              objectOut.writeObject(value);
          }
          byte[] serializedObject = bytes.toByteArray();
          out.write(serializedObject, 4, serializedObject.length - 4);
      }
  
      private static byte[] serialize(JCEDHPrivateKey privateKey) throws Exception {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {
              out.writeObject(privateKey);
          }
          return bytes.toByteArray();
      }
  
      private static JCEDHPrivateKey deserialize(byte[] serializedKey) throws Exception {
          try (ObjectInputStream in = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {
              return (JCEDHPrivateKey) in.readObject();
          }
      }
  
      private static void assertPrivateKey(JCEDHPrivateKey privateKey) {
          assertThat(privateKey.getAlgorithm()).isEqualTo("DH");
          assertThat(privateKey.getFormat()).isEqualTo("PKCS#8");
          assertThat(privateKey.getX()).isEqualTo(PRIVATE_VALUE);
          assertThat(privateKey.getParams().getP()).isEqualTo(PRIME);
          assertThat(privateKey.getParams().getG()).isEqualTo(GENERATOR);
          assertThat(privateKey.getParams().getL()).isEqualTo(PRIVATE_VALUE_LENGTH);
          assertThat(privateKey.getEncoded()).isNotEmpty();
      }
  }
