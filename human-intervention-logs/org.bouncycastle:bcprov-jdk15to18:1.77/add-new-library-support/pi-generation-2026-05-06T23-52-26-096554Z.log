alTo(privateKey.getEncoded());\n        assertThat(restoredKey.getParameters().getN()).isEqualTo(privateKey.getParameters().getN());\n        assertThat(restoredKey.getParameters().getH()).isEqualTo(privateKey.getParameters().getH());\n        assertThat(restoredKey.getParams().getOrder()).isEqualTo(privateKey.getParams().getOrder());\n        assertThat(restoredKey.getParams().getCofactor()).isEqualTo(privateKey.getParams().getCofactor());\n    }\n\n    private static BCECGOST3410_2012PrivateKey createPrivateKey() throws Exception {\n        KeyPairGenerator keyPairGenerator = KeyPairGenerator.getInstance(ALGORITHM, new BouncyCastleProvider());\n        keyPairGenerator.initialize(new ECGenParameterSpec(CURVE_NAME), new SecureRandom(new byte[] {1, 2, 3, 4}));\n        KeyPair keyPair = keyPairGenerator.generateKeyPair();\n        assertThat(keyPair.getPrivate()).isInstanceOf(BCECGOST3410_2012PrivateKey.class);\n        return (BCECGOST3410_2012PrivateKey)keyPair.getPrivate();\n    }\n\n    private static byte[] serialize(BCECGOST3410_2012PrivateKey privateKey) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {\n            out.writeObject(privateKey);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static BCECGOST3410_2012PrivateKey deserialize(byte[] serializedKey) throws Exception {\n        try (ObjectInputStream in = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {\n            return (BCECGOST3410_2012PrivateKey)in.readObject();\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778111504410}}
