  package org_bouncycastle.bcprov_jdk15to18;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.math.BigInteger;
  
  import org.bouncycastle.jcajce.provider.asymmetric.ecgost.BCECGOST3410PublicKey;
  import org.bouncycastle.jce.ECGOST3410NamedCurveTable;
  import org.bouncycastle.jce.provider.BouncyCastleProvider;
  import org.bouncycastle.jce.spec.ECNamedCurveParameterSpec;
  import org.bouncycastle.jce.spec.ECPublicKeySpec;
  import org.bouncycastle.math.ec.ECPoint;
  import org.junit.jupiter.api.Test;
  
  public class BCECGOST3410PublicKeyTest {
      private static final BigInteger PRIVATE_VALUE = BigInteger.valueOf(41);
      private static final String CURVE_NAME = "GostR3410-2001-CryptoPro-A";
  
      @Test
      public void serializesAndDeserializesEcGost3410PublicKey() throws Exception {
          BCECGOST3410PublicKey publicKey = createPublicKey();
  
          byte[] serializedKey = serialize(publicKey);
          BCECGOST3410PublicKey restoredKey = deserialize(serializedKey);
  
          assertThat(restoredKey).isEqualTo(publicKey);
          assertThat(restoredKey.hashCode()).isEqualTo(publicKey.hashCode());
          assertThat(restoredKey.getAlgorithm()).isEqualTo("ECGOST3410");
          assertThat(restoredKey.getFormat()).isEqualTo("X.509");
          assertThat(restoredKey.getW()).isEqualTo(publicKey.getW());
          assertThat(restoredKey.getQ()).isEqualTo(publicKey.getQ());
          assertThat(restoredKey.getEncoded()).isEqualTo(publicKey.getEncoded());
          assertThat(restoredKey.getParameters()).isInstanceOf(ECNamedCurveParameterSpec.class);
          assertThat(restoredKey.getParameters().getN()).isEqualTo(publicKey.getParameters().getN());
          assertThat(restoredKey.getParameters().getH()).isEqualTo(publicKey.getParameters().getH());
      }
  
      private static BCECGOST3410PublicKey createPublicKey() {
          ECNamedCurveParameterSpec curveSpec = ECGOST3410NamedCurveTable.getParameterSpec(CURVE_NAME);
          assertThat(curveSpec).isNotNull();
          ECPoint publicPoint = curveSpec.getG().multiply(PRIVATE_VALUE).normalize();
          return new BCECGOST3410PublicKey(
                  new ECPublicKeySpec(publicPoint, curveSpec),
                  BouncyCastleProvider.CONFIGURATION);
      }
  
      private static byte[] serialize(BCECGOST3410PublicKey publicKey) throws Exception {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {
              out.writeObject(publicKey);
          }
          return bytes.toByteArray();
      }
  
      private static BCECGOST3410PublicKey deserialize(byte[] serializedKey) throws Exception {
          try (ObjectInputStream in = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {
              return (BCECGOST3410PublicKey) in.readObject();
          }
      }
  }
