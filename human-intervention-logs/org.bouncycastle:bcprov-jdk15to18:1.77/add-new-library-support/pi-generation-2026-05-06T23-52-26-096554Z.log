[tool-call] delta {"path":"tests/src/org.bouncycastle/bcprov-jdk15to18/1.77/src/test/java/org_bouncycastle/bcprov_jdk15to18/BCECGOST3410_2012PublicKeyTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk15to18;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.security.KeyPair;\nimport java.security.KeyPairGenerator;\nimport java.security.SecureRandom;\nimport java.security.spec.ECGenParameterSpec;\n\nimport org.bouncycastle.jcajce.provider.asymmetric.ecgost12.BCECGOST3410_2012PublicKey;\nimport org.bouncycastle.jce.provider.BouncyCastleProvider;\nimport org.junit.jupiter.api.Test;\n\npublic class BCECGOST3410_2012PublicKeyTest {\n    private static final String ALGORITHM = \"ECGOST3410-2012\";\n    private static final String CURVE_NAME = \"Tc26-Gost-3410-12-256-paramSetA\";\n\n    @Test\n    public void serializesAndDeserializesEcGost34102012PublicKey() throws Exception {\n        BCECGOST3410_2012PublicKey publicKey = createPublicKey();\n\n        byte[] serializedKey = serialize(publicKey);\n        BCECGOST3410_2012PublicKey restoredKey = deserialize(serializedKey);\n\n        assertThat(restoredKey).isEqualTo(publicKey);\n        assertThat(restoredKey.hashCode()).isEqualTo(publicKey.hashCode());\n        assertThat(restoredKey.getAlgorithm()).isEqualTo(ALGORITHM);\n        assertThat(restoredKey.getFormat()).isEqualTo(\"X.509\");\n        assertThat(restoredKey.getW()).isEqualTo(publicKey.getW());\n        assertThat(restoredKey.getQ()).isEqualTo(publicKey.getQ());\n        assertThat(restoredKey.getEncoded()).isEqualTo(publicKey.getEncoded());\n        assertThat(restoredKey.getGostParams().getPublicKeyParamSet())\n                .isEqualTo(publicKey.getGostParams().getPublicKeyParamSet());\n        assertThat(restoredKey.getGostParams().getDigestParamSet())\n                .isEqualTo(publicKey.getGostParams().getDigestParamSet());\n        assertThat(restoredKey.getParameters().getN()).isEqualTo(publicKey.getParameters().getN());\n        assertThat(restoredKey.getParameters().getH()).isEqualTo(publicKey.getParameters().getH());\n        assertThat(restoredKey.getParams().getOrder()).isEqualTo(publicKey.getParams().getOrder());\n        assertThat(restoredKey.getParams().getCofactor()).isEqualTo(publicKey.getParams().getCofactor());\n    }\n\n    private static BCECGOST3410_2012PublicKey createPublicKey() throws Exception {\n        KeyPairGenerator keyPairGenerator = KeyPairGenerator.getInstance(ALGORITHM, new BouncyCastleProvider());\n        keyPairGenerator.initialize(new ECGenParameterSpec(CURVE_NAME), new SecureRandom(new byte[] {1, 2, 3, 4}));\n        KeyPair keyPair = keyPairGenerator.generateKeyPair();\n        assertThat(keyPair.getPublic()).isInstanceOf(BCECGOST3410_2012PublicKey.class);\n        return (BCECGOST3410_2012PublicKey)keyPair.getPublic();\n    }\n\n    private static byte[] serialize(BCECGOST3410_2012PublicKey publicKey) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {\n            out.writeObject(publicKey);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static BCECGOST3410_2012PublicKey deserialize(byte[] serializedKey) throws Exception {\n        try (ObjectInputStream in = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {\n            return (BCECGOST3410_2012PublicKey)in.readObject();\n        }\n    }\n}\n"}
