                          ((DSAPrivateKeyParameters)params).getParameters().getG()));
              }
              else
              {
                  throw new IllegalArgumentException("openssh private key is not dsa privare key");
              }
  
          }
  
          return super.engineGeneratePrivate(keySpec);
      }
  
