    Ed448PrivateKeyParameters parameters = new Ed448PrivateKeyParameters(\n                createSeed(Ed448PrivateKeyParameters.KEY_SIZE));\n        PrivateKeyInfo keyInfo = PrivateKeyInfoFactory.createPrivateKeyInfo(parameters);\n        return generatePrivateKey(\"Ed448\", keyInfo);\n    }\n\n    private static BCEdDSAPrivateKey generatePrivateKey(String algorithm, PrivateKeyInfo keyInfo) throws Exception {\n        KeyFactory keyFactory = KeyFactory.getInstance(algorithm, PROVIDER);\n        PrivateKey privateKey = keyFactory.generatePrivate(new PKCS8EncodedKeySpec(keyInfo.getEncoded()));\n        assertThat(privateKey).isInstanceOf(BCEdDSAPrivateKey.class);\n        return (BCEdDSAPrivateKey) privateKey;\n    }\n\n    private static void assertRestoredKey(\n            BCEdDSAPrivateKey restoredKey,\n            BCEdDSAPrivateKey privateKey,\n            String algorithm) {\n        assertThat(restoredKey).isEqualTo(privateKey);\n        assertThat(restoredKey.hashCode()).isEqualTo(privateKey.hashCode());\n        assertThat(restoredKey.getAlgorithm()).isEqualTo(algorithm);\n        assertThat(restoredKey.getFormat()).isEqualTo(\"PKCS#8\");\n        assertThat(restoredKey.getEncoded()).isEqualTo(privateKey.getEncoded());\n        assertThat(restoredKey.getPublicKey().getAlgorithm()).isEqualTo(algorithm);\n        assertThat(restoredKey.toString()).contains(algorithm);\n    }\n\n    private static byte[] createSeed(int size) {\n        byte[] seed = new byte[size];\n        for (int index = 0; index < seed.length; index++) {\n            seed[index] = (byte) (index + 1);\n        }\n        return seed;\n    }\n\n    private static byte[] serialize(BCEdDSAPrivateKey privateKey) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {\n            out.writeObject(privateKey);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static BCEdDSAPriva