[tool-call] delta {"path":"tests/src/org.bouncycastle/bcprov-jdk15to18/1.77/src/test/java/org_bouncycastle/bcprov_jdk15to18/BCXDHPrivateKeyTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk15to18;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.security.KeyPairGenerator;\nimport java.security.PrivateKey;\nimport java.security.Provider;\nimport java.security.SecureRandom;\n\nimport org.bouncycastle.jcajce.provider.asymmetric.edec.BCXDHPrivateKey;\nimport org.bouncycastle.jce.provider.BouncyCastleProvider;\nimport org.junit.jupiter.api.Test;\n\npublic class BCXDHPrivateKeyTest {\n    private static final Provider PROVIDER = new BouncyCastleProvider();\n    private static final byte[] RANDOM_SEED = new byte[] {8, 7, 6, 5, 4, 3, 2, 1};\n\n    @Test\n    public void serializesAndDeserializesX25519PrivateKey() throws Exception {\n        BCXDHPrivateKey privateKey = createPrivateKey(\"X25519\", 256);\n\n        byte[] serializedKey = serialize(privateKey);\n        BCXDHPrivateKey restoredKey = deserialize(serializedKey);\n\n        assertRestoredKey(restoredKey, privateKey, \"X25519\");\n    }\n\n    @Test\n    public void serializesAndDeserializesX448PrivateKey() throws Exception {\n        BCXDHPrivateKey privateKey = createPrivateKey(\"X448\", 448);\n\n        byte[] serializedKey = serialize(privateKey);\n        BCXDHPrivateKey restoredKey = deserialize(serializedKey);\n\n        assertRestoredKey(restoredKey, privateKey, \"X448\");\n    }\n\n    private static BCXDHPrivateKey createPrivateKey(String algorithm, int strength) throws Exception {\n        KeyPairGenerator keyPairGenerator = KeyPairGenerator.getInstance(algorithm, PROVIDER);\n        keyPairGenerator.initialize(strength, new SecureRandom(RANDOM_SEED));\n        PrivateKey privateKey = keyPairGenerator.generateKeyPair().getPrivate();\n        assertThat(privateKey).isInstanceOf(BCXDHPrivateKey.class);\n        return (BCXDHPrivateKey) privateKey;\n    }\n\n    private static void assertRestoredKey(\n            BCXDHPrivateKey restoredKey,\n            BCXDHPrivateKey privateKey,\n            String algorithm) {\n        assertThat(restoredKey).isEqualTo(privateKey);\n        assertThat(restoredKey.hashCode()).isEqualTo(privateKey.hashCode());\n        assertThat(restoredKey.getAlgorithm()).isEqualTo(algorithm);\n        assertThat(restoredKey.getFormat()).isEqualTo(\"PKCS#8\");\n        assertThat(restoredKey.getEncoded()).isEqualTo(privateKey.getEncoded());\n        assertThat(restoredKey.getPublicKey().getAlgorithm()).isEqualTo(algorithm);\n        assertThat(restoredKey.toString()).contains(algorithm);\n    }\n\n    private static byte[] serialize(BCXDHPrivateKey privateKey) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {\n            out.writeObject(privateKey);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static BCXDHPrivateKey deserialize(byte[] serializedKey) throws Exception {\n        try (ObjectInputStream in = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {\n            return (BCXDHPrivateKey) in.readObject();\n        }\n    }\n}\n"}
