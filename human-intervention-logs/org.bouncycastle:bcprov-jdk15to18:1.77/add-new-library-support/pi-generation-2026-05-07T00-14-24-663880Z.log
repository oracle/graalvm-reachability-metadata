          BCEdDSAPrivateKey restoredKey = deserialize(serializedKey);
  
          assertRestoredKey(restoredKey, privateKey, "Ed25519");
      }
  
      @Test
      public void serializesAndDeserializesEd448PrivateKey() throws Exception {
          BCEdDSAPrivateKey privateKey = createEd448PrivateKey();
  
          byte[] serializedKey = serialize(privateKey);
          BCEdDSAPrivateKey restoredKey = deserialize(serializedKey);
  
          assertRestoredKey(restoredKey, privateKey, "Ed448");
      }
  
      private static BCEdDSAPrivateKey createEd25519PrivateKey() throws Exception {
          Ed25519PrivateKeyParameters parameters = new Ed25519PrivateKeyParameters(
                  createSeed(Ed25519PrivateKeyParameters.KEY_SIZE));
          PrivateKeyInfo keyInfo = PrivateKeyInfoFactory.createPrivateKeyInfo(parameters);
