ouncyCastleProvider;\\nimport org.junit.jupiter.api.Test;\\n\\npublic class BaseBlockCipherInnerAEADGenericBlockCipherTest {\\n    private static final byte[] KEY_BYTES = new byte[] {\\n        0x00, 0x01, 0x02, 0x03,\\n        0x04, 0x05, 0x06, 0x07,\\n        0x08, 0x09, 0x0a, 0x0b,\\n        0x0c, 0x0d, 0x0e, 0x0f\\n    };\\n    private static final byte[] NONCE = new byte[] {\\n        0x10, 0x11, 0x12, 0x13,\\n        0x14, 0x15, 0x16, 0x17,\\n        0x18, 0x19, 0x1a, 0x1b\\n    };\\n    private static final byte[] AAD = \\\"associated-data\\\".getBytes(StandardCharsets.UTF_8);\\n    private static final byte[] PLAINTEXT = \\\"authenticated message\\\".getBytes(StandardCharsets.UTF_8);\\n\\n    @Test\\n    public void throwsJdkAeadBadTagExceptionWhenGcmAuthenticationFails() throws Exception {\\n        Provider provider = new BouncyCastleProvider();\\n        SecretKey key = new SecretKeySpec(KEY_BYTES, \\\"AES\\\");\\n        GCMParameterSpec parameters = new GCMParameterSpec(128, NONCE);\\n\\n        Cipher encryptCipher = Cipher.getInstance(\\\"AES/GCM/NoPadding\\\", provider);\\n        encryptCipher.init(Cipher.ENCRYPT_MODE, key, parameters);\\n        encryptCipher.updateAAD(AAD);\\n        byte[] ciphertext = encryptCipher.doFinal(PLAINTEXT);\\n\\n        byte[] tamperedCiphertext = Arrays.copyOf(ciphertext, ciphertext.length);\\n        tamperedCiphertext[tamperedCiphertext.length - 1] ^= 0x01;\\n\\n        Cipher decryptCipher = Cipher.getInstance(\\\"AES/GCM/NoPadding\\\", provider);\\n        decryptCipher.init(Cipher.DECRYPT_MODE, key, parameters);\\n        decryptCipher.updateAAD(AAD);\\n\\n        assertThatThrownBy(() -> decryptCipher.doFinal(tamperedCiphertext))\\n            .isInstanceOf(AEADBadTagException.class)\\n            .hasMessageContaining(\\\"mac check\\\");\\n\\n        assertThat(tamperedCiphertext).isNotEqualTo(ciphertext);\\n    }\\n}\\n\",\"exit_code\":0,\"status\":\"completed\"}}\n{\"type\":\"item.started\",\"item\":{\"id\":