 = 0x74;\\n    private static final int TC_BLOCKDATA = 0x77;\\n    private static final int TC_ENDBLOCKDATA = 0x78;\\n    private static final int TC_NULL = 0x70;\\n    private static final int SC_WRITE_METHOD = 0x01;\\n    private static final int SC_SERIALIZABLE = 0x02;\\n\\n    private static final BigInteger PRIVATE_VALUE = BigInteger.valueOf(11);\\n    private static final BigInteger PRIME = BigInteger.valueOf(23);\\n    private static final BigInteger GENERATOR = BigInteger.valueOf(5);\\n    private static final int PRIVATE_VALUE_LENGTH = 5;\\n\\n    @Test\\n    public void serializesAndDeserializesDiffieHellmanPrivateKey() throws Exception {\\n        JCEDHPrivateKey privateKey = deserialize(createSerializedPrivateKey());\\n\\n        assertPrivateKey(privateKey);\\n\\n        byte[] serializedKey = serialize(privateKey);\\n        JCEDHPrivateKey restoredKey = deserialize(serializedKey);\\n\\n        assertPrivateKey(restoredKey);\\n        assertThat(restoredKey.getEncoded()).isEqualTo(privateKey.getEncoded());\\n    }\\n\\n    private static byte[] createSerializedPrivateKey() throws Exception {\\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\\n        DataOutputStream out = new DataOutputStream(bytes);\\n\\n        out.writeShort(STREAM_MAGIC);\\n        out.writeShort(STREAM_VERSION);\\n        out.writeByte(TC_OBJECT);\\n        writeClassDescription(out);\\n        writeSerializedObject(out, PRIVATE_VALUE);\\n        writeSerializedObject(out, PRIME);\\n        writeSerializedObject(out, GENERATOR);\\n        out.writeByte(TC_BLOCKDATA);\\n        out.writeByte(Integer.BYTES);\\n        out.writeInt(PRIVATE_VALUE_LENGTH);\\n        out.writeByte(TC_ENDBLOCKDATA);\\n        out.flush();\\n\\n        return bytes.toByteArray();\\n    }\\n\\n    private static void writeClassDescription(DataOutputStream out) throws Exception {\\n        ObjectStreamClass streamClass = ObjectStreamClass.lookup(JCEDHPrivateKey.class);\\n\\n        out.writeByte(TC_CLASSDESC);\\n        out.writeUTF(JCEDHPrivateKey.class.getName());\\n        out.writeLong(streamClass.getSerialVersionUID());\\n        out.writeByte(SC_WRITE_METHOD | SC_SERIALIZABLE);\\n        ObjectStreamField[] fields = streamClass.getFields();\\n        out.writeShort(fields.length);\\n        for (ObjectStreamField field : fields) {\\n            out.writeByte(field.getTypeCode());\\n            out.writeUTF(field.getName());\\n            String typeString = field.getTypeString();\\n            if (typeString != null) {\\n                out.writeByte(TC_STRING);\\n                out.writeUTF(typeString);\\n            }\\n        }\\n        out.writeByte(TC_ENDBLOCKDATA);\\n        out.writeByte(TC_NULL);\\n    }\\n\\n    private static void writeSerializedObject(DataOutputStream out, Object value) throws Exception {\\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\\n        try (ObjectOutputStream objectOut = new ObjectOutputStream(bytes)) {\\n            objectOut.writeObject(value);\\n        }\\n        byte[] serializedObject = bytes.toByteArray();\\n        out.write(serializedObject, 4, serializedObject.length - 4);\\n    }\\n\\n    private static byte[] serialize(JCEDHPrivateKey privateKey) throws Exception {\\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\\n        try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {\\n            out.writeObject(privateKey);\\n        }\\n        return bytes.toByteArray();\\n    }\\n\\n    private static JCEDHPrivateKey deserialize(byte[] serializedKey) throws Exception {\\n        try (ObjectInputStream in = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {\\n            return (JCEDHPrivateKey) in.readObject();\\n        }\\n    }\\n\\n    private static void assertPrivateKey(JCEDHPrivateKey privateKey) {\\n        assertThat(privateKey.getAlgorithm()).isEqualTo(\\\"DH\\\");\\n        assertThat(privateKey.getFormat()).isEqualTo