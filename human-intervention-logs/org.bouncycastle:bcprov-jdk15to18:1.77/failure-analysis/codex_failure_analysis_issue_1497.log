 work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage org_bouncycastle.bcprov_jdk15to18;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\n\\nimport java.io.ByteArrayInputStream;\\nimport java.io.ByteArrayOutputStream;\\nimport java.io.ObjectInputStream;\\nimport java.io.ObjectOutputStream;\\nimport java.math.BigInteger;\\n\\nimport javax.crypto.spec.DHParameterSpec;\\n\\nimport org.bouncycastle.asn1.ASN1Encoding;\\nimport org.bouncycastle.asn1.ASN1Integer;\\nimport org.bouncycastle.asn1.pkcs.DHParameter;\\nimport org.bouncycastle.asn1.pkcs.PKCSObjectIdentifiers;\\nimport org.bouncycastle.asn1.pkcs.PrivateKeyInfo;\\nimport org.bouncycastle.asn1.x509.AlgorithmIdentifier;\\nimport org.bouncycastle.jcajce.provider.asymmetric.dh.BCDHPrivateKey;\\nimport org.junit.jupiter.api.Test;\\n\\npublic class BCDHPrivateKeyTest {\\n    private static final BigInteger PRIVATE_VALUE = BigInteger.valueOf(11);\\n    private static final BigInteger PRIME = BigInteger.valueOf(23);\\n    private static final BigInteger GENERATOR = BigInteger.valueOf(5);\\n    private static final int PRIVATE_VALUE_LENGTH = 5;\\n\\n    @Test\\n    public void serializesAndDeserializesDiffieHellmanPrivateKey() throws Exception {\\n        BCDHPrivateKey privateKey = createPrivateKey();\\n\\n        byte[] serializedKey = serialize(privateKey);\\n        BCDHPrivateKey restoredKey = deserialize(serializedKey);\\n\\n        assertThat(restoredKey).isEqualTo(privateKey);\\n        assertThat(restoredKey.getAlgorithm()).isEqualTo(\\\"DH\\\");\\n        assertThat(restoredKey.getFormat()).isEqualTo(\\\"PKCS#8\\\");\\n        assertThat(restoredKey.getX()).isEqualTo(PRIVATE_VALUE);\\n        assertThat(restoredKey.getParams().getP()).isEqualTo(PRIME);\\n        assertThat(restoredKey.getParams().getG()).isEqualTo(GENERATOR);\\n        assertThat(restoredKey.getParams().getL()).isEqualTo(PRIVATE_VALUE_LENGTH);\\n        assertThat(restoredKey.getEncoded()).isEqualTo(privateKey.getEncoded());\\n    }\\n\\n    private static BCDHPrivateKey createPrivateKey() throws Exception {\\n        DHParameterSpec parameters = new DHParameterSpec(PRIME, GENERATOR, PRIVATE_VALUE_LENGTH);\\n        AlgorithmIdentifier algorithmIdentifier = new AlgorithmIdentifier(\\n                PKCSObjectIdentifiers.dhKeyAgreement,\\n                new DHParameter(parameters.getP(), parameters.getG(), parameters.getL()).toASN1Primitive());\\n        PrivateKeyInfo privateKeyInfo = new PrivateKeyInfo(algorithmIdentifier, new ASN1Integer(PRIVATE_VALUE));\\n        return new BCDHPrivateKey(PrivateKeyInfo.getInstance(privateKeyInfo.getEncoded(ASN1Encoding.DER)));\\n    }\\n\\n    private static byte[] serialize(BCDHPrivateKey privateKey) throws Exception {\\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\\n        try (ObjectOutputStream out = new ObjectOutputStream(bytes)) {\\n            out.writeObject(privateKey);\\n        }\\n        return bytes.toByteArray();\\n    }\\n\\n    private static BCDHPrivateKey deserialize(byte[] serializedKey) throws Exception {\\n        try (ObjectInputStream in = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {\\n            return (BCDHPrivateKey) in.readObject();\\n        }\\n    }\\n}\\n\"}], \"isError\": false, \"timestamp\": 1778107944583}]}\nhuman-intervention-logs/org.bouncycastle:bcprov-jdk15to18:1.77/add-new-library-support/pi-generation-2026-05-06T22-52-46-419942Z.log:946:[recv] {\"type\": \"message_end\", \"message\": {\"role\": \"assistant\", \"content\": [{\"type\": \"thinking\", \"thinking\": \"\", \"thinkingSignature\": \"{\\\"id\\\":\\\"rs_0f9b2d6accb292e20169fbc62d0f7c81a389abc9fa8156b0a4\\\",\\\"type\\\":\\\"reasoning\\\",\\\"encrypted_content\\\":\\\"gAAAAABp-8Yw-gZoFNuDEqh9HGjBthmPR4aEytx4DMZedvbu2Qn7seNG8rndxTHXGfwTUnJ2xtUJOdIEwyM17oEpQnQrUSfVImDQC23JKCHgipJif5ZNlhtlwmWmAaKoH5uNrOINTrrWNp5xzU8PCxME5woxChR226VP3ogLwn-IhHxg_zPHkCVgteL5y38h5hutDJ7rDGz9OSw8PlM-nn