src/test/java/org_jboss_logmanager/jboss_logmanager/Formatters12Test.java:185:                java.util.logging.LogRecord record = new java.util.logging.LogRecord(Level.SEVERE, \"coverage\");\n../2369-09df0baa/tests/src/org.apache.tomcat/tomcat-juli/10.1.7/src/test/java/org_apache_tomcat/tomcat_juli/LogFactoryTest.java:21:        Log log = LogFactory.getLog(\"coverage.service-loaded-log\");\n../2369-09df0baa/tests/src/org.apache.tomcat/tomcat-juli/10.1.7/src/test/java/org_apache_tomcat/tomcat_juli/LogFactoryTest.java:24:        assertThat(((ServiceLoadedLog) log).getName()).isEqualTo(\"coverage.service-loaded-log\");\n../2369-09df0baa/tests/src/org.apache.tomcat/tomcat-juli/10.1.7/src/test/java/org_apache_tomcat/tomcat_juli/ClassLoaderLogManagerTest.java:152:            return \"coverage-webapp\";\n../2369-09df0baa/tests/src/org.apache.tomcat/tomcat-juli/10.1.7/src/test/java/org_apache_tomcat/tomcat_juli/ClassLoaderLogManagerTest.java:162:            return \"coverage-service\";\n../2369-09df0baa/tests/src/org.apache.tomcat/tomcat-juli/10.1.7/src/test/java/org_apache_tomcat/tomcat_juli/FileHandlerTest.java:43:        FileHandler handler = new FileHandler(logDirectory.toString(), \"coverage-\", \".log\", 0, false, -1);\n../2369-09df0baa/tests/src/org.apache.tomcat/tomcat-juli/10.1.7/src/test/java/org_apache_tomcat/tomcat_juli/FileHandlerTest.java:56:            assertThat(Files.readString(logDirectory.resolve(\"coverage-.log\")))\n../2369-09df0baa/tests/src/org.apache.tomcat/tomcat-juli/10.1.7/src/test/java/org_apache_tomcat/tomcat_juli/DirectJDKLogTest.java:34:            Log log = LogFactory.getLog(\"coverage.direct-jdk-log\");\n../2369-09df0baa/tests/src/org.apache.tomcat/tomcat-juli/10.1.7/src/test/java/org_apache_tomcat/tomcat_juli/DirectJDKLogTest.java:45:        String loggerName = \"coverage.direct-jdk-log\";\n../2574-8f806a45/tests/src/org.lz4/lz4-java/1.8.0/src/test/java/org_lz4/lz4_java/NativeTest.java:30:                + \"lz4 native library loading coverage\")\n../2574-8f806a45/tests/src/org.lz4/lz4-java/1.8.0/src/test/java/org_lz4/lz4_java/LZ4FactoryTest.java:38:                + \"lz4 factory dynamic access coverage\")\n../2574-8f806a45/tests/src/org.lz4/lz4-java/1.8.0/src/test/java/org_lz4/lz4_java/XXHashFactoryTest.java:36:                + \"xxhash factory dynamic access coverage\")\n../2574-8f806a45/tests/src/org.immutables/value/2.8.2/src/test/java/org_immutables/value/$ThrowablesTest.java:57:            return \"coverage\".substring(beginIndex, endIndex);\n../2574-8f806a45/tests/src/org.immutables/value/2.8.6/src/test/java/org_immutables/value/$ThrowablesTest.java:57:            return \"coverage\".substring(beginIndex, endIndex);\n../2574-8f806a45/COVERAGE.md:3:![Coverage over time](https://raw.githubusercontent.com/oracle/graalvm-reachability-metadata/stats/coverage/latest/metrics-over-time.svg)\n../2574-8f806a45/gradlew:195:        # iterations, nor the values presented in `arg`.\n../2574-8f806a45/skills/review-fixes-java-run-fail/SKILL.md:3:description: Review pull requests with the `fixes-java-run-fail` label in graalvm-reachability-metadata. Use when asked to review or triage a PR described as `fixes-java-run-fail` or one that fixes Java/JVM runtime test failures for an existing library version update. Focus on validating the Java runtime fix, keeping the diff scoped, and ensuring dynamic-access coverage does not drop between the previously tested version and the new version.\n../2574-8f806a45/skills/review-fixes-java-run-fail/SKILL.md:9:These PRs repair tests, dependencies, or narrow runtime setup after an existing library version compiles, but the JVM-based test fails when it runs. Review them more lightly than `library-new-request` PRs: the library already exists, so the goal is to restore Java runtime behavior for the new version while preserving meaningful test and dynamic-access coverage.\n../2574-8f806a45/skills/review-fixes-java-run-fail/SKILL.md:17:- Be more relaxed than `library-new-request`: do not reject only because a test resembles older coverage, stays in an existing package layout, or contains compatibility branches for multiple supported versions.\n../2574-8f806a45/skills/review-fixes-java-run-fail/SKILL.md:18:- Do not accept changes that remove meaningful test coverage just to make `java` pass.\n../2574-8f806a45/skills/review-fixes-java-run-fail/SKILL.md:19:- Treat dynamic-access coverage preservation as the main quality gate. The new version should not report lower dynamic-access coverage than the previously tested version unless the PR gives a concrete, credible reason.\n../2574-8f806a45/skills/review-fixes-java-run-fail/SKILL.md:51:4. Check dynamic-access coverage across versions.\n../2574-8f806a45/skills/review-fixes-java-run-fail/SKILL.md:53:   - Compare `dynamicAccess.coverageRatio`, `coveredCalls`, `totalCalls`, and the `dynamicAccess.breakdown` entries for reflection, resources, proxies, serialization, JNI, or any other present report type.\n../2574-8f806a45/skills/review-fixes-java-run-fail/SKILL.md:54:   - A lower `coverageRatio` or lower `coveredCalls` for the new version is blocking unless the total dynamic-access surface changed and the PR explains why the reduction is expected.\n../2574-8f806a45/skills/review-fixes-java-run-fail/SKILL.md:55:   - If `totalCalls` increases while `coveredCalls` stays flat or the ratio drops, ask for additional test coverage or metadata unless the uncovered calls are clearly outside the library behavior under test.\n../2574-8f806a45/skills/review-fixes-java-run-fail/SKILL.md:62:   - Treat a large drop as blocking or at least requiring explanation when the tests and dynamic-access stats still claim comparable coverage.\n../2574-8f806a45/skills/review-fixes-java-run-fail/SKILL.md:68:   - Prefer seeing the full target `test` lane green because a Java runtime fix can still reduce native-image coverage.\n../2574-8f806a45/skills/review-fixes-java-run-fail/SKILL.md:70:   - If CI is flaky but the diff and coverage comparison are sound, ask for a rerun instead of blocking on speculation.\n../2574-8f806a45/skills/review-fixes-java-run-fail/SKILL.md:78:- Dynamic-access coverage does not drop between the previous and new tested versions, or any apparent drop is convincingly explained by a changed upstream API/runtime surface.\n../2574-8f806a45/skills/review-fixes-java-run-fail/SKILL.md:85:- Dynamic-access coverage drops without a credible explanation and replacement coverage.\n../2574-8f806a45/skills/review-fixes-java-run-fail/SKILL.md:93:- The API or runtime behavior change is plausible but the PR does not explain why a coverage drop is expected.\n../2574-8f806a45/skills/review-fixes-java-run-fail/SKILL.md:100:- For coverage drops: say that dynamic-access coverage must not regress between tested versions, cite the old and new values, and ask for either restored coverage or a concrete explanation.\n../2574-8f806a45/skills/review-fixes-java-run-fail/SKILL.md:102:- For deleted or bypassed coverage: say that the PR fixes Java runtime execution by removing coverage and should instead adapt the test to the new runtime behavior.\n../2574-8f806a45/skills/review-fixes-native-image-run-fail/SKILL.md:3:description: Review pull requests with the `fixes-native-image-run-fail` label in graalvm-reachability-metadata. Use when asked to review or triage a PR that fixes a native-image runtime failure for an existing library version update. Focus on validating the runtime/native fix, keeping the diff scoped, and ensuring dynamic-access coverage does not drop between the previously tested version and the new version.\n../2574-8f806a45/skills/review-fixes-native-image-run-fail/SKILL.md:9:These PRs repair metadata or tests after an existing library version compiles and builds a native image, but the native image fails when the test runs. Review them more lightly than `library-new-request` PRs: the library is already supported, so the goal is to restore native-image behavior for a newer version while preserving existing dynamic-access coverage.\n../2574-8f806a45/skills/review-fixes-native-image-run-fail/SKILL.md:19:- Treat dynamic-access coverage preservation as the main quality gate. The new version should not report lower dynamic-access coverage than the previously tested version unless the PR gives a concrete, credible reason.\n../2574-8f806a45/skills/review-fixes-native-image-run-fail/SKILL.md:50:4. Check dynamic-access coverage across versions.\n../2574-8f806a45/skills/review-fixes-native-image-run-fail/SKILL.md:52:   - Compare `dynamicAccess.coverageRatio`, `coveredCalls`, `totalCalls`, and the `dynamicAccess.breakdown` entries for reflection, resources, proxies, serialization, JNI, or any other present report type.\n../2574-8f806a45/skills/review-fixes-native-image-run-fail/SKILL.md:53:   - A lower `coverageRatio` or lower `coveredCalls` for the new version is blocking unless the total dynamic-access surface changed and the PR explains why the reduction is expected.\n../2574-8f806a45/skills/review-fixes-native-image-run-fail/SKILL.md:54:   - If metadata fixes make the native run pass but the dynamic-access ratio drops, ask for restored coverage first. Passing native execution is not enough by itself.\n../2574-8f806a45/skills/review-fixes-native-image-run-fail/SKILL.md:55:   - If `totalCalls` increases while `coveredCalls` stays flat or the ratio drops, ask for additional test coverage or metadata unless the uncovered calls are clearly outside the library behavior under test.\n../2574-8f806a45/skills/review-fixes-native-image-run-fail/SKILL.md:62:   - Treat a large drop as blocking or at least requiring explanation when the tests and dynamic-access stats still claim comparable coverage.\n../2574-8f806a45/skills/review-fixes-native-image-run-fail/SKILL.md:69:   - If CI is flaky but the diff and coverage comparison are sound, ask for a rerun instead of blocking on speculation.\n../2574-8f806a45/skills/review-fixes-native-image-run-fail/SKILL.md:77:- Dynamic-access coverage does not drop between the previous and new tested versions, or any apparent drop is convincingly explained by a changed upstream API surface.\n../2574-8f806a45/skills/review-fixes-native-image-run-fail/SKILL.md:83:- The fix makes native execution pass by skipping the failing native path, disabling assertions, or removing coverage.\n../2574-8f806a45/skills/review-fixes-native-image-run-fail/SKILL.md:84:- Dynamic-access coverage drops without a credible explanation and replacement coverage.\n../2574-8f806a45/skills/review-fixes-native-image-run-fail/SKILL.md:93:- The API or native runtime change is plausible but the PR does not explain why a coverage drop is expected.\n../2574-8f806a45/skills/review-fixes-native-image-run-fail/SKILL.md:100:- For coverage drops: say that dynamic-access coverage must not regress between tested versions, cite the old and new values, and ask for either restored coverage or a concrete explanation.\n../2574-8f806a45/skills/review-fixes-native-image-run-fail/SKILL.md:102:- For native skips: say that the PR avoids the failing native path instead of fixing it, so it does not demonstrate native-image runtime coverage.\n../2574-8f806a45/skills/review-library-new-request/SKILL.md:19:- Do not accept tests that disable themselves under native image. If the added library behavior is guarded by checks such as `assumeFalse(\"runtime\".equals(System.getProperty(\"org.graalvm.nativeimage.imagecode\")))`, `if (!\"runtime\".equals(System.getProperty(\"org.graalvm.nativeimage.imagecode\")))`, or a similar native-only skip, then the PR does not provide native runtime coverage.\n../2574-8f806a45/skills/review-library-new-request/SKILL.md:21:- Require at least 50% reported dynamic-access coverage when there are dynamic-access calls to cover. Use the exploded stats files under `stats/<group>/<artifact>/<metadata-version>/stats.json` when available, and block the PR when dynamic-access coverage is below 50% or the PR provides no credible dynamic-access coverage evidence for non-zero dynamic-access calls.\n../2574-8f806a45/skills/review-library-new-request/SKILL.md:22:- Treat dynamic-access coverage counts as a minimum gate, not complete metadata evidence. They can miss metadata required through downstream libraries, so do not use high coverage alone to prove that the submitted metadata is complete or necessary.\n../2574-8f806a45/skills/review-library-new-request/SKILL.md:23:- Treat `0/0` dynamic-access coverage as a valid no-calls case, not as failed coverage. Do not reject a PR only because the exploded stats report `0/0` dynamic-access calls while the PR adds metadata; those stats can miss metadata required through downstream libraries.\n../2574-8f806a45/skills/review-library-new-request/SKILL.md:56:5. Compare the PR claims, test, and reported coverage as one unit.\n../2574-8f806a45/skills/review-library-new-request/SKILL.md:57:   - If the PR claims specific coverage numbers that do not line up with the diff, ask for investigation.\n../2574-8f806a45/skills/review-library-new-request/SKILL.md:58:   - Confirm reported dynamic-access coverage is at least 50% when the stats include dynamic-access calls.\n../2574-8f806a45/skills/review-library-new-request/SKILL.md:61:   - If the stats report less than 50% coverage for non-zero dynamic-access calls, or no usable coverage signal for claimed dynamic-access behavior, ask for stronger tests or refreshed coverage evidence.\n../2574-8f806a45/skills/review-library-new-request/SKILL.md:83:  - Reported dynamic-access coverage is below 50% for non-zero dynamic-access calls, absent for claimed dynamic-access behavior, or not credible from the diff.\n../2574-8f806a45/skills/review-library-new-request/SKILL.md:90:- For missing native runtime coverage: say that the added tests disable themselves under native image, so the library behavior never runs there and the PR does not provide native-image coverage.\n../2574-8f806a45/skills/review-library-new-request/SKILL.md:93:- For insufficient dynamic-access coverage: say that new-library PRs need at least 50% dynamic-access coverage when there are dynamic-access calls to cover, and ask for stronger tests or refreshed coverage evidence.\n../2574-8f806a45/skills/review-library-new-request/SKILL.md:94:- For metadata/coverage mismatch: ask for investigation only when the PR makes concrete coverage claims that are not supported by the diff, or when reported dynamic-access coverage is below the 50% minimum for non-zero dynamic-access calls. Do not argue from metadata contents alone.\n../2574-8f806a45/skills/review-fixes-javac-fail/SKILL.md:3:description: Review pull requests with the `fixes-javac-fail` label in graalvm-reachability-metadata. Use when asked to review or triage a PR that fixes Java compilation failures for an existing library version update. Focus on validating the compile fix, keeping the diff scoped, and ensuring dynamic-access coverage does not drop between the previously tested version and the new version.\n../2574-8f806a45/skills/review-fixes-javac-fail/SKILL.md:9:These PRs repair test sources or test dependencies after an existing library is bumped and the new version no longer compiles with the old test code. Review them more lightly than `library-new-request` PRs: the library already exists, so the goal is to preserve working coverage across the version update rather than prove a brand-new metadata contribution from scratch.\n../2574-8f806a45/skills/review-fixes-javac-fail/SKILL.md:17:- Be more relaxed than `library-new-request`: do not reject only because a test resembles older coverage, stays in an existing package layout, or contains compatibility branches for multiple supported versions.\n../2574-8f806a45/skills/review-fixes-javac-fail/SKILL.md:18:- Do not accept changes that remove meaningful test coverage just to make `javac` pass.\n../2574-8f806a45/skills/review-fixes-javac-fail/SKILL.md:19:- Treat dynamic-access coverage preservation as the main quality gate. The new version should not report lower dynamic-access coverage than the previously tested version unless the PR gives a concrete, credible reason.\n../2574-8f806a45/skills/review-fixes-javac-fail/SKILL.md:49:4. Check dynamic-access coverage across versions.\n../2574-8f806a45/skills/review-fixes-javac-fail/SKILL.md:51:   - Compare `dynamicAccess.coverageRatio`, `coveredCalls`, `totalCalls`, and the `dynamicAccess.breakdown` entries for reflection, resources, proxies, serialization, JNI, or any other present report type.\n../2574-8f806a45/skills/review-fixes-javac-fail/SKILL.md:52:   - A lower `coverageRatio` or lower `coveredCalls` for the new version is blocking unless the total dynamic-access surface changed and the PR explains why the reduction is expected.\n../2574-8f806a45/skills/review-fixes-javac-fail/SKILL.md:53:   - If `totalCalls` increases while `coveredCalls` stays flat or the ratio drops, ask for additional test coverage or metadata unless the uncovered calls are clearly outside the library behavior under test.\n../2574-8f806a45/skills/review-fixes-javac-fail/SKILL.md:60:   - Treat a large drop as blocking or at least requiring explanation when the tests and dynamic-access stats still claim comparable coverage.\n../2574-8f806a45/skills/review-fixes-javac-fail/SKILL.md:65:   - Prefer seeing the full target `test` lane green because a compile fix can still reduce runtime or native coverage.\n../2574-8f806a45/skills/review-fixes-javac-fail/SKILL.md:67:   - If CI is flaky but the diff and coverage comparison are sound, ask for a rerun instead of blocking on speculation.\n../2574-8f806a45/skills/review-fixes-javac-fail/SKILL.md:75:- Dynamic-access coverage does not drop between the previous and new tested versions, or any apparent drop is convincingly explained by a changed upstream API surface.\n../2574-8f806a45/skills/review-fixes-javac-fail/SKILL.md:81:- The fix makes compilation pass by weakening or bypassing the test instead of adapting it to the changed API while preserving meaningful coverage.\n../2574-8f806a45/skills/review-fixes-javac-fail/SKILL.md:82:- Dynamic-access coverage drops without a credible explanation and replacement coverage.\n../2574-8f806a45/skills/review-fixes-javac-fail/SKILL.md:90:- The API change is plausible but the PR does not explain why a coverage drop is expected.\n../2574-8f806a45/skills/review-fixes-javac-fail/SKILL.md:97:- For coverage drops: say that dynamic-access coverage must not regress between tested versions, cite the old and new values, and ask for either restored coverage or a concrete explanation.\n../2574-8f806a45/skills/review-fixes-javac-fail/SKILL.md:99:- For deleted coverage: say that the PR fixes compilation by removing coverage and should instead adapt the test to the new API.\n../2574-8f806a45/skills/README.md:22:It covers new-library metadata PRs, including titles like `[GenAI] Add support for com.fasterxml:classmate:1.5.1 using gpt-5.4`, and encodes the review rules already used in this repository: reject scaffold-only tests, keep test packages separate from library packages so tests do not bypass visibility boundaries, and question metadata coverage claims that are not supported by the diff.\n../2574-8f806a45/skills/README.md:27:It covers compile-failure repair PRs for existing libraries and applies a lighter review than `library-new-request`: keep the diff scoped to the compile fix, preserve meaningful tests, and block regressions where dynamic-access coverage drops between the previously tested version and the new version.\n../2574-8f806a45/skills/README.md:32:It covers JVM runtime-failure repair PRs for existing libraries and applies a lighter review than `library-new-request`: keep the diff scoped to the Java runtime fix, preserve meaningful tests and assertions, and block regressions where dynamic-access coverage drops between the previously tested version and the new version.\n../2574-8f806a45/skills/README.md:37:It covers native-image runtime-failure repair PRs for existing libraries and applies a lighter review than `library-new-request`: verify the native path is fixed rather than skipped, keep metadata and test changes scoped, and block regressions where dynamic-access coverage drops between the previously tested version and the new version.\n../2574-8f806a45/README.md:3:[![Libraries supported](https://img.shields.io/badge/dynamic/json.svg?label=libraries%20supported&query=%24.badges.librariesSupported&url=https%3A%2F%2Fraw.githubusercontent.com%2Foracle%2Fgraalvm-reachability-metadata%2Fstats%2Fcoverage%2Flatest%2Fbadges.json&style=flat-square&color=0A7EC2)](COVERAGE.md)\n../2574-8f806a45/README.md:4:[![Tested library versions](https://img.shields.io/badge/dynamic/json.svg?label=tested%20library%20versions&query=%24.badges.testedLibraryVersions&url=https%3A%2F%2Fraw.githubusercontent.com%2Foracle%2Fgraalvm-reachability-metadata%2Fstats%2Fcoverage%2Flatest%2Fbadges.json&style=flat-square&color=BF8700)](COVERAGE.md)\n../2574-8f806a45/README.md:5:[![Dynamic access coverage](https://img.shields.io/badge/dynamic/json.svg?label=dynamic%20access%20coverage&query=%24.badges.dynamicAccessCoverage&url=https%3A%2F%2Fraw.githubusercontent.com%2Foracle%2Fgraalvm-reachability-metadata%2Fstats%2Fcoverage%2Flatest%2Fbadges.json&style=flat-square&color=1F9D55)](COVERAGE.md)\n../2574-8f806a45/README.md:6:[![Tested lines of code](https://img.shields.io/badge/dynamic/json.svg?label=tested%20lines%20of%20code&query=%24.badges.testedLinesOfCode&url=https%3A%2F%2Fraw.githubusercontent.com%2Foracle%2Fgraalvm-reachability-metadata%2Fstats%2Fcoverage%2Flatest%2Fbadges.json&style=flat-square&color=C2410C)](COVERAGE.md)\n../2574-8f806a45/stats/org.apache.yetus/audience-annotations/0.12.0/stats.json:6:      \"coverageRatio\" : 1.0,\n../2574-8f806a45/build.gradle:130:            \"jacocoTestReport\",\n../2574-8f806a45/stats/javax.activation/javax.activation-api/1.2.0/stats.json:7:          \"coverageRatio\" : 1.0,\n../2574-8f806a45/stats/javax.activation/javax.activation-api/1.2.0/stats.json:12:          \"coverageRatio\" : 1.0,\n../2574-8f806a45/stats/javax.activation/javax.activation-api/1.2.0/stats.json:17:      \"coverageRatio\" : 1.0,\n../2574-8f806a45/stats/javax.activation/activation/1.1/stats.json:7:          \"coverageRatio\" : 0.625,\n../2574-8f806a45/stats/javax.activation/activation/1.1/stats.json:12:          \"coverageRatio\" : 1.0,\n../2574-8f806a45/stats/javax.activation/activation/1.1/stats.json:17:      \"coverageRatio\" : 0.727273,\n../2574-8f806a45/stats/org.jvnet/animal-sniffer-annotation/1.0/stats.json:6:      \"coverageRatio\" : 1.0,\n../2574-8f806a45/stats/org.jboss.interceptor/jboss-interceptor-api/1.1/stats.json:6:      \"coverageRatio\" : 1.0,\n../2574-8f806a45/stats/com.sun.mail/jakarta.mail/2.0.1/stats.json:7:          \"coverageRatio\" : 0.054545,\n../2574-8f806a45/stats/com.sun.mail/jakarta.mail/2.0.1/stats.json:12:          \"coverageRatio\" : 0.666667,\n../2574-8f806a45/stats/com.sun.mail/jakarta.mail/2.0.1/stats.json:17:      \"coverageRatio\" : 0.086207,\n../2574-8f806a45/stats/org.snakeyaml/snakeyaml-engine/3.0.1/stats.json:6:      \"coverageRatio\" : 1.0,\n../2574-8f806a45/stats/com.google.auth/google-auth-library-credentials/1.10.0/stats.json:6:      \"coverageRatio\" : 1.0,\n../2574-8f806a45/stats/org.postgresql/postgresql/42.3.4/stats.json:7:          \"coverageRatio\" : 0.022727,\n../2574-8f806a45/stats/org.postgresql/postgresql/42.3.4/stats.json:12:          \"coverageRatio\" : 0.25,\n../2574-8f806a45/stats/org.postgresql/postgresql/42.3.4/stats.json:17:      \"coverageRatio\" : 0.041667,\n../2574-8f806a45/stats/org.postgresql/postgresql/42.7.3/stats.json:7:          \"coverageRatio\" : 0.06383,\n../2574-8f806a45/stats/org.postgresql/postgresql/42.7.3/stats.json:12:          \"coverageRatio\" : 0.25,\n../2574-8f806a45/stats/org.postgresql/postgresql/42.7.3/stats.json:17:      \"coverageRatio\" : 0.078431,\n../2574-8f806a45/stats/javax.servlet/javax.servlet-api/