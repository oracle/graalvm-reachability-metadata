OgnlRuntime.clearCache();\n        final boolean installed = installSecurityManager(securityManager);\n        try {\n            if (installed) {\n                fields = OgnlRuntime.getFields(PublicFieldFallbackFixture.class);\n                methods = OgnlRuntime.getMethods(PublicMethodFallbackFixture.class, false);\n                accessors = OgnlRuntime.getDeclaredMethods(PublicAccessorFallbackFixture.class, \"name\", false);\n            } else {\n                assertThat(System.getSecurityManager()).isSameAs(previousSecurityManager);\n            }\n        } finally {\n            restoreSecurityManager(previousSecurityManager);\n            OgnlRuntime.clearCache();\n        }\n\n        if (installed) {\n            assertThat(fields).containsKey(\"VISIBLE\");\n            assertThat(methods).containsKey(\"visibleMethod\");\n            assertThat(accessors).asList().isNotEmpty();\n        }\n    }\n"}, {"oldText": "    @Test\n    void invokesMethodThroughPreinstalledOgnlSandbox() throws Exception {\n        final OgnlContext context = newContext();\n        final InvocationFixture fixture = new InvocationFixture(\"Grace\");\n        final String previousValue = System.getProperty(\"ognl.security.manager\");\n        final SecurityManager previousSecurityManager = System.getSecurityManager();\n        final SetSecurityManagerDenyingSecurityManager parentSecurityManager =\n                new SetSecurityManagerDenyingSecurityManager();\n        final OgnlSecurityManager ognlSecurityManager = new OgnlSecurityManager(parentSecurityManager);\n        final boolean installed = installSecurityManager(ognlSecurityManager);\n        System.setProperty(\"ognl.security.manager\", \"true\");\n        try {\n            if (installed) {\n                assertThat(OgnlRuntime.callMethod(context, fixture, \"greet\", new Object[] {\"Hi\"}))\n                        .isEqualTo(\"Hi Grace\");\n\n                parentSecurityManager.denySetSecurityManager = true;\n                assertThat(OgnlRuntime.callMethod(context, fixture, \"greet\", new Object[] {\"Welcome\"}))\n                        .isEqualTo(\"Welcome Grace\");\n                parentSecurityManager.denySetSecurityManager = false;\n            } else {\n                try {\n                    assertThat(OgnlRuntime.callMethod(context, fixture, \"greet\", new Object[] {\"Hi\"}))\n                            .isEqualTo(\"Hi Grace\");\n                } catch (MethodFailedException exception) {\n                    assertThat(securityManagerInstallationIsDisabled(exception)).isTrue();\n                } catch (Error error) {\n                    if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                        throw error;\n                    }\n                }\n            }\n        } finally {\n            parentSecurityManager.denySetSecurityManager = false;\n            restoreSecurityManager(previousSecurityManager);\n            restoreProperty(\"ognl.security.manager\", previousValue);\n        }\n    }\n", "newText": "    @Test\n    void invokesMethodThroughPreinstalledOgnlSandbox() throws Exception {\n        final OgnlContext context = newContext();\n        final InvocationFixture fixture = new InvocationFixture(\"Grace\");\n        final String previousValue = System.getProperty(\"ognl.security.manager\");\n        final SecurityManager previousSecurityManager = System.getSecurityManager();\n        final SetSecurityManagerDenyingSecurityManager parentSecurityManager =\n                new SetSecurityManagerDenyingSecurityManager();\n        final OgnlSecurityManager ognlSecurityManager = new OgnlSecurityManager(parentSecurityManager);\n        final boolean installed = installSecurityManager(ognlSecurityManager);\n        System.setProperty(\"ognl.security.manager\", \"true\");\n        try {\n            if (installed) {\n                assertThat(OgnlRuntime.callMethod(context, fixture, \"greet\", new Object[] {\"Hi\"}))\n                        .isEqualTo(\"Hi Grace\");\n\n                parentSecurityManager.denySetSecurityManager = true;\n                assertThat(OgnlRuntime.callMethod(context, fixture, \"greet\", new Object[] {\"Welcome\"}))\n                        .isEqualTo(\"Welcome Grace\");\n                parentSecurityManager.denySetSecurityManager = false;\n            } else {\n                assertSandboxUnavailableOrResult(\n                        () -> OgnlRuntime.callMethod(context, fixture, \"greet\", new Object[] {\"Hi\"}),\n                        \"Hi Grace\");\n            }\n        } finally {\n            parentSecurityManager.denySetSecurityManager = false;\n            restoreSecurityManager(previousSecurityManager);\n            restoreProperty(\"ognl.security.manager\", previousValue);\n        }\n    }\n\n    @Test\n    void invokesMethodThroughOgnlSandboxCreatedOnDemand() throws Exception {\n        try {\n            runIsolatedScenario(SandboxCreatedOnDemandScenario.class.getName());\n        } catch (ClassNotFoundException exception) {\n            if (!isUnsupportedNativeImageClasspathReload(exception, SandboxCreatedOnDemandScenario.class.getName())) {\n                throw exception;\n            }\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    @Test\n    void invokesMethodWhenOgnlSandboxCannotReplaceParentSecurityManager() throws Exception {\n        try {\n            runIsolatedScenario(SandboxParentDeniesReplacementScenario.class.getName());\n        } catch (ClassNotFoundException exception) {\n            if (!isUnsupportedNativeImageClasspathReload(\n                    exception,\n                    SandboxParentDeniesReplacementScenario.class.getName())) {\n                throw exception;\n            }\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n"}]}
