                                            <arg value="-OUTPUT_DIRECTORY=${project.build.sourceDirectory}/ognl" />
                                            <arg value="${project.basedir}/src/etc/ognl.jj" />
                                        </java>
                                    </target>
                                </configuration>
                            </execution>
                        </executions>
                    </plugin>
                </plugins>
            </build>
        </profile>
        <profile>
            <id>jdk17</id>
            <activation>
                <jdk>[17,)</jdk>
            </activation>
            <build>
                <pluginManagement>
                    <plugins>
                        <plugin>
                            <groupId>org.apache.maven.plugins</groupId>

