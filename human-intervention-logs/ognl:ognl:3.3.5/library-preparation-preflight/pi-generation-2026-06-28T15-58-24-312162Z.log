  51:                 OgnlSecurityManager.class.getName().replace('.', '/') + ".class"));
  52:         ognlSecurityManagerClass = defineClass(null, byteArray, 0, byteArray.length, pd);
  53:     }
  54: 
  55:     private Object build(SecurityManager parentSecurityManager) throws NoSuchMethodException, IllegalAccessException,
  56:             InvocationTargetException, InstantiationException {
