                  </configuration>
                  <executions>
                      <execution>
                          <goals>
                              <goal>jar</goal>
                          </goals>
                      </execution>
                  </executions>
              </plugin>
              <plugin>
                  <groupId>org.apache.maven.plugins</groupId>
                  <artifactId>maven-javadoc-plugin</artifactId>
                  <version>3.4.0</version>
                  <configuration>
                      <archive>
                          <compress>true</compress>
                          <index>true</index>
                      </archive>
                      <source>1.8</source>
