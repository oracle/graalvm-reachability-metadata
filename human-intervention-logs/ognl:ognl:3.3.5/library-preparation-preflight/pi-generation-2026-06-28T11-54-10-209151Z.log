[tool-call] delta {"command":"tmp=$(mktemp -d); cat > $tmp/TestOgnl.java <<'JAVA'\nimport ognl.*;\nimport java.util.*;\npublic class TestOgnl {\n  public static class Person { public String name; public Person child; public List<String> tags = List.of(\"a\",\"b\"); public Person(String n){name=n;} public String greet(String p){return p+\" \"+name;} }\n  public static void main(String[] args) throws Exception {\n    Person p = new Person(\"Ada\"); p.child = new Person(\"Grace\");\n    OgnlContext ctx = (OgnlContext) Ognl.createDefaultContext(p);\n    System.out.println(Ognl.getValue(Ognl.parseExpression(\"child.name\"), ctx, p));\n    Ognl.setValue(Ognl.parseExpression(\"name\"), ctx, p, \"Bob\");\n    System.out.println(Ognl.getValue(\"greet('Hi')\", ctx, p));\n    System.out.println(Ognl.getValue(\"tags[1]\", ctx, p));\n  }\n}\nJAVA\nCP=\"$HOME/.gradle/caches/modules-2/files-2.1/ognl/ognl/3.3.5/b4cb896a364038c1b71a8eec7d0554df7bcae464/ognl-3.3.5.jar:$HOME/.gradle/caches/modules-2/files-2.1/org.javassist/javassist/3.29.0-GA/d3959fa7e00bf04dbe519228a23213d2afb625d8/javassist-3.29.0-GA.jar\"\njavac -cp \"$CP\" $tmp/TestOgnl.java && java -cp \"$CP:$tmp\" TestOgnl\nrm -rf $tmp","timeout":20}
