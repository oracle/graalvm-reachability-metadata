              return "static";
          }
      }
  
      public static final class AllMethodDiscoveryFixture {
          public String allMessage() {
              return "all";
          }
      }
  
      public static final class AccessorFixture {
          private String name = "accessor";
  
          public String getName() {
              return name;
          }
  
          public void setName(String name) {
              this.name = name;
  
