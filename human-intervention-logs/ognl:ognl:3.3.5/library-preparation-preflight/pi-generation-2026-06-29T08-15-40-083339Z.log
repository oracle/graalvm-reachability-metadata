e87dd13"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_0b113ZKpnyKLS0qGBaQIvEfi|fc_0f5a932191c78024016a422941f1908196bd615fbd0cc911ee", "toolName": "bash", "content": [{"type": "text", "text": "\n--- ognl/AccessibleObjectHandlerJDK9Plus.java ---\n1: /*\n2:  * Licensed to the Apache Software Foundation (ASF) under one\n3:  * or more contributor license agreements.  See the NOTICE file\n4:  * and/or LICENSE file distributed with this work for additional\n5:  * information regarding copyright ownership.  The ASF licenses\n6:  * this file to you under the Apache License, Version 2.0 (the\n7:  * \"License\"); you may not use this file except in compliance\n8:  * with the License.  You may obtain a copy of the License at\n9:  *\n10:  *   http://www.apache.org/licenses/LICENSE-2.0\n11:  *\n12:  * Unless required by applicable law or agreed to in writing,\n13:  * software distributed under the License is distributed on an\n14:  * \"AS IS\" BASIS, WITHOUT WARRANTIES OR CONDITIONS OF ANY\n15:  * KIND, either express or implied.  See the License for the\n16:  * specific language governing permissions and limitations\n17:  * under the License.\n18:  */\n19: package ognl;\n20: \n21: import java.lang.reflect.AccessibleObject;\n22: import java.lang.reflect.Field;\n23: import java.lang.reflect.Method;\n24: \n25: /**\n26:  * Utilizes a JDK 9 and later mechanism for changing the accessibility level of a given\n27:  *   AccessibleObject.\n28:  *\n29:  * If the JDK 9+ mechanism fails, this class will fall back to a standard pre-JDK 9 reflection mechanism.\n30:  *   Note:  That may cause \"WARNING: Illegal reflective access\" output to be generated to stdout/stderr.\n31:  *\n32:  * For reference, this class draws on information from the following locations:\n33:  *   - Post about Illegal Reflective Access <a href=\"https://stackoverflow.com/questions/50251798/what-is-an-illegal-reflective-access\">what is an illegal reflective access</a>\n34:  *   - Blog on Unsafe <a href=\"http://mishadoff.com/blog/java-magic-part-4-sun-dot-misc-dot-unsafe/\">Java Magic. Part 4: sun.misc.Unsafe</a>\n35:  *   - Blog on Unsafe <a href=\"https://www.baeldung.com/java-unsafe\">Guide to sun.misc.Unsafe</a>\n36:  *   - JEP about access to Unsafe being retained in JDK 9 <a href=\"https://openjdk.java.net/jeps/260\">JEP 260: Encapsulate Most Internal APIs</a>\n37:  *\n38:  * In addition to the above, inspiration was drawn from Gson: <a href=\"https://github.com/google/gson/pull/1218\">PR 1218</a>,\n39:  *   <a href=\"https://github.com/google/gson/pull/1306\">PR 1306</a>.\n40:  *\n41:  * Appreciation and credit to the authors, contributors and commenters for the information contained in the preceding links.\n42:  *\n43:  * @since 3.1.24\n44:  */\n45: class AccessibleObjectHandlerJDK9Plus implements AccessibleObjectHandler\n46: {\n47:     private static final Class _clazzUnsafe = instantiateClazzUnsafe();\n48:     private static final Object _unsafeInstance = instantiateUnsafeInstance(_clazzUnsafe);\n49:     private static final Method _unsafeObjectFieldOffsetMethod = instantiateUnsafeObjectFieldOffsetMethod(_clazzUnsafe);\n50:     private static final Method _unsafePutBooleanMethod = instantiateUnsafePutBooleanMethod(_clazzUnsafe);\n51:     private static final Field _accessibleObjectOverrideField = instantiateAccessibleObjectOverrideField();\n52:     private static final long _accessibleObjectOverrideFieldOffset = determineAccessibleObjectOverrideFieldOffset();\n53: \n54:     /**\n55:      * Private constructor\n56:      */\n57:     private AccessibleObjectHandlerJDK9Plus() {}\n58: \n59:     /**\n60:      * Package-accessible method to determine if a given class is Unsafe or a descendant\n61:      *   of Unsafe.\n62:      *\n63:      * @param clazz the Class upon which to perform the unsafe check.\n64:      * @return true if parameter is Unsafe or a descendant, false otherwise\n65:      */\n66:     static boolean unsafeOrDescendant(final Class clazz) {\n67:         return (_clazzUnsafe != null ? _clazzUnsafe.isAssignableFrom(clazz) : false);\n68:     }\n69: \n70:     /**\n71:      * Instantiate an instance of the Unsafe class.\n72:      *\n73:      * @return class if available, null otherwise\n74:      */\n75:     private static Class instantiateClazzUnsafe() {\n76:         Class clazz;\n77: \n78:         try {\n79:             clazz = Class.forName(\"sun.misc.Unsafe\");\n80:         } catch (Throwable t) {\n81:             clazz = null;\n82:         }\n83: \n84:         return clazz;\n85:     }\n86: \n87:     /**\n88:      * Instantiate an instance of Unsafe object.\n89:      *\n90:      * @param clazz (expected to be an Unsafe instance)\n91:      * @return instance if available, null otherwise\n92:      */\n93:     private static Object instantiateUnsafeInstance(Class clazz) {\n94:         Object unsafe;\n95: \n96:         if (clazz != null) {\n97:             Field field = null;\n98:             try {\n99:                 field = clazz.getDeclaredField(\"theUnsafe\");\n100:                 field.setAccessible(true);\n101:                 unsafe = field.get(null);\n102:             } catch (Throwable t) {\n103:                 unsafe = null;\n104:             } finally {\n105:                 if (field != null) {\n106:                     try {\n107:                         field.setAccessible(false);\n108:                     } catch (Throwable t) {\n109:                         // Don't care\n110:                     }\n111:                 }\n112:             }\n113:         } else {\n114:             unsafe = null;\n115:         }\n116: \n117:         return unsafe;\n118:     }\n119: \n120:     /**\n121:      * Instantiate an Unsafe.objectFieldOffset() method instance.\n122:      *\n123:      * @param clazz (expected to be an Unsafe instance)\n124:      * @return method if available, null otherwise\n125:      */\n126:     private static Method instantiateUnsafeObjectFieldOffsetMethod(Class clazz) {\n127:         Method method;\n128: \n129:         if (clazz != null) {\n130:             try {\n131:                 method = clazz.getMethod(\"objectFieldOffset\", Field.class);\n132:             } catch (Throwable t) {\n133:                 method = null;\n134:             }\n135:         } else {\n136:             method = null;\n137:         }\n138: \n139:         return method;\n140:     }\n141: \n142:     /**\n143:      * Instantiate an Unsafe.putBoolean() method instance.\n144:      *\n145:      * @param clazz (expected to be an Unsafe instance)\n146:      * @return method if available, null otherwise\n147:      */\n148:     private static Method instantiateUnsafePutBooleanMethod(Class clazz) {\n149:         Method method;\n150: \n151:         if (clazz != null) {\n152:             try {\n153:                 method = clazz.getMethod(\"putBoolean\", Object.class, long.class, boolean.class);\n154:             } catch (Throwable t) {\n155:                 method = null;\n156:             }\n157:         } else {\n158:             method = null;\n159:         }\n160: \n161:         return method;\n162:     }\n163: \n164:     /**\n165:      * Instantiate an AccessibleObject override field instance.\n166:      *\n167:      * @return field if available, null otherwise\n168:      */\n169:     private static Field instantiateAccessibleObjectOverrideField() {\n170:         Field field;\n171: \n172:         try {\n173:             field = AccessibleObject.class.getDeclaredField(\"override\");\n174:         } catch (Throwable t) {\n175:             field = null;\n176:         }\n177: \n178:         return field;\n179:     }\n180: \n181:     /**\n182:      * Attempt to determined the AccessibleObject override field offset.\n183:      *\n184:      * @return field offset if available, -1 otherwise\n185:      */\n186:     private static long determineAccessibleObjectOverrideFieldOffset() {\n187:         long offset = -1;\n188: \n189:         if (_accessibleObjectOverrideField != null && _unsafeObjectFieldOffsetMethod != null && _unsafeInstance != null) {\n190:             try {\n191:                 offset = (Long) _unsafeObjectFieldOffsetMethod.invoke(_unsafeInstance, _accessibleObjectOverrideField);\n192:             } catch (Throwable t) {\n193:                 // Don't care (offset already -1)\n194:             }\n195:         }\n196: \n197:         return offset;\n198:     }\n199: \n200:     /**\n201:      * Package-level generator of an AccessibleObjectHandlerJDK9Plus instance.\n202:      *\n203:      * Not intended for use outside of the package.\n204:      *\n205:      * Note: An AccessibleObjectHandlerJDK9Plus will only be created if running on a\n206:      *   JDK9+ and the environment flag is set.  Otherwise this method will return\n207:      *   an AccessibleHandlerPreJDK9 instance instead,\n208:      *\n209:      * @return an AccessibleObjectHandler instance\n210:      *\n211:      * @since 3.1.24\n212:      */\n213:     static AccessibleObjectHandler createHandler() {\n214:         if (OgnlRuntime.usingJDK9PlusAccessHandler()){\n215:             return new AccessibleObjectHandlerJDK9Plus();\n216:         } else {\n217:             return AccessibleObjectHandlerPreJDK9.createHandler();\n218:         }\n219:     }\n220: \n221:     /**\n222:      * Utilize accessibility modification mechanism for JDK 9 (Java Major Version 9) and later.\n223:      *   Should that mechanism fail, attempt a standard pre-JDK9 accessibility modification.\n224:      *\n225:      * @param accessibleObject the AccessibleObject upon which to apply the flag.\n226:      * @param flag the new accessible flag value.\n227:      */\n228:     public void setAccessible(AccessibleObject accessibleObject, boolean flag) {\n229:         boolean operationComplete = false;\n230: \n231:         if (_unsafeInstance != null && _unsafePutBooleanMethod != null && _accessibleObjectOverrideFieldOffset != -1) {\n232:             try {\n233:                 _unsafePutBooleanMethod.invoke(_unsafeInstance, accessibleObject, _accessibleObjectOverrideFieldOffset, flag);\n234:                 operationComplete = true;\n235:             } catch (Throwable t) {\n236:                 // Don't care (operationComplete already false)\n237:             }\n238:         }\n239:         if (!operationComplete) {\n240:             // Fallback to standard reflection if Unsafe processing fails\n241:             accessibleObject.setAccessible(flag);\n242:         }\n243:     }\n244: \n245: }\n\n--- ognl/OgnlRuntime.java ---\n150:      *    -Dognl.UseStricterInvocation=false\n151:      *\n152:      * Note: Using the \"true\" value has the same effect as omitting the option completely.\n153:      *   The default behaviour is to use the \"stricter\" invocation processing.\n154:      *   Using the \"false\" value reverts to the older \"less strict\" invocation processing\n155:      *   (in the event the \"stricter\" processing causes issues for existing applications).\n156:      */\n157:     static final String USE_STRICTER_INVOCATION = \"ognl.UseStricterInvocation\";\n158: \n159:     /**\n160:      * Hold environment flag state associated with USE_JDK9PLUS_ACESS_HANDLER.\n161:      *   Default: false (if not set)\n162:      */\n163:     private static final boolean _useJDK9PlusAccessHandler;\n164:     static {\n165:         boolean initialFlagState = false;\n166:         try {\n167:             final String propertyString = System.getProperty(USE_JDK9PLUS_ACESS_HANDLER);\n168:             if (propertyString != null && propertyString.length() > 0) {\n169:                 initialFlagState = Boolean.parseBoolean(propertyString);\n170:             }\n171:         } catch (Exception ex) {\n172:             // Unavailable (SecurityException, etc.)\n173:         }\n174:         _useJDK9PlusAccessHandler = initialFlagState;\n175:     }\n176: \n177:     /**\n178:      * Hold environment flag state associated with USE_STRICTER_INVOCATION.\n179:      *   Default: true (if not set)\n180:      */\n181:     private static final boolean _useStricterInvocation;\n182:     static {\n183:         boolean initialFlagState = true;\n184:         try {\n185:             final String propertyString = System.getProperty(USE_STRICTER_INVOCATION);\n186:             if (propertyString != null && propertyString.length() > 0) {\n187:                 initialFlagState = Boolean.parseBoolean(propertyString);\n188:             }\n189:         } catch (Exception ex) {\n190:             // Unavailable (SecurityException, etc.)\n191:         }\n192:         _useStricterInvocation = initialFlagState;\n193:     }\n194: \n195:     /*\n196:      * Attempt to detect the system-reported Major Java Version (e.g. 5, 7, 11).\n197:      */\n198:     private static final int _majorJavaVersion = detectMajorJavaVersion();\n199:     private static final boolean _jdk9Plus = _majorJavaVersion >= 9;\n200: \n201:     /*\n202:      * Assign an accessibility modification mechanism, based on Major Java Version and Java option flag\n203:      *   flag {@link OgnlRuntime#USE_JDK9PLUS_ACESS_HANDLER}.\n204:      *\n205:      * Note: Will use the standard Pre-JDK9 accessibility modification mechanism unless OGNL is running\n206:      *   on JDK9+ and the Java option flag has also been set true.\n207:      */\n208:     private static final AccessibleObjectHandler _accessibleObjectHandler;\n209:     static {\n210:         _accessibleObjectHandler = usingJDK9PlusAccessHandler() ? AccessibleObjectHandlerJDK9Plus.createHandler() :\n211:             AccessibleObjectHandlerPreJDK9.createHandler();\n212:     }\n213: \n214:     /**\n215:      * Private references for use in blocking direct invocation by invokeMethod().\n216:      */\n217:     private static final Method SYS_CONSOLE_REF;\n218:     private static final Method SYS_EXIT_REF;\n219:     private static final Method AO_SETACCESSIBLE_REF;\n220:     private static final Method AO_SETACCESSIBLE_ARR_REF;\n221: \n222:     /**\n223:      * Initialize the Method references used for blocking usage within invokeMethod().\n224:      */\n225:     static {\n226:         Method setAccessibleMethod = null;\n227:         Method setAccessibleMethodArray = null;\n228:         Method systemExitMethod = null;\n229:         Method systemConsoleMethod = null;\n230:         try {\n231:             setAccessibleMethod = AccessibleObject.class.getMethod(\"setAccessible\", new Class<?>[]{boolean.class});\n232:         } catch (NoSuchMethodException nsme) {\n233:             // Should not happen.  To debug, uncomment the next line.\n234:             //throw new IllegalStateException(\"OgnlRuntime initialization missing setAccessible method\", nsme);\n235:         } catch (SecurityException se) {\n236:             // May be blocked by existing SecurityManager.  To debug, uncomment the next line.\n237:             //throw new SecurityException(\"OgnlRuntime initialization cannot access setAccessible method\", se);\n238:         } finally {\n239:             AO_SETACCESSIBLE_REF = setAccessibleMethod;\n240:         }\n241: \n242:         try {\n243:             setAccessibleMethodArray = AccessibleObject.class.getMethod(\"setAccessible\", new Class<?>[]{AccessibleObject[].class, boolean.class});\n244:         } catch (NoSuchMethodException nsme) {\n245:             // Should not happen.  To debug, uncomment the next line.\n246:             //throw new IllegalStateException(\"OgnlRuntime initialization missing setAccessible method\", nsme);\n247:         } catch (SecurityException se) {\n248:             // May be blocked by existing SecurityManager.  To debug, uncomment the next line.\n249:             //throw new SecurityException(\"OgnlRuntime initialization cannot access setAccessible method\", se);\n250:         } finally {\n251:             AO_SETACCESSIBLE_ARR_REF = setAccessibleMethodArray;\n252:         }\n253: \n254:         try {\n255:             systemExitMethod = System.class.getMethod(\"exit\", new Class<?>[]{int.class});\n256:         } catch (NoSuchMethodException nsme) {\n257:             // Should not happen.  To debug, uncomment the next line.\n258:             //throw new IllegalStateException(\"OgnlRuntime initialization missing exit method\", nsme);\n259:         } catch (SecurityException se) {\n260:             // May be blocked by existing SecurityManager.  To debug, uncomment the next line.\n261:             //throw new SecurityException(\"OgnlRuntime initialization cannot access exit method\", se);\n262:         } finally {\n263:             SYS_EXIT_REF = systemExitMethod;\n264:         }\n265: \n266:         try {\n267:             systemConsoleMethod = System.class.getMethod(\"console\", new Class<?>[]{});  // Not available in JDK 1.5 or earlier\n268:         } catch (NoSuchMethodException nsme) {\n269:             // May happen for JDK 1.5 and earlier.  To debug, uncomment the next line.\n270:             //throw new IllegalStateException(\"OgnlRuntime initialization missing console method\", nsme);\n271:         } catch (SecurityException se) {\n272:             // May be blocked by existing SecurityManager.  To debug, uncomment the next line.\n273:             //throw new SecurityException(\"OgnlRuntime initialization cannot access console method\", se);\n274:         } finally {\n275:             SYS_CONSOLE_REF = systemConsoleMethod;\n276:         }\n277:     }\n278: \n279:     /**\n280:      * Control usage of the OGNL Security Manager using the JVM option:\n281:      *   -Dognl.security.manager=true  (or any non-null value other than 'disable')\n282:      *\n283:      * Omit '-Dognl.security.manager=' or nullify the property to disable the feature.\n284:      *\n285:      * To forcibly disable the feature (only possible at OGNL Library initialization, use the option:\n286:      *   -Dognl.security.manager=forceDisableOnInit\n287:      *\n288:      * Users that have their own Security Manager implementations and no intention to use the OGNL SecurityMan