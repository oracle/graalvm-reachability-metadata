utBooleanMethod.invoke(_unsafeInstance, accessibleObject, _accessibleObjectOverrideFieldOffset, flag);\n234:                 operationComplete = true;\n235:             } catch (Throwable t) {\n236:                 // Don't care (operationComplete already false)\n237:             }\n238:         }\n239:         if (!operationComplete) {\n240:             // Fallback to standard reflection if Unsafe processing fails\n241:             accessibleObject.setAccessible(flag);\n242:         }\n243:     }\n244: \n245: }\n\n--- ognl/OgnlRuntime.java ---\n150:      *    -Dognl.UseStricterInvocation=false\n151:      *\n152:      * Note: Using the \"true\" value has the same effect as omitting the option completely.\n153:      *   The default behaviour is to use the \"stricter\" invocation processing.\n154:      *   Using the \"false\" value reverts to the older \"less strict\" invocation processing\n155:      *   (in the event the \"stricter\" processing causes issues for existing applications).\n156:      */\n157:     static final String USE_STRICTER_INVOCATION = \"ognl.UseStricterInvocation\";\n158: \n159:     /**\n160:      * Hold environment flag state associated with USE_JDK9PLUS_ACESS_HANDLER.\n161:      *   Default: false (if not set)\n162:      */\n163:     private static final boolean _useJDK9PlusAccessHandler;\n164:     static {\n165:         boolean initialFlagState = false;\n166:         try {\n167:             final String propertyString = System.getProperty(USE_JDK9PLUS_ACESS_HANDLER);\n168:             if (propertyString != null && propertyString.length() > 0) {\n169:                 initialFlagState = Boolean.parseBoolean(propertyString);\n170:             }\n171:         } catch (Exception ex) {\n172:             // Unavailable (SecurityException, etc.)\n173:         }\n174:         _useJDK9PlusAccessHandler = initialFlagState;\n175:     }\n176: \n177:     /**\n178:      * Hold environment flag state associated with USE_STRICTER_INVOCATION.\n179:      *   Default: true (if not set)\n180:      */\n181:     private static final boolean _useStricterInvocation;\n182:     static {\n183:         boolean initialFlagState = true;\n184:         try {\n185:             final String propertyString = System.getProperty(USE_STRICTER_INVOCATION);\n186:             if (propertyString != null && propertyString.length() > 0) {\n187:                 initialFlagState = Boolean.parseBoolean(propertyString);\n188:             }\n189:         } catch (Exception ex) {\n190:             // Unavailable (SecurityException, etc.)\n191:         }\n192:         _useStricterInvocation = initialFlagState;\n193:     }\n194: \n195:     /*\n196:      * Attempt to detect the system-reported Major Java Version (e.g. 5, 7, 11).\n197:      */\n198:     private static final int _majorJavaVersion = detectMajorJavaVersion();\n199:     private static final boolean _jdk9Plus = _majorJavaVersion >= 9;\n200: \n201:     /*\n202:      * Assign an accessibility modification mechanism, based on Major Java Version and Java option flag\n203:      *   flag {@link OgnlRuntime#USE_JDK9PLUS_ACESS_HANDLER}.\n204:      *\n205:      * Note: Will use the standard Pre-JDK9 accessibility modification mechanism unless OGNL is running\n206:      *   on JDK9+ and the Java option flag has also been set true.\n207:      */\n208:     private static final AccessibleObjectHandler _accessibleObjectHandler;\n209:     static {\n210:         _accessibleObjectHandler = usingJDK9PlusAccessHandler() ? AccessibleObjectHandlerJDK9Plus.createHandler() :\n211:             AccessibleObjectHandlerPreJDK9.createHandler();\n212:     }\n213: \n214:     /**\n215:      * Private references for use in blocking direct invocation by invokeMethod().\n216:      */\n217:     private static final Method SYS_CONSOLE_REF;\n218:     private static final Method SYS_EXIT_REF;\n219:     private static final Method AO_SETACCESSIBLE_REF;\n220:     private static final Method AO_SETACCESSIBLE_ARR_REF;\n221: \n222:     /**\n223:      * Initialize the Method references used for blocking usage within invokeMethod().\n224:      */\n225:     static {\n226:         Method setAccessibleMethod = null;\n227:         Method setAccessibleMethodArray = null;\n228:         Method systemExitMethod = null;\n229:         Method systemConsoleMethod = null;\n230:         try {\n231:             setAccessibleMethod = AccessibleObject.class.getMethod(\"setAccessible\", new Class<?>[]{boolean.class});\n232:         } catch (NoSuchMethodException nsme) {\n233:             // Should not happen.  To debug, uncomment the next line.\n234:             //throw new IllegalStateException(\"OgnlRuntime initialization missing setAccessible method\", nsme);\n235:         } catch (SecurityException se) {\n236:             // May be blocked by existing SecurityManager.  To debug, uncomment the next line.\n237:             //throw new SecurityException(\"OgnlRuntime initialization cannot access setAccessible method\", se);\n238:         } finally {\n239:             AO_SETACCESSIBLE_REF = setAccessibleMethod;\n240:         }\n241: \n242:         try {\n243:             setAccessibleMethodArray = AccessibleObject.class.getMethod(\"setAccessible\", new Class<?>[]{AccessibleObject[].class, boolean.class});\n244:         } catch (NoSuchMethodException nsme) {\n245:             // Should not happen.  To debug, uncomment the next line.\n246:             //throw new IllegalStateException(\"OgnlRuntime initialization missing setAccessible method\", nsme);\n247:         } catch (SecurityException se) {\n248:             // May be blocked by existing SecurityManager.  To debug, uncomment the next line.\n249:             //throw new SecurityException(\"OgnlRuntime initialization cannot access setAccessible method\", se);\n250:         } finally {\n251:             AO_SETACCESSIBLE_ARR_REF = setAccessibleMethodArray;\n252:         }\n253: \n254:         try {\n255:             systemExitMethod = System.class.getMethod(\"exit\", new Class<?>[]{int.class});\n256:         } catch (NoSuchMethodException nsme) {\n257:             // Should not happen.  To debug, uncomment the next line.\n258:             //throw new IllegalStateException(\"OgnlRuntime initialization missing exit method\", nsme);\n259:         } catch (SecurityException se) {\n260:             // May be blocked by existing SecurityManager.  To debug, uncomment the next line.\n261:             //throw new SecurityException(\"OgnlRuntime initialization cannot access exit method\", se);\n262:         } finally {\n263:             SYS_EXIT_REF = systemExitMethod;\n264:         }\n265: \n266:         try {\n267:             systemConsoleMethod = System.class.getMethod(\"console\", new Class<?>[]{});  // Not available in JDK 1.5 or earlier\n268:         } catch (NoSuchMethodException nsme) {\n269:             // May happen for JDK 1.5 and earlier.  To debug, uncomment the next line.\n270:             //throw new IllegalStateException(\"OgnlRuntime initialization missing console method\", nsme);\n271:         } catch (SecurityException se) {\n272:             // May be blocked by existing SecurityManager.  To debug, uncomment the next line.\n273:             //throw new SecurityException(\"OgnlRuntime initialization cannot access console method\", se);\n274:         } finally {\n275:             SYS_CONSOLE_REF = systemConsoleMethod;\n276:         }\n277:     }\n278: \n279:     /**\n280:      * Control usage of the OGNL Security Manager using the JVM option:\n281:      *   -Dognl.security.manager=true  (or any non-null value other than 'disable')\n282:      *\n283:      * Omit '-Dognl.security.manager=' or nullify the property to disable the feature.\n284:      *\n285:      * To forcibly disable the feature (only possible at OGNL Library initialization, use the option:\n286:      *   -Dognl.security.manager=forceDisableOnInit\n287:      *\n288:      * Users that have their own Security Manager implementations and no intention to use the OGNL SecurityManager\n289:      *   sandbox may choose to use the 'forceDisableOnInit' flag option for performance reasons (avoiding overhead\n290:      *   involving the system property security checks - when that feature will not be used).\n291:      */\n292:     static final String OGNL_SECURITY_MANAGER = \"ognl.security.manager\";\n293:     static final String OGNL_SM_FORCE_DISABLE_ON_INIT = \"forceDisableOnInit\";\n294: \n295:     /**\n296:      * Hold environment flag state associated with OGNL_SECURITY_MANAGER.  See\n297:      * {@link OgnlRuntime#OGNL_SECURITY_MANAGER} for more details.\n298:      *   Default: false (if not set).\n299:      */\n300:     private static final boolean _disableOgnlSecurityManagerOnInit;\n301:     static {\n302:         boolean initialFlagState = false;\n303:         try {\n304:             final String propertyString = System.getProperty(OGNL_SECURITY_MANAGER);\n305:             if (propertyString != null && propertyString.length() > 0) {\n306:                 initialFlagState = OGNL_SM_FORCE_DISABLE_ON_INIT.equalsIgnoreCase(propertyString);\n307:             }\n308:         } catch (Exception ex) {\n309:             // Unavailable (SecurityException, etc.)\n310:         }\n311:         _disableOgnlSecurityManagerOnInit = initialFlagState;\n312:     }\n313: \n314:     /**\n315:      * Allow users to revert to the old \"first match\" lookup for getters/setters by OGNL using the JVM options:\n316:      *    -Dognl.UseFirstMatchGetSetLookup=true\n317:      *    -Dognl.UseFirstMatchGetSetLookup=false\n318:      *\n319:      * Note: Using the \"false\" value has the same effect as omitting the option completely.\n320:      *   The default behaviour is to use the \"best match\" lookup for getters/setters.\n321:      *   Using the \"true\" value reverts to the older \"first match\" lookup for getters/setters\n322:      *   (in the event the \"best match\" processing causes issues for existing applications).\n323:      */\n324:     static final String USE_FIRSTMATCH_GETSET_LOOKUP = \"ognl.UseFirstMatchGetSetLookup\";\n325: \n326:     /**\n327:      * Hold environment flag state associated with USE_FIRSTMATCH_GETSET_LOOKUP.\n328:      *   Default: false (if not set)\n329:      */\n330:     private static final boolean _useFirstMatchGetSetLookup;\n331:     static {\n332:         boolean initialFlagState = false;\n333:         try {\n334:             final String propertyString = System.getProperty(USE_FIRSTMATCH_GETSET_LOOKUP);\n335:             if (propertyString != null && propertyString.length() > 0) {\n336:                 initialFlagState = Boolean.parseBoolean(propertyString);\n337:             }\n338:         } catch (Exception ex) {\n339:             // Unavailable (SecurityException, etc.)\n340:         }\n341:         _useFirstMatchGetSetLookup = initialFlagState;\n342:     }\n343: \n344:     static final ClassCache _methodAccessors = new ClassCacheImpl();\n345:     static final ClassCache _propertyAccessors = new ClassCacheImpl();\n346:     static final ClassCache _elementsAccessors = new ClassCacheImpl();\n347:     static final ClassCache _nullHandlers = new ClassCacheImpl();\n348: \n349:     static final ClassCache _propertyDescriptorCache = new ClassCacheImpl();\n350:     static final ClassCache _constructorCache = new ClassCacheImpl();\n351:     static final ClassCache _staticMethodCache = new ClassCacheImpl();\n352:     static final ClassCache _instanceMethodCache = new ClassCacheImpl();\n353:     static final ClassCache _invokePermissionCache = new ClassCacheImpl();\n354:     static final ClassCache _fieldCache = new ClassCacheImpl();\n355:     static final List _superclasses = new ArrayList(); /* Used by fieldCache lookup */\n356:     static final ClassCache[] _declaredMethods = new ClassCache[]{new ClassCacheImpl(), new ClassCacheImpl()};\n357: \n358:     static final Map _primitiveTypes = new HashMap(101);\n359:     static final ClassCache _primitiveDefaults = new ClassCacheImpl();\n360:     static final Map _methodParameterTypesCache = new HashMap(101);\n4000: \n4001: \n4002:         /**\n4003:          * Allow clearing for the underlying cache of the ClassPropertyMethodCache.\n4004:          *\n4005:          * @since 3.1.25\n4006:          */\n4007:         void clear() {\n4008:             this.cache.clear();\n4009:         }\n4010: \n4011:     }\n4012: \n4013:     /**\n4014:      * Detect the (reported) Major Java version running OGNL.\n4015:      *\n4016:      * Should support naming conventions of pre-JDK9 and JDK9+.\n4017:      * See <a href=\"https://openjdk.java.net/jeps/223\">JEP 223: New Version-String Scheme</a> for details.\n4018:      *\n4019:      * @return Detected Major Java Version, or 5 (minimum supported version for OGNL) if unable to detect.\n4020:      *\n4021:      * @since 3.1.25\n4022:      */\n4023:     static int detectMajorJavaVersion() {\n4024:         int majorVersion = -1;\n4025:         try {\n4026:             majorVersion = parseMajorJavaVersion(System.getProperty(\"java.version\"));\n4027:         } catch (Exception ex) {\n4028:             // Unavailable (SecurityException, etc.)\n4029:         }\n4030:         if (majorVersion == -1) {\n4031:             majorVersion = 5;  // Return minimum supported Java version for OGNL\n4032:         }\n4033: \n4034:         return majorVersion;\n4035:     }\n4036: \n4037:     /**\n4038:      * Parse a Java version string to determine the Major Java version.\n4039:      *\n4040:      * Should support naming conventions of pre-JDK9 and JDK9+.\n4041:      * See <a href=\"https://openjdk.java.net/jeps/223\">JEP 223: New Version-String Scheme</a> for details.\n4042:      *\n4043:      * @return Detected Major Java Version, or 5 (minimum supported version for OGNL) if unable to detect.\n4044:      *\n4045:      * @since 3.1.25\n4046:      */\n4047:     static int parseMajorJavaVersion(String versionString) {\n4048:         int majorVersion = -1;\n4049:         try {\n405