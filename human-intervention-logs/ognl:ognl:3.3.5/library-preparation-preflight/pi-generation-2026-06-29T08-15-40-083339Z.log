  21: import java.lang.reflect.AccessibleObject;
  22: import java.lang.reflect.Field;
  23: import java.lang.reflect.Method;
  24: 
  25: /**
  26:  * Utilizes a JDK 9 and later mechanism for changing the accessibility level of a given
  27:  *   AccessibleObject.
  28:  *
  29:  * If the JDK 9+ mechanism fails, this class will fall back to a standard pre-JDK 9 reflection mechanism.
  30:  *   Note:  That may cause "WARNING: Illegal reflective access" output to be generated to stdout/stderr.
  31:  *
  32:  * For reference, this class draws on information from the following locations:
  33:  *   - Post about Illegal Reflective Access <a href="https://stackoverflow.com/questions/50251798/what-is-an-illegal-reflective-access">what is an illegal reflective access</a>
  34:  *   - Blog on Unsafe <a href="http://mishadoff.com/blog/java-magic-part-4-sun-dot-misc-dot-unsafe/">Java Magic. Part 4: sun.misc.Unsafe</a>
  35:  *   - Blog on Unsafe <a href="https://www.baeldung.com/java-unsafe">Guide to sun.misc.Unsafe</a>
  36:  *   - JEP about access to Unsafe being retained in JDK 9 <a href="https://openjdk.java.net/jeps/260">JEP 260: Encapsulate Most Internal APIs</a>
  37:  *
  38:  * In addition to the above, inspiration was drawn from Gson: <a href="https://github.com/google/gson/pull/1218">PR 1218</a>,
  39:  *   <a href="https://github.com/google/gson/pull/1306">PR 1306</a>.
  40:  *
  41:  * Appreciation and credit to the authors, contributors and commenters for the information contained in the preceding links.
  42:  *
  43:  * @since 3.1.24
  44:  */
  45: class AccessibleObjectHandlerJDK9Plus implements AccessibleObjectHandler
  46: {
  47:     private static final Class _clazzUnsafe = instantiateClazzUnsafe();
  48:     private static final Object _unsafeInstance = instantiateUnsafeInstance(_clazzUnsafe);
  49:     private static final Method _unsafeObjectFieldOffsetMethod = instantiateUnsafeObjectFieldOffsetMethod(_clazzUnsafe);
  50:     private static final Method _unsafePutBooleanMethod = instantiateUnsafePutBooleanMethod(_clazzUnsafe);
  51:     private static final Field _accessibleObjectOverrideField = instantiateAccessibleObjectOverrideField();
  52:     private static final long _accessibleObjectOverrideFieldOffset = determineAccessibleObjectOverrideFieldOffset();
  53: 
  54:     /**
  55:      * Private constructor
  56:      */
  57:     private AccessibleObjectHandlerJDK9Plus() {}
  58: 
  59:     /**
  60:      * Package-accessible method to determine if a given class is Unsafe or a descendant
  61:      *   of Unsafe.
  62:      *
  63:      * @param clazz the Class upon which to perform the unsafe check.
  64:      * @return true if parameter is Unsafe or a descendant, false otherwise
  65:      */
  66:     static boolean unsafeOrDescendant(final Class clazz) {
  67:         return (_clazzUnsafe != null ? _clazzUnsafe.isAssignableFrom(clazz) : false);
  68:     }
  69: 
  70:     /**
  71:      * Instantiate an instance of the Unsafe class.
  72:      *
  73:      * @return class if available, null otherwise
  74:      */
  75:     private static Class instantiateClazzUnsafe() {
  76:         Class clazz;
  77: 
  78:         try {
  79:             clazz = Class.forName("sun.misc.Unsafe");
  80:         } catch (Throwable t) {
  81:             clazz = null;
  82:         }
  83: 
  84:         return clazz;
  85:     }
  86: 
  87:     /**
  88:      * Instantiate an instance of Unsafe object.
  89:      *
  90:      * @param clazz (expected to be an Unsafe instance)
  91:      * @return instance if available, null otherwise
  92:      */
  93:     private static Object instantiateUnsafeInstance(Class clazz) {
  94:         Object unsafe;
  95: 
  96:         if (clazz != null) {
  97:             Field field = null;
  98:             try {
  99:                 field = clazz.getDeclaredField("theUnsafe");
  100:                 field.setAccessible(true);
  101:                 unsafe = field.get(null);
  102:             } catch (Throwable t) {
  103:                 unsafe = null;
  104:             } finally {
