  4047:     static int parseMajorJavaVersion(String versionString) {
  4048:         int majorVersion = -1;
  4049:         try {
  4050:             if (versionString != null && versionString.length() > 0) {
  4051:                 final String[] sections = versionString.split("[\\.\\-\\+]");
  4052:                 final int firstSection;
  4053:                 final int secondSection;
  4054:                 if (sections.length > 0) {  // Should not happen, guard anyway
  4055:                     if (sections[0].length() > 0) {
  4056:                         if (sections.length > 1  && sections[1].length() > 0) {
  4057:                             firstSection = Integer.parseInt(sections[0]);
  4058:                             if (sections[1].matches("\\d+")) {
  4059:                                 secondSection = Integer.parseInt(sections[1]);
  4060:                             } else {
  4061:                                 secondSection = -1;
  4062:                             }
  4063:                         } else  {
  4064:                             firstSection = Integer.parseInt(sections[0]);
  4065:                             secondSection = -1;
  4066:                         }
  4067:                         if (firstSection == 1 && secondSection != -1) {
  4068:                             majorVersion = secondSection;  // Pre-JDK 9 versioning
  4069:                         } else {
  4070:                             majorVersion = firstSection;   // JDK9+ versioning
  4071:                         }
  4072:                     }
  4073:                 }
  4074:             }
  4075:         } catch (Exception ex) {
  4076:             // Unavailable (NumberFormatException, etc.)
  4077:         }
  4078:         if (majorVersion == -1) {
  4079:             majorVersion = 5;  // Return minimum supported Java version for OGNL
  4080:         }
  4081: 
  4082:         return majorVersion;
  4083:     }
