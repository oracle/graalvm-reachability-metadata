[tool-call] delta {"command":"python3 - <<'PY'\nimport urllib.request, zipfile, io, re\nversion='3.3.5'\nbase=f'https://repo1.maven.org/maven2/ognl/ognl/{version}/ognl-{version}'\nfor suffix in ['-sources.jar','.jar']:\n    url=base+suffix\n    print('---',url)\n    data=urllib.request.urlopen(url, timeout=30).read()\n    z=zipfile.ZipFile(io.BytesIO(data))\n    names=z.namelist()\n    print('entries', len(names), 'sample', names[:10])\n    for pattern in ['security.manager','add-opens','javassist','ClassPool','OgnlRuntime','AccessibleObjectHandler']:\n        hits=[]\n        for n in names:\n            if n.endswith(('.java','.properties','.xml','.MF')):\n                txt=z.read(n).decode(errors='ignore')\n                if pattern in txt:\n                    hits.append(n)\n        if hits:\n            print(pattern, hits[:20])\n    if suffix == '-sources.jar':\n        for n in ['ognl/OgnlRuntime.java','ognl/security/OgnlSecurityManager.java','ognl/AccessibleObjectHandlerJDK9Plus.java','ognl/ExpressionCompiler.java']:\n            print('\\n###', n)\n            txt=z.read(n).decode(errors='replace')\n            for line in txt.splitlines():\n                if any(s in line for s in ['security.manager','setAccessible','trySetAccessible','InaccessibleObjectException','javassist','ClassPool','defineClass','add-opens','AccessibleObjectHandler']):\n                    print(line[:200])\nPY","timeout":60}
