                       </goals>\n                        <configuration>\n                            <source>1.7</source>\n                            <target>1.7</target>\n                        </configuration>\n                    </execution>\n                </executions>\n            </plugin>\n            <plugin>\n                <groupId>org.apache.maven.plugins</groupId>\n                <artifactId>maven-surefire-plugin</artifactId>\n                <version>2.22.2</version>  <!-- Most recent 2.x available -->\n                <configuration>\n                    <excludes>\n                        <exclude>**/OgnlTestCase.java</exclude>\n                        <exclude>**/Java8Test.java</exclude>\n                        <exclude>**/*$*</exclude>\n                    </excludes>\n                    <includes>\n                        <include>**/*Test.java</include>\n                        <include>**/TestOgnlRuntime.java</include>\n                        <include>**/TestOgnlException.java</include>\n                        <include>**/TestExpressionCompiler.java</include>\n                    </includes>\n                </configuration>\n            </plugin>\n            <plugin>\n                <groupId>org.apache.maven.plugins</groupId>\n                <artifactId>maven-jar-plugin</artifactId>\n                <version>3.1.0</version>\n                <configuration>\n                    <archive>\n                        <compress>true</compress>\n                        <index>true</index>\n                        <manifestEntries>\n                            <Automatic-Module-Name>ognl</Automatic-Module-Name>\n                        </manifestEntries>\n                    </archive>\n                </configuration>\n            </plugin>\n            <plugin>\n                <groupId>org.apache.maven.plugins</groupId>\n                <artifactId>maven-source-plugin</artifactId>\n                <version>3.0.1</version>\n             