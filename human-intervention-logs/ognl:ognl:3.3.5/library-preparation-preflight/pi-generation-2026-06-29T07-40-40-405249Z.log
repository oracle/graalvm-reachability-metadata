tors and commenters for the information contained in the preceding links.\n42:  *\n43:  * @since 3.1.24\n44:  */\n45: class AccessibleObjectHandlerJDK9Plus implements AccessibleObjectHandler\n46: {\n47:     private static final Class _clazzUnsafe = instantiateClazzUnsafe();\n48:     private static final Object _unsafeInstance = instantiateUnsafeInstance(_clazzUnsafe);\n49:     private static final Method _unsafeObjectFieldOffsetMethod = instantiateUnsafeObjectFieldOffsetMethod(_clazzUnsafe);\n50:     private static final Method _unsafePutBooleanMethod = instantiateUnsafePutBooleanMethod(_clazzUnsafe);\n51:     private static final Field _accessibleObjectOverrideField = instantiateAccessibleObjectOverrideField();\n52:     private static final long _accessibleObjectOverrideFieldOffset = determineAccessibleObjectOverrideFieldOffset();\n53: \n54:     /**\n55:      * Private constructor\n56:      */\n57:     private AccessibleObjectHandlerJDK9Plus() {}\n58: \n59:     /**\n60:      * Package-accessible method to determine if a given class is Unsafe or a descendant\n61:      *   of Unsafe.\n62:      *\n63:      * @param clazz the Class upon which to perform the unsafe check.\n64:      * @return true if parameter is Unsafe or a descendant, false otherwise\n65:      */\n66:     static boolean unsafeOrDescendant(final Class clazz) {\n67:         return (_clazzUnsafe != null ? _clazzUnsafe.isAssignableFrom(clazz) : false);\n68:     }\n69: \n70:     /**\n71:      * Instantiate an instance of the Unsafe class.\n72:      *\n73:      * @return class if available, null otherwise\n74:      */\n75:     private static Class instantiateClazzUnsafe() {\n76:         Class clazz;\n77: \n78:         try {\n79:             clazz = Class.forName(\"sun.misc.Unsafe\");\n80:         } catch (Throwable t) {\n81:             clazz = null;\n82:         }\n83: \n84:         return clazz;\n85:     }\n86: \n87:     /**\n88:      * Instantiate an instance of Unsafe object.\n89:      *\n90:      * @param clazz (expected to be an Unsafe instance)\n91:      * @return instance if available, null otherwise\n92:      */\n93:     private static Object instantiateUnsafeInstance(Class clazz) {\n94:         Object unsafe;\n95: \n96:         if (clazz != null) {\n97:             Field field = null;\n98:             try {\n99:                 field = clazz.getDeclaredField(\"theUnsafe\");\n100:                 field.setAccessible(true);\n101:                 unsafe = field.get(null);\n102:             } catch (Throwable t) {\n103:                 unsafe = null;\n104:             } finally {\n105:                 if (field != null) {\n106:                     try {\n107:                         field.setAccessible(false);\n108:                     } catch (Throwable t) {\n109:                         // Don't care\n110:                     }\n111:                 }\n112:             }\n113:         } else {\n114:             unsafe = null;\n115:         }\n116: \n117:         return unsafe;\n118:     }\n119: \n120:     /**\n121:      * Instantiate an Unsafe.objectFieldOffset() method instance.\n122:      *\n123:      * @param clazz (expected to be an Unsafe instance)\n124:      * @return method if available, null otherwise\n125:      */\n126:     private static Method instantiateUnsafeObjectFieldOffsetMethod(Class clazz) {\n127:         Method method;\n128: \n129:         if (clazz != null) {\n130:             try {\n131:                 method = clazz.getMethod(\"objectFieldOffset\", Field.class);\n132:             } catch (Throwable t) {\n133:                 method = null;\n134:             }\n135:         } else {\n136:             method = null;\n137:         }\n138: \n139:         return method;\n140:     }\n141: \n142:     /**\n143:      * Instantiate an Unsafe.putBoolean() method instance.\n144:      *\n145:      * @param clazz (expected to be an Unsafe instance)\n146:      * @return method if available, null otherwise\n147:      */\n148:     private static Method instantiateUnsafePutBooleanMethod(Class clazz) {\n149:         Method method;\n150: \n151:         if (clazz != null) {\n152:             try {\n153:                 method = clazz.getMethod(\"putBoolean\", Object.class, long.class, boolean.class);\n154:             } catch (Throwable t) {\n155:                 method = null;\n156:             }\n157:         } else {\n158:             method = null;\n159:         }\n160: \n161:         return method;\n162:     }\n163: \n164:     /**\n165:      * Instantiate an AccessibleObject override field instance.\n166:      *\n167:      * @return field if available, null otherwise\n168:      */\n169:     private static Field instantiateAccessibleObjectOverrideField() {\n170:         Field field;\n171: \n172:         try {\n173:             field = AccessibleObject.class.getDeclaredField(\"override\");\n174:         } catch (Throwable t) {\n175:             field = null;\n176:         }\n177: \n178:         return field;\n179:     }\n180: \n181:     /**\n182:      * Attempt to determined the AccessibleObject override field offset.\n183:      *\n184:      * @return field offset if available, -1 otherwise\n185:      */\n186:     private static long determineAccessibleObjectOverrideFieldOffset() {\n187:         long offset = -1;\n188: \n189:         if (_accessibleObjectOverrideField != null && _unsafeObjectFieldOffsetMethod != null && _unsafeInstance != null) {\n190:             try {\n191:                 offset = (Long) _unsafeObjectFieldOffsetMethod.invoke(_unsafeInstance, _accessibleObjectOverrideField);\n192:             } catch (Throwable t) {\n193:                 // Don't care (offset already -1)\n194:             }\n195:         }\n196: \n197:         return offset;\n198:     }\n199: \n200:     /**\n201:      * Package-level generator of an AccessibleObjectHandlerJDK9Plus instance.\n202:      *\n203:      * Not intended for use outside of the package.\n204:      *\n205:      * Note: An AccessibleObjectHandlerJDK9Plus will only be created if running on a\n206:      *   JDK9+ and the environment flag is set.  Otherwise this method will return\n207:      *   an AccessibleHandlerPreJDK9 instance instead,\n208:      *\n209:      * @return an AccessibleObjectHandler instance\n210:      *\n211:      * @since 3.1.24\n212:      */\n213:     static AccessibleObjectHandler createHandler() {\n214:         if (OgnlRuntime.usingJDK9PlusAccessHandler()){\n215:             return new AccessibleObjectHandlerJDK9Plus();\n216:         } else {\n217:             return AccessibleObjectHandlerPreJDK9.createHandler();\n218:         }\n219:     }\n220: \n221:     /**\n222:      * Utilize accessibility modification mechanism for JDK 9 (Java Major Version 9) and later.\n223:      *   Should that mechanism fail, attempt a standard pre-JDK9 accessibility modification.\n224:      *\n225:      * @param accessibleObject the AccessibleObject upon which to apply the flag.\n226:      * @param flag the new accessible flag value.\n227:      */\n228:     public void setAccessible(AccessibleObject accessibleObject, boolean flag) {\n229:         boolean operationComplete = false;\n230: \n231:         if (_unsafeInstance != null && _unsafePutBooleanMethod != null && _accessibleObjectOverrideFieldOffset != -1) {\n232:             try {\n233:                 _unsafePutBooleanMethod.invoke(_unsafeInstance, accessibleObject, _accessibleObjectOverrideFieldOffset, flag);\n234:                 operationComplete = true;\n235:             } catch (Throwable t) {\n236:                 // Don't care (operationComplete already false)\n237:             }\n238:         }\n239:         if (!operationComplete) {\n240:             // Fallback to standard reflection if Unsafe processing fails\n241:             accessibleObject.setAccessible(flag);\n242:         }\n243:     }\n244: \n245: }\n"}], "isError": false, "timestamp": 1782718784884}}
