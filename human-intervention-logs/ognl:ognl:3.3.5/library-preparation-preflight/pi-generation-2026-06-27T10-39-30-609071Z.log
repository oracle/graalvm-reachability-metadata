[assistant]   "summary": "OGNL is a pure in-process expression/reflection library; no extra Maven dependency or Docker service is needed, but meaningful coverage on modern JDKs should run tests with module opens because OGNL and its own upstream JDK17+ test profile rely on reflective access to JDK packages.",
[assistant]   "deterministic_setup": [],
[assistant]   "agent_guidance": "Configure JVM test execution with `--add-opens=java.base/java.lang=ALL-UNNAMED` and `--add-opens=java.base/java.util=ALL-UNNAMED` when exercising OGNL reflective property/method access, map/list expressions, or expression compilation on JDK 17+. Do not set `ognl.security.manager` globally; if covering OGNL sandbox/security-manager paths, set and restore it inside the specific isolated test scenario, and make tests tolerate `System.setSecurityManager` being unsupported on newer JDKs.",
[assistant]   "risks": [
[assistant]     "OGNL 3.3.5 depends on `org.javassist:javassist:3.29.0-GA`, but it is a normal transitive runtime dependency of `ognl:ognl:3.3.5`, so adding it separately should not be necessary.",
[assistant]     "SecurityManager coverage is version-sensitive on JDK 25 and later; tests that require installing a SecurityManager instead of detecting unsupported installation can fail during Java run.",
[assistant]     "Javassist expression-compilation coverage may be harder under native image and should be guarded separately from basic expression evaluation if local native verification shows unsupported dynamic class generation."
[assistant]   ]
[assistant] }
