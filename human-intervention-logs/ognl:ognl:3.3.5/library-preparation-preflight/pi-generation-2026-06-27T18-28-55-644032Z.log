                                          </java>
                                      </target>
                                  </configuration>
                              </execution>
                          </executions>
                      </plugin>
                  </plugins>
              </build>
          </profile>
          <profile>
              <id>jdk17</id>
              <activation>
                  <jdk>[17,)</jdk>
              </activation>
              <build>
                  <pluginManagement>
                      <plugins>
