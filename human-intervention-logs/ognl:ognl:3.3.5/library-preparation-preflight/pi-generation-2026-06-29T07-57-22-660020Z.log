  package ognl;
  
  import java.lang.reflect.AccessibleObject;
  import java.lang.reflect.Field;
  import java.lang.reflect.Method;
  
  /**
   * Utilizes a JDK 9 and later mechanism for changing the accessibility level of a given
   *   AccessibleObject.
   *
