          Object unsafe;
  
          if (clazz != null) {
              Field field = null;
              try {
                  field = clazz.getDeclaredField("theUnsafe");
                  field.setAccessible(true);
                  unsafe = field.get(null);
              } catch (Throwable t) {
                  unsafe = null;
              } finally {
