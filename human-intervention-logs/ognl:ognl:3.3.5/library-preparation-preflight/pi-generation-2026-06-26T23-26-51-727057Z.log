                          <index>true</index>
                          <manifestEntries>
                              <Automatic-Module-Name>ognl</Automatic-Module-Name>
                          </manifestEntries>
                      </archive>
                  </configuration>
              </plugin>
              <plugin>
                  <groupId>org.apache.maven.plugins</groupId>
                  <artifactId>maven-source-plugin</artifactId>
