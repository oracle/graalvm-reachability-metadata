                  </plugins>
              </build>
          </profile>
          <profile>
              <id>jdk17</id>
              <activation>
                  <jdk>[17,)</jdk>
              </activation>
              <build>
                  <pluginManagement>
                      <plugins>
                          <plugin>
                              <groupId>org.apache.maven.plugins</groupId>
  
