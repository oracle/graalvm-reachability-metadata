"https://github.com/jboss-javassist/javassist\",\nmetadata/javassist/javassist/index.json:7:    \"test-code-url\" : \"https://github.com/jboss-javassist/javassist/tree/rel_3_12_0_ga/src/test?version=$version$\",\nmetadata/javassist/javassist/index.json:8:    \"documentation-url\" : \"https://github.com/jboss-javassist/javassist/blob/rel_3_12_0_ga/tutorial/tutorial.html?version=$version$\",\nmetadata/javassist/javassist/index.json:9:    \"description\" : \"Javassist is a Java bytecode manipulation library that lets programs inspect, modify, and generate classes at runtime or build time. It provides source-level and bytecode-level APIs for editing methods, fields, annotations, class files, and proxies without requiring direct bytecode assembly.\",\nmetadata/javassist/javassist/index.json:15:      \"javassist\"\nmetadata/javassist/javassist/index.json:20:    \"source-code-url\" : \"https://repo.maven.apache.org/maven2/javassist/javassist/$version$/javassist-$version$-sources.jar\",\nmetadata/javassist/javassist/index.json:21:    \"repository-url\" : \"https://github.com/jboss-javassist/javassist\",\nmetadata/javassist/javassist/index.json:24:    \"description\" : \"Javassist is a Java bytecode manipulation library that lets programs inspect, modify, and generate classes at runtime or build time. It provides source-level and bytecode-level APIs for editing methods, fields, annotations, class files, and proxies without requiring direct bytecode assembly.\",\nmetadata/javassist/javassist/index.json:29:      \"javassist\"\nmetadata/org.jboss.weld/weld-api/index.json:9:    \"description\" : \"Weld API provides Weld-specific extensions to the CDI API for Java applications. It defines context, conversation, servlet, and related dependency injection integration interfaces used by Weld-based runtimes.\",\nmetadata/org.jboss.weld/weld-api/index.json:38:    \"description\" : \"Weld API provides Weld-specific extensions to the CDI API for Java applications. It defines context, conversation, servlet, and related dependency injection integration interfaces used by Weld-based runtimes.\",\nmetadata/org.jboss.weld/weld-api/index.json:52:    \"description\" : \"Weld API provides Weld-specific extensions to the CDI API for Java EE applications. It defines interfaces for contexts, conversations, servlet integration, and other dependency injection integration points used by Weld-based runtimes.\",\nmetadata/org.jboss.weld/weld-api/index.json:75:    \"description\" : \"Weld API provides Weld-specific extensions to the CDI API for Java EE applications. It defines interfaces for Weld-managed contexts, conversations, servlet integration, and related dependency injection integration points.\",\nmetadata/javassist/javassist/3.12.0.GA/reachability-metadata.json:5:        \"typeReached\" : \"javassist.util.HotSwapper\"\nmetadata/javassist/javassist/3.12.0.GA/reachability-metadata.json:11:        \"typeReached\" : \"javassist.util.HotSwapper\"\nmetadata/javassist/javassist/3.12.0.GA/reachability-metadata.json:17:        \"typeReached\" : \"javassist.util.HotSwapper\"\nmetadata/javassist/javassist/3.12.0.GA/reachability-metadata.json:23:        \"typeReached\" : \"javassist.util.HotSwapper\"\nmetadata/javassist/javassist/3.12.0.GA/reachability-metadata.json:29:        \"typeReached\" : \"javassist.util.HotSwapper\"\nmetadata/javassist/javassist/3.12.0.GA/reachability-metadata.json:35:        \"typeReached\" : \"javassist.util.HotSwapper\"\nmetadata/javassist/javassist/3.12.0.GA/reachability-metadata.json:41:        \"typeReached\" : \"javassist.Loader\"\nmetadata/javassist/javassist/3.12.0.GA/reachability-metadata.json:47:        \"typeReached\" : \"javassist.tools.web.Viewer\"\nmetadata/javassist/javassist/3.12.0.GA/reachability-metadata.json:53:        \"typeReached\" : \"javassist.util.proxy.SecurityActions\"\nmetadata/javassist/javassist/3.12.0.GA/reachability-metadata.json:59:        \"typeReached\" : \"javassist.tools.rmi.AppletServer\"\nmetadata/javass