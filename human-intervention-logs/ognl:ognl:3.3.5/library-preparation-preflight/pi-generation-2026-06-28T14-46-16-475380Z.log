  1240:             return method.invoke(target, argsArray);  // Feature was disabled at OGNL initialization.
  1241:         }
  1242: 
  1243:         try {
  1244:             if (System.getProperty(OGNL_SECURITY_MANAGER) == null) {
  1245:                 return method.invoke(target, argsArray);
  1246:             }
  1247:         } catch (SecurityException ignored) {
  1248:             // already enabled or user has applied a policy that doesn't allow read property so we have to honor user's sandbox
  1249:         }
