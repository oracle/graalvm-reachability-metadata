  1256:         // creating object before entering sandbox to load classes out of the sandbox
  1257:         UserMethod userMethod = new UserMethod(target, method, argsArray);
  1258:         Permissions p = new Permissions(); // not any permission
  1259:         ProtectionDomain pd = new ProtectionDomain(null, p);
  1260:         AccessControlContext acc = new AccessControlContext(new ProtectionDomain[]{pd});
