  1251:         if (ClassLoader.class.isAssignableFrom(method.getDeclaringClass())) {
  1252:             // to support OgnlSecurityManager.isAccessDenied
  1253:             throw new IllegalAccessException("OGNL direct access to class loader denied!");
  1254:         }
