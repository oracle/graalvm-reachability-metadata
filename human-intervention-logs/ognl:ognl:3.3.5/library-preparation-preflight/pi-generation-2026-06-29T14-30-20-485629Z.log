                                              <arg value="${project.basedir}/src/etc/ognl.jjt" />
                                          </java>
  
                                          <java classname="org.javacc.parser.Main" fork="true">
                                              <arg value="-OUTPUT_DIRECTORY=${project.build.sourceDirectory}/ognl" />
  
