            <include>**/TestOgnlException.java</include>\n                        <include>**/TestExpressionCompiler.java</include>\n                    </includes>\n                </configuration>\n            </plugin>\n            <plugin>\n                <groupId>org.apache.maven.plugins</groupId>\n                <artifactId>maven-jar-plugin</artifactId>\n                <version>3.2.2</version>\n                <configuration>\n                    <archive>\n                        <compress>true</compress>\n                        <index>true</index>\n                        <manifestEntries>\n                            <Automatic-Module-Name>ognl</Automatic-Module-Name>\n                        </manifestEntries>\n                    </archive>\n                </configuration>\n            </plugin>\n            <plugin>\n                <groupId>org.apache.maven.plugins</groupId>\n                <artifactId>maven-source-plugin</artifactId>\n                <version>3.2.1</version>\n                <configuration>\n                    <archive>\n                        <compress>true</compress>\n                        <index>true</index>\n                    </archive>\n                </configuration>\n                <executions>\n                    <execution>\n                        <goals>\n                            <goal>jar</goal>\n                        </goals>\n                    </execution>\n                </executions>\n            </plugin>\n            <plugin>\n                <groupId>org.apache.maven.plugins</groupId>\n                <artifactId>maven-javadoc-plugin</artifactId>\n                <version>3.4.0</version>\n                <configuration>\n                    <archive>\n                        <compress>true</compress>\n                        <index>true</index>\n                    </archive>\n                    <source>1.8</source>\n                    <links>\n                        <link>https://docs.oracle.com/javase/8/docs/api/</link>\n                    </links>\n                </configuration>\n                <executions>\n                    <execution>\n                        <goals>\n                            <goal>jar</goal>\n                        </goals>\n                    </execution>\n                </executions>\n            </plugin>\n            <plugin>\n                <groupId>org.apache.maven.plugins</groupId>\n                <artifactId>maven-clean-plugin</artifactId>\n                <version>3.2.0</version>  <!-- Most recent 2.x available -->\n            </plugin>\n        </plugins>\n\n        <defaultGoal>install</defaultGoal>\n\n    </build>\n\n    <profiles>\n        <profile>\n            <id>javacc-generate</id>\n            <build>\n                <plugins>\n                    <plugin>\n                        <groupId>org.apache.maven.plugins</groupId>\n                        <artifactId>maven-antrun-plugin</artifactId>\n                        <executions>\n                            <execution>\n                                <id>generate</id>\n                                <phase>generate-sources</phase>\n                                <goals>\n                                    <goal>run</goal>\n                                </goals>\n                                <configuration>\n                                    <target>\n                                        <java classname=\"org.javacc.jjtree.Main\" fork=\"true\">\n                                            <arg value=\"-OUTPUT_DIRECTORY=${project.build.sourceDirectory}/ognl\" />\n                                            <arg value=\"${project.basedir}/src/etc/ognl.jjt\" />\n                                        </java>\n\n                                        <java classname=\"org.javacc.parser.Main\" fork=\"true\">\n                                            <arg value=\"-OUTPUT_DIRECTORY=${project.build.sourceDirectory}/ognl\" />\n                                            <arg value=\"${project.basedir}/src/etc/ognl.jj\" />\n                                        </java>\n                                    </target>\n                                </configuration>\n                            </execution>\n                        </executions>\n                    </plugin>\n                </plugins>\n            </build>\n        </profile>\n        <profile>\n            <id>jdk17</id>\n            <activation>\n                <jdk>[17,)</jdk>\n            </activation>\n            <build>\n                <pluginManagement>\n                    <plugins>\n                        <plugin>\n                            <groupId>org.apache.maven.plugins</groupId>\n                            <artifactId>maven-surefire-plugin</artifactId>\n                            <configuration>\n                                <argLine>\n                                    --illegal-access=permit\n                                    --add-opens java.base/java.lang=ALL-UNNAMED\n                                    --add-opens java.base/java.util=ALL-UNNAMED\n                                    -Dillegal-access=permit\n                                </argLine>\n                            </configuration>\n                        </plugin>\n                    </plugins>\n                </pluginManagement>\n            </build>\n        </profile>\n    </profiles>\n\n</project>\n"}], "isError": false, "timestamp": 1782667647793}}
