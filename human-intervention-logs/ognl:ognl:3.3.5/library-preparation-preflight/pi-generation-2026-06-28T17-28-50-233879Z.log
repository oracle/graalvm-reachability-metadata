       1	package ognl.security;
       2	
       3	import java.io.FilePermission;
       4	import java.security.*;
       5	import java.util.ArrayList;
       6	import java.util.List;
       7	
       8	/**
       9	 * Wraps current security manager with JDK security manager if is inside OgnlRuntime user's methods body execution.
      10	 *
      11	 * Add the `-Dognl.security.manager` to JVM options to enable.
      12	 *
      13	 * <p> Note: Due to potential performance and concurrency issues, try this only if you afraid your app can have an
      14	 * unknown "expression injection" flaw or you afraid you cannot prevent those in your app's internal sandbox
      15	 * comprehensively e.g. you cannot discover and maintain all attack vectors over time because of many dependencies
      16	 * and also their change over time.</p>
      17	 *
      18	 * <p> This tries to provide an option to you to enable a security manager that disables any sensitive action e.g.
      19	 * exec and exit even if attacker had a successful "expression injection" in any unknown way into your app. However,
      20	 * also honors previous security manager and policies if any set, as parent, and rolls back to them after method
      21	 * execution finished.</p>
      22	 *
      23	 * @author Yasser Zamani
      24	 * @since 3.1.24
      25	 */
      26	public class OgnlSecurityManager extends SecurityManager {
      27	    private static final String OGNL_SANDBOX_CLASS_NAME = "ognl.security.UserMethod";
      28	    private static final Class<?> CLASS_LOADER_CLASS = ClassLoader.class;
      29	    private static final Class<?> FILE_PERMISSION_CLASS = FilePermission.class;
      30	
      31	    private SecurityManager parentSecurityManager;
      32	    private List<Long> residents = new ArrayList<Long>();
      33	    private SecureRandom rnd = new SecureRandom();
      34	
      35	    public OgnlSecurityManager(SecurityManager parentSecurityManager) {
      36	        this.parentSecurityManager = parentSecurityManager;
      37	    }
      38	
      39	    private boolean isAccessDenied(Permission perm) {
      40	        Class[] classContext = getClassContext();
      41	        Boolean isInsideClassLoader = null;
      42	        for (Class c : classContext) {
      43	            if (isInsideClassLoader == null && CLASS_LOADER_CLASS.isAssignableFrom(c)) {
      44	                if (FILE_PERMISSION_CLASS.equals(perm.getClass()) && "read".equals(perm.getActions())) {
      45	                    // TODO: might be risky but we have to - fix it if any POC discovered
      46	                    // relax a bit with containers class loaders lazy class load
      47	                    return false;
      48	                } else {
      49	                    isInsideClassLoader = false;
      50	                }
      51	            }
      52	            if (OGNL_SANDBOX_CLASS_NAME.equals(c.getName())) {
      53	                return true;
      54	            }
      55	        }
      56	        return false;
      57	    }
      58	
      59	    @Override
      60	    public void checkPermission(Permission perm) {
      61	        if (parentSecurityManager != null) {
      62	            parentSecurityManager.checkPermission(perm);
      63	        }
      64	        if (isAccessDenied(perm)) {
      65	            super.checkPermission(perm);
      66	        }
      67	    }
      68	
      69	    @Override
      70	    public void checkPermission(Permission perm, Object context) {
      71	        if (parentSecurityManager != null) {
      72	            parentSecurityManager.checkPermission(perm, context);
      73	        }
      74	        if (isAccessDenied(perm)) {
      75	            super.checkPermission(perm, context);
      76	        }
      77	    }
      78	
      79	    public Long enter() {
      80	        synchronized (this) {
      81	            long token = rnd.nextLong();
      82	            if (residents.size() == 0) {
      83	                if (install()) {
      84	                    residents.add(token);
      85	                    return token;
      86	                } else {
      87	                    return null;
      88	                }
      89	            }
      90	            residents.add(token);
      91	            return token;
      92	        }
      93	    }
      94	
      95	    public void leave(long token) throws SecurityException {
      96	        synchronized (this) {
      97	            if (!residents.contains(token)) {
      98	                throw new SecurityException();
      99	            }
     100	            residents.remove(token);
     101	            if (residents.size() == 0) {
     102	                // no user so roll back to previous state to save performance
     103	                uninstall();
     104	            }
     105	        }
     106	    }
     107	
     108	    private boolean install() {
     109	        try {
     110	            System.setSecurityManager(this);
     111	        } catch (SecurityException ex) {
     112	            // user has applied a policy that doesn't allow setSecurityManager so we have to honor user's sandbox
     113	            return false;
     114	        }
     115	
     116	        return true;
     117	    }
     118	
     119	    private void uninstall() {
     120	        System.setSecurityManager(parentSecurityManager);
     121	    }
     122	}
