stemConsoleMethod = null;\n230:         try {\n231:             setAccessibleMethod = AccessibleObject.class.getMethod(\"setAccessible\", new Class<?>[]{boolean.class});\n232:         } catch (NoSuchMethodException nsme) {\n233:             // Should not happen.  To debug, uncomment the next line.\n234:             //throw new IllegalStateException(\"OgnlRuntime initialization missing setAccessible method\", nsme);\n235:         } catch (SecurityException se) {\n236:             // May be blocked by existing SecurityManager.  To debug, uncomment the next line.\n237:             //throw new SecurityException(\"OgnlRuntime initialization cannot access setAccessible method\", se);\n238:         } finally {\n239:             AO_SETACCESSIBLE_REF = setAccessibleMethod;\n240:         }\n241: \n242:         try {\n243:             setAccessibleMethodArray = AccessibleObject.class.getMethod(\"setAccessible\", new Class<?>[]{AccessibleObject[].class, boolean.class});\n244:         } catch (NoSuchMethodException nsme) {\n245:             // Should not happen.  To debug, uncomment the next line.\n246:             //throw new IllegalStateException(\"OgnlRuntime initialization missing setAccessible method\", nsme);\n247:         } catch (SecurityException se) {\n248:             // May be blocked by existing SecurityManager.  To debug, uncomment the next line.\n249:             //throw new SecurityException(\"OgnlRuntime initialization cannot access setAccessible method\", se);\n250:         } finally {\n251:             AO_SETACCESSIBLE_ARR_REF = setAccessibleMethodArray;\n252:         }\n253: \n254:         try {\n255:             systemExitMethod = System.class.getMethod(\"exit\", new Class<?>[]{int.class});\n256:         } catch (NoSuchMethodException nsme) {\n257:             // Should not happen.  To debug, uncomment the next line.\n258:             //throw new IllegalStateException(\"OgnlRuntime initialization missing exit method\", nsme);\n259:         } catch (SecurityException se) {\n260:             // May be blocked by existing SecurityManager.  To debug, uncomment the next line.\n261:             //throw new SecurityException(\"OgnlRuntime initialization cannot access exit method\", se);\n262:         } finally {\n263:             SYS_EXIT_REF = systemExitMethod;\n264:         }\n265: \n266:         try {\n267:             systemConsoleMethod = System.class.getMethod(\"console\", new Class<?>[]{});  // Not available in JDK 1.5 or earlier\n268:         } catch (NoSuchMethodException nsme) {\n269:             // May happen for JDK 1.5 and earlier.  To debug, uncomment the next line.\n270:             //throw new IllegalStateException(\"OgnlRuntime initialization missing console method\", nsme);\n271:         } catch (SecurityException se) {\n272:             // May be blocked by existing SecurityManager.  To debug, uncomment the next line.\n273:             //throw new SecurityException(\"OgnlRuntime initialization cannot access console method\", se);\n274:         } finally {\n275:             SYS_CONSOLE_REF = systemConsoleMethod;\n276:         }\n277:     }\n278: \n279:     /**\n280:      * Control usage of the OGNL Security Manager using the JVM option:\n281:      *   -Dognl.security.manager=true  (or any non-null value other than 'disable')\n282:      *\n283:      * Omit '-Dognl.security.manager=' or nullify the property to disable the feature.\n284:      *\n285:      * To forcibly disable the feature (only possible at OGNL Library initialization, use the option:\n286:      *   -Dognl.security.manager=forceDisableOnInit\n287:      *\n288:      * Users that have their own Security Manager implementations and no intention to use the OGNL SecurityManager\n289:      *   sandbox may choose to use the 'forceDisableOnInit' flag option for performance reasons (avoiding overhead\n290:      *   involving the system property security checks - when that feature will not be used).\n291:      */\n292:     static final String OGNL_SECURIT