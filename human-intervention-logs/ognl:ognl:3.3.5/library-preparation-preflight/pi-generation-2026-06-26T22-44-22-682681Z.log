ler();\n387:         } catch (ClassNotFoundException e) {\n388:             throw new IllegalArgumentException(\"Javassist library is missing in classpath! Please add missed dependency!\",e);\n389:         } catch (RuntimeException rt) {\n390:             throw new IllegalStateException(\"Javassist library cannot be loaded, is it restricted by runtime environment?\");\n391:         }\n392:     }\n393: \n394:     private static final Class[] EMPTY_CLASS_ARRAY = new Class[0];\n395: \n396:     private static IdentityHashMap PRIMITIVE_WRAPPER_CLASSES = new IdentityHashMap();\n397: \n398:     /**\n399:      * Used to provide primitive type equivalent conversions into and out of\n400:      * native / object types.\n401:      */\n402:     static {\n403:         PRIMITIVE_WRAPPER_CLASSES.put(Boolean.TYPE, Boolean.class);\n404:         PRIMITIVE_WRAPPER_CLASSES.put(Boolean.class, Boolean.TYPE);\n405:         PRIMITIVE_WRAPPER_CLASSES.put(Byte.TYPE, Byte.class);\n406:         PRIMITIVE_WRAPPER_CLASSES.put(Byte.class, Byte.TYPE);\n407:         PRIMITIVE_WRAPPER_CLASSES.put(Character.TYPE, Character.class);\n408:         PRIMITIVE_WRAPPER_CLASSES.put(Character.class, Character.TYPE);\n409:         PRIMITIVE_WRAPPER_CLASSES.put(Short.TYPE, Short.class);\n410:         PRIMITIVE_WRAPPER_CLASSES.put(Short.class, Short.TYPE);\n1215:                     _accessibleObjectHandler.setAccessible(method, false);\n1216:                 }\n1217:             }\n1218:         } else\n1219:         {\n1220:             if (checkPermission)\n1221:             {\n1222:                 try\n1223:                 {\n1224:                     _securityManager.checkPermission(getPermission(method));\n1225:                 } catch (SecurityException ex) {\n1226:                     throw new IllegalAccessException(\"Method [\" + method + \"] cannot be accessed.\");\n1227:                 }\n1228:             }\n1229: \n1230:             result = invokeMethodInsideSandbox(target, method, argsArray);\n