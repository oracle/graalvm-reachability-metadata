ajorVersion = -1;\n4025:         try {\n4026:             majorVersion = parseMajorJavaVersion(System.getProperty(\"java.version\"));\n4027:         } catch (Exception ex) {\n4028:             // Unavailable (SecurityException, etc.)\n4029:         }\n4030:         if (majorVersion == -1) {\n4031:             majorVersion = 5;  // Return minimum supported Java version for OGNL\n4032:         }\n4033: \n4034:         return majorVersion;\n4035:     }\n\n--- ognl/AccessibleObjectHandlerJDK9Plus.java\n150: \n151:         if (clazz != null) {\n152:             try {\n153:                 method = clazz.getMethod(\"putBoolean\", Object.class, long.class, boolean.class);\n154:             } catch (Throwable t) {\n155:                 method = null;\n156:             }\n157:         } else {\n158:             method = null;\n159:         }\n160: \n161:         return method;\n162:     }\n163: \n164:     /**\n165:      * Instantiate an AccessibleObject override field instance.\n166:      *\n167:      * @return field if available, null otherwise\n168:      */\n169:     private static Field instantiateAccessibleObjectOverrideField() {\n170:         Field field;\n171: \n172:         try {\n173:             field = AccessibleObject.class.getDeclaredField(\"override\");\n174:         } catch (Throwable t) {\n175:             field = null;\n176:         }\n177: \n178:         return field;\n179:     }\n180: \n181:     /**\n182:      * Attempt to determined the AccessibleObject override field offset.\n183:      *\n184:      * @return field offset if available, -1 otherwise\n185:      */\n186:     private static long determineAccessibleObjectOverrideFieldOffset() {\n187:         long offset = -1;\n188: \n189:         if (_accessibleObjectOverrideField != null && _unsafeObjectFieldOffsetMethod != null && _unsafeInstance != null) {\n190:             try {\n191:                 offset = (Long) _unsafeObjectFieldOffsetMethod.invoke(_unsafeInstance, _accessibleObjectOverrideField);\n192:             } catch (Throwable t) {\n193:                 // Don't care (offset already -1)\n194:             }\n195:         }\n196: \n197:         return offset;\n198:     }\n199: \n200:     /**\n201:      * Package-level generator of an AccessibleObjectHandlerJDK9Plus instance.\n202:      *\n203:      * Not intended for use outside of the package.\n204:      *\n205:      * Note: An AccessibleObjectHandlerJDK9Plus will only be created if running on a\n206:      *   JDK9+ and the environment flag is set.  Otherwise this method will return\n207:      *   an AccessibleHandlerPreJDK9 instance instead,\n208:      *\n209:      * @return an AccessibleObjectHandler instance\n210:      *\n211:      * @since 3.1.24\n212:      */\n213:     static AccessibleObjectHandler createHandler() {\n214:         if (OgnlRuntime.usingJDK9PlusAccessHandler()){\n215:             return new AccessibleObjectHandlerJDK9Plus();\n216:         } else {\n217:             return AccessibleObjectHandlerPreJDK9.createHandler();\n218:         }\n219:     }\n220: \n221:     /**\n222:      * Utilize accessibility modification mechanism for JDK 9 (Java Major Version 9) and later.\n223:      *   Should that mechanism fail, attempt a standard pre-JDK9 accessibility modification.\n224:      *\n225:      * @param accessibleObject the AccessibleObject upon which to apply the flag.\n226:      * @param flag the new accessible flag value.\n227:      */\n228:     public void setAccessible(AccessibleObject accessibleObject, boolean flag) {\n229:         boolean operationComplete = false;\n230: \n231:         if (_unsafeInstance != null && _unsafePutBooleanMethod != null && _accessibleObjectOverrideFieldOffset != -1) {\n232:             try {\n233:                 _unsafePutBooleanMethod.invoke(_unsafeInstance, accessibleObject, _accessibleObjectOverrideFieldOffset, flag);\n234:                 operationComplete = true;\n235:             } catch (Throwable t) {\n236:                 // Don't care (operationComplete already false)\n237:             }\n238:         }\n239:         if (!operationComplete) {\n240:             // Fallback to standard reflection if Unsafe processing fails\n241:             accessibleObject.setAccessible(flag);\n242:         }\n243:     }\n244: \n245: }\n\n--- ognl/OgnlContext.java\n150: \n151:     /**\n152:      * Set (put) the provided value map content into the existing values Map for this OgnlContext.\n153:      * \n154:      * @param value a Map of additional values to put into this OgnlContext.\n155:      */\n156:     public void setValues(Map value)\n157:     {\n158:         for (Object k : value.keySet()) {\n159:             _values.put(k, value.get(k));\n160:         }\n161:     }\n162: \n163:     /**\n164:      * Get the values Map for this OgnlContext.\n165:      * \n166:      * @return Map of values for this OgnlContext.\n167:      */\n168:     public Map getValues()\n169:     {\n170:         return _values;\n171:     }\n172: \n173:     @Deprecated\n174:     public void setClassResolver(ClassResolver ignore) {\n175:         // no-op\n176:     }\n177: \n178:     public ClassResolver getClassResolver()\n179:     {\n180:         return _classResolver;\n181:     }\n182: \n183:     @Deprecated\n184:     public void setTypeConverter(TypeConverter ignore)\n185:     {\n186:         // no-op\n187:     }\n188: \n189:     public TypeConverter getTypeConverter()\n190:     {\n191:         return _typeConverter;\n192:     }\n193: \n194:     @Deprecated\n195:     public void setMemberAccess(MemberAccess ignore)\n196:     {\n197:         // no-op\n198:     }\n199: \n200:     public MemberAccess getMemberAccess()\n201:     {\n202:         return _memberAccess;\n203:     }\n204: \n205:     public void setRoot(Object value)\n206:     {\n207:         _root = value;\n208:         _accessorStack.clear();\n209:         _typeStack.clear();\n210:         _currentObject = value;\n211: \n212:         if (_currentObject != null)\n213:         {\n214:           