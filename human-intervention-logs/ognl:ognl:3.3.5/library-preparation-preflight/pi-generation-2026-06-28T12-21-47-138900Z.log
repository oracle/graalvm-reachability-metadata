  *   (in the event the \"stricter\" processing causes issues for existing applications).\n156:      */\n157:     static final String USE_STRICTER_INVOCATION = \"ognl.UseStricterInvocation\";\n158: \n159:     /**\n160:      * Hold environment flag state associated with USE_JDK9PLUS_ACESS_HANDLER.\n161:      *   Default: false (if not set)\n162:      */\n163:     private static final boolean _useJDK9PlusAccessHandler;\n164:     static {\n165:         boolean initialFlagState = false;\n166:         try {\n167:             final String propertyString = System.getProperty(USE_JDK9PLUS_ACESS_HANDLER);\n168:             if (propertyString != null && propertyString.length() > 0) {\n169:                 initialFlagState = Boolean.parseBoolean(propertyString);\n170:             }\n171:         } catch (Exception ex) {\n172:             // Unavailable (SecurityException, etc.)\n173:         }\n174:         _useJDK9PlusAccessHandler = initialFlagState;\n175:     }\n176: \n177:     /**\n178:      * Hold environment flag state associated with USE_STRICTER_INVOCATION.\n179:      *   Default: true (if not set)\n180:      */\n181:     private static final boolean _useStricterInvocation;\n182:     static {\n183:         boolean initialFlagState = true;\n184:         try {\n185:             final String propertyString = System.getProperty(USE_STRICTER_INVOCATION);\n186:             if (propertyString != null && propertyString.length() > 0) {\n187:                 initialFlagState = Boolean.parseBoolean(propertyString);\n188:             }\n189:         } catch (Exception ex) {\n190:             // Unavailable (SecurityException, etc.)\n191:         }\n192:         _useStricterInvocation = initialFlagState;\n193:     }\n194: \n195:     /*\n196:      * Attempt to detect the system-reported Major Java Version (e.g. 5, 7, 11).\n197:      */\n198:     private static final int _majorJavaVersion = detectMajorJavaVersion();\n199:     private static final boolean _jdk9Plus = _majorJavaVersion >= 9;\n200: \n201:     /*\n202:      * Assign an accessibility modification mechanism, based on Major Java Version and Java option flag\n203:      *   flag {@link OgnlRuntime#USE_JDK9PLUS_ACESS_HANDLER}.\n204:      *\n205:      * Note: Will use the standard Pre-JDK9 accessibility modification mechanism unless OGNL is running\n206:      *   on JDK9+ and the Java option flag has also been set true.\n207:      */\n208:     private static final AccessibleObjectHandler _accessibleObjectHandler;\n209:     static {\n210:         _accessibleObjectHandler = usingJDK9PlusAccessHandler() ? AccessibleObjectHandlerJDK9Plus.createHandler() :\n--- 260-350\n260:             // May be blocked by existing SecurityManager.  To debug, uncomment the next line.\n261:             //throw new SecurityException(\"OgnlRuntime initialization cannot access exit method\", se);\n262:         } finally {\n263:             SYS_EXIT_REF = systemExitMethod;\n264:         }\n265: \n266:         try {\n267:             systemConsoleMethod = System.class.getMethod(\"console\", new Class<?>[]{});  // Not available in JDK 1.5 or earlier\n268:         } catch (NoSuchMethodException nsme) {\n269:             // May happen for JDK 1.5 and earlier.  To debug, uncomment the next line.\n270:             //throw new IllegalStateException(\"OgnlRuntime initialization missing console method\", nsme);\n271:         } catch (SecurityException se) {\n272:             // May be blocked by existing SecurityManager.  To debug, uncomment the next line.\n273:             //throw new SecurityException(\"OgnlRuntime initialization cannot access console method\", se);\n274:         } finally {\n275:             SYS_CONSOLE_REF = systemConsoleMethod;\n276:         }\n277:     }\n278: \n279:     /**\n280:      * Control usage of the OGNL Security Manager using the JVM option:\n281:      *   -Dognl.security.manager=true  (or any non-null value other than 'disable')\n282:      *\n283:      * Omit '-Dognl.security.manager=' or nullify the property to disable the feature.\n284:      *\n285:      * To forcibly disable the feature (only possible at OGNL Library initialization, use the option:\n286:      *   -Dognl.security.manager=forceDisableOnInit\n287:      *\n288:      * Users that have their own Security Manager implementations and no intention to use the OGNL SecurityManager\n289:      *   sandbox may choose to use the 'forceDisableOnInit' flag option for performance reasons (avoiding overhead\n290:      *   involving the system property security checks - when that feature will not be used).\n291:      */\n292:     static final String OGNL_SECURITY_MANAGER = \"ognl.security.manager\";\n293:     static final String OGNL_SM_FORCE_DISABLE_ON_INIT = \"forceDisableOnInit\";\n294: \n295:     /**\n296:      * Hold environment flag state associated with OGNL_SECURITY_MANAGER.  See\n297:      * {@link OgnlRuntime#OGNL_SECURITY_MANAGER} for more details.\n298:      *   Default: false (if not set).\n299:      */\n300:     private static final boolean _disableOgnlSecurityManagerOnInit;\n301:     static {\n302:         boolean initialFlagState = false;\n303:         try {\n304:             final String propertyString = System.getProperty(OGNL_SECURITY_MANAGER);\n305:             if (propertyString != null && propertyString.length() > 0) {\n306:                 initialFlagState = OGNL_SM_FORCE_DISABLE_ON_INIT.equalsIgnoreCase(propertyString);\n307:             }\n308:         } catch (Exception ex) {\n309:             // Unavailable (SecurityException, etc.)\n310:         }\n311:         _disableOgnlSecurityManagerOnInit = initialFlagState;\n312:     }\n313: \n314:     /**\n315:      * Allow users to revert to the old \"first match\" lookup for getters/setters by OGNL using the JVM options:\n316:      *    -Dognl.UseFirstMatchGetSetLookup=true\n317:      *    -Dognl.UseFirstMatchGetSetLookup=false\n318:      *\n319:      * Note: Using the \"false\" value has the same effect as omitting the option completely.\n320:      *   The default behaviour is to use the \"best match\" lookup for getters/setters.\n321:      *   Using the \"true\" value reverts to the older \"first match\" lookup for getters/setters\n322:      *   (in the event the \"best match\" processing causes issues for existing applications).\n323:      */\n324:     static final String USE_FIRSTMATCH_GETSET_LOOKUP = \"ognl.UseFirstMatchGetSetLookup\";\n325: \n326:     /**\n327:      * Hold environment flag state associated with USE_FIRSTMATCH_GETSET_LOOKUP.\n328:      *   Default: false (if not set)\n329:      */\n330:     private static final boolean _useFirstMatchGetSetLookup;\n331:     static {\n332:         boolean initialFlagState = false;\n333:         try {\n334:             final String propertyString = System.getProperty(USE_FIRSTMATCH_GETSET_LOOKUP);\n335:             if (propertyString != null && propertyString.length() > 0) {\n336:                 initialFlagState = Boolean.parseBoolean(propertyString);\n337:             }\n338:         } catch (Exception ex) {\n339:             // Unavailable (SecurityException, etc.)\n340:         }\n341:         _useFirstMatchGetSetLookup = initialFlagState;\n342:     }\n343: \n344:     static final ClassCache _methodAccessors = new ClassCacheImpl();\n345:     static final ClassCache _propertyAccessors = new ClassCacheImpl();\n346:     static final ClassCache _elementsAccessors = new ClassCacheImpl();\n347:     static final ClassCache _nullHandlers = new ClassCacheImpl();\n348: \n349:     static final ClassCache _propertyDescriptorCache = new ClassCacheImpl();\n350:     static final ClassCache _constructorCache = new ClassCacheImpl();\n--- 1220-1265\n1220:             if (checkPermission)\n1221:             {\n1222:                 try\n1223:                 {\n1224:                     _securityManager.checkPermission(getPermission(method));\n1225:                 } catch (SecurityException ex) {\n1226:                     throw new IllegalAccessException(\"Method [\" + method + \"] cannot be accessed.\");\n1227:                 }\n1228:             }\n1229: \n1230:             result = invokeMethodInsideSandbox(target, method, argsArray);\n1231:         }\n1232: \n1233:         return result;\n1234:     }\n1235: \n1236:     private static Object invokeMethodInsideSandbox(Object target, Method method, Object[] argsArray)\n1237:             throws InvocationTargetException, IllegalAccessException {\n1238: \n1239:         if (_disableOgnlSecurityManagerOnInit) {\n1240:             return method.invoke(target, argsArray);  // Feature was disabled at OGNL initialization.\n1241:         }\n1242: \n1243:         try {\n1244:             if (System.getProperty(OGNL_SECURITY_MANAGER) == null) {\n1245:                 return method.invoke(target, argsArray);\n1246:             }\n1247:         } catch (SecurityException ignored) {\n1248:             // already enabled or user has applied a policy that doesn't allow read property so we have to honor user's sandbox\n1249:         }\n1250: \n1251:         if (ClassLoader.class.isAssignableFrom(method.getDeclaringClass())) {\n1252:             // to support OgnlSecurityManager.isAccessDenied\n1253:             throw new IllegalAccessException(\"OGNL direct access to class loader denied!\");\n1254:         }\n1255: \n1256:         // creating object before entering sandbox to load classes out of the sandbox\n1257:         UserMethod userMethod = new UserMethod(target, method, argsArray);\n1258:         Permissions p = new Permissions(); // not any permission\n1259:         ProtectionDomain pd = new ProtectionDomain(null, p);\n1260:         AccessControlContext acc = new AccessControlContext(new ProtectionDomain[]{pd});\n1261: \n1262:         Object ognlSecurityManager = OgnlSecurityManagerFactory.getOgnlSecurityManager();\n1263: \n1264:         Long token;\n1265:         try {\n\n=== ognl/security/OgnlSecurityManager.java ===\n--- 1-120\n1: package ognl.security;\n2: \n3: import java.io.FilePermission;\n4: import java.security.*;\n5: import java.util.ArrayList;\n6: import java.util.List;\n7: \n8: /**\n9:  * Wraps current security manager with JDK security manager if is inside OgnlRuntime user's methods body execution.\n10:  *\n11:  * Add the `-Dognl.security.manager` to JVM options to enable.\n12:  *\n13:  * <p> Note: Due to potential performance and concurrency issues, try this only if you afraid your app can have an\n14:  * unknown \"expression injection\" flaw or you afraid you cannot prevent those in your app's internal sandbox\n15:  * comprehensively e.g. you cannot discover and maintain all attack vectors over time because of many dependencies\n16:  * and also their change over time.</p>\n17:  *\n18:  * <p> This tries to provide an option to you to enable a security manager that disables any sensitive action e.g.\n19:  * exec and exit even if attacker had a successful \"expression injection\" in any unknown way into your app. However,\n20:  * also honors previous security manager and policies if any set, as parent, and rolls back to them after method\n21:  * execution finished.</p>\n22:  *\n23:  * @author Yasser Zamani\n24:  * @since 3.1.24\n25:  */\n26: public class OgnlSecurityManager extends SecurityManager {\n27:     private static final String OGNL_SANDBOX_CLASS_NAME = \"ognl.security.UserMethod\";\n28:     private static final Class<?> CLASS_LOADER_CLASS = ClassLoader.class;\n29:     private static final Class<?> FILE_PERMISSION_CLASS = FilePermission.class;\n30: \n31:     private SecurityManager parentSecurityManager;\n32:     private List<Long> residents = new ArrayList<Long>();\n33:     private SecureRandom rnd = new SecureRandom();\n34: \n35:     public OgnlSecurityManager(SecurityManager parentSecurityManager) {\n36:         this.parentSecurityManager = parentSecurityManager;\n37:     }\n38: \n39:     private boolean isAccessDenied(Permission perm) {\n40:         Class[] classContext = getClassContext();\n41:         Boolean isInsideClassLoader = null;\n42:         for (Class c : classContext) {\n43:             if (isInsideClassLoader == null && CLASS_LOADER_CLASS.isAssignableFrom(c)) {\n44:                 if (FILE_PERMISSION_CLASS.equals(perm.getClass()) && \"read\".equals(perm.getActions())) {\n45:                     // TODO: might be risky but we have to - fix it if any POC discovered\n46:                     // relax a bit with containers class loaders lazy class load\n47:                     return false;\n48:                 } else {\n49:                     isInsideClassLoader = false;\n50:                 }\n51:             }\n52:             if (OGNL_SANDBOX_CLASS_NAME.equals(c.getName())) {\n53:                 return true;\n54:             }\n55:         }\n56:         return false;\n57:     }\n58: \n59:     @Override\n60:     public void checkPermission(Permission perm) {\n61:         if (parentSecurityManager != null) {\n62:             parentSecurityManager.checkPermission(perm);\n63:         }\n64:         if (isAccessDenied(perm)) {\n65:             super.checkPermission(perm);\n66:         }\n67:     }\n68: \n69:     @Override\n70:     public void checkPermission(Permission perm, Object context) {\n71:         if (parentSecurityManager != null) {\n72:             parentSecurityManager.checkPermission(perm, context);\n73:         }\n74:         if (isAccessDenied(perm)) {\n75:             super.checkPermission(perm, context);\n76:         }\n77:     }\n78: \n79:     public Long enter() {\n80:         synchronized (this) {\n81:             long token = rnd.nextLong();\n82:             if (residents.size() == 0) {\n83:                 if (install()) {\n84:                     residents.add(token);\n85:                     return token;\n86:                 } else {\n87:                     return null;\n88:                 }\n89:             }\n90:             residents.add(token);\n91:             return token;\n92:         }\n93:     }\n94: \n95:     public void 