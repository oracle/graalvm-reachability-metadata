al Map<Object, Object> RESERVED_KEYS = new HashMap<>(6);\n60:     \n61:     private Object _root;\n62:     private Object _currentObject;\n63:     private Node _currentNode;\n64:     private boolean _traceEvaluations = DEFAULT_TRACE_EVALUATIONS;\n65:     private Evaluation _rootEvaluation;\n66:     private Evaluation _currentEvaluation;\n67:     private Evaluation _lastEvaluation;\n68:     private boolean _keepLastEvaluation = DEFAULT_KEEP_LAST_EVALUATION;\n69:     \n70:     private final Map _values;\n71:     \n72:     private final ClassResolver _classResolver;\n73:     private final TypeConverter _typeConverter;\n74:     private final MemberAccess _memberAccess;\n75:     \n76:     static {\n77:         String s;\n78: \n79:         RESERVED_KEYS.put(ROOT_CONTEXT_KEY, null);\n80:         RESERVED_KEYS.put(THIS_CONTEXT_KEY, null);\n81:         RESERVED_KEYS.put(TRACE_EVALUATIONS_CONTEXT_KEY, null);\n82:         RESERVED_KEYS.put(LAST_EVALUATION_CONTEXT_KEY, null);\n83:         RESERVED_KEYS.put(KEEP_LAST_EVALUATION_CONTEXT_KEY, null);\n84: \n85:         try {\n86:             if ((s = System.getProperty(PROPERTY_KEY_PREFIX + \".traceEvaluations\")) != null) {\n87:                 DEFAULT_TRACE_EVALUATIONS = Boolean.valueOf(s.trim());\n88:             }\n89:             if ((s = System.getProperty(PROPERTY_KEY_PREFIX + \".keepLastEvaluation\")) != null) {\n90:                 DEFAULT_KEEP_LAST_EVALUATION = Boolean.valueOf(s.trim());\n91:             }\n92:         } catch (SecurityException ex) {\n93:             // restricted access environment, just keep defaults\n94:         }\n95:     }\n96: \n97:     private final List<Class<?>> _typeStack = new ArrayList<>(3);     // size 3 should be enough stack for most expressions\n98:     private final List<Class<?>> _accessorStack = new ArrayList<>(3); // size 3 should be enough stack for most expressions\n99: \n100:     private int _localReferenceCounter = 0;\n101:     private Map<String, LocalReference> _localReferenceMa