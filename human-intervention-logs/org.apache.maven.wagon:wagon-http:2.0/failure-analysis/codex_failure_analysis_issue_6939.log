rtifact-urls\n/home/vjovanov/c/forge/forge2/graalvm-reachability-metadata/forge/logs/org.apache.maven.wagon:wagon-http:2.0/populate-artifact-urls/populate_artifact_urls.log\n/home/vjovanov/c/forge/forge2/graalvm-reachability-metadata/forge/local_repositories/forge_worktrees/6939-4823fbaa/human-intervention-logs/org.apache.maven.wagon:wagon-http:2.0\n/home/vjovanov/c/forge/forge2/graalvm-reachability-metadata/forge/local_repositories/forge_worktrees/6939-4823fbaa/human-intervention-logs/org.apache.maven.wagon:wagon-http:2.0/gradle-test\n/home/vjovanov/c/forge/forge2/graalvm-reachability-metadata/forge/local_repositories/forge_worktrees/6939-4823fbaa/human-intervention-logs/org.apache.maven.wagon:wagon-http:2.0/gradle-test/gradle-test-2026-05-19T07-15-19-020865Z.log\n/home/vjovanov/c/forge/forge2/graalvm-reachability-metadata/forge/local_repositories/forge_worktrees/6939-4823fbaa/human-intervention-logs/org.apache.maven.wagon:wagon-http:2.0/gradle-test/gradle-test-2026-05-19T07-14-31-336620Z.log\n/home/vjovanov/c/forge/forge2/graalvm-reachability-metadata/forge/local_repositories/forge_worktrees/6939-4823fbaa/human-intervention-logs/org.apache.maven.wagon:wagon-http:2.0/gradle-test/gradle-test-2026-05-19T07-15-38-034812Z.log\n/home/vjovanov/c/forge/forge2/graalvm-reachability-metadata/forge/local_repositories/forge_worktrees/6939-4823fbaa/human-intervention-logs/org.apache.maven.wagon:wagon-http:2.0/gradle-test/gradle-test-2026-05-19T07-14-01-483891Z.log\n/home/vjovanov/c/forge/forge2/graalvm-reachability-metadata/forge/local_repositories/forge_worktrees/6939-4823fbaa/human-intervention-logs/org.apache.maven.wagon:wagon-http:2.0/gradle-test/gradle-test-2026-05-19T07-13-10-494957Z.log\n/home/vjovanov/c/forge/forge2/graalvm-reachability-metadata/forge/local_repositories/forge_worktrees/6939-4823fbaa/human-intervention-logs/org.apache.maven.wagon:wagon-http:2.0/fix-javac-fail\n/home/vjovanov/c/forge/forge2/graalvm-reachability-metadata/forge/local_repositories/forge_work