  		if ( context.isFullyXmlConfigured() ) {
  			context.logMessage(
  					Diagnostic.Kind.OTHER,
  					"Skipping the processing of annotations since persistence unit is purely xml configured."
  			);
  			return ALLOW_OTHER_PROCESSORS_TO_CLAIM_ANNOTATIONS;
