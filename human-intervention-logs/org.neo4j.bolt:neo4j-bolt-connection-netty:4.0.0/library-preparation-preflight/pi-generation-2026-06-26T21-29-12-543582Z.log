e</trimStackTrace>\n                    </configuration>\n                </plugin>\n                <plugin>\n                    <groupId>org.apache.maven.plugins</groupId>\n                    <artifactId>maven-failsafe-plugin</artifactId>\n                    <version>${surefire.and.failsafe.version}</version>\n                    <configuration>\n                        <useModulePath>false</useModulePath>\n                    </configuration>\n                    <executions>\n                        <execution>\n                            <id>integration-test</id>\n                            <goals>\n                                <goal>integration-test</goal>\n                                <goal>verify</goal>\n                            </goals>\n                        </execution>\n                    </executions>\n                </plugin>\n                <plugin>\n                    <groupId>org.apache.maven.plugins</groupId>\n                    <artifactId>maven-deploy-plugin</artifactId>\n                    <version>2.8.2</version>\n                </plugin>\n                <plugin>\n                    <groupId>org.apache.maven.plugins</groupId>\n                    <artifactId>maven-source-plugin</artifactId>\n                    <version>3.3.1</version>\n                    <executions>\n                        <execution>\n                            <id>attach-sources</id>\n                            <goals>\n                                <goal>jar-no-fork</goal>\n                            </goals>\n                            <configuration>\n                                <archive>\n                                    <manifestEntries>\n                                        <Bundle-Name>${project.name} (Source)</Bundle-Name>\n                                        <Bundle-SymbolicName>${bundle.name}.source</Bundle-SymbolicName>\n                                        <Bundle-Version>${parsedVersion.majorVersion}.${parsedVersion.minorVersion}.${parsedVersion.incrementalVersion}.${build.timestamp}</Bundle-Version>\n                                        <Eclipse-SourceBundle>${bundle.name};version=\"${parsedVersion.majorVersion}.${parsedVersion.minorVersion}.${parsedVersion.incrementalVersion}.${build.timestamp}\";roots:=\".\"</Eclipse-SourceBundle>\n                                    </manifestEntries>\n                                </archive>\n                            </configuration>\n                        </execution>\n                    </executions>\n                </plugin>\n                <plugin>\n                    <groupId>org.apache.maven.plugins</groupId>\n                    <artifactId>maven-jar-plugin</artifactId>\n                    <version>3.1.0</version>\n                </plugin>\n                <plugin>\n                    <groupId>com.diffplug.spotless</groupId>\n                    <artifactId>spotless-maven-plugin</artifactId>\n                    <version>2.44.3</version>\n                    <configuration>\n                        <java>\n                            <palantirJavaFormat />\n                            <toggleOffOn />\n                        </java>\n                    </configuration>\n                    <executions>\n                        <execution>\n                            <goals>\n                                <goal>check</goal>\n                            </goals>\n                        </execution>\n                    </executions>\n                </plugin>\n                <plugin>\n                    <groupId>org.apache.maven.plugins</groupId>\n                    <artifactId>maven-enforcer-plugin</artifactId>\n                    <version>3.5.0</version>\n                    <configuration>\n                        <rules>\n                            <RestrictImports>\n                                <reason>Star imports are not allowed, please configure your editor to substitute them with fully qualified imports.</reason>\n                                <bannedImport>**.'*'</bannedImport>\n                            </RestrictImports>\n                        </rules>\n                        <fail>true</fail>\n                    </configuration>\n                    <dependencies>\n                        <dependency>\n                            <groupId>de.skuzzle.enforcer</groupId>\n                            <artifactId>restrict-imports-enforcer-rule</artifactId>\n                            <version>2.0.0</version>\n                        </dependency>\n                    </dependencies>\n                    <executions>\n                        <execution>\n                            <goals>\n                                <goal>enforce</goal>\n                            </goals>\n                        </execution>\n                    </executions>\n                </plugin>\n                <plugin>\n                    <groupId>com.mycila</groupId>\n                    <artifactId>license-maven-plugin</artifactId>\n                    <version>3.0</version>\n                    <configuration>\n                        <strictCheck>true</strictCheck>\n                        <header>license/neo4j_apache_v2/header.txt</header>\n                        <mapping>\n                            <java>SLASHSTAR_STYLE</java>\n                        </mapping>\n                        <includes>\n                            <include>**/*.java</include>\n                        </includes>\n                    </configuration>\n                    <dependencies>\n                        <dependency>\n                            <groupId>org.neo4j.build</groupId>\n                            <artifactId>resources</artifactId>\n                            <version>${build-resources.version}</version>\n                        </dependency>\n                    </dependencies>\n                    <executions>\n                        <execution>\n      