      <artifactId>neo4j-bolt-connection-netty</artifactId>
  
      <packaging>jar</packaging>
      <name>Neo4j Bolt Connection (Bolt Provider reference impl)</name>
      <description>Implements a provider that supports `bolt`, `bolt+s` and `bolt+ssc` schemes.</description>
  
