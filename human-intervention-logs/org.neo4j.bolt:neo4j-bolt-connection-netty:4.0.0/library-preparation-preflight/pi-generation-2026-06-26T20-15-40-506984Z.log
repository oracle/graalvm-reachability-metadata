                      <executions>
                          <execution>
                              <goals>
                                  <goal>enforce</goal>
                              </goals>
                          </execution>
                      </executions>
                  </plugin>
                  <plugin>
                      <groupId>com.mycila</groupId>
                      <artifactId>license-maven-plugin</artifactId>
                      <version>3.0</version>
                      <configuration>
                          <strictCheck>true</strictCheck>
                          <header>license/neo4j_apache_v2/header.txt</header>
                          <mapping>
                              <java>SLASHSTAR_STYLE</java>
                          </mapping>
                          <includes>
