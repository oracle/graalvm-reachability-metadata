              <groupId>io.netty</groupId>
              <artifactId>netty-handler</artifactId>
          </dependency>
          <dependency>
              <groupId>io.netty</groupId>
              <artifactId>netty-tcnative-classes</artifactId>
          </dependency>
          <dependency>
              <groupId>org.neo4j.bolt</groupId>
              <artifactId>neo4j-bolt-connection</artifactId>
          </dependency>
          <dependency>
