          `Content-Encoding`(encoding) +: message.headers)
      else message.self
  
    def encodeData[T](t: T)(implicit mapper: DataMapper[T]): T =
      mapper.transformDataBytes(t, Flow.fromGraph(singleUseEncoderFlow()))
  
