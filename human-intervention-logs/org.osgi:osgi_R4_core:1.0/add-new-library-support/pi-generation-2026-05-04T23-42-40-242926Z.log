            this.key = expression.substring(0, separatorIndex);\n            this.value = expression.substring(separatorIndex + 1);\n        }\n\n        public boolean match(ServiceReference reference) {\n            return value.equals(reference.getProperty(key));\n        }\n\n        public boolean match(Dictionary dictionary) {\n            return value.equals(dictionary.get(key));\n        }\n\n        public boolean matchCase(Dictionary dictionary) {\n            return match(dictionary);\n        }\n\n        public String toString() {\n            return filter;\n        }\n\n        public boolean equals(Object other) {\n            return other instanceof Filter && filter.equals(other.toString());\n        }\n\n        public int hashCode() {\n            return filter.hashCode();\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 778, "output": 680, "cacheRead": 16384, "cacheWrite": 0, "totalTokens": 17842, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777938096338, "responseId": "resp_0f9c9a9133b887400169f92eb0b3e08195bcb802bbbf8a2401"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_2oboxeRkqJS1f0PRplgyt9vw|fc_0f9c9a9133b887400169f92eb4a16081959e7e7c32ecbe694f", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2069 bytes to tests/src/org.osgi/osgi_R4_core/1.0/src/test/java/org_osgi/osgi_R4_core/vendor/FrameworkUtil.java"}], "isError": false, "timestamp": 1777938103777}]}
