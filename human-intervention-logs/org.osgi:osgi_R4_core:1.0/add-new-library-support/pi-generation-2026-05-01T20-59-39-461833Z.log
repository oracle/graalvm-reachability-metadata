      @Override
      public boolean implies(Permission permission) {
          impliesCalls++;
          if (!(permission instanceof DeploymentAdminPermission other)) {
              return false;
          }
          return Objects.equals(getName(), other.getName()) && actionSet.containsAll(other.actionSet);
