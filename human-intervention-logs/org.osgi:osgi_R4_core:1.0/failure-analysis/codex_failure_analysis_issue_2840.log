ngBuffer.\\r\\n\\t */\\r\\n\\tprivate static void escapeString(String str, StringBuffer output) {\\r\\n\\t\\tint len = str.length();\\r\\n\\t\\tfor (int i = 0; i < len; i++) {\\r\\n\\t\\t\\tchar c = str.charAt(i);\\r\\n\\t\\t\\tswitch (c) {\\r\\n\\t\\t\\t\\tcase '\\\"' :\\r\\n\\t\\t\\t\\tcase '\\\\\\\\' :\\r\\n\\t\\t\\t\\t\\toutput.append('\\\\\\\\');\\r\\n\\t\\t\\t\\t\\toutput.append(c);\\r\\n\\t\\t\\t\\t\\tbreak;\\r\\n\\t\\t\\t\\tcase '\\\\r' :\\r\\n\\t\\t\\t\\t\\toutput.append(\\\"\\\\\\\\r\\\");\\r\\n\\t\\t\\t\\t\\tbreak;\\r\\n\\t\\t\\t\\tcase '\\\\n' :\\r\\n\\t\\t\\t\\t\\toutput.append(\\\"\\\\\\\\n\\\");\\r\\n\\t\\t\\t\\t\\tbreak;\\r\\n\\t\\t\\t\\tdefault :\\r\\n\\t\\t\\t\\t\\toutput.append(c);\\r\\n\\t\\t\\t\\t\\tbreak;\\r\\n\\t\\t\\t}\\r\\n\\t\\t}\\r\\n\\t}\\r\\n\\r\\n\\t/**\\r\\n\\t * Takes an encoded character array and decodes it into a new String.\\r\\n\\t */\\r\\n\\tprivate static String unescapeString(char[] str, int begin, int end) {\\r\\n\\t\\tStringBuffer output = new StringBuffer(end - begin);\\r\\n\\t\\tfor (int i = begin; i < end; i++) {\\r\\n\\t\\t\\tchar c = str[i];\\r\\n\\t\\t\\tif (c == '\\\\\\\\') {\\r\\n\\t\\t\\t\\ti++;\\r\\n\\t\\t\\t\\tif (i < end) {\\r\\n\\t\\t\\t\\t\\tc = str[i];\\r\\n\\t\\t\\t\\t\\tswitch (c) {\\r\\n\\t\\t\\t\\t\\t\\tcase '\\\"' :\\r\\n\\t\\t\\t\\t\\t\\tcase '\\\\\\\\' :\\r\\n\\t\\t\\t\\t\\t\\t\\tbreak;\\r\\n\\t\\t\\t\\t\\t\\tcase 'r' :\\r\\n\\t\\t\\t\\t\\t\\t\\tc = '\\\\r';\\r\\n\\t\\t\\t\\t\\t\\t\\tbreak;\\r\\n\\t\\t\\t\\t\\t\\tcase 'n' :\\r\\n\\t\\t\\t\\t\\t\\t\\tc = '\\\\n';\\r\\n\\t\\t\\t\\t\\t\\t\\tbreak;\\r\\n\\t\\t\\t\\t\\t\\tdefault :\\r\\n\\t\\t\\t\\t\\t\\t\\tc = '\\\\\\\\';\\r\\n\\t\\t\\t\\t\\t\\t\\ti--;\\r\\n\\t\\t\\t\\t\\t\\t\\tbreak;\\r\\n\\t\\t\\t\\t\\t}\\r\\n\\t\\t\\t\\t}\\r\\n\\t\\t\\t}\\r\\n\\t\\t\\toutput.append(c);\\r\\n\\t\\t}\\r\\n\\r\\n\\t\\treturn output.toString();\\r\\n\\t}\\r\\n}\\r\\n\"}], \"isError\": false, \"timestamp\": 1777669841039}}\n1616:[recv] {\"type\": \"message_end\", \"message\":