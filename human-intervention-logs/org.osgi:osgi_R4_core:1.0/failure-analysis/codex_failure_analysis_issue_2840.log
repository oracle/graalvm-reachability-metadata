   \"line\" : 146,\n      \"metadataType\" : \"reflection\",\n      \"trackedApi\" : \"java.lang.Class#forName(java.lang.String)\"\n    }, {\n      \"covered\" : true,\n      \"frame\" : \"org.osgi.framework.AdminPermission$1.run(AdminPermission.java:155)\",\n      \"line\" : 155,\n      \"metadataType\" : \"reflection\",\n      \"trackedApi\" : \"java.lang.Class#getConstructor(java.lang.Class[])\"\n    }, {\n      \"covered\" : true,\n      \"frame\" : \"org.osgi.framework.AdminPermission$1.run(AdminPermission.java:158)\",\n      \"line\" : 158,\n      \"metadataType\" : \"reflection\",\n      \"trackedApi\" : \"java.lang.Class#getConstructor(java.lang.Class[])\"\n    } ],\n    \"className\" : \"org.osgi.framework.AdminPermission$1\",\n    \"coveredCalls\" : 3,\n    \"sourceFile\" : \"AdminPermission.java\",\n    \"totalCalls\" : 3\n  } ],\n  \"coordinate\" : \"org.osgi:osgi_R4_core:1.0\",\n  \"hasDynamicAccess\" : true,\n  \"totals\" : {\n    \"coveredCalls\" : 5,\n    \"totalCalls\" : 12\n  }\n}\n","exit_code":0,"status":"completed"}}
