onvert into UTC.\"\n  (partial parse-timestamp (validated construct-date)))\n\n(def read-instant-calendar\n  \"To read an instant as a java.util.Calendar, bind *data-readers* to a map with\nthis var as the value for the 'inst key.  Calendar preserves the timezone\noffset.\"\n  (partial parse-timestamp (validated construct-calendar)))\n\n(def read-instant-timestamp\n  \"To read an instant as a java.sql.Timestamp, bind *data-readers* to a\nmap with this var as the value for the 'inst key. Timestamp preserves\nfractional seconds with nanosecond precision. The timezone offset will\nbe used to convert into UTC.\"\n  (partial parse-timestamp (validated construct-timestamp)))\n\n;;; clojure.uuid ;;;\n\n(defn default-uuid-reader [form]\n  {:pre [(string? form)]}\n  (java.util.UUID/fromString form))\n\n(defmethod print-method java.util.UUID [uuid ^java.io.Writer w]\n  (.write w (str \"#uuid \\\"\" (str uuid) \"\\\"\")))\n\n(defmethod print-dup java.util.UUID [o w]\n  (print-method o w))\n/tmp/tmp.7rNyvIMgpl/tools.reader-tools.reader-0.9.2/src/main/clojure/clojure/tools/reader.clj:13:                            default-data-readers *default-data-reader-fn*\n/tmp/tmp.7rNyvIMgpl/tools.reader-tools.reader-0.9.2/src/main/clojure/clojure/tools/reader.clj-14-                            *read-eval* *data-readers* *suppress-read*])\n/tmp/tmp.7rNyvIMgpl/tools.reader-tools.reader-0.9.2/src/main/clojure/clojure/tools/reader.clj-15-  (:use clojure.tools.reader.reader-types\n/tmp/tmp.7rNyvIMgpl/tools.reader-tools.reader-0.9.2/src/main/clojure/clojure/tools/reader.clj-16-        [clojure.tools.reader.impl utils commons])\n/tmp/tmp.7rNyvIMgpl/tools.reader-tools.reader-0.9.2/src/main/clojure/clojure/tools/reader.clj:17:  (:require [clojure.tools.reader.default-data-readers :as data-readers])\n/tmp/tmp.7rNyvIMgpl/tools.reader-tools.reader-0.9.2/src/main/clojure/clojure/tools/reader.clj-18-  (:import (clojure.lang PersistentHashSet IMeta\n/tmp/tmp.7rNyvIMgpl/tools.reader-tools.reader-0.9.2/src