  170: (defn merge-meta
  171:   "Returns an object of the same type and value as `obj`, with its
  172: metadata merged over `m`."
  173:   [obj m]
  174:   (let [orig-meta (meta obj)]
  175:     (with-meta obj (merge m (dissoc orig-meta :source)))))
  176: 
  177: (defn- peek-source-log
  178:   "Returns a string containing the contents of the top most source
  179: logging frame."
  180:   [source-log-frames]
  181:   (let [current-frame @source-log-frames]
  182:     (.substring ^StringBuilder (:buffer current-frame) (:offset current-frame))))
  183: 
  184: (defn- log-source-char
  185:   "Logs `char` to all currently active source logging frames."
  186:   [source-log-frames char]
  187:   (when-let [^StringBuilder buffer (:buffer @source-log-frames)]
  188:     (.append buffer char)))
  189: 
  190: (defn- drop-last-logged-char
  191:   "Removes the last logged character from all currently active source
  192: logging frames. Called when pushing a character back."
  193:   [source-log-frames]
  194:   (when-let [^StringBuilder buffer (:buffer @source-log-frames)]
  195:     (.deleteCharAt buffer (dec (.length buffer)))))
  196: 
  197: (deftype SourceLoggingPushbackReader
  198:     [rdr ^:unsynchronized-mutable line ^:unsynchronized-mutable column
  199:      ^:unsynchronized-mutable line-start? ^:unsynchronized-mutable prev
  200:      ^:unsynchronized-mutable prev-column file-name source-log-frames]
  201:   Reader
  202:   (read-char [reader]
  203:     (when-let [ch (read-char rdr)]
  204:       (let [ch (normalize-newline rdr ch)]
  205:         (set! prev line-start?)
  206:         (set! line-start? (newline? ch))
  207:         (when line-start?
  208:           (set! prev-column column)
  209:           (set! column 0)
  210:           (update! line inc))
  211:         (update! column inc)
  212:         (log-source-char source-log-frames ch)
  213:         ch)))
  214: 
  215:   (peek-char [reader]
  216:     (peek-char rdr))
  217: 
  218:   IPushbackReader
  219:   (unread [reader ch]
  220:     (if line-start?
  221:       (do (update! line dec)
  222:           (set! column prev-column))
  223:       (update! column dec))
  224:     (set! line-start? prev)
  225:     (when ch
  226:       (drop-last-logged-char source-log-frames))
  227:     (unread rdr ch))
  228: 
  229:   IndexingReader
  230:   (get-line-number [reader] (int line))
  231:   (get-column-number [reader] (int column))
  232:   (get-file-name [reader] file-name))
  233: 
  234: (defn log-source*
  235:   [reader f]
  236:   (let [frame (.source-log-frames ^SourceLoggingPushbackReader reader)
  237:         ^StringBuilder buffer (:buffer @frame)
  238:         new-frame (assoc-in @frame [:offset] (.length buffer))]
  239:     (with-bindings {frame new-frame}
  240:       (let [ret (f)]
  241:         (if (instance? clojure.lang.IMeta ret)
  242:           (merge-meta ret {:source (peek-source-log frame)})
  243:           ret)))))
