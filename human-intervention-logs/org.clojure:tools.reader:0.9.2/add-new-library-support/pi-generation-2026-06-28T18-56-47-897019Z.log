  249: ;; fast check for provided implementations
  250: (defn indexing-reader?
  251:   "Returns true if the reader satisfies IndexingReader"
  252:   [rdr]
  253:   (or (instance? clojure.tools.reader.reader_types.IndexingReader rdr)
  254:       (instance? LineNumberingPushbackReader rdr)
  255:       (and (not (instance? clojure.tools.reader.reader_types.PushbackReader rdr))
