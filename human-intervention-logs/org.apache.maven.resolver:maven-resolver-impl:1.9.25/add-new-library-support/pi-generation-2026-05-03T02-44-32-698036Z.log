  package org_apache_maven_resolver.maven_resolver_impl;
  
  import java.util.List;
  
  import org.eclipse.aether.impl.DefaultServiceLocator;
  import org.eclipse.aether.internal.impl.DefaultFileProcessor;
  import org.eclipse.aether.spi.io.FileProcessor;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class DefaultServiceLocatorInnerEntryTest {
      @Test
      void createsDefaultImplementationClassThroughServiceLocatorEntry() {
          DefaultServiceLocator locator = new DefaultServiceLocator();
  
          FileProcessor processor = locator.getService(FileProcessor.class);
  
          assertThat(processor).isInstanceOf(DefaultFileProcessor.class);
          assertThat(locator.getService(FileProcessor.class)).isSameAs(processor);
      }
  
      @Test
      void returnsConfiguredImplementationClassInstances() {
          DefaultServiceLocator locator = new DefaultServiceLocator();
  
          List<FileProcessor> processors = locator.getServices(FileProcessor.class);
  
          assertThat(processors).hasSize(1);
          assertThat(processors.get(0)).isInstanceOf(DefaultFileProcessor.class);
      }
  }
