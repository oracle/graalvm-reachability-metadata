   DefaultServiceLocator locator = new DefaultServiceLocator();\n        locator.setService(TestService.class, TestServiceImpl.class);\n\n        List<TestService> services = locator.getServices(TestService.class);\n\n        assertThat(services).hasSize(1);\n        assertThat(services.get(0)).isInstanceOf(TestServiceImpl.class);\n    }\n\n    private interface TestService {}\n\n    private static final class TestServiceImpl implements TestService, Service {\n        private ServiceLocator initializedWith;\n\n        private TestServiceImpl() {}\n\n        @Override\n        public void initService(ServiceLocator locator) {\n            initializedWith = locator;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 755, "output": 673, "cacheRead": 14848, "cacheWrite": 0, "totalTokens": 16276, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777776211434, "responseId": "resp_02a217922f96b34d0169f6b653cb948196944787f7dda8be29"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_9sA59vSW6RQp4rQsZ6vyxHpw|fc_02a217922f96b34d0169f6b658077c81969d4f6f1a58f824fb", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1917 bytes to tests/src/org.apache.maven.resolver/maven-resolver-impl/1.9.25/src/test/java/org_apache_maven_resolver/maven_resolver_impl/DefaultServiceLocatorInnerEntryTest.java"}], "isError": false, "timestamp": 1777776218004}]}
