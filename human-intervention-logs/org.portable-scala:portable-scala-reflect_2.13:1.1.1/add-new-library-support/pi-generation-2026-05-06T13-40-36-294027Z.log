        if (clazz.getAnnotation(classOf[EnableReflectiveInstantiation]) != null) {
          true
        } else {
          (Iterator(clazz.getSuperclass) ++ clazz.getInterfaces.iterator)
            .filter(_ != null)
            .exists(c)
        }
      }
  
      c(clazz)
    }
  }
