  object ReflectTest {
    private final val ConstructorThrowsMessage = "constructor throws"
  
    def intercept[T <: Throwable : ClassTag](body: => Unit): T = {
      try {
        body
        throw new AssertionError("no exception was thrown")
      } catch {
        case t: T => t
      }
    }
  
    trait Accessors {
      val x: Int
      val y: String
