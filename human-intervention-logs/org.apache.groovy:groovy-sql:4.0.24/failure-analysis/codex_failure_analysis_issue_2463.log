/1.0/>.\\n */\\npackage org_apache_groovy.groovy_sql\\n\\nimport groovy.sql.Sql\\nimport groovy.transform.CompileStatic\\nimport org.codehaus.groovy.runtime.InvokerHelper\\nimport org.graalvm.internal.tck.NativeImageSupport\\nimport org.junit.jupiter.api.Test\\n\\nimport java.net.URL\\nimport java.net.URLClassLoader\\n\\nimport static org.assertj.core.api.Assertions.assertThat\\n\\n@CompileStatic\\npublic class GroovySqlSqlTest {\\n    @Test\\n    void loadDriverUsesClassForNameWhenDriverIsVisibleToSqlClassLoader() {\\n        Sql.loadDriver(String.name)\\n    }\\n\\n    @Test\\n    void loadDriverFallsBackToContextClassLoader() {\\n        String driverClassName = 'example.ContextOnlyDriver'\\n        DriverReturningClassLoader contextClassLoader = new DriverReturningClassLoader(\\n                driverClassName,\\n                Object\\n        )\\n\\n        Throwable thrown = callLoadDriverWithContext(driverClassName, contextClassLoader)\\n\\n        assertThat(thrown).isNull()\\n        assertThat(contextClassLoader.requestedNames).startsWith(driverClassName)\\n    }\\n\\n    @Test\\n    void loadDriverCanLoadDriverFromSqlClassLoaderFallback() {\\n        String driverClassName = 'example.SqlClassLoaderOnlyDriver'\\n        RejectingClassLoader contextClassLoader = new RejectingClassLoader()\\n\\n        try (IsolatedSqlClassLoader isolatedSqlClassLoader = new IsolatedSqlClassLoader(driverClassName)) {\\n            Throwable thrown = callIsolatedLoadDriverWithContext(driverClassName, isolatedSqlClassLoader, contextClassLoader)\\n\\n            assertThat(thrown).isNull()\\n            assertThat(contextClassLoader.requestedNames).contains(driverClassName)\\n            assertThat(isolatedSqlClassLoader.sqlClassLoaderDriverLoads).isEqualTo(1)\\n        } catch (Error error) {\\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\\n                throw error\\n            }\\n        }\\n    }\\n\\n    @Test\\n    void loadDriverFallsBackToSqlClassLoaderBeforeReportingMissingDriver() {\\n        String driverClassName = 'example.MissingDriver'\\n        RejectingClassLoader contextClassLoader = new RejectingClassLoader()\\n\\n        Throwable thrown = callLoadDriverWithContext(driverClassName, contextClassLoader)\\n\\n        assertThat(thrown)\\n                .isInstanceOf(ClassNotFoundException)\\n                .hasMessageContaining(driverClassName)\\n        assertThat(contextClassLoader.requestedNames).startsWith(driverClassName)\\n    }\\n\\n    private static Throwable callIsolatedLoadDriverWithContext(\\n            String driverClassName,\\n            IsolatedSqlClassLoader isolatedSqlClassLoader,\\n            ClassLoader contextClassLoader) {\\n        Thread thread = Thread.currentThread()\\n        ClassLoader previousContextClassLoader = thread.contextClassLoader\\n        thread.contextClassLoader = contextClassLoader\\n        try {\\n            Class<?> isolatedSql = isolatedSqlClassLoader.loadClass(IsolatedSqlClassLoader.SQL_CLASS_NAME)\\n            InvokerHelper.invokeStaticMethod(isolatedSql, 'loadDriver', driverClassName)\\n            return null\\n        } catch (Error error) {\\n            throw error\\n        } catch (Throwable throwable) {\\n            return throwable\\n        } finally {\\n            thread.contextClassLoader = previousContextClassLoader\\n        }\\n    }\\n\\n    private static Throwable callLoadDriverWithContext(String driverClassName, ClassLoader contextClassLoader) {\\n        Thread thread = Thread.currentThread()\\n        ClassLoader previousContextClassLoader = thread.contextClassLoader\\n        thread.contextClassLoader = contextClassLoader\\n        try {\\n            Sql.loadDriver(driverClassName)\\n            return null\\n        } catch (Throwable throwable) {\\n            return throwable\\n        } finally {\\n            thread.contextClassLoader = previousContextClassLoader\\n        }\\n    }\\n}\\n\\n@CompileStatic\\npublic final class IsolatedSqlClassLoader extends URLClassLoader {\\n    static final String SQL_CLASS_NAME = 'groovy.sql.Sql'\\n\\n    private final String driverClassName\\n    int sqlClassLoaderDriverLoads\\n\\n    IsolatedSqlClassLoader(String driverClassName) {\\n        super([Sql.class.getProtectionDomain().getCodeSource().getLocation()] as URL[], Sql.class.getClassLoader())\\n        this.driverClassName = driverClassName\\n    }\\n\\n    @Override\\n    protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {\\n        if (driverClassName.equals(name)) {\\n            if (calledFromClassForName()) {\\n                throw new ClassNotFoundException(name)\\n            }\\n            sqlClassLoaderDriverLoads++\\n            return Object\\n        }\\n        if (name.equals(SQL_CLASS_NAME) || name.startsWith(SQL_CLASS_NAME + '$')) {\\n            Class<?> loadedClass = findLoadedClass(name)\\n            if (loadedClass == null) {\\n                loadedClass = findClass(name)\\n            }\\n            if (resolve) {\\n                resolveClass(loadedClass)\\n            }\\n            return loadedClass\\n        }\\n        return super.loadClass(name, resolve)\\n    }\\n\\n    private static boolean calledFromClassForName() {\\n        StackTraceElement[] frames = Thread.currentThread().getStackTrace()\\n        for (StackTraceElement frame : frames) {\\n            if ('java.lang.Class'.equals(frame.className) && 'forName'.equals(frame.methodName)) {\\n                return true\\n            }\\n        }\\n        return false\\n    }\\n}\\n\\n@CompileStatic\\npublic final class DriverReturningClassLoader extends ClassLoader {\\n    private final String supportedName\\n    private final Class<?> returnedClass\\n    final List<String> requestedNames = new ArrayList<>()\\n\\n    DriverReturningClassLoader(String supportedName, Class<?> returnedClass) {\\n        super(null)\\n        this.supportedName = supportedName\\n        this.returnedClass = returnedClass\\n    }\\n\\n    @Override\\n    Class<?> loadClass(String name) throws ClassNotFoundException {\\n        requestedNames.add(name)\\n        if (supportedName.equals(name)) {\\n            return returnedClass\\n        }\\n        throw new ClassNotFoundException(name)\\n    }\\n}\\n\\n@CompileStatic\\npublic final class RejectingClassLoader extends ClassLoader {\\n    final List<String> requestedNames = new ArrayList<>()\\n\\n    RejectingClassLoader() {\\n        super(null)\\n    }\\n\\n    @Override\\n    Class<?> loadClass(String name) throws ClassNotFoundException {\\n        requestedNames.add(name)\\n        throw new ClassNotFoundException(name)\\n    }\\n}\\n\",\"exit_code\":0,\"status\":\"completed\"}}\n{\"type\":\"item.started\",\"item\":{\"id\":\"item_7\",\"type\":\"command_execution\",\"command\":\"/usr/bin/bash -lc \\\"sed -n '1,220p' tests/src/org.apache.groovy/groovy-sql/4.0.24/src/test/groovy/org_apache_groovy/groovy_sql/GroovyResultSetProxyTest.groovy\\\"\",\"aggregated_output\":\"\",\"exit_code\":null,\"status\":\"in_progress\"}}\n{\"type\":\"item.completed\",\"item\":{\"id\":\"item_7\",\"type\":\"command_execution\",\"command\":\"/usr/bin/bash -lc \\\"sed -n '1,220p' tests/src/org.apache.groovy/groovy-sql/4.0.24/src/test/groovy/org_apache_groovy/groovy_sql/GroovyResultSetProxyTest.groovy\\\"\",\"aggregated_output\":\"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage org_apache_groovy.groovy_sql\\n\\nimport groovy.sql.GroovyResultSet\\nimport groovy.sql.GroovyResultSetProxy\\nimport groovy.transform.CompileStatic\\nimport org.junit.jupiter.api.Test\\n\\nimport java.sql.ResultSet\\n\\nimport static org.assertj.core.api.Assertions.assertThat\\n\\n@CompileStatic\\npublic class GroovyResultSetProxyTest {\\n    @Test\\n 