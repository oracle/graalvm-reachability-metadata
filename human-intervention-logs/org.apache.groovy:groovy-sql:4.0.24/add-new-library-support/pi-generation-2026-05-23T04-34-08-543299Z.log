[tool-call] delta {"path":"tests/src/org.apache.groovy/groovy-sql/4.0.24/src/test/groovy/org_apache_groovy/groovy_sql/SqlTest.groovy","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_apache_groovy.groovy_sql\n\nimport groovy.sql.Sql\nimport groovy.transform.CompileStatic\nimport org.junit.jupiter.api.Test\n\nimport static org.junit.jupiter.api.Assertions.assertEquals\nimport static org.junit.jupiter.api.Assertions.assertTrue\nimport static org.junit.jupiter.api.Assertions.fail\n\n@CompileStatic\npublic class SqlTest {\n    private static final String CONTEXT_ONLY_DRIVER = 'org_apache_groovy.groovy_sql.ContextOnlyDriver'\n    private static final String MISSING_DRIVER = 'org_apache_groovy.groovy_sql.NoSuchJdbcDriver'\n\n    @Test\n    void loadDriverResolvesClassAvailableToSqlClassLoader() throws ClassNotFoundException {\n        Sql.loadDriver(String.class.getName())\n    }\n\n    @Test\n    void loadDriverUsesThreadContextClassLoaderWhenClassForNameCannotResolveDriver() throws ClassNotFoundException {\n        Thread thread = Thread.currentThread()\n        ClassLoader originalClassLoader = thread.getContextClassLoader()\n        ContextResolvingClassLoader contextClassLoader = new ContextResolvingClassLoader()\n\n        thread.setContextClassLoader(contextClassLoader)\n        try {\n            Sql.loadDriver(CONTEXT_ONLY_DRIVER)\n        } finally {\n            thread.setContextClassLoader(originalClassLoader)\n        }\n\n        assertTrue(contextClassLoader.requested)\n    }\n\n    @Test\n    void loadDriverAttemptsSqlClassLoaderWhenContextClassLoaderCannotResolveDriver() {\n        Thread thread = Thread.currentThread()\n        ClassLoader originalClassLoader = thread.getContextClassLoader()\n\n        ClassNotFoundException thrown = null\n        thread.setContextClassLoader(new RejectingClassLoader())\n        try {\n            Sql.loadDriver(MISSING_DRIVER)\n        } catch (ClassNotFoundException exception) {\n            thrown = exception\n        } finally {\n            thread.setContextClassLoader(originalClassLoader)\n        }\n\n        if (thrown == null) {\n            fail('Expected missing driver class to throw ClassNotFoundException')\n        }\n        assertEquals(MISSING_DRIVER, thrown.getMessage())\n    }\n\n    private static final class ContextResolvingClassLoader extends ClassLoader {\n        boolean requested\n\n        ContextResolvingClassLoader() {\n            super(null)\n        }\n\n        @Override\n        Class<?> loadClass(String name) throws ClassNotFoundException {\n            if (CONTEXT_ONLY_DRIVER.equals(name)) {\n                requested = true\n                return ContextOnlyDriver.class\n            }\n            throw new ClassNotFoundException(name)\n        }\n    }\n\n    private static final class RejectingClassLoader extends ClassLoader {\n        RejectingClassLoader() {\n            super(null)\n        }\n\n        @Override\n        Class<?> loadClass(String name) throws ClassNotFoundException {\n            throw new ClassNotFoundException(name)\n        }\n    }\n\n    private static final class ContextOnlyDriver {\n    }\n}\n"}
