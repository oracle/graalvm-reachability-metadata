[tool-call] delta {"path":"tests/src/org.apache.groovy/groovy-sql/4.0.24/src/test/groovy/org_apache_groovy/groovy_sql/SqlTest.groovy","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_apache_groovy.groovy_sql\n\nimport groovy.sql.Sql\nimport org.junit.jupiter.api.Test\n\nimport static org.junit.jupiter.api.Assertions.assertDoesNotThrow\nimport static org.junit.jupiter.api.Assertions.assertThrows\n\npublic class SqlTest {\n    @Test\n    void loadDriverResolvesClassAvailableToSqlClassLoader() {\n        assertDoesNotThrow({ Sql.loadDriver(String.name) })\n    }\n\n    @Test\n    void loadDriverAttemptsFallbackClassLoadersWhenDriverClassIsUnavailable() {\n        Thread thread = Thread.currentThread()\n        ClassLoader originalClassLoader = thread.contextClassLoader\n        ClassLoader rejectingClassLoader = new ClassLoader(null) {\n            @Override\n            Class<?> loadClass(String name) throws ClassNotFoundException {\n                throw new ClassNotFoundException(name)\n            }\n        }\n\n        thread.contextClassLoader = rejectingClassLoader\n        try {\n            ClassNotFoundException exception = assertThrows(ClassNotFoundException) {\n                Sql.loadDriver('org_apache_groovy.groovy_sql.NoSuchJdbcDriver')\n            }\n\n            assert exception.message == 'org_apache_groovy.groovy_sql.NoSuchJdbcDriver'\n        } finally {\n            thread.contextClassLoader = originalClassLoader\n        }\n    }\n}\n"}
