d loadDriverUsesThreadContextClassLoaderWhenClassForNameCannotResolveDriver() throws ClassNotFoundException {\n        Thread thread = Thread.currentThread()\n        ClassLoader originalClassLoader = thread.getContextClassLoader()\n        ContextResolvingClassLoader contextClassLoader = new ContextResolvingClassLoader()\n\n        thread.setContextClassLoader(contextClassLoader)\n        try {\n            Sql.loadDriver(CONTEXT_ONLY_DRIVER)\n        } finally {\n            thread.setContextClassLoader(originalClassLoader)\n        }\n\n        assertTrue(contextClassLoader.requested)\n    }\n\n    @Test\n    void loadDriverUsesSqlClassLoaderWhenContextClassLoaderCannotResolveDriver() throws Exception {\n        try {\n            IsolatedSqlClassLoader sqlClassLoader = new IsolatedSqlClassLoader(sqlCodeSource())\n            try {\n                Class<?> isolatedSqlClass = sqlClassLoader.loadClass(Sql.class.getName())\n                Method loadDriver = isolatedSqlClass.getMethod('loadDriver', String.class)\n                invokeLoadDriverWithRejectingContextClassLoader(loadDriver)\n\n                assertTrue(sqlClassLoader.sqlLoaderRequested)\n            } finally {\n                sqlClassLoader.close()\n            }\n        } catch (InvocationTargetException exception) {\n            Throwable cause = exception.getCause()\n            if (cause instanceof Error && NativeImageSupport.isUnsupportedFeatureError((Error) cause)) {\n                return\n            }\n            throw exception\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error\n            }\n        }\n    }\n\n    @Test\n    void loadDriverAttemptsSqlClassLoaderWhenContextClassLoaderCannotResolveDriver() {\n        Thread thread = Thread.currentThread()\n        ClassLoader originalClassLoader = thread.getContextClassLoader()\n\n        ClassNotFoundException thrown = null\n        thread.setContextClassLoader(new RejectingClassLoader())\n        try {\n            Sql.loadDriver(MISSING_DRIVER)\n        } catch (ClassNotFoundException exception) {\n            thrown = exception\n        } finally {\n            thread.setContextClassLoader(originalClassLoader)\n        }\n\n        if (thrown == null) {\n            fail('Expected missing driver class to throw ClassNotFoundException')\n        }\n        assertEquals(MISSING_DRIVER, thrown.getMessage())\n    }\n\n    private static URL sqlCodeSource() {\n        return Sql.class.getProtectionDomain().getCodeSource().getLocation()\n    }\n\n    private static void invokeLoadDriverWithRejectingContextClassLoader(Method loadDriver) throws Exception {\n        Thread thread = Thread.currentThread()\n        ClassLoader originalClassLoader = thread.getContextClassLoader()\n\n        thread.setContextClassLoader(new RejectingClassLoader())\n        try {\n            loadDriver.invoke(null, SQL_LOADER_ONLY_DRIVER)\n        } finally {\n            thread.setContextClassLoader(originalClassLoader)\n        }\n    }\n\n    private static final class IsolatedSqlClassLoader extends URLClassLoader {\n        boolean sqlLoaderRequested\n        private boolean rejectFirstDriverRequest = true\n\n        IsolatedSqlClassLoader(URL sqlJar) {\n            super([sqlJar] as URL[], SqlTest.class.getClassLoader())\n        }\n\n        @Override\n        protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {\n            synchronized (getClassLoadingLock(name)) {\n                if (SQL_LOADER_ONLY_DRIVER.equals(name)) {\n                    if (rejectFirstDriverRequest) {\n                        rejectFirstDriverRequest = false\n                        throw new ClassNotFoundException(name)\n                    }\n                    sqlLoaderRequested = true\n                    return SqlLoaderOnlyDriver.class\n                }\n                if (name.equals(Sql.class.getName()) || name.startsWith(Sql.class.getName() + '$')) {\n                    Class<?> loadedClass = findLoadedClass(name)\n                    if (loadedClass == null) {\n                        loadedClass = findClass(name)\n                    }\n                    if (resolve) {\n                        resolveClass(loadedClass)\n                    }\n                    return loadedClass\n                }\n                return super.loadClass(name, resolve)\n            }\n        }\n    }\n\n    private static final class ContextResolvingClassLoader extends ClassLoader {\n        boolean requested\n\n        ContextResolvingClassLoader() {\n            super(null)\n        }\n\n        @Override\n        Class<?> loadClass(String name) throws ClassNotFoundException {\n            if (CONTEXT_ONLY_DRIVER.equals(name)) {\n                requested = true\n                return ContextOnlyDriver.class\n            }\n            throw new ClassNotFoundException(name)\n        }\n    }\n\n    private static final class RejectingClassLoader extends ClassLoader {\n        RejectingClassLoader() {\n            super(null)\n        }\n\n        @Override\n        Class<?> loadClass(String name) throws ClassNotFoundException {\n            throw new ClassNotFoundException(name)\n        }\n    }\n\n    private static final class ContextOnlyDriver {\n    }\n\n    private static final class SqlLoaderOnlyDriver {\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1247, "output": 2821, "cacheRead": 34304, "cacheWrite": 0, "totalTokens": 38372, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1779511145491, "responseId": "resp_029c64c034dc2895016a112f6a4110819cb2a5c83ca134a12f"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_80pdpT1ORkcYlBwsjBRQRamr|fc_029c64c034dc2895016a112f7b5e8c819cb5e0c83f521152f3", "toolName": "write", "content": [{"type": "