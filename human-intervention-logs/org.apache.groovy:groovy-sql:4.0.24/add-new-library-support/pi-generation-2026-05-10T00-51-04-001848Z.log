  new file mode 100644
  index 0000000000..e238d3517e
  --- /dev/null
  +++ 2/tests/src/org.apache.groovy/groovy-sql/4.0.24/src/test/groovy/org_apache_groovy/groovy_sql/GroovySqlSqlTest.groovy
  @@ -0,0 +1,101 @@
  +/*
  + * Copyright and related rights waived via CC0
  + *
  + * You should have received a copy of the CC0 legalcode along with this
  + * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.
  + */
  +package org_apache_groovy.groovy_sql
  +
  +import groovy.sql.Sql
  +import org.junit.jupiter.api.Test
  +
  +import static org.assertj.core.api.Assertions.assertThat
  +import static org.assertj.core.api.Assertions.catchThrowable
  +
  +public class GroovySqlSqlTest {
  +    @Test
  +    void loadDriverUsesClassForNameWhenDriverIsVisibleToSqlClassLoader() {
  +        Sql.loadDriver(String.name)
  +    }
  +
  +    @Test
  +    void loadDriverFallsBackToContextClassLoader() {
  +        String driverClassName = 'example.ContextOnlyDriver'
  +        DriverReturningClassLoader contextClassLoader = new DriverReturningClassLoader(
  +                driverClassName,
  +                ContextOnlyDriverMarker
  +        )
  +
  +        withContextClassLoader(contextClassLoader) {
  +            Sql.loadDriver(driverClassName)
  +        }
  +
  +        assertThat(contextClassLoader.requestedNames).containsExactly(driverClassName)
  +    }
  +
  +    @Test
  +    void loadDriverFallsBackToSqlClassLoaderBeforeReportingMissingDriver() {
  +        String driverClassName = 'example.MissingDriver'
  +        RejectingClassLoader contextClassLoader = new RejectingClassLoader()
  +
  +        Throwable thrown = catchThrowable {
  +            withContextClassLoader(contextClassLoader) {
  +                Sql.loadDriver(driverClassName)
  +            }
  +        }
  +
  +        assertThat(thrown)
  +                .isInstanceOf(ClassNotFoundException)
  +                .hasMessageContaining(driverClassName)
  +        assertThat(contextClassLoader.requestedNames).containsExactly(driverClassName)
  +    }
  +
  +    private static void withContextClassLoader(ClassLoader contextClassLoader, Closure<?> action) {
  +        Thread thread = Thread.currentThread()
  +        ClassLoader previousContextClassLoader = thread.contextClassLoader
  +        thread.contextClassLoader = contextClassLoader
  +        try {
  +            action.call()
  +        } finally {
  +            thread.contextClassLoader = previousContextClassLoader
  +        }
  +    }
  +}
  +
  +public final class ContextOnlyDriverMarker {
  +}
  +
  +public final class DriverReturningClassLoader extends ClassLoader {
  +    private final String supportedName
  +    private final Class<?> returnedClass
  +    final List<String> requestedNames = []
  +
  +    DriverReturningClassLoader(String supportedName, Class<?> returnedClass) {
  +        super(null)
  +        this.supportedName = supportedName
  +        this.returnedClass = returnedClass
  +    }
  +
  +    @Override
  +    Class<?> loadClass(String name) throws ClassNotFoundException {
  +        requestedNames.add(name)
  +        if (supportedName == name) {
  +            return returnedClass
  +        }
  +        throw new ClassNotFoundException(name)
  +    }
  +}
  +
  +public final class RejectingClassLoader extends ClassLoader {
  +    final List<String> requestedNames = []
  +
  +    RejectingClassLoader() {
  +        super(null)
  +    }
  +
  +    @Override
  +    Class<?> loadClass(String name) throws ClassNotFoundException {
  +        requestedNames.add(name)
  +        throw new ClassNotFoundException(name)
  +    }
  +}
