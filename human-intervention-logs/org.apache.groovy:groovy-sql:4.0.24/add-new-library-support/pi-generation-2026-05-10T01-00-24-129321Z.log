  package org_apache_groovy.groovy_sql
  
  import groovy.sql.Sql
  import groovy.transform.CompileStatic
  import org.codehaus.groovy.runtime.InvokerHelper
  import org.graalvm.internal.tck.NativeImageSupport
  import org.junit.jupiter.api.Test
  
  import java.net.URL
  import java.net.URLClassLoader
  
  import static org.assertj.core.api.Assertions.assertThat
  
  @CompileStatic
  public class GroovySqlSqlTest {
      @Test
      void loadDriverUsesClassForNameWhenDriverIsVisibleToSqlClassLoader() {
          Sql.loadDriver(String.name)
      }
  
      @Test
      void loadDriverFallsBackToContextClassLoader() {
          String driverClassName = 'example.ContextOnlyDriver'
          DriverReturningClassLoader contextClassLoader = new DriverReturningClassLoader(
                  driverClassName,
                  Object
          )
  
          Throwable thrown = callLoadDriverWithContext(driverClassName, contextClassLoader)
  
          assertThat(thrown).isNull()
          assertThat(contextClassLoader.requestedNames).startsWith(driverClassName)
      }
  
      @Test
      void loadDriverCanLoadDriverFromSqlClassLoaderFallback() {
          String driverClassName = 'example.SqlClassLoaderOnlyDriver'
          RejectingClassLoader contextClassLoader = new RejectingClassLoader()
  
          try (IsolatedSqlClassLoader isolatedSqlClassLoader = new IsolatedSqlClassLoader(driverClassName)) {
              Throwable thrown = callIsolatedLoadDriverWithContext(driverClassName, isolatedSqlClassLoader, contextClassLoader)
  
              assertThat(thrown).isNull()
              assertThat(contextClassLoader.requestedNames).contains(driverClassName)
              assertThat(isolatedSqlClassLoader.sqlClassLoaderDriverLoads).isEqualTo(1)
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error
              }
          }
      }
  
      @Test
      void loadDriverFallsBackToSqlClassLoaderBeforeReportingMissingDriver() {
          String driverClassName = 'example.MissingDriver'
          RejectingClassLoader contextClassLoader = new RejectingClassLoader()
  
          Throwable thrown = callLoadDriverWithContext(driverClassName, contextClassLoader)
  
          assertThat(thrown)
                  .isInstanceOf(ClassNotFoundException)
                  .hasMessageContaining(driverClassName)
          assertThat(contextClassLoader.requestedNames).startsWith(driverClassName)
      }
  
      private static Throwable callIsolatedLoadDriverWithContext(
              String driverClassName,
              IsolatedSqlClassLoader isolatedSqlClassLoader,
              ClassLoader contextClassLoader) {
          Thread thread = Thread.currentThread()
          ClassLoader previousContextClassLoader = thread.contextClassLoader
          thread.contextClassLoader = contextClassLoader
          try {
              Class<?> isolatedSql = isolatedSqlClassLoader.loadClass(IsolatedSqlClassLoader.SQL_CLASS_NAME)
              InvokerHelper.invokeStaticMethod(isolatedSql, 'loadDriver', driverClassName)
              return null
          } catch (Error error) {
              throw error
          } catch (Throwable throwable) {
              return throwable
          } finally {
              thread.contextClassLoader = previousContextClassLoader
          }
      }
  
      private static Throwable callLoadDriverWithContext(String driverClassName, ClassLoader contextClassLoader) {
          Thread thread = Thread.currentThread()
          ClassLoader previousContextClassLoader = thread.contextClassLoader
          thread.contextClassLoader = contextClassLoader
          try {
              Sql.loadDriver(driverClassName)
              return null
          } catch (Throwable throwable) {
              return throwable
          } finally {
              thread.contextClassLoader = previousContextClassLoader
          }
      }
  }
  
  @CompileStatic
  public final class IsolatedSqlClassLoader extends URLClassLoader {
      static final String SQL_CLASS_NAME = 'groovy.sql.Sql'
  
      private final String driverClassName
      int sqlClassLoaderDriverLoads
  
      IsolatedSqlClassLoader(String driverClassName) {
          super([Sql.class.getProtectionDomain().getCodeSource().getLocation()] as URL[], Sql.class.getClassLoader())
          this.driverClassName = driverClassName
      }
  
      @Override
      protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {
          if (driverClassName.equals(name)) {
              if (calledFromClassForName()) {
                  throw new ClassNotFoundException(name)
              }
              sqlClassLoaderDriverLoads++
              return Object
          }
          if (name.equals(SQL_CLASS_NAME) || name.startsWith(SQL_CLASS_NAME + '$')) {
              Class<?> loadedClass = findLoadedClass(name)
              if (loadedClass == null) {
                  loadedClass = findClass(name)
              }
              if (resolve) {
                  resolveClass(loadedClass)
              }
              return loadedClass
          }
          return super.loadClass(name, resolve)
      }
  
      private static boolean calledFromClassForName() {
          StackTraceElement[] frames = Thread.currentThread().getStackTrace()
          for (StackTraceElement frame : frames) {
              if ('java.lang.Class'.equals(frame.className) && 'forName'.equals(frame.methodName)) {
                  return true
              }
          }
          return false
      }
  }
  
  @CompileStatic
  public final class DriverReturningClassLoader extends ClassLoader {
      private final String supportedName
      private final Class<?> returnedClass
      final List<String> requestedNames = new ArrayList<>()
  
      DriverReturningClassLoader(String supportedName, Class<?> returnedClass) {
          super(null)
          this.supportedName = supportedName
          this.returnedClass = returnedClass
      }
  
      @Override
      Class<?> loadClass(String name) throws ClassNotFoundException {
          requestedNames.add(name)
          if (supportedName.equals(name)) {
              return returnedClass
          }
          throw new ClassNotFoundException(name)
      }
  }
  
  @CompileStatic
  public final class RejectingClassLoader extends ClassLoader {
      final List<String> requestedNames = new ArrayList<>()
  
      RejectingClassLoader() {
          super(null)
      }
  
      @Override
      Class<?> loadClass(String name) throws ClassNotFoundException {
          requestedNames.add(name)
          throw new ClassNotFoundException(name)
      }
  }
