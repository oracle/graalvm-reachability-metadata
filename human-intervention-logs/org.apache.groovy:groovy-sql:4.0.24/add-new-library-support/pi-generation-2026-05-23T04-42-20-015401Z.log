  package org_apache_groovy.groovy_sql
  
  import groovy.sql.Sql
  import groovy.transform.CompileStatic
  import org.graalvm.internal.tck.NativeImageSupport
  import org.junit.jupiter.api.Test
  
  import java.lang.reflect.InvocationTargetException
  import java.lang.reflect.Method
  import java.net.URL
  import java.net.URLClassLoader
  
  import static org.junit.jupiter.api.Assertions.assertEquals
  import static org.junit.jupiter.api.Assertions.assertTrue
  import static org.junit.jupiter.api.Assertions.fail
  
  @CompileStatic
  public class SqlTest {
      private static final String CONTEXT_ONLY_DRIVER = 'org_apache_groovy.groovy_sql.ContextOnlyDriver'
      private static final String SQL_LOADER_ONLY_DRIVER = 'org_apache_groovy.groovy_sql.SqlLoaderOnlyDriver'
      private static final String MISSING_DRIVER = 'org_apache_groovy.groovy_sql.NoSuchJdbcDriver'
  
      @Test
      void loadDriverResolvesClassAvailableToSqlClassLoader() throws ClassNotFoundException {
          Sql.loadDriver(String.class.getName())
      }
  
      @Test
      void loadDriverUsesThreadContextClassLoaderWhenClassForNameCannotResolveDriver() throws ClassNotFoundException {
          Thread thread = Thread.currentThread()
          ClassLoader originalClassLoader = thread.getContextClassLoader()
          ContextResolvingClassLoader contextClassLoader = new ContextResolvingClassLoader()
  
          thread.setContextClassLoader(contextClassLoader)
          try {
              Sql.loadDriver(CONTEXT_ONLY_DRIVER)
          } finally {
              thread.setContextClassLoader(originalClassLoader)
          }
  
          assertTrue(contextClassLoader.requested)
      }
  
      @Test
      void loadDriverUsesSqlClassLoaderWhenContextClassLoaderCannotResolveDriver() throws Exception {
          try {
              IsolatedSqlClassLoader sqlClassLoader = new IsolatedSqlClassLoader(sqlCodeSource())
              try {
                  Class<?> isolatedSqlClass = sqlClassLoader.loadClass(Sql.class.getName())
                  Method loadDriver = isolatedSqlClass.getMethod('loadDriver', String.class)
                  invokeLoadDriverWithRejectingContextClassLoader(loadDriver)
  
                  assertTrue(sqlClassLoader.sqlLoaderRequested)
              } finally {
                  sqlClassLoader.close()
              }
          } catch (InvocationTargetException exception) {
              Throwable cause = exception.getCause()
              if (cause instanceof Error && NativeImageSupport.isUnsupportedFeatureError((Error) cause)) {
                  return
              }
              throw exception
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error
              }
          }
      }
  
      @Test
      void loadDriverAttemptsSqlClassLoaderWhenContextClassLoaderCannotResolveDriver() {
          Thread thread = Thread.currentThread()
          ClassLoader originalClassLoader = thread.getContextClassLoader()
  
          ClassNotFoundException thrown = null
          thread.setContextClassLoader(new RejectingClassLoader())
          try {
              Sql.loadDriver(MISSING_DRIVER)
          } catch (ClassNotFoundException exception) {
              thrown = exception
          } finally {
              thread.setContextClassLoader(originalClassLoader)
          }
  
          if (thrown == null) {
              fail('Expected missing driver class to throw ClassNotFoundException')
          }
          assertEquals(MISSING_DRIVER, thrown.getMessage())
      }
  
      private static URL sqlCodeSource() {
          return Sql.class.getProtectionDomain().getCodeSource().getLocation()
      }
  
      private static void invokeLoadDriverWithRejectingContextClassLoader(Method loadDriver) throws Exception {
          Thread thread = Thread.currentThread()
          ClassLoader originalClassLoader = thread.getContextClassLoader()
  
          thread.setContextClassLoader(new RejectingClassLoader())
          try {
              loadDriver.invoke(null, SQL_LOADER_ONLY_DRIVER)
          } finally {
              thread.setContextClassLoader(originalClassLoader)
          }
      }
  
      private static final class IsolatedSqlClassLoader extends URLClassLoader {
          boolean sqlLoaderRequested
          private boolean rejectFirstDriverRequest = true
  
          IsolatedSqlClassLoader(URL sqlJar) {
              super([sqlJar] as URL[], SqlTest.class.getClassLoader())
          }
  
          @Override
          protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {
              synchronized (getClassLoadingLock(name)) {
                  if (SQL_LOADER_ONLY_DRIVER.equals(name)) {
                      if (rejectFirstDriverRequest) {
                          rejectFirstDriverRequest = false
                          throw new ClassNotFoundException(name)
                      }
                      sqlLoaderRequested = true
                      return SqlLoaderOnlyDriver.class
                  }
                  if (name.equals(Sql.class.getName()) || name.startsWith(Sql.class.getName() + '$')) {
                      Class<?> loadedClass = findLoadedClass(name)
                      if (loadedClass == null) {
                          loadedClass = findClass(name)
                      }
                      if (resolve) {
                          resolveClass(loadedClass)
                      }
                      return loadedClass
                  }
                  return super.loadClass(name, resolve)
              }
          }
      }
  
      private static final class ContextResolvingClassLoader extends ClassLoader {
          boolean requested
  
          ContextResolvingClassLoader() {
              super(null)
          }
  
          @Override
          Class<?> loadClass(String name) throws ClassNotFoundException {
              if (CONTEXT_ONLY_DRIVER.equals(name)) {
                  requested = true
                  return ContextOnlyDriver.class
              }
              throw new ClassNotFoundException(name)
          }
      }
  
      private static final class RejectingClassLoader extends ClassLoader {
          RejectingClassLoader() {
              super(null)
          }
  
          @Override
          Class<?> loadClass(String name) throws ClassNotFoundException {
              throw new ClassNotFoundException(name)
          }
      }
  
      private static final class ContextOnlyDriver {
      }
  
      private static final class SqlLoaderOnlyDriver {
      }
  }
