commons.org/publicdomain/zero/1.0/>.\n */\npackage org_apache_groovy.groovy_sql\n\nimport groovy.sql.GroovyResultSet\nimport groovy.sql.GroovyResultSetProxy\nimport groovy.transform.CompileStatic\nimport org.junit.jupiter.api.Test\n\nimport javax.sql.rowset.CachedRowSet\nimport javax.sql.rowset.RowSetMetaDataImpl\nimport javax.sql.rowset.RowSetProvider\nimport java.sql.Types\n\nimport static org.junit.jupiter.api.Assertions.assertEquals\nimport static org.junit.jupiter.api.Assertions.assertFalse\nimport static org.junit.jupiter.api.Assertions.assertTrue\n\n@CompileStatic\npublic class GroovyResultSetProxyTest {\n    @Test\n    void getImplCreatesGroovyResultSetThatDelegatesToWrappedResultSet() throws Exception {\n        CachedRowSet rowSet = singleRowSet('name', 'Ada')\n        try {\n            GroovyResultSet resultSet = new GroovyResultSetProxy(rowSet).getImpl()\n\n            assertTrue(resultSet.next())\n            assertEquals('Ada', resultSet.getString(1))\n            assertEquals('Ada', resultSet.getAt(0))\n            assertFalse(resultSet.next())\n        } finally {\n            rowSet.close()\n        }\n    }\n\n    private static CachedRowSet singleRowSet(String columnName, String value) throws Exception {\n        CachedRowSet rowSet = RowSetProvider.newFactory().createCachedRowSet()\n        RowSetMetaDataImpl metadata = new RowSetMetaDataImpl()\n        metadata.setColumnCount(1)\n        metadata.setColumnName(1, columnName)\n        metadata.setColumnLabel(1, columnName)\n        metadata.setColumnType(1, Types.VARCHAR)\n        rowSet.setMetaData(metadata)\n\n        rowSet.moveToInsertRow()\n        rowSet.updateString(1, value)\n        rowSet.insertRow()\n        rowSet.moveToCurrentRow()\n        rowSet.beforeFirst()\n        return rowSet\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 230, "output": 926, "cacheRead": 26112, "cacheWrite": 0, "totalTokens": 27268, "cost": {"input": 0, 