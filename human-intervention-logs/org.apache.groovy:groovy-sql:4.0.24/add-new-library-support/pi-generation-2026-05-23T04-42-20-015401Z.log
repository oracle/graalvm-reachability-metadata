;\nimport java.lang.reflect.Method;\nimport java.lang.reflect.Proxy;\nimport java.sql.ResultSet;\n\n/**\n * GroovyResultSetProxy is used to create a proxy for GroovyResultSet.\n * Due to the version incompatibility between java 6 and older versions\n * methods with additional logic were moved into an extension class. When\n * getting properties or calling methods, the runtime will try to first\n * execute these on the extension and then on the ResultSet itself.\n * This way it is possible to replace and add methods. To overload methods\n * from ResultSet all methods have to be implemented on the extension\n * class.\n */\npublic final class GroovyResultSetProxy implements InvocationHandler {\n\n    private final GroovyResultSetExtension extension;\n\n    /**\n     * Creates a new proxy instance.\n     * This will create the extension automatically using\n     * GroovyResultSetExtension\n     *\n     * @param set the result set to delegate to\n     * @see GroovyResultSetExtension\n     */\n    public GroovyResultSetProxy(ResultSet set) {\n        extension = new GroovyResultSetExtension(set);\n    }\n\n    /**\n     * Creates a new proxy instance with a custom extension.\n     *\n     * @param ext the extension\n     * @see GroovyResultSetExtension\n     */\n    public GroovyResultSetProxy(GroovyResultSetExtension ext) {\n        extension = ext;\n    }\n\n    /**\n     * Invokes a method for the GroovyResultSet.\n     * This will try to invoke the given method first on the extension\n     * and then on the result set given as proxy parameter.\n     *\n     * @param proxy  the result set\n     * @param method the method name of this method will be used\n     *               to make a call on the extension. If this fails the call will be\n     *               done on the proxy instead\n     * @param args   for the call\n     * @see ResultSet\n     * @see java.lang.reflect.InvocationHandler#invoke(java.lang.Object, java.lang.reflect.Method, java.lang.Object[])\n     */\n    @Override\n    public Object invoke(Object proxy, Method method, Object[] args) throws Throwable {\n        String name = method.getName();\n        if (method.getDeclaringClass() == GroovyObject.class) {\n            if (name.equals(\"getMetaClass\")) {\n                return getMetaClass();\n            } else if (name.equals(\"setMetaClass\")) {\n                return setMetaClass((MetaClass) args[0]);\n            }\n        }\n\n        return InvokerHelper.invokeMethod(extension, method.getName(), args);\n    }\n\n    private MetaClass metaClass;\n\n    private MetaClass setMetaClass(MetaClass mc) {\n        metaClass = mc;\n        return mc;\n    }\n\n    /**\n     * This class is introduced as a workaround for GROOVY-6187, which failed\n     * because if you use a metaclass from an interface, methods defined on\n     * Object cannot be called.\n     */\n    private abstract static class DummyResultSet implements GroovyResultSet {}\n\n    private MetaClass getMetaClass() {\n        if (metaClass == null) {\n            metaClass = GroovySystem.getMetaClassRegistry().getMetaClass(DummyResultSet.class);\n        }\n        return metaClass;\n    }\n\n    /**\n     * Gets a proxy instance that can be used as GroovyResultSet.\n     *\n     * @return the proxy\n     */\n    public GroovyResultSet getImpl() {\n        return (GroovyResultSet)\n                Proxy.newProxyInstance(\n                        this.getClass().getClassLoader(),\n                        new Class[]{GroovyResultSet.class},\n                        this\n                );\n    }\n}\n"}], "isError": false, "timestamp": 1779511266204}, {"role": "toolResult", "toolCallId": "call_EkVBSPERF0HuICVH6JcHalkt|fc_02ec3edb6951f0d8016a112fe1ffe881a18d9b2e0347faab59", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_apache_groovy.groovy_sql\n\nimport groovy.sql.Sql\nimport groovy.transform.CompileStatic\nimport org.graalvm.internal.tck.NativeImageSupport\nimport org.junit.jupiter.api.Test\n\nimport java.lang.reflect.InvocationTargetException\nimport java.lang.reflect.Method\nimport java.net.URL\nimport java.net.URLClassLoader\n\nimport static org.junit.jupiter.api.Assertions.assertEquals\nimport static org.junit.jupiter.api.Assertions.assertTrue\nimport static org.junit.jupiter.api.Assertions.fail\n\n@CompileStatic\npublic class SqlTest {\n    private static final String CONTEXT_ONLY_DRIVER = 'org_apache_groovy.groovy_sql.ContextOnlyDriver'\n    private static final String SQL_LOADER_ONLY_DRIVER = 'org_apache_groovy.groovy_sql.SqlLoaderOnlyDriver'\n    private static final String MISSING_DRIVER = 'org_apache_groovy.groovy_sql.NoSuchJdbcDriver'\n\n    @Test\n    void loadDriverResolvesClassAvailableToSqlClassLoader() throws ClassNotFoundException {\n        Sql.loadDriver(String.class.getName())\n    }\n\n    @Test\n    void loadDriverUsesThreadContextClassLoaderWhenClassForNameCannotResolveDriver() throws ClassNotFoundException {\n        Thread thread = Thread.currentThread()\n        ClassLoader originalClassLoader = thread.getContextClassLoader()\n        ContextResolvingClassLoader contextClassLoader = new ContextResolvingClassLoader()\n\n        thread.setContextClassLoader(contextClassLoader)\n        try {\n            Sql.loadDriver(CONTEXT_ONLY_DRIVER)\n        } finally {\n            thread.setContextClassLoader(originalClassLoader)\n        }\n\n        assertTrue(contextClassLoader.requested)\n    }\n\n    @Test\n    void loadDriverUsesSqlClassLoaderWhenContextClassLoaderCannotResolveDriver() throws Exception {\n        try {\n            IsolatedSqlClassLoader sqlClassLoader = new IsolatedSqlClassLoader(sqlCodeSource())\n            try {\n                Class<?> isolatedSqlClass = sqlClassLoader.loadClass(Sql.class.getName())\n                Method loadDriver = isolatedSqlClass.getMethod('loadDriver', String.class)\n                invokeLoadDriverWithRejectingContextClassLoader(loadDriver)\n\n                assertTrue(sqlClassLoader.sqlLoaderRequested)\n            } finally {\n                sqlClassLoader.close()\n            }\n        } catch (InvocationTargetException exception) {\n            Throwable cause = exception.getCause()\n            if (cause instanceof Error && NativeImageSupport.isUnsupportedFeatureError((Error) cause)) {\n                return\n            }\n            throw exception\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error\n            }\n        }\n    }\n\n    @Test\n    void loadDriverAttemptsSqlClassLoaderWhenContextClassLoaderCannotResolveDriver() {\n        Thread thread = Thread.currentThread()\n        ClassLoader originalClassLoader = thread.getContextClassLoader()\n\n        ClassNotFoundException thrown = null\n        thread.setContextClassLoader(new RejectingClassLoader())\n        try {\n            Sql.loadDriver(MISSING_DRIVER)\n        } catch (ClassNotFoundException exception) {\n            thrown = exception\n        } finally {\n            thread.setContextClassLoader(originalClassLoader)\n        }\n\n        if (thrown == null) {\n            fail('Expected missing driver class to throw ClassNotFoundException')\n        }\n        assertEquals(MISSING_DRIVER, thrown.getMessage())\n    }\n\n    private static URL sqlCodeSource() {\n        return Sql.class.getProtectionDomain().getCodeSource().getLocation()\n    }\n\n    private static void invokeLoadDriverWithRejectingContextClassLoader(Method loadDriver) throws Exception {\n        Thread thread = Thread.currentThread()\n        ClassLoader originalClassLoader = thread.getContextClassLoader()\n\n        thread.setContextClassLoader(new RejectingClassLoader())\n        try {\n            loadDriver.invoke(null, SQL_LOADER_ONLY_DRIVER)\n        } finally {\n            thread.setContextClassLoader(originalClassLoader)\n        }\n    }\n\n    private static final class IsolatedSqlClassLoader extends URLClassLoader {\n        boolean sqlLoaderRequested\n        private boolean rejectFirstDriverRequest = true\n\n        IsolatedSqlClassLoader(URL sqlJar) {\n            super([sqlJar] as URL[], SqlTest.class.getClassLoader())\n        }\n\n        @Override\n        protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {\n            synchronized (getClassLoadingLock(name)) {\n                if (SQL_LOADER_ONLY_DRIVER.equals(name)) {\n                    if (rejectFirstDriverRequest) {\n                        rejectFirstDriverRequest = false\n                        throw new ClassNotFoundException(name)\n                    }\n                    sqlLoaderRequested = true\n                    return SqlLoaderOnlyDriver.class\n                }\n                if (name.equals(Sql.class.getName()) || name.startsWith(Sql.class.getName() + '$')) {\n                    Class<?> loadedClass = findLoadedClass(name)\n                    if (loadedClass == null) {\n                        loadedClass = findClass(name)\n                    }\n                    if (resolve) {\n                        resolveClass(loadedClass)\n                    }\n                    return loadedClass\n                }\n                return super.loadClass(name, resolve)\n            }\n        }\n    }\n\n    private static final class ContextResolvingClassLoader extends ClassLoader {\n        boolean requested\n\n        ContextResolvingClassLoader() {\n            super(null)\n        }\n\n        @Override\n        Class<?> loadClass(String name) throws ClassNotFoundException {\n            if (CONTEXT_ONLY_DRIVER.equals(name)) {\n                requested = true\n                return ContextOnlyDriver.class\n            }\n            throw new ClassNotFoundException(name)\n        }\n    }\n\n    private static final class RejectingClassLoader extends ClassLoader {\n        RejectingClassLoader() {\n            super(null)\n        }\n\n        @Override\n        Class<?> loadClass(String name) throws ClassNotFoundException {\n            throw new ClassNotFoundException(name)\n        }\n    }\n\n    private static final class ContextOnlyDriver {\n    }\n\n    private static final class SqlLoaderOnlyDriver {\n    }\n}\n"}], "isError": false, "timestamp": 1779511266204}, {"role": "toolResult", "toolCallId": "call_gvckBnk2VkTxejq8dQI38nsn|fc_02ec3edb6951f0d8016a112fe1fff481a1b963b9b1873efe0c", "toolName": "bash", "content": [{"type": "text", "text": "/home/vjovanov/c/forge/forge10/graalvm-reachability-metadata/forge/local_repositories/source_context/org.apache.groovy/groovy-sql/4.0.24/main/extracted/groovy/sql/BatchingPreparedStatementWrapper.java\n/home/vjovanov/c/forge/forge10/graalvm-reachability-metadata/forge/local_repositories/source_context/org.apache.groovy/groovy-sql/4.0.24/main/extracted/groovy/sql/BatchingStatementWrapper.java\n/home/vjovanov/c/forge/forge10/graalvm-reachability-metadata/forge/local_repositories/source_context/org.apache.groovy/groovy-sql/4.0.24/main/extracted/groovy/sql/CallResultSet.java\n/home/vjovanov/c/forge/forge10/graalvm-reachability-metadata/forge/local_repositories/source_context/org.apache.groovy/groovy-sql/4.0.24/main/extracted/groovy/sql/DataSet.java\n/home/vjovanov/c/forge/forge10/graalvm-reachability-metadata/forge/local_repositories/source_context/org.apache.groovy/groovy-sql/4.0.24/main/extracted/groovy/sql/ExpandedVariable.java\n/home/vjovanov/c/forge/forge10/graalvm-reachability-metadata/forge/local_repositories/source_context/org.apache.groovy/groovy-sql/4.0.24/main/extracted/groovy/sql/ExtractIndexAndSql.java\n/home/vjovanov/c/forge/forge10/graalvm-reachability-metadata/forge/local_repositories/source_context/org.apache.groovy/gr