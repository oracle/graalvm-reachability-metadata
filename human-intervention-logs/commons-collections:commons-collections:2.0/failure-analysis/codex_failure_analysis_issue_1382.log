Map(settings);\\n\\n        BeanMap clonedMap = (BeanMap) beanMap.clone();\\n\\n        assertThat(clonedMap).isNotSameAs(beanMap);\\n        assertThat(clonedMap.getBean()).isInstanceOf(BeanBackedSettings.class).isNotSameAs(settings);\\n        assertThat(clonedMap.get(\\\"name\\\")).isEqualTo(\\\"source\\\");\\n        assertThat(clonedMap.get(\\\"count\\\")).isEqualTo(Integer.valueOf(13));\\n    }\\n\\n    public static final class BeanBackedSettings {\\n        private String name = \\\"default-name\\\";\\n        private Integer count = Integer.valueOf(1);\\n\\n        public BeanBackedSettings() {\\n        }\\n\\n        public String getName() {\\n            return name;\\n        }\\n\\n        public void setName(String name) {\\n            this.name = name;\\n        }\\n\\n        public Integer getCount() {\\n            return count;\\n        }\\n\\n        public void setCount(Integer count) {\\n            this.count = count;\\n        }\\n    }\\n}\\n\",\"exit_code\":0,\"status\":\"completed\"}}\n{\"type\":\"item.started\",\"item\":{\"id\":\"item_8\",\"type\":\"command_execution\",\"command\":\"/usr/bin/bash -lc \\\"sed -n '1,240p' tests/src/commons-collections/commons-collections/2.0/src/test/java/commons_collections/commons_collections/Commons_collectionsTest.java\\\"\",\"aggregated_output\":\"\",\"exit_code\":null,\"status\":\"in_progress\"}}\n{\"type\":\"item.completed\",\"item\":{\"id\":\"item_8\",\"type\":\"command_execution\",\"command\":\"/usr/bin/bash -lc \\\"sed -n '1,240p' tests/src/commons-collections/commons-collections/2.0/src/test/java/commons_collections/commons_collections/Commons_collectionsTest.java\\\"\",\"aggregated_output\":\"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage commons_collections.commons_collections;\\n\\nimport org.junit.jupiter.api.Test;\