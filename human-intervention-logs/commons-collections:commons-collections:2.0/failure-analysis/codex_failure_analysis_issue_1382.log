   \\\"com.example.Foo.get(Unknown Source)\\\",\\n                    \\\"com.example.Foo.miss(Unknown Source)\\\",\\n                    \\\"com.example.Foo.lineCovered(Foo.java:10)\\\",\\n                    \\\"com.example.Foo.lineMissed(Foo.java:11)\\\"\\n                  ]\\n                }\\n                \\\"\\\"\\\",\\n                StandardCharsets.UTF_8\\n        );\\n\\n        Path jacocoReport = tempDir.resolve(\\\"jacoco.xml\\\");\\n        Files.writeString(\\n                jacocoReport,\\n                \\\"\\\"\\\"\\n                <?xml version=\\\"1.0\\\" encoding=\\\"UTF-8\\\" standalone=\\\"yes\\\"?>\\n                <report name=\\\"demo\\\">\\n                  <package name=\\\"com/example\\\">\\n                    <class name=\\\"com/example/Foo\\\">\\n                      <method name=\\\"get\\\" desc=\\\"()Ljava/lang/Object;\\\">\\n                        <counter type=\\\"INSTRUCTION\\\" missed=\\\"0\\\" covered=\\\"4\\\"/>\\n                        <counter type=\\\"METHOD\\\" missed=\\\"0\\\" covered=\\\"1\\\"/>\\n                      </method>\\n                      <method name=\\\"miss\\\" desc=\\\"()Ljava/lang/Object;\\\">\\n                        <counter type=\\\"INSTRUCTION\\\" missed=\\\"4\\\" covered=\\\"0\\\"/>\\n                        <counter type=\\\"METHOD\\\" missed=\\\"1\\\" covered=\\\"0\\\"/>\\n                      </method>\\n                      <counter type=\\\"INSTRUCTION\\\" missed=\\\"4\\\" covered=\\\"4\\\"/>\\n                      <counter type=\\\"METHOD\\\" missed=\\\"1\\\" covered=\\\"1\\\"/>\\n                    </class>\\n                    <sourcefile name=\\\"Foo.java\\\">\\n                      <line nr=\\\"10\\\" mi=\\\"0\\\" ci=\\\"3\\\" mb=\\\"0\\\" cb=\\\"0\\\"/>\\n                      <line nr=\\\"11\\\" mi=\\\"3\\\" ci=\\\"0\\\" mb=\\\"0\\\" cb=\\\"0\\\"/>\\n                    </sourcefile>\\n                  </package>\\n                  <counter type=\\\"INSTRUCTION\