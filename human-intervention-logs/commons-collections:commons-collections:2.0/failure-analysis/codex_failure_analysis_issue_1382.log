ap.getBean()).isInstanceOf(SampleBean.class).isNotSameAs(bean);\\n        SampleBean clearedBean = (SampleBean) beanMap.getBean();\\n        assertThat(clearedBean.getName()).isEqualTo(\\\"default-name\\\");\\n        assertThat(clearedBean.getConvertedValue()).isNull();\\n    }\\n\\n    @Test\\n    public void cloneCreatesANewBeanAndCopiesWritableProperties() throws CloneNotSupportedException {\\n        SampleBean bean = new SampleBean();\\n        bean.setName(\\\"original\\\");\\n        bean.setConvertedValue(new ConvertibleValue(\\\"copy-me\\\"));\\n        BeanMap beanMap = new BeanMap(bean);\\n\\n        BeanMap clonedMap = (BeanMap) beanMap.clone();\\n\\n        assertThat(clonedMap).isNotSameAs(beanMap);\\n        assertThat(clonedMap.getBean()).isInstanceOf(SampleBean.class).isNotSameAs(bean);\\n        SampleBean clonedBean = (SampleBean) clonedMap.getBean();\\n        assertThat(clonedBean.getName()).isEqualTo(\\\"original\\\");\\n        assertThat(clonedBean.getConvertedValue()).isEqualTo(new ConvertibleValue(\\\"copy-me\\\"));\\n    }\\n\\n    public static class SampleBean {\\n        private String name = \\\"default-name\\\";\\n        private ConvertibleValue convertedValue;\\n\\n        public SampleBean() {\\n        }\\n\\n        public String getName() {\\n            return name;\\n        }\\n\\n        public void setName(String name) {\\n            this.name = name;\\n        }\\n\\n        public ConvertibleValue getConvertedValue() {\\n            return convertedValue;\\n        }\\n\\n        public void setConvertedValue(ConvertibleValue convertedValue) {\\n            this.convertedValue = convertedValue;\\n        }\\n    }\\n\\n    public static class ConvertibleValue {\\n        private final String value;\\n\\n        public ConvertibleValue(String value) {\\n            this.value = value;\\n        }\\n\\n        public String getValue() {\\n            return value;\\n        }\\n\\n        @Override\\n        public boolean equals(Object object) {\\n            if (this == object) {\\n                return true;\\n            }\\n            if (!(object instanceof ConvertibleValue)) {\\n                return false;\\n            }\\n            ConvertibleValue that = (ConvertibleValue) object;\\n            return value.equals(that.value);\\n        }\\n\\n        @Override\\n        public int hashCode() {\\n            return value.hashCode();\\n        }\\n    }\\n}\\n\", \"newText\": \"package commons_collections.commons_collections;\\n\\nimport org.apache.commons.collections.BeanMap;\\nimport org.junit.jupiter.api.Test;\\n\\nimport java.io.File;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\n\\npublic class BeanMapTest {\\n    private String name = \\\"default-name\\\";\\n    private File path;\\n\\n    @Test\\n    public void readsAndWritesBeanProperties() {\\n        BeanMapTest bean = newBean(\\\"before\\\", null);\\n        BeanMap beanMap = new BeanMap(bean);\\n\\n        assertThat(beanMap.get(\\\"name\\\")).isEqualTo(\\\"before\\\");\\n        assertThat(beanMap.put(\\\"name\\\", \\\"after\\\")).isEqualTo(\\\"before\\\");\\n\\n        assertThat(bean.getName()).isEqualTo(\\\"after\\\");\\n        assertThat(beanMap.get(\\\"name\\\")).isEqualTo(\\\"after\\\");\\n    }\\n\\n    @Test\\n    public void convertsStringValuesUsingSingleArgumentConstructors() {\\n        BeanMapTest bean = newBean(\\\"unchanged\\\", null);\\n        BeanMap beanMap = new BeanMap(bean);\\n\\n        Object previousValue = beanMap.put(\\\"path\\\", \\\"converted-path\\\");\\n\\n        assertThat(previousValue).isNull();\\n        assertThat(bean.getPath()).isEqualTo(new File(\\\"converted-path\\\"));\\n        assertThat(beanMap.get(\\\"path\\\")).isEqualTo(new File(\\\"converted-path\\\"));\\n    }\\n\\n    @Test\\n    public void clearReplacesBeanWithDefaultInstance() {\\n        BeanMapTest bean = newBean(\\\"before-clear\\\", new File(\\\"set-path\\\"));\\n        BeanMap beanMap = new BeanMap(bean);\\n\\n        beanMap.clear();\\n\\n        assertThat(beanMap.getBean()).isInstanceOf(BeanMapTest.class).isNotSameAs(bean);\\n        BeanMapTest clearedBean = (BeanMapTest) beanMap.getBean();\\n        assertThat(clearedBean.getName()).isEqualTo(\\\"default-name\\\");\\n        assertThat(clearedBean.getPath()).isNull();\\n    }\\n\\n    @Test\\n    public void cloneCreatesANewBeanAndCopiesWritableProperties() throws CloneNotSupportedException {\\n        BeanMapTest bean = newBean(\\\"original\\\", new File(\\\"copy-me\\\"));\\n        BeanMap beanMap = new BeanMap(bean);\\n\\n        BeanMap clonedMap = (BeanMap) beanMap.clone();\\n\\n        assertThat(clonedMap).isNotSameAs(beanMap);\\n        assertThat(clonedMap.getBean()).isInstanceOf(BeanMapTest.class).isNotSameAs(bean);\\n        BeanMapTest clonedBean = (BeanMapTest) clonedMap.getBean();\\n        assertThat(clonedBean.getName()).isEqualTo(\\\"original\\\");\\n        assertThat(clonedBean.getPath()).isEqualTo(new File(\\\"copy-me\\\"));\\n    }\\n\\n    public String getName() {\\n        return name;\\n    }\\n\\n    public void setName(String name) {\\n        this.name = name;\\n    }\\n\\n    public File getPath() {\\n        return path;\\n    }\\n\\n    public void setPath(File path) {\\n        this.path = path;\\n    }\\n\\n    private static BeanMapTest newBean(String name, File path) {\\n        BeanMapTest bean = new BeanMapTest();\\n        bean.setName(name);\\n        bean.setPath(path);\\n        return bean;\\n    }\\n}\\n\"}]}\nhuman-intervention-logs/commons-collections:commons-collections:2.0/add-new-library-support/pi-generation-2026-04-28T02-45-43-405257Z.log:6740:[recv] {\"type\": \"message_end\", \"message\": {\"role\": \"assistant\", \"content\": [{\"type\": \"thinking\", \"thinking\": \"**Evaluating Java class properties**\\n\\nI'm considering a one-to-one mapping for an active class in its own dedicated Java test file. I wonder if using helper Java