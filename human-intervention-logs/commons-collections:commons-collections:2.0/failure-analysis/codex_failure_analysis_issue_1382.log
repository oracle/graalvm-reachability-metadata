ANewBeanAndCopiesWritableProperties() throws CloneNotSupportedException {\\n        BeanMapTest bean = newBean(\\\"original\\\", new File(\\\"copy-me\\\"));\\n        BeanMap beanMap = new BeanMap(bean);\\n\\n        BeanMap clonedMap = (BeanMap) beanMap.clone();\\n\\n        assertThat(clonedMap).isNotSameAs(beanMap);\\n        assertThat(clonedMap.getBean()).isInstanceOf(BeanMapTest.class).isNotSameAs(bean);\\n        BeanMapTest clonedBean = (BeanMapTest) clonedMap.getBean();\\n        assertThat(clonedBean.getName()).isEqualTo(\\\"original\\\");\\n        assertThat(clonedBean.getPath()).isEqualTo(new File(\\\"copy-me\\\"));\\n    }\\n\\n    public String getName() {\\n        return name;\\n    }\\n\\n    public void setName(String name) {\\n        this.name = name;\\n    }\\n\\n    public File getPath() {\\n        return path;\\n    }\\n\\n    public void setPath(File path) {\\n        this.path = path;\\n    }\\n\\n    private static BeanMapTest newBean(String name, File path) {\\n        BeanMapTest bean = new BeanMapTest();\\n        bean.setName(name);\\n        bean.setPath(path);\\n        return bean;\\n    }\\n}\\n\"}], \"isError\": false, \"timestamp\": 1777344627744}]}\nhuman-intervention-logs/commons-collections:commons-collections:2.0/add-new-library-support/pi-generation-2026-04-28T02-45-43-405257Z.log:7475:[thinking] I'm thinking I might need to commit further and ensure the native image reflection metadata for the test class is correct. The dynamic report seems old, and the user mentioned there’s nothing after the workflow. The test class might have an extra getter that affects things, and it looks like new attempts might not be running as expected. I need to check the logs and see if the native agent generates metadata correctly for test beans. Perhaps adding a direct test to cover dynamic calls could help!\nhuman-intervention-logs/commons-collections:commons-collections:2.0/add-new-library-support/pi-generation-2026-04-28T02-45-43-405257Z.lo