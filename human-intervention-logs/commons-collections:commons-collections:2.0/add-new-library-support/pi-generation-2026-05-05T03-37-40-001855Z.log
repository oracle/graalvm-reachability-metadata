  +                        Tuple.tuple("com.example.Foo.lineCovered(Foo.java:10)", true),
  +                        Tuple.tuple("com.example.Foo.lineMissed(Foo.java:11)", false),
  +                        Tuple.tuple("com.example.Foo.miss(Unknown Source)", false)
  +                );
