p://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage commons_collections.commons_collections;\n\nimport org.apache.commons.collections.BeanMap;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class BeanMapTest {\n    @Test\n    public void readsAndWritesBeanProperties() {\n        SampleBean bean = new SampleBean();\n        bean.setName(\"before\");\n        BeanMap beanMap = new BeanMap(bean);\n\n        assertThat(beanMap.get(\"name\")).isEqualTo(\"before\");\n        assertThat(beanMap.put(\"name\", \"after\")).isEqualTo(\"before\");\n\n        assertThat(bean.getName()).isEqualTo(\"after\");\n        assertThat(beanMap.get(\"name\")).isEqualTo(\"after\");\n    }\n\n    @Test\n    public void convertsValuesUsingSingleArgumentConstructors() {\n        SampleBean bean = new SampleBean();\n        BeanMap beanMap = new BeanMap(bean);\n\n        Object previousValue = beanMap.put(\"convertedValue\", \"converted\");\n\n        assertThat(previousValue).isNull();\n        assertThat(bean.getConvertedValue().getValue()).isEqualTo(\"converted\");\n        assertThat(beanMap.get(\"convertedValue\")).isEqualTo(new ConvertibleValue(\"converted\"));\n    }\n\n    @Test\n    public void clearReplacesBeanWithDefaultInstance() {\n        SampleBean bean = new SampleBean();\n        bean.setName(\"before-clear\");\n        bean.setConvertedValue(new ConvertibleValue(\"set\"));\n        BeanMap beanMap = new BeanMap(bean);\n\n        beanMap.clear();\n\n        assertThat(beanMap.getBean()).isInstanceOf(SampleBean.class).isNotSameAs(bean);\n        SampleBean clearedBean = (SampleBean) beanMap.getBean();\n        assertThat(clearedBean.getName()).isEqualTo(\"default-name\");\n        assertThat(clearedBean.getConvertedValue()).isNull();\n    }\n\n    @Test\n    public void cloneCreatesANewBeanAndCopiesWritableProperties() throws CloneNotSupportedException {\n        SampleBean bean = new SampleBean();\n        bean.setName(\"original\");\n        bean.setConvertedValue(new ConvertibleValue(\"copy-me\"));\n        BeanMap beanMap = new BeanMap(bean);\n\n        BeanMap clonedMap = (BeanMap) beanMap.clone();\n\n        assertThat(clonedMap).isNotSameAs(beanMap);\n        assertThat(clonedMap.getBean()).isInstanceOf(SampleBean.class).isNotSameAs(bean);\n        SampleBean clonedBean = (SampleBean) clonedMap.getBean();\n        assertThat(clonedBean.getName()).isEqualTo(\"original\");\n        assertThat(clonedBean.getConvertedValue()).isEqualTo(new ConvertibleValue(\"copy-me\"));\n    }\n\n    public static class SampleBean {\n        private String name = \"default-name\";\n        private ConvertibleValue convertedValue;\n\n        public SampleBean() {\n        }\n\n        public String getName() {\n            return name;\n        }\n\n        public void setName(String name) {\n            this.name = name;\n        }\n\n        public ConvertibleValue getConvertedValue() {\n            return convertedValue;\n        }\n\n        public void setConvertedValue(ConvertibleValue convertedValue) {\n            this.convertedValue = convertedValue;\n        }\n    }\n\n    public static class ConvertibleValue {\n        private final String value;\n\n        public ConvertibleValue(String value) {\n            this.value = value;\n        }\n\n        public String getValue() {\n            return value;\n        }\n\n        @Override\n        public boolean equals(Object object) {\n            if (this == object) {\n                return true;\n            }\n            if (!(object instanceof ConvertibleValue)) {\n                return false;\n            }\n            ConvertibleValue that = (ConvertibleValue) object;\n            return value.equals(that.value);\n        }\n\n        @Override\n        public int hashCode() {\n            return value.hashCode();\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777344444337}]}
