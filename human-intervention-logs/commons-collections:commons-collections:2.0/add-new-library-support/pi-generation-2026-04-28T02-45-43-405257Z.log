  package commons_collections.commons_collections;
  
  import org.apache.commons.collections.BeanMap;
  import org.junit.jupiter.api.Test;
  
  import java.io.File;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class BeanMapTest {
      private String name = "default-name";
      private File path;
  
      @Test
      public void readsAndWritesBeanProperties() {
          BeanMapTest bean = newBean("before", null);
          BeanMap beanMap = new BeanMap(bean);
  
          assertThat(beanMap.get("name")).isEqualTo("before");
          assertThat(beanMap.put("name", "after")).isEqualTo("before");
  
          assertThat(bean.getName()).isEqualTo("after");
          assertThat(beanMap.get("name")).isEqualTo("after");
      }
  
      @Test
      public void convertsStringValuesUsingSingleArgumentConstructors() {
          BeanMapTest bean = newBean("unchanged", null);
          BeanMap beanMap = new BeanMap(bean);
  
          Object previousValue = beanMap.put("path", "converted-path");
  
          assertThat(previousValue).isNull();
          assertThat(bean.getPath()).isEqualTo(new File("converted-path"));
          assertThat(beanMap.get("path")).isEqualTo(new File("converted-path"));
      }
  
      @Test
      public void clearReplacesBeanWithDefaultInstance() {
          BeanMapTest bean = newBean("before-clear", new File("set-path"));
          BeanMap beanMap = new BeanMap(bean);
  
          beanMap.clear();
  
          assertThat(beanMap.getBean()).isInstanceOf(BeanMapTest.class).isNotSameAs(bean);
          BeanMapTest clearedBean = (BeanMapTest) beanMap.getBean();
          assertThat(clearedBean.getName()).isEqualTo("default-name");
          assertThat(clearedBean.getPath()).isNull();
      }
  
      @Test
      public void cloneCreatesANewBeanAndCopiesWritableProperties() throws CloneNotSupportedException {
          BeanMapTest bean = newBean("original", new File("copy-me"));
          BeanMap beanMap = new BeanMap(bean);
  
          BeanMap clonedMap = (BeanMap) beanMap.clone();
  
          assertThat(clonedMap).isNotSameAs(beanMap);
          assertThat(clonedMap.getBean()).isInstanceOf(BeanMapTest.class).isNotSameAs(bean);
          BeanMapTest clonedBean = (BeanMapTest) clonedMap.getBean();
          assertThat(clonedBean.getName()).isEqualTo("original");
          assertThat(clonedBean.getPath()).isEqualTo(new File("copy-me"));
      }
  
      public String getName() {
          return name;
      }
  
      public void setName(String name) {
          this.name = name;
      }
  
      public File getPath() {
          return path;
      }
  
      public void setPath(File path) {
          this.path = path;
      }
  
      private static BeanMapTest newBean(String name, File path) {
          BeanMapTest bean = new BeanMapTest();
          bean.setName(name);
          bean.setPath(path);
          return bean;
