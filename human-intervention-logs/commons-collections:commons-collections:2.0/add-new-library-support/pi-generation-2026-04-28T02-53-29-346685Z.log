stContentsAndBehavior() throws Exception {\n        CursorableLinkedList list = new CursorableLinkedList();\n        list.add(\"first\");\n        list.add(\"second\");\n        list.add(\"third\");\n\n        byte[] serialized = serialize(list);\n        CursorableLinkedList deserialized = deserialize(serialized);\n\n        assertThat(deserialized).isNotSameAs(list);\n        assertThat(deserialized.toArray()).containsExactly(\"first\", \"second\", \"third\");\n\n        deserialized.addFirst(\"zero\");\n        deserialized.addLast(\"fourth\");\n\n        assertThat(deserialized.toArray(new String[0])).containsExactly(\"zero\", \"first\", \"second\", \"third\", \"fourth\");\n    }\n"}]}
