[tool-call] delta {"path":"tests/src/commons-collections/commons-collections/2.0/src/test/java/commons_collections/commons_collections/CursorableLinkedListTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage commons_collections.commons_collections;\n\nimport org.apache.commons.collections.CursorableLinkedList;\nimport org.junit.jupiter.api.Test;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class CursorableLinkedListTest {\n    @Test\n    public void toArrayCreatesATypedArrayWhenProvidedArrayIsTooSmall() {\n        CursorableLinkedList list = new CursorableLinkedList();\n        list.add(\"first\");\n        list.add(\"second\");\n\n        String[] providedArray = new String[0];\n\n        String[] copiedValues = (String[]) list.toArray(providedArray);\n\n        assertThat(copiedValues).isNotSameAs(providedArray);\n        assertThat(copiedValues).containsExactly(\"first\", \"second\");\n    }\n\n    @Test\n    public void serializationRoundTripPreservesListContentsAndBehavior() throws Exception {\n        CursorableLinkedList list = new CursorableLinkedList();\n        list.add(\"first\");\n        list.add(\"second\");\n        list.add(\"third\");\n\n        CursorableLinkedList deserialized = serializeAndDeserialize(list);\n\n        assertThat(deserialized).isNotSameAs(list);\n        assertThat(deserialized.toArray()).containsExactly(\"first\", \"second\", \"third\");\n\n        deserialized.addFirst(\"zero\");\n        deserialized.addLast(\"fourth\");\n\n        assertThat(deserialized.toArray()).containsExactly(\"zero\", \"first\", \"second\", \"third\", \"fourth\");\n    }\n\n    private static CursorableLinkedList serializeAndDeserialize(CursorableLinkedList list) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(list);\n        }\n\n        try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(bytes.toByteArray()))) {\n            return (CursorableLinkedList) input.readObject();\n        }\n    }\n}\n"}
