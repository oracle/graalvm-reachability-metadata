  package commons_collections.commons_collections;
  
  import org.apache.commons.collections.CursorableLinkedList;
  import org.junit.jupiter.api.Test;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class CursorableLinkedListTest {
      @Test
      public void toArrayCreatesATypedArrayWhenProvidedArrayIsTooSmall() {
          CursorableLinkedList list = new CursorableLinkedList();
          list.add("first");
          list.add("second");
  
          CharSequence[] providedArray = new CharSequence[1];
  
          Object[] copiedValues = list.toArray(providedArray);
  
          assertThat(copiedValues).isNotSameAs(providedArray);
          assertThat(copiedValues).isInstanceOf(CharSequence[].class);
          assertThat(copiedValues).containsExactly("first", "second");
      }
  
      @Test
      public void serializationRoundTripPreservesListContentsAndBehavior() throws Exception {
          CursorableLinkedList list = new CursorableLinkedList();
          list.add("first");
          list.add("second");
          list.add("third");
  
          byte[] serialized = serialize(list);
          CursorableLinkedList deserialized = deserialize(serialized);
  
          assertThat(deserialized).isNotSameAs(list);
          assertThat(deserialized.toArray()).containsExactly("first", "second", "third");
  
          deserialized.addFirst("zero");
          deserialized.addLast("fourth");
  
          assertThat(deserialized.toArray(new String[0]))
                  .containsExactly("zero", "first", "second", "third", "fourth");
      }
  
      private static byte[] serialize(CursorableLinkedList list) throws Exception {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {
              output.writeObject(list);
          }
          return bytes.toByteArray();
      }
  
      private static CursorableLinkedList deserialize(byte[] serialized) throws Exception {
          try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(serialized))) {
              return (CursorableLinkedList) input.readObject();
          }
      }
  }
