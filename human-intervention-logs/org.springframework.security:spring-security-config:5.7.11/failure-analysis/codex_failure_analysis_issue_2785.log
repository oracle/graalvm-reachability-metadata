eUserDetailsBeanManagerConfigurer(context))));\\n\\n            AuthenticationManager authenticationManager = configuration.getAuthenticationManager();\\n            Authentication authentication = authenticationManager.authenticate(\\n                    UsernamePasswordAuthenticationToken.unauthenticated(\\\"reporter\\\", \\\"changeit\\\"));\\n\\n            assertThat(authentication.isAuthenticated()).isTrue();\\n            assertThat(authentication.getName()).isEqualTo(\\\"reporter\\\");\\n            assertThat(authentication.getAuthorities())\\n                    .extracting(GrantedAuthority::getAuthority)\\n                    .containsExactly(\\\"ROLE_REPORTER\\\");\\n        }\\n    }\\n\\n    private static UserDetails userNamed(Collection<UserDetails> users, String username) {\\n\"}]}\n817:[recv] {\"type\": \"message_end\", \"message\": {\"role\": \"assistant\", \"content\": [{\"type\": \"thinking\", \"thinking\": \"\", \"thinkingSignature\": \"{\\\"id\\\":\\\"rs_06774f97b9e8e5b9016a0258017e3481918bc107da1d7f9f53\\\",\\\"type\\\":\\\"reasoning\\\",\\\"encrypted_content\\\":\\\"gAAAAABqAlgR-N7w2ltoxr854Q-mHaha4TX8tHBxNuWMqBtUQg0Y2aNXzETIOHcGMdPfPXKqlfJcjdEHfhgmVshCdBTj7hYl4EpipCkWk2gg3Gtu4hxt96JB9NO1SrYtVOwvVz0Hq-PCvJCRkleYLPKQRoqaSRLtGXFbVi__WUr7QgtEGTLngpVSC3t--Ane_V2ZHdCi5uDOxC6xpgbphl060auMsYH0zT-wJOd--m_YqJR3UxxT4M3ANSc7Sg0BYGDZc6lqzEqy-K7YvLuX-veOw-YHW0hhXw-V45tklH_H5p8kHVC1UVOZ3NW8BWfwz0YlKYiyoQCLuZ8L68MtLndhn3Gsf7d6h9cfYJ6G0hyeoLA6LQUkBXN4CABn1phuMXocOqh848wDw8dReAONaHX_YyHvmZvc2arKVX9t90KsZltvtTLXb9G6zziT0rmvkdNO6XBKkb1pyTjGtXGattbQYnGcTcXxqEuf-aN1d4rO8O391AEoXY810TQ4YQ28eKXB8GoDapZAOsDUxn_EstewYBhzEMUO8unDAivDwVnoEeMAAZKF3b_kaAfuxEqHJj4rtjpzPVnP6lkuqTFIgfODqLfvMUnWMeBV_Z9VcdLGKH8anc-z1OLvCbnn4VCiNyQW0JU26n_rBQ3wh5tMlgmbbDwBl_Rh_6TZMnHixTkCVZ1jaxDvAZPde2H1ZLipnP69PcPfexARSrtEHzN7EZLjo-CNT_9PFURLV6lUt7TB29--w60XnLOXFv9AtK7-U2SCUL3AVxcU4B4y2kyi2L_PcbFs6tN4cWVwwhRbyTULTAbHwtq7rB0nbuN_hPheyCxxtOgkx7pHq-UJ5-wtOhztqQJXIqrJiM1RMhs-5QGIhGvusbkguD3QPUvls