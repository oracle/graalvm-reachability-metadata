rayList<>()));\\n            configuration.setGlobalAuthenticationConfigurers(\\n                    List.of(AuthenticationConfiguration.initializeAuthenticationProviderBeanManagerConfigurer(context)));\\n\\n            AuthenticationManager authenticationManager = configuration.getAuthenticationManager();\\n            Authentication authentication = authenticationManager.authenticate(\\n                    UsernamePasswordAuthenticationToken.unauthenticated(\\\"api-client\\\", \\\"token\\\"));\\n\\n            assertThat(authentication.isAuthenticated()).isTrue();\\n            assertThat(authentication.getAuthorities())\\n                    .extracting(GrantedAuthority::getAuthority)\\n                    .containsExactly(\\\"ROLE_API\\\");\\n        }\\n    }\\n\\n\"}, {\"oldText\": \"    @Configuration(proxyBeanMethods = false)\\n    @EnableMethodSecurity(prePostEnabled = true)\\n    static class MethodSecurityConfiguration {\\n\\n        @Bean\\n        SecuredMessageService messageService() {\\n            return new DefaultSecuredMessageService();\\n        }\\n    }\\n\\n    interface SecuredMessageService {\\n\\n        @PreAuthorize(\\\"hasAuthority('message:read')\\\")\\n        String readMessage();\\n    }\\n\\n    static class DefaultSecuredMessageService implements SecuredMessageService {\\n\\n        @Override\\n        public String readMessage() {\\n            return \\\"classified message\\\";\\n        }\\n    }\\n\\n\", \"newText\": \"\"}]}}], \"api\": \"openai-responses\", \"provider\": \"OCA\", \"model\": \"gpt-5.5\", \"usage\": {\"input\": 1066, \"output\": 1725, \"cacheRead\": 34816, \"cacheWrite\": 0, \"totalTokens\": 37607, \"cost\": {\"input\": 0, \"output\": 0, \"cacheRead\": 0, \"cacheWrite\": 0, \"total\": 0}}, \"stopReason\": \"toolUse\", \"timestamp\": 1778538356699, \"responseId\": \"resp_0a8581cb5ddac578016a0257755a8c819d883d8acc84501a90\"}}\n7283:[tool-exec] start id=call_oxvbFNuc79x4da5kHdj8HO9t|fc_0a8581cb5ddac578016a02577f3b