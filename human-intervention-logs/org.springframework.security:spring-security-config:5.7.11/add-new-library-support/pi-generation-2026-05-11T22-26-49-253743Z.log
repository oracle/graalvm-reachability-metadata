ppliesPreAuthorizeRulesToSpringBeans() {\n+        try (AnnotationConfigApplicationContext context = new AnnotationConfigApplicationContext(\n+                MethodSecurityConfiguration.class)) {\n+            SecuredMessageService messageService = context.getBean(SecuredMessageService.class);\n+\n+            SecurityContextHolder.clearContext();\n+            assertThatExceptionOfType(AuthenticationCredentialsNotFoundException.class)\n+                    .isThrownBy(messageService::readMessage);\n+\n+            TestingAuthenticationToken unauthorized = new TestingAuthenticationToken(\"writer\", \"n/a\", \"message:write\");\n+            unauthorized.setAuthenticated(true);\n+            SecurityContextHolder.getContext().setAuthentication(unauthorized);\n+            assertThatExceptionOfType(AccessDeniedException.class).isThrownBy(messageService::readMessage);\n+\n+            TestingAuthenticationToken authorized = new TestingAuthenticationToken(\"reader\", \"n/a\", \"message:read\");\n+            authorized.setAuthenticated(true);\n+            SecurityContextHolder.getContext().setAuthentication(authorized);\n+            assertThat(messageService.readMessage()).isEqualTo(\"classified message\");\n+        }\n+        finally {\n+            SecurityContextHolder.clearContext();\n+        }\n+    }\n+\n     private static UserDetails userNamed(Collection<UserDetails> users, String username) {\n         return users.stream()\n                 .filter(user -> username.equals(user.getUsername()))\n@@ -199,6 +233,30 @@ public class Spring_security_configTest {\n                 .orElseThrow();\n     }\n \n+    @Configuration(proxyBeanMethods = false)\n+    @EnableMethodSecurity(prePostEnabled = true)\n+    static class MethodSecurityConfiguration {\n+\n+        @Bean\n+        SecuredMessageService messageService() {\n+            return new DefaultSecuredMessageService();\n+        }\n+    }\n+\n+    interface SecuredMessageService {\n+\n+        @PreAuthoriz