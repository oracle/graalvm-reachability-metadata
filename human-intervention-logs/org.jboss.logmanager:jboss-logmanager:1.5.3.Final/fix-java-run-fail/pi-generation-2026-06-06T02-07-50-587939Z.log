      private static String applySegments(final int count, final String subject) {
          if (count == 0) {
              return subject;
          }
          int idx = subject.length() + 1;
          for (int i = 0; i < count; i ++) {
              idx = subject.lastIndexOf('.', idx - 1);
              if (idx == -1) {
                  return subject;
              }
          }
          return subject.substring(idx + 1);
      }
  
