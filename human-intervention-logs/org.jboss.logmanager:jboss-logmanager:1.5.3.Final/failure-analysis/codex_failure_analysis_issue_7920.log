t.java\",\"content\":\"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage org_jboss_logmanager.jboss_logmanager;\\n\\nimport org.jboss.logmanager.LogManager;\\nimport org.junit.jupiter.api.Test;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\n\\npublic class LogManagerInnerKnownLevelBuilderTest {\\n\\n    @Test\\n    void constructorInstallsJbossLevelsInJulLevelRegistry() {\\n        new LogManager();\\n\\n        assertThat(java.util.logging.Level.parse(\\\"TRACE\\\").intValue()).isEqualTo(org.jboss.logmanager.Level.TRACE.intValue());\\n        assertThat(java.util.logging.Level.parse(\\\"DEBUG\\\").intValue()).isEqualTo(org.jboss.logmanager.Level.DEBUG.intValue());\\n        assertThat(java.util.logging.Level.parse(\\\"WARN\\\").intValue()).isEqualTo(org.jboss.logmanager.Level.WARN.intValue());\\n        assertThat(java.util.logging.Level.parse(\\\"ERROR\\\").intValue()).isEqualTo(org.jboss.logmanager.Level.ERROR.intValue());\\n        assertThat(java.util.logging.Level.parse(\\\"FATAL\\\").intValue()).isEqualTo(org.jboss.logmanager.Level.FATAL.intValue());\\n    }\\n}\\n\"}\n2143:[tool-call] end id=call_VLCKCsy0vjKIgcQwAnZwLzdJ|fc_061ae871c3261499016a2382affce08194a0ed49d0425089ee name=write args={\"path\": \"tests/src/org.jboss.logmanager/jboss-logmanager/1.5.3.Final/src/test/java/org_jboss_logmanager/jboss_logmanager/LogManagerInnerKnownLevelBuilderTest.java\", \"content\": \"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage org_jboss_logmanager.jboss_logmanager;\\n\\nimport org.jboss.logmanager.LogManager;\\nimport org.junit.jupiter.api.Test;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\