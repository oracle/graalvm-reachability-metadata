  package com_typesafe_akka.akka_actor_2_13
  
  import akka.actor.TypedActor
  import org.junit.jupiter.api.Assertions.assertEquals
  
  import java.lang.reflect.Method
  import org.junit.jupiter.api.Test
  
  class TypedActorInnerMethodCallTest {
    @Test
    def invokesNoArgumentMethodWhenParametersAreNull(): Unit = {
      val target: MethodCallTarget = new MethodCallTarget
      val method: Method = classOf[MethodCallTarget].getMethod("noArguments")
      val call: TypedActor.MethodCall = TypedActor.MethodCall(method, null)
  
      assertEquals("no-arguments", call(target))
    }
  
    @Test
    def invokesNoArgumentMethodWhenParametersAreEmpty(): Unit = {
      val target: MethodCallTarget = new MethodCallTarget
      val method: Method = classOf[MethodCallTarget].getMethod("noArguments")
      val call: TypedActor.MethodCall = TypedActor.MethodCall(method, Array.empty[AnyRef])
  
      assertEquals("no-arguments", call(target))
    }
  
    @Test
    def invokesMethodWithSuppliedParameters(): Unit = {
      val target: MethodCallTarget = new MethodCallTarget
      val method: Method = classOf[MethodCallTarget].getMethod("withArguments", classOf[String], classOf[java.lang.Integer])
      val call: TypedActor.MethodCall = TypedActor.MethodCall(method, Array[AnyRef]("payload", Integer.valueOf(7)))
  
      assertEquals("payload:7", call(target))
    }
