  package com_typesafe_akka.akka_actor_2_13
  
  import akka.actor.Actor
  import akka.actor.ActorSystem
  import akka.actor.Props
  import org.junit.jupiter.api.Assertions.assertEquals
  import org.junit.jupiter.api.Assertions.assertTrue
  import org.junit.jupiter.api.Test
  
  import java.util.concurrent.CountDownLatch
  import java.util.concurrent.TimeUnit
  import java.util.concurrent.atomic.AtomicReference
  import scala.concurrent.Await
  import scala.concurrent.duration.DurationInt
  
  class ReflectTest {
    @Test
    def createsActorWithPublicNoArgConstructor(): Unit = {
      PublicNoArgActor.started.set(new CountDownLatch(1))
      val system: ActorSystem = ActorSystem("reflect-public-no-arg")
      try {
        system.actorOf(Props(classOf[PublicNoArgActor]), "public-no-arg")
  
        assertTrue(PublicNoArgActor.started.get().await(10, TimeUnit.SECONDS))
      } finally {
        Await.result(system.terminate(), 10.seconds)
      }
    }
  
    @Test
    def createsActorWithPrivateNoArgConstructor(): Unit = {
      PrivateNoArgActor.started.set(new CountDownLatch(1))
      val originalClassLoader: ClassLoader = Thread.currentThread().getContextClassLoader
      val system: ActorSystem = {
        Thread.currentThread().setContextClassLoader(null)
        try ActorSystem("reflect-private-no-arg")
        finally Thread.currentThread().setContextClassLoader(originalClassLoader)
      }
  
      try {
        system.actorOf(Props(classOf[PrivateNoArgActor]), "private-no-arg")
  
        assertTrue(PrivateNoArgActor.started.get().await(10, TimeUnit.SECONDS))
      } finally {
        Await.result(system.terminate(), 10.seconds)
      }
    }
  
    @Test
    def createsActorWithMatchingConstructorArguments(): Unit = {
      ConstructorArgsActor.started.set(new CountDownLatch(1))
      ConstructorArgsActor.values.set(null)
      val system: ActorSystem = ActorSystem("reflect-constructor-args")
      try {
        system.actorOf(Props(classOf[ConstructorArgsActor], "payload", Integer.valueOf(7), null), "constructor-args")
  
        assertTrue(ConstructorArgsActor.started.get().await(10, TimeUnit.SECONDS))
        assertEquals(ConstructorArgsActor.Values("payload", 7, null), ConstructorArgsActor.values.get())
      } finally {
        Await.result(system.terminate(), 10.seconds)
      }
    }
  }
  
  class PublicNoArgActor extends Actor {
    override def preStart(): Unit = PublicNoArgActor.started.get().countDown()
  
    override def receive: Receive = Actor.emptyBehavior
  }
  
  object PublicNoArgActor {
    val started: AtomicReference[CountDownLatch] = new AtomicReference[CountDownLatch]()
  }
  
  class PrivateNoArgActor private () extends Actor {
    override def preStart(): Unit = PrivateNoArgActor.started.get().countDown()
  
    override def receive: Receive = Actor.emptyBehavior
  }
  
  object PrivateNoArgActor {
    val started: AtomicReference[CountDownLatch] = new AtomicReference[CountDownLatch]()
  }
  
  class ConstructorArgsActor(message: String, count: java.lang.Integer, marker: AnyRef) extends Actor {
    override def preStart(): Unit = {
      ConstructorArgsActor.values.set(ConstructorArgsActor.Values(message, count.intValue(), marker))
      ConstructorArgsActor.started.get().countDown()
    }
  
    override def receive: Receive = Actor.emptyBehavior
  }
  
  object ConstructorArgsActor {
    final case class Values(message: String, count: Int, marker: AnyRef)
  
    val started: AtomicReference[CountDownLatch] = new AtomicReference[CountDownLatch]()
    val values: AtomicReference[Values] = new AtomicReference[Values]()
  }
