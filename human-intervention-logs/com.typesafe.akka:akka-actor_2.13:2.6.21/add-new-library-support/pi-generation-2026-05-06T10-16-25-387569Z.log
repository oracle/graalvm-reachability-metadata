  plugins {
      id "org.graalvm.internal.tck"
      id "scala"
  }
  
  String libraryVersion = tck.testedLibraryVersion.get()
  Provider<Directory> sunReflectPatchClasses = layout.buildDirectory.dir("sunReflectPatch")
  
  tasks.register("compileSunReflectPatch", JavaCompile) {
      source = fileTree("src/testPatch/java")
      classpath = files()
      destinationDirectory = sunReflectPatchClasses
      options.compilerArgs.addAll([
          "--patch-module",
          "jdk.unsupported=${file("src/testPatch/java").absolutePath}"
      ])
  }
  
  tasks.named("test") {
      dependsOn("compileSunReflectPatch")
      jvmArgs("--patch-module", "jdk.unsupported=${sunReflectPatchClasses.get().asFile.absolutePath}")
      jvmArgs("--add-exports=java.base/sun.net.dns=ALL-UNNAMED")
  }
  
  dependencies {
      testImplementation "com.typesafe.akka:akka-actor_2.13:$libraryVersion"
      testImplementation 'org.assertj:assertj-core:3.22.0'
      testImplementation 'org.scala-lang:scala-library:2.13.16'
      testImplementation 'org.scala-lang:scala-compiler:2.13.16'
      testRuntimeOnly files(sunReflectPatchClasses).builtBy("compileSunReflectPatch")
  }
  
  java {
      toolchain {
          languageVersion = JavaLanguageVersion.of(21)
      }
  }
  
  graalvmNative {
      agent {
          defaultMode = "conditional"
          modes {
              conditional {
                  userCodeFilterPath = "user-code-filter.json"
              }
          }
      }
      binaries {
          all {
              buildArgs.add('--add-exports=java.base/sun.net.dns=ALL-UNNAMED')
          }
      }
  }
