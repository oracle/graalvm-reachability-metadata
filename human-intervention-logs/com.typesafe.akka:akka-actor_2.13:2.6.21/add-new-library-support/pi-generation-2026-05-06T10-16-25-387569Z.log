  Provider<Directory> sunReflectPatchClasses = layout.buildDirectory.dir("sunReflectPatch")
  
  tasks.register("compileSunReflectPatch", JavaCompile) {
      source = fileTree("src/testPatch/java")
      classpath = files()
      destinationDirectory = sunReflectPatchClasses
      options.compilerArgs.addAll([
