sts/src/com.typesafe.akka/akka-actor_2.13/2.6.21/src/test/scala/com_typesafe_akka/akka_actor_2_13/LineNumbersTest.scala", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_typesafe_akka.akka_actor_2_13\n\nimport akka.util.LineNumbers\nimport akka.util.LineNumbers.Result\nimport akka.util.LineNumbers.SourceFile\nimport akka.util.LineNumbers.SourceFileLines\nimport org.junit.jupiter.api.Assertions.assertEquals\nimport org.junit.jupiter.api.Assertions.assertTrue\nimport org.junit.jupiter.api.Assertions.fail\nimport org.junit.jupiter.api.Test\n\nimport java.util.concurrent.Callable\n\nclass LineNumbersTest {\n  @Test\n  def readsSourceInfoForRegularClass(): Unit = {\n    val result: Result = LineNumbers(new LineNumbersSampleClass)\n\n    assertLineNumbersResult(result)\n  }\n\n  @Test\n  def readsSourceInfoForSerializableLambda(): Unit = {\n    val callable: LineNumbersSerializableCallable = () => \"lambda-result\"\n\n    assertEquals(\"lambda-result\", callable.call())\n    val result: Result = LineNumbers(callable)\n\n    assertLineNumbersResult(result)\n  }\n\n  private def assertLineNumbersResult(result: Result): Unit = {\n    result match {\n      case SourceFile(filename) =>\n        assertEquals(\"LineNumbersTest.scala\", filename)\n      case SourceFileLines(filename, from, to) =>\n        assertEquals(\"LineNumbersTest.scala\", filename)\n        assertTrue(from > 0, s\"Expected a positive starting line number, but got $from\")\n        assertTrue(to >= from, s\"Expected ending line number $to to be greater than or equal to $from\")\n      case other =>\n        fail(s\"Expected source information for LineNumbersTest.scala, but got $other\")\n    }\n  }\n}\n\nfinal class LineNumbersSampleClass\n\ntrait LineNumbersSerializableCallable extends Callable[String] with Serializable\n"}}]