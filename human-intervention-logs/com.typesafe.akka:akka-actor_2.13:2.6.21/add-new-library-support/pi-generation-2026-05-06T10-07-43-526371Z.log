[tool-call] delta {"path":"tests/src/com.typesafe.akka/akka-actor_2.13/2.6.21/src/test/scala/com_typesafe_akka/akka_actor_2_13/ReflectTest.scala","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_typesafe_akka.akka_actor_2_13\n\nimport akka.actor.Actor\nimport akka.actor.ActorSystem\nimport akka.actor.Props\nimport org.junit.jupiter.api.Assertions.assertEquals\nimport org.junit.jupiter.api.Assertions.assertTrue\nimport org.junit.jupiter.api.Test\n\nimport java.util.concurrent.CountDownLatch\nimport java.util.concurrent.TimeUnit\nimport java.util.concurrent.atomic.AtomicReference\nimport scala.concurrent.Await\nimport scala.concurrent.duration.DurationInt\n\nclass ReflectTest {\n  @Test\n  def createsActorWithPublicNoArgConstructor(): Unit = {\n    PublicNoArgActor.started.set(new CountDownLatch(1))\n    val system: ActorSystem = ActorSystem(\"reflect-public-no-arg\")\n    try {\n      system.actorOf(Props(classOf[PublicNoArgActor]), \"public-no-arg\")\n\n      assertTrue(PublicNoArgActor.started.get().await(10, TimeUnit.SECONDS))\n    } finally {\n      Await.result(system.terminate(), 10.seconds)\n    }\n  }\n\n  @Test\n  def createsActorWithPrivateNoArgConstructor(): Unit = {\n    PrivateNoArgActor.started.set(new CountDownLatch(1))\n    val originalClassLoader: ClassLoader = Thread.currentThread().getContextClassLoader\n    val system: ActorSystem = {\n      Thread.currentThread().setContextClassLoader(null)\n      try ActorSystem(\"reflect-private-no-arg\")\n      finally Thread.currentThread().setContextClassLoader(originalClassLoader)\n    }\n\n    try {\n      system.actorOf(Props(classOf[PrivateNoArgActor]), \"private-no-arg\")\n\n      assertTrue(PrivateNoArgActor.started.get().await(10, TimeUnit.SECONDS))\n    } finally {\n      Await.result(system.terminate(), 10.seconds)\n    }\n  }\n\n  @Test\n  def createsActorWithMatchingConstructorArguments(): Unit = {\n    ConstructorArgsActor.started.set(new CountDownLatch(1))\n    ConstructorArgsActor.values.set(null)\n    val system: ActorSystem = ActorSystem(\"reflect-constructor-args\")\n    try {\n      system.actorOf(Props(classOf[ConstructorArgsActor], \"payload\", Integer.valueOf(7), null), \"constructor-args\")\n\n      assertTrue(ConstructorArgsActor.started.get().await(10, TimeUnit.SECONDS))\n      assertEquals(ConstructorArgsActor.Values(\"payload\", 7, null), ConstructorArgsActor.values.get())\n    } finally {\n      Await.result(system.terminate(), 10.seconds)\n    }\n  }\n}\n\nclass PublicNoArgActor extends Actor {\n  override def preStart(): Unit = PublicNoArgActor.started.get().countDown()\n\n  override def receive: Receive = Actor.emptyBehavior\n}\n\nobject PublicNoArgActor {\n  val started: AtomicReference[CountDownLatch] = new AtomicReference[CountDownLatch]()\n}\n\nclass PrivateNoArgActor private () extends Actor {\n  override def preStart(): Unit = PrivateNoArgActor.started.get().countDown()\n\n  override def receive: Receive = Actor.emptyBehavior\n}\n\nobject PrivateNoArgActor {\n  val started: AtomicReference[CountDownLatch] = new AtomicReference[CountDownLatch]()\n}\n\nclass ConstructorArgsActor(message: String, count: java.lang.Integer, marker: AnyRef) extends Actor {\n  override def preStart(): Unit = {\n    ConstructorArgsActor.values.set(ConstructorArgsActor.Values(message, count.intValue(), marker))\n    ConstructorArgsActor.started.get().countDown()\n  }\n\n  override def receive: Receive = Actor.emptyBehavior\n}\n\nobject ConstructorArgsActor {\n  final case class Values(message: String, count: Int, marker: AnyRef)\n\n  val started: AtomicReference[CountDownLatch] = new AtomicReference[CountDownLatch]()\n  val values: AtomicReference[Values] = new AtomicReference[Values]()\n}\n"}
