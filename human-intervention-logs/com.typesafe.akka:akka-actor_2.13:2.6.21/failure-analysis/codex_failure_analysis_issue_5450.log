\\n    val config = ConfigFactory.parseString(\\\"\\\"\\\"\\n      akka.io.dns.resolver = async-dns\\n      akka.loglevel = WARNING\\n    \\\"\\\"\\\")\\n    val system: ActorSystem = ActorSystem(\\\"dns-settings-reflection-fallback\\\", config)\\n    try {\\n      try {\\n        assertNotNull(Dns(system).getResolver)\\n      } catch {\\n        case exception: IllegalStateException if DnsSettingsTest.isExpectedDefaultNameserverFailure(exception) =>\\n          assertTrue(exception.getMessage.contains(\\\"Unable to obtain default nameservers\\\"))\\n        case exception: ActorInitializationException\\n            if DnsSettingsTest.isExpectedDefaultNameserverFailure(exception) =>\\n          assertTrue(Option(exception.getMessage).exists(_.nonEmpty))\\n      }\\n    } finally {\\n      DnsSettingsTest.failJndiLookups.set(false)\\n      Await.result(system.terminate(), 10.seconds)\\n    }\\n  }\\n}\\n\\nobject DnsSettingsTest {\\n  private val installed: AtomicBoolean = new AtomicBoolean(false)\\n  private val failJndiLookups: AtomicBoolean = new AtomicBoolean(false)\\n\\n  private def isExpectedDefaultNameserverFailure(exception: Throwable): Boolean = {\\n    if (exception == null) false\\n    else {\\n      val message = Option(exception.getMessage).getOrElse(\\\"\\\")\\n      message.contains(\\\"Unable to obtain default nameservers\\\") ||\\n      message.contains(\\\"Empty nameservers list discovered using reflection\\\") ||\\n      isExpectedDefaultNameserverFailure(exception.getCause)\\n    }\\n  }\\n\\n  private def installFailingJndiBuilder(): Unit = {\\n    if (installed.compareAndSet(false, true)) {\\n      try {\\n        NamingManager.setInitialContextFactoryBuilder(new InitialContextFactoryBuilder {\\n          override def createInitialContextFactory(environment: Hashtable[_, _]): InitialContextFactory = {\\n            new InitialContextFactory {\\n              override def getInitialContext(environment: Hashtable[_, _]): Context = {\\n                if (failJndiLookups.get()) {\\n                  throw new NamingException(\\\"JNDI DNS lookup disabled to exercise Akka's reflection fallback\\\")\\n                }\\n                throw new NamingException(\\\"No default JNDI context is available from this test factory\\\")\\n              }\\n            }\\n          }\\n        })\\n      } catch {\\n        case _: IllegalStateException =>\\n          installed.set(true)\\n      }\\n    }\\n  }\\n}\\n\",\"exit_code\":0,\"status\":\"completed\"}}\n{\"type\":\"item.started\",\"item\":{\"id\":\"item_16\",\"type\":\"command_execution\",\"command\":\"/usr/bin/bash -lc \\\"sed -n '160,240p' metadata/com.typesafe/config/1.4.2/reachability-metadata.json\\\"\",\"aggregated_output\":\"\",\"exit_code\":null,\"status\":\"in_progress\"}}\n{\"type\":\"item.completed\",\"item\":{\"id\":\"item_16\",\"type\":\"command_execution\",\"command\":\"/usr/bin/bash -lc \\\"sed -n '160,240p' metadata/com.typesafe/config/1.4.2/reachability-metadata.json\\\"\",\"aggregated_output\":\"      \\\"condition\\\" : {\\n        \\\"typeReached\\\" : \\\"com.typesafe.config.ConfigBeanFactory\\\"\\n      },\\n      \\\"type\\\" : \\\"java.lang.Object\\\"\\n    },\\n    {\\n      \\\"condition\\\" : {\\n        \\\"typeReached\\\" : \\\"com.typesafe.config.ConfigBeanFactory\\\"\\n      },\\n      \\\"type\\\" : \\\"java.lang.ObjectBeanInfo\\\"\\n    },\\n    {\\n      \\\"condition\\\" : {\\n        \\\"typeReached\\\" : \\\"com.typesafe.config.ConfigBeanFactory\\\"\\n      },\\n      \\\"type\\\" : \\\"java.lang.ObjectCustomizer\\\"\\n    }\\n  ],\\n  \\\"resources\\\" : [\\n    {\\n      \\\"condition\\\" : {\\n        \\\"typeReached\\\" : \\\"com.typesafe.config.impl.Parseable$ParseableURL\\\"\\n      },\\n      \\\"module\\\" : \\\"java.base\\\",\\n      \\\"glob\\\" : \\\"sun/net/www/content-types.properties\\\"\\n    }\\n  ]\\n}\\n\",\"exit_code\":0,\"status\":\"completed\"}}\n{\"type\":\"item.started\",\"item\":{\"id\":\"item_17\"