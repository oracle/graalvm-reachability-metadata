es(String coordinateFilter) {\n497:                List<String> tested = (List<String>) entry.get(\"tested-versions\");\n498:                String metaVer = (String) entry.get(\"metadata-version\");\n500:                if (tested == null || metaVer == null || !Files.isDirectory(fullDir.resolve(metaVer))) {\n519:    public List<String> getMatchingCoordinatesStrict(String coordinateFilter) {\n529:                List<String> tested = (List<String>) entry.get(\"tested-versions\");\n534:                        .filter(v -> Files.isDirectory(fullDir.resolve(v)))\n","exit_code":0,"status":"completed"}}
