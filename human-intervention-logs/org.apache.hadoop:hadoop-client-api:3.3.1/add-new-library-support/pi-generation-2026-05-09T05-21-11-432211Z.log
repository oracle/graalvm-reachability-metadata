  +        Configuration configuration = new Configuration();
  +        java.nio.file.Path temporaryDirectory = Files.createTempDirectory("hadoop-client-api-local-fs");
  +        Path root = new Path(temporaryDirectory.toUri());
  +
  +        try (FileSystem localFileSystem = FileSystem.getLocal(configuration)) {
  +            Path directory = new Path(root, "dataset");
