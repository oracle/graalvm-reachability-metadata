[tool-call] delta {"path":"tests/src/org.apache.hadoop/hadoop-client-api/3.3.1/src/test/java/org_apache_hadoop/hadoop_client_api/Hadoop_client_apiTest.java","edits":[{"oldText":"import java.io.ByteArrayInputStream;\nimport java.net.URI;\nimport java.nio.ByteBuffer;\nimport java.nio.charset.StandardCharsets;\nimport java.util.List;\nimport java.util.Set;\nimport java.util.concurrent.TimeUnit;\n","newText":"import java.io.ByteArrayInputStream;\nimport java.io.IOException;\nimport java.io.UncheckedIOException;\nimport java.net.URI;\nimport java.nio.ByteBuffer;\nimport java.nio.charset.StandardCharsets;\nimport java.util.Comparator;\nimport java.util.List;\nimport java.util.Set;\nimport java.util.concurrent.TimeUnit;\nimport java.util.stream.Stream;\n"},{"oldText":"import org.apache.hadoop.conf.StorageUnit;\nimport org.apache.hadoop.fs.Path;\n","newText":"import org.apache.hadoop.conf.StorageUnit;\nimport org.apache.hadoop.fs.FSDataInputStream;\nimport org.apache.hadoop.fs.FSDataOutputStream;\nimport org.apache.hadoop.fs.FileStatus;\nimport org.apache.hadoop.fs.FileSystem;\nimport org.apache.hadoop.fs.Path;\n"},{"oldText":"    @Test\n    void writableValueTypesCompareCopyAndExposeUtf8Content() throws Exception {\n","newText":"    @Test\n    void localFileSystemCreatesReadsRenamesAndDeletesFiles() throws Exception {\n        Configuration configuration = new Configuration();\n        java.nio.file.Path temporaryDirectory = java.nio.file.Files.createTempDirectory(\"hadoop-client-api-local-fs\");\n        Path root = new Path(temporaryDirectory.toUri());\n\n        try (FileSystem localFileSystem = FileSystem.getLocal(configuration)) {\n            Path directory = new Path(root, \"dataset\");\n            assertThat(localFileSystem.mkdirs(directory)).isTrue();\n\n            Path original = new Path(directory, \"part-00000\");\n            byte[] expected = \"row-1\\nrow-2\\n\".getBytes(StandardCharsets.UTF_8);\n            try (FSDataOutputStream output = localFileSystem.create(original, true)) {\n                output.write(expected);\n            }\n\n            FileStatus status = localFileSystem.getFileStatus(original);\n            assertThat(status.isFile()).isTrue();\n            assertThat(status.getLen()).isEqualTo(expected.length);\n\n            byte[] actual = new byte[expected.length];\n            try (FSDataInputStream input = localFileSystem.open(original)) {\n                input.readFully(actual);\n            }\n            assertThat(actual).isEqualTo(expected);\n            assertThat(localFileSystem.listStatus(directory))\n                    .extracting(fileStatus -> fileStatus.getPath().getName())\n                    .contains(\"part-00000\");\n\n            Path renamed = new Path(directory, \"part-00001\");\n            assertThat(localFileSystem.rename(original, renamed)).isTrue();\n            assertThat(localFileSystem.exists(original)).isFalse();\n            assertThat(localFileSystem.getFileStatus(renamed).getLen()).isEqualTo(expected.length);\n\n            assertThat(localFileSystem.delete(directory, true)).isTrue();\n            assertThat(localFileSystem.exists(directory)).isFalse();\n        } finally {\n            deleteRecursively(temporaryDirectory);\n        }\n    }\n\n    @Test\n    void writableValueTypesCompareCopyAndExposeUtf8Content() throws Exception {\n"},{"oldText":"    private static void assertTokenKind(TokenIdentifier identifier, Text expectedKind) {\n        assertThat(identifier.getKind()).isEqualTo(expectedKind);\n    }\n","newText":"    private static void assertTokenKind(TokenIdentifier identifier, Text expectedKind) {\n        assertThat(identifier.getKind()).isEqualTo(expectedKind);\n    }\n\n    private static void deleteRecursively(java.nio.file.Path root) throws IOException {\n        if (!java.nio.file.Files.exists(root)) {\n            return;\n        }\n        try (Stream<java.nio.file.Path> paths = java.nio.file.Files.walk(root)) {\n            paths.sorted(Comparator.reverseOrder()).forEach(path -> {\n                try {\n                    java.nio.file.Files.deleteIfExists(path);\n                } catch (IOException exception) {\n                    throw new UncheckedIOException(exception);\n                }\n            });\n        } catch (UncheckedIOException exception) {\n            throw exception.getCause();\n        }\n    }\n"}]}
[tool-call] end id=call_gHQjDiXLFVHPBqjktmZDyhr3|fc_0c063f8bbf3950130169fec42773b081a38b87b423fdc7483e name=edit args={"path": "tests/src/org.apache.hadoop/hadoop-client-api/3.3.1/src/test/java/org_apache_hadoop/hadoop_client_api/Hadoop_client_apiTest.java", "edits": [{"oldText": "import java.io.ByteArrayInputStream;\nimport java.net.URI;\nimport java.nio.ByteBuffer;\nimport java.nio.charset.StandardCharsets;\nimport java.util.List;\nimport java.util.Set;\nimport java.util.concurrent.TimeUnit;\n", "newText": "import java.io.ByteArrayInputStream;\nimport java.io.IOException;\nimport java.io.UncheckedIOException;\nimport java.net.URI;\nimport java.nio.ByteBuffer;\nimport java.nio.charset.StandardCharsets;\nimport java.util.Comparator;\nimport java.util.List;\nimport java.util.Set;\nimport java.util.concurrent.TimeUnit;\nimport java.util.stream.Stream;\n"}, {"oldText": "import org.apache.hadoop.conf.StorageUnit;\nimport org.apache.hadoop.fs.Path;\n", "newText": "import org.apache.hadoop.conf.StorageUnit;\nimport org.apache.hadoop.fs.FSDataInputStream;\nimport org.apache.hadoop.fs.FSDataOutputStream;\nimport org.apache.hadoop.fs.FileStatus;\nimport org.apache.hadoop.fs.FileSystem;\nimport org.apache.hadoop.fs.Path;\n"}, {"oldText": "    @Test\n    void writableValueTypesCompareCopyAndExposeUtf8Content() throws Exception {\n", "newText": "    @Test\n    void localFileSystemCreatesReadsRenamesAndDeletesFiles() throws Exception {\n        Configuration configuration = new Configuration();\n        java.nio.file.Path temporaryDirectory = java.nio.file.Files.createTempDirectory(\"hadoop-client-api-local-fs\");\n        Path root = new Path(temporaryDirectory.toUri());\n\n        try (FileSystem localFileSystem = FileSystem.getLocal(configuration)) {\n            Path directory = new Path(root, \"dataset\");\n            assertThat(localFileSystem.mkdirs(directory)).isTrue();\n\n            Path original = new Path(directory, \"part-00000\");\n            byte[] expected = \"row-1\\nrow-2\\n\".getBytes(StandardCharsets.UTF_8);\n            try (FSDataOutputStream output = localFileSystem.create(original, true)) {\n                output.write(expected);\n            }\n\n            FileStatus status = localFileSystem.getFileStatus(original);\n            assertThat(status.isFile()).isTrue();\n            assertThat(status.getLen()).isEqualTo(expected.length);\n\n            byte[] actual = new byte[expected.length];\n            try (FSDataInputStream input = localFileSystem.open(original)) {\n                input.readFully(actual);\n            }\n            assertThat(actual).isEqualTo(expected);\n            assertThat(localFileSystem.listStatus(directory))\n                    .extracting(fileStatus -> fileStatus.getPath().getName())\n                    .contains(\"part-00000\");\n\n            Path renamed = new Path(directory, \"part-00001\");\n            assertThat(localFileSystem.rename(original, renamed)).isTrue();\n            assertThat(localFileSystem.exists(original)).isFalse();\n            assertThat(localFileSystem.getFileStatus(renamed).getLen()).isEqualTo(expected.length);\n\n            assertThat(localFileSystem.delete(directory, true)).isTrue();\n            assertThat(localFileSystem.exists(directory)).isFalse();\n        } finally {\n            deleteRecursively(temporaryDirectory);\n        }\n    }\n\n    @Test\n    void writableValueTypesCompareCopyAndExposeUtf8Content() throws Exception {\n"}, {"oldText": "    private static void assertTokenKind(TokenIdentifier identifier, Text expectedKind) {\n        assertThat(identifier.getKind()).isEqualTo(expectedKind);\n    }\n", "newText": "    private static void assertTokenKind(TokenIdentifier identifier, Text expectedKind) {\n        assertThat(identifier.getKind()).isEqualTo(expectedKind);\n    }\n\n    private static void deleteRecursively(java.nio.file.Path root) throws IOException {\n        if (!java.nio.file.Files.exists(root)) {\n            return;\n        }\n        try (Stream<java.nio.file.Path> paths = java.nio.file.Files.walk(root)) {\n            paths.sorted(Comparator.reverseOrder()).forEach(path -> {\n                try {\n                    java.nio.file.Files.deleteIfExists(path);\n                } catch (IOException exception) {\n                    throw new UncheckedIOException(exception);\n                }\n            });\n        } catch (UncheckedIOException exception) {\n            throw exception.getCause();\n        }\n    }\n"}]}
