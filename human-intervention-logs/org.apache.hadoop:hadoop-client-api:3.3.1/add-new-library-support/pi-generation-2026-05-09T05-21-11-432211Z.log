  +            assertThat(status.getLen()).isEqualTo(expected.length);
  +
  +            byte[] actual = new byte[expected.length];
  +            try (FSDataInputStream input = localFileSystem.open(original)) {
  +                input.readFully(actual);
  +            }
  +            assertThat(actual).isEqualTo(expected);
  +            assertThat(localFileSystem.listStatus(directory))
  +                    .extracting(fileStatus -> fileStatus.getPath().getName())
  +                    .contains("part-00000");
  +
  +            Path renamed = new Path(directory, "part-00001");
  +            assertThat(localFileSystem.rename(original, renamed)).isTrue();
  +            assertThat(localFileSystem.exists(original)).isFalse();
  +            assertThat(localFileSystem.getFileStatus(renamed).getLen()).isEqualTo(expected.length);
  +
  +            assertThat(localFileSystem.delete(directory, true)).isTrue();
  +            assertThat(localFileSystem.exists(directory)).isFalse();
  +        } finally {
  +            deleteRecursively(temporaryDirectory);
  +        }
  +    }
