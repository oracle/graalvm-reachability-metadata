olt/neo4j-bolt-connection-routed/index.json:9:    \"description\" : \"Neo4j Bolt Connection Routed provides the routed connection-provider implementation for Neo4j Bolt protocol connections. It maintains routing tables, performs cluster rediscovery, and selects servers for routed connections used by Neo4j drivers and related Neo4j solutions.\",\nmetadata/org.neo4j.bolt/neo4j-bolt-connection-routed/index.json:14:      \"org.neo4j.bolt.connection.routed\"\nmetadata/org.neo4j.bolt/neo4j-bolt-connection-pooled/index.json:5:    \"source-code-url\" : \"https://repo1.maven.org/maven2/org/neo4j/bolt/neo4j-bolt-connection-pooled/$version$/neo4j-bolt-connection-pooled-$version$-sources.jar\",\nmetadata/org.neo4j.bolt/neo4j-bolt-connection-pooled/index.json:6:    \"repository-url\" : \"https://github.com/neo4j/bolt-connection-java\",\nmetadata/org.neo4j.bolt/neo4j-bolt-connection-pooled/index.json:7:    \"test-code-url\" : \"https://github.com/neo4j/bolt-connection-java/tree/$version$/neo4j-bolt-connection-pooled/src/test\",\nmetadata/org.neo4j.bolt/neo4j-bolt-connection-pooled/index.json:8:    \"documentation-url\" : \"https://repo1.maven.org/maven2/org/neo4j/bolt/neo4j-bolt-connection-pooled/$version$/neo4j-bolt-connection-pooled-$version$-javadoc.jar\",\nmetadata/org.neo4j.bolt/neo4j-bolt-connection-pooled/index.json:9:    \"description\" : \"Neo4j Bolt Connection's pooled provider implementation supplies a BoltConnectionProvider that manages reusable Neo4j Bolt connections. It builds on the core Bolt connection API to reuse connections for Neo4j clients that need efficient repeated access.\",\nmetadata/org.neo4j.bolt/neo4j-bolt-connection-pooled/index.json:14:      \"org.neo4j.bolt.connection.pooled\"\nmetadata/org.neo4j.bolt/neo4j-bolt-connection-pooled/index.json:19:    \"source-code-url\" : \"https://repo1.maven.org/maven2/org/neo4j/bolt/neo4j-bolt-connection-pooled/$version$/neo4j-bolt-connection-pooled-$version$-sources.jar\",\nmetadata/org.neo4j.bolt/neo4j-bolt-conne