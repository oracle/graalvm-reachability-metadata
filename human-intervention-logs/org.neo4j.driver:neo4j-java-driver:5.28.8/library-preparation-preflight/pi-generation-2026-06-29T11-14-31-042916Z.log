[assistant] {
[assistant]   "action": "advisory_preparation",
[assistant]   "summary": "Neo4j Java Driver is a Bolt client whose documented normal use is opening a Driver against a Neo4j server and running Cypher; the artifact resolves Bolt/Netty/Reactor transport dependencies, and upstream integration testing relies on Docker/Testcontainers. Meaningful connection/session/query coverage therefore needs a Neo4j server image.",
[assistant]   "deterministic_setup": [
[assistant]     {
[assistant]       "kind": "docker_image",
[assistant]       "image": "neo4j:5.26.8",
[assistant]       "slug": "neo4j",
[assistant]       "reason": "Provides a local Neo4j server so generated tests can exercise GraphDatabase.driver, Bolt connection establishment, sessions, transactions, and query execution instead of only in-process value/mapping helpers."
[assistant]     }
[assistant]   ],
[assistant]   "agent_guidance": "If adding server-backed tests, start the Neo4j container with auth disabled, for example `NEO4J_AUTH=none`, expose Bolt port 7687 on an available localhost port, wait until the Bolt endpoint is accepting connections, then use `GraphDatabase.driver(\"bolt://localhost:<port>\", AuthTokens.none())`. Keep any container lifecycle cleanup in the test code.",
[assistant]   "risks": [
[assistant]     "The current failure is in an existing in-process value-mapping test, so a focused regression fix may not need Docker even though broader driver coverage does.",
[assistant]     "Neo4j container startup can be slow and port-sensitive; local Gradle and Native Image verification remain authoritative.",
[assistant]     "If local verification shows incompatibility with the pinned server tag, use a compatible Neo4j 5.x/2025.x Docker tag rather than changing the driver dependency."
[assistant]   ]
[assistant] }
[assistant-event] text_end
