                              .withTrustStrategy(Config.TrustStrategy.trustCustomCertificateSignedBy(cert))
                              .withEncryption()
                              .build());
          } else {
              driver = GraphDatabase.driver(boltUri, authToken);
          }
          waitForBoltAvailability();
      }
  
