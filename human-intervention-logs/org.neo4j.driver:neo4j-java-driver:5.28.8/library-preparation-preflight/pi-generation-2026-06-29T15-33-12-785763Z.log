\nmetadata/org.neo4j.driver/neo4j-java-driver/5.28.5/reachability-metadata.json:80:          \"org.neo4j.driver.mapping.Property\"\nmetadata/org.neo4j.driver/neo4j-java-driver/index.json:5:    \"source-code-url\" : \"https://repo.maven.apache.org/maven2/org/neo4j/driver/neo4j-java-driver/$version$/neo4j-java-driver-$version$-sources.jar\",\nmetadata/org.neo4j.driver/neo4j-java-driver/index.json:6:    \"repository-url\" : \"https://github.com/neo4j/neo4j-java-driver\",\nmetadata/org.neo4j.driver/neo4j-java-driver/index.json:7:    \"test-code-url\" : \"https://repo.maven.apache.org/maven2/org/neo4j/driver/neo4j-java-driver/$version$/neo4j-java-driver-$version$-tests.jar\",\nmetadata/org.neo4j.driver/neo4j-java-driver/index.json:8:    \"documentation-url\" : \"https://repo.maven.apache.org/maven2/org/neo4j/driver/neo4j-java-driver/$version$/neo4j-java-driver-$version$-javadoc.jar\",\nmetadata/org.neo4j.driver/neo4j-java-driver/index.json:9:    \"description\" : \"The Neo4j Java Driver is the official Java client for connecting Java applications to Neo4j databases. It manages Bolt protocol communication, connection pooling, transactions, and query execution against single-instance and clustered Neo4j deployments.\",\nmetadata/org.neo4j.driver/neo4j-java-driver/index.json:16:      \"org.neo4j.driver\"\nmetadata/library-and-framework-list.json:1851:    \"artifact\": \"org.neo4j.driver:neo4j-java-driver\",\nmetadata/library-and-framework-list.json:1852:    \"description\": \"Official Java Driver for Neo4j\",\nmetadata/library-and-framework-list.json:1857:          \"https://github.com/neo4j/neo4j-java-driver/tree/5.0/driver/src/main/resources/META-INF/native-image/org.neo4j.driver/neo4j-java-driver\"\nmetadata/library-and-framework-list.json:1860:          \"https://github.com/neo4j-drivers/neo4j-java-driver-native-smoke-tests\"\nmetadata/org.neo4j.bolt/neo4j-bolt-connection-routed/index.json:9:    \"description\" : \"Neo4j Bolt Connection Routed provides the routed connection-provider implementation for Neo4j Bolt protocol connections. It maintains routing tables, performs cluster rediscovery, and selects servers for routed connections used by Neo4j drivers and related Neo4j solutions.\",\nmetadata/org.neo4j.bolt/neo4j-bolt-connection-pooled/index.json:9:    \"description\" : \"Neo4j Bolt Connection's pooled provider implementation supplies a BoltConnectionProvider that manages reusable Neo4j Bolt connections. It builds on the core Bolt connection API to reuse connections for Neo4j clients that need efficient repeated access.\",\nmetadata/org.neo4j.bolt/neo4j-bolt-connection-pooled/index.json:23:    \"description\" : \"Neo4j Bolt Connection's pooled provider implementation supplies a connection provider that pools Bolt connections for Neo4j driver-style clients. It builds on the core provider SPI to manage reusable connections and connection metadata while implementing the Bolt protocol API for Neo4j integrations.\",\nmetadata/org.neo4j.bolt/neo4j-bolt-connection-netty/index.json:9:    \"description\" : \"Neo4j Bolt Connection Netty implements the Netty-based provider for Neo4j Bolt connections, including the bolt, bolt+s, and bolt+ssc schemes. It supplies asynchronous networking and protocol plumbing used by Neo4j drivers and related Neo4j integrations rather than a standalone end-user driver.\",\nmetadata/org.neo4j.bolt/neo4j-bolt-connection-netty/index.json:23:    \"description\" : \"Neo4j Bolt Connection Netty is the Netty-based reference implementation for creating Neo4j Bolt protocol connections from Java code. It provides asynchronous networking, message encoding, and protocol plumbing used by Neo4j drivers and related Neo4j solutions rather than a standalone end-user driver.\",\nmetadata/org.neo4j.bolt/neo4j-bolt-connection/index.json:9:    \"description\" : \"Neo4j Bolt Connection provides Java APIs for creating and using Neo4j Bolt protocol connections. This artifact contains the provider SPI used by Neo4j drivers and related Neo4j solutions rather than an end-user driver.\",\ntests/src/org.neo4j.driver/neo4j-java-driver/5.28.5/build.gradle:14:    testImplementation \"org.neo4j.driver:neo4j-java-driver:$libraryVersion\"\ntests/src/org.neo4j.driver/neo4j-java-driver/5.28.5/settings.gradle:20:rootProject.name = 'org.neo4j.driver.neo4j-java-driver_tests'\ntests/src/org.neo4j.driver/neo4j-java-driver/5.28.5/src/test/resources/META-INF/native-image/reachability-metadata.json:5:        \"typeReached\" : \"org.neo4j.driver.Values\"\ntests/src/org.neo4j.driver/neo4j-java-driver/5.28.5/src/test/resources/META-INF/native-image/reachability-metadata.json:7:      \"type\" : \"org_neo4j_driver.neo4j_java_driver.ValuesTest$Movie\"\ntests/src/org.neo4j.driver/neo4j-java-driver/5.28.5/src/test/java/org_neo4j_driver/neo4j_java_driver/UnsupportedDateTimeValueTest.java:7:package org_neo4j_driver.neo4j_java_driver;\ntests/src/org.neo4j.driver/neo4j-java-driver/5.28.5/src/test/java/org_neo4j_driver/neo4j_java_driver/UnsupportedDateTimeValueTest.java:14:import org.neo4j.driver.Value;\ntests/src/org.neo4j.driver/neo4j-java-driver/5.28.5/src/test/java/org_neo4j_driver/neo4j_java_driver/UnsupportedDateTimeValueTest.java:15:import org.neo4j.driver.internal.value.UnsupportedDateTimeValue;\ntests/src/org.neo4j.driver/neo4j-java-driver/5.28.5/src/test/java/org_neo4j_driver/neo4j_java_driver/ConstructorFinderTest.java:7:package org_neo4j_driver.neo4j_java_driver;\ntests/src/org.neo4j.driver/neo4j-java-driver/5.28.5/src/test/java/org_neo4j_driver/neo4j_java_driver/ConstructorFinderTest.java:13:import org.neo4j.driver.Value;\ntests/src/org.neo4j.driver/neo4j-java-driver/5.28.5/src/test/java/org_neo4j_driver/neo4j_java_driver/ConstructorFinderTest.java:14:import org.neo4j.driver.Values;\ntests/src/org.neo4j.driver/neo4j-java-driver/5.28.5/src/test/java/org_neo4j_driver/neo4j_java_driver/ConstructorFinderTest.java:15:import org.neo4j.driver.exceptions.value.ValueException;\ntests/src/org.neo4j.driver/neo4j-java-drive