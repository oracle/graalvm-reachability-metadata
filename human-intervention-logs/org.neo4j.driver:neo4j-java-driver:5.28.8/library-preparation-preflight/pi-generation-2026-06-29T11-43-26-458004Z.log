              }
          }
      }
  
      private void pullDockerImage(String image) {
          System.out.println("Pulling image " + image + "...");
          getExecOperations().exec(execSpec -> {
              execSpec.setExecutable("docker");
              execSpec.args(List.of("pull", image));
          });
      }
  }
