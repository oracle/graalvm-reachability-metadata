e.as(PersonWithPrimitiveAge.class))\n                .isInstanceOf(ValueException.class)\n                .hasMessageContaining(\"Failed to map 'age' property to 'int'\")\n                .hasMessageContaining(PersonWithPrimitiveAge.class.getCanonicalName());\n    }\n\n    public static class PersonWithPrimitiveAge {\n        private final int age;\n\n        public PersonWithPrimitiveAge(@Property(\"age\") int age) {\n            this.age = age;\n        }\n\n        public int age() {\n            return age;\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1782747796874}, {"role": "toolResult", "toolCallId": "call_aweXMJSYjE1w9hPZ8nzwGBz5|fc_050afedd7cab471c016a429294a5b08196ae68b0a78c5bbcbd", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_neo4j_driver.neo4j_java_driver;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.util.Map;\nimport org.junit.jupiter.api.Test;\nimport org.neo4j.driver.Value;\nimport org.neo4j.driver.Values;\nimport org.neo4j.driver.mapping.Property;\n\npublic class ObjectInstantiatorTest {\n    @Test\n    void instantiatesMappedObjectWithConvertedConstructorArguments() {\n        Value value = Values.value(Map.of(\"name\", \"Trinity\", \"crewRank\", 1, \"active\", true));\n\n        CrewMember crewMember = value.as(CrewMember.class);\n\n        assertThat(crewMember.name()).isEqualTo(\"Trinity\");\n        assertThat(crewMember.rank()).isEqualTo(1);\n        assertThat(crewMember.active()).isTrue();\n    }\n\n    public record CrewMember(String name, @Property(\"crewRank\") int rank, boolean active) {}\n}\n"}], "isError": false, "timestamp": 1782747796874}, {"role": "toolResult", "toolCallId": "call_qmZ26TocFJHXX2oj8bCoSlWd|fc_050afedd7cab471c016a429294a5b481968a418d3995386f3f", 