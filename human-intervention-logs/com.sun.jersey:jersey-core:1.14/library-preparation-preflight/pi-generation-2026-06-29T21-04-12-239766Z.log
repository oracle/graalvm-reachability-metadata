Class<?>>>>>();\n100:     private final ReadWriteLock lock = new ReentrantReadWriteLock();\n101: \n102:     private static OsgiRegistry instance;\n103: \n104:     private Map<String, Bundle> classToBundleMapping = new HashMap<String, Bundle>();\n105: \n106:     /**\n107:      * Returns an {@code OsgiRegistry} instance. Call this method only if sure that the application is running in OSGi\n108:      * environment, otherwise a call to this method can lead to an {@link ClassNotFoundException}.\n109:      *\n110:      * @return an {@code OsgiRegistry} instance.\n111:      */\n112:     public static synchronized OsgiRegistry getInstance() {\n113:         if (instance == null) {\n114:             final ClassLoader classLoader = ReflectionHelper.class.getClassLoader();\n115:             if (classLoader instanceof BundleReference) {\n116:                 final BundleContext context = FrameworkUtil.getBundle(OsgiRegistry.class).getBundleContext();\n117:                 if (context != null) { // context could be still null in GlassFish\n118:                     instance = new OsgiRegistry(context);\n119:                     instance.hookUp();\n120:                 }\n121:             }\n122:         }\n123:         return instance;\n124:     }\n125: \n126:     private final class OsgiServiceFinder<T> extends ServiceFinder.ServiceIteratorProvider<T> {\n127: \n128:         final ServiceFinder.ServiceIteratorProvider defaultIterator = new ServiceFinder.DefaultServiceIteratorProvider();\n129: \n130:         @Override\n131:         public Iterator<T> createIterator(final Class<T> serviceClass, final String serviceName, ClassLoader loader, boolean ignoreOnClassNotFound) {\n132:             final List<Class<?>> providerClasses = locateAllProviders(serviceName);\n133:             if (!providerClasses.isEmpty()) {\n134:                 return new Iterator<T>() {\n135: \n136:                     Iterator<Class<?>> it = providerClasses.iterator();\n137: \n138:                     @Override\n139:                     public boolean hasNext() {\n140:                         return it.hasNext();\n141:                     }\n142: \n143:                     @Override\n144:                     public T next() {\n145:                         Class<T> nextClass = (Class<T>) it.next();\n146:                         try {\n147:                             return serviceClass.cast(nextClass.newInstance());\n148:                         } catch (Exception ex) {\n149:                             ServiceConfigurationError sce = new ServiceConfigurationError(serviceName + \": \"\n150:                                     + SpiMessages.PROVIDER_COULD_NOT_BE_CREATED(nextClass.getName(), serviceClass,\n151:                                     ex.getLocalizedMessage()));\n152:                             sce.initCause(ex);\n153:                             throw sce;\n154:                         }\n155:                     }\n156: \n157:                     @Override\n158:                     public void remove() {\n159:                         throw new UnsupportedOperationException();\n"}], "isError": false, "timestamp": 1782767019703}]}
