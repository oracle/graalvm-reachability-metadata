junit.jupiter.api.Test;\\nimport org.junit.jupiter.api.io.TempDir;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\nimport static org.assertj.core.api.Assertions.assertThatThrownBy;\\n\\npublic class Maven_archiverTest {\\n\\n    @TempDir\\n    Path temporaryDirectory;\\n\\n    @Test\\n    void manifestConfigurationNormalizesClasspathPrefixAndSupportsLegacyRepositoryLayoutFlag() {\\n        ManifestConfiguration configuration = new ManifestConfiguration();\\n\\n        assertThat(configuration.getClasspathPrefix()).isEmpty();\\n        assertThat(configuration.getClasspathLayoutType()).isEqualTo(ManifestConfiguration.CLASSPATH_LAYOUT_TYPE_SIMPLE);\\n        assertThat(configuration.isUseUniqueVersions()).isTrue();\\n        assertThat(configuration.isAddClasspath()).isFalse();\\n\\n        configuration.setClasspathPrefix(\\\"lib\\\\\\\\runtime\\\");\\n        configuration.setClasspathMavenRepositoryLayout(true);\\n        configuration.setAddClasspath(true);\\n        configuration.setUseUniqueVersions(false);\\n\\n        assertThat(configuration.getClasspathPrefix()).isEqualTo(\\\"lib/runtime/\\\");\\n        assertThat(configuration.getClasspathLayoutType()).isEqualTo(ManifestConfiguration.CLASSPATH_LAYOUT_TYPE_REPOSITORY);\\n        assertThat(configuration.isAddClasspath()).isTrue();\\n        assertThat(configuration.isUseUniqueVersions()).isFalse();\\n    }\\n\\n    @Test\\n    void archiveConfigurationCollectsManifestEntriesAndSections() {\\n        MavenArchiveConfiguration configuration = new MavenArchiveConfiguration();\\n        Map<String, String> entries = new LinkedHashMap<>();\\n        entries.put(\\\"Implementation-Title\\\", \\\"Configured title\\\");\\n        entries.put(\\\"X-Custom\\\", \\\"custom value\\\");\\n        ManifestSection section = new ManifestSection();\\n        section.setName(\\\"com/example/Resource.txt\\\");\\n        section.addManifestEntry(\\\"SHA-256-Digest\\\", \\\"digest-value\\\");\\n\\n        configuration.setCompress(false);\\n        configuration.setIndex(true);\\n        configuration.setAddMavenDescriptor(false);\\n        configuration.setForced(false);\\n        configuration.addManifestEntries(entries);\\n        configuration.addManifestSection(section);\\n\\n        assertThat(configuration.isCompress()).isFalse();\\n        assertThat(configuration.isIndex()).isTrue();\\n        assertThat(configuration.isAddMavenDescriptor()).isFalse();\\n        assertThat(configuration.isForced()).isFalse();\\n        assertThat(configuration.isManifestEntriesEmpty()).isFalse();\\n        assertThat(configuration.getManifestEntries()).containsAllEntriesOf(entries);\\n        assertThat(configuration.isManifestSectionsEmpty()).isFalse();\\n        assertThat(configuration.getManifestSections()).containsExactly(section);\\n        assertThat(section.isManifestEntriesEmpty()).isFalse();\\n    }\\n\\n    @Test\\n    void generatedManifestContainsProjectDefaultsCustomEntriesAndNamedSections() throws Exception {\\n        MavenProject project = newProject(temporaryDirectory);\\n        MavenArchiveConfiguration archiveConfiguration = new MavenArchiveConfiguration();\\n        ManifestConfiguration manifestConfiguration = archiveConfiguration.getManifest();\\n        manifestConfiguration.setMainClass(\\\"com.example.Main\\\");\\n        manifestConfiguration.setPackageName(\\\"com.example\\\");\\n        manifestConfiguration.setAddDefaultImplementationEntries(true);\\n        manifestConfiguration.setAddDefaultSpecificationEntries(true);\\n        archiveConfiguration.addManifestEntry(\\\"X-Feature\\\", \\\"enabled\\\");\\n        archiveConfiguration.addManifestEntry(\\\"Implementation-Title\\\", \\\"Overridden title\\\");\\n        ManifestSection section = new ManifestSection();\\n        section.setName(\\\"com/example/Main.class\\\");\\n        section.addManifestEntry(\\\"Sealed\\\", \\\"true\\\");\\n        archiveConfiguration.addManifestSection(section);\\n\\n        Manifest manifest = new MavenArchiver().getManifest(project, archiveConfiguration);\\n\\n        Attributes mainAttributes = manifest.getMainAttributes();\\n        assertThat(attribute(mainAttributes, \\\"Created-By\\\")).isEqualTo(\\\"Apache Maven\\\");\\n        assertThat(attribute(mainAttributes, \\\"Built-By\\\")).isEqualTo(System.getProperty(\\\"user.name\\\"));\\n        assertThat(attribute(mainAttributes, \\\"Build-Jdk\\\")).isEqualTo(System.getProperty(\\\"java.version\\\"));\\n        assertThat(attribute(mainAttributes, \\\"Package\\\")).isEqualTo(\\\"com.example\\\");\\n        assertThat(attribute(mainAttributes, \\\"Main-Class\\\")).isEqualTo(\\\"com.example.Main\\\");\\n        assertThat(attribute(mainAttributes, \\\"X-Feature\\\")).isEqualTo(\\\"enabled\\\");\\n        assertThat(attribute(mainAttributes, \\\"Implementation-Title\\\")).isEqualTo(\\\"Overridden title\\\");\\n        assertThat(attribute(mainAttributes, \\\"Implementation-Version\\\")).isEqualTo(\\\"1.0.0\\\");\\n        assertThat(attribute(mainAttributes, \\\"Implementation-Vendor-Id\\\")).isEqualTo(\\\"com.example\\\");\\n        assertThat(attribute(mainAttributes, \\\"Implementation-Vendor\\\")).isEqualTo(\\\"Example Foundation\\\");\\n        assertThat(attribute(mainAttributes, \\\"Specification-Title\\\")).isEqualTo(\\\"Example Project\\\");\\n        assertThat(attribute(mainAttributes, \\\"Specification-Version\\\")).isEqualTo(\\\"1.0.0\\\");\\n        assertThat(attribute(mainAttributes, \\\"Specification-Vendor\\\")).isEqualTo(\\\"Example Foundation\\\");\\n        assertThat(attribute(manifest.getAttributes(\\\"com/example/Main.class\\\"), \\\"Sealed\\\")).isEqualTo(\\\"true\\\");\\n    }\\n\\n    @Test\\n    void generatedManifestBuildsClasspathUsingSimpleRepositoryAndCustomLayouts() throws Exception {\\n        Artifact compileDependency = newArtifact(\\n                \\\"com.acme.tools\\\", \\\"helper\\\", \\\"1.2.3\\\", Artifact.SCOPE_COMPILE, null, temporaryDirectory);\\n        Artifact runtimeDependency = newArtifact(\\n                \\\"org.example\\\", \\\"runtime-lib\\\", \\\"2.0.1\\\", Artifact.SCOPE_RUNTIME, \\\"tests\\\", temporaryDirectory);\\n        MavenProject project = newProject(temporaryDirectory);\\n        project.setArtifacts(new LinkedHashSet<>(Arrays.asList(compileDependency, runtimeDependency)));\\n\\n        assertThat(classPathFor(project, ManifestConfiguration.CLASSPATH_LAYOUT_TYPE_SIMPLE, null, true))\\n                .isEqualTo(\\\"lib/helper-1.2.3.jar lib/runtime-lib-2.0.1-tests.jar\\\");\\n        assertThat(classPathFor(project, ManifestConfiguration.CLASSPATH_LAYOUT_TYPE_REPOSITORY, null, true))\\n                .isEqualTo(\\\"lib/com/acme/tools/helper/1.2.3/helper-1.2.3.jar \\\"\\n                        + \\\"lib/org/example/runtime-lib/2.0.1/runtime-lib-2.0.1-tests.jar\\\");\\n        assertThat(classPathFor(\\n                project,\\n                ManifestConfiguration.CLASSPATH_LAYOUT_TYPE_CUSTOM,\\n                \\\"${artifact.groupIdPath}/${artifact.artifactId}${dashClassifier?}-${artifact.version}.${artifact.extension}\\\",\\n                true))\\n                .isEqualTo(\\\"lib/com/acme/tools/helper-1.2.3.jar \\\"\\n                        + \\\"lib/org/example/runtime-lib-tests-2.0.1.jar\\\");\\n    }\\n\\n    @Test\\n    void invalidCustomClasspathLayoutFailsFast() throws Exception {\\n        MavenProject project = newProject(temporaryDirectory);\\n        project.setArtifacts(Set.of(newArtifact(\\n                \\\"com.acme.tools\\\", \\\"helper\\\", \\\"1.2.3\\\", Artifact.SCOPE_COMPILE, null, temporaryDirectory)));\\n        MavenArchiveConfiguration archiveConfiguration = new MavenArchiveConfiguration();\\n        ManifestConfiguration manifestConfiguration = archiveConfiguration.getManifest();\\n        manifestConfiguration.setAddClasspath(true);\\n        manifestConfiguration.setClasspathLayoutType(ManifestConfiguration.CLASSPATH_LAYOUT_TYPE_CUS