:maven-archiver:2.5/populate-artifact-urls\\n/home/vjovanov/c/forge/forge8/graalvm-reachability-metadata/forge/logs/org.apache.maven:maven-archiver:2.5/populate-artifact-urls/populate_artifact_urls.log\\n/home/vjovanov/c/forge/forge8/graalvm-reachability-metadata/forge/logs/org.apache.maven:maven-archiver:2.5/discover-artifact-metadata\\n/home/vjovanov/c/forge/forge8/graalvm-reachability-metadata/forge/logs/org.apache.maven:maven-archiver:2.5/discover-artifact-metadata/discover_artifact_metadata.log\\n/home/vjovanov/c/forge/forge8/graalvm-reachability-metadata/forge/local_repositories/forge_worktrees/2359-bf1d9ae9/human-intervention-logs/org.apache.maven:maven-archiver:2.5\\n/home/vjovanov/c/forge/forge8/graalvm-reachability-metadata/forge/local_repositories/forge_worktrees/2359-bf1d9ae9/human-intervention-logs/org.apache.maven:maven-archiver:2.5/gradle-test\\n/home/vjovanov/c/forge/forge8/graalvm-reachability-metadata/forge/local_repositories/forge_worktrees/2359-bf1d9ae9/human-intervention-logs/org.apache.maven:maven-archiver:2.5/gradle-test/gradle-test-2026-05-12T18-49-53-681816Z.log\\n/home/vjovanov/c/forge/forge8/graalvm-reachability-metadata/forge/local_repositories/forge_worktrees/2359-bf1d9ae9/human-intervention-logs/org.apache.maven:maven-archiver:2.5/gradle-test/gradle-test-2026-05-12T18-44-41-342182Z.log\\n/home/vjovanov/c/forge/forge8/graalvm-reachability-metadata/forge/local_repositories/forge_worktrees/2359-bf1d9ae9/human-intervention-logs/org.apache.maven:maven-archiver:2.5/gradle-test/gradle-test-2026-05-12T18-50-08-330721Z.log\\n/home/vjovanov/c/forge/forge8/graalvm-reachability-metadata/forge/local_repositories/forge_worktrees/2359-bf1d9ae9/human-intervention-logs/org.apache.maven:maven-archiver:2.5/gradle-test/gradle-test-2026-05-12T18-50-16-698569Z.log\\n/home/vjovanov/c/forge/forge8/graalvm-reachability-metadata/forge/local_repositories/forge_worktrees/2359-bf1d9ae9/human-intervention-logs/org.apache.maven:maven-archiver:2.5/gradle-test/gradle-t