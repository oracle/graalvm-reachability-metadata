\\")\\n                    .containsEntry(\\\"artifactId\\\", \\\"example-app\\\")\\n                    .containsEntry(\\\"version\\\", \\\"1.0.0\\\");\\n        }\\n    }\\n\\n    private static MavenProject newProject(Path baseDirectory) throws IOException {\\n        MavenProject project = new MavenProject();\\n        project.setGroupId(\\\"com.example\\\");\\n        project.setArtifactId(\\\"example-app\\\");\\n        project.setVersion(\\\"1.0.0\\\");\\n        project.setName(\\\"Example Project\\\");\\n        Organization organization = new Organization();\\n        organization.setName(\\\"Example Foundation\\\");\\n        project.setOrganization(organization);\\n        Build build = new Build();\\n        build.setDirectory(baseDirectory.resolve(\\\"target\\\").toString());\\n        build.setOutputDirectory(baseDirectory.resolve(\\\"target/classes\\\").toString());\\n        project.setBuild(build);\\n        Path pom = baseDirectory.resolve(\\\"pom.xml\\\");\\n        Files.writeString(pom, \\\"\\\"\\\"\\n                <project>\\n                  <modelVersion>4.0.0</modelVersion>\\n                  <groupId>com.example</groupId>\\n                  <artifactId>example-app</artifactId>\\n                  <version>1.0.0</version>\\n                </project>\\n                \\\"\\\"\\\", StandardCharsets.UTF_8);\\n        project.setFile(pom.toFile());\\n        project.setArtifact(newArtifact(\\\"com.example\\\", \\\"example-app\\\", \\\"1.0.0\\\", Artifact.SCOPE_COMPILE, null, baseDirectory));\\n        project.setArtifacts(new LinkedHashSet<>());\\n        return project;\\n    }\\n\\n    private static Artifact newArtifact(\\n            String groupId, String artifactId, String version, String scope, String classifier, Path baseDirectory)\\n            throws IOException {\\n        Artifact artifact = new DefaultArtifact(\\n                groupId,\\n                artifactId,\\n                VersionRange.createFromVersion(version),\\n                scope,\\n                \\\"jar\\\",\\n                classifier,\\n                new ClasspathArtifactHandler());\\n        Path file = baseDirectory.resolve(artifactId + \\\"-\\\" + version + (classifier == null ? \\\"\\\" : \\\"-\\\" + classifier) + \\\".jar\\\");\\n        Files.writeString(file, artifactId, StandardCharsets.UTF_8);\\n        artifact.setFile(file.toFile());\\n        return artifact;\\n    }\\n\\n    private static String classPathFor(\\n            MavenProject project, String layoutType, String customLayout, boolean useUniqueVersions) throws Exception {\\n        MavenArchiveConfiguration archiveConfiguration = new MavenArchiveConfiguration();\\n        ManifestConfiguration manifestConfiguration = archiveConfiguration.getManifest();\\n        manifestConfiguration.setAddClasspath(true);\\n        manifestConfiguration.setClasspathPrefix(\\\"lib\\\");\\n        manifestConfiguration.setClasspathLayoutType(layoutType);\\n        manifestConfiguration.setCustomClasspathLayout(customLayout);\\n        manifestConfiguration.setUseUniqueVersions(useUniqueVersions);\\n        Manifest manifest = new MavenArchiver().getManifest(project, archiveConfiguration);\\n        return attribute(manifest.getMainAttributes(), \\\"Class-Path\\\");\\n    }\\n\\n    private static String attribute(Attributes attributes, String name) {\\n        return attributes.getValue(new Attributes.Name(name));\\n    }\\n\\n    private static Properties loadProperties(JarFile jarFile, String entryName) throws IOException {\\n        Properties properties = new Properties();\\n        try (InputStream inputStream = jarFile.getInputStream(jarFile.getEntry(entryName))) {\\n            properties.load(inputStream);\\n        }\\n        return properties;\\n    }\\n\\n    private static final class ClasspathArtifactHandler implements ArtifactHandler {\\n        @Override\\n        public String getExtension() {\\n            return \\\"jar\\\";\\n        }\\n\\n        @Override\\n        public String getType() {\\n            return \\\"jar\\\";\\n        }\\n\\n        @Override\\n        public String getClassifier() {\\n            return null;\\n        }\\n\\n        @Override\\n        public String getDirectory() {\\n            return \\\"jars\\\";\\n        }\\n\\n        @Override\\n        public String getPackaging() {\\n            return \\\"jar\\\";\\n        }\\n\\n        @Override\\n        public boolean isIncludesDependencies() {\\n            return false;\\n        }\\n\\n        @Override\\n        public String getLanguage() {\\n            return \\\"java\\\";\\n        }\\n\\n        @Override\\n        public boolean isAddedToClasspath() {\\n            return true;\\n        }\\n    }\\n}\\n\"}\n/home/vjovanov/c/forge/forge8/graalvm-reachability-metadata/forge/logs/org.apache.maven:maven-archiver:2.5/add-new-library-support/pi-generation-2026-05-12T18-42-07-540292Z.log:13812:[recv] {\"type\": \"message_end\", \"message\": {\"role\": \"assistant\", \"content\": [{\"type\": \"thinking\", \"thinking\": \"\", \"thinkingSignature\": \"{\\\"id\\\":\\\"rs_088c43fe69dfbf67016a0373eb55fc819e9d42f18c1edbf76d\\\",\\\"type\\\":\\\"reasoning\\\",\\\"encrypted_content\\\":\\\"gAAAAABqA3PtV1lTq9uZ3iTyx3XxdLee7TWPFQzwMIn-iz0jb4uKI2mTXz1-UsJINY21rczn6vqFqLFy36Uq0X2KLOoS17nuuwEag8bYv7AcwSsWTOZAr4llkV_6TGThOpYpSI9ylqjD4bXHkvLzMhUfBioIaguAaU2aPNCkX_vDyEYMJaS23mgVQsmLpXd3VnrIkdWUVA4OUnjs30Gv9fjhcPJR2TRix8-srgX1Qevb3YuK2fj_4sbRLAy88MaQPK01QVKVm_3XrKYso4Mgfzui3_RmMzOCel8xfL37IX2ocbMCKX7xb0u-pDZQZwt2LwJy-P1p30bspl8SKkHuRMzAL2H3CFpmm6WmsBzLyi8OP82Gtnzu8Zm5L63wmF_wrsxl4YAxSw9rMmSN9xqf19L9bdfv8_UiG6e4N4XWeVvipr-KbJvrfQP_uNgl7bmxncCHNIV1ELPfCi1mSisBnnjHSkLijGnwBUv5ek6Fbt7sMd4pk_pbJ9Xk2jGIEfwC-dtZbNilWJocIHEQm5MtLhrL1tSLFptWHNhqYTagVOsn2SYK7Ic7XObiGfgpTBu0P7whITSckjGyYyPQCV-qrjjMy7WP3zTEeA0msxuWJdqdWLaxNgLm9i1h_uLYjIoZ5WMgaufVWdBzDDMxQ2II7W3FB1-VzKaD7pcH1eZIPbafeAQa5vCEb5MaoCAsdGP8lYfZcm3ekNEbMh-d6_7HBx_At1Rm9qwfDL7U