artaee_api;\n\nimport static org.assertj.core.api.Assertions.assertThat;\nimport static org.assertj.core.api.Assertions.assertThatThrownBy;\n\nimport java.util.Map;\n\nimport jakarta.xml.bind.JAXBContext;\nimport jakarta.xml.bind.JAXBException;\n\nimport org.junit.jupiter.api.Test;\n\npublic class ContextFinderTest {\n    @Test\n    void contextPathUsesProviderMethodWithProperties() {\n        ContextPathProviderWithProperties.invoked = false;\n        ContextPathProviderWithProperties.contextPath = null;\n        ContextPathProviderWithProperties.classLoader = null;\n        ContextPathProviderWithProperties.properties = null;\n        Map<String, Object> properties = Map.of(\n                JAXBContext.JAXB_CONTEXT_FACTORY,\n                ContextPathProviderWithProperties.class.getName(),\n                \"custom\", \"value\");\n\n        assertThatThrownBy(() -> JAXBContext.newInstance(getClass().getPackageName(), getClass().getClassLoader(), properties))\n                .isInstanceOf(JAXBException.class)\n                .hasMessageContaining(\"Provider\")\n                .hasRootCauseInstanceOf(JAXBException.class)\n                .hasRootCauseMessageContaining(\"ClassCastException\");\n\n        assertThat(ContextPathProviderWithProperties.invoked).isTrue();\n        assertThat(ContextPathProviderWithProperties.contextPath).isEqualTo(getClass().getPackageName());\n        assertThat(ContextPathProviderWithProperties.classLoader).isSameAs(getClass().getClassLoader());\n        assertThat(ContextPathProviderWithProperties.properties).isSameAs(properties);\n    }\n\n    @Test\n    void contextPathFallsBackToProviderMethodWithoutProperties() {\n        ContextPathProviderWithoutProperties.invoked = false;\n        ContextPathProviderWithoutProperties.contextPath = null;\n        ContextPathProviderWithoutProperties.classLoader = null;\n        Map<String, Object> properties = Map.of(\n                JAXBContext.JAXB_CONTEXT_FACTORY,\n                ContextPathProviderWithoutProperties.class.getName());\n\n        assertThatThrownBy(() -> JAXBContext.newInstance(getClass().getPackageName(), getClass().getClassLoader(), properties))\n                .isInstanceOf(JAXBException.class)\n                .hasMessageContaining(\"Provider\")\n                .hasRootCauseInstanceOf(JAXBException.class)\n                .hasRootCauseMessageContaining(\"ClassCastException\");\n\n        assertThat(ContextPathProviderWithoutProperties.invoked).isTrue();\n        assertThat(ContextPathProviderWithoutProperties.contextPath).isEqualTo(getClass().getPackageName());\n        assertThat(ContextPathProviderWithoutProperties.classLoader).isSameAs(getClass().getClassLoader());\n    }\n\n    @Test\n    void classArrayUsesProviderMethodWithProperties() {\n        ClassArrayProvider.invoked = false;\n        ClassArrayProvider.classes = null;\n        ClassArrayProvider.properties = null;\n        Class<?>[] classes = {BoundType.class};\n        Map<String, Object> properties = Map.of(\n                JAXBContext.JAXB_CONTEXT_FACTORY,\n                ClassArrayProvider.class.getName(),\n                \"custom\", \"value\");\n\n        assertThatThrownBy(() -> JAXBContext.newInstance(classes, properties))\n                .isInstanceOf(JAXBException.class)\n                .hasMessageContaining(\"ClassCastException\");\n\n        assertThat(ClassArrayProvider.invoked).isTrue();\n        assertThat(ClassArrayProvider.classes).isSameAs(classes);\n        assertThat(ClassArrayProvider.properties).isSameAs(properties);\n    }\n\n    public static final class ContextPathProviderWithProperties {\n        static boolean invoked;\n        static String contextPath;\n        static ClassLoader classLoader;\n        static Map<String, ?> properties;\n\n        private ContextPathProviderWithProperties() {\n        }\n\n        public static Object createContext(String contextPath, ClassLoader classLoader, Map<String, ?> properties) {\n            ContextPathProviderWithProperties.invoked = true;\n            ContextPathProviderWithProperties.contextPath = contextPath;\n            ContextPathProviderWithProperties.classLoader = classLoader;\n            ContextPathProviderWithProperties.properties = properties;\n            return new NonContextResult();\n        }\n\n        public static Object createContext(String contextPath, ClassLoader classLoader) {\n            throw new AssertionError(\"The properties-aware createContext method should be preferred\");\n        }\n    }\n\n    public static final class ContextPathProviderWithoutProperties {\n        static boolean invoked;\n        static String contextPath;\n        static ClassLoader classLoader;\n\n        private ContextPathProviderWithoutProperties() {\n        }\n\n        public static Object createContext(String contextPath, ClassLoader classLoader) {\n            ContextPathProviderWithoutProperties.invoked = true;\n            ContextPathProviderWithoutProperties.contextPath = contextPath;\n            ContextPathProviderWithoutProperties.classLoader = classLoader;\n            return new NonContextResult();\n        }\n    }\n\n    public static final class ClassArrayProvider {\n        static boolean invoked;\n        static Class<?>[] classes;\n        static Map<String, ?> properties;\n\n        private ClassArrayProvider() {\n        }\n\n        public static Object createContext(Class<?>[] classes, Map<String, ?> properties) {\n            ClassArrayProvider.invoked = true;\n            ClassArrayProvider.classes = classes;\n            ClassArrayProvider.properties = properties;\n            return new NonContextResult();\n        }\n    }\n\n    public static final class BoundType {\n    }\n\n    public static final class NonContextResult {\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 581, "output": 1888, "cacheRead": 26624, "cacheWrite": 0, "totalTokens": 29093, "cost": {"