[tool-call] delta {"path":"tests/src/jakarta.platform/jakarta.jakartaee-api/10.0.0/src/test/java/jakarta_platform/jakarta_jakartaee_api/JakartaElFactoryFinderTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage jakarta_platform.jakarta_jakartaee_api;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.util.Properties;\n\nimport jakarta.el.ELContext;\nimport jakarta.el.ExpressionFactory;\nimport jakarta.el.MethodExpression;\nimport jakarta.el.ValueExpression;\n\nimport org.junit.jupiter.api.Test;\n\npublic class JakartaElFactoryFinderTest {\n    private static final String EXPRESSION_FACTORY_PROPERTY = \"jakarta.el.ExpressionFactory\";\n\n    @Test\n    void newInstanceUsesPropertiesConstructorWhenContextClassLoaderIsNull() {\n        String previousProvider = System.getProperty(EXPRESSION_FACTORY_PROPERTY);\n        ClassLoader previousContextClassLoader = Thread.currentThread().getContextClassLoader();\n        Properties properties = new Properties();\n        properties.setProperty(\"jakarta.el.cacheSize\", \"32\");\n\n        try {\n            System.setProperty(EXPRESSION_FACTORY_PROPERTY, PropertiesExpressionFactory.class.getName());\n            Thread.currentThread().setContextClassLoader(null);\n\n            ExpressionFactory expressionFactory = ExpressionFactory.newInstance(properties);\n\n            assertThat(expressionFactory)\n                    .isInstanceOf(PropertiesExpressionFactory.class)\n                    .extracting(factory -> ((PropertiesExpressionFactory) factory).properties())\n                    .isSameAs(properties);\n        } finally {\n            restoreProviderProperty(previousProvider);\n            Thread.currentThread().setContextClassLoader(previousContextClassLoader);\n        }\n    }\n\n    private static void restoreProviderProperty(String previousProvider) {\n        if (previousProvider == null) {\n            System.clearProperty(EXPRESSION_FACTORY_PROPERTY);\n        } else {\n            System.setProperty(EXPRESSION_FACTORY_PROPERTY, previousProvider);\n        }\n    }\n\n    public static class PropertiesExpressionFactory extends ExpressionFactory {\n        private final Properties properties;\n\n        public PropertiesExpressionFactory(Properties properties) {\n            this.properties = properties;\n        }\n\n        Properties properties() {\n            return properties;\n        }\n\n        @Override\n        public ValueExpression createValueExpression(ELContext context, String expression, Class<?> expectedType) {\n            throw new UnsupportedOperationException(\"Expression parsing is not needed by this test\");\n        }\n\n        @Override\n        public ValueExpression createValueExpression(Object instance, Class<?> expectedType) {\n            throw new UnsupportedOperationException(\"Expression parsing is not needed by this test\");\n        }\n\n        @Override\n        public MethodExpression createMethodExpression(\n                ELContext context,\n                String expression,\n                Class<?> expectedReturnType,\n                Class<?>[] expectedParamTypes) {\n            throw new UnsupportedOperationException(\"Expression parsing is not needed by this test\");\n        }\n\n        @Override\n        public <T> T coerceToType(Object obj, Class<T> targetType) {\n            throw new UnsupportedOperationException(\"Type coercion is not needed by this test\");\n        }\n    }\n}\n"}
