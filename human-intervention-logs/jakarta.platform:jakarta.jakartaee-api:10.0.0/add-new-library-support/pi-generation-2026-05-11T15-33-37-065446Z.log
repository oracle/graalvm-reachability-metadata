3QWfjHJK|fc_0ecf9a32559f3aa3016a01f693719c8193b72c05e9ba6d7640", "name": "write", "arguments": {"path": "tests/src/jakarta.platform/jakarta.jakartaee-api/10.0.0/src/test/java/jakarta_platform/jakarta_jakartaee_api/ConvertMessageFactoryTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage jakarta_platform.jakarta_jakartaee_api;\n\nimport static org.assertj.core.api.Assertions.assertThat;\nimport static org.junit.jupiter.api.Assertions.assertThrows;\n\nimport java.util.Collections;\nimport java.util.HashMap;\nimport java.util.Iterator;\nimport java.util.Locale;\nimport java.util.Map;\n\nimport jakarta.faces.application.Application;\nimport jakarta.faces.application.ApplicationWrapper;\nimport jakarta.faces.application.FacesMessage;\nimport jakarta.faces.application.FacesMessage.Severity;\nimport jakarta.faces.component.UIComponentBase;\nimport jakarta.faces.component.UIViewRoot;\nimport jakarta.faces.context.ExternalContext;\nimport jakarta.faces.context.FacesContext;\nimport jakarta.faces.context.ResponseStream;\nimport jakarta.faces.context.ResponseWriter;\nimport jakarta.faces.convert.ConverterException;\nimport jakarta.faces.convert.IntegerConverter;\nimport jakarta.faces.convert.LongConverter;\nimport jakarta.faces.lifecycle.Lifecycle;\nimport jakarta.faces.render.RenderKit;\n\nimport org.junit.jupiter.api.Test;\n\npublic class ConvertMessageFactoryTest {\n    private static final String APPLICATION_BUNDLE = \"jakarta_platform.jakarta_jakartaee_api.MessageFactoryMessages\";\n\n    @Test\n    void converterFailureUsesApplicationMessageBundleWhenConfigured() {\n        try (TestFacesContext context = TestFacesContext.activate(new TestApplication(APPLICATION_BUNDLE))) {\n            TestComponent component = new TestComponent(\"Count\");\n            IntegerConverter converter = new IntegerConverter();\n\n            ConverterException exception = assertThrows(ConverterException.class,\n                    () -> converter.getAsObject(context, component, \"not-an-int\"));\n\n            assertThat(exception.getFacesMessage()).satisfies(message -> {\n                assertThat(message.getSummary()).isEqualTo(\"Application converter cannot parse not-an-int for Count\");\n                assertThat(message.getSeverity()).isEqualTo(FacesMessage.SEVERITY_ERROR);\n            });\n        }\n    }\n\n    @Test\n    void converterFailureFallsBackToFacesMessagesBundleWhenApplicationBundleIsNotConfigured() {\n        try (TestFacesContext context = TestFacesContext.activate(new TestApplication(null))) {\n            TestComponent component = new TestComponent(\"Quantity\");\n            IntegerConverter converter = new IntegerConverter();\n\n            ConverterException exception = assertThrows(ConverterException.class,\n                    () -> converter.getAsObject(context, component, \"many\"));\n\n            assertThat(exception.getFacesMessage()).satisfies(message -> {\n                assertThat(message.getSummary()).isEqualTo(\"Faces converter cannot parse many for Quantity\");\n                assertThat(message.getSeverity()).isEqualTo(FacesMessage.SEVERITY_ERROR);\n            });\n        }\n    }\n\n    @Test\n    void converterFailureFallsBackToMojarraMessagesWhenFacesMessagesBundleDoesNotContainKey() {\n        try (TestFacesContext context = TestFacesContext.activate(new TestApplication(null))) {\n            TestComponent component = new TestComponent(\"Identifier\");\n            LongConverter converter = new LongConverter();\n\n            ConverterException exception = assertThrows(ConverterException.class,\n                    () -> converter.getAsObject(context, component, \"not-a-long\"));\n\n            assertThat(exception.getFacesMessage()).satisfies(message -> {\n                assertThat(message.getSummary()).isEqualTo(\"Mojarra converter cannot parse not-a-long for Identifier\");\n                assertThat(message.getSeverity()).isEqualTo(FacesMessage.SEVERITY_ERROR);\n            });\n        }\n    }\n\n    public static class TestComponent extends UIComponentBase {\n        private final Map<String, Object> attributes = new HashMap<>();\n\n        TestComponent(String label) {\n            attributes.put(\"label\", label);\n        }\n\n        @Override\n        public Map<String, Object> getAttributes() {\n            return attributes;\n        }\n\n        @Override\n        public String getFamily() {\n            return \"test\";\n        }\n    }\n\n    private static final class TestApplication extends ApplicationWrapper {\n        private final String messageBundle;\n\n        private TestApplication(String messageBundle) {\n            this.messageBundle = messageBundle;\n        }\n\n        @Override\n        public String getMessageBundle() {\n            return messageBundle;\n        }\n    }\n\n    private static final class TestFacesContext extends FacesContext implements AutoCloseable {\n        private final Application application;\n        private final Locale originalDefaultLocale;\n\n        private TestFacesContext(Application application, Locale originalDefaultLocale) {\n            this.application = application;\n            this.originalDefaultLocale = originalDefaultLocale;\n        }\n\n        static TestFacesContext activate(Application application) {\n            Locale originalDefaultLocale = Locale.getDefault();\n            Locale.setDefault(Locale.ROOT);\n            TestFacesContext context = new TestFacesContext(application, originalDefaultLocale);\n            setCurrentInstance(context);\n            return context;\n        }\n\n        @Override\n        public Application getApplication() {\n            return application;\n        }\n\n        @Override\n        public Iterator<String> getClientIdsWithMessages() {\n            return Collections.emptyIterator();\n        }\n\n        @Override\n        public Lifecycle getLifecycle() {\n            return null;\n        }\n\n        @Override\n        public ExternalContext getExternalContext() {\n            return null;\n        }\n\n        @Override\n        public Severity getMaximumSeverity() {\n            return null;\n        }\n\n        @Override\n        public Iterator<FacesMessage> getMessages() {\n            return Collections.emptyIterator();\n        }\n\n        @Override\n        public Iterator<FacesMessage> getMessages(String clientId) {\n            return Collections.emptyIterator();\n        }\n\n        @Override\n        public RenderKit getRenderKit() {\n            return null;\n        }\n\n        @Override\n        public boolean getRenderResponse() {\n            return false;\n        }\n\n        @Override\n        public boolean getResponseComplete() {\n            return false;\n        }\n\n        @Override\n        public ResponseStream getResponseStream() {\n            return null;\n        }\n\n        @Override\n        public void setResponseStream(ResponseStream responseStream) {\n            throw new UnsupportedOperationException(\"Response streams are not used by this test\");\n        }\n\n        @Override\n        public ResponseWriter getResponseWriter() {\n            return null;\n        }\n\n        @Override\n        public void setResponseWriter(ResponseWriter responseWriter) {\n            throw new UnsupportedOperationException(\"Response writers are not used by this test\");\n        }\n\n        @Override\n        public UIViewRoot getViewRoot() {\n            return null;\n        }\n\n        @Override\n        public void setViewRoot(UIViewRoot root) {\n            throw new UnsupportedOperationException(\"View roots are not used by this test\");\n        }\n\n        @Override\n        public void addMessage(String clientId, FacesMessage message) {\n            throw new UnsupportedOperationException(\"Faces messages are not used by this test\");\n        }\n\n        @Override\n        public void release() {\n            setCurrentInstance(null);\n            Locale.setDefault(originalDefaultLocale);\n        }\n\n        @Override\n        public void renderResponse() {\n            throw new UnsupportedOperationException(\"Rendering is not used by this test\");\n        }\n\n        @Override\n        public void responseComplete() {\n            throw new UnsupportedOperationException(\"Response completion is not used by this test\");\n        }\n\n        @Override\n        public void close() {\n            release();\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1193, "output": 2177, "cacheRead": 24064, "cacheWrite": 0, "totalTokens": 27434, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778513547425, "responseId": "resp_0ecf9a32559f3aa3016a01f68c29148193b91c3757418cc510"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_tkRYHo87QUtKonWe3QWfjHJK|fc_0ecf9a32559f3aa3016a01f693719c8193b72c05e9ba6d7640", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 8146 bytes to tests/src/jakarta.platform/jakarta.jakartaee-api/10.0.0/src/test/java/jakarta_platform/jakarta_jakartaee_api/ConvertMessageFactoryTest.java"}], "isError": false, "timestamp": 1778513565344}]}
