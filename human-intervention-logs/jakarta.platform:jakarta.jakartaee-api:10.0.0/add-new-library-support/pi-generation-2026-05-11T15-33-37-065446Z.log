              if (locale != null) {
                  mf.setLocale(locale);
                  b.append(mf.format(params));
                  localizedStr = b.toString();
              }
              return localizedStr;
          }
  
          private Locale locale;
          private Object[] parameters;
          private Object[] resolvedParameters;
      }
  
  } // end of class MessageFactory
