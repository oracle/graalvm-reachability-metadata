              return m;
          }
  
          @Override
          public Class<?>[] getParameterTypes() {
              return m.getParameterTypes();
          }
  
          @Override
          public boolean isVarArgs() {
              return m.isVarArgs();
          }
  
          @Override
          public boolean isBridge() {
              return m.isBridge();
          }
      }
  
