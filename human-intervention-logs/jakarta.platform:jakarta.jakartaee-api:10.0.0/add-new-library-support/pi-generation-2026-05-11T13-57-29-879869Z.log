j.core.api.Assertions.assertThat;\nimport static org.assertj.core.api.Assertions.assertThatThrownBy;\n\nimport java.util.Properties;\n\nimport jakarta.mail.Address;\nimport jakarta.mail.Message;\nimport jakarta.mail.NoSuchProviderException;\nimport jakarta.mail.Provider;\nimport jakarta.mail.Session;\nimport jakarta.mail.Transport;\nimport jakarta.mail.URLName;\n\nimport org.junit.jupiter.api.Test;\n\npublic class SessionTest {\n    private static final String PROTOCOL = \"session-test-transport\";\n\n    @Test\n    void getTransportInstantiatesConfiguredProvider() throws Exception {\n        TestTransport.constructorSession = null;\n        TestTransport.constructorUrlName = null;\n        Session session = Session.getInstance(new Properties());\n        Provider provider = new Provider(\n                Provider.Type.TRANSPORT,\n                PROTOCOL,\n                TestTransport.class.getName(),\n                \"test\",\n                null);\n\n        session.setProvider(provider);\n\n        Transport transport = session.getTransport(PROTOCOL);\n\n        assertThat(transport).isInstanceOf(TestTransport.class);\n        assertThat(TestTransport.constructorSession).isSameAs(session);\n        assertThat(TestTransport.constructorUrlName.getProtocol()).isEqualTo(PROTOCOL);\n        assertThat(transport.getURLName().getProtocol()).isEqualTo(PROTOCOL);\n    }\n\n    @Test\n    void getTransportRejectsProviderClassThatIsNotATransport() {\n        Session session = Session.getInstance(new Properties());\n        Provider provider = new Provider(\n                Provider.Type.TRANSPORT,\n                PROTOCOL,\n                String.class.getName(),\n                \"test\",\n                null);\n\n        assertThatThrownBy(() -> session.getTransport(provider))\n                .isInstanceOf(NoSuchProviderException.class)\n                .hasMessageContaining(PROTOCOL);\n    }\n\n    public static final class TestTransport extends Transport {\n        private static Session constructorSession;\n        private static URLName constructorUrlName;\n\n        public TestTransport(Session session, URLName urlname) {\n            super(session, urlname);\n            constructorSession = session;\n            constructorUrlName = urlname;\n        }\n\n        @Override\n        public void sendMessage(Message message, Address[] addresses) {\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 993, "output": 1136, "cacheRead": 19968, "cacheWrite": 0, "totalTokens": 22097, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778507798640, "responseId": "resp_02dcfc066afe59aa016a01e017326081a293cb880678cf0c70"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_9JunHDc7SNKVzJosxcedeaCx|fc_02dcfc066afe59aa016a01e021017081a2a48f469c5cd87e37", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2617 bytes to tests/src/jakarta.platform/jakarta.jakartaee-api/10.0.0/src/test/java/jakarta_platform/jakarta_jakartaee_api/SessionTest.java"}], "isError": false, "timestamp": 1778507811824}]}
