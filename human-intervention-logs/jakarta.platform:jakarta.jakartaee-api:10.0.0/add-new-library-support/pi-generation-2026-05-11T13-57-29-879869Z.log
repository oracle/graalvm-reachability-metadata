  package jakarta_platform.jakarta_jakartaee_api;
  
  import static org.assertj.core.api.Assertions.assertThat;
  import static org.assertj.core.api.Assertions.assertThatThrownBy;
  
  import java.util.Map;
  
  import jakarta.xml.bind.JAXBContext;
  import jakarta.xml.bind.JAXBException;
  
  import org.junit.jupiter.api.Test;
  
  public class ContextFinderTest {
      @Test
      void contextPathUsesProviderMethodWithProperties() {
          ContextPathProviderWithProperties.invoked = false;
          ContextPathProviderWithProperties.contextPath = null;
          ContextPathProviderWithProperties.classLoader = null;
          ContextPathProviderWithProperties.properties = null;
          Map<String, Object> properties = Map.of(
                  JAXBContext.JAXB_CONTEXT_FACTORY,
                  ContextPathProviderWithProperties.class.getName(),
                  "custom", "value");
  
          assertThatThrownBy(() -> JAXBContext.newInstance(
                  getClass().getPackageName(),
                  getClass().getClassLoader(),
                  properties))
                  .isInstanceOf(JAXBException.class)
                  .hasMessageContaining("Provider")
                  .hasMessageContaining("ClassCastException");
  
          assertThat(ContextPathProviderWithProperties.invoked).isTrue();
          assertThat(ContextPathProviderWithProperties.contextPath).isEqualTo(getClass().getPackageName());
          assertThat(ContextPathProviderWithProperties.classLoader).isSameAs(getClass().getClassLoader());
          assertThat(ContextPathProviderWithProperties.properties).isSameAs(properties);
      }
  
      @Test
      void contextPathFallsBackToProviderMethodWithoutProperties() {
          ContextPathProviderWithoutProperties.invoked = false;
          ContextPathProviderWithoutProperties.contextPath = null;
          ContextPathProviderWithoutProperties.classLoader = null;
          Map<String, Object> properties = Map.of(
                  JAXBContext.JAXB_CONTEXT_FACTORY,
                  ContextPathProviderWithoutProperties.class.getName());
  
          assertThatThrownBy(() -> JAXBContext.newInstance(
                  getClass().getPackageName(),
                  getClass().getClassLoader(),
                  properties))
                  .isInstanceOf(JAXBException.class)
                  .hasMessageContaining("Provider")
                  .hasMessageContaining("ClassCastException");
  
          assertThat(ContextPathProviderWithoutProperties.invoked).isTrue();
          assertThat(ContextPathProviderWithoutProperties.contextPath).isEqualTo(getClass().getPackageName());
          assertThat(ContextPathProviderWithoutProperties.classLoader).isSameAs(getClass().getClassLoader());
      }
  
      @Test
      void classArrayUsesProviderMethodWithProperties() {
          ClassArrayProvider.invoked = false;
          ClassArrayProvider.classes = null;
          ClassArrayProvider.properties = null;
          Class<?>[] classes = {BoundType.class};
          Map<String, Object> properties = Map.of(
                  JAXBContext.JAXB_CONTEXT_FACTORY,
                  ClassArrayProvider.class.getName(),
                  "custom", "value");
  
          assertThatThrownBy(() -> JAXBContext.newInstance(classes, properties))
                  .isInstanceOf(JAXBException.class)
                  .hasMessageContaining("ClassCastException");
  
          assertThat(ClassArrayProvider.invoked).isTrue();
          assertThat(ClassArrayProvider.classes).isSameAs(classes);
          assertThat(ClassArrayProvider.properties).isSameAs(properties);
      }
  
      public static final class ContextPathProviderWithProperties {
          private static boolean invoked;
          private static String contextPath;
          private static ClassLoader classLoader;
          private static Map<String, ?> properties;
  
          private ContextPathProviderWithProperties() {
          }
  
          public static Object createContext(String contextPath, ClassLoader classLoader, Map<String, ?> properties) {
              ContextPathProviderWithProperties.invoked = true;
              ContextPathProviderWithProperties.contextPath = contextPath;
              ContextPathProviderWithProperties.classLoader = classLoader;
              ContextPathProviderWithProperties.properties = properties;
              return new NonContextResult();
          }
  
          public static Object createContext(String contextPath, ClassLoader classLoader) {
              throw new AssertionError("The properties-aware createContext method should be preferred");
          }
      }
  
      public static final class ContextPathProviderWithoutProperties {
          private static boolean invoked;
          private static String contextPath;
          private static ClassLoader classLoader;
  
          private ContextPathProviderWithoutProperties() {
          }
  
          public static Object createContext(String contextPath, ClassLoader classLoader) {
              ContextPathProviderWithoutProperties.invoked = true;
              ContextPathProviderWithoutProperties.contextPath = contextPath;
              ContextPathProviderWithoutProperties.classLoader = classLoader;
              return new NonContextResult();
          }
      }
  
      public static final class ClassArrayProvider {
          private static boolean invoked;
          private static Class<?>[] classes;
          private static Map<String, ?> properties;
  
          private ClassArrayProvider() {
          }
  
          public static Object createContext(Class<?>[] classes, Map<String, ?> properties) {
              ClassArrayProvider.invoked = true;
              ClassArrayProvider.classes = classes;
              ClassArrayProvider.properties = properties;
              return new NonContextResult();
          }
      }
  
      public static final class BoundType {
      }
  
      public static final class NonContextResult {
