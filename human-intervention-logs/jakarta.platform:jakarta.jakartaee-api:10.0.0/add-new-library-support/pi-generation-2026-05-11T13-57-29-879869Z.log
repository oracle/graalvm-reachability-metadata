[tool-call] delta {"path":"tests/src/jakarta.platform/jakarta.jakartaee-api/10.0.0/src/test/java/jakarta_platform/jakarta_jakartaee_api/SessionTest.java","edits":[{"oldText":"    void getTransportInstantiatesConfiguredProvider() throws Exception {\n        TestTransport.constructorSession = null;\n        TestTransport.constructorUrlName = null;\n        Session session = Session.getInstance(new Properties());\n        Provider provider = new Provider(\n                Provider.Type.TRANSPORT,\n                PROTOCOL,\n                TestTransport.class.getName(),\n                \"test\",\n                null);\n\n        session.setProvider(provider);\n\n        Transport transport = session.getTransport(PROTOCOL);\n\n        assertThat(transport).isInstanceOf(TestTransport.class);\n        assertThat(TestTransport.constructorSession).isSameAs(session);\n        assertThat(TestTransport.constructorUrlName.getProtocol()).isEqualTo(PROTOCOL);\n        assertThat(transport.getURLName().getProtocol()).isEqualTo(PROTOCOL);\n    }\n\n    @Test\n    void getTransportRejectsProviderClassThatIsNotATransport() {\n        Session session = Session.getInstance(new Properties());\n        Provider provider = new Provider(\n                Provider.Type.TRANSPORT,\n                PROTOCOL,\n                String.class.getName(),\n                \"test\",\n                null);\n\n        assertThatThrownBy(() -> session.getTransport(provider))\n                .isInstanceOf(NoSuchProviderException.class)\n                .hasMessageContaining(PROTOCOL);\n    }\n","newText":"    void getTransportInstantiatesConfiguredProvider() throws Exception {\n        ClassLoader originalContextClassLoader = Thread.currentThread().getContextClassLoader();\n        Thread.currentThread().setContextClassLoader(SessionTest.class.getClassLoader());\n        try {\n            TestTransport.constructorSession = null;\n            TestTransport.constructorUrlName = null;\n            Session session = Session.getInstance(new Properties());\n            Provider provider = new Provider(\n                    Provider.Type.TRANSPORT,\n                    PROTOCOL,\n                    TestTransport.class.getName(),\n                    \"test\",\n                    null);\n\n            session.setProvider(provider);\n\n            Transport transport = session.getTransport(PROTOCOL);\n\n            assertThat(transport).isInstanceOf(TestTransport.class);\n            assertThat(TestTransport.constructorSession).isSameAs(session);\n            assertThat(TestTransport.constructorUrlName.getProtocol()).isEqualTo(PROTOCOL);\n            assertThat(transport.getURLName().getProtocol()).isEqualTo(PROTOCOL);\n        } finally {\n            Thread.currentThread().setContextClassLoader(originalContextClassLoader);\n        }\n    }\n\n    @Test\n    void getTransportRejectsProviderClassThatIsNotATransport() {\n        ClassLoader originalContextClassLoader = Thread.currentThread().getContextClassLoader();\n        Thread.currentThread().setContextClassLoader(SessionTest.class.getClassLoader());\n        try {\n            Session session = Session.getInstance(new Properties());\n            Provider provider = new Provider(\n                    Provider.Type.TRANSPORT,\n                    PROTOCOL,\n                    String.class.getName(),\n                    \"test\",\n                    null);\n\n            assertThatThrownBy(() -> session.getTransport(provider))\n                    .isInstanceOf(NoSuchProviderException.class)\n                    .hasMessageContaining(PROTOCOL);\n        } finally {\n            Thread.currentThread().setContextClassLoader(originalContextClassLoader);\n        }\n    }\n"}]}
