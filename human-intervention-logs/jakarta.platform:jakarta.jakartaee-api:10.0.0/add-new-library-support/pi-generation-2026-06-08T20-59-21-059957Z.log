        Map<String, Object> properties = providerProperties(ThreeArgumentContextPathProvider.class);\n\n        JAXBContext context = JAXBContext.newInstance(\n                \"jakarta_platform.jakarta_jakartaee_api\",\n                contextClassLoader(),\n                properties);\n\n        assertThat(context).isInstanceOf(TestJAXBContext.class);\n        TestJAXBContext testContext = (TestJAXBContext) context;\n        assertThat(testContext.getSource()).isEqualTo(\"context-path-with-properties\");\n        assertThat(testContext.getContextPath()).isEqualTo(\"jakarta_platform.jakarta_jakartaee_api\");\n        assertThat(testContext.getProperties()).isSameAs(properties);\n    }\n\n    @Test\n    void createsContextPathProviderUsingLegacyFactoryMethod() throws Exception {\n        JAXBContext context = JAXBContext.newInstance(\n                \"jakarta_platform.jakarta_jakartaee_api\",\n                contextClassLoader(),\n                providerProperties(LegacyContextPathProvider.class));\n\n        assertThat(context).isInstanceOf(TestJAXBContext.class);\n        TestJAXBContext testContext = (TestJAXBContext) context;\n        assertThat(testContext.getSource()).isEqualTo(\"legacy-context-path\");\n        assertThat(testContext.getContextPath()).isEqualTo(\"jakarta_platform.jakarta_jakartaee_api\");\n    }\n\n    @Test\n    void createsClassArrayProviderUsingFactoryMethod() throws Exception {\n        Map<String, Object> properties = providerProperties(ClassArrayProvider.class);\n\n        JAXBContext context = JAXBContext.newInstance(new Class<?>[] { BoundType.class }, properties);\n\n        assertThat(context).isInstanceOf(TestJAXBContext.class);\n        TestJAXBContext testContext = (TestJAXBContext) context;\n        assertThat(testContext.getSource()).isEqualTo(\"class-array\");\n        assertThat(testContext.getBoundClasses()).containsExactly(BoundType.class);\n        assertThat(testContext.getProperties()).isSameAs(properties);\n    }\n\n    @Test\n    void reportsInvalidProviderResultWithClassLoaderLocations() {\n        assertThatThrownBy(() -> JAXBContext.newInstance(\n                new Class<?>[] { BoundType.class },\n                providerProperties(InvalidProvider.class)))\n                .isInstanceOf(JAXBException.class)\n                .hasMessageContaining(\"ClassCastException\");\n    }\n\n    private static ClassLoader contextClassLoader() {\n        return Thread.currentThread().getContextClassLoader();\n    }\n\n    private static Map<String, Object> providerProperties(Class<?> providerClass) {\n        return Map.of(JAXBContext.JAXB_CONTEXT_FACTORY, providerClass.getName());\n    }\n\n    public static class ThreeArgumentContextPathProvider {\n        public static JAXBContext createContext(\n                String contextPath,\n                ClassLoader classLoader,\n                Map<String, ?> properties) {\n            return TestJAXBContext.forContextPath(\"context-path-with-properties\", contextPath, properties);\n        }\n    }\n\n    public static class LegacyContextPathProvider {\n        public static JAXBContext createContext(String contextPath, ClassLoader classLoader) {\n            return TestJAXBContext.forContextPath(\"legacy-context-path\", contextPath, null);\n        }\n    }\n\n    public static class ClassArrayProvider {\n        public static JAXBContext createContext(Class<?>[] classes, Map<String, ?> properties) {\n            return TestJAXBContext.forClasses(\"class-array\", classes, properties);\n        }\n    }\n\n    public static class InvalidProvider {\n        public static Object createContext(Class<?>[] classes, Map<String, ?> properties) {\n            return new InvalidProviderResult();\n        }\n    }\n\n    public static class BoundType {\n    }\n\n    public static class InvalidProviderResult {\n    }\n\n    public static class TestJAXBContext extends JAXBContext {\n        private final String source;\n        private final String contextPath;\n        private final Class<?>[] boundClasses;\n        private final Map<String, ?> properties;\n\n        private TestJAXBContext(\n                String source,\n                String contextPath,\n                Class<?>[] boundClasses,\n                Map<String, ?> properties) {\n            this.source = source;\n            this.contextPath = contextPath;\n            this.boundClasses = boundClasses == null ? new Class<?>[0] : boundClasses.clone();\n            this.properties = properties;\n        }\n\n        static TestJAXBContext forContextPath(String source, String contextPath, Map<String, ?> properties) {\n            return new TestJAXBContext(source, contextPath, null, properties);\n        }\n\n        static TestJAXBContext forClasses(String source, Class<?>[] boundClasses, Map<String, ?> properties) {\n            return new TestJAXBContext(source, null, boundClasses, properties);\n        }\n\n        String getSource() {\n            return source;\n        }\n\n        String getContextPath() {\n            return contextPath;\n        }\n\n        Class<?>[] getBoundClasses() {\n            return boundClasses.clone();\n        }\n\n        Map<String, ?> getProperties() {\n            return properties;\n        }\n\n        @Override\n        public Unmarshaller createUnmarshaller() {\n            throw new UnsupportedOperationException(\"Unmarshaller creation is not needed by this test\");\n        }\n\n        @Override\n        public Marshaller createMarshaller() {\n            throw new UnsupportedOperationException(\"Marshaller creation is not needed by this test\");\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1780952215328}]}
