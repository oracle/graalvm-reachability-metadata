[tool-call] delta {"path":"tests/src/jakarta.platform/jakarta.jakartaee-api/10.0.0/src/test/java/jakarta_platform/jakarta_jakartaee_api/ELProcessorTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage jakarta_platform.jakarta_jakartaee_api;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.lang.reflect.Method;\nimport java.lang.reflect.Modifier;\n\nimport jakarta.el.ELContext;\nimport jakarta.el.ELProcessor;\nimport jakarta.el.ExpressionFactory;\nimport jakarta.el.MethodExpression;\nimport jakarta.el.ValueExpression;\n\nimport org.junit.jupiter.api.AfterAll;\nimport org.junit.jupiter.api.BeforeAll;\nimport org.junit.jupiter.api.Test;\n\npublic class ELProcessorTest {\n    private static final String EXPRESSION_FACTORY_PROPERTY = \"jakarta.el.ExpressionFactory\";\n\n    private static String previousExpressionFactory;\n\n    @BeforeAll\n    static void configureExpressionFactory() {\n        previousExpressionFactory = System.getProperty(EXPRESSION_FACTORY_PROPERTY);\n        System.setProperty(EXPRESSION_FACTORY_PROPERTY, TestExpressionFactory.class.getName());\n    }\n\n    @AfterAll\n    static void restoreExpressionFactory() {\n        if (previousExpressionFactory == null) {\n            System.clearProperty(EXPRESSION_FACTORY_PROPERTY);\n        } else {\n            System.setProperty(EXPRESSION_FACTORY_PROPERTY, previousExpressionFactory);\n        }\n    }\n\n    @Test\n    void mapsNamedStaticFunctionByScanningDeclaredMethods() throws Exception {\n        ELProcessor processor = new ELProcessor();\n\n        processor.defineFunction(\"math\", \"largest\", Math.class.getName(), \"max\");\n\n        Method mappedMethod = resolveFunction(processor, \"math\", \"largest\");\n        assertThat(mappedMethod).isNotNull();\n        assertThat(mappedMethod.getName()).isEqualTo(\"max\");\n        assertThat(Modifier.isStatic(mappedMethod.getModifiers())).isTrue();\n    }\n\n    @Test\n    void mapsStaticFunctionBySignatureWithReferenceArrayParameters() throws Exception {\n        ELProcessor processor = new ELProcessor();\n\n        processor.defineFunction(\n                \"fixture\",\n                \"describe\",\n                FunctionLibrary.class.getName(),\n                \"java.lang.String describe(java.lang.String, java.lang.String[], java.lang.String[][])\");\n\n        Method mappedMethod = resolveFunction(processor, \"fixture\", \"describe\");\n        assertThat(mappedMethod).isNotNull();\n        assertThat(mappedMethod.getName()).isEqualTo(\"describe\");\n        assertThat(mappedMethod.getReturnType()).isEqualTo(String.class);\n        assertThat(mappedMethod.getParameterTypes())\n                .containsExactly(String.class, String[].class, String[][].class);\n        assertThat(Modifier.isStatic(mappedMethod.getModifiers())).isTrue();\n    }\n\n    private static Method resolveFunction(ELProcessor processor, String prefix, String localName) {\n        return processor.getELManager().getELContext().getFunctionMapper().resolveFunction(prefix, localName);\n    }\n\n    public static class FunctionLibrary {\n        public static String describe(String prefix, String[] values, String[][] matrix) {\n            return prefix + values.length + matrix.length;\n        }\n    }\n\n    public static class TestExpressionFactory extends ExpressionFactory {\n        @Override\n        public ValueExpression createValueExpression(ELContext context, String expression, Class<?> expectedType) {\n            throw new UnsupportedOperationException(\"Expression parsing is not needed by these tests\");\n        }\n\n        @Override\n        public ValueExpression createValueExpression(Object instance, Class<?> expectedType) {\n            throw new UnsupportedOperationException(\"Expression parsing is not needed by these tests\");\n        }\n\n        @Override\n        public MethodExpression createMethodExpression(\n                ELContext context,\n                String expression,\n                Class<?> expectedReturnType,\n                Class<?>[] expectedParamTypes) {\n            throw new UnsupportedOperationException(\"Expression parsing is not needed by these tests\");\n        }\n\n        @Override\n        public <T> T coerceToType(Object obj, Class<T> targetType) {\n            return targetType.cast(obj);\n        }\n    }\n}\n"}
[tool-call] end id=call_EpRpTswZomohgQhjg9bFp6KJ|fc_01be2842630e2bf3016a272cee8c0c819497aae88c7370f290 name=write args={"path": "tests/src/jakarta.platform/jakarta.jakartaee-api/10.0.0/src/test/java/jakarta_platform/jakarta_jakartaee_api/ELProcessorTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage jakarta_platform.jakarta_jakartaee_api;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.lang.reflect.Method;\nimport java.lang.reflect.Modifier;\n\nimport jakarta.el.ELContext;\nimport jakarta.el.ELProcessor;\nimport jakarta.el.ExpressionFactory;\nimport jakarta.el.MethodExpression;\nimport jakarta.el.ValueExpression;\n\nimport org.junit.jupiter.api.AfterAll;\nimport org.junit.jupiter.api.BeforeAll;\nimport org.junit.jupiter.api.Test;\n\npublic class ELProcessorTest {\n    private static final String EXPRESSION_FACTORY_PROPERTY = \"jakarta.el.ExpressionFactory\";\n\n    private static String previousExpressionFactory;\n\n    @BeforeAll\n    static void configureExpressionFactory() {\n        previousExpressionFactory = System.getProperty(EXPRESSION_FACTORY_PROPERTY);\n        System.setProperty(EXPRESSION_FACTORY_PROPERTY, TestExpressionFactory.class.getName());\n    }\n\n    @AfterAll\n    static void restoreExpressionFactory() {\n        if (previousExpressionFactory == null) {\n            System.clearProperty(EXPRESSION_FACTORY_PROPERTY);\n        } else {\n            System.setProperty(EXPRESSION_FACTORY_PROPERTY, previousExpressionFactory);\n        }\n    }\n\n    @Test\n    void mapsNamedStaticFunctionByScanningDeclaredMethods() throws Exception {\n        ELProcessor processor = new ELProcessor();\n\n        processor.defineFunction(\"math\", \"largest\", Math.class.getName(), \"max\");\n\n        Method mappedMethod = resolveFunction(processor, \"