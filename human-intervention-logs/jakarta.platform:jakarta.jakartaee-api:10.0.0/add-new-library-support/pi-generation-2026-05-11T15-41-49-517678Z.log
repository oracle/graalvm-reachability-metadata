n(null))) {\n            TestInput input = new TestInput();\n            input.getAttributes().put(\"label\", \"Standard Label\");\n\n            input.validateValue(context, \"\");\n\n            assertThat(context.messages()).singleElement().satisfies(message -> {\n                assertThat(message.getSummary()).isEqualTo(\"Faces bundle says Standard Label is required\");\n                assertThat(message.getSeverity()).isEqualTo(FacesMessage.SEVERITY_ERROR);\n            });\n            assertThat(input.isValid()).isFalse();\n        }\n    }\n\n    @Test\n    void selectOneFallsBackToMojarraMessagesWhenFacesMessagesBundleDoesNotContainKey() {\n        try (TestFacesContext context = TestFacesContext.activate(new TestApplication(null))) {\n            TestSelectOne select = new TestSelectOne();\n            select.getAttributes().put(\"label\", \"Selection Label\");\n\n            select.validateValue(context, \"missing-option\");\n\n            assertThat(context.messages()).singleElement().satisfies(message -> {\n                assertThat(message.getSummary()).isEqualTo(\"Mojarra bundle says Selection Label is not valid\");\n                assertThat(message.getSeverity()).isEqualTo(FacesMessage.SEVERITY_ERROR);\n            });\n            assertThat(select.isValid()).isFalse();\n        }\n    }\n\n    public static class TestInput extends UIInput {\n        private final Map<String, Object> attributes = new HashMap<>();\n        private boolean valid = true;\n\n        @Override\n        public Map<String, Object> getAttributes() {\n            return attributes;\n        }\n\n        @Override\n        public String getClientId(FacesContext context) {\n            return \"testInput\";\n        }\n\n        @Override\n        public boolean isRequired() {\n            return true;\n        }\n\n        @Override\n        public String getRequiredMessage() {\n            return null;\n        }\n\n        @Override\n        public boolean isValid() {\