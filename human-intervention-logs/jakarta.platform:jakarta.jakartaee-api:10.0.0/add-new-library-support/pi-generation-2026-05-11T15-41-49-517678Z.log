cale.setDefault(Locale.ROOT);\n            TestFacesContext context = new TestFacesContext(application, originalDefaultLocale);\n            setCurrentInstance(context);\n            return context;\n        }\n","newText":"        private final Application application;\n        private final List<FacesMessage> messages = new ArrayList<>();\n        private final Locale originalDefaultLocale;\n        private final ClassLoader originalContextClassLoader;\n        private final ClassLoader bundleClassLoader;\n\n        private TestFacesContext(Application application, Locale originalDefaultLocale,\n                ClassLoader originalContextClassLoader, ClassLoader bundleClassLoader) {\n            this.application = application;\n            this.originalDefaultLocale = originalDefaultLocale;\n            this.originalContextClassLoader = originalContextClassLoader;\n            this.bundleClassLoader = bundleClassLoader;\n        }\n\n        static TestFacesContext activate(Application application) {\n            Locale originalDefaultLocale = Locale.getDefault();\n            ClassLoader originalContextClassLoader = Thread.currentThread().getContextClassLoader();\n            ClassLoader bundleClassLoader = new InMemoryResourceBundleClassLoader(originalContextClassLoader, Map.of(\n                    APPLICATION_BUNDLE_RESOURCE, \"\"\"\n                            jakarta.faces.component.UIInput.REQUIRED=Application bundle says {0} is required\n                            jakarta.faces.converter.IntegerConverter.INTEGER=Application converter cannot parse {0} for {2}\n                            \"\"\",\n                    FACES_BUNDLE_RESOURCE, \"\"\"\n                            jakarta.faces.component.UIInput.REQUIRED=Faces bundle says {0} is required\n                            jakarta.faces.converter.IntegerConverter.INTEGER=Faces converter cannot parse {0} for {2}\n                            \"\"\",\n                    MOJARRA_BUNDLE_RESOURCE, \"\"\"\n                            jakarta.faces.component.UISelectOne.INVALID=Mojarra bundle says {0} is not valid\n                            jakarta.faces.converter.LongConverter.LONG=Mojarra converter cannot parse {0} for {2}\n                            jakarta.faces.validator.RegexValidator.NOT_MATCHED=Mojarra regex says pattern {0} did not match\n                            \"\"\"));\n            Locale.setDefault(Locale.ROOT);\n            Thread.currentThread().setContextClassLoader(bundleClassLoader);\n            TestFacesContext context = new TestFacesContext(\n                    application, originalDefaultLocale, originalContextClassLoader, bundleClassLoader);\n            setCurrentInstance(context);\n            return context;\n        }\n"},{"oldText":"        public void release() {\n            setCurrentInstance(null);\n            Locale.setDefault(originalDefaultLocale);\n        }\n","newText":"        public void release() {\n            setCurrentInstance(null);\n            ResourceBundle.clearCache(bundleClassLoader);\n            Thread.currentThread().setContextClassLoader(originalContextClassLoader);\n            Locale.setDefault(originalDefaultLocale);\n        }\n"},{"oldText":"    }\n}\n","newText":"    }\n\n    private static final class InMemoryResourceBundleClassLoader extends ClassLoader {\n        private final Map<String, byte[]> resources;\n\n        private InMemoryResourceBundleClassLoader(ClassLoader parent, Map<String, String> resources) {\n            super(parent);\n            this.resources = new HashMap<>();\n            resources.forEach((name, content) -> this.resources.put(name, content.getBytes(StandardCharsets.UTF_8)));\n        }\n\n        @Override\n        public URL getResource(String name) {\n            if (resources.containsKey(name)) {\n                return resourceUrl(name);\n            }\n            return super.getResource(name);\n        }\n\n        @Override\n        public InputStream getResourceAs