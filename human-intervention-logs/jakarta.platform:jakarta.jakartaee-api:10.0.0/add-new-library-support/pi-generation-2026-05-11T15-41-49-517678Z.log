sage;\nimport jakarta.faces.application.FacesMessage.Severity;\nimport jakarta.faces.component.UIViewRoot;\nimport jakarta.faces.context.ExternalContext;\nimport jakarta.faces.context.FacesContext;\nimport jakarta.faces.context.ResponseStream;\nimport jakarta.faces.context.ResponseWriter;\nimport jakarta.faces.lifecycle.Lifecycle;\nimport jakarta.faces.render.RenderKit;\n\nimport org.junit.jupiter.api.Test;\n\npublic class MessageFactoryTest {\n    private static final String MESSAGE_FACTORY_CLASS = \"jakarta.faces.webapp.MessageFactory\";\n    private static final String APPLICATION_BUNDLE = \"jakarta_platform.jakarta_jakartaee_api.MessageFactoryMessages\";\n    private static final String APPLICATION_BUNDLE_RESOURCE =\n            \"jakarta_platform/jakarta_jakartaee_api/MessageFactoryMessages.properties\";\n    private static final String FACES_BUNDLE_RESOURCE = \"jakarta/faces/Messages.properties\";\n    private static final String MOJARRA_BUNDLE_RESOURCE = \"com/sun/faces/resources/Messages.properties\";\n\n    @Test\n    public void getMessageUsesConfiguredApplicationBundle() throws Throwable {\n        try (TestFacesContext context = TestFacesContext.activate(new TestApplication(APPLICATION_BUNDLE))) {\n            FacesMessage message = getMessage(\"jakarta.faces.component.UIInput.REQUIRED\", \"Custom Label\");\n\n            assertThat(message.getSummary()).isEqualTo(\"Application bundle says Custom Label is required\");\n            assertThat(message.getSeverity()).isEqualTo(FacesMessage.SEVERITY_ERROR);\n            assertThat(context.getApplication().getMessageBundle()).isEqualTo(APPLICATION_BUNDLE);\n        }\n    }\n\n    @Test\n    public void getMessageFallsBackToFacesMessagesBundleWhenApplicationBundleIsNotConfigured() throws Throwable {\n        try (TestFacesContext context = TestFacesContext.activate(new TestApplication(null))) {\n            FacesMessage message = getMessage(\"jakarta.faces.component.UIInput.REQUIRED\", \"Standard Label\");\n\