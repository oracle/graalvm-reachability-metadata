  package jakarta_platform.jakarta_jakartaee_api;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.lang.invoke.MethodHandle;
  import java.lang.invoke.MethodHandles;
  import java.lang.invoke.MethodType;
  import java.security.Permission;
  import java.util.logging.Logger;
  
  import jakarta.xml.bind.JAXBContextFactory;
  
  import org.junit.jupiter.api.Test;
  
  public class ServiceLoaderUtilTest {
      private static final String SERVICE_LOADER_UTIL_CLASS = "jakarta.xml.bind.ServiceLoaderUtil";
  
      @Test
      void lookupUsingOsgiServiceLoaderReturnsNullWhenLocatorIsAbsent() throws Throwable {
          MethodHandle lookupUsingOSGiServiceLoader = staticMethod(
                  "lookupUsingOSGiServiceLoader",
                  Object.class,
                  String.class,
                  Logger.class);
  
          Object provider = lookupUsingOSGiServiceLoader.invokeWithArguments(
                  JAXBContextFactory.class.getName(),
                  Logger.getLogger(ServiceLoaderUtilTest.class.getName()));
  
          assertThat(provider).isNull();
      }
  
      @Test
      void nullSafeLoadClassUsesClassForNameWhenClassLoaderIsNull() throws Throwable {
          MethodHandle nullSafeLoadClass = staticMethod(
                  "nullSafeLoadClass",
                  Class.class,
                  String.class,
                  ClassLoader.class);
  
          Class<?> providerClass = (Class<?>) nullSafeLoadClass.invokeWithArguments(
                  ConstructibleProvider.class.getName(),
                  null);
  
          assertThat(providerClass).isEqualTo(ConstructibleProvider.class);
      }
  
      @Test
      void newInstanceCreatesProviderWithPublicNoArgConstructor() throws Throwable {
          ConstructibleProvider.instances = 0;
          MethodHandle newInstance = staticMethod(
                  "newInstance",
                  Object.class,
                  String.class,
                  String.class,
                  exceptionHandlerClass());
  
          Object provider = withContextClassLoader(
                  null,
                  () -> newInstance.invokeWithArguments(
                          ConstructibleProvider.class.getName(),
                          ConstructibleProvider.class.getName(),
                          null));
  
          assertThat(provider).isInstanceOf(ConstructibleProvider.class);
          assertThat(ConstructibleProvider.instances).isEqualTo(1);
      }
  
      @Test
      @SuppressWarnings("removal")
      void safeLoadClassUsesClassForNameForDefaultImplementationWhenPackageAccessIsDenied() throws Throwable {
          MethodHandle safeLoadClass = staticMethod(
                  "safeLoadClass",
                  Class.class,
                  String.class,
                  String.class,
                  ClassLoader.class);
          SecurityManager previousSecurityManager = System.getSecurityManager();
          PackageAccessDenyingSecurityManager securityManager =
                  new PackageAccessDenyingSecurityManager(ConstructibleProvider.class.getPackage().getName());
          boolean securityManagerInstalled = installSecurityManagerIfSupported(securityManager);
  
          try {
              Class<?> providerClass = (Class<?>) safeLoadClass.invokeWithArguments(
                      ConstructibleProvider.class.getName(),
                      ConstructibleProvider.class.getName(),
                      getClass().getClassLoader());
  
              assertThat(providerClass).isEqualTo(ConstructibleProvider.class);
              if (securityManagerInstalled) {
                  assertThat(securityManager.wasCheckPackageAccessCalled()).isTrue();
              }
          } finally {
              if (securityManagerInstalled) {
                  System.setSecurityManager(previousSecurityManager);
              }
          }
      }
  
      private static MethodHandle staticMethod(
              String methodName,
              Class<?> returnType,
              Class<?>... parameterTypes) throws ReflectiveOperationException {
          Class<?> serviceLoaderUtilClass = Class.forName(SERVICE_LOADER_UTIL_CLASS);
          MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(serviceLoaderUtilClass, MethodHandles.lookup());
          return lookup.findStatic(serviceLoaderUtilClass, methodName, MethodType.methodType(returnType, parameterTypes));
      }
  
      private static Class<?> exceptionHandlerClass() throws ClassNotFoundException {
          return Class.forName(SERVICE_LOADER_UTIL_CLASS + "$ExceptionHandler");
      }
  
      @SuppressWarnings("removal")
      private static boolean installSecurityManagerIfSupported(SecurityManager securityManager) {
          try {
              System.setSecurityManager(securityManager);
              return System.getSecurityManager() == securityManager;
          } catch (UnsupportedOperationException unsupportedOperationException) {
              return false;
          }
      }
  
      private static <T> T withContextClassLoader(
              ClassLoader classLoader,
              ThrowingSupplier<T> supplier) throws Throwable {
          Thread currentThread = Thread.currentThread();
          ClassLoader previousClassLoader = currentThread.getContextClassLoader();
          currentThread.setContextClassLoader(classLoader);
          try {
              return supplier.get();
          } finally {
              currentThread.setContextClassLoader(previousClassLoader);
          }
      }
  
      @FunctionalInterface
      private interface ThrowingSupplier<T> {
          T get() throws Throwable;
      }
  
      public static final class ConstructibleProvider {
          private static int instances;
  
          public ConstructibleProvider() {
  
