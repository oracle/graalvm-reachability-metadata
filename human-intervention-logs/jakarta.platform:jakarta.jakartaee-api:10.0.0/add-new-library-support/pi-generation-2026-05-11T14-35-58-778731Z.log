  package jakarta_platform.jakarta_jakartaee_api;
  
  import static org.assertj.core.api.Assertions.assertThat;
  import static org.assertj.core.api.Assertions.assertThatThrownBy;
  
  import java.io.ByteArrayInputStream;
  import java.io.IOException;
  import java.io.InputStream;
  import java.io.OutputStream;
  import java.nio.charset.StandardCharsets;
  import java.util.Properties;
  
  import jakarta.mail.Address;
  import jakarta.mail.Message;
  import jakarta.mail.NoSuchProviderException;
  import jakarta.mail.Provider;
  import jakarta.mail.Session;
  import jakarta.mail.Transport;
  import jakarta.mail.URLName;
  import jakarta.mail.util.LineInputStream;
  import jakarta.mail.util.LineOutputStream;
  import jakarta.mail.util.StreamProvider;
  
  import org.junit.jupiter.api.Test;
  
  public class SessionTest {
      private static final String PROTOCOL = "session-test-transport";
  
      @Test
      void getTransportInstantiatesConfiguredProvider() throws Exception {
          ClassLoader originalContextClassLoader = Thread.currentThread().getContextClassLoader();
          String originalStreamProvider = System.getProperty(StreamProvider.class.getName());
          Thread.currentThread().setContextClassLoader(SessionTest.class.getClassLoader());
          System.setProperty(StreamProvider.class.getName(), TestStreamProvider.class.getName());
          try {
              TestTransport.constructorSession = null;
              TestTransport.constructorUrlName = null;
              Session session = Session.getInstance(new Properties());
              Provider provider = new Provider(
                      Provider.Type.TRANSPORT,
                      PROTOCOL,
                      TestTransport.class.getName(),
                      "test",
                      null);
  
              session.setProvider(provider);
  
              Transport transport = session.getTransport(PROTOCOL);
  
              assertThat(transport).isInstanceOf(TestTransport.class);
              assertThat(TestTransport.constructorSession).isSameAs(session);
              assertThat(TestTransport.constructorUrlName.getProtocol()).isEqualTo(PROTOCOL);
              assertThat(transport.getURLName().getProtocol()).isEqualTo(PROTOCOL);
          } finally {
              restoreStreamProvider(originalStreamProvider);
              Thread.currentThread().setContextClassLoader(originalContextClassLoader);
          }
      }
  
      @Test
      void getTransportRejectsProviderClassThatIsNotATransport() {
          ClassLoader originalContextClassLoader = Thread.currentThread().getContextClassLoader();
          String originalStreamProvider = System.getProperty(StreamProvider.class.getName());
          Thread.currentThread().setContextClassLoader(SessionTest.class.getClassLoader());
          System.setProperty(StreamProvider.class.getName(), TestStreamProvider.class.getName());
          try {
              Session session = Session.getInstance(new Properties());
              Provider provider = new Provider(
                      Provider.Type.TRANSPORT,
                      PROTOCOL,
                      String.class.getName(),
                      "test",
                      null);
  
              assertThatThrownBy(() -> session.getTransport(provider))
                      .isInstanceOf(NoSuchProviderException.class)
                      .hasMessageContaining(PROTOCOL);
          } finally {
              restoreStreamProvider(originalStreamProvider);
              Thread.currentThread().setContextClassLoader(originalContextClassLoader);
          }
      }
  
      private static void restoreStreamProvider(String originalStreamProvider) {
          if (originalStreamProvider == null) {
              System.clearProperty(StreamProvider.class.getName());
          } else {
              System.setProperty(StreamProvider.class.getName(), originalStreamProvider);
          }
      }
  
      public static final class TestTransport extends Transport {
          private static Session constructorSession;
          private static URLName constructorUrlName;
          private static Message sentMessage;
          private static Address[] sentAddresses;
  
          public TestTransport(Session session, URLName urlname) {
              super(session, urlname);
              constructorSession = session;
              constructorUrlName = urlname;
          }
  
          @Override
          public void sendMessage(Message message, Address[] addresses) {
              sentMessage = message;
              sentAddresses = addresses;
          }
      }
  
      public static final class TestStreamProvider implements StreamProvider {
          public TestStreamProvider() {
          }
  
          @Override
          public InputStream inputBase64(InputStream inputStream) {
              return inputStream;
          }
  
          @Override
          public OutputStream outputBase64(OutputStream outputStream) {
              return outputStream;
          }
  
          @Override
          public InputStream inputBinary(InputStream inputStream) {
              return inputStream;
          }
  
          @Override
          public OutputStream outputBinary(OutputStream outputStream) {
              return outputStream;
          }
  
          @Override
          public OutputStream outputB(OutputStream outputStream) {
              return outputStream;
          }
  
          @Override
          public InputStream inputQ(InputStream inputStream) {
              return inputStream;
          }
  
          @Override
          public OutputStream outputQ(OutputStream outputStream, boolean encodingWord) {
              return outputStream;
          }
  
          @Override
          public LineInputStream inputLineStream(InputStream inputStream, boolean allowUtf8) {
              return () -> new String(inputStream.readAllBytes(), StandardCharsets.US_ASCII);
          }
  
          @Override
          public LineOutputStream outputLineStream(OutputStream outputStream, boolean allowUtf8) {
              return new TestLineOutputStream(outputStream);
          }
  
          @Override
          public InputStream inputQP(InputStream inputStream) {
              return inputStream;
          }
  
          @Override
          public OutputStream outputQP(OutputStream outputStream) {
              return outputStream;
          }
  
          @Override
          public InputStream inputSharedByteArray(byte[] buffer) {
              return new ByteArrayInputStream(buffer);
          }
  
          @Override
          public InputStream inputUU(InputStream inputStream) {
              return inputStream;
          }
  
          @Override
          public OutputStream outputUU(OutputStream outputStream, String filename) {
              return outputStream;
          }
      }
  
      public static final class TestLineOutputStream implements LineOutputStream {
          private final OutputStream outputStream;
  
          private TestLineOutputStream(OutputStream outputStream) {
              this.outputStream = outputStream;
          }
  
          @Override
          public void writeln(String value) throws IOException {
              outputStream.write(value.getBytes(StandardCharsets.US_ASCII));
              writeln();
          }
  
          @Override
          public void writeln() throws IOException {
              outputStream.write('\r');
              outputStream.write('\n');
          }
  
          @Override
          public void write(byte[] content) throws IOException {
              outputStream.write(content);
          }
      }
