  package jakarta_platform.jakarta_jakartaee_api;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.net.URL;
  import java.net.URLClassLoader;
  import java.util.Set;
  import java.util.concurrent.Callable;
  
  import jakarta.mail.MessagingException;
  import jakarta.mail.internet.MimeBodyPart;
  import jakarta.mail.internet.MimePart;
  import jakarta.mail.util.StreamProvider;
  
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  
  public class MimeUtilTest {
      @Test
      void getContentTypeUsesConfiguredHandlerLoadedByTheContextClassLoader() throws MessagingException {
          String propertyName = "mail.mime.contenttypehandler";
          String originalHandler = System.getProperty(propertyName);
          String originalStreamProvider = System.getProperty(StreamProvider.class.getName());
          Thread currentThread = Thread.currentThread();
          ClassLoader originalContextClassLoader = currentThread.getContextClassLoader();
          System.setProperty(StreamProvider.class.getName(), SessionTest.TestStreamProvider.class.getName());
          try {
              MimeBodyPart part = new MimeBodyPart();
              part.setHeader("Content-Type", "text/plain; charset=iso-8859-1");
  
              System.setProperty(propertyName, ContentTypeHandler.class.getName());
              currentThread.setContextClassLoader(MimeUtilTest.class.getClassLoader());
              String contentType = part.getContentType();
  
              assertThat(contentType).isEqualTo("text/plain; charset=utf-8");
          } finally {
              currentThread.setContextClassLoader(originalContextClassLoader);
              restoreProperty(propertyName, originalHandler);
              restoreProperty(StreamProvider.class.getName(), originalStreamProvider);
          }
      }
  
      @Test
      void getContentTypeFallsBackToHandlerLoadedByMimeUtilClassLoader() throws Exception {
          try {
              assertIsolatedFallbackHandlerCleansContentType();
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
      }
  
      private static void assertIsolatedFallbackHandlerCleansContentType() throws Exception {
          String propertyName = "mail.mime.contenttypehandler";
          String originalHandler = System.getProperty(propertyName);
          String originalStreamProvider = System.getProperty(StreamProvider.class.getName());
          Thread currentThread = Thread.currentThread();
          ClassLoader originalContextClassLoader = currentThread.getContextClassLoader();
          URL mailApiLocation = MimeBodyPart.class.getProtectionDomain().getCodeSource().getLocation();
          URL testClassesLocation = MimeUtilTest.class.getProtectionDomain().getCodeSource().getLocation();
          try (ChildFirstClassLoader mailClassLoader = new ChildFirstClassLoader(
                  new URL[] { mailApiLocation, testClassesLocation },
                  MimeUtilTest.class.getClassLoader()
          )) {
              System.setProperty(StreamProvider.class.getName(), SessionTest.TestStreamProvider.class.getName());
              System.setProperty(propertyName, IsolatedContentTypeHandler.class.getName());
              currentThread.setContextClassLoader(new RejectingClassLoader(
                      mailClassLoader,
                      Set.of(IsolatedContentTypeHandler.class.getName())
              ));
  
              Class<?> runnerClass = mailClassLoader.loadClass(IsolatedMimeUtilRunner.class.getName());
              Callable<?> runner = (Callable<?>) runnerClass.getConstructor().newInstance();
  
              assertThat(runner.call()).isEqualTo("text/plain; charset=utf-8");
          } finally {
              currentThread.setContextClassLoader(originalContextClassLoader);
              restoreProperty(propertyName, originalHandler);
              restoreProperty(StreamProvider.class.getName(), originalStreamProvider);
          }
      }
  
      private static void restoreProperty(String propertyName, String originalValue) {
          if (originalValue == null) {
              System.clearProperty(propertyName);
          } else {
              System.setProperty(propertyName, originalValue);
          }
      }
  
      public static final class ContentTypeHandler {
          public ContentTypeHandler() {
          }
  
          public static String cleanContentType(MimePart part, String contentType) {
              return contentType.replace("iso-8859-1", "utf-8");
          }
      }
  
      public static final class IsolatedMimeUtilRunner implements Callable<String> {
          public IsolatedMimeUtilRunner() {
          }
  
