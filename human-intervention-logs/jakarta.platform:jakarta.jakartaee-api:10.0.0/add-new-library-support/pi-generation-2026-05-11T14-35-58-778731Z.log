[tool-call] delta {"path":"tests/src/jakarta.platform/jakarta.jakartaee-api/10.0.0/src/test/java/jakarta_platform/jakarta_jakartaee_api/MimeUtilTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage jakarta_platform.jakarta_jakartaee_api;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.util.ArrayList;\nimport java.util.List;\nimport java.util.Set;\n\nimport jakarta.mail.MessagingException;\nimport jakarta.mail.internet.MimeBodyPart;\nimport jakarta.mail.internet.MimePart;\n\nimport org.junit.jupiter.api.Test;\n\npublic class MimeUtilTest {\n    @Test\n    void getContentTypeUsesConfiguredHandlerWhenContextLoaderFallsBackToClassForName() throws MessagingException {\n        String propertyName = \"mail.mime.contenttypehandler\";\n        String originalHandler = System.getProperty(propertyName);\n        Thread currentThread = Thread.currentThread();\n        ClassLoader originalContextClassLoader = currentThread.getContextClassLoader();\n        RejectingClassLoader rejectingClassLoader = new RejectingClassLoader(\n                originalContextClassLoader,\n                Set.of(ContentTypeHandler.class.getName())\n        );\n        System.setProperty(propertyName, ContentTypeHandler.class.getName());\n        currentThread.setContextClassLoader(rejectingClassLoader);\n        try {\n            MimeBodyPart part = new MimeBodyPart();\n            part.setHeader(\"Content-Type\", \"text/plain; charset=iso-8859-1\");\n\n            String contentType = part.getContentType();\n\n            assertThat(contentType).isEqualTo(\"text/plain; charset=utf-8\");\n            assertThat(rejectingClassLoader.getRejectedLoads()).containsExactly(ContentTypeHandler.class.getName());\n        } finally {\n            currentThread.setContextClassLoader(originalContextClassLoader);\n            if (originalHandler == null) {\n                System.clearProperty(propertyName);\n            } else {\n                System.setProperty(propertyName, originalHandler);\n            }\n        }\n    }\n\n    public static final class ContentTypeHandler {\n        public ContentTypeHandler() {\n        }\n\n        public static String cleanContentType(MimePart part, String contentType) {\n            return contentType.replace(\"iso-8859-1\", \"utf-8\");\n        }\n    }\n\n    private static final class RejectingClassLoader extends ClassLoader {\n        private final Set<String> rejectedNames;\n        private final List<String> rejectedLoads;\n\n        private RejectingClassLoader(ClassLoader parent, Set<String> rejectedNames) {\n            super(parent);\n            this.rejectedNames = rejectedNames;\n            this.rejectedLoads = new ArrayList<>();\n        }\n\n        @Override\n        public Class<?> loadClass(String name) throws ClassNotFoundException {\n            if (rejectedNames.contains(name)) {\n                rejectedLoads.add(name);\n                throw new ClassNotFoundException(name);\n            }\n            return super.loadClass(name);\n        }\n\n        private List<String> getRejectedLoads() {\n            return rejectedLoads;\n        }\n    }\n}\n"}
