ContextClassLoader();\n        URL mailApiLocation = MimeBodyPart.class.getProtectionDomain().getCodeSource().getLocation();\n        URL testClassesLocation = MimeUtilTest.class.getProtectionDomain().getCodeSource().getLocation();\n        try (ChildFirstClassLoader mailClassLoader = new ChildFirstClassLoader(\n                new URL[] { mailApiLocation, testClassesLocation },\n                MimeUtilTest.class.getClassLoader()\n        )) {\n            System.setProperty(StreamProvider.class.getName(), SessionTest.TestStreamProvider.class.getName());\n            System.setProperty(propertyName, IsolatedContentTypeHandler.class.getName());\n            currentThread.setContextClassLoader(new RejectingClassLoader(\n                    mailClassLoader,\n                    Set.of(IsolatedContentTypeHandler.class.getName())\n            ));\n\n            Class<?> runnerClass = mailClassLoader.loadClass(IsolatedMimeUtilRunner.class.getName());\n            Callable<?> runner = (Callable<?>) runnerClass.getConstructor().newInstance();\n\n            assertThat(runner.call()).isEqualTo(\"text/plain; charset=utf-8\");\n        } finally {\n            currentThread.setContextClassLoader(originalContextClassLoader);\n            restoreProperty(propertyName, originalHandler);\n            restoreProperty(StreamProvider.class.getName(), originalStreamProvider);\n        }\n    }\n\n    private static void restoreProperty(String propertyName, String originalValue) {\n        if (originalValue == null) {\n            System.clearProperty(propertyName);\n        } else {\n            System.setProperty(propertyName, originalValue);\n        }\n    }\n\n    public static final class ContentTypeHandler {\n        public ContentTypeHandler() {\n        }\n\n        public static String cleanContentType(MimePart part, String contentType) {\n            return contentType.replace(\"iso-8859-1\", \"utf-8\");\n        }\n    }\n\n    public static final class IsolatedMimeUtilRunner implements Callable<String> {\n        public IsolatedMimeUtilRunner() {\n        }\n\n        @Override\n        public String call() throws MessagingException {\n            MimeBodyPart part = new MimeBodyPart();\n            part.setHeader(\"Content-Type\", \"text/plain; charset=iso-8859-1\");\n            return part.getContentType();\n        }\n    }\n\n    public static final class IsolatedContentTypeHandler {\n        public IsolatedContentTypeHandler() {\n        }\n\n        public static String cleanContentType(MimePart part, String contentType) {\n            return contentType.replace(\"iso-8859-1\", \"utf-8\");\n        }\n    }\n\n    private static final class RejectingClassLoader extends ClassLoader {\n        private final Set<String> rejectedNames;\n\n        private RejectingClassLoader(ClassLoader parent, Set<String> rejectedNames) {\n            super(parent);\n            this.rejectedNames = rejectedNames;\n        }\n\n        @Override\n        public Class<?> loadClass(String name) throws ClassNotFoundException {\n            if (rejectedNames.contains(name)) {\n                throw new ClassNotFoundException(name);\n            }\n            return super.loadClass(name);\n        }\n    }\n\n    private static final class ChildFirstClassLoader extends URLClassLoader {\n        private ChildFirstClassLoader(URL[] urls, ClassLoader parent) {\n            super(urls, parent);\n        }\n\n        @Override\n        protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {\n            if (!isChildFirst(name)) {\n                return super.loadClass(name, resolve);\n            }\n            synchronized (getClassLoadingLock(name)) {\n                Class<?> loadedClass = findLoadedClass(name);\n                if (loadedClass == null) {\n                    loadedClass = findChildFirstClass(name);\n                }\n                if (resolve) {\n                    resolveClass(loadedClass);\n                }\n                return loadedClass;\n            }\n        }\n\n        private Class<?> findChildFirstClass(String name) throws ClassNotFoundException {\n            try {\n                return findClass(name);\n            } catch (ClassNotFoundException exception) {\n                return super.loadClass(name, false);\n            }\n        }\n\n        private static boolean isChildFirst(String name) {\n            return name.startsWith(\"jakarta.mail.\")\n                    || name.startsWith(MimeUtilTest.class.getName() + \"$Isolated\")\n                    || name.equals(SessionTest.TestStreamProvider.class.getName())\n                    || name.equals(SessionTest.TestLineOutputStream.class.getName());\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778511741172}]}
