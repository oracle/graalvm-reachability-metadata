  package jakarta_platform.jakarta_jakartaee_api;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.util.ArrayList;
  import java.util.Collections;
  import java.util.Iterator;
  import java.util.LinkedHashMap;
  
  import jakarta.faces.application.Application;
  import jakarta.faces.application.FacesMessage;
  import jakarta.faces.application.FacesMessage.Severity;
  import jakarta.faces.component.UIComponentBase;
  import jakarta.faces.component.UIViewRoot;
  import jakarta.faces.context.ExternalContext;
  import jakarta.faces.context.FacesContext;
  import jakarta.faces.context.ResponseStream;
  import jakarta.faces.context.ResponseWriter;
  import jakarta.faces.event.FacesListener;
  import jakarta.faces.lifecycle.Lifecycle;
  import jakarta.faces.render.RenderKit;
  
  import org.junit.jupiter.api.Test;
  
  public class UIComponentBaseTest {
      @Test
      void getFacesListenersReturnsTypedEmptyArrayWhenNoListenersHaveBeenAdded() {
          TestComponent component = new TestComponent();
  
          TestFacesListener[] listeners = component.facesListeners(TestFacesListener.class);
  
          assertThat(listeners).isEmpty();
          assertThat(listeners.getClass().getComponentType()).isEqualTo(TestFacesListener.class);
      }
  
      @Test
      void getFacesListenersReturnsTypedEmptyArrayAfterAllListenersAreRemoved() {
          TestComponent component = new TestComponent();
          TestFacesListener listener = new TestFacesListener();
          component.addListener(listener);
  
          component.removeListener(listener);
          TestFacesListener[] listeners = component.facesListeners(TestFacesListener.class);
  
          assertThat(listeners).isEmpty();
          assertThat(listeners.getClass().getComponentType()).isEqualTo(TestFacesListener.class);
      }
  
      @Test
      void getFacesListenersReturnsMatchingListenersInTypedArray() {
          TestComponent component = new TestComponent();
          TestFacesListener listener = new TestFacesListener();
          component.addListener(listener);
          component.addListener(new OtherFacesListener());
  
          TestFacesListener[] listeners = component.facesListeners(TestFacesListener.class);
  
          assertThat(listeners).containsExactly(listener);
          assertThat(listeners.getClass().getComponentType()).isEqualTo(TestFacesListener.class);
      }
  
      @Test
      void restoreAttachedCollectionStateInstantiatesOriginalCollectionType() {
          try (TestFacesContext context = TestFacesContext.activate()) {
              ArrayList<String> attachedState = new ArrayList<>();
              attachedState.add("first");
              attachedState.add("second");
  
              Object savedState = UIComponentBase.saveAttachedState(context, attachedState);
              Object restoredState = UIComponentBase.restoreAttachedState(context, savedState);
  
              assertThat(restoredState).isInstanceOf(ArrayList.class);
              assertThat((ArrayList<?>) restoredState).containsExactly("first", "second");
          }
      }
  
      @Test
      void restoreAttachedMapStateInstantiatesOriginalMapType() {
          try (TestFacesContext context = TestFacesContext.activate()) {
              LinkedHashMap<String, String> attachedState = new LinkedHashMap<>();
              attachedState.put("first", "one");
              attachedState.put("second", "two");
  
              Object savedState = UIComponentBase.saveAttachedState(context, attachedState);
              Object restoredState = UIComponentBase.restoreAttachedState(context, savedState);
  
              assertThat(restoredState).isInstanceOf(LinkedHashMap.class);
              assertThat(restoredState).isEqualTo(attachedState);
          }
      }
  
      public static class TestComponent extends UIComponentBase {
          @Override
          public String getFamily() {
              return "test";
          }
  
          void addListener(FacesListener listener) {
              addFacesListener(listener);
          }
  
          void removeListener(FacesListener listener) {
              removeFacesListener(listener);
          }
  
          @SuppressWarnings("unchecked")
          <T extends FacesListener> T[] facesListeners(Class<T> listenerType) {
              return (T[]) getFacesListeners(listenerType);
          }
      }
  
      public static class TestFacesListener implements FacesListener {
      }
  
      public static class OtherFacesListener implements FacesListener {
      }
  
