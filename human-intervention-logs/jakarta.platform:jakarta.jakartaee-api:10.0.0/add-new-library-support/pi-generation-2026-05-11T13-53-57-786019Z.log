t(restoredState).isInstanceOf(LinkedHashMap.class);\n            assertThat((Map<?, ?>) restoredState).containsExactlyEntriesOf(attachedState);\n        }\n    }\n\n    public static class TestComponent extends UIComponentBase {\n        @Override\n        public String getFamily() {\n            return \"test\";\n        }\n\n        void addListener(FacesListener listener) {\n            addFacesListener(listener);\n        }\n\n        void removeListener(FacesListener listener) {\n            removeFacesListener(listener);\n        }\n\n        @SuppressWarnings(\"unchecked\")\n        <T extends FacesListener> T[] facesListeners(Class<T> listenerType) {\n            return (T[]) getFacesListeners(listenerType);\n        }\n    }\n\n    public static class TestFacesListener implements FacesListener {\n    }\n\n    public static class OtherFacesListener implements FacesListener {\n    }\n\n    private static final class TestFacesContext extends FacesContext implements AutoCloseable {\n        static TestFacesContext activate() {\n            TestFacesContext context = new TestFacesContext();\n            setCurrentInstance(context);\n            return context;\n        }\n\n        @Override\n        public Application getApplication() {\n            return null;\n        }\n\n        @Override\n        public Iterator<String> getClientIdsWithMessages() {\n            return Collections.emptyIterator();\n        }\n\n        @Override\n        public Lifecycle getLifecycle() {\n            return null;\n        }\n\n        @Override\n        public ExternalContext getExternalContext() {\n            return null;\n        }\n\n        @Override\n        public Severity getMaximumSeverity() {\n            return null;\n        }\n\n        @Override\n        public Iterator<FacesMessage> getMessages() {\n            return Collections.emptyIterator();\n        }\n\n        @Override\n        public Iterator<FacesMessage> getMessages(String clientId) {\n          