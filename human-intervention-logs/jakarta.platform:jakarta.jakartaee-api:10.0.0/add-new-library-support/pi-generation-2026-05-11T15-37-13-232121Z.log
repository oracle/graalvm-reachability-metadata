  package jakarta_platform.jakarta_jakartaee_api;
  
  import static org.assertj.core.api.Assertions.assertThat;
  import static org.junit.jupiter.api.Assertions.assertThrows;
  
  import java.util.Collections;
  import java.util.HashMap;
  import java.util.Iterator;
  import java.util.Locale;
  import java.util.Map;
  
  import jakarta.faces.application.Application;
  import jakarta.faces.application.ApplicationWrapper;
  import jakarta.faces.application.FacesMessage;
  import jakarta.faces.application.FacesMessage.Severity;
  import jakarta.faces.component.UIComponentBase;
  import jakarta.faces.component.UIViewRoot;
  import jakarta.faces.context.ExternalContext;
  import jakarta.faces.context.FacesContext;
  import jakarta.faces.context.ResponseStream;
  import jakarta.faces.context.ResponseWriter;
  import jakarta.faces.convert.ConverterException;
  import jakarta.faces.convert.IntegerConverter;
  import jakarta.faces.convert.LongConverter;
  import jakarta.faces.lifecycle.Lifecycle;
  import jakarta.faces.render.RenderKit;
  
  import org.junit.jupiter.api.Test;
  
  public class ConvertMessageFactoryTest {
      private static final String APPLICATION_BUNDLE = "jakarta_platform.jakarta_jakartaee_api.MessageFactoryMessages";
  
      @Test
      void converterFailureUsesApplicationMessageBundleWhenConfigured() {
          try (TestFacesContext context = TestFacesContext.activate(new TestApplication(APPLICATION_BUNDLE))) {
              TestComponent component = new TestComponent("Count");
              IntegerConverter converter = new IntegerConverter();
  
              ConverterException exception = assertThrows(ConverterException.class,
                      () -> converter.getAsObject(context, component, "not-an-int"));
  
              assertThat(exception.getFacesMessage()).satisfies(message -> {
                  assertThat(message.getSummary()).isEqualTo("Application converter cannot parse not-an-int for Count");
                  assertThat(message.getSeverity()).isEqualTo(FacesMessage.SEVERITY_ERROR);
              });
          }
      }
  
      @Test
      void converterFailureFallsBackToFacesMessagesBundleWhenApplicationBundleIsNotConfigured() {
          try (TestFacesContext context = TestFacesContext.activate(new TestApplication(null))) {
              TestComponent component = new TestComponent("Quantity");
              IntegerConverter converter = new IntegerConverter();
  
              ConverterException exception = assertThrows(ConverterException.class,
                      () -> converter.getAsObject(context, component, "many"));
  
              assertThat(exception.getFacesMessage()).satisfies(message -> {
                  assertThat(message.getSummary()).isEqualTo("Faces converter cannot parse many for Quantity");
                  assertThat(message.getSeverity()).isEqualTo(FacesMessage.SEVERITY_ERROR);
              });
          }
      }
  
      @Test
      void converterFailureFallsBackToMojarraMessagesWhenFacesMessagesBundleDoesNotContainKey() {
          try (TestFacesContext context = TestFacesContext.activate(new TestApplication(null))) {
              TestComponent component = new TestComponent("Identifier");
              LongConverter converter = new LongConverter();
  
              ConverterException exception = assertThrows(ConverterException.class,
                      () -> converter.getAsObject(context, component, "not-a-long"));
  
              assertThat(exception.getFacesMessage()).satisfies(message -> {
                  assertThat(message.getSummary()).isEqualTo("Mojarra converter cannot parse not-a-long for Identifier");
                  assertThat(message.getSeverity()).isEqualTo(FacesMessage.SEVERITY_ERROR);
              });
          }
      }
  
      public static class TestComponent extends UIComponentBase {
          private final Map<String, Object> attributes = new HashMap<>();
  
          TestComponent(String label) {
              attributes.put("label", label);
          }
  
          @Override
          public Map<String, Object> getAttributes() {
              return attributes;
          }
  
          @Override
          public String getFamily() {
              return "test";
          }
      }
  
      private static final class TestApplication extends ApplicationWrapper {
          private final String messageBundle;
  
          private TestApplication(String messageBundle) {
              this.messageBundle = messageBundle;
          }
  
          @Override
          public String getMessageBundle() {
              return messageBundle;
          }
      }
  
      private static final class TestFacesContext extends FacesContext implements AutoCloseable {
          private final Application application;
          private final Locale originalDefaultLocale;
  
          private TestFacesContext(Application application, Locale originalDefaultLocale) {
              this.application = application;
              this.originalDefaultLocale = originalDefaultLocale;
          }
  
          static TestFacesContext activate(Application application) {
              Locale originalDefaultLocale = Locale.getDefault();
              Locale.setDefault(Locale.ROOT);
              TestFacesContext context = new TestFacesContext(application, originalDefaultLocale);
              setCurrentInstance(context);
              return context;
          }
  
          @Override
          public Application getApplication() {
              return application;
          }
  
          @Override
          public Iterator<String> getClientIdsWithMessages() {
              return Collections.emptyIterator();
          }
  
          @Override
          public Lifecycle getLifecycle() {
              return null;
          }
  
          @Override
          public ExternalContext getExternalContext() {
              return null;
          }
  
          @Override
          public Severity getMaximumSeverity() {
              return null;
          }
  
          @Override
  
