ass.getName(),\n                null);\n\n        assertThat(providerClass).isEqualTo(ConstructibleProvider.class);\n    }\n\n    @Test\n    void newInstanceCreatesProviderWithPublicNoArgConstructor() throws Throwable {\n        ConstructibleProvider.instances = 0;\n        MethodHandle newInstance = staticMethod(\n                \"newInstance\",\n                Object.class,\n                String.class,\n                String.class,\n                exceptionHandlerClass());\n\n        Object provider = withContextClassLoader(\n                null,\n                () -> newInstance.invokeWithArguments(\n                        ConstructibleProvider.class.getName(),\n                        ConstructibleProvider.class.getName(),\n                        null));\n\n        assertThat(provider).isInstanceOf(ConstructibleProvider.class);\n        assertThat(ConstructibleProvider.instances).isEqualTo(1);\n    }\n\n    @Test\n    @SuppressWarnings(\"removal\")\n    void safeLoadClassUsesClassForNameForDefaultImplementationWhenPackageAccessIsDenied() throws Throwable {\n        MethodHandle safeLoadClass = staticMethod(\n                \"safeLoadClass\",\n                Class.class,\n                String.class,\n                String.class,\n                ClassLoader.class);\n        SecurityManager previousSecurityManager = System.getSecurityManager();\n        PackageAccessDenyingSecurityManager securityManager =\n                new PackageAccessDenyingSecurityManager(ConstructibleProvider.class.getPackage().getName());\n        boolean securityManagerInstalled = installSecurityManagerIfSupported(securityManager);\n\n        try {\n            Class<?> providerClass = (Class<?>) safeLoadClass.invokeWithArguments(\n                    ConstructibleProvider.class.getName(),\n                    ConstructibleProvider.class.getName(),\n                    getClass().getClassLoader());\n\n            assertThat(providerClass).isEqualTo(ConstructibleProvider.class);\n            if (securityManagerInstalled) {\n                assertThat(securityManager.wasCheckPackageAccessCalled()).isTrue();\n            }\n        } finally {\n            if (securityManagerInstalled) {\n                System.setSecurityManager(previousSecurityManager);\n            }\n        }\n    }\n\n    private static MethodHandle staticMethod(\n            String methodName,\n            Class<?> returnType,\n            Class<?>... parameterTypes) throws ReflectiveOperationException {\n        Class<?> serviceLoaderUtilClass = Class.forName(SERVICE_LOADER_UTIL_CLASS);\n        MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(serviceLoaderUtilClass, MethodHandles.lookup());\n        return lookup.findStatic(serviceLoaderUtilClass, methodName, MethodType.methodType(returnType, parameterTypes));\n    }\n\n    private static Class<?> exceptionHandlerClass() throws ClassNotFoundException {\n        return Class.forName(SERVICE_LOADER_UTIL_CLASS + \"$ExceptionHandler\");\n    }\n\n    @SuppressWarnings(\"removal\")\n    private static boolean installSecurityManagerIfSupported(SecurityManager securityManager) {\n        try {\n            System.setSecurityManager(securityManager);\n            return System.getSecurityManager() == securityManager;\n        } catch (UnsupportedOperationException unsupportedOperationException) {\n            return false;\n        }\n    }\n\n    private static <T> T withContextClassLoader(ClassLoader classLoader, ThrowingSupplier<T> supplier) throws Throwable {\n        Thread currentThread = Thread.currentThread();\n        ClassLoader previousClassLoader = currentThread.getContextClassLoader();\n        currentThread.setContextClassLoader(classLoader);\n        try {\n            return supplier.get();\n        } finally {\n            currentThread.setContextClassLoader(previousClassLoader);\n        }\n    }\n\n    @FunctionalInterface\n    private interface ThrowingSupplier<T> {\n        T get() throws Throwable;\n    }\n\n    public static final class ConstructibleProvider {\n        private static int instances;\n\n        public ConstructibleProvider() {\n            instances++;\n        }\n    }\n\n    @SuppressWarnings(\"removal\")\n    private static final class PackageAccessDenyingSecurityManager extends SecurityManager {\n        private final String deniedPackageName;\n        private boolean checkPackageAccessCalled;\n\n        private PackageAccessDenyingSecurityManager(String deniedPackageName) {\n            this.deniedPackageName = deniedPackageName;\n        }\n\n        @Override\n        public void checkPermission(Permission permission) {\n        }\n\n        @Override\n        public void checkPackageAccess(String packageName) {\n            if (deniedPackageName.equals(packageName)) {\n                checkPackageAccessCalled = true;\n                throw new SecurityException(packageName);\n            }\n        }\n\n        private boolean wasCheckPackageAccessCalled() {\n            return checkPackageAccessCalled;\n        }\n    }\n}\n"}
