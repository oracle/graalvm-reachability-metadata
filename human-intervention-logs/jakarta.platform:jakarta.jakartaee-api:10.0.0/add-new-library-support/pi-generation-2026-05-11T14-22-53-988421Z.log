      51	    static <T> T lookupUsingOSGiServiceLoader(String factoryId, Logger logger) {
      52	
      53	        try {
      54	            // Use reflection to avoid having any dependency on ServiceLoader class
      55	            @SuppressWarnings("unchecked")
      56	            Class<? extends T> serviceClass = (Class<? extends T>) Class.forName(factoryId);
      57	            Class<?> target = Class.forName(OSGI_SERVICE_LOADER_CLASS_NAME);
      58	            Method m = target.getMethod(OSGI_SERVICE_LOADER_METHOD_NAME, Class.class);
      59	            @SuppressWarnings("unchecked")
      60	            Iterator<? extends T> iter = ((Iterable<? extends T>) m.invoke(null, serviceClass)).iterator();
      61	            if (iter.hasNext()) {
      62	                T next = iter.next();
      63	                logger.log(Level.FINE, "Found implementation using OSGi facility; returning object [{0}].",
      64	                        next.getClass().getName());
      65	                return next;
      66	            } else {
      67	                return null;
      68	            }
      69	        } catch (IllegalAccessException |
      70	                InvocationTargetException |
      71	                ClassNotFoundException |
      72	                NoSuchMethodException ex) {
      73	
      74	            logger.log(Level.FINE, "Unable to find from OSGi: [" + factoryId + "]", ex);
      75	            return null;
      76	        }
      77	    }
