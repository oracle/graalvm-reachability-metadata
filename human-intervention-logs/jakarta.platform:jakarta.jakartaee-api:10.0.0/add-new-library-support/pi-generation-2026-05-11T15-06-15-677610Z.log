[tool-call] delta {"path":"tests/src/jakarta.platform/jakarta.jakartaee-api/10.0.0/src/test/java/jakarta_platform/jakarta_jakartaee_api/SoapServiceLoaderUtilTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage jakarta_platform.jakarta_jakartaee_api;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.lang.invoke.MethodHandle;\nimport java.lang.invoke.MethodHandles;\nimport java.lang.invoke.MethodType;\n\nimport org.junit.jupiter.api.Test;\n\npublic class SoapServiceLoaderUtilTest {\n    private static final String SERVICE_LOADER_UTIL_CLASS = \"jakarta.xml.soap.ServiceLoaderUtil\";\n\n    @Test\n    void nullSafeLoadClassUsesClassForNameWhenClassLoaderIsNull() throws Throwable {\n        MethodHandle nullSafeLoadClass = staticMethod(\n                \"nullSafeLoadClass\",\n                Class.class,\n                String.class,\n                ClassLoader.class);\n\n        Class<?> providerClass = (Class<?>) nullSafeLoadClass.invokeWithArguments(\n                ConstructibleSoapProvider.class.getName(),\n                null);\n\n        assertThat(providerClass).isEqualTo(ConstructibleSoapProvider.class);\n    }\n\n    @Test\n    void nullSafeLoadClassUsesProvidedClassLoaderWhenPresent() throws Throwable {\n        MethodHandle nullSafeLoadClass = staticMethod(\n                \"nullSafeLoadClass\",\n                Class.class,\n                String.class,\n                ClassLoader.class);\n\n        Class<?> providerClass = (Class<?>) nullSafeLoadClass.invokeWithArguments(\n                ConstructibleSoapProvider.class.getName(),\n                getClass().getClassLoader());\n\n        assertThat(providerClass).isEqualTo(ConstructibleSoapProvider.class);\n    }\n\n    @Test\n    void newInstanceCreatesProviderWithPublicNoArgConstructor() throws Throwable {\n        ConstructibleSoapProvider.instances = 0;\n        MethodHandle newInstance = staticMethod(\n                \"newInstance\",\n                Object.class,\n                String.class,\n                String.class,\n                ClassLoader.class,\n                exceptionHandlerClass());\n\n        Object provider = newInstance.invokeWithArguments(\n                ConstructibleSoapProvider.class.getName(),\n                ConstructibleSoapProvider.class.getName(),\n                getClass().getClassLoader(),\n                null);\n\n        assertThat(provider).isInstanceOf(ConstructibleSoapProvider.class);\n        assertThat(ConstructibleSoapProvider.instances).isEqualTo(1);\n    }\n\n    private static MethodHandle staticMethod(\n            String methodName,\n            Class<?> returnType,\n            Class<?>... parameterTypes) throws ReflectiveOperationException {\n        Class<?> serviceLoaderUtilClass = Class.forName(SERVICE_LOADER_UTIL_CLASS);\n        MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(serviceLoaderUtilClass, MethodHandles.lookup());\n        return lookup.findStatic(serviceLoaderUtilClass, methodName, MethodType.methodType(returnType, parameterTypes));\n    }\n\n    private static Class<?> exceptionHandlerClass() throws ClassNotFoundException {\n        return Class.forName(SERVICE_LOADER_UTIL_CLASS + \"$ExceptionHandler\");\n    }\n\n    public static final class ConstructibleSoapProvider {\n        private static int instances;\n\n        public ConstructibleSoapProvider() {\n            instances++;\n        }\n    }\n}\n"}
