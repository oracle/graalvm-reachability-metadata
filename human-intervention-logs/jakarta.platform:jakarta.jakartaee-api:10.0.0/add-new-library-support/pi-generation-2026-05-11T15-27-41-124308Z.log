ort java.util.Currency;\nimport java.util.Iterator;\nimport java.util.Locale;\n\nimport jakarta.faces.application.Application;\nimport jakarta.faces.application.FacesMessage;\nimport jakarta.faces.application.FacesMessage.Severity;\nimport jakarta.faces.component.UIComponentBase;\nimport jakarta.faces.component.UIViewRoot;\nimport jakarta.faces.context.ExternalContext;\nimport jakarta.faces.context.FacesContext;\nimport jakarta.faces.context.ResponseStream;\nimport jakarta.faces.context.ResponseWriter;\nimport jakarta.faces.convert.NumberConverter;\nimport jakarta.faces.lifecycle.Lifecycle;\nimport jakarta.faces.render.RenderKit;\n\nimport org.junit.jupiter.api.Test;\n\npublic class NumberConverterTest {\n    @Test\n    void getAsStringAppliesCurrencyCodeToCurrencyFormatter() {\n        try (TestFacesContext context = TestFacesContext.activate()) {\n            NumberConverter converter = new NumberConverter();\n            converter.setLocale(Locale.US);\n            converter.setType(\"currency\");\n            converter.setCurrencyCode(\"EUR\");\n\n            String formattedValue = converter.getAsString(context, new TestComponent(), BigDecimal.valueOf(12.34));\n\n            NumberFormat expectedFormat = NumberFormat.getCurrencyInstance(Locale.US);\n            expectedFormat.setCurrency(Currency.getInstance(\"EUR\"));\n            assertThat(formattedValue).isEqualTo(expectedFormat.format(BigDecimal.valueOf(12.34)));\n            assertThat(formattedValue).doesNotContain(\"$\");\n        }\n    }\n\n    public static class TestComponent extends UIComponentBase {\n        @Override\n        public String getFamily() {\n            return \"test\";\n        }\n    }\n\n    private static final class TestFacesContext extends FacesContext implements AutoCloseable {\n        static TestFacesContext activate() {\n            TestFacesContext context = new TestFacesContext();\n            setCurrentInstance(context);\n            return context;\n        }\n\n        @Override\n        public Application getApplication() {\n            return null;\n        }\n\n        @Override\n        public Iterator<String> getClientIdsWithMessages() {\n            return Collections.emptyIterator();\n        }\n\n        @Override\n        public Lifecycle getLifecycle() {\n            return null;\n        }\n\n        @Override\n        public ExternalContext getExternalContext() {\n            return null;\n        }\n\n        @Override\n        public Severity getMaximumSeverity() {\n            return null;\n        }\n\n        @Override\n        public Iterator<FacesMessage> getMessages() {\n            return Collections.emptyIterator();\n        }\n\n        @Override\n        public Iterator<FacesMessage> getMessages(String clientId) {\n            return Collections.emptyIterator();\n        }\n\n        @Override\n        public RenderKit getRenderKit() {\n            return null;\n        }\n\n        @Override\n        public boolean getRenderResponse() {\n            return false;\n        }\n\n        @Override\n        public boolean getResponseComplete() {\n            return false;\n        }\n\n        @Override\n        public ResponseStream getResponseStream() {\n            return null;\n        }\n\n        @Override\n        public void setResponseStream(ResponseStream responseStream) {\n            throw new UnsupportedOperationException(\"Response streams are not used by this test\");\n        }\n\n        @Override\n        public ResponseWriter getResponseWriter() {\n            return null;\n        }\n\n        @Override\n        public void setResponseWriter(ResponseWriter responseWriter) {\n            throw new UnsupportedOperationException(\"Response writers are not used by this test\");\n        }\n\n        @Override\n        public UIViewRoot getViewRoot() {\n            return null;\n        }\n\n        @Override\n        public void setViewRoot(UIViewRoot root) {\n            throw new Unsupported