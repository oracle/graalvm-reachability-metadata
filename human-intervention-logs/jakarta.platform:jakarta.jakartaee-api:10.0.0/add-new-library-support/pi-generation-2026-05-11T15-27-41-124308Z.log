   setRendererType(null);\n        }\n\n        @Override\n        public void validateValue(FacesContext context, Object newValue) {\n            super.validateValue(context, newValue);\n        }\n    }\n\n    public static class TestSelectOne extends UISelectOne {\n        TestSelectOne() {\n            setRendererType(null);\n        }\n\n        @Override\n        public void validateValue(FacesContext context, Object value) {\n            super.validateValue(context, value);\n        }\n    }\n\n    private static final class TestApplication extends ApplicationWrapper {\n        private final String messageBundle;\n\n        private TestApplication(String messageBundle) {\n            this.messageBundle = messageBundle;\n        }\n\n        @Override\n        public String getMessageBundle() {\n            return messageBundle;\n        }\n\n        @Override\n        public void publishEvent(FacesContext context, Class<? extends SystemEvent> systemEventClass, Object source) {\n        }\n    }\n\n    private static final class TestFacesContext extends FacesContext implements AutoCloseable {\n        private final Application application;\n        private final List<FacesMessage> messages = new ArrayList<>();\n        private final UIViewRoot viewRoot = new UIViewRoot();\n\n        private TestFacesContext(Application application) {\n            this.application = application;\n            viewRoot.setLocale(Locale.US);\n        }\n\n        static TestFacesContext activate(Application application) {\n            TestFacesContext context = new TestFacesContext(application);\n            setCurrentInstance(context);\n            return context;\n        }\n\n        List<FacesMessage> messages() {\n            return messages;\n        }\n\n        @Override\n        public Application getApplication() {\n            return application;\n        }\n\n        @Override\n        public Iterator<String> getClientIdsWithMessages() {\n            return Collections.emptyIterator();\n        }\n\n        @Override\n        public Lifecycle getLifecycle() {\n            return null;\n        }\n\n        @Override\n        public ExternalContext getExternalContext() {\n            return null;\n        }\n\n        @Override\n        public Severity getMaximumSeverity() {\n            return messages.stream()\n                    .map(FacesMessage::getSeverity)\n                    .findFirst()\n                    .orElse(null);\n        }\n\n        @Override\n        public Iterator<FacesMessage> getMessages() {\n            return messages.iterator();\n        }\n\n        @Override\n        public Iterator<FacesMessage> getMessages(String clientId) {\n            return messages.iterator();\n        }\n\n        @Override\n        public RenderKit getRenderKit() {\n            return null;\n        }\n\n        @Override\n        public boolean getRenderResponse() {\n            return false;\n        }\n\n        @Override\n        public boolean getResponseComplete() {\n            return false;\n        }\n\n        @Override\n        public ResponseStream getResponseStream() {\n            return null;\n        }\n\n        @Override\n        public void setResponseStream(ResponseStream responseStream) {\n            throw new UnsupportedOperationException(\"Response streams are not used by this test\");\n        }\n\n        @Override\n        public ResponseWriter getResponseWriter() {\n            return null;\n        }\n\n        @Override\n        public void setResponseWriter(ResponseWriter responseWriter) {\n            throw new UnsupportedOperationException(\"Response writers are not used by this test\");\n        }\n\n        @Override\n        public UIViewRoot getViewRoot() {\n            return viewRoot;\n        }\n\n        @Override\n        public void setViewRoot(UIViewRoot root) {\n            throw new UnsupportedOperationException(\"View roots are fixed by this test\");\n        }\n\n        @Over