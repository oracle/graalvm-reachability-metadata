  package jakarta_platform.jakarta_jakartaee_api;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.util.ArrayList;
  import java.util.Collections;
  import java.util.Iterator;
  import java.util.List;
  import java.util.Locale;
  
  import jakarta.faces.application.Application;
  import jakarta.faces.application.ApplicationWrapper;
  import jakarta.faces.application.FacesMessage;
  import jakarta.faces.application.FacesMessage.Severity;
  import jakarta.faces.component.UIInput;
  import jakarta.faces.component.UISelectOne;
  import jakarta.faces.component.UIViewRoot;
  import jakarta.faces.context.ExternalContext;
  import jakarta.faces.context.FacesContext;
  import jakarta.faces.context.ResponseStream;
  import jakarta.faces.context.ResponseWriter;
  import jakarta.faces.lifecycle.Lifecycle;
  import jakarta.faces.render.RenderKit;
  
  import org.junit.jupiter.api.Test;
  
  public class MessageFactoryTest {
      private static final String APPLICATION_BUNDLE = "jakarta_platform.jakarta_jakartaee_api.MessageFactoryMessages";
  
      @Test
      void requiredInputUsesApplicationMessageBundleWhenConfigured() {
          try (TestFacesContext context = TestFacesContext.activate(new TestApplication(APPLICATION_BUNDLE))) {
              TestInput input = new TestInput();
              input.setId("customRequired");
              input.setRequired(true);
              input.getAttributes().put("label", "Custom Label");
  
              input.validateValue(context, "");
  
              assertThat(context.messages()).singleElement().satisfies(message -> {
                  assertThat(message.getSummary()).isEqualTo("Application bundle says Custom Label is required");
                  assertThat(message.getSeverity()).isEqualTo(FacesMessage.SEVERITY_ERROR);
              });
              assertThat(input.isValid()).isFalse();
          }
      }
  
      @Test
      void requiredInputFallsBackToFacesMessagesBundleWhenApplicationBundleIsNotConfigured() {
          try (TestFacesContext context = TestFacesContext.activate(new TestApplication(null))) {
              TestInput input = new TestInput();
              input.setId("standardRequired");
              input.setRequired(true);
              input.getAttributes().put("label", "Standard Label");
  
              input.validateValue(context, "");
  
              assertThat(context.messages()).singleElement().satisfies(message -> {
                  assertThat(message.getSummary()).isEqualTo("Faces bundle says Standard Label is required");
                  assertThat(message.getSeverity()).isEqualTo(FacesMessage.SEVERITY_ERROR);
              });
              assertThat(input.isValid()).isFalse();
          }
      }
  
      @Test
      void selectOneFallsBackToMojarraMessagesWhenFacesMessagesBundleDoesNotContainKey() {
          try (TestFacesContext context = TestFacesContext.activate(new TestApplication(null))) {
              TestSelectOne select = new TestSelectOne();
              select.setId("invalidSelection");
              select.getAttributes().put("label", "Selection Label");
  
              select.validateValue(context, "missing-option");
  
              assertThat(context.messages()).singleElement().satisfies(message -> {
                  assertThat(message.getSummary()).isEqualTo("Mojarra bundle says Selection Label is not valid");
                  assertThat(message.getSeverity()).isEqualTo(FacesMessage.SEVERITY_ERROR);
              });
              assertThat(select.isValid()).isFalse();
          }
      }
  
      public static class TestInput extends UIInput {
          TestInput() {
              setRendererType(null);
          }
  
          @Override
          public void validateValue(FacesContext context, Object newValue) {
              super.validateValue(context, newValue);
          }
      }
  
      public static class TestSelectOne extends UISelectOne {
          TestSelectOne() {
              setRendererType(null);
          }
  
          @Override
          public void validateValue(FacesContext context, Object value) {
              super.validateValue(context, value);
          }
      }
  
      private static final class TestApplication extends ApplicationWrapper {
          private final String messageBundle;
  
          private TestApplication(String messageBundle) {
              this.messageBundle = messageBundle;
          }
  
          @Override
          public String getMessageBundle() {
              return messageBundle;
          }
      }
  
      private static final class TestFacesContext extends FacesContext implements AutoCloseable {
          private final Application application;
          private final List<FacesMessage> messages = new ArrayList<>();
          private final Locale originalDefaultLocale;
  
          private TestFacesContext(Application application, Locale originalDefaultLocale) {
              this.application = application;
              this.originalDefaultLocale = originalDefaultLocale;
          }
  
          static TestFacesContext activate(Application application) {
              Locale originalDefaultLocale = Locale.getDefault();
              Locale.setDefault(Locale.ROOT);
              TestFacesContext context = new TestFacesContext(application, originalDefaultLocale);
              setCurrentInstance(context);
              return context;
          }
  
          List<FacesMessage> messages() {
              return messages;
          }
  
          @Override
          public Application getApplication() {
              return application;
          }
  
          @Override
          public Iterator<String> getClientIdsWithMessages() {
              return Collections.emptyIterator();
          }
  
          @Override
          public Lifecycle getLifecycle() {
              return null;
          }
  
          @Override
          public ExternalContext getExternalContext() {
              return null;
          }
  
          @Override
          public Severity getMaximumSeverity() {
              return messages.stream()
                      .map(FacesMessage::getSeverity)
                      .findFirst()
                      .orElse(null);
          }
  
          @Override
          public Iterator<FacesMessage> getMessages() {
              return messages.iterator();
          }
  
          @Override
          public Iterator<FacesMessage> getMessages(String clientId) {
              return messages.iterator();
          }
  
          @Override
          public RenderKit getRenderKit() {
              return null;
          }
  
          @Override
          public boolean getRenderResponse() {
              return false;
          }
  
          @Override
          public boolean getResponseComplete() {
              return false;
          }
  
          @Override
          public ResponseStream getResponseStream() {
              return null;
          }
  
          @Override
          public void setResponseStream(ResponseStream responseStream) {
              throw new UnsupportedOperationException("Response streams are not used by this test");
          }
  
          @Override
          public ResponseWriter getResponseWriter() {
              return null;
          }
  
          @Override
          public void setResponseWriter(ResponseWriter responseWriter) {
              throw new UnsupportedOperationException("Response writers are not used by this test");
          }
  
          @Override
          public UIViewRoot getViewRoot() {
              return null;
          }
  
          @Override
          public void setViewRoot(UIViewRoot root) {
              throw new UnsupportedOperationException("View roots are not used by this test");
          }
  
          @Override
          public void addMessage(String clientId, FacesMessage message) {
              messages.add(message);
          }
  
          @Override
          public void release() {
              setCurrentInstance(null);
              Locale.setDefault(originalDefaultLocale);
          }
  
          @Override
  
