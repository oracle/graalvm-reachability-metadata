ualTo(\"detail\");\n        assertThat(restoredMessage.isRendered()).isTrue();\n    }\n\n    private static byte[] serialize(FacesMessage message) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(message);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static FacesMessage deserialize(byte[] value) throws Exception {\n        try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(value))) {\n            return (FacesMessage) input.readObject();\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1343, "output": 665, "cacheRead": 12800, "cacheWrite": 0, "totalTokens": 14808, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778506373025, "responseId": "resp_075b9d5d62f6a4f2016a01da85600081a3af7e85b92cb5a89d"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_yaUqiOnd5KcR79TyVJJHs1Xx|fc_075b9d5d62f6a4f2016a01da8a8e6881a3acb99193776206ae", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1700 bytes to tests/src/jakarta.platform/jakarta.jakartaee-api/10.0.0/src/test/java/jakarta_platform/jakarta_jakartaee_api/FacesMessageTest.java"}], "isError": false, "timestamp": 1778506380821}]}
