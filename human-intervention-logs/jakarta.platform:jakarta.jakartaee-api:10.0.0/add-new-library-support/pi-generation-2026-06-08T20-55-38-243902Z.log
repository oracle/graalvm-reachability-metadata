  public class UIComponentBaseInnerAttributesMapTest {
      @Test
      void invokesBeanPropertyAccessorsThroughAttributesMap() {
          TestFacesContext context = new TestFacesContext();
          TestFacesContext.setCurrent(context);
          try {
              AttributeComponent component = new AttributeComponent();
              Map<String, Object> attributes = component.getAttributes();
  
              assertThat(attributes.get("label")).isEqualTo("initial");
              assertThat(attributes.put("label", "updated")).isEqualTo("initial");
  
              assertThat(component.getLabel()).isEqualTo("updated");
              assertThat(attributes.get("label")).isEqualTo("updated");
          } finally {
              context.release();
          }
      }
  
      @Test
      void serializesAndRestoresAttributesMapWithSavedComponentState() throws Exception {
          TestFacesContext context = new TestFacesContext();
          TestFacesContext.setCurrent(context);
          try {
              AttributeComponent component = new AttributeComponent();
              Map<String, Object> attributes = component.getAttributes();
              attributes.put("dynamicAttribute", "dynamic-value");
  
              byte[] serializedAttributes = serialize((Serializable) attributes);
              @SuppressWarnings("unchecked")
              Map<String, Object> restoredAttributes = (Map<String, Object>) deserialize(serializedAttributes);
  
              assertThat(restoredAttributes.get("dynamicAttribute")).isEqualTo("dynamic-value");
          } finally {
              context.release();
          }
      }
  
      private static byte[] serialize(Serializable serializable) throws Exception {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {
              output.writeObject(serializable);
          }
          return bytes.toByteArray();
      }
  
      private static Object deserialize(byte[] bytes) throws Exception {
          try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(bytes))) {
              return input.readObject();
          }
      }
  
      public static class AttributeComponent extends UIComponentBase {
          private String label = "initial";
  
          public AttributeComponent() {
          }
  
          @Override
          public String getFamily() {
              return "test";
          }
  
          public String getLabel() {
              return label;
          }
  
          public void setLabel(String label) {
              this.label = label;
          }
      }
  
