  package jakarta_platform.jakarta_jakartaee_api;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  
  import jakarta.faces.application.FacesMessage;
  
  import org.junit.jupiter.api.Test;
  
  public class FacesMessageTest {
      @Test
      void serializesAndRestoresMessageState() throws Exception {
          FacesMessage message = new FacesMessage(FacesMessage.SEVERITY_ERROR, "summary", "detail");
          message.rendered();
  
          FacesMessage restoredMessage = deserialize(serialize(message));
  
          assertThat(restoredMessage.getSeverity()).isSameAs(FacesMessage.SEVERITY_ERROR);
          assertThat(restoredMessage.getSummary()).isEqualTo("summary");
          assertThat(restoredMessage.getDetail()).isEqualTo("detail");
          assertThat(restoredMessage.isRendered()).isTrue();
      }
  
      private static byte[] serialize(FacesMessage message) throws Exception {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {
              output.writeObject(message);
          }
          return bytes.toByteArray();
      }
  
