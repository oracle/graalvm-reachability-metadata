  public class UIComponentBaseInnerAttributesMapTest {
      @Test
      void componentBeanPropertiesAreReadAndWrittenThroughAttributesMap() {
          try (TestFacesContext context = TestFacesContext.activate()) {
              TestComponent component = new TestComponent();
              Map<String, Object> attributes = component.getAttributes();
  
              Object previousValue = attributes.put("id", "componentId");
  
              assertThat(context).isSameAs(FacesContext.getCurrentInstance());
              assertThat(previousValue).isNull();
              assertThat(component.getId()).isEqualTo("componentId");
              assertThat(attributes.get("id")).isEqualTo("componentId");
          }
      }
  
      @Test
      void attributesMapSerializesAndRestoresItsOwningComponent() throws Exception {
          try (TestFacesContext context = TestFacesContext.activate()) {
              TestComponent component = new TestComponent();
              Map<String, Object> attributes = component.getAttributes();
              attributes.put("id", "serializedComponent");
  
              byte[] serializedAttributes = serialize(attributes);
              Object restoredAttributes = deserialize(serializedAttributes);
  
              assertThat(context).isSameAs(FacesContext.getCurrentInstance());
              assertThat(restoredAttributes).isInstanceOf(Map.class);
              assertThat((Map<?, ?>) restoredAttributes).isEmpty();
          }
      }
  
      private static byte[] serialize(Object value) throws Exception {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {
              output.writeObject(value);
          }
          return bytes.toByteArray();
      }
  
      private static Object deserialize(byte[] value) throws Exception {
          try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(value))) {
              return input.readObject();
          }
      }
  
