  		}
  		if (getSupertype().isAspect()) {
  			decps.addAll(Arrays.asList(getSupertype().getDeclarePrecedence()));
  		}
  		DeclarePrecedence[] ret = new DeclarePrecedence[decps.size()];
  		decps.toArray(ret);
  		return ret;
  	}
  
