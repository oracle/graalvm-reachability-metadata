  						throw new IllegalStateException("Can't find field get dispatch method for " + m.getName());
  					}
  				}
  			}
  			addAnnotationStyleITDFields(itdfs, true);
  			this.itdFields = new InterTypeFieldDeclaration[itdfs.size()];
