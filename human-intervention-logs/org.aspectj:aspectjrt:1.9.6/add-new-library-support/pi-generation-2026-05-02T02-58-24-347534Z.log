  						InterTypeFieldDeclaration itdf = new InterTypeFieldDeclarationImpl(
  								this,ann.targetType(),ann.modifiers(),ann.name(),
  								AjTypeSystem.getAjType(dispatch.getReturnType()),
  								dispatch.getGenericReturnType());
