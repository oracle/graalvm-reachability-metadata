  	public static Type[] commaSeparatedListToTypeArray(String typeNames, Class classScope) 
  	throws ClassNotFoundException {
  		StringTokenizer strTok = new StringTokenizer(typeNames,",");
  		Type[] ret = new Type[strTok.countTokens()];
  		int index = 0;
