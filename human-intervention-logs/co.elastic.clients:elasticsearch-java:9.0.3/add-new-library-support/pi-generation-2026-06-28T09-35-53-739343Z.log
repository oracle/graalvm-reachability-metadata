[tool-call] delta {"path":"tests/src/co.elastic.clients/elasticsearch-java/9.0.3/src/test/java/co_elastic_clients/elasticsearch_java/JsonpMapperBaseTest.java","edits":[{"oldText":"import co.elastic.clients.elasticsearch.core.InfoResponse;\nimport co.elastic.clients.json.JsonpDeserializer;\nimport co.elastic.clients.json.JsonpMapperBase;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class JsonpMapperBaseTest {\n    @Test\n    void findsGeneratedDeserializerFromJsonpDeserializableAnnotation() {\n        JsonpDeserializer<InfoResponse> deserializer = JsonpMapperBase.findDeserializer(InfoResponse.class);\n\n        assertThat(deserializer).isSameAs(InfoResponse._DESERIALIZER);\n    }\n}\n","newText":"import co.elastic.clients.elasticsearch.core.InfoResponse;\nimport co.elastic.clients.json.JsonpMapper;\nimport co.elastic.clients.json.SimpleJsonpMapper;\nimport jakarta.json.stream.JsonParser;\nimport org.junit.jupiter.api.Test;\n\nimport java.io.StringReader;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class JsonpMapperBaseTest {\n    @Test\n    void deserializesGeneratedApiTypeUsingAnnotationDeserializer() {\n        String json = \"\"\"\n            {\n              \"cluster_name\": \"integration-cluster\",\n              \"cluster_uuid\": \"cluster-uuid\",\n              \"name\": \"node-1\",\n              \"tagline\": \"You Know, for Search\",\n              \"version\": {\n                \"build_date\": \"2025-01-01T00:00:00Z\",\n                \"build_flavor\": \"default\",\n                \"build_hash\": \"abc123\",\n                \"build_snapshot\": false,\n                \"build_type\": \"docker\",\n                \"lucene_version\": \"10.0.0\",\n                \"minimum_index_compatibility_version\": \"8.0.0\",\n                \"minimum_wire_compatibility_version\": \"8.0.0\",\n                \"number\": \"9.0.0\"\n              }\n            }\n            \"\"\";\n        JsonpMapper mapper = new SimpleJsonpMapper();\n\n        try (JsonParser parser = mapper.jsonProvider().createParser(new StringReader(json))) {\n            InfoResponse response = mapper.deserialize(parser, InfoResponse.class);\n\n            assertThat(response.clusterName()).isEqualTo(\"integration-cluster\");\n            assertThat(response.version().number()).isEqualTo(\"9.0.0\");\n        }\n    }\n}\n"}]}
