);\n        assertThat(LanguageRuntimeVersions.scalaVersion()).isEqualTo(scalaVersion);\n        assertThat(LanguageRuntimeVersions.getRuntimeMetadata())\n            .contains(\",kt=\" + kotlinVersion)\n            .contains(\",sc=\" + scalaVersion);\n    }\n\n    private static String keepMajorMinor(String version) {\n        int firstDot = version.indexOf('.');\n        int secondDot = version.indexOf('.', firstDot + 1);\n        if (secondDot < 0) {\n            return version;\n        }\n        return version.substring(0, secondDot);\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 1551, "output": 879, "cacheRead": 17408, "cacheWrite": 0, "totalTokens": 19838, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1782638830037, "responseId": "resp_0d16857c4f9e7773016a40e8eea5cc819691a98ef487d73934"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_ebM6hLN7rFMqtJ8lAvNfQxCN|fc_0d16857c4f9e7773016a40e8f763288196bcfe859d75a0da73", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1361 bytes to tests/src/co.elastic.clients/elasticsearch-java/9.0.3/src/test/java/co_elastic_clients/elasticsearch_java/LanguageRuntimeVersionsTest.java"}], "isError": false, "timestamp": 1782638840346}]}
