      public Rest5ClientBuilder setHttpClient(CloseableHttpAsyncClient httpAsyncClient) {
          Objects.requireNonNull(httpAsyncClient, "custom rest client must not be null");
          this.httpClient = httpAsyncClient;
          return this;
      }
  
      /**
