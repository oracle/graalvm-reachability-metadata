      private def evalCaseDefPattern(m: Term, pattern: Tree, scrutinee: Term,
                                     bindings: Map[Symbol, Term]): Option[Map[Symbol, Term]] =
        pattern match
          case TypedOrTest(v, tpt) =>
            evalCaseDefPattern(m, v, scrutinee, bindings).flatMap { newBinding =>
