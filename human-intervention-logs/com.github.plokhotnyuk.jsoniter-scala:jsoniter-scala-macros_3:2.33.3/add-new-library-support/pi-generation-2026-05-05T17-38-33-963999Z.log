          caseDef.guard match
            case Some(guard) =>
              if (evalCondition(guard, newBinding)) Some(evalTerm(caseDef.rhs, newBinding, optDefault))
              else None
            case None =>
              Some(evalTerm(caseDef.rhs, newBinding, optDefault))
