se.isInstanceOf[Error] =>\n        val error: Error = ex.getCause.asInstanceOf[Error]\n        if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n          throw error\n        }\n    }\n  }\n}\n\nobject CompileTimeEvalInnerQuoteScopeInnerHelperObjectJvmReflectionMethodCallTest {\n  def compileMacroSupportAndUsage(): Unit = {\n    val rootDir: Path = Files.createTempDirectory(\"jsoniter-helper-object-call-\")\n    try {\n      val outputDir: Path = Files.createDirectory(rootDir.resolve(\"classes\"))\n      val supportSource: Path = rootDir.resolve(\"HelperObjectJvmReflectionMethodCallMacro.scala\")\n      val usageSource: Path = rootDir.resolve(\"HelperObjectJvmReflectionMethodCallUsage.scala\")\n\n      Files.write(\n        supportSource,\n        \"\"\"\n          |package com.github.plokhotnyuk.jsoniter_scala.macros\n          |\n          |import scala.quoted.*\n          |\n          |final class HelperObjectJvmReflectionMethodCallTarget {\n          |  def combine(owner: HelperObjectJvmReflectionMethodCallTarget, suffix: String): String =\n          |    \"helper_\" + suffix\n          |}\n          |\n          |object HelperObjectJvmReflectionMethodCallMacro {\n          |  inline def mappedName: String = ${ mappedNameImpl }\n          |\n          |  def mappedNameImpl(using Quotes): Expr[String] = {\n          |    val scope = new CompileTimeEval.QuoteScope()\n          |    val target = new HelperObjectJvmReflectionMethodCallTarget()\n          |    val call = new scope.HelperObjectJvmReflectionMethodCall(\n          |      target,\n          |      target,\n          |      \"combine\",\n          |      Array(\"value\".asInstanceOf[AnyRef])\n          |    )\n          |    Expr(call.process().asInstanceOf[String])\n          |  }\n          |}\n          |\"\"\".stripMargin.getBytes(UTF_8)\n      )\n      invokeScalaCompiler(\n        Array(\n          \"-classpath\",\n          runtimeClasspath,\n          \"-d\",\n          outputDir.toStr