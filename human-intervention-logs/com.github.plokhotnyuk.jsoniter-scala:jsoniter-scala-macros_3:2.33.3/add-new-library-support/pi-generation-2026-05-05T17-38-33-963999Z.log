  import scala.collection.mutable.ArrayBuffer
  
  class CompileTimeEvalInnerQuoteScopeInnerHelperObjectJvmReflectionMethodCallTest {
    import CompileTimeEvalInnerQuoteScopeInnerHelperObjectJvmReflectionMethodCallTest.*
  
    @Test
    def compilesMacroThatInvokesHelperObjectReflectionMethodCall(): Unit = {
      try {
        compileMacroSupportAndUsage()
      } catch {
        case error: Error =>
          if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
            throw error
          }
        case ex: InvocationTargetException if ex.getCause.isInstanceOf[Error] =>
          val error: Error = ex.getCause.asInstanceOf[Error]
          if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
            throw error
          }
      }
    }
  }
  
  object CompileTimeEvalInnerQuoteScopeInnerHelperObjectJvmReflectionMethodCallTest {
    def compileMacroSupportAndUsage(): Unit = {
      val rootDir: Path = Files.createTempDirectory("jsoniter-helper-object-call-")
      try {
        val outputDir: Path = Files.createDirectory(rootDir.resolve("classes"))
        val supportSource: Path = rootDir.resolve("HelperObjectJvmReflectionMethodCallMacro.scala")
        val usageSource: Path = rootDir.resolve("HelperObjectJvmReflectionMethodCallUsage.scala")
  
        Files.write(
          supportSource,
          """
            |package com.github.plokhotnyuk.jsoniter_scala.macros
            |
            |import scala.quoted.*
            |
            |final class HelperObjectJvmReflectionMethodCallTarget {
            |  def combine(owner: HelperObjectJvmReflectionMethodCallTarget, suffix: String): String =
            |    "helper_" + suffix
            |}
            |
            |object HelperObjectJvmReflectionMethodCallMacro {
            |  inline def mappedName: String = ${ mappedNameImpl }
            |
            |  def mappedNameImpl(using Quotes): Expr[String] = {
            |    val scope = new CompileTimeEval.QuoteScope()
            |    val target = new HelperObjectJvmReflectionMethodCallTarget()
            |    val call = new scope.HelperObjectJvmReflectionMethodCall(
            |      target,
            |      target,
            |      "combine",
            |      Array("value".asInstanceOf[AnyRef])
            |    )
            |    Expr(call.process().asInstanceOf[String])
            |  }
            |}
            |""".stripMargin.getBytes(UTF_8)
        )
        invokeScalaCompiler(
          Array(
            "-classpath",
            runtimeClasspath,
            "-d",
            outputDir.toString,
            supportSource.toString
          )
        )
  
        Files.write(
          usageSource,
          """
            |package compiled_jsoniter_helper_object
            |
            |import com.github.plokhotnyuk.jsoniter_scala.macros.HelperObjectJvmReflectionMethodCallMacro
            |
            |object HelperObjectJvmReflectionMethodCallUsage {
            |  val mappedName: String = HelperObjectJvmReflectionMethodCallMacro.mappedName
            |}
            |""".stripMargin.getBytes(UTF_8)
        )
        invokeScalaCompiler(
          Array(
            "-classpath",
            runtimeClasspath + File.pathSeparator + outputDir,
            "-d",
            outputDir.toString,
            usageSource.toString
          )
        )
      } finally {
        deleteRecursively(rootDir)
      }
    }
  
    private def runtimeClasspath: String = {
      val entries: ArrayBuffer[String] = ArrayBuffer.empty[String]
      var loader: ClassLoader = Thread.currentThread().getContextClassLoader
      while (loader != null) {
        loader match {
          case urlClassLoader: URLClassLoader =>
            urlClassLoader.getURLs.foreach(url => entries += Path.of(url.toURI).toString)
          case _ =>
        }
        loader = loader.getParent
      }
      if (entries.nonEmpty) entries.distinct.mkString(File.pathSeparator)
      else System.getProperty("java.class.path")
    }
  
    private def invokeScalaCompiler(args: Array[String]): Unit = {
      val driverClass: Class[?] = Class.forName("dotty.tools.dotc.Driver")
      val driver: AnyRef = driverClass.getDeclaredConstructor().newInstance().asInstanceOf[AnyRef]
      val reporter: AnyRef = driverClass
        .getMethod("process", classOf[Array[String]])
        .invoke(driver, args.asInstanceOf[AnyRef])
        .asInstanceOf[AnyRef]
      val hasErrors: Boolean = reporter.getClass.getMethod("hasErrors").invoke(reporter).asInstanceOf[Boolean]
  
      assertFalse(hasErrors, "Runtime Scala compilation should expand the helper object macro successfully")
    }
  
    private def deleteRecursively(path: Path): Unit = {
      if (Files.exists(path)) {
        val paths: Stream[Path] = Files.walk(path)
        try {
          paths.sorted(Comparator.reverseOrder[Path]()).forEach((path: Path) => Files.deleteIfExists(path))
        } finally {
          paths.close()
        }
      }
    }
  }
