  package com_github_plokhotnyuk_jsoniter_scala.jsoniter_scala_macros_3
  
  import com.github.plokhotnyuk.jsoniter_scala.core.JsonValueCodec
  import com.github.plokhotnyuk.jsoniter_scala.core.readFromString
  import com.github.plokhotnyuk.jsoniter_scala.core.writeToString
  import com.github.plokhotnyuk.jsoniter_scala.macros.CodecMakerConfig
  import com.github.plokhotnyuk.jsoniter_scala.macros.JsonCodecMaker
  import com_github_plokhotnyuk_jsoniter_scala.jsoniter_scala_macros_3.CompileTimeEvalInnerQuoteScopeTest.FieldMapped
  import com_github_plokhotnyuk_jsoniter_scala.jsoniter_scala_macros_3.CompileTimeEvalInnerQuoteScopeTest.MethodMapped
  import com_github_plokhotnyuk_jsoniter_scala.jsoniter_scala_macros_3.support.MacroRuntimeNames
  import org.junit.jupiter.api.Assertions.assertEquals
  import org.junit.jupiter.api.Test
  
  object CompileTimeEvalInnerQuoteScopeTest:
    final case class MethodMapped(methodName: String)
    final case class FieldMapped(fieldName: String)
  
    given JsonValueCodec[MethodMapped] = JsonCodecMaker.make[MethodMapped](
      CodecMakerConfig.withFieldNameMapper { case name =>
        MacroRuntimeNames.methodPrefix + name
      })
  
    given JsonValueCodec[FieldMapped] = JsonCodecMaker.make[FieldMapped](
      CodecMakerConfig.withFieldNameMapper { case name =>
        MacroRuntimeNames.publicFieldHolder.value + name
      })
  
  class CompileTimeEvalInnerQuoteScopeTest:
    @Test
    def mapsFieldNamesThroughRuntimeModuleMethod(): Unit =
      val value: MethodMapped = MethodMapped("Ada")
      val json: String = """{"method_methodName":"Ada"}"""
  
      assertEquals(json, writeToString(value))
      assertEquals(value, readFromString[MethodMapped](json))
  
    @Test
    def mapsFieldNamesThroughRuntimePublicField(): Unit =
      val value: FieldMapped = FieldMapped("Lovelace")
      val json: String = """{"field_fieldName":"Lovelace"}"""
  
