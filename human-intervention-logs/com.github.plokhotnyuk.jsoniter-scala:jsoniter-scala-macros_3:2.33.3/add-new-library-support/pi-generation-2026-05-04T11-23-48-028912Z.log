\n\nobject CompileTimeEvalInnerQuoteScopeTest:\n  final case class MethodMapped(methodName: String)\n  final case class FieldMapped(fieldName: String)\n\n  given JsonValueCodec[MethodMapped] = JsonCodecMaker.make[MethodMapped](\n    CodecMakerConfig.withFieldNameMapper { case name =>\n      MacroRuntimeNames.methodPrefix + name\n    })\n\n  given JsonValueCodec[FieldMapped] = JsonCodecMaker.make[FieldMapped](\n    CodecMakerConfig.withFieldNameMapper { case name =>\n      MacroRuntimeNames.publicFieldHolder.value + name\n    })\n\nclass CompileTimeEvalInnerQuoteScopeTest:\n  @Test\n  def mapsFieldNamesThroughRuntimeModuleMethod(): Unit =\n    val value: MethodMapped = MethodMapped(\"Ada\")\n    val json: String = \"\"\"{\"method_methodName\":\"Ada\"}\"\"\"\n\n    assertEquals(json, writeToString(value))\n    assertEquals(value, readFromString[MethodMapped](json))\n\n  @Test\n  def mapsFieldNamesThroughRuntimePublicField(): Unit =\n    val value: FieldMapped = FieldMapped(\"Lovelace\")\n    val json: String = \"\"\"{\"field_fieldName\":\"Lovelace\"}\"\"\"\n\n    assertEquals(json, writeToString(value))\n    assertEquals(value, readFromString[FieldMapped](json))\n"}], "isError": false, "timestamp": 1777893808434}, {"role": "toolResult", "toolCallId": "call_hliiz1ryLLA6QB3JCKwpaxlu|fc_05db16ac799a99ce0169f881b00ddc819c89bdc7664dcd36de", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\nplugins {\n    id \"org.graalvm.internal.tck\"\n    id \"scala\"\n}\n\nString libraryVersion = tck.testedLibraryVersion.get()\n\nsourceSets {\n    macroSupport {\n        java.srcDir 'src/macroSupport/java'\n        scala.srcDir 'src/macroSupport/scala'\n    }\n}\n\ntasks.named('compileTestScala') {\n    dependsOn tasks.named('macroSupportClasses')\n}\n\ndependencies {\n    testImplementation \"com.github.plokhotnyuk.jsoniter-scala:jsoniter-scala-macros_3:$libraryVersion\"\n    testImplementation 'org.assertj:assertj-core:3.22.0'\n    testImplementation 'org.scala-lang:scala3-library_3:3.3.6'\n    testImplementation 'org.scala-lang:scala3-compiler_3:3.3.6'\n    macroSupportImplementation 'org.scala-lang:scala3-library_3:3.3.6'\n    macroSupportImplementation 'org.scala-lang:scala3-compiler_3:3.3.6'\n    testCompileOnly sourceSets.macroSupport.output\n    testRuntimeOnly sourceSets.macroSupport.output\n}\n\njava {\n    toolchain {\n        languageVersion = JavaLanguageVersion.of(21)\n    }\n}\n\ngraalvmNative {\n    agent {\n        defaultMode = \"conditional\"\n        modes {\n            conditional {\n                userCodeFilterPath = \"user-code-filter.json\"\n            }\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777893808434}]}
