guredClasspath: String = System.getProperty(\"jsoniter.scala.test.classpath\", \"\")\n    if configuredClasspath.nonEmpty then configuredClasspath\n    else System.getProperty(\"java.class.path\", \"\")\n\n  private def rethrowIfNotNativeImageDynamicClassLoadingError(error: Error): Unit =\n    if !NativeImageSupport.isUnsupportedFeatureError(error) then throw error\n\n  private def runtimeCompilationSource: String =\n    \"\"\"\n      |package runtime_compiled_jsoniter_scala\n      |\n      |import com.github.plokhotnyuk.jsoniter_scala.core.JsonValueCodec\n      |import com.github.plokhotnyuk.jsoniter_scala.macros.CodecMakerConfig\n      |import com.github.plokhotnyuk.jsoniter_scala.macros.JsonCodecMaker\n      |import com_github_plokhotnyuk_jsoniter_scala.jsoniter_scala_macros_3.support.MacroRuntimeNames\n      |\n      |object RuntimeCompiledJsoniterCodecs:\n      |  final case class MethodMapped(methodName: String)\n      |  final case class FieldMapped(fieldName: String)\n      |\n      |  given JsonValueCodec[MethodMapped] = JsonCodecMaker.make[MethodMapped](\n      |    CodecMakerConfig.withFieldNameMapper { case name =>\n      |      MacroRuntimeNames.methodPrefix + name\n      |    })\n      |\n      |  given JsonValueCodec[FieldMapped] = JsonCodecMaker.make[FieldMapped](\n      |    CodecMakerConfig.withFieldNameMapper { case name =>\n      |      MacroRuntimeNames.publicFieldHolder.value + name\n      |    })\n      |\"\"\".stripMargin\n"}
