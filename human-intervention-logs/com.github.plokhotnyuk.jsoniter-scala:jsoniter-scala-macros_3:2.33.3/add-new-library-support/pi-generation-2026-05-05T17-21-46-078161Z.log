  import scala.collection.mutable.ArrayBuffer
  
  class CompileTimeEvalInnerQuoteScopeTest {
    import CompileTimeEvalInnerQuoteScopeTest.*
  
    @Test
    def derivesCodecWithMapperCallingRuntimeModuleMethod(): Unit = {
      val value: ModuleMethodMapped = ModuleMethodMapped("alpha")
      val json: String = writeToString(value)(moduleMethodCodec)
  
      assertEquals("{\"module_value\":\"alpha\"}", json)
      assertEquals(value, readFromString[ModuleMethodMapped](json)(moduleMethodCodec))
    }
  
    @Test
    def derivesCodecWithMapperReadingRuntimeFieldThroughAccessorMethod(): Unit = {
      val value: MethodFieldMapped = MethodFieldMapped("beta")
      val json: String = writeToString(value)(methodFieldCodec)
  
      assertEquals("{\"method_value\":\"beta\"}", json)
      assertEquals(value, readFromString[MethodFieldMapped](json)(methodFieldCodec))
    }
  
    @Test
    def derivesCodecWithMapperReadingRuntimeJavaPublicField(): Unit = {
      val value: JavaFieldMapped = JavaFieldMapped("gamma")
      val json: String = writeToString(value)(javaFieldCodec)
  
      assertEquals("{\"5_value\":\"gamma\"}", json)
      assertEquals(value, readFromString[JavaFieldMapped](json)(javaFieldCodec))
    }
  
    @Test
    def compilesJsonCodecAtRuntimeToExerciseQuoteScopeReflection(): Unit = {
      try {
        compileScalaSource(
          """
            |package compiled_jsoniter_quote_scope
            |
            |import com.github.plokhotnyuk.jsoniter_scala.core.JsonValueCodec
            |import com.github.plokhotnyuk.jsoniter_scala.macros.CodecMakerConfig
            |import com.github.plokhotnyuk.jsoniter_scala.macros.JsonCodecMaker
            |import com_github_plokhotnyuk_jsoniter_scala.jsoniter_scala_macros_3.JsoniterCompileTimeNameMappingSupport
            |
            |object RuntimeCompiledCodecDefinitions {
            |  case class ModuleMethodMapped(value: String)
            |  case class MethodFieldMapped(value: String)
            |  case class JavaFieldMapped(value: String)
            |
            |  val moduleMethodCodec: JsonValueCodec[ModuleMethodMapped] =
            |    JsonCodecMaker.make[ModuleMethodMapped](
            |      CodecMakerConfig.withFieldNameMapper { case name =>
            |        JsoniterCompileTimeNameMappingSupport.modulePrefix(name)
            |      }
            |    )
            |
            |  val methodFieldCodec: JsonValueCodec[MethodFieldMapped] =
            |    JsonCodecMaker.make[MethodFieldMapped](
            |      CodecMakerConfig.withFieldNameMapper { case name =>
            |        JsoniterCompileTimeNameMappingSupport.methodBackedPrefixer.transform(name)
            |      }
            |    )
            |
            |  val javaFieldCodec: JsonValueCodec[JavaFieldMapped] =
            |    JsonCodecMaker.make[JavaFieldMapped](
            |      CodecMakerConfig.withFieldNameMapper { case name =>
            |        JsoniterCompileTimeNameMappingSupport.publicPoint.x.toString + "_" + name
            |      }
            |    )
            |}
            |""".stripMargin
        )
      } catch {
        case error: Error =>
          if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
            throw error
          }
        case ex: InvocationTargetException if ex.getCause.isInstanceOf[Error] =>
          val error: Error = ex.getCause.asInstanceOf[Error]
          if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
            throw error
          }
      }
    }
  }
  
  object CompileTimeEvalInnerQuoteScopeTest {
    case class ModuleMethodMapped(value: String)
    case class MethodFieldMapped(value: String)
    case class JavaFieldMapped(value: String)
  
    val moduleMethodCodec: JsonValueCodec[ModuleMethodMapped] =
      JsonCodecMaker.make[ModuleMethodMapped](
        CodecMakerConfig.withFieldNameMapper { case name =>
          JsoniterCompileTimeNameMappingSupport.modulePrefix(name)
        }
      )
  
    val methodFieldCodec: JsonValueCodec[MethodFieldMapped] =
      JsonCodecMaker.make[MethodFieldMapped](
        CodecMakerConfig.withFieldNameMapper { case name =>
          JsoniterCompileTimeNameMappingSupport.methodBackedPrefixer.transform(name)
        }
      )
  
    val javaFieldCodec: JsonValueCodec[JavaFieldMapped] =
      JsonCodecMaker.make[JavaFieldMapped](
        CodecMakerConfig.withFieldNameMapper { case name =>
          JsoniterCompileTimeNameMappingSupport.publicPoint.x.toString + "_" + name
        }
      )
  
    def compileScalaSource(source: String): Unit = {
      val rootDir: Path = Files.createTempDirectory("jsoniter-quote-scope-")
      try {
        val outputDir: Path = Files.createDirectory(rootDir.resolve("classes"))
        val sourceFile: Path = rootDir.resolve("RuntimeCompiledCodecDefinitions.scala")
        Files.write(sourceFile, source.getBytes(UTF_8))
        invokeScalaCompiler(
          Array(
            "-classpath",
            runtimeClasspath,
            "-d",
            outputDir.toString,
            sourceFile.toString
          )
        )
      } finally {
        deleteRecursively(rootDir)
      }
    }
  
    private def runtimeClasspath: String = {
      val entries: ArrayBuffer[String] = ArrayBuffer.empty[String]
      var loader: ClassLoader = Thread.currentThread().getContextClassLoader
      while (loader != null) {
        loader match {
          case urlClassLoader: URLClassLoader =>
            urlClassLoader.getURLs.foreach(url => entries += Path.of(url.toURI).toString)
          case _ =>
        }
        loader = loader.getParent
      }
      if (entries.nonEmpty) entries.distinct.mkString(File.pathSeparator)
      else System.getProperty("java.class.path")
    }
  
    private def invokeScalaCompiler(args: Array[String]): Unit = {
      val driverClass: Class[?] = Class.forName("dotty.tools.dotc.Driver")
      val driver: AnyRef = driverClass.getDeclaredConstructor().newInstance().asInstanceOf[AnyRef]
      val reporter: AnyRef = driverClass
        .getMethod("process", classOf[Array[String]])
        .invoke(driver, args.asInstanceOf[AnyRef])
        .asInstanceOf[AnyRef]
      val hasErrors: Boolean = reporter.getClass.getMethod("hasErrors").invoke(reporter).asInstanceOf[Boolean]
  
      assertFalse(hasErrors, "Runtime Scala compilation should expand jsoniter-scala macros successfully")
    }
  
    private def deleteRecursively(path: Path): Unit = {
      if (Files.exists(path)) {
        val paths: Stream[Path] = Files.walk(path)
        try {
          paths.sorted(Comparator.reverseOrder()).forEach(path => Files.deleteIfExists(path))
        } finally {
          paths.close()
        }
      }
    }
  }
