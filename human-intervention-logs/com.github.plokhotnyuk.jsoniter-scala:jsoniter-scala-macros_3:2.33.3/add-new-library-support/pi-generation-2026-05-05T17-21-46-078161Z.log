\n      val sourceFile: Path = rootDir.resolve(\"RuntimeCompiledCodecDefinitions.scala\")\n      Files.write(sourceFile, source.getBytes(UTF_8))\n      invokeScalaCompiler(\n        Array(\n          \"-classpath\",\n          runtimeClasspath,\n          \"-d\",\n          outputDir.toString,\n          sourceFile.toString\n        )\n      )\n    } finally {\n      deleteRecursively(rootDir)\n    }\n  }\n\n  private def runtimeClasspath: String = {\n    val entries: ArrayBuffer[String] = ArrayBuffer.empty[String]\n    var loader: ClassLoader = Thread.currentThread().getContextClassLoader\n    while (loader != null) {\n      loader match {\n        case urlClassLoader: URLClassLoader =>\n          urlClassLoader.getURLs.foreach(url => entries += Path.of(url.toURI).toString)\n        case _ =>\n      }\n      loader = loader.getParent\n    }\n    if (entries.nonEmpty) entries.distinct.mkString(File.pathSeparator)\n    else System.getProperty(\"java.class.path\")\n  }\n\n  private def invokeScalaCompiler(args: Array[String]): Unit = {\n    val driverClass: Class[?] = Class.forName(\"dotty.tools.dotc.Driver\")\n    val driver: AnyRef = driverClass.getDeclaredConstructor().newInstance().asInstanceOf[AnyRef]\n    val reporter: AnyRef = driverClass\n      .getMethod(\"process\", classOf[Array[String]])\n      .invoke(driver, args.asInstanceOf[AnyRef])\n      .asInstanceOf[AnyRef]\n    val hasErrors: Boolean = reporter.getClass.getMethod(\"hasErrors\").invoke(reporter).asInstanceOf[Boolean]\n\n    assertFalse(hasErrors, \"Runtime Scala compilation should expand jsoniter-scala macros successfully\")\n  }\n\n  private def deleteRecursively(path: Path): Unit = {\n    if (Files.exists(path)) {\n      val paths: Stream[Path] = Files.walk(path)\n      try {\n        paths.sorted(Comparator.reverseOrder()).forEach(path => Files.deleteIfExists(path))\n      } finally {\n        paths.close()\n      }\n    }\n  }\n}\n"}], "isError": false, "timestamp": 1778002375952}}
