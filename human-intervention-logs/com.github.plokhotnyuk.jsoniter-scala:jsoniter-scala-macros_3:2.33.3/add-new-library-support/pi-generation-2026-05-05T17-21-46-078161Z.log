        def prependArgument(obj: AnyRef, args: Array[AnyRef]): Array[AnyRef] =
          val retval = new Array[AnyRef](args.length + 1)
          retval(0) = obj
          System.arraycopy(args, 0, retval, 1, args.length)
          retval
      }
  
