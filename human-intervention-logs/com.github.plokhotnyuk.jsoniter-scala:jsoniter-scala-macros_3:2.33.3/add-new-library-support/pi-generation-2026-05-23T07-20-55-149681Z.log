  package com_github_plokhotnyuk_jsoniter_scala.jsoniter_scala_macros_3
  
  import dotty.tools.dotc.Main
  import dotty.tools.dotc.reporting.Reporter
  import org.graalvm.internal.tck.NativeImageSupport
  import org.junit.jupiter.api.Assertions.fail
  import org.junit.jupiter.api.Test
  
  import java.io.ByteArrayOutputStream
  import java.nio.charset.StandardCharsets.UTF_8
  import java.nio.file.Files
  import java.nio.file.Path
  import java.util.Comparator
  import javax.tools.ToolProvider
  
  class CompileTimeEvalInnerQuoteScopeTest {
    @Test
    def compilesCodecsWhoseNameMappersComeFromRuntimeModuleFields(): Unit = {
      try {
        val workDir: Path = Files.createTempDirectory("jsoniter-scala-macro-runtime-fields")
        try compileCodecs(workDir)
        finally deleteRecursively(workDir)
      } catch {
        case error: Error if NativeImageSupport.isUnsupportedFeatureError(error) =>
      }
    }
  
    private def compileCodecs(workDir: Path): Unit = {
      val helperSourceDir: Path = Files.createDirectories(workDir.resolve("helper-src"))
      val helperClassesDir: Path = Files.createDirectories(workDir.resolve("helper-classes"))
      val macroSourceDir: Path = Files.createDirectories(workDir.resolve("macro-src"))
      val macroClassesDir: Path = Files.createDirectories(workDir.resolve("macro-classes"))
  
      val fixturePackageDir: Path = Files.createDirectories(helperSourceDir.resolve("runtime_compile_fixture"))
      val helperObjectSource: Path = fixturePackageDir.resolve("RuntimeMappers.scala")
      val publicFieldHolderSource: Path = fixturePackageDir.resolve("PublicPartialFunctionHolder.java")
      val macroSource: Path = macroSourceDir.resolve("CodecCompilationTarget.scala")
  
      writeSource(
        helperObjectSource,
        """
          |package runtime_compile_fixture
          |
          |object RuntimeMappers {
          |  val accessorBackedMapper: PartialFunction[String, String] = {
          |    case "firstName" => "first_name"
          |  }
          |
          |  val fieldBackedMapperHolder: PublicPartialFunctionHolder = new PublicPartialFunctionHolder()
          |}
          |""".stripMargin
      )
      writeSource(
        publicFieldHolderSource,
        """
          |package runtime_compile_fixture;
          |
          |public final class PublicPartialFunctionHolder {
          |    public final scala.PartialFunction<String, String> fieldBackedMapper =
          |            new scala.runtime.AbstractPartialFunction<String, String>() {
          |                @Override
          |                public boolean isDefinedAt(String value) {
          |                    return "lastName".equals(value);
          |                }
          |
          |                @Override
          |                public String apply(String value) {
          |                    return "last_name";
          |                }
          |            };
          |}
          |""".stripMargin
      )
      compileJavaSource(publicFieldHolderSource, helperClassesDir, System.getProperty("java.class.path"))
      compileSources(
        Seq(helperObjectSource),
        helperClassesDir,
        helperClassesDir.toString + java.io.File.pathSeparator + System.getProperty("java.class.path")
      )
  
      writeSource(
        macroSource,
        """
          |import com.github.plokhotnyuk.jsoniter_scala.core.JsonValueCodec
          |import com.github.plokhotnyuk.jsoniter_scala.macros.CodecMakerConfig
          |import com.github.plokhotnyuk.jsoniter_scala.macros.JsonCodecMaker
          |import runtime_compile_fixture.RuntimeMappers
          |
          |final case class Person(firstName: String, lastName: String)
          |
          |object CodecCompilationTarget {
          |  val accessorBackedCodec: JsonValueCodec[Person] =
          |    JsonCodecMaker.make[Person](
          |      CodecMakerConfig.withFieldNameMapper(RuntimeMappers.accessorBackedMapper)
          |    )
          |
          |  val fieldBackedCodec: JsonValueCodec[Person] =
          |    JsonCodecMaker.make[Person](
          |      CodecMakerConfig.withFieldNameMapper(RuntimeMappers.fieldBackedMapperHolder.fieldBackedMapper)
          |    )
          |}
          |""".stripMargin
      )
      compileSources(
        Seq(macroSource),
        macroClassesDir,
        helperClassesDir.toString + java.io.File.pathSeparator + System.getProperty("java.class.path")
      )
    }
  
    private def compileJavaSource(source: Path, outputDir: Path, classpath: String): Unit = {
      val compiler = ToolProvider.getSystemJavaCompiler
      if (compiler == null) {
        fail("Expected a system Java compiler to be available for compiling the runtime macro fixture")
      }
      val diagnostics: ByteArrayOutputStream = new ByteArrayOutputStream()
      val exitCode: Int = compiler.run(
        null,
        diagnostics,
        diagnostics,
        "-classpath",
        classpath,
        "-d",
        outputDir.toString,
        source.toString
      )
      if (exitCode != 0) {
        fail("Expected Java fixture compilation to succeed, but javac exited with " + exitCode + ":\n" +
          diagnostics.toString(UTF_8))
      }
    }
  
    private def compileSources(sources: Seq[Path], outputDir: Path, classpath: String): Unit = {
      val args: Array[String] = Array("-classpath", classpath, "-d", outputDir.toString) ++
        sources.map(_.toString)
      val reporter: Reporter = Main.process(args)
      if (reporter.hasErrors) {
        fail("Expected Scala compilation to succeed, but it reported errors:\n" + reporter.allErrors.mkString("\n"))
      }
    }
  
    private def writeSource(path: Path, source: String): Unit = {
      Files.write(path, source.getBytes(UTF_8))
    }
  
    private def deleteRecursively(path: Path): Unit = {
      if (Files.exists(path)) {
        val stream: java.util.stream.Stream[Path] = Files.walk(path)
        try {
          stream.sorted(Comparator.reverseOrder[Path]()).forEach { p: Path =>
            Files.deleteIfExists(p)
            ()
          }
        } finally {
          stream.close()
        }
      }
    }
  }
