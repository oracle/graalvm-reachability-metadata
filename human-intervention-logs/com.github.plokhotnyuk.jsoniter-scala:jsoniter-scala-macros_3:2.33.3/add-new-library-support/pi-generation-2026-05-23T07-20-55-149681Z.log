rs.scala\")\n    val publicFieldHolderSource: Path = fixturePackageDir.resolve(\"PublicPartialFunctionHolder.java\")\n    val macroSource: Path = macroSourceDir.resolve(\"CodecCompilationTarget.scala\")\n\n    writeSource(\n      helperObjectSource,\n      \"\"\"\n        |package runtime_compile_fixture\n        |\n        |object RuntimeMappers {\n        |  val accessorBackedMapper: PartialFunction[String, String] = {\n        |    case \"firstName\" => \"first_name\"\n        |  }\n        |\n        |  val fieldBackedMapperHolder: PublicPartialFunctionHolder = new PublicPartialFunctionHolder()\n        |}\n        |\"\"\".stripMargin\n    )\n    writeSource(\n      publicFieldHolderSource,\n      \"\"\"\n        |package runtime_compile_fixture;\n        |\n        |public final class PublicPartialFunctionHolder {\n        |    public final scala.PartialFunction<String, String> fieldBackedMapper =\n        |            new scala.runtime.AbstractPartialFunction<String, String>() {\n        |                @Override\n        |                public boolean isDefinedAt(String value) {\n        |                    return \"lastName\".equals(value);\n        |                }\n        |\n        |                @Override\n        |                public String apply(String value) {\n        |                    return \"last_name\";\n        |                }\n        |            };\n        |}\n        |\"\"\".stripMargin\n    )\n    compileSources(\n      Seq(helperObjectSource, publicFieldHolderSource),\n      helperClassesDir,\n      System.getProperty(\"java.class.path\")\n    )\n\n    writeSource(\n      macroSource,\n      \"\"\"\n        |import com.github.plokhotnyuk.jsoniter_scala.core.JsonValueCodec\n        |import com.github.plokhotnyuk.jsoniter_scala.macros.CodecMakerConfig\n        |import com.github.plokhotnyuk.jsoniter_scala.macros.JsonCodecMaker\n        |import runtime_compile_fixture.RuntimeMappers\n        |\n        |final case class Pers