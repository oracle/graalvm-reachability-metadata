      private def retrieveRuntimeField(obj: AnyRef, name: String): AnyRef =
        try obj.getClass.getMethod(name).invoke(obj) catch { // TODO: error handling
          case ex: NoSuchMethodException => obj.getClass.getField(name).get(obj)
        }
  
  
