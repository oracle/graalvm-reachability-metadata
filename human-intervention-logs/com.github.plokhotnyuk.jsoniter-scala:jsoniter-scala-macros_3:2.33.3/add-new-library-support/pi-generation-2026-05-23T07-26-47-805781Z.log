reflection\")\n      try compileCodec(workDir)\n      finally deleteRecursively(workDir)\n    } catch {\n      case error: Error =>\n        if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n          throw error\n        }\n    }\n  }\n\n  private def compileCodec(workDir: Path): Unit = {\n    val sourceDir: Path = Files.createDirectories(workDir.resolve(\"src\"))\n    val classesDir: Path = Files.createDirectories(workDir.resolve(\"classes\"))\n    val source: Path = sourceDir.resolve(\"DirectJvmReflectionCodecTarget.scala\")\n\n    writeSource(\n      source,\n      \"\"\"\n        |import com.github.plokhotnyuk.jsoniter_scala.core.JsonValueCodec\n        |import com.github.plokhotnyuk.jsoniter_scala.macros.CodecMakerConfig\n        |import com.github.plokhotnyuk.jsoniter_scala.macros.JsonCodecMaker\n        |import com_github_plokhotnyuk_jsoniter_scala.jsoniter_scala_macros_3.RuntimeDirectJvmReflectionMapperTest\n        |\n        |final case class DirectJvmReflectionPerson(firstName: String, lastName: String)\n        |\n        |object DirectJvmReflectionCodecTarget {\n        |  val codec: JsonValueCodec[DirectJvmReflectionPerson] =\n        |    JsonCodecMaker.make[DirectJvmReflectionPerson](\n        |      CodecMakerConfig.withFieldNameMapper {\n        |        case fieldName if RuntimeDirectJvmReflectionMapperTest.accepts(fieldName) =>\n        |          RuntimeDirectJvmReflectionMapperTest.rename(fieldName)\n        |      }\n        |    )\n        |}\n        |\"\"\".stripMargin\n    )\n    compileSources(Seq(source), classesDir, System.getProperty(\"java.class.path\"))\n  }\n\n  private def compileSources(sources: Seq[Path], outputDir: Path, classpath: String): Unit = {\n    val args: Array[String] = Array(\"-classpath\", classpath, \"-d\", outputDir.toString) ++ sources.map(_.toString)\n    val reporter: Reporter = Main.process(args)\n    if (reporter.hasErrors) {\n      fail(\"Expected Scala compilation to succeed, but it reported errors:\\n\" + reporter.allErrors.mkString(\"\\n\"))\n    }\n  }\n\n  private def writeSource(path: Path, source: String): Unit = {\n    Files.write(path, source.getBytes(UTF_8))\n  }\n\n  private def deleteRecursively(path: Path): Unit = {\n    if (Files.exists(path)) {\n      val stream: java.util.stream.Stream[Path] = Files.walk(path)\n      try {\n        val iterator: java.util.Iterator[Path] = stream.sorted(Comparator.reverseOrder[Path]()).iterator()\n        while (iterator.hasNext) {\n          Files.deleteIfExists(iterator.next())\n          ()\n        }\n      } finally {\n        stream.close()\n      }\n    }\n  }\n}\n\nobject RuntimeDirectJvmReflectionMapperTest {\n  def accepts(fieldName: String): Boolean = true\n\n  def rename(fieldName: String): String = fieldName match {\n    case \"firstName\" => \"first_name\"\n    case \"lastName\" => \"last_name\"\n    case other => other\n  }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 727, "output": 1569, "cacheRead": 23040, "cacheWrite": 0, "totalTokens": 25336, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1779521123475, "responseId": "resp_052eeebdf1dfee3c016a115663f26081969562bc579a27560f"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_wH0ygVx873g6KlXsDyQO49ys|fc_052eeebdf1dfee3c016a11566bdb3c81968cd2da73bf5f35a4", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 3660 bytes to tests/src/com.github.plokhotnyuk.jsoniter-scala/jsoniter-scala-macros_3/2.33.3/src/test/scala/com_github_plokhotnyuk_jsoniter_scala/jsoniter_scala_macros_3/CompileTimeEvalInnerQuoteScopeInnerDirectJvmReflectionMethodCallTest.scala"}], "isError": false, "timestamp": 1779521137422}]}
