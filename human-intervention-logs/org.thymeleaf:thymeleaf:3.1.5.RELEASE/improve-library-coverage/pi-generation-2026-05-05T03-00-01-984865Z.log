\n    @Test\n    void serializeValueUsesJackson3DisableFallbackWhenConfigureMethodIsUnavailable() {\n        ClassLoader originalClassLoader = Thread.currentThread().getContextClassLoader();\n        Thread.currentThread().setContextClassLoader(new NoConfigureObjectMapperClassLoader(originalClassLoader));\n        try {\n            StandardJavaScriptSerializer serializer = new StandardJavaScriptSerializer(true);\n            Map<String, Object> model = new LinkedHashMap<>();\n            model.put(\"path\", \"fallback/path\");\n            StringWriter writer = new StringWriter();\n\n            serializer.serializeValue(model, writer);\n\n            assertThat(writer.toString()).isEqualTo(\"{\\\"path\\\":\\\"fallback\\\\/path\\\"}\");\n        } finally {\n            Thread.currentThread().setContextClassLoader(originalClassLoader);\n        }\n    }\n\n    private static final class NoConfigureObjectMapperClassLoader extends ClassLoader {\n\n        private NoConfigureObjectMapperClassLoader(ClassLoader parent) {\n            super(parent);\n        }\n\n        @Override\n        protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {\n            if (\"tools.jackson.databind.json.JsonMapper\".equals(name)) {\n                throw new ClassNotFoundException(name);\n            }\n            if (\"tools.jackson.databind.ObjectMapper\".equals(name)) {\n                return NoConfigureObjectMapper.class;\n            }\n            return super.loadClass(name, resolve);\n        }\n    }\n}"}]}
