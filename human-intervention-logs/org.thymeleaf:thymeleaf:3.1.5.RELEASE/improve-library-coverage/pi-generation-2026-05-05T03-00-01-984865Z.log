     JsonMapper.setBuilderAvailable(true);\n        }\n    }\n}", "newText": "    @Test\n    void serializeValueFallsBackToJackson3ObjectMapperWhenBuilderIsUnavailable() {\n        JsonMapper.setBuilderAvailable(false);\n        try {\n            StandardJavaScriptSerializer serializer = new StandardJavaScriptSerializer(true);\n            Map<String, Object> model = new LinkedHashMap<>();\n            model.put(\"path\", \"one/two&three\");\n            StringWriter writer = new StringWriter();\n\n            serializer.serializeValue(model, writer);\n\n            assertThat(writer.toString()).isEqualTo(\"{\\\"path\\\":\\\"one\\\\/two\\\\u0026three\\\"}\");\n        } finally {\n            JsonMapper.setBuilderAvailable(true);\n        }\n    }\n\n    @Test\n    void serializeValueUsesJackson3DisableFallbackWhenConfigureMethodIsUnavailable() {\n        ClassLoader originalClassLoader = Thread.currentThread().getContextClassLoader();\n        Thread.currentThread().setContextClassLoader(new NoConfigureObjectMapperClassLoader(originalClassLoader));\n        try {\n            StandardJavaScriptSerializer serializer = new StandardJavaScriptSerializer(true);\n            Map<String, Object> model = new LinkedHashMap<>();\n            model.put(\"path\", \"fallback/path\");\n            StringWriter writer = new StringWriter();\n\n            serializer.serializeValue(model, writer);\n\n            assertThat(writer.toString()).isEqualTo(\"{\\\"path\\\":\\\"fallback\\\\/path\\\"}\");\n        } finally {\n            Thread.currentThread().setContextClassLoader(originalClassLoader);\n        }\n    }\n\n    private static final class NoConfigureObjectMapperClassLoader extends ClassLoader {\n\n        private NoConfigureObjectMapperClassLoader(ClassLoader parent) {\n            super(parent);\n        }\n\n        @Override\n        protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {\n            if (\"tools.jackson.databind.json.JsonMapper\".equals(name)) {\n                throw new ClassNotFoundException(name);\n            }\n            if (\"tools.jackson.databind.ObjectMapper\".equals(name)) {\n                return NoConfigureObjectMapper.class;\n            }\n            return super.loadClass(name, resolve);\n        }\n    }\n}"}]}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1969, "output": 1008, "cacheRead": 62976, "cacheWrite": 0, "totalTokens": 65953, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777950918433, "responseId": "resp_053c9c0e976b369b0169f960c75c608196a0d0fc360058b299"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_dREzXhZ1oH7y97MIlbtaiLgI|fc_053c9c0e976b369b0169f960cb7ffc8196ada859a0c219bcab", "toolName": "edit", "content": [{"type": "text", "text": "Successfully replaced 2 block(s) in tests/src/org.thymeleaf/thymeleaf/3.1.5.RELEASE/src/test/java/org_thymeleaf/thymeleaf/StandardJavaScriptSerializerInnerJackson3StandardJavaScriptSerializerTest.java."}], "details": {"diff": "    ...\n 13 \n 14 import org.junit.jupiter.api.Test;\n 15 import org.thymeleaf.standard.serializer.StandardJavaScriptSerializer;\n 16 \n+17 import tools.jackson.databind.NoConfigureObjectMapper;\n 17 import tools.jackson.databind.json.JsonMapper;\n 18 \n 19 import static org.assertj.core.api.Assertions.assertThat;\n 20 \n    ...\n 49         } finally {\n 50             JsonMapper.setBuilderAvailable(true);\n 51         }\n 52     }\n+54 \n+55     @Test\n+56     void serializeValueUsesJackson3DisableFallbackWhenConfigureMethodIsUnavailable() {\n+57         ClassLoader originalClassLoader = Thread.currentThread().getContextClassLoader();\n+58         Thread.currentThread().setContextClassLoader(new NoConfigureObjectMapperClassLoader(originalClassLoader));\n+59         try {\n+60             StandardJavaScriptSerializer serializer = new StandardJavaScriptSerializer