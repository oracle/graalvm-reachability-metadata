              assertThat(repository).isInstanceOf(InMemoryChatMemoryRepository.class);
              assertThat(chatMemory).isInstanceOf(RecordingChatMemory.class);
  
              chatMemory.add(CONVERSATION_ID, List.of(new UserMessage("custom question"),
