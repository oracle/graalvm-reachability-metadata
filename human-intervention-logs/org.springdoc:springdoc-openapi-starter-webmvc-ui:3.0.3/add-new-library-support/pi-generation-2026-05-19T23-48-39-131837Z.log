  			html = addDocumentTitle(html);
  
  		return html;
  	}
  
  	/**
  	 * Add parameters string.
  	 *
  	 * @param html                      the html
  	 * @param swaggerUiConfigParameters the swagger ui config parameters
  	 * @return the string
  	 * @throws JsonProcessingException the json processing exception
