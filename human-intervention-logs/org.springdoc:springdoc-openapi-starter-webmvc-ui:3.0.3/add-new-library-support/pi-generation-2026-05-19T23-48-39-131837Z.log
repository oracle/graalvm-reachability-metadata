  		if (contextPath.endsWith(DEFAULT_PATH_SEPARATOR)) {
  			return contextPath.substring(0, contextPath.length() - 1) + docsUrl;
  		}
  		if (!docsUrl.startsWith(DEFAULT_PATH_SEPARATOR))
