  	protected void buildConfigUrl(SwaggerUiConfigParameters swaggerUiConfigParameters, UriComponentsBuilder uriComponentsBuilder) {
  		if (StringUtils.isEmpty(swaggerUiConfig.getConfigUrl())) {
