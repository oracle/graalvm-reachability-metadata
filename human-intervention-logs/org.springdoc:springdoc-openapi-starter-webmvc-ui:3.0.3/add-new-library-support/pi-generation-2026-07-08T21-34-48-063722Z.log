erverApplicationContext;\nimport org.springframework.context.ConfigurableApplicationContext;\nimport org.springframework.context.annotation.Bean;\nimport org.springframework.http.MediaType;\nimport org.springframework.web.bind.annotation.GetMapping;\nimport org.springframework.web.bind.annotation.RestController;\n\npublic class Springdoc_openapi_starter_webmvc_uiTest {\n    private static final Duration REQUEST_TIMEOUT = Duration.ofSeconds(10);\n\n    private static ConfigurableApplicationContext applicationContext;\n    private static HttpClient httpClient;\n    private static String baseUrl;\n\n    @BeforeAll\n    static void startApplication() {\n        applicationContext = SpringApplication.run(TestApplication.class, \"--server.port=0\");\n        int port = ((WebServerApplicationContext) applicationContext).getWebServer().getPort();\n        baseUrl = \"http://localhost:\" + port;\n        httpClient = HttpClient.newBuilder().connectTimeout(REQUEST_TIMEOUT).build();\n    }\n\n    @AfterAll\n    static void stopApplication() {\n        applicationContext.close();\n    }\n\n    @Test\n    void exposesOpenApiDocumentationAndSwaggerUiForWebMvcEndpoint() throws Exception {\n        HttpResponse<String> apiDocs = get(\"/v3/api-docs\");\n        assertThat(apiDocs.statusCode()).isEqualTo(200);\n        assertThat(apiDocs.headers().firstValue(\"content-type\")).hasValueSatisfying(\n                contentType -> assertThat(contentType).contains(\"application/json\"));\n        assertThat(apiDocs.body()).contains(\"\\\"openapi\\\"\");\n        assertThat(apiDocs.body()).contains(\"\\\"/greeting\\\"\");\n        assertThat(apiDocs.body()).contains(\"\\\"get\\\"\");\n\n        HttpResponse<String> swaggerUi = get(\"/swagger-ui/index.html\");\n        assertThat(swaggerUi.statusCode()).isEqualTo(200);\n        assertThat(swaggerUi.headers().firstValue(\"content-type\")).hasValueSatisfying(\n                contentType -> assertThat(contentType).contains(\"text/html\"));\n        assertThat(swaggerUi.body()).contains(\"Swagger UI\");\n        assertThat(swaggerUi.body()).contains(\"swagger-ui\");\n    }\n\n    private static HttpResponse<String> get(String path) throws Exception {\n        HttpRequest request = HttpRequest.newBuilder(URI.create(baseUrl + path))\n                .timeout(REQUEST_TIMEOUT)\n                .GET()\n                .build();\n        return httpClient.send(request, HttpResponse.BodyHandlers.ofString());\n    }\n\n    @SpringBootApplication\n    static class TestApplication {\n        @Bean\n        GreetingController greetingController() {\n            return new GreetingController();\n        }\n    }\n\n    @RestController\n    static class GreetingController {\n        @GetMapping(value = \"/greeting\", produces = MediaType.TEXT_PLAIN_VALUE)\n        String greeting() {\n            return \"Hello from Springdoc\";\n        }\n    }\n}"}]}}], "api": "openai-codex-responses", "provider": "openai-codex", "model": "gpt-5.6-terra", "usage": {"input": 841, "output": 1849, "cacheRead": 18944, "cacheWrite": 0, "totalTokens": 21634, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1783546445067, "responseId": "resp_0185c193c11e16ea016a4ec24d54a481919d8fdbba4c94116a"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_S7jzDDFuqgGJ1Vm17IlC9j3W|fc_0185c193c11e16ea016a4ec25fd93c8191b76eff4c4ac0f48c", "toolName": "edit", "content": [{"type": "text", "text": "Successfully replaced 1 block(s) in tests/src/org.springdoc/springdoc-openapi-starter-webmvc-ui/3.0.3/src/test/java/org_springdoc/springdoc_openapi_starter_webmvc_ui/Springdoc_openapi_starter_webmvc_uiTest.java."}], "details": {"diff": "    ...\n  5  * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n  6  */\n  7 package org_springdoc.springdoc_openapi_starter_webmvc_ui;\n  8 \n+ 9 import static org.assertj.core.api.Assertions.assertThat;\n+10 \n+11 import java