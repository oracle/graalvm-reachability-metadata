  		this.swaggerUiConfigProperties = swaggerUiConfigProperties;
  	}
  
  	/**
  	 * Find web jar resource path string.
  	 *
  	 * @param pathStr the path
  	 * @return the string
  	 */
  	@Nullable
  	@Override
  	protected String findWebJarResourcePath(String pathStr) {
