 135\t    @Test\n   136\t    void swaggerResourceResolverServesVersionlessSwaggerUiAssetsFromVersionedLocation() throws IOException {\n   137\t        SwaggerUiConfigProperties swaggerUiProperties = createSwaggerUiConfig();\n   138\t        SwaggerResourceResolver resolver = new SwaggerResourceResolver(swaggerUiProperties);\n   139\t        Path stylesheet = temporaryDirectory.resolve(\"swagger-ui\").resolve(swaggerUiProperties.getVersion())\n   140\t                .resolve(\"swagger-ui.css\");\n   141\t        Files.createDirectories(stylesheet.getParent());\n   142\t        Files.writeString(stylesheet, \"body { color: #173647; }\", StandardCharsets.UTF_8);\n   143\t        Resource location = new FileSystemResource(temporaryDirectory.toAbsolutePath() + \"/\");\n   144\t        String versionlessStylesheet = \"swagger-ui/swagger-ui.css\";\n   145\t\n   146\t        Resource resolvedResource = resolver.resolveResource(request(\"\", \"/webjars/\" + versionlessStylesheet),\n   147\t                versionlessStylesheet, List.of(location), new FileSystemResourceResolverChain());\n   148\t        String resolvedUrlPath = resolver.resolveUrlPath(versionlessStylesheet, List.of(location),\n   149\t                new FileSystemResourceResolverChain());\n   150\t\n   151\t        assertThat(resolvedResource).isNotNull();\n   152\t        assertThat(resolvedResource.getContentAsString(StandardCharsets.UTF_8)).isEqualTo(\"body { color: #173647; }\");\n   153\t        assertThat(resolvedUrlPath).isEqualTo(\"swagger-ui/\" + swaggerUiProperties.getVersion() + \"/swagger-ui.css\");\n   154\t    }\n   155\t\n   156\t    @Test\n   157\t    void indexPageTransformerInjectsSwaggerUiAndOAuthConfiguration() throws IOException {\n   158\t        SwaggerUiConfigProperties swaggerUiProperties = createSwaggerUiConfig();\n   159\t        swaggerUiProperties.setConfigUrl(\"/gateway/swagger-config\");\n   160\t        swaggerUiProperties.setDocumentTitle(\"Orders API Documentation\");\n   161\t        swaggerUiProperties.setDisableSwaggerDefaultUrl(true);\n   162\t        SwaggerUiOAuthProperties oauthProperties = new SwaggerUiOAuthProperties();\n   163\t        oauthProperties.setClientId(\"orders-ui\");\n   164\t        oauthProperties.setAppName(\"Orders UI\");\n   165\t        SwaggerWelcomeWebMvc welcome = new SwaggerWelcomeWebMvc(swaggerUiProperties, createSpringDocConfig(),\n   166\t                new FixedSpringWebProvider(\"/api\"));\n   167\t        SwaggerIndexPageTransformer transformer = new SwaggerIndexPageTransformer(swaggerUiProperties,\n   168\t                oauthProperties, welcome, new ObjectMapperProvider(createSpringDocConfig()));\n   169\t        Path initializer = temporaryDirectory.resolve(\"META-INF/resources/webjars/swagger-ui/\")\n   170\t                .resolve(swaggerUiProperties.getVersion()).resolve(\"swagger-initializer.js\");\n   171\t        Files.createDirectories(initializer.getParent());\n   172\t        Files.writeString(initializer, \"\"\"\n   173\t                window.ui = SwaggerUIBundle({\n   174\t                  url: \"https://petstore.swagger.io/v2/swagger.json\",\n   175\t                  layout: \"StandaloneLayout\"\n   176\t                  });\n   177\t                \"\"\", StandardCharsets.UTF_8);\n   178\t        MockHttpServletRequest request = request(\"/gateway\", \"/swagger-ui/swagger-initializer.js\");\n   179\t\n   180\t        Resource transformed = transformer.transform(request, new FileSystemResource(initializer), new NoOpChain());\n   181\t\n   182\t        assertThat(transformed).isInstanceOf(TransformedResource.class);\n   183\t        String content = transformed.getContentAsString(StandardCharsets.UTF_8);\n   184\t        assertThat(content).contains(\"configUrl\", \"/gateway/swagger-config\")\n   185\t                .contains(\"displayOperationId\", \"true\")\n   186\t                .contains(\"ui.initOAuth\")\n   187\t                .contains(\"orders-ui\")\n   188\t                .contains(\"Orders UI\")\n   189\t                .doesNotContain(\"https://petstore.swagger.io/v2/swagger.json\");\n   190\t    }\n   191\t\n   192\t    private static SwaggerWelcomeWebMvc createWelcome(String pathPrefix) {\n   193\t        return new SwaggerWelcomeWebMvc(createSwaggerUiConfig(), createSpringDocConfig(),\n   194\t                new FixedSpringWebProvider(pathPrefix));\n   195\t    }\n   196\t\n   197\t    private static SwaggerUiConfigProperties createSwaggerUiConfig() {\n   198\t        SwaggerUiConfigProperties swaggerUiConfig = new SwaggerUiConfigProperties();\n   199\t        swaggerUiConfig.setDeepLinking(true);\n   200\t        swaggerUiConfig.setDisplayOperationId(true);\n   201\t        swaggerUiConfig.setFilter(\"tag:orders\");\n   202\t        swaggerUiConfig.afterPropertiesSet();\n   203\t        return swaggerUiConfig;\n   204\t    }\n   205\t\n   206\t    private static SpringDocConfigProperties createSpringDocConfig() {\n   207\t        SpringDocConfigProperties properties = new SpringDocConfigProperties();\n   208\t        properties.addGroupConfig(new GroupConfig(\"public-api\", null, null, null, null, null, null, null,\n   209\t                \"Public API\"));\n   210\t        return properties;\n   211\t    }\n   212\t\n   213\t    private static MockHttpServletRequest request(String contextPath, String servletPath) {\n   214\t        MockHttpServletRequest request = new MockHttpServletRequest(\"GET\", contextPath + servletPath);\n   215\t        request.setContextPath(contextPath);\n   216\t        request.setServletPath(servletPath);\n   217\t        request.setServerName(\"localhost\");\n   218\t        request.setServerPort(8080);\n   219\t        request.setScheme(\"http\");\n   220\t        ServletRequestPathUtils.parseAndCache(request);\n   221\t        return request;\n   222\t    }\n   223\t\n   224\t    private static final class FixedSpringWebProvider implements ObjectProvider<SpringWebProvider> {\n   225\t\n   226\t        private final SpringWebProvider springWebProvider;\n   227\t\n   228\t        private FixedSpringWebProvider(String pathPrefix) {\n   229\t            this.springWebProvider = new FixedPathPrefixSpringWebProvider(pathPrefix);\n   230\t        }\n   231\t\n   232\t        @Override\n   233\t        public SpringWebProvider getObject(Object... args) throws BeansException {\n   234\t            return springWebProvider;\n   235\t        }\n   236\t\n   237\t        @Override\n   238\t        public SpringWebProvider getIfAvailable() throws BeansException {\n   239\t            return springWebProvider;\n   240\t        }\n   241\t\n   242\t        @Override\n   243\t        public SpringWebProvider getIfUnique() throws BeansException {\n   244\t            return springWebProvider;\n   245\t        }\n   246\t\n   247\t        @Override\n   248\t        public SpringWebProvider getObject() throws BeansException {\n   249\t            return springWebProvider;\n   250\t        }\n   251\t\n   252\t        @Override\n   253\t        public Iterator<SpringWebProvider> iterator() {\n   254\t            return Stream.of(springWebProvider).iterator();\n   255\t        }\n   256\t\n   257\t        @Override\n   258\t        public Stream<SpringWebProvider> stream() {\n   259\t            return Stream.of(springWebProvider);\n   260\t        }\n","exit_code":0,"status":"completed"}}
