          MethodVisitor method = writer.visitMethod(ACC_PUBLIC | ACC_STATIC, "chooseList",
                  "(Z)Ljava/util/AbstractList;", null, null);
          Label useLinkedList = new Label();
          Label returnList = new Label();
  
