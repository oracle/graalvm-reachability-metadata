  package org_aspectj.aspectjweaver;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.lang.invoke.MethodHandle;
  import java.lang.invoke.MethodHandles;
  import java.lang.invoke.MethodType;
  
  import org.aspectj.bridge.ICommand;
  import org.aspectj.bridge.IMessageHandler;
  import org.aspectj.bridge.MessageHandler;
  import org.aspectj.bridge.ReflectionFactory;
  import org.junit.jupiter.api.Test;
  
  public class ReflectionFactoryTest {
      @Test
      void createsCommandByClassNameUsingNoArgumentConstructor() {
          MessageHandler messages = new MessageHandler();
  
          ICommand command = ReflectionFactory.makeCommand(NoArgumentCommand.class.getName(), messages);
  
          assertThat(command).isInstanceOf(NoArgumentCommand.class);
          assertThat(command.runCommand(new String[] { "compile", "test" }, messages)).isTrue();
          assertThat(((NoArgumentCommand) command).getLastArguments()).containsExactly("compile", "test");
          assertThat(messages.getUnmodifiableListView()).isEmpty();
      }
  
      @Test
      void createsObjectUsingPublicParameterizedConstructor() throws Throwable {
          MethodHandle make = privateMakeMethod();
          MessageHandler messages = new MessageHandler();
  
          Object value = make.invoke(ParameterizedValue.class, ParameterizedValue.class.getName(),
                  new Object[] { "created with public constructor" }, messages);
  
          assertThat(value).isInstanceOfSatisfying(ParameterizedValue.class,
                  parameterizedValue -> assertThat(parameterizedValue.getDescription())
                          .isEqualTo("created with public constructor"));
          assertThat(messages.getUnmodifiableListView()).isEmpty();
      }
  
      private static MethodHandle privateMakeMethod() throws ReflectiveOperationException {
          MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(ReflectionFactory.class, MethodHandles.lookup());
          MethodType type = MethodType.methodType(Object.class, Class.class, String.class, Object[].class,
                  IMessageHandler.class);
          return lookup.findStatic(ReflectionFactory.class, "make", type);
      }
  
      public static class ParameterizedValue {
          private final String description;
  
          public ParameterizedValue(String description) {
              this.description = description;
          }
  
          public String getDescription() {
              return description;
          }
      }
  
      public static class NoArgumentCommand implements ICommand {
          private String[] lastArguments = new String[0];
  
          @Override
          public boolean runCommand(String[] args, IMessageHandler handler) {
              lastArguments = args.clone();
              return true;
          }
  
          @Override
          public boolean repeatCommand(IMessageHandler handler) {
              return runCommand(lastArguments, handler);
          }
  
          public String[] getLastArguments() {
              return lastArguments.clone();
          }
      }
  }
