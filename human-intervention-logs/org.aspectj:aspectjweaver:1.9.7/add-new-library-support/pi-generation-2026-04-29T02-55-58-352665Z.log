     467		/**
     468		 * Register the aspect, following include / exclude rules
     469		 *
     470		 * @param weaver
     471		 * @param loader
     472		 * @param definitions
     473		 */
     474		private boolean registerAspects(final BcelWeaver weaver, final ClassLoader loader, final List<Definition> definitions) {
     475			if (trace.isTraceEnabled()) {
     476				trace.enter("registerAspects", this, new Object[] { weaver, loader, definitions });
     477			}
     478			boolean success = true;
     479	
     480			// TODO: the exclude aspect allow to exclude aspect defined upper in the CL hierarchy - is it what we want ??
     481			// if not, review the getResource so that we track which resource is defined by which CL
     482	
     483			// iterate aspectClassNames
     484			// exclude if in any of the exclude list
     485			for (Definition definition : definitions) {
     486				for (String aspectClassName : definition.getAspectClassNames()) {
     487					if (acceptAspect(aspectClassName)) {
     488						info("register aspect " + aspectClassName);
     489						// System.err.println("? ClassLoaderWeavingAdaptor.registerAspects() aspectName=" + aspectClassName +
     490						// ", loader=" + loader + ", bundle=" + weavingContext.getClassLoaderName());
     491						String requiredType = definition.getAspectRequires(aspectClassName);
     492						if (requiredType != null) {
     493							// This aspect expresses that it requires a type to be around, otherwise it should 'switch off'
     494							((BcelWorld) weaver.getWorld()).addAspectRequires(aspectClassName, requiredType);
     495						}
     496						String definedScope = definition.getScopeForAspect(aspectClassName);
     497						if (definedScope != null) {
     498							((BcelWorld) weaver.getWorld()).addScopedAspect(aspectClassName, definedScope);
     499						}
     500						// ResolvedType aspect =
     501						weaver.addLibraryAspect(aspectClassName);
     502	
     503						// generate key for SC
     504						if (namespace == null) {
     505							namespace = new StringBuffer(aspectClassName);
     506						} else {
     507							namespace = namespace.append(";").append(aspectClassName);
     508						}
     509	
     510					} else {
     511						// warn("aspect excluded: " + aspectClassName);
     512						lint("aspectExcludedByConfiguration", new String[] { aspectClassName, getClassLoaderName(loader) });
     513					}
     514				}
     515			}
     516	
     517			// iterate concreteAspects
     518			// exclude if in any of the exclude list - note that the user defined name matters for that to happen
     519			for (Definition definition : definitions) {
     520				for (Definition.ConcreteAspect concreteAspect : definition.getConcreteAspects()) {
     521					if (acceptAspect(concreteAspect.name)) {
     522						info("define aspect " + concreteAspect.name);
     523						ConcreteAspectCodeGen gen = new ConcreteAspectCodeGen(concreteAspect, weaver.getWorld());
     524						if (!gen.validate()) {
     525							error("Concrete-aspect '" + concreteAspect.name + "' could not be registered");
     526							success = false;
     527							break;
     528						}
     529	
     530						((BcelWorld) weaver.getWorld()).addSourceObjectType(Utility.makeJavaClass(concreteAspect.name, gen.getBytes()),
     531								true);
     532	
     533						concreteAspects.add(gen);
     534	
     535						weaver.addLibraryAspect(concreteAspect.name);
     536	
     537						// generate key for SC
     538						if (namespace == null) {
     539							namespace = new StringBuffer(concreteAspect.name);
     540						} else {
     541							namespace = namespace.append(";" + concreteAspect.name);
     542						}
     543					}
     544				}
     545			}
     546	
     547			/* We couldn't register one or more aspects so disable the adaptor */
     548			if (!success) {
     549				warn("failure(s) registering aspects. Disabling weaver for class loader " + getClassLoaderName(loader));
     550			}
     551	
     552			/* We didn't register any aspects so disable the adaptor */
     553			else if (namespace == null) {
     554				success = false;
     555				info("no aspects registered. Disabling weaver for class loader " + getClassLoaderName(loader));
     556			}
     557	
     558			if (trace.isTraceEnabled()) {
     559				trace.exit("registerAspects", success);
     560			}
     561			return success;
     562		}
     563	
     564		private boolean weaveAndDefineConceteAspects() {
     565			if (trace.isTraceEnabled()) {
     566				trace.enter("weaveAndDefineConceteAspects", this, concreteAspects);
     567			}
     568			boolean success = true;
     569	
     570			for (ConcreteAspectCodeGen gen : concreteAspects) {
     571				String name = gen.getClassName();
     572				byte[] bytes = gen.getBytes();
     573	
     574				try {
     575					byte[] newBytes = weaveClass(name, bytes, true);
     576					this.generatedClassHandler.acceptClass(name, bytes, newBytes);
     577				} catch (IOException ex) {
     578					trace.error("weaveAndDefineConceteAspects", ex);
     579					error("exception weaving aspect '" + name + "'", ex);
     580				}
     581			}
     582	
     583			if (trace.isTraceEnabled()) {
     584				trace.exit("weaveAndDefineConceteAspects", success);
     585			}
     586			return success;
     587		}
