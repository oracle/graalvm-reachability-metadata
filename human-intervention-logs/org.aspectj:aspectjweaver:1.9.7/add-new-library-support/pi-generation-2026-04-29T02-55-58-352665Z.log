dType;\n    41\timport org.aspectj.weaver.World;\n    42\timport org.aspectj.weaver.bcel.BcelWeakClassLoaderReference;\n    43\timport org.aspectj.weaver.bcel.BcelWeaver;\n    44\timport org.aspectj.weaver.bcel.BcelWorld;\n    45\timport org.aspectj.weaver.bcel.Utility;\n    46\timport org.aspectj.weaver.loadtime.definition.Definition;\n    47\timport org.aspectj.weaver.loadtime.definition.DocumentParser;\n    48\timport org.aspectj.weaver.ltw.LTWWorld;\n    49\timport org.aspectj.weaver.patterns.PatternParser;\n    50\timport org.aspectj.weaver.patterns.TypePattern;\n    51\timport org.aspectj.weaver.tools.GeneratedClassHandler;\n    52\timport org.aspectj.weaver.tools.Trace;\n    53\timport org.aspectj.weaver.tools.TraceFactory;\n    54\timport org.aspectj.weaver.tools.WeavingAdaptor;\n    55\timport org.aspectj.weaver.tools.cache.WeavedClassCache;\n    56\t\n    57\timport sun.misc.Unsafe;\n    58\t\n    59\t/**\n    60\t * @author Alexandre Vasseur\n    61\t * @author Andy Clement\n    62\t * @author Abraham Nevado\n    63\t * @author David Knibb\n    64\t * @author John Kew\n    65\t */\n    66\tpublic class ClassLoaderWeavingAdaptor extends WeavingAdaptor {\n    67\t\n    68\t\tprivate final static String AOP_XML = Constants.AOP_USER_XML + \";\" + Constants.AOP_AJC_XML + \";\" + Constants.AOP_OSGI_XML;\n    69\t\n    70\t\tprivate boolean initialized;\n    71\t\n    72\t\tprivate List<TypePattern> dumpTypePattern = new ArrayList<>();\n    73\t\tprivate boolean dumpBefore = false;\n    74\t\tprivate boolean dumpDirPerClassloader = false;\n    75\t\n    76\t\tprivate boolean hasExcludes = false;\n    77\t\tprivate List<TypePattern> excludeTypePattern = new ArrayList<>(); // anything\n    78\t\tprivate List<String> excludeStartsWith = new ArrayList<>(); // com.foo..*\n    79\t\tprivate List<String> excludeStarDotDotStar = new ArrayList<>(); // *..*CGLIB*\n    80\t\tprivate List<String> excludeExactName = new ArrayList<>(); // com.foo.Bar\n    81\t\tprivate List<String> excludeEndsWith = new ArrayList<>(); // com.foo.Bar\n    82\t\tprivate List<String[]> excludeSpecial = new ArrayList<>();\n    83\t\n    84\t\tprivate boolean hasIncludes = false;\n    85\t\tprivate List<TypePattern> includeTypePattern = new ArrayList<>();\n    86\t\tprivate List<String> includeStartsWith = new ArrayList<>();\n    87\t\tprivate List<String> includeExactName = new ArrayList<>();\n    88\t\tprivate boolean includeStar = false;\n    89\t\n    90\t\tprivate List<TypePattern> aspectExcludeTypePattern = new ArrayList<>();\n    91\t\tprivate List<String> aspectExcludeStartsWith = new ArrayList<>();\n    92\t\tprivate List<TypePattern> aspectIncludeTypePattern = new ArrayList<>();\n    93\t\tprivate List<String> aspectIncludeStartsWith = new ArrayList<>();\n    94\t\n    95\t\tprivate StringBuffer namespace;\n    96\t\tprivate IWeavingContext weavingContext;\n    97\t\n    98\t\tprivate List<ConcreteAspectCodeGen> concreteAspects = new ArrayList<>();\n    99\t\n   100\t\tprivate static Trace trace = TraceFactory.getTraceFactory().getTrace(ClassLoaderWeavingAdaptor.class);\n   101\t\n   102\t\tpublic ClassLoaderWeavingAdaptor() {\n   103\t\t\tsuper();\n   104\t\t\tif (trace.isTraceEnabled()) {\n   105\t\t\t\ttrace.enter(\"<init>\", this);\n   106\t\t\t}\n   107\t\t\tif (trace.isTraceEnabled()) {\n   108\t\t\t\ttrace.exit(\"<init>\");\n   109\t\t\t}\n   110\t\t}\n   111\t\n   112\t\t/**\n   113\t\t * We don't need a reference to the class loader and using it during construction can cause problems with recursion. It also\n   114\t\t * makes sense to supply the weaving context during initialization to.\n   115\t\t *\n   116\t\t * @deprecated\n   117\t\t */\n   118\t\t@Deprecated\n   119\t\tpublic ClassLoaderWeavingAdaptor(final ClassLoader deprecatedLoader, final IWeavingContext deprecatedContext) {\n   120\t\t\tsuper();\n   121\t\t\tif (trace.isTraceEnabled()) {\n   122\t\t\t\ttrace.enter(\"<init>\", this, new Object[] { deprecatedLoader, deprecatedContext });\n   123\t\t\t}\n   124\t\t\tif (trace.isTraceEnabled()) {\n   125\t\t\t\ttrace.exit(\"<init>\");\n   126\t\t\t}\n   127\t\t}\n   128\t\n   129\t\tclass SimpleGeneratedClassHandler implements GeneratedClassHandler {\n   130\t\t\tprivate BcelWeakClassLoaderReference loaderRef;\n   131\t\n   132\t\t\tSimpleGeneratedClassHandler(ClassLoader loader) {\n   133\t\t\t\tloaderRef = new BcelWeakClassLoaderReference(loader);\n   134\t\t\t}\n   135\t\n   136\t\t\t/**\n   137\t\t\t * Callback when we need to define a Closure in the JVM\n   138\t\t\t *\n   139\t\t\t */\n   140\t\t\t@Override\n   141\t\t\tpublic void acceptClass (String name, byte[] originalBytes, byte[] wovenBytes) {\n   142\t\t\t\ttry {\n   143\t\t\t\t\tif (shouldDump(name.replace('/', '.'), false)) {\n   144\t\t\t\t\t\tdump(name, wovenBytes, false);\n   145\t\t\t\t\t}\n   146\t\t\t\t} catch (Throwable throwable) {\n   147\t\t\t\t\tthrowable.printStackTrace();\n   148\t\t\t\t}\n   149\t\t\t\tif (activeProtectionDomain != null) {\n   150\t\t\t\t\tdefineClass(loaderRef.getClassLoader(), name, wovenBytes, activeProtectionDomain);\n   151\t\t\t\t} else {\n   152\t\t\t\t\tdefineClass(loaderRef.getClassLoader(), name, wovenBytes); // could be done lazily using the hook\n   153\t\t\t\t}\n   154\t\t\t}\n   155\t\t}\n   156\t\n   157\t\tpublic void initialize(final ClassLoader classLoader, IWeavingContext context) {\n   158\t\t\tif (initialized) {\n   159\t\t\t\treturn;\n   160\t\t\t}\n   161\t\n   162\t\t\tboolean success = true;\n   163\t\n   164\t\t\tthis.weavingContext = context;\n   165\t\t\tif (weavingContext == null) {\n   166\t\t\t\tweavingContext = new DefaultWeavingContext(classLoader);\n   167\t\t\t}\n   168\t\n   169\t\t\tcreateMessageHandler();\n   170\t\n   171\t\t\tthis.generatedClassHandler = new SimpleGeneratedClassHandler(classLoader);\n   172\t\n   173\t\t\tList<Definition> definitions = weavingContext.getDefinitions(classLoader, this);\n   174\t\t\tif (definitions.isEmpty()) {\n   175\t\t\t\tdisable(); // TODO maw Needed to ensure messages are flushed\n   176\t\t\t\tif (trace.isTraceEnabled()) {\n   177\t\t\t\t\ttrace.exit(\"initialize\", definitions);\n   178\t\t\t\t}\n   179\t\t\t\treturn;\n   180\t\t\t}\n   180\t\t\t}\n   181\t\n   182\t\t\t// TODO when the world works in terms of the context, we can remove the loader\n   183\t\t\tbcelWorld = new LTWWorld(classLoader, weavingContext, getMessageHandler(), null);\n   184\t\n   185\t\t\tweaver = new BcelWeaver(bcelWorld);\n   186\t\n   187\t\t\t// register the definitions\n   188\t\t\tsuccess = registerDefinitions(weaver, classLoader, definitions);\n   189\t\t\tif (success) {\n   190\t\n   191\t\t\t\t// after adding aspects\n   192\t\t\t\tweaver.prepareForWeave();\n   193\t\n   194\t\t\t\tenable(); // TODO maw Needed to ensure messages are flushed\n   195\t\t\t\tsuccess = weaveAndDefineConceteAspects();\n   196\t\t\t}\n   197\t\n   198\t\t\tif (success) {\n   199\t\t\t\tenable();\n   200\t\t\t} else {\n   201\t\t\t\tdisable();\n   202\t\t\t\tbcelWorld = null;\n   203\t\t\t\tweaver = null;\n   204\t\t\t}\n   205\t\t\tif (WeavedClassCache.isEnabled()) {\n   206\t\t\t\tinitializeCache(classLoader, getAspectClassNames(definitions), generatedClassHandler, getMessageHandler());\n   207\t\t\t}\n   208\t\n   209\t\t\tinitialized = true;\n   210\t\t\tif (trace.isTraceEnabled()) {\n   211\t\t\t\ttrace.exit(\"initialize\", isEnabled());\n   212\t\t\t}\n   213\t\t}\n   214\t\n   215\t\t/**\n   216\t\t * Get the list of all aspects from the defintion list\n   217\t\t * @param definitions\n   218\t\t * @return\n   219\t\t */\n   220\t\tList<String> getAspectClassNames(List<Definition> definitions) {\n   221\t\t\tList<String> aspects = new LinkedList<>();\n   222\t\t\tfor (Definition def : definitions) {\n   223\t\t\t\tList<String> defAspects = def.getAspectClassNames();\n   224\t\t\t\tif (defAspects != null) {\n   225\t\t\t\t\taspects.addAll(defAspects);\n   226\t\t\t\t}\n   227\t\t\t}\n   228\t\t\treturn aspects;\n   229\t\t}\n   230\t\n   231\t\t/**\n   232\t\t * Load and cache the aop.xml/properties according to the classloader visibility rules\n   233\t\t *\n   234\t\t * @param loader\n   235\t\t */\n   236\t\tList<Definition> parseDefinitions(final ClassLoader loader) {\n   237\t\t\tif (trace.isTraceEnabled()) {\n   238\t\t\t\ttrace.enter(\"parseDefinitions\", this);\n   239\t\t\t}\n   240\t\n   241\t\t\tList<Definition> definitions = new ArrayList<>();\n   242\t\t\ttry {\n   243\t\t\t\tinfo(\"register classloader \" + getClassLoaderName(loader));\n   244\t\t\t\t// TODO av underoptimized: we will parse each XML once per CL that see it\n   245\t\n   246\t\t\t\t// TODO av dev mode needed ? TBD -Daj5.def=...\n   247\t\t\t\tif (loader.equals(ClassLoader.getSystemClassLoader())) {\n   248\t\t\t\t\tString file = System.getProperty(\"aj5.def\", null);\n   249\t\t\t\t\tif (file != null) {\n   250\t\t\t\t\t\tinfo(\"using (-Daj5.def) \" + file);\n   251\t\t\t\t\t\tdefinitions.add(DocumentParser.parse((new File(file)).toURI().toURL()));\n   252\t\t\t\t\t}\n   253\t\t\t\t}\n   254\t\n   255\t\t\t\tString resourcePath = System.getProperty(\"org.aspectj.weaver.loadtime.configuration\", AOP_XML);\n   256\t\t\t\tif (trace.isTraceEnabled()) {\n   257\t\t\t\t\ttrace.event(\"parseDefinitions\", this, resourcePath);\n   258\t\t\t\t}\n   259\t\n   260\t\t\t\tStringTokenizer st = new StringTokenizer(resourcePath, \";\");\n   261\t\n   262\t\t\t\twhile (st.hasMoreTokens()) {\n   263\t\t\t\t\tString nextDefinition = st.nextToken();\n   264\t\t\t\t\tif (nextDefinition.startsWith(\"file:\")) {\n   265\t\t\t\t\t\ttry {\n   266\t\t\t\t\t\t\tString fpath = new URL(nextDefinition).getFile();\n   267\t\t\t\t\t\t\tFile configFile = new File(fpath);\n   268\t\t\t\t\t\t\tif (!configFile.exists()) {\n   269\t\t\t\t\t\t\t\twarn(\"configuration does not exist: \" + nextDefinition);\n   270\t\t\t\t\t\t\t} else {\n   271\t\t\t\t\t\t\t\tdefinitions.add(DocumentParser.parse(configFile.toURI().toURL()));\n   272\t\t\t\t\t\t\t}\n   273\t\t\t\t\t\t} catch (MalformedURLException mue) {\n   274\t\t\t\t\t\t\terror(\"malformed definition url: \" + nextDefinition);\n   275\t\t\t\t\t\t}\n   276\t\t\t\t\t} else {\n   277\t\t\t\t\t\tEnumeration<URL> xmls = weavingContext.getResources(nextDefinition);\n   278\t\t\t\t\t\t// System.out.println(\"? registerDefinitions: found-aop.xml=\" + xmls.hasMoreElements() + \", loader=\" + loader);\n   279\t\n   280\t\t\t\t\t\tSet<URL> seenBefore = new HashSet<>();\n   281\t\t\t\t\t\twhile (xmls.hasMoreElements()) {\n   282\t\t\t\t\t\t\tURL xml = xmls.nextElement();\n   283\t\t\t\t\t\t\tif (trace.isTraceEnabled()) {\n   284\t\t\t\t\t\t\t\ttrace.event(\"parseDefinitions\", this, xml);\n   285\t\t\t\t\t\t\t}\n   286\t\t\t\t\t\t\tif (!seenBefore.contains(xml)) {\n   287\t\t\t\t\t\t\t\tinfo(\"using configuration \" + weavingContext.getFile(xml));\n   288\t\t\t\t\t\t\t\tdefinitions.add(DocumentParser.parse(xml));\n   289\t\t\t\t\t\t\t\tseenBefore.add(xml);\n   290\t\t\t\t\t\t\t} else {\n   291\t\t\t\t\t\t\t\tdebug(\"ignoring duplicate definition: \" + xml);\n   292\t\t\t\t\t\t\t}\n   293\t\t\t\t\t\t}\n   294\t\t\t\t\t}\n   295\t\t\t\t}\n   296\t\t\t\tif (definitions.isEmpty()) {\n   297\t\t\t\t\tinfo(\"no configuration found. Disabling weaver for class loader \" + getClassLoaderName(loader));\n   298\t\t\t\t}\n   299\t\t\t} catch (Exception e) {\n   300\t\t\t\tdefinitions.clear();\n   301\t\t\t\twarn(\"parse definitions failed\", e);\n   302\t\t\t}\n   303\t\n   304\t\t\tif (trace.isTraceEnabled()) {\n   305\t\t\t\ttrace.exit(\"parseDefinitions\", definitions);\n   306\t\t\t}\n   307\t\t\treturn definitions;\n   308\t\t}\n   309\t\n   310\t\tprivate boolean registerDefinitions(final BcelWeaver weaver, final ClassLoader loader, List<Definition> definitions) {\n   311\t\t\tif (trace.isTraceEnabled()) {\n   312\t\t\t\ttrace.enter(\"registerDefinitions\", this, definitions);\n   313\t\t\t}\n   314\t\t\tboolean success = true;\n   315\t\n   316\t\t\ttry {\n   317\t\t\t\tregisterOptions(weaver, loader, definitions);\n   318\t\t\t\tregisterAspectExclude(weaver, loader, definitions);\n   319\t\t\t\tregisterAspectInclude(weaver, loader, definitions);\n   320\t\t\t\tsuccess = registerAspects(weaver, loader, definitions);\n   321\t\t\t\tregisterIncludeExclude(weaver, loader, definitions);\n   322\t\t\t\tregisterDump(weaver, loader, definitions);\n   323\t\t\t} catch (Exception ex) {\n   324\t\t\t\ttrace.error(\"register definition failed\", ex);\n   325\t\t\t\tsuccess = false;\n   326\t\t\t\twarn(\"register definition failed\", (ex instanceof AbortException) ? null : ex);\n   327\t\t\t}\n   328\t\n   329\t\t\tif (trace.isTraceEnabled()) {\n   330\t\t\t\ttrace.exit(\"registerDefinitions\", success);\n   420\t\t\t\t\tif (weaverOption.lint.equals(\"ignore\")) {\n   421\t\t\t\t\t\tbcelWorld.setAllLintIgnored();\n   422\t\t\t\t\t}\n   423\t\t\t\t}\n   424\t\t\t}\n   425\t\t\t// TODO proceedOnError option\n   426\t\t}\n   427\t\n   428\t\tprivate void registerAspectExclude(final BcelWeaver weaver, final ClassLoader loader, final List<Definition> definitions) {\n   429\t\t\tString fastMatchInfo = null;\n   430\t\t\tfor (Definition definition : definitions) {\n   431\t\t\t\tfor (String exclude : definition.getAspectExcludePatterns()) {\n   432\t\t\t\t\tTypePattern excludePattern = new PatternParser(exclude).parseTypePattern();\n   433\t\t\t\t\taspectExcludeTypePattern.add(excludePattern);\n   434\t\t\t\t\tfastMatchInfo = looksLikeStartsWith(exclude);\n   435\t\t\t\t\tif (fastMatchInfo != null) {\n   436\t\t\t\t\t\taspectExcludeStartsWith.add(fastMatchInfo);\n   437\t\t\t\t\t}\n   438\t\t\t\t}\n   439\t\t\t}\n   440\t\t}\n   441\t\n   442\t\tprivate void registerAspectInclude(final BcelWeaver weaver, final ClassLoader loader, final List<Definition> definitions) {\n   443\t\t\tString fastMatchInfo = null;\n   444\t\t\tfor (Definition definition : definitions) {\n   445\t\t\t\tfor (String include : definition.getAspectIncludePatterns()) {\n   446\t\t\t\t\tTypePattern includePattern = new PatternParser(include).parseTypePattern();\n   447\t\t\t\t\taspectIncludeTypePattern.add(includePattern);\n   448\t\t\t\t\tfastMatchInfo = looksLikeStartsWith(include);\n   449\t\t\t\t\tif (fastMatchInfo != null) {\n   450\t\t\t\t\t\taspectIncludeStartsWith.add(fastMatchInfo);\n   451\t\t\t\t\t}\n   452\t\t\t\t}\n   453\t\t\t}\n   454\t\t}\n   455\t\n   456\t\tprotected void lint(String name, String[] infos) {\n   457\t\t\tLint lint = bcelWorld.getLint();\n   458\t\t\tKind kind = lint.getLintKind(name);\n   459\t\t\tkind.signal(infos, null, null);\n   460\t\t}\n   461\t\n   462\t\t@Override\n   463\t\tpublic String getContextId() {\n   464\t\t\treturn weavingContext.getId();\n   465\t\t}\n   466\t\n   467\t\t/**\n   468\t\t * Register the aspect, following include / exclude rules\n   469\t\t *\n   470\t\t * @param weaver\n   471\t\t * @param loader\n   472\t\t * @param definitions\n   473\t\t */\n   474\t\tprivate boolean registerAspects(final BcelWeaver weaver, final ClassLoader loader, final List<Definition> definitions) {\n   475\t\t\tif (trace.isTraceEnabled()) {\n   476\t\t\t\ttrace.enter(\"registerAspects\", this, new Object[] { weaver, loader, definitions });\n   477\t\t\t}\n   478\t\t\tboolean success = true;\n   479\t\n   480\t\t\t// TODO: the exclude aspect allow to exclude aspect defined upper in the CL hierarchy - is it what we want ??\n   481\t\t\t// if not, review the getResource so that we track which resource is defined by which CL\n   482\t\n   483\t\t\t// iterate aspectClassNames\n   484\t\t\t// exclude if in any of the exclude list\n   485\t\t\tfor (Definition definition : definitions) {\n   486\t\t\t\tfor (String aspectClassName : definition.getAspectClassNames()) {\n   487\t\t\t\t\tif (acceptAspect(aspectClassName)) {\n   488\t\t\t\t\t\tinfo(\"register aspect \" + aspectClassName);\n   489\t\t\t\t\t\t// System.err.println(\"? ClassLoaderWeavingAdaptor.registerAspects() aspectName=\" + aspectClassName +\n   490\t\t\t\t\t\t// \", loader=\" + loader + \", bundle=\" + weavingContext.getClassLoaderName());\n   491\t\t\t\t\t\tString requiredType = definition.getAspectRequires(aspectClassName);\n   492\t\t\t\t\t\tif (requiredType != null) {\n   493\t\t\t\t\t\t\t// This aspect expresses that it requires a type to be around, otherwise it should 'switch off'\n   494\t\t\t\t\t\t\t((BcelWorld) weaver.getWorld()).addAspectRequires(aspectClassName, requiredType);\n   495\t\t\t\t\t\t}\n   496\t\t\t\t\t\tString definedScope = definition.getScopeForAspect(aspectClassName);\n   497\t\t\t\t\t\tif (definedScope != null) {\n   498\t\t\t\t\t\t\t((BcelWorld) weaver.getWorld()).addScopedAspect(aspectClassName, definedScope);\n   499\t\t\t\t\t\t}\n   500\t\t\t\t\t\t// ResolvedType aspect =\n   501\t\t\t\t\t\tweaver.addLibraryAspect(aspectClassName);\n   502\t\n   503\t\t\t\t\t\t// generate key for SC\n   504\t\t\t\t\t\tif (namespace == null) {\n   505\t\t\t\t\t\t\tnamespace = new StringBuffer(aspectClassName);\n   506\t\t\t\t\t\t} else {\n   507\t\t\t\t\t\t\tnamespace = namespace.append(\";\").append(aspectClassName);\n   508\t\t\t\t\t\t}\n   509\t\n   510\t\t\t\t\t} else {\n   511\t\t\t\t\t\t// warn(\"aspect excluded: \" + aspectClassName);\n   512\t\t\t\t\t\tlint(\"aspectExcludedByConfiguration\", new String[] { aspectClassName, getClassLoaderName(loader) });\n   513\t\t\t\t\t}\n   514\t\t\t\t}\n   515\t\t\t}\n   516\t\n   517\t\t\t// iterate concreteAspects\n   518\t\t\t// exclude if in any of the exclude list - note that the user defined name matters for that to happen\n   519\t\t\tfor (Definition definition : definitions) {\n   520\t\t\t\tfor (Definition.ConcreteAspect concreteAspect : definition.getConcreteAspects()) {\n   521\t\t\t\t\tif (acceptAspect(concreteAspect.name)) {\n   522\t\t\t\t\t\tinfo(\"define aspect \" + concreteAspect.name);\n   523\t\t\t\t\t\tConcreteAspectCodeGen gen = new ConcreteAspectCodeGen(concreteAspect, weaver.getWorld());\n   524\t\t\t\t\t\tif (!gen.validate()) {\n   525\t\t\t\t\t\t\terror(\"Concrete-aspect '\" + concreteAspect.name + \"' could not be registered\");\n   526\t\t\t\t\t\t\tsuccess = false;\n   527\t\t\t\t\t\t\tbreak;\n   528\t\t\t\t\t\t}\n   529\t\n   530\t\t\t\t\t\t((BcelWorld) weaver.getWorld()).addSourceObjectType(Utility.makeJavaClass(concreteAspect.name, gen.getBytes()),\n   531\t\t\t\t\t\t\t\ttrue);\n   532\t\n   533\t\t\t\t\t\tconcreteAspects.add(gen);\n   534\t\n   535\t\t\t\t\t\tweaver.addLibraryAspect(concreteAspect.name);\n   536\t\n   537\t\t\t\t\t\t// generate key for SC\n   538\t\t\t\t\t\tif (namespace == null) {\n   539\t\t\t\t\t\t\tnamespace = new StringBuffer(concreteAspect.name);\n   540\t\t\t\t\t\t} else {\n   541\t\t\t\t\t\t\tnamespace = namespace.append(\";\" + concreteAspect.name);\n   542\t\t\t\t\t\t}\n   543\t\t\t\t\t}\n   544\t\t\t\t}\n   545\t\t\t}\n   546\t\n   547\t\t\t/* We couldn't register one or more aspects so disable the adaptor */\n   548\t\t\tif (!success) {\n   549\t\t\t\twarn(\"failure(s) registering aspects. Disabling weaver for class loader \" + getClassLoaderName(loader));\n   550\t\t\t}\n   551\t\n   552\t\t\t/* We didn't register any aspects so disable the adaptor */\n   553\t\t\telse if (namespace == null) {\n   554\t\t\t\tsuccess = false;\n   555\t\t\t\tinfo(\"no aspects registered. Disabling weaver for class loader \" + getClassLoaderName(loader));\n   556\t\t\t}\n   557\t\n   558\t\t\tif (trace.isTraceEnabled()) {\n   559\t\t\t\ttrace.exit(\"registerAspects\", success);\n   560\t\t\t}\n   561\t\t\treturn success;\n   562\t\t}\n   563\t\n   564\t\tprivate boolean weaveAndDefineConceteAspects() {\n   565\t\t\tif (trace.isTraceEnabled()) {\n   566\t\t\t\ttrace.enter(\"weaveAndDefineConceteAspects\", this, concreteAspects);\n   567\t\t\t}\n   568\t\t\tboolean success = true;\n   569\t\n   570\t\t\tfor (ConcreteAspectCodeGen gen : concreteAspects) {\n   571\t\t\t\tString name = gen.getClassName();\n   572\t\t\t\tbyte[] bytes = gen.getBytes();\n   573\t\n   574\t\t\t\ttry {\n   575\t\t\t\t\tbyte[] newBytes = weaveClass(name, bytes, true);\n   576\t\t\t\t\tthis.generatedClassHandler.acceptClass(name, bytes, newBytes);\n   577\t\t\t\t} catch (IOException ex) {\n   578\t\t\t\t\ttrace.error(\"weaveAndDefineConceteAspects\", ex);\n   579\t\t\t\t\terror(\"exception weaving aspect '\" + name + \"'\", ex);\n   580\t\t\t\t}\n   581\t\t\t}\n   582\t\n   583\t\t\tif (trace.isTraceEnabled()) {\n   584\t\t\t\ttrace.exit(\"weaveAndDefineConceteAspects\", success);\n   585\t\t\t}\n   586\t\t\treturn success;\n   587\t\t}\n   588\t\n   589\t\t/**\n   590\t\t * Register the include / exclude filters. We duplicate simple patterns in startWith filters that will allow faster matching\n   591\t\t * without ResolvedType\n   592\t\t *\n   593\t\t * @param weaver\n   594\t\t * @param loader\n   595\t\t * @param definitions\n   596\t\t */\n   597\t\tprivate void registerIncludeExclude(final BcelWeaver weaver, final ClassLoader loader, final List<Definition> definitions) {\n   598\t\t\tString fastMatchInfo = null;\n   599\t\t\tfor (Definition definition : definitions) {\n   600\t\t\t\tfor (String value : definition.getIncludePatterns()) {\n   601\t\t\t\t\thasIncludes = true;\n   602\t\t\t\t\tString include = value;\n   603\t\t\t\t\tfastMatchInfo = looksLikeStartsWith(include);\n   604\t\t\t\t\tif (fastMatchInfo != null) {\n   605\t\t\t\t\t\tincludeStartsWith.add(fastMatchInfo);\n   606\t\t\t\t\t} else if (include.equals(\"*\")) {\n   607\t\t\t\t\t\tincludeStar = true;\n   608\t\t\t\t\t} else if ((fastMatchInfo = looksLikeExactName(include)) != null) {\n   609\t\t\t\t\t\tincludeExactName.add(fastMatchInfo);\n   610\t\t\t\t\t} else {\n   611\t\t\t\t\t\tTypePattern includePattern = new PatternParser(include).parseTypePattern();\n   612\t\t\t\t\t\tincludeTypePattern.add(includePattern);\n   613\t\t\t\t\t}\n   614\t\t\t\t}\n   615\t\t\t\tfor (String s : definition.getExcludePatterns()) {\n   616\t\t\t\t\thasExcludes = true;\n   617\t\t\t\t\tString exclude = s;\n   618\t\t\t\t\tfastMatchInfo = looksLikeStartsWith(exclude);\n   619\t\t\t\t\tif (fastMatchInfo != null) {\n   620\t\t\t\t\t\texcludeStartsWith.add(fastMatchInfo);\n   620\t\t\t\t\t\texcludeStartsWith.add(fastMatchInfo);\n   621\t\t\t\t\t} else if ((fastMatchInfo = looksLikeStarDotDotStarExclude(exclude)) != null) {\n   622\t\t\t\t\t\texcludeStarDotDotStar.add(fastMatchInfo);\n   623\t\t\t\t\t} else if ((fastMatchInfo = looksLikeExactName(exclude)) != null) {\n   624\t\t\t\t\t\texcludeExactName.add(exclude);\n   625\t\t\t\t\t} else if ((fastMatchInfo = looksLikeEndsWith(exclude)) != null) {\n   626\t\t\t\t\t\texcludeEndsWith.add(fastMatchInfo);\n   627\t\t\t\t\t} else if (exclude\n   628\t\t\t\t\t\t\t.equals(\"org.codehaus.groovy..* && !org.codehaus.groovy.grails.web.servlet.mvc.SimpleGrailsController*\")) {\n   629\t\t\t\t\t\t// TODO need a more sophisticated analysis here, to allow for similar situations\n   630\t\t\t\t\t\texcludeSpecial.add(new String[]{\"org.codehaus.groovy.\",\n   631\t\t\t\t\t\t\t\t\"org.codehaus.groovy.grails.web.servlet.mvc.SimpleGrailsController\"});\n   632\t\t\t\t\t\t// for the related test:\n   633\t\t\t\t\t\t// } else if (exclude.equals(\"testdata..* && !testdata.sub.Oran*\")) {\n   634\t\t\t\t\t\t// excludeSpecial.add(new String[] { \"testdata.\", \"testdata.sub.Oran\" });\n   635\t\t\t\t\t} else {\n   636\t\t\t\t\t\tTypePattern excludePattern = new PatternParser(exclude).parseTypePattern();\n   637\t\t\t\t\t\texcludeTypePattern.add(excludePattern);\n   638\t\t\t\t\t}\n   639\t\t\t\t}\n   640\t\t\t}\n   641\t\t}\n   642\t\n   643\t\t/**\n   644\t\t * Checks if the pattern looks like \"*..*XXXX*\" and if so returns XXXX. This will enable fast name matching of CGLIB exclusion\n   645\t\t *\n   646\t\t */\n   647\t\tprivate String looksLikeStarDotDotStarExclude(String typePattern) {\n   648\t\t\tif (!typePattern.startsWith(\"*..*\")) {\n   649\t\t\t\treturn null;\n   650\t\t\t}\n   651\t\t\tif (!typePattern.endsWith(\"*\")) {\n   652\t\t\t\treturn null;\n   653\t\t\t}\n   654\t\t\tString subPattern = typePattern.substring(4, typePattern.length() - 1);\n   655\t\t\tif (hasStarDot(subPattern, 0)) {\n   656\t\t\t\treturn null;\n   657\t\t\t}\n   658\t\t\treturn subPattern.replace('$', '.');\n   659\t\t}\n   660\t\n   661\t\t/**\n   662\t\t * Checks if the pattern looks like \"com.foo.Bar\" - an exact name\n   663\t\t */\n   664\t\tprivate String looksLikeExactName(String typePattern) {\n   665\t\t\tif (hasSpaceAnnotationPlus(typePattern, 0) || typePattern.contains(\"*\")) {\n   666\t\t\t\treturn null;\n   667\t\t\t}\n   668\t\t\treturn typePattern.replace('$', '.');\n   669\t\t}\n   670\t\n   671\t\t/**\n   672\t\t * Checks if the pattern looks like \"*Exception\"\n   673\t\t */\n   674\t\tprivate String looksLikeEndsWith(String typePattern) {\n   675\t\t\tif (typePattern.charAt(0) != '*') {\n   676\t\t\t\treturn null;\n   677\t\t\t}\n   678\t\t\tif (hasSpaceAnnotationPlus(typePattern, 1) || hasStarDot(typePattern, 1)) {\n   679\t\t\t\treturn null;\n   680\t\t\t}\n   681\t\t\treturn typePattern.substring(1).replace('$', '.');\n   682\t\t}\n   683\t\n   684\t\t/**\n   685\t\t * Determine if something in the string is going to affect our ability to optimize. Checks for: ' ' '@' '+'\n   686\t\t */\n   687\t\tprivate boolean hasSpaceAnnotationPlus(String string, int pos) {\n   688\t\t\tfor (int i = pos, max = string.length(); i < max; i++) {\n   689\t\t\t\tchar ch = string.charAt(i);\n   690\t\t\t\tif (ch == ' ' || ch == '@' || ch == '+') {\n   691\t\t\t\t\treturn true;\n   692\t\t\t\t}\n   693\t\t\t}\n   694\t\t\treturn false;\n   695\t\t}\n   696\t\n   697\t\t/**\n   698\t\t * Determine if something in the string is going to affect our ability to optimize. Checks for: '*' '.'\n   699\t\t */\n   700\t\tprivate boolean hasStarDot(String string, int pos) {\n   701\t\t\tfor (int i = pos, max = string.length(); i < max; i++) {\n   702\t\t\t\tchar ch = string.charAt(i);\n   703\t\t\t\tif (ch == '*' || ch == '.') {\n   704\t\t\t\t\treturn true;\n   705\t\t\t\t}\n   706\t\t\t}\n   707\t\t\treturn false;\n   708\t\t}\n   709\t\n   710\t\t/**\n   711\t\t * Checks if the type pattern looks like \"com.foo..*\"\n   712\t\t */\n   713\t\tprivate String looksLikeStartsWith(String typePattern) {\n   714\t\t\tif (hasSpaceAnnotationPlus(typePattern, 0) || typePattern.charAt(typePattern.length() - 1) != '*') {\n   715\t\t\t\treturn null;\n   716\t\t\t}\n   717\t\t\t// now must looks like with \"charsss..*\" or \"cha.rss..*\" etc\n   718\t\t\t// note that \"*\" and \"*..*\" won't be fast matched\n   719\t\t\t// and that \"charsss.*\" will not neither\n   720\t\t\tint length = typePattern.length();\n   721\t\t\tif (typePattern.endsWith(\"..*\") && length > 3) {\n   722\t\t\t\tif (typePattern.indexOf(\"..\") == length - 3 // no \"..\" before last sequence\n   723\t\t\t\t\t\t&& typePattern.indexOf('*') == length - 1) { // no earlier '*'\n   724\t\t\t\t\treturn typePattern.substring(0, length - 2).replace('$', '.'); // \"charsss.\" or \"char.rss.\" etc\n   725\t\t\t\t}\n   726\t\t\t}\n   727\t\t\treturn null;\n   728\t\t}\n   729\t\n   730\t\t/**\n   731\t\t * Register the dump filter\n   732\t\t *\n   733\t\t * @param weaver\n   734\t\t * @param loader\n   735\t\t * @param definitions\n   736\t\t */\n   737\t\tprivate void registerDump(final BcelWeaver weaver, final ClassLoader loader, final List<Definition> definitions) {\n   738\t\t\tfor (Definition definition : definitions) {\n   739\t\t\t\tfor (String dump : definition.getDumpPatterns()) {\n   740\t\t\t\t\tTypePattern pattern = new PatternParser(dump).parseTypePattern();\n   741\t\t\t\t\tdumpTypePattern.add(pattern);\n   742\t\t\t\t}\n   743\t\t\t\tif (definition.shouldDumpBefore()) {\n   744\t\t\t\t\tdumpBefore = true;\n   745\t\t\t\t}\n   746\t\t\t\tif (definition.createDumpDirPerClassloader()) {\n   747\t\t\t\t\tdumpDirPerClassloader = true;\n   748\t\t\t\t}\n   749\t\t\t}\n   750\t\t}\n   751\t\n   752\t\t/**\n   753\t\t * Determine whether a type should be accepted for weaving, by checking it against any includes/excludes.\n   754\t\t *\n   755\t\t * @param className the name of the type to possibly accept\n   756\t\t * @param bytes the bytecode for the type (in case we need to look inside, eg. annotations)\n   757\t\t * @return true if it should be accepted for weaving\n   758\t\t */\n   759\t\t@Override\n   760\t\tprotected boolean accept(String className, byte[] bytes) {\n   761\t\n   762\t\t\tif (!hasExcludes && !hasIncludes) {\n   763\t\t\t\treturn true;\n   764\t\t\t}\n   765\t\n   766\t\t\t// still try to avoid ResolvedType if we have simple patterns\n   767\t\t\tString fastClassName = className.replace('/', '.');\n   768\t\t\tfor (String excludeStartsWithString : excludeStartsWith) {\n   769\t\t\t\tif (fastClassName.startsWith(excludeStartsWithString)) {\n   770\t\t\t\t\treturn false;\n   771\t\t\t\t}\n   772\t\t\t}\n   773\t\n   774\t\t\t// Fast exclusion of patterns like: \"*..*CGLIB*\"\n   775\t\t\tif (!excludeStarDotDotStar.isEmpty()) {\n   776\t\t\t\tfor (String namePiece : excludeStarDotDotStar) {\n   777\t\t\t\t\tint index = fastClassName.lastIndexOf('.');\n   778\t\t\t\t\tif (fastClassName.indexOf(namePiece, index + 1) != -1) {\n   779\t\t\t\t\t\treturn false;\n   780\t\t\t\t\t}\n   781\t\t\t\t}\n   782\t\t\t}\n   783\t\t\tfastClassName = fastClassName.replace('$', '.');\n   784\t\n   785\t\t\tif (!excludeEndsWith.isEmpty()) {\n   786\t\t\t\tfor (String lastPiece : excludeEndsWith) {\n   787\t\t\t\t\tif (fastClassName.endsWith(lastPiece)) {\n   788\t\t\t\t\t\treturn false;\n   789\t\t\t\t\t}\n   790\t\t\t\t}\n   791\t\t\t}\n   792\t\n   793\t\t\t// Fast exclusion of exact names\n   794\t\t\tif (!excludeExactName.isEmpty()) {\n   795\t\t\t\tfor (String name : excludeExactName) {\n   796\t\t\t\t\tif (fastClassName.equals(name)) {\n   797\t\t\t\t\t\treturn false;\n   798\t\t\t\t\t}\n   799\t\t\t\t}\n   800\t\t\t}\n   801\t\n   802\t\t\tif (!excludeSpecial.isEmpty()) {\n   803\t\t\t\tfor (String[] entry : excludeSpecial) {\n   804\t\t\t\t\tString excludeThese = entry[0];\n   805\t\t\t\t\tString exceptThese = entry[1];\n   806\t\t\t\t\tif (fastClassName.startsWith(excludeThese) && !fastClassName.startsWith(exceptThese)) {\n   807\t\t\t\t\t\treturn false;\n   808\t\t\t\t\t}\n   809\t\t\t\t}\n   810\t\t\t}\n   811\t\n   812\t\t\t/*\n   813\t\t\t * Bug 120363 If we have an exclude pattern that cannot be matched using \"starts with\" then we cannot fast accept\n   814\t\t\t */\n   815\t\t\tboolean didSomeIncludeMatching = false;\n   816\t\t\tif (excludeTypePattern.isEmpty()) {\n   817\t\t\t\tif (includeStar) {\n   818\t\t\t\t\treturn true;\n   819\t\t\t\t}\n   820\t\t\t\tif (!includeExactName.isEmpty()) {\n   821\t\t\t\t\tdidSomeIncludeMatching = true;\n   822\t\t\t\t\tfor (String exactname : includeExactName) {\n   823\t\t\t\t\t\tif (fastClassName.equals(exactname)) {\n   824\t\t\t\t\t\t\treturn true;\n   825\t\t\t\t\t\t}\n   826\t\t\t\t\t}\n   827\t\t\t\t}\n   828\t\t\t\tboolean fastAccept = false;// defaults to false if no fast include\n   829\t\t\t\tfor (String s : includeStartsWith) {\n   830\t\t\t\t\tdidSomeIncludeMatching = true;\n   831\t\t\t\t\tfastAccept = fastClassName.startsWith(s);\n   832\t\t\t\t\tif (fastAccept) {\n   833\t\t\t\t\t\treturn true;\n   834\t\t\t\t\t}\n   835\t\t\t\t}\n   836\t\t\t\t// We may have processed all patterns now... check that and return\n   837\t\t\t\tif (includeTypePattern.isEmpty()) {\n   838\t\t\t\t\treturn !didSomeIncludeMatching;\n   839\t\t\t\t}\n   840\t\t\t}\n   841\t\n   842\t\t\tboolean accept;\n   843\t\t\ttry {\n   844\t\t\t\tensureDelegateInitialized(className, bytes);\n   845\t\n   846\t\t\t\tResolvedType classInfo = delegateForCurrentClass.getResolvedTypeX();\n   847\t\n   848\t\t\t\t// exclude are \"AND\"ed\n   849\t\t\t\tfor (TypePattern typePattern : excludeTypePattern) {\n   850\t\t\t\t\tif (typePattern.matchesStatically(classInfo)) {\n   850\t\t\t\t\tif (typePattern.matchesStatically(classInfo)) {\n   851\t\t\t\t\t\t// exclude match - skip\n   852\t\t\t\t\t\treturn false;\n   853\t\t\t\t\t}\n   854\t\t\t\t}\n   855\t\t\t\t// include are \"OR\"ed\n   856\t\t\t\tif (includeStar) {\n   857\t\t\t\t\treturn true;\n   858\t\t\t\t}\n   859\t\t\t\tif (!includeExactName.isEmpty()) {\n   860\t\t\t\t\tdidSomeIncludeMatching = true;\n   861\t\t\t\t\tfor (String exactname : includeExactName) {\n   862\t\t\t\t\t\tif (fastClassName.equals(exactname)) {\n   863\t\t\t\t\t\t\treturn true;\n   864\t\t\t\t\t\t}\n   865\t\t\t\t\t}\n   866\t\t\t\t}\n   867\t\t\t\tfor (String s : includeStartsWith) {\n   868\t\t\t\t\tdidSomeIncludeMatching = true;\n   869\t\t\t\t\tboolean fastaccept = fastClassName.startsWith(s);\n   870\t\t\t\t\tif (fastaccept) {\n   871\t\t\t\t\t\treturn true;\n   872\t\t\t\t\t}\n   873\t\t\t\t}\n   874\t\t\t\taccept = !didSomeIncludeMatching; // only true if no includes at all\n   875\t\t\t\tfor (TypePattern typePattern : includeTypePattern) {\n   876\t\t\t\t\taccept = typePattern.matchesStatically(classInfo);\n   877\t\t\t\t\tif (accept) {\n   878\t\t\t\t\t\tbreak;\n   879\t\t\t\t\t}\n   880\t\t\t\t\t// goes on if this include did not match (\"OR\"ed)\n   881\t\t\t\t}\n   882\t\t\t} finally {\n   883\t\t\t\tthis.bcelWorld.demote();\n   884\t\t\t}\n   885\t\t\treturn accept;\n   886\t\t}\n   887\t\n   888\t\t// FIXME we don't use include/exclude of others aop.xml\n   889\t\t// this can be nice but very dangerous as well to change that\n   890\t\tprivate boolean acceptAspect(String aspectClassName) {\n   891\t\t\t// avoid ResolvedType if not needed\n   892\t\t\tif (aspectExcludeTypePattern.isEmpty() && aspectIncludeTypePattern.isEmpty()) {\n   893\t\t\t\treturn true;\n   894\t\t\t}\n   895\t\n   896\t\t\t// still try to avoid ResolvedType if we have simple patterns\n   897\t\t\t// EXCLUDE: if one match then reject\n   898\t\t\tString fastClassName = aspectClassName.replace('/', '.').replace('.', '$');\n   899\t\t\tfor (String value : aspectExcludeStartsWith) {\n   900\t\t\t\tif (fastClassName.startsWith(value)) {\n   901\t\t\t\t\treturn false;\n   902\t\t\t\t}\n   903\t\t\t}\n   904\t\t\t// INCLUDE: if one match then accept\n   905\t\t\tfor (String s : aspectIncludeStartsWith) {\n   906\t\t\t\tif (fastClassName.startsWith(s)) {\n   907\t\t\t\t\treturn true;\n   908\t\t\t\t}\n   909\t\t\t}\n   910\t\n   911\t\t\t// needs further analysis\n   912\t\t\tResolvedType classInfo = weaver.getWorld().resolve(UnresolvedType.forName(aspectClassName), true);\n   913\t\t\t// exclude are \"AND\"ed\n   914\t\t\tfor (TypePattern typePattern: aspectExcludeTypePattern) {\n   915\t\t\t\tif (typePattern.matchesStatically(classInfo)) {\n   916\t\t\t\t\t// exclude match - skip\n   917\t\t\t\t\treturn false;\n   918\t\t\t\t}\n   919\t\t\t}\n   920\t\t\t// include are \"OR\"ed\n   921\t\t\tboolean accept = true;// defaults to true if no include\n   922\t\t\tfor (TypePattern typePattern: aspectIncludeTypePattern) {\n   923\t\t\t\taccept = typePattern.matchesStatically(classInfo);\n   924\t\t\t\tif (accept) {\n   925\t\t\t\t\tbreak;\n   926\t\t\t\t}\n   927\t\t\t\t// goes on if this include did not match (\"OR\"ed)\n   928\t\t\t}\n   929\t\t\treturn accept;\n   930\t\t}\n   931\t\n   932\t\t@Override\n   933\t\tprotected boolean shouldDump(String className, boolean before) {\n   934\t\t\t// Don't dump before weaving unless asked to\n   935\t\t\tif (before && !dumpBefore) {\n   936\t\t\t\treturn false;\n   937\t\t\t}\n   938\t\n   939\t\t\t// avoid ResolvedType if not needed\n   940\t\t\tif (dumpTypePattern.isEmpty()) {\n   941\t\t\t\treturn false;\n   942\t\t\t}\n   943\t\n   944\t\t\t// TODO AV - optimize for className.startWith only\n   945\t\t\tResolvedType classInfo = weaver.getWorld().resolve(UnresolvedType.forName(className), true);\n   946\t\t\t// dump\n   947\t\t\tfor (TypePattern typePattern : dumpTypePattern) {\n   948\t\t\t\tif (typePattern.matchesStatically(classInfo)) {\n   949\t\t\t\t\t// dump match\n   950\t\t\t\t\treturn true;\n   951\t\t\t\t}\n   952\t\t\t}\n   953\t\t\treturn false;\n   954\t\t}\n   955\t\n   956\t\t@Override\n   957\t\tprotected String getDumpDir() {\n   958\t\t\tif (dumpDirPerClassloader) {\n   959\t\t\t\tStringBuffer dir = new StringBuffer();\n   960\t\t\t\tdir.append(\"_ajdump\").append(File.separator).append(weavingContext.getId());\n   961\t\t\t\treturn dir.toString();\n   962\t\t\t} else {\n   963\t\t\t\treturn super.getDumpDir();\n   964\t\t\t}\n   965\t\t}\n   966\t\n   967\t\t/*\n   968\t\t * shared classes methods\n   969\t\t */\n   970\t\n   971\t\t/**\n   972\t\t * @return Returns the key.\n   973\t\t */\n   974\t\tpublic String getNamespace() {\n   975\t\t\t// System.out.println(\"ClassLoaderWeavingAdaptor.getNamespace() classloader=\" + weavingContext.getClassLoaderName() +\n   976\t\t\t// \", namespace=\" + namespace);\n   977\t\t\tif (namespace == null) {\n   978\t\t\t\treturn \"\";\n   979\t\t\t} else {\n   980\t\t\t\treturn new String(namespace);\n   981\t\t\t}\n   982\t\t}\n   983\t\n   984\t\t/**\n   985\t\t * Check to see if any classes are stored in the generated classes cache. Then flush the cache if it is not empty\n   986\t\t *\n   987\t\t * @param className TODO\n   988\t\t * @return true if a class has been generated and is stored in the cache\n   989\t\t */\n   990\t\tpublic boolean generatedClassesExistFor(String className) {\n   991\t\t\t// System.err.println(\"? ClassLoaderWeavingAdaptor.generatedClassesExist() classname=\" + className + \", size=\" +\n   992\t\t\t// generatedClasses);\n   993\t\t\tif (className == null) {\n   994\t\t\t\treturn !generatedClasses.isEmpty();\n   995\t\t\t} else {\n   996\t\t\t\treturn generatedClasses.containsKey(className);\n   997\t\t\t}\n   998\t\t}\n   999\t\n  1000\t\t/**\n  1001\t\t * Flush the generated classes cache\n  1002\t\t */\n  1003\t\tpublic void flushGeneratedClasses() {\n  1004\t\t\t// System.err.println(\"? ClassLoaderWeavingAdaptor.flushGeneratedClasses() generatedClasses=\" + generatedClasses);\n  1005\t\t\tgeneratedClasses = new HashMap<>();\n  1006\t\t}\n  1007\t\n  1008\t\t/**\n  1009\t\t * Remove generated classes based on the supplied className. This will\n  1010\t\t * remove any entries related to this name - so the class itself plus\n  1130\t\t\t\ttrace.exit(\"defineClass\", clazz);\n  1131\t\t\t}\n  1132\t\t}\n  1133\t\tstatic Method defineClassMethod;\n  1134\t\tprivate static String lock = \"lock\";\n  1135\t\n  1136\t\n  1137\t//    /*\n  1138\t//    This method is equivalent to the following code but use reflection to compile on Java 7:\n  1139\t//     MethodHandles.Lookup baseLookup = MethodHandles.lookup();\n  1140\t//    MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(ClassLoader.class, baseLookup);\n  1141\t//    MethodHandle defineClassMethodHandle = lookup.findVirtual(ClassLoader.class, \"defineClass\", defineClassMethodType);\n  1142\t//    handle.bindTo(classLoader).invokeWithArguments(className, classBytes, 0, classBytes.length));\n  1143\t// */\n  1144\t//@Override\n  1145\t//@SuppressWarnings(\"unchecked\")\n  1146\t//public <T> Class<T> defineClass(ClassLoader classLoader, String className, byte[] classBytes) {\n  1147\t//    Object baseLookup = methodHandlesLookup.invoke(null);\n  1148\t//    Object lookup = methodHandlesPrivateLookupIn.invoke(null, ClassLoader.class, baseLookup);\n  1149\t//    MethodHandle defineClassMethodHandle = (MethodHandle) lookupFindVirtual.invoke(lookup, ClassLoader.class, \"defineClass\", defineClassMethodType);\n  1150\t//    try {\n  1151\t//        return Cast.uncheckedCast(defineClassMethodHandle.bindTo(classLoader).invokeWithArguments(className, classBytes, 0, classBytes.length));\n  1152\t//    } catch (Throwable throwable) {\n  1153\t//        throw new RuntimeException(throwable);\n  1154\t//        return (Class) defineClassMethodHandle.bindTo(classLoader).invokeWithArguments(className, classBytes, 0, classBytes.length);\n  1155\t//    } catch (Throwable e) {\n  1156\t//        throw new RuntimeException(e);\n  1157\t//    }\n  1158\t//}\n  1159\t\n  1160\t\tprivate void defineClass(ClassLoader loader, String name, byte[] bytes){\n  1161\t\t\tdefineClass(loader,name,bytes,null);//, ProtectionDomain protectionDomain) {\n  1162\t\t}\n  1163\t//\t\tif (trace.isTraceEnabled()) {\n  1164\t//\t\t\ttrace.enter(\"defineClass\", this, new Object[] { loader, name, bytes, protectionDomain });\n  1165\t//\t\t}\n  1166\t//\t\tObject clazz = null;\n  1167\t//\t\tdebug(\"generating class '\" + name + \"'\");\n  1168\t//\t\ttry {\n  1169\t//\t\t\tgetUnsafe().defineClass(name, bytes, 0, bytes.length, loader, protectionDomain);\n  1170\t//\t\t} catch (LinkageError le) {\n  1171\t//\t\t\t// likely thrown due to defining something that already exists?\n  1172\t//\t\t\t// Old comments from before moving to Unsafe.defineClass():\n  1173\t//\t\t\t// is already defined (happens for X$ajcMightHaveAspect interfaces since aspects are reweaved)\n  1174\t//\t\t\t// TODO maw I don't think this is OK and\n  1175\t//\t\t} catch (Exception e) {\n  1176\t//\t\t\twarn(\"define generated class failed\", e);\n  1177\t//\t\t}\n  1178\t//\n  1179\t//\t\tif (trace.isTraceEnabled()) {\n  1180\t//\t\t\ttrace.exit(\"defineClass\", clazz);\n"}], "isError": false, "timestamp": 1777431137237}}
[recv] {"type": "message_end", "message": {"role": "toolResult", "toolCallId": "call_cyq4PzVBxCDIef1RmQHgaLE3|fc_0417ab6ecc6edbf40169f172606e788192af98cb67509029d5", "toolName": "bash", "content": [{"type": "text", "text": "     1\t/*******************************************************************************\n     2\t * Copyright (c) 2005, 2017 Contributors.\n     3\t * All rights reserved.\n     4\t * This program and the accompanying materials are made available\n     5\t * under the terms of the Eclipse Public License v 2.0\n     6\t * which accompanies this distribution and is available at\n     7\t * https://www.eclipse.org/org/documents/epl-2.0/EPL-2.0.txt\n     8\t *******************************************************************************/\n     9\tpackage org.aspectj.weaver.loadtime;\n    10\t\n    11\timport java.io.File;\n    12\timport java.io.IOException;\n    13\timport java.io.InputStream;\n    14\timport java.lang.reflect.Field;\n    15\timport java.lang.reflect.Method;\n    16\timport java.net.MalformedURLException;\n    17\timport java.net.URL;\n    18\timport java.security.ProtectionDomain;\n    19\timport java.util.ArrayList;\n    20\timport java.util.Enumeration;\n    21\timport java.util.HashMap;\n    22\timport java.util.HashSet;\n    23\timport java.util.Iterator;\n    24\timport java.util.LinkedList;\n    25\timport java.util.List;\n    26\timport java.util.Map;\n    27\timport java.util.Map.Entry;\n    28\timport java.util.Properties;\n    29\timport java.util.Set;\n    30\timport java.util.StringTokenizer;\n    31\t\n    32\timport org.aspectj.bridge.AbortException;\n    33\timport org.aspectj.bridge.Constants;\n    34\timport org.aspectj.bridge.MessageUtil;\n    35\timport org.aspectj.util.LangUtil;\n    36\timport org.aspectj.weaver.IUnwovenClassFile;\n    37\timport org.aspectj.weaver.Lint;\n    38\timport org.aspectj.weaver.Lint.Kind;\n    39\timport org.aspectj.weaver.ResolvedType;\n    40\timport org.aspectj.weaver.UnresolvedType;\n    41\timport org.aspectj.weaver.World;\n    42\timport org.aspectj.weaver.bcel.BcelWeakClassLoaderReference;\n    43\timport org.aspectj.weaver.bcel.BcelWeaver;\n    44\timport org.aspectj.weaver.bcel.BcelWorld;\n    45\timport org.aspectj.weaver.bcel.Utility;\n    46\timport org.aspectj.weaver.loadtime.definition.Definition;\n    47\timport org.aspectj.weaver.loadtime.definition.DocumentParser;\n    48\timport org.aspectj.weaver.ltw.LTWWorld;\n    49\timport org.aspectj.weaver.patterns.PatternParser;\n    50\timport org.aspectj.weaver.patterns.TypePattern;\n    51\timport org.aspectj.weaver.tools.GeneratedClassHandler;\n    52\timport org.aspectj.weaver.tools.Trace;\n    53\timport org.aspectj.weaver.tools.TraceFactory;\n    54\timport org.aspectj.weaver.tools.WeavingAdaptor;\n    55\timport org.aspectj.weaver.tools.cache.WeavedClassCache;\n    56\t\n    57\timport sun.misc.Unsafe;\n    58\t\n    59\t/**\n    60\t * @author Alexandre Vasseur\n    61\t * @author Andy Clement\n    62\t * @author Abraham Nevado\n    63\t * @author David Knibb\n    64\t * @author John Kew\n    65\t */\n    66\tpublic class ClassLoaderWeavingAdaptor extends WeavingAdaptor {\n    67\t\n    68\t\tprivate final static String AOP_XML = Constants.AOP_USER_XML + \";\" + Constants.AOP_AJC_XML + \";\" + Constants.AOP_OSGI_XML;\n    69\t\n    70\t\tprivate boolean initialized;\n    71\t\n    72\t\tprivate List<TypePattern> dumpTypePattern = new ArrayList<>();\n    73\t\tprivate boolean dumpBefore = false;\n    74\t\tprivate boolean dumpDirPerClassloader = false;\n    75\t\n    76\t\tprivate boolean hasExcludes = false;\n    77\t\tprivate List<TypePattern> excludeTypePattern = new ArrayList<>(); // anything\n    78\t\tprivate List<String> excludeStartsWith = new ArrayList<>(); // com.foo..*\n    79\t\tprivate List<String> excludeStarDotDotStar = new ArrayList<>(); // *..*CGLIB*\n    80\t\tprivate List<String> excludeExactName = new ArrayList<>(); // com.foo.Bar\n    81\t\tprivate List<String> excludeEndsWith = new ArrayList<>(); // com.foo.Bar\n    82\t\tprivate List<String[]> excludeSpecial = new ArrayList<>();\n    83\t\n    84\t\tprivate boolean hasIncludes = false;\n    85\t\tprivate List<TypePattern> includeTypePattern = new ArrayList<>();\n    86\t\tprivate List<String> includeStartsWith = new ArrayList<>();\n    87\t\tprivate List<String> includeExactName = new ArrayList<>();\n    88\t\tprivate boolean includeStar = false;\n    89\t\n    90\t\tprivate List<TypePattern> aspectExcludeTypePattern = new ArrayList<>();\n    91\t\tprivate List<String> aspectExcludeStartsWith = new ArrayList<>();\n    92\t\tprivate List<TypePattern> aspectIncludeTypePattern = new ArrayList<>();\n    93\t\tprivate List<String> aspectIncludeStartsWith = new ArrayList<>();\n    94\t\n    95\t\tprivate StringBuffer namespace;\n    96\t\tprivate IWeavingContext weavingContext;\n    97\t\n    98\t\tprivate List<ConcreteAspectCodeGen> concreteAspects = new ArrayList<>();\n    99\t\n   100\t\tprivate static Trace trace = TraceFactory.getTraceFactory().getTrace(ClassLoaderWeavingAdaptor.class);\n   101\t\n   102\t\tpublic ClassLoaderWeavingAdaptor() {\n   103\t\t\tsuper();\n   104\t\t\tif (trace.isTraceEnabled()) {\n   105\t\t\t\ttrace.enter(\"<init>\", this);\n   106\t\t\t}\n   107\t\t\tif (trace.isTraceEnabled()) {\n   108\t\t\t\ttrace.exit(\"<init>\");\n   109\t\t\t}\n   110\t\t}\n   111\t\n   112\t\t/**\n   113\t\t * We don't need a reference to the class loader and using it during construction can cause problems with recursion. It also\n   114\t\t * makes sense to supply the weaving context during initialization to.\n   115\t\t *\n   116\t\t * @deprecated\n   117\t\t */\n   118\t\t@Deprecated\n   119\t\tpublic ClassLoaderWeavingAdaptor(final ClassLoader deprecatedLoader, final IWeavingContext deprecatedContext) {\n   120\t\t\tsuper();\n   121\t\t\tif (trace.isTraceEnabled()) {\n   122\t\t\t\ttrace.enter(\"<init>\", this, new Object[] { deprecatedLoader, deprecatedContext });\n   123\t\t\t}\n   124\t\t\tif (trace.isTraceEnabled()) {\n   125\t\t\t\ttrace.exit(\"<init>\");\n   126\t\t\t}\n   127\t\t}\n   128\t\n   129\t\tclass SimpleGeneratedClassHandler implements GeneratedClassHandler {\n   130\t\t\tprivate BcelWeakClassLoaderReference loaderRef;\n   131\t\n   132\t\t\tSimpleGeneratedClassHandler(ClassLoader loader) {\n   133\t\t\t\tloaderRef = new BcelWeakClassLoaderReference(loader);\n   134\t\t\t}\n   135\t\n   136\t\t\t/**\n   137\t\t\t * Callback when we need to define a Closure in the JVM\n   138\t\t\t *\n   139\t\t\t */\n   140\t\t\t@Override\n   141\t\t\tpublic void acceptClass (String name, byte[] originalBytes, byte[] wovenBytes) {\n   142\t\t\t\ttry {\n   143\t\t\t\t\tif (shouldDump(name.replace('/', '.'), false)) {\n   144\t\t\t\t\t\tdump(name, wovenBytes, false);\n   145\t\t\t\t\t}\n   146\t\t\t\t} catch (Throwable throwable) {\n   147\t\t\t\t\tthrowable.printStackTrace();\n   148\t\t\t\t}\n   149\t\t\t\tif (activeProtectionDomain != null) {\n   150\t\t\t\t\tdefineClass(loaderRef.getClassLoader(), name, wovenBytes, activeProtectionDomain);\n   151\t\t\t\t} else {\n   152\t\t\t\t\tdefineClass(loaderRef.getClassLoader(), name, wovenBytes); // could be done lazily using the hook\n   153\t\t\t\t}\n   154\t\t\t}\n   155\t\t}\n   156\t\n   157\t\tpublic void initialize(final ClassLoader classLoader, IWeavingContext context) {\n   158\t\t\tif (initialized) {\n   159\t\t\t\treturn;\n   160\t\t\t}\n   161\t\n   162\t\t\tboolean success = true;\n   163\t\n   164\t\t\tthis.weavingContext = context;\n   165\t\t\tif (weavingContext == null) {\n   166\t\t\t\tweavingContext = new DefaultWeavingContext(classLoader);\n   167\t\t\t}\n   168\t\n   169\t\t\tcreateMessageHandler();\n   170\t\n   171\t\t\tthis.generatedClassHandler = new SimpleGeneratedClassHandler(classLoader);\n   172\t\n   173\t\t\tList<Definition> definitions = weavingContext.getDefinitions(classLoader, this);\n   174\t\t\tif (definitions.isEmpty()) {\n   175\t\t\t\tdisable(); // TODO maw Needed to ensure messages are flushed\n   176\t\t\t\tif (trace.isTraceEnabled()) {\n   177\t\t\t\t\ttrace.exit(\"initialize\", definitions);\n   178\t\t\t\t}\n   179\t\t\t\treturn;\n   180\t\t\t}\n   180\t\t\t}\n   181\t\n   182\t\t\t// TODO when the world works in terms of the context, we can remove the loader\n   183\t\t\tbcelWorld = new LTWWorld(classLoader, weavingContext, getMessageHandler(), null);\n   184\t\n   185\t\t\tweaver = new BcelWeaver(bcelWorld);\n   186\t\n   187\t\t\t// register the definitions\n   188\t\t\tsuccess = registerDefinitions(weaver, classLoader, definitions);\n   189\t\t\tif (success) {\n   190\t\n   191\t\t\t\t// after adding aspects\n   192\t\t\t\tweaver.prepareForWeave();\n   193\t\n   194\t\t\t\tenable(); // TODO maw Needed to ensure messages are flushed\n   195\t\t\t\tsuccess = weaveAndDefineConceteAspects();\n   196\t\t\t}\n   197\t\n   198\t\t\tif (success) {\n   199\t\t\t\tenable();\n   200\t\t\t} else {\n   201\t\t\t\tdisable();\n   202\t\t\t\tbcelWorld = null;\n   203\t\t\t\tweaver = null;\n   204\t\t\t}\n   205\t\t\tif (WeavedClassCache.isEnabled()) {\n   206\t\t\t\tinitializeCache(classLoader, getAspectClassNames(definitions), generatedClassHandler, getMessageHandler());\n   207\t\t\t}\n   208\t\n   209\t\t\tinitialized = true;\n   210\t\t\tif (trace.isTraceEnabled()) {\n   211\t\t\t\ttrace.exit(\"initialize\", isEnabled());\n   212\t\t\t}\n   213\t\t}\n   214\t\n   215\t\t/**\n   216\t\t * Get the list of all aspects from the defintion list\n   217\t\t * @param definitions\n   218\t\t * @return\n   219\t\t */\n   220\t\tList<String> getAspectClassNames(List<Definition> definitions) {\n   221\t\t\tList<String> aspects = new LinkedList<>();\n   222\t\t\tfor (Definition def : definitions) {\n   223\t\t\t\tList<String> defAspects = def.getAspectClassNames();\n   224\t\t\t\tif (defAspects != null) {\n   225\t\t\t\t\taspects.addAll(defAspects);\n   226\t\t\t\t}\n   227\t\t\t}\n   228\t\t\treturn aspects;\n   229\t\t}\n   230\t\n   231\t\t/**\n   232\t\t * Load and cache the aop.xml/properties according to the classloader visibility rules\n   233\t\t *\n   234\t\t * @param loader\n   235\t\t */\n   236\t\tList<Definition> parseDefinitions(final ClassLoader loader) {\n   237\t\t\tif (trace.isTraceEnabled()) {\n   238\t\t\t\ttrace.enter(\"parseDefinitions\", this);\n   239\t\t\t}\n   240\t\n   241\t\t\tList<Definition> definitions = new ArrayList<>();\n   242\t\t\ttry {\n   243\t\t\t\tinfo(\"register classloader \" + getClassLoaderName(loader));\n   244\t\t\t\t// TODO av underoptimized: we will parse each XML once per CL that see it\n   245\t\n   246\t\t\t\t// TODO av dev mode needed ? TBD -Daj5.def=...\n   247\t\t\t\tif (loader.equals(ClassLoader.getSystemClassLoader())) {\n   248\t\t\t\t\tString file = System.getProperty(\"aj5.def\", null);\n   249\t\t\t\t\tif (file != null) {\n   250\t\t\t\t\t\tinfo(\"using (-Daj5.def) \" + file);\n   251\t\t\t\t\t\tdefinitions.add(DocumentParser.parse((new File(file)).toURI().toURL()));\n   252\t\t\t\t\t}\n   253\t\t\t\t}\n   254\t\n   255\t\t\t\tString resourcePath = System.getProperty(\"org.aspectj.weaver.loadtime.configuration\", AOP_XML);\n   256\t\t\t\tif (trace.isTraceEnabled()) {\n   257\t\t\t\t\ttrace.event(\"parseDefinitions\", this, resourcePath);\n   258\t\t\t\t}\n   259\t\n   260\t\t\t\tStringTokenizer st = new StringTokenizer(resourcePath, \";\");\n   261\t\n   262\t\t\t\twhile (st.hasMoreTokens()) {\n   263\t\t\t\t\tString nextDefinition = st.nextToken();\n   264\t\t\t\t\tif (nextDefinition.startsWith(\"file:\")) {\n   265\t\t\t\t\t\ttry {\n   266\t\t\t\t\t\t\tString fpath = new URL(nextDefinition).getFile();\n   267\t\t\t\t\t\t\tFile configFile = new File(fpath);\n   268\t\t\t\t\t\t\tif (!configFile.exists()) {\n   269\t\t\t\t\t\t\t\twarn(\"configuration does not exist: \" + nextDefinition);\n   270\t\t\t\t\t\t\t} else {\n   271\t\t\t\t\t\t\t\tdefinitions.add(DocumentParser.parse(configFile.toURI().toURL()));\n   272\t\t\t\t\t\t\t}\n   273\t\t\t\t\t\t} catch (MalformedURLException mue) {\n   274\t\t\t\t\t\t\terror(\"malformed definition url: \" + nextDefinition);\n   275\t\t\t\t\t\t}\n   276\t\t\t\t\t} else {\n   277\t\t\t\t\t\tEnumeration<URL> xmls = weavingContext.getResources(nextDefinition);\n   278\t\t\t\t\t\t// System.out.println(\"? registerDefinitions: found-aop.xml=\" + xmls.hasMoreElements() + \", loader=\" + loader);\n   279\t\n   280\t\t\t\t\t\tSet<URL> seenBefore = new HashSet<>();\n   281\t\t\t\t\t\twhile (xmls.hasMoreElements()) {\n   282\t\t\t\t\t\t\tURL xml = xmls.nextElement();\n   283\t\t\t\t\t\t\tif (trace.isTraceEnabled()) {\n   284\t\t\t\t\t\t\t\ttrace.event(\"parseDefinitions\", this, xml);\n   285\t\t\t\t\t\t\t}\n   286\t\t\t\t\t\t\tif (!seenBefore.contains(xml)) {\n   287\t\t\t\t\t\t\t\tinfo(\"using configuration \" + weavingContext.getFile(xml));\n   288\t\t\t\t\t\t\t\tdefinitions.add(DocumentParser.parse(xml));\n   289\t\t\t\t\t\t\t\tseenBefore.add(xml);\n   290\t\t\t\t\t\t\t} else {\n   291\t\t\t\t\t\t\t\tdebug(\"ignoring duplicate definition: \" + xml);\n   292\t\t\t\t\t\t\t}\n   293\t\t\t\t\t\t}\n   294\t\t\t\t\t}\n   295\t\t\t\t}\n   296\t\t\t\tif (definitions.isEmpty()) {\n   297\t\t\t\t\tinfo(\"no configuration found. Disabling weaver for class loader \" + getClassLoaderName(loader));\n   298\t\t\t\t}\n   299\t\t\t} catch (Exception e) {\n   300\t\t\t\tdefinitions.clear();\n   301\t\t\t\twarn(\"parse definitions failed\", e);\n   302\t\t\t}\n   303\t\n   304\t\t\tif (trace.isTraceEnabled()) {\n   305\t\t\t\ttrace.exit(\"parseDefinitions\", definitions);\n   306\t\t\t}\n   307\t\t\treturn definitions;\n   308\t\t}\n   309\t\n   310\t\tprivate boolean registerDefinitions(final BcelWeaver weaver, final ClassLoader loader, List<Definition> definitions) {\n   311\t\t\tif (trace.isTraceEnabled()) {\n   312\t\t\t\ttrace.enter(\"registerDefinitions\", this, definitions);\n   313\t\t\t}\n   314\t\t\tboolean success = true;\n   315\t\n   316\t\t\ttry {\n   317\t\t\t\tregisterOptions(weaver, loader, definitions);\n   318\t\t\t\tregisterAspectExclude(weaver, loader, definitions);\n   319\t\t\t\tregisterAspectInclude(weaver, loader, definitions);\n   320\t\t\t\tsuccess = registerAspects(weaver, loader, definitions);\n   321\t\t\t\tregisterIncludeExclude(weaver, loader, definitions);\n   322\t\t\t\tregisterDump(weaver, loader, definitions);\n   323\t\t\t} catch (Exception ex) {\n   324\t\t\t\ttrace.error(\"register definition failed\", ex);\n   325\t\t\t\tsuccess = false;\n   326\t\t\t\twarn(\"register definition failed\", (ex instanceof AbortException) ? null : ex);\n   327\t\t\t}\n   328\t\n   329\t\t\tif (trace.isTraceEnabled()) {\n   330\t\t\t\ttrace.exit(\"registerDefinitions\", success);\n   420\t\t\t\t\tif (weaverOption.lint.equals(\"ignore\")) {\n   421\t\t\t\t\t\tbcelWorld.setAllLintIgnored();\n   422\t\t\t\t\t}\n   423\t\t\t\t}\n   424\t\t\t}\n   425\t\t\t// TODO proceedOnError option\n   426\t\t}\n   427\t\n   428\t\tprivate void registerAspectExclude(final BcelWeaver weaver, final ClassLoader loader, final List<Definition> definitions) {\n   429\t\t\tString fastMatchInfo = null;\n   430\t\t\tfor (Definition definition : definitions) {\n   431\t\t\t\tfor (String exclude : definition.getAspectExcludePatterns()) {\n   432\t\t\t\t\tTypePattern excludePattern = new PatternParser(exclude).parseTypePattern();\n   433\t\t\t\t\taspectExcludeTypePattern.add(excludePattern);\n   434\t\t\t\t\tfastMatchInfo = looksLikeStartsWith(exclude);\n   435\t\t\t\t\tif (fastMatchInfo != null) {\n   436\t\t\t\t\t\taspectExcludeStartsWith.add(fastMatchInfo);\n   437\t\t\t\t\t}\n   438\t\t\t\t}\n   439\t\t\t}\n   440\t\t}\n   441\t\n   442\t\tprivate void registerAspectInclude(final BcelWeaver weaver, final ClassLoader loader, final List<Definition> definitions) {\n   443\t\t\tString fastMatchInfo = null;\n   444\t\t\tfor (Definition definition : definitions) {\n   445\t\t\t\tfor (String include : definition.getAspectIncludePatterns()) {\n   446\t\t\t\t\tTypePattern includePattern = new PatternParser(include).parseTypePattern();\n   447\t\t\t\t\taspectIncludeTypePattern.add(includePattern);\n   448\t\t\t\t\tfastMatchInfo = looksLikeStartsWith(include);\n   449\t\t\t\t\tif (fastMatchInfo != null) {\n   450\t\t\t\t\t\taspectIncludeStartsWith.add(fastMatchInfo);\n   451\t\t\t\t\t}\n   452\t\t\t\t}\n   453\t\t\t}\n   454\t\t}\n   455\t\n   456\t\tprotected void lint(String name, String[] infos) {\n   457\t\t\tLint lint = bcelWorld.getLint();\n   458\t\t\tKind kind = lint.getLintKind(name);\n   459\t\t\tkind.signal(infos, null, null);\n   460\t\t}\n   461\t\n   462\t\t@Override\n   463\t\tpublic String getContextId() {\n   464\t\t\treturn weavingContext.getId();\n   465\t\t}\n   466\t\n   467\t\t/**\n   468\t\t * Register the aspect, following include / exclude rules\n   469\t\t *\n   470\t\t * @param weaver\n   471\t\t * @param loader\n   472\t\t * @param definitions\n   473\t\t */\n   474\t\tprivate boolean registerAspects(final BcelWeaver weaver, final ClassLoader loader, final List<Definition> definitions) {\n   475\t\t\tif (trace.isTraceEnabled()) {\n   476\t\t\t\ttrace.enter(\"registerAspects\", this, new Object[] { weaver, loader, definitions });\n   477\t\t\t}\n   478\t\t\tboolean success = true;\n   479\t\n   480\t\t\t// TODO: the exclude aspect allow to exclude aspect defined upper in the CL hierarchy - is it what we want ??\n   481\t\t\t// if not, review the getResource so that we track which resource is defined by which CL\n   482\t\n   483\t\t\t// iterate aspectClassNames\n   484\t\t\t// exclude if in any of the exclude list\n   485\t\t\tfor (Definition definition : definitions) {\n   486\t\t\t\tfor (String aspectClassName : definition.getAspectClassNames()) {\n   487\t\t\t\t\tif (acceptAspect(aspectClassName)) {\n   488\t\t\t\t\t\tinfo(\"register aspect \" + aspectClassName);\n   489\t\t\t\t\t\t// System.err.println(\"? ClassLoaderWeavingAdaptor.registerAspects() aspectName=\" + aspectClassName +\n   490\t\t\t\t\t\t// \", loader=\" + loader + \", bundle=\" + weavingContext.getClassLoaderName());\n   491\t\t\t\t\t\tString requiredType = definition.getAspectRequires(aspectClassName);\n   492\t\t\t\t\t\tif (requiredType != null) {\n   493\t\t\t\t\t\t\t// This aspect expresses that it requires a type to be around, otherwise it should 'switch off'\n   494\t\t\t\t\t\t\t((BcelWorld) weaver.getWorld()).addAspectRequires(aspectClassName, requiredType);\n   495\t\t\t\t\t\t}\n   496\t\t\t\t\t\tString definedScope = definition.getScopeForAspect(aspectClassName);\n   497\t\t\t\t\t\tif (definedScope != null) {\n   498\t\t\t\t\t\t\t((BcelWorld) weaver.getWorld()).addScopedAspect(aspectClassName, definedScope);\n   499\t\t\t\t\t\t}\n   500\t\t\t\t\t\t// ResolvedType aspect =\n   501\t\t\t\t\t\tweaver.addLibraryAspect(aspectClassName);\n   502\t\n   503\t\t\t\t\t\t// generate key for SC\n   504\t\t\t\t\t\tif (namespace == null) {\n   505\t\t\t\t\t\t\tnamespace = new StringBuffer(aspectClassName);\n   506\t\t\t\t\t\t} else {\n   507\t\t\t\t\t\t\tnamespace = namespace.append(\";\").append(aspectClassName);\n   508\t\t\t\t\t\t}\n   509\t\n   510\t\t\t\t\t} else {\n   511\t\t\t\t\t\t// warn(\"aspect excluded: \" + aspectClassName);\n   512\t\t\t\t\t\tlint(\"aspectExcludedByConfiguration\", new String[] { aspectClassName, getClassLoaderName(loader) });\n   513\t\t\t\t\t}\n   514\t\t\t\t}\n   515\t\t\t}\n   516\t\n   517\t\t\t// iterate concreteAspects\n   518\t\t\t// exclude if in any of the exclude list - note that the user defined name matters for that to happen\n   519\t\t\tfor (Definition definition : definitions) {\n   520\t\t\t\tfor (Definition.ConcreteAspect concreteAspect : definition.getConcreteAspects()) {\n   521\t\t\t\t\tif (acceptAspect(concreteAspect.name)) {\n   522\t\t\t\t\t\tinfo(\"define aspect \" + concreteAspect.name);\n   523\t\t\t\t\t\tConcreteAspectCodeGen gen = new ConcreteAspectCodeGen(concreteAspect, weaver.getWorld());\n   524\t\t\t\t\t\tif (!gen.validate()) {\n   525\t\t\t\t\t\t\terror(\"Concrete-aspect '\" + concreteAspect.name + \"' could not be registered\");\n   526\t\t\t\t\t\t\tsuccess = false;\n   527\t\t\t\t\t\t\tbreak;\n   528\t\t\t\t\t\t}\n   529\t\n   530\t\t\t\t\t\t((BcelWorld) weaver.getWorld()).addSourceObjectType(Utility.makeJavaClass(concreteAspect.name, gen.getBytes()),\n   531\t\t\t\t\t\t\t\ttrue);\n   532\t\n   533\t\t\t\t\t\tconcreteAspects.add(gen);\n   534\t\n   535\t\t\t\t\t\tweaver.addLibraryAspect(concreteAspect.name);\n   536\t\n   537\t\t\t\t\t\t// generate key for SC\n   538\t\t\t\t\t\tif (namespace == null) {\n   539\t\t\t\t\t\t\tnamespace = new StringBuffer(concreteAspect.name);\n   540\t\t\t\t\t\t} else {\n   541\t\t\t\t\t\t\tnamespace = namespace.append(\";\" + concreteAspect.name);\n   542\t\t\t\t\t\t}\n   543\t\t\t\t\t}\n   544\t\t\t\t}\n   545\t\t\t}\n   546\t\n   547\t\t\t/* We couldn't register one or more aspects so disable the adaptor */\n   548\t\t\tif (!success) {\n   549\t\t\t\twarn(\"failure(s) registering aspects. Disabling weaver for class loader \" + getClassLoaderName(loader));\n   550\t\t\t}\n   551\t\n   552\t\t\t/* We didn't register any aspects so disable the adaptor */\n   553\t\t\telse if (namespace == null) {\n   554\t\t\t\tsuccess = false;\n   555\t\t\t\tinfo(\"no aspects registered. Disabling weaver for class loader \" + getClassLoaderName(loader));\n   556\t\t\t}\n   557\t\n   558\t\t\tif (trace.isTraceEnabled()) {\n   559\t\t\t\ttrace.exit(\"registerAspects\", success);\n   560\t\t\t}\n   561\t\t\treturn success;\n   562\t\t}\n   563\t\n   564\t\tprivate boolean weaveAndDefineConceteAspects() {\n   565\t\t\tif (trace.isTraceEnabled()) {\n   566\t\t\t\ttrace.enter(\"weaveAndDefineConceteAspects\", this, concreteAspects);\n   567\t\t\t}\n   568\t\t\tboolean success = true;\n   569\t\n   570\t\t\tfor (ConcreteAspectCodeGen gen : concreteAspects) {\n   571\t\t\t\tString name = gen.getClassName();\n   572\t\t\t\tbyte[] bytes = gen.getBytes();\n   573\t\n   574\t\t\t\ttry {\n   575\t\t\t\t\tbyte[] newBytes = weaveClass(name, bytes, true);\n   576\t\t\t\t\tthis.generatedClassHandler.acceptClass(name, bytes, newBytes);\n   577\t\t\t\t} catch (IOException ex) {\n   578\t\t\t\t\ttrace.error(\"weaveAndDefineConceteAspects\", ex);\n   579\t\t\t\t\terror(\"exception weaving aspect '\" + name + \"'\", ex);\n   580\t\t\t\t}\n   581\t\t\t}\n   582\t\n   583\t\t\tif (trace.isTraceEnabled()) {\n   584\t\t\t\ttrace.exit(\"weaveAndDefineConceteAspects\", success);\n   585\t\t\t}\n   586\t\t\treturn success;\n   587\t\t}\n   588\t\n   589\t\t/**\n   590\t\t * Register the include / exclude filters. We duplicate simple patterns in startWith filters that will allow faster matching\n   591\t\t * without ResolvedType\n   592\t\t *\n   593\t\t * @param weaver\n   594\t\t * @param loader\n   595\t\t * @param definitions\n   596\t\t */\n   597\t\tprivate void registerIncludeExclude(final BcelWeaver weaver, final ClassLoader loader, final List<Definition> definitions) {\n   598\t\t\tString fastMatchInfo = null;\n   599\t\t\tfor (Definition definition : definitions) {\n   600\t\t\t\tfor (String value : definition.getIncludePatterns()) {\n   601\t\t\t\t\thasIncludes = true;\n   602\t\t\t\t\tString include = value;\n   603\t\t\t\t\tfastMatchInfo = looksLikeStartsWith(include);\n   604\t\t\t\t\tif (fastMatchInfo != null) {\n   605\t\t\t\t\t\tincludeStartsWith.add(fastMatchInfo);\n   606\t\t\t\t\t} else if (include.equals(\"*\")) {\n   607\t\t\t\t\t\tincludeStar = true;\n   608\t\t\t\t\t} else if ((fastMatchInfo = looksLikeExactName(include)) != null) {\n   609\t\t\t\t\t\tincludeExactName.add(fastMatchInfo);\n   610\t\t\t\t\t} else {\n   611\t\t\t\t\t\tTypePattern includePattern = new PatternParser(include).parseTypePattern();\n   612\t\t\t\t\t\tincludeTypePattern.add(includePattern);\n   613\t\t\t\t\t}\n   614\t\t\t\t}\n   615\t\t\t\tfor (String s : definition.getExcludePatterns()) {\n   616\t\t\t\t\thasExcludes = true;\n   617\t\t\t\t\tString exclude = s;\n   618\t\t\t\t\tfastMatchInfo = looksLikeStartsWith(exclude);\n   619\t\t\t\t\tif (fastMatchInfo != null) {\n   620\t\t\t\t\t\texcludeStartsWith.add(fastMatchInfo);\n   620\t\t\t\t\t\texcludeStartsWith.add(fastMatchInfo);\n   621\t\t\t\t\t} else if ((fastMatchInfo = looksLikeStarDotDotStarExclude(exclude)) != null) {\n   622\t\t\t\t\t\texcludeStarDotDotStar.add(fastMatchInfo);\n   623\t\t\t\t\t} else if ((fastMatchInfo = looksLikeExactName(exclude)) != null) {\n   624\t\t\t\t\t\texcludeExactName.add(exclude);\n   625\t\t\t\t\t} else if ((fastMatchInfo = looksLikeEndsWith(exclude)) != null) {\n   626\t\t\t\t\t\texcludeEndsWith.add(fastMatchInfo);\n   627\t\t\t\t\t} else if (exclude\n   628\t\t\t\t\t\t\t.equals(\"org.codehaus.groovy..* && !org.codehaus.groovy.grails.web.servlet.mvc.SimpleGrailsController*\")) {\n   629\t\t\t\t\t\t// TODO need a more sophisticated analysis here, to allow for similar situations\n   630\t\t\t\t\t\texcludeSpecial.add(new String[]{\"org.codehaus.groovy.\",\n   631\t\t\t\t\t\t\t\t\"org.codehaus.groovy.grails.web.servlet.mvc.SimpleGrailsController\"});\n   632\t\t\t\t\t\t// for the related test:\n   633\t\t\t\t\t\t// } else if (exclude.equals(\"testdata..* && !testdata.sub.Oran*\")) {\n   634\t\t\t\t\t\t// excludeSpecial.add(new String[] { \"testdata.\", \"testdata.sub.Oran\" });\n   635\t\t\t\t\t} else {\n   636\t\t\t\t\t\tTypePattern excludePattern = new PatternParser(exclude).parseTypePattern();\n   637\t\t\t\t\t\texcludeTypePattern.add(excludePattern);\n   638\t\t\t\t\t}\n   639\t\t\t\t}\n   640\t\t\t}\n   641\t\t}\n   642\t\n   643\t\t/**\n   644\t\t * Checks if the pattern looks like \"*..*XXXX*\" and if so returns XXXX. This will enable fast name matching of CGLIB exclusion\n   645\t\t *\n   646\t\t */\n   647\t\tprivate String looksLikeStarDotDotStarExclude(String typePattern) {\n   648\t\t\tif (!typePattern.startsWith(\"*..*\")) {\n   649\t\t\t\treturn null;\n   650\t\t\t}\n   651\t\t\tif (!typePattern.endsWith(\"*\")) {\n   652\t\t\t\treturn null;\n   653\t\t\t}\n   654\t\t\tString subPattern = typePattern.substring(4, typePattern.length() - 1);\n   655\t\t\tif (hasStarDot(subPattern, 0)) {\n   656\t\t\t\treturn null;\n   657\t\t\t}\n   658\t\t\treturn subPattern.replace('$', '.');\n   659\t\t}\n   660\t\n   661\t\t/**\n   662\t\t * Checks if the pattern looks like \"com.foo.Bar\" - an exact name\n   663\t\t */\n   664\t\tprivate String looksLikeExactName(String typePattern) {\n   665\t\t\tif (hasSpaceAnnotationPlus(typePattern, 0) || typePattern.contains(\"*\")) {\n   666\t\t\t\treturn null;\n   667\t\t\t}\n   668\t\t\treturn typePattern.replace('$', '.');\n   669\t\t}\n   670\t\n   671\t\t/**\n   672\t\t * Checks if the pattern looks like \"*Exception\"\n   673\t\t */\n   674\t\tprivate String looksLikeEndsWith(String typePattern) {\n   675\t\t\tif (typePattern.charAt(0) != '*') {\n   676\t\t\t\treturn null;\n   677\t\t\t}\n   678\t\t\tif (hasSpaceAnnotationPlus(typePattern, 1) || hasStarDot(typePattern, 1)) {\n   679\t\t\t\treturn null;\n   680\t\t\t}\n   681\t\t\treturn typePattern.substring(1).replace('$', '.');\n   682\t\t}\n   683\t\n   684\t\t/**\n   685\t\t * Determine if something in the string is going to affect our ability to optimize. Checks for: ' ' '@' '+'\n   686\t\t */\n   687\t\tprivate boolean hasSpaceAnnotationPlus(String string, int pos) {\n   688\t\t\tfor (int i = pos, max = string.length(); i < max; i++) {\n   689\t\t\t\tchar ch = string.charAt(i);\n   690\t\t\t\tif (ch == ' ' || ch == '@' || ch == '+') {\n   691\t\t\t\t\treturn true;\n   692\t\t\t\t}\n   693\t\t\t}\n   694\t\t\treturn false;\n   695\t\t}\n   696\t\n   697\t\t/**\n   698\t\t * Determine if something in the string is going to affect our ability to optimize. Checks for: '*' '.'\n   699\t\t */\n   700\t\tprivate boolean hasStarDot(String string, int pos) {\n   701\t\t\tfor (int i = pos, max = string.length(); i < max; i++) {\n   702\t\t\t\tchar ch = string.charAt(i);\n   703\t\t\t\tif (ch == '*' || ch == '.') {\n   704\t\t\t\t\treturn true;\n   705\t\t\t\t}\n   706\t\t\t}\n   707\t\t\treturn false;\n   708\t\t}\n   709\t\n   710\t\t/**\n   711\t\t * Checks if the type pattern looks like \"com.foo..*\"\n   712\t\t */\n   713\t\tprivate String looksLikeStartsWith(String typePattern) {\n   714\t\t\tif (hasSpaceAnnotationPlus(typePattern, 0) || typePattern.charAt(typePattern.length() - 1) != '*') {\n   715\t\t\t\treturn null;\n   716\t\t\t}\n   717\t\t\t// now must looks like with \"charsss..*\" or \"cha.rss..*\" etc\n   718\t\t\t// note that \"*\" and \"*..*\" won't be fast matched\n   719\t\t\t// and that \"charsss.*\" will not neither\n   720\t\t\tint length = typePattern.length();\n   721\t\t\tif (typePattern.endsWith(\"..*\") && length > 3) {\n   722\t\t\t\tif (typePattern.indexOf(\"..\") == length - 3 // no \"..\" before last sequence\n   723\t\t\t\t\t\t&& typePattern.indexOf('*') == length - 1) { // no earlier '*'\n   724\t\t\t\t\treturn typePattern.substring(0, length - 2).replace('$', '.'); // \"charsss.\" or \"char.rss.\" etc\n   725\t\t\t\t}\n   726\t\t\t}\n   727\t\t\treturn null;\n   728\t\t}\n   729\t\n   730\t\t/**\n   731\t\t * Register the dump filter\n   732\t\t *\n   733\t\t * @param weaver\n   734\t\t * @param loader\n   735\t\t * @param definitions\n   736\t\t */\n   737\t\tprivate void registerDump(final BcelWeaver weaver, final ClassLoader loader, final List<Definition> definitions) {\n   738\t\t\tfor (Definition definition : definitions) {\n   739\t\t\t\tfor (String dump : definition.getDumpPatterns()) {\n   740\t\t\t\t\tTypePattern pattern = new PatternParser(dump).parseTypePattern();\n   741\t\t\t\t\tdumpTypePattern.add(pattern);\n   742\t\t\t\t}\n   743\t\t\t\tif (definition.shouldDumpBefore()) {\n   744\t\t\t\t\tdumpBefore = true;\n   745\t\t\t\t}\n   746\t\t\t\tif (definition.createDumpDirPerClassloader()) {\n   747\t\t\t\t\tdumpDirPerClassloader = true;\n   748\t\t\t\t}\n   749\t\t\t}\n   750\t\t}\n   751\t\n   752\t\t/**\n   753\t\t * Determine whether a type should be accepted for weaving, by checking it against any includes/excludes.\n   754\t\t *\n   755\t\t * @param className the name of the type to possibly accept\n   756\t\t * @param bytes the bytecode for the type (in case we need to look inside, eg. annotations)\n   757\t\t * @return true if it should be accepted for weaving\n   758\t\t */\n   759\t\t@Override\n   760\t\tprotected boolean accept(String className, byte[] bytes) {\n   761\t\n   762\t\t\tif (!hasExcludes && !hasIncludes) {\n   763\t\t\t\treturn true;\n   764\t\t\t}\n   765\t\n   766\t\t\t// still try to avoid ResolvedType if we have simple patterns\n   767\t\t\tString fastClassName = className.replace('/', '.');\n   768\t\t\tfor (String excludeStartsWithString : excludeStartsWith) {\n   769\t\t\t\tif (fastClassName.startsWith(excludeStartsWithString)) {\n   770\t\t\t\t\treturn false;\n   771\t\t\t\t}\n   772\t\t\t}\n   773\t\n   774\t\t\t// Fast exclusion of patterns like: \"*..*CGLIB*\"\n   775\t\t\tif (!excludeStarDotDotStar.isEmpty()) {\n   776\t\t\t\tfor (String namePiece : excludeStarDotDotStar) {\n   777\t\t\t\t\tint index = fastClassName.lastIndexOf('.');\n   778\t\t\t\t\tif (fastClassName.indexOf(namePiece, index + 1) != -1) {\n   779\t\t\t\t\t\treturn false;\n   780\t\t\t\t\t}\n   781\t\t\t\t}\n   782\t\t\t}\n   783\t\t\tfastClassName = fastClassName.replace('$', '.');\n   784\t\n   785\t\t\tif (!excludeEndsWith.isEmpty()) {\n   786\t\t\t\tfor (String lastPiece : excludeEndsWith) {\n   787\t\t\t\t\tif (fastClassName.endsWith(lastPiece)) {\n   788\t\t\t\t\t\treturn false;\n   789\t\t\t\t\t}\n   790\t\t\t\t}\n   791\t\t\t}\n   792\t\n   793\t\t\t// Fast exclusion of exact names\n   794\t\t\tif (!excludeExactName.isEmpty()) {\n   795\t\t\t\tfor (String name : excludeExactName) {\n   796\t\t\t\t\tif (fastClassName.equals(name)) {\n   797\t\t\t\t\t\treturn false;\n   798\t\t\t\t\t}\n   799\t\t\t\t}\n   800\t\t\t}\n   801\t\n   802\t\t\tif (!excludeSpecial.isEmpty()) {\n   803\t\t\t\tfor (String[] entry : excludeSpecial) {\n   804\t\t\t\t\tString excludeThese = entry[0];\n   805\t\t\t\t\tString exceptThese = entry[1];\n   806\t\t\t\t\tif (fastClassName.startsWith(excludeThese) && !fastClassName.startsWith(exceptThese)) {\n   807\t\t\t\t\t\treturn false;\n   808\t\t\t\t\t}\n   809\t\t\t\t}\n   810\t\t\t}\n   811\t\n   812\t\t\t/*\n   813\t\t\t * Bug 120363 If we have an exclude pattern that cannot be matched using \"starts with\" then we cannot fast accept\n   814\t\t\t */\n   815\t\t\tboolean didSomeIncludeMatching = false;\n   816\t\t\tif (excludeTypePattern.isEmpty()) {\n   817\t\t\t\tif (includeStar) {\n   818\t\t\t\t\treturn true;\n   819\t\t\t\t}\n   820\t\t\t\tif (!includeExactName.isEmpty()) {\n   821\t\t\t\t\tdidSomeIncludeMatching = true;\n   822\t\t\t\t\tfor (String exactname : includeExactName) {\n   823\t\t\t\t\t\tif (fastClassName.equals(exactname)) {\n   824\t\t\t\t\t\t\treturn true;\n   825\t\t\t\t\t\t}\n   826\t\t\t\t\t}\n   827\t\t\t\t}\n   828\t\t\t\tboolean fastAccept = false;// defaults to false if no fast include\n   829\t\t\t\tfor (String s : includeStartsWith) {\n   830\t\t\t\t\tdidSomeIncludeMatching = true;\n   831\t\t\t\t\tfastAccept = fastClassName.startsWith(s);\n   832\t\t\t\t\tif (fastAccept) {\n   833\t\t\t\t\t\treturn true;\n   834\t\t\t\t\t}\n   835\t\t\t\t}\n   836\t\t\t\t// We may have processed all patterns now... check that and return\n   837\t\t\t\tif (includeTypePattern.isEmpty()) {\n   838\t\t\t\t\treturn !didSomeIncludeMatching;\n   839\t\t\t\t}\n   840\t\t\t}\n   841\t\n   842\t\t\tboolean accept;\n   843\t\t\ttry {\n   844\t\t\t\tensureDelegateInitialized(className, bytes);\n   845\t\n   846\t\t\t\tResolvedType classInfo = delegateForCurrentClass.getResolvedTypeX();\n   847\t\n   848\t\t\t\t// exclude are \"AND\"ed\n   849\t\t\t\tfor (TypePattern typePattern : excludeTypePattern) {\n   850\t\t\t\t\tif (typePattern.matchesStatically(classInfo)) {\n   850\t\t\t\t\tif (typePattern.matchesStatically(classInfo)) {\n   851\t\t\t\t\t\t// exclude match - skip\n   852\t\t\t\t\t\treturn false;\n   853\t\t\t\t\t}\n   854\t\t\t\t}\n   855\t\t\t\t// include are \"OR\"ed\n   856\t\t\t\tif (includeStar) {\n   857\t\t\t\t\treturn true;\n   858\t\t\t\t}\n   859\t\t\t\tif (!includeExactName.isEmpty()) {\n   860\t\t\t\t\tdidSomeIncludeMatching = true;\n   861\t\t\t\t\tfor (String exactname : includeExactName) {\n   862\t\t\t\t\t\tif (fastClassName.equals(exactname)) {\n   863\t\t\t\t\t\t\treturn true;\n   864\t\t\t\t\t\t}\n   865\t\t\t\t\t}\n   866\t\t\t\t}\n   867\t\t\t\tfor (String s : includeStartsWith) {\n   868\t\t\t\t\tdidSomeIncludeMatching = true;\n   869\t\t\t\t\tboolean fastaccept = fastClassName.startsWith(s);\n   870\t\t\t\t\tif (fastaccept) {\n   871\t\t\t\t\t\treturn true;\n   872\t\t\t\t\t}\n   873\t\t\t\t}\n   874\t\t\t\taccept = !didSomeIncludeMatching; // only true if no includes at all\n   875\t\t\t\tfor (TypePattern typePattern : includeTypePattern) {\n   876\t\t\t\t\taccept = typePattern.matchesStatically(classInfo);\n   877\t\t\t\t\tif (accept) {\n   878\t\t\t\t\t\tbreak;\n   879\t\t\t\t\t}\n   880\t\t\t\t\t// goes on if this include did not match (\"OR\"ed)\n   881\t\t\t\t}\n   882\t\t\t} finally {\n   883\t\t\t\tthis.bcelWorld.demote();\n   884\t\t\t}\n   885\t\t\treturn accept;\n   886\t\t}\n   887\t\n   888\t\t// FIXME we don't use include/exclude of others aop.xml\n   889\t\t// this can be nice but very dangerous as well to change that\n   890\t\tprivate boolean acceptAspect(String aspectClassName) {\n   891\t\t\t// avoid ResolvedType if not needed\n   892\t\t\tif (aspectExcludeTypePattern.isEmpty() && aspectIncludeTypePattern.isEmpty()) {\n   893\t\t\t\treturn true;\n   894\t\t\t}\n   895\t\n   896\t\t\t// still try to avoid ResolvedType if we have simple patterns\n   897\t\t\t// EXCLUDE: if one match then reject\n   898\t\t\tString fastClassName = aspectClassName.replace('/', '.').replace('.', '$');\n   899\t\t\tfor (String value : aspectExcludeStartsWith) {\n   900\t\t\t\tif (fastClassName.startsWith(value)) {\n   901\t\t\t\t\treturn false;\n   902\t\t\t\t}\n   903\t\t\t}\n   904\t\t\t// INCLUDE: if one match then accept\n   905\t\t\tfor (String s : aspectIncludeStartsWith) {\n   906\t\t\t\tif (fastClassName.startsWith(s)) {\n   907\t\t\t\t\treturn true;\n   908\t\t\t\t}\n   909\t\t\t}\n   910\t\n   911\t\t\t// needs further analysis\n   912\t\t\tResolvedType classInfo = weaver.getWorld().resolve(UnresolvedType.forName(aspectClassName), true);\n   913\t\t\t// exclude are \"AND\"ed\n   914\t\t\tfor (TypePattern typePattern: aspectExcludeTypePattern) {\n   915\t\t\t\tif (typePattern.matchesStatically(classInfo)) {\n   916\t\t\t\t\t// exclude match - skip\n   917\t\t\t\t\treturn false;\n   918\t\t\t\t}\n   919\t\t\t}\n   920\t\t\t// include are \"OR\"ed\n   921\t\t\tboolean accept = true;// defaults to true if no include\n   922\t\t\tfor (TypePattern typePattern: aspectIncludeTypePattern) {\n   923\t\t\t\taccept = typePattern.matchesStatically(classInfo);\n   924\t\t\t\tif (accept) {\n   925\t\t\t\t\tbreak;\n   926\t\t\t\t}\n   927\t\t\t\t// goes on if this include did not match (\"OR\"ed)\n   928\t\t\t}\n   929\t\t\treturn accept;\n   930\t\t}\n   931\t\n   932\t\t@Override\n   933\t\tprotected boolean shouldDump(String className, boolean before) {\n   934\t\t\t// Don't dump before weaving unless asked to\n   935\t\t\tif (before && !dumpBefore) {\n   936\t\t\t\treturn false;\n   937\t\t\t}\n   938\t\n   939\t\t\t// avoid ResolvedType if not needed\n   940\t\t\tif (dumpTypePattern.isEmpty()) {\n   941\t\t\t\treturn false;\n   942\t\t\t}\n   943\t\n   944\t\t\t// TODO AV - optimize for className.startWith only\n   945\t\t\tResolvedType classInfo = weaver.getWorld().resolve(UnresolvedType.forName(className), true);\n   946\t\t\t// dump\n   947\t\t\tfor (TypePattern typePattern : dumpTypePattern) {\n   948\t\t\t\tif (typePattern.matchesStatically(classInfo)) {\n   949\t\t\t\t\t// dump match\n   950\t\t\t\t\treturn true;\n   951\t\t\t\t}\n   952\t\t\t}\n   953\t\t\treturn false;\n   954\t\t}\n   955\t\n   956\t\t@Override\n   957\t\tprotected String getDumpDir() {\n   958\t\t\tif (dumpDirPerClassloader) {\n   959\t\t\t\tStringBuffer dir = new StringBuffer();\n   960\t\t\t\tdir.append(\"_ajdump\").append(File.separator).append(weavingContext.getId());\n   961\t\t\t\treturn dir.toString();\n   962\t\t\t} else {\n   963\t\t\t\treturn super.getDumpDir();\n   964\t\t\t}\n   965\t\t}\n   966\t\n   967\t\t/*\n   968\t\t * shared classes methods\n   969\t\t */\n   970\t\n   971\t\t/**\n   972\t\t * @return Returns the key.\n   973\t\t */\n   974\t\tpublic String getNamespace() {\n   975\t\t\t// System.out.println(\"ClassLoaderWeavingAdaptor.getNamespace() classloader=\" + weavingContext.getClassLoaderName() +\n   976\t\t\t// \", namespace=\" + namespace);\n   977\t\t\tif (namespace == null) {\n   978\t\t\t\treturn \"\";\n   979\t\t\t} else {\n   980\t\t\t\treturn new String(namespace);\n   981\t\t\t}\n   982\t\t}\n   983\t\n   984\t\t/**\n   985\t\t * Check to see if any classes are stored in the generated classes cache. Then flush the cache if it is not empty\n   986\t\t *\n   987\t\t * @param className TODO\n   988\t\t * @return true if a class has been generated and is stored in the cache\n   989\t\t */\n   990\t\tpublic boolean generatedClassesExistFor(String className) {\n   991\t\t\t// System.err.println(\"? ClassLoaderWeavingAdaptor.generatedClassesExist() classname=\" + className + \", size=\" +\n   992\t\t\t// generatedClasses);\n   993\t\t\tif (className == null) {\n   994\t\t\t\treturn !generatedClasses.isEmpty();\n   995\t\t\t} else {\n   996\t\t\t\treturn generatedClasses.containsKey(className);\n   997\t\t\t}\n   998\t\t}\n   999\t\n  1000\t\t/**\n  1001\t\t * Flush the generated classes cache\n  1002\t\t */\n  1003\t\tpublic void flushGeneratedClasses() {\n  1004\t\t\t// System.err.println(\"? ClassLoaderWeavingAdaptor.flushGeneratedClasses() generatedClasses=\" + generatedClasses);\n  1005\t\t\tgeneratedClasses = new HashMap<>();\n  1006\t\t}\n  1007\t\n  1008\t\t/**\n  1009\t\t * Remove generated classes based on the supplied className. This will\n  1010\t\t * remove any entries related to this name - so the class itself plus\n  1130\t\t\t\ttrace.exit(\"defineClass\", clazz);\n  1131\t\t\t}\n  1132\t\t}\n  1133\t\tstatic Method defineClassMethod;\n  1134\t\tprivate static String lock = \"lock\";\n  1135\t\n  1136\t\n  1137\t//    /*\n  1138\t//    This method is equivalent to the following code but use reflection to compile on Java 7:\n  1139\t//     MethodHandles.Lookup baseLookup = MethodHandles.lookup();\n  1140\t//    MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(ClassLoader.class, baseLookup);\n  1141\t//    MethodHandle defineClassMethodHandle = lookup.findVirtual(ClassLoader.class, \"defineClass\", defineClassMethodType);\n  1142\t//    handle.bindTo(classLoader).invokeWithArguments(className, classBytes, 0, classBytes.length));\n  1143\t// */\n  1144\t//@Override\n  1145\t//@SuppressWarnings(\"unchecked\")\n  1146\t//public <T> Class<T> defineClass(ClassLoader classLoader, String className, byte[] classBytes) {\n  1147\t//    Object baseLookup = methodHandlesLookup.invoke(null);\n  1148\t//    Object lookup = methodHandlesPrivateLookupIn.invoke(null, ClassLoader.class, baseLookup);\n  1149\t//    MethodHandle defineClassMethodHandle = (MethodHandle) lookupFindVirtual.invoke(lookup, ClassLoader.class, \"defineClass\", defineClassMethodType);\n  1150\t//    try {\n  1151\t//        return Cast.uncheckedCast(defineClassMethodHandle.bindTo(classLoader).invokeWithArguments(className, classBytes, 0, classBytes.length));\n  1152\t//    } catch (Throwable throwable) {\n  1153\t//        throw new RuntimeException(throwable);\n  1154\t//        return (Class) defineClassMethodHandle.bindTo(classLoader).invokeWithArguments(className, classBytes, 0, classBytes.length);\n  1155\t//    } catch (Throwable e) {\n  1156\t//        throw new RuntimeException(e);\n  1157\t//    }\n  1158\t//}\n  1159\t\n  1160\t\tprivate void defineClass(ClassLoader loader, String name, byte[] bytes){\n  1161\t\t\tdefineClass(loader,name,bytes,null);//, ProtectionDomain protectionDomain) {\n  1162\t\t}\n  1163\t//\t\tif (trace.isTraceEnabled()) {\n  1164\t//\t\t\ttrace.enter(\"defineClass\", this, new Object[] { loader, name, bytes, protectionDomain });\n  1165\t//\t\t}\n  1166\t//\t\tObject clazz = null;\n  1167\t//\t\tdebug(\"generating class '\" + name + \"'\");\n  1168\t//\t\ttry {\n  1169\t//\t\t\tgetUnsafe().defineClass(name, bytes, 0, bytes.length, loader, protectionDomain);\n  1170\t//\t\t} catch (LinkageError le) {\n  1171\t//\t\t\t// likely thrown due to defining something that already exists?\n  1172\t//\t\t\t// Old comments from before moving to Unsafe.defineClass():\n  1173\t//\t\t\t// is already defined (happens for X$ajcMightHaveAspect interfaces since aspects are reweaved)\n  1174\t//\t\t\t// TODO maw I don't think this is OK and\n  1175\t//\t\t} catch (Exception e) {\n  1176\t//\t\t\twarn(\"define generated class failed\", e);\n  1177\t//\t\t}\n  1178\t//\n  1179\t//\t\tif (trace.isTraceEnabled()) {\n  1180\t//\t\t\ttrace.exit(\"defineClass\", clazz);\n"}], "isError": false, "timestamp": 1777431137237}}
