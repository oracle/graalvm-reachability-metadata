     335		private boolean hasPointcutAnnotation(ResolvedMember member) {
     336			AnnotationAJ[] as = member.getAnnotations();
     337			if (as == null || as.length == 0) {
     338				return false;
     339			}
     340			for (AnnotationAJ a : as) {
     341				if (a.getTypeSignature().equals("Lorg/aspectj/lang/annotation/Pointcut;")) {
     342					return true;
     343				}
     344			}
     345			return false;
     346		}
