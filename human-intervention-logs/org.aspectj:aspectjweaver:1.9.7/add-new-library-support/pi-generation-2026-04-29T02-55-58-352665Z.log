     509		/**
     510		 * The DeclareAnnotation object encapsulates an method/field/type descriptor and an annotation. This uses a DeclareAnnotation object
     511		 * captured from the XML (something like '<declare-annotation field="* field1(..)" annotation="@Annot(a='a',fred=false,'abc')"/>')
     512		 * and builds the same construct that would have existed if the code style variant was used.  This involves creating a member upon
     513		 * which to hang the real annotation and then creating a classfile level attribute indicating a declare annotation is present
     514		 * (that includes the signature pattern and a pointer to the real member holding the annotation).
     515		 *
     516		 */
     517		private void generateDeclareAnnotation(Definition.DeclareAnnotation da, int decCounter, LazyClassGen cg) {
     518	
     519			// Here is an example member from a code style declare annotation:
     520			//void ajc$declare_at_method_1();
     521			//  RuntimeInvisibleAnnotations: length = 0x6
     522			//   00 01 00 1B 00 00
     523			//  RuntimeVisibleAnnotations: length = 0x15
     524			//   00 01 00 1D 00 03 00 1E 73 00 1F 00 20 73 00 21
     525			//   00 22 73 00 23
     526			//  org.aspectj.weaver.MethodDeclarationLineNumber: length = 0x8
     527			//   00 00 00 02 00 00 00 16
     528			//  org.aspectj.weaver.AjSynthetic: length = 0x
     529			//
     530			//  Code:
     531			//   Stack=0, Locals=1, Args_size=1
     532			//   0:	return
     533	
     534			// and at the class level a Declare attribute:
     535			//		  org.aspectj.weaver.Declare: length = 0x51
     536			//		   05 00 00 00 03 01 00 05 40 41 6E 6E 6F 01 00 17
     537			//		   61 6A 63 24 64 65 63 6C 61 72 65 5F 61 74 5F 6D
     538			//		   65 74 68 6F 64 5F 31 01 01 00 00 00 00 05 05 00
     539			//		   08 73 61 79 48 65 6C 6C 6F 00 01 04 00 00 00 00
     540			//		   07 00 00 00 27 00 00 00 34 00 00 00 16 00 00 00
     541			//		   3C
     542	
     543			AnnotationAJ constructedAnnotation = buildDeclareAnnotation_actualAnnotation(cg, da);
     544			if (constructedAnnotation==null) {
     545				return; // error occurred (and was reported), do not continue
     546			}
     547	
     548			String nameComponent = da.declareAnnotationKind.name().toLowerCase();
     549			String declareName = new StringBuilder("ajc$declare_at_").append(nameComponent).append("_").append(decCounter).toString();
     550			LazyMethodGen declareMethod = new LazyMethodGen(Modifier.PUBLIC, Type.VOID, declareName, Type.NO_ARGS, EMPTY_STRINGS, cg);
     551			InstructionList declareMethodBody = declareMethod.getBody();
     552			declareMethodBody.append(InstructionFactory.RETURN);
     553			declareMethod.addAnnotation(constructedAnnotation);
     554	
     555			DeclareAnnotation deca = null;
     556			ITokenSource tokenSource = BasicTokenSource.makeTokenSource(da.pattern,null);
     557			PatternParser pp = new PatternParser(tokenSource);
     558	
     559			if (da.declareAnnotationKind==DeclareAnnotationKind.Method || da.declareAnnotationKind==DeclareAnnotationKind.Field) {
     560				ISignaturePattern isp = (da.declareAnnotationKind==DeclareAnnotationKind.Method?pp.parseCompoundMethodOrConstructorSignaturePattern(true):pp.parseCompoundFieldSignaturePattern());
