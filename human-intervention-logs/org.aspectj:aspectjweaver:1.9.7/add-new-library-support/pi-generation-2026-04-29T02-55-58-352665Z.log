[recv] {"type": "message_start", "message": {"role": "toolResult", "toolCallId": "call_GtrC3vwBng9seJhal1TYlo2e|fc_0417ab6ecc6edbf40169f1727788708192a3cb6ad4a97fac5d", "toolName": "bash", "content": [{"type": "text", "text": "   260\t\t\tfor (String elligiblePc : elligibleAbstractions) {\n   261\t\t\t\tif (!pointcutNames.contains(elligiblePc)) {\n   262\t\t\t\t\treportError(\"Abstract pointcut '\" + elligiblePc + \"' not configured: \" + stringify());\n   263\t\t\t\t\treturn false;\n   264\t\t\t\t}\n   265\t\t\t}\n   266\t\n   267\t\t\tif (concreteAspect.perclause != null) {\n   268\t\t\t\tString perclauseString = concreteAspect.perclause;\n   269\t\t\t\tif (perclauseString.startsWith(\"persingleton\")) {\n   270\t\t\t\t} else if (perclauseString.startsWith(\"percflow\")) {\n   271\t\t\t\t} else if (perclauseString.startsWith(\"pertypewithin\")) {\n   272\t\t\t\t} else if (perclauseString.startsWith(\"perthis\")) {\n   273\t\t\t\t} else if (perclauseString.startsWith(\"pertarget\")) {\n   274\t\t\t\t} else if (perclauseString.startsWith(\"percflowbelow\")) {\n   275\t\t\t\t} else {\n   276\t\t\t\t\treportError(\"Unrecognized per clause specified \" + stringify());\n   277\t\t\t\t\treturn false;\n   278\t\t\t\t}\n   279\t\t\t}\n   280\t\t\tisValid = true;\n   281\t\t\treturn isValid;\n   282\t\t}\n   283\t\n   284\t\tprivate Collection<ResolvedMember> getOutstandingAbstractMethods(ResolvedType type) {\n   285\t\t\tMap<String, ResolvedMember> collector = new HashMap<>();\n   286\t\t\t// let's get to the top of the hierarchy and then walk down ...\n   287\t\t\t// recording abstract methods then removing\n   288\t\t\t// them if they get defined further down the hierarchy\n   289\t\t\tgetOutstandingAbstractMethodsHelper(type, collector);\n   290\t\t\treturn collector.values();\n   291\t\t}\n   292\t\n   293\t\t// We are trying to determine abstract methods left over at the bottom of a\n   294\t\t// hierarchy that have not been concretized.\n   295\t\tprivate void getOutstandingAbstractMethodsHelper(ResolvedType type, Map<String, ResolvedMember> collector) {\n   296\t\t\tif (type == null) {\n   297\t\t\t\treturn;\n   298\t\t\t}\n   299\t\t\t// Get to the top\n   300\t\t\tif (!type.equals(ResolvedType.OBJECT)) {\n   301\t\t\t\tif (type.getSuperclass() != null) {\n   302\t\t\t\t\tgetOutstandingAbstractMethodsHelper(type.getSuperclass(), collector);\n   303\t\t\t\t}\n   304\t\t\t}\n   305\t\t\tResolvedMember[] rms = type.getDeclaredMethods();\n   306\t\t\tif (rms != null) {\n   307\t\t\t\tfor (ResolvedMember member : rms) {\n   308\t\t\t\t\tString key = member.getName() + member.getSignature();\n   309\t\t\t\t\tif (member.isAbstract()) {\n   310\t\t\t\t\t\tcollector.put(key, member);\n   311\t\t\t\t\t} else {\n   312\t\t\t\t\t\tcollector.remove(key);\n   313\t\t\t\t\t}\n   314\t\t\t\t}\n   315\t\t\t}\n   316\t\t}\n   317\t\n   318\t\t/**\n   319\t\t * Rebuild the XML snip that defines this concrete aspect, for log error purpose\n   320\t\t *\n   321\t\t * @return string repr.\n   322\t\t */\n   323\t\tprivate String stringify() {\n   324\t\t\tStringBuffer sb = new StringBuffer(\"<concrete-aspect name='\");\n   325\t\t\tsb.append(concreteAspect.name);\n   326\t\t\tsb.append(\"' extends='\");\n   327\t\t\tsb.append(concreteAspect.extend);\n   328\t\t\tsb.append(\"' perclause='\");\n   329\t\t\tsb.append(concreteAspect.perclause);\n   330\t\t\tsb.append(\"'/> in aop.xml\");\n   331\t\t\t// TODO needs the extra state from the definition (concretized pointcuts and advice definitions)\n   332\t\t\treturn sb.toString();\n   333\t\t}\n   334\t\n   335\t\tprivate boolean hasPointcutAnnotation(ResolvedMember member) {\n   336\t\t\tAnnotationAJ[] as = member.getAnnotations();\n   337\t\t\tif (as == null || as.length == 0) {\n   338\t\t\t\treturn false;\n   339\t\t\t}\n   340\t\t\tfor (AnnotationAJ a : as) {\n   341\t\t\t\tif (a.getTypeSignature().equals(\"Lorg/aspectj/lang/annotation/Pointcut;\")) {\n   342\t\t\t\t\treturn true;\n   343\t\t\t\t}\n   344\t\t\t}\n   345\t\t\treturn false;\n   346\t\t}\n   347\t\n   348\t\tpublic String getClassName() {\n   349\t\t\treturn concreteAspect.name;\n   350\t\t}\n   351\t\n   352\t\t/**\n   353\t\t * @return the bytecode for the concrete aspect\n   354\t\t */\n   355\t\tpublic byte[] getBytes() {\n   356\t\t\tif (!isValid) {\n   357\t\t\t\tthrow new RuntimeException(\"Must validate first\");\n   358\t\t\t}\n   359\t\t\tif (bytes != null) {\n   360\t\t\t\treturn bytes;\n   361\t\t\t}\n   362\t\t\tPerClause.Kind perclauseKind = PerClause.SINGLETON;\n   363\t\t\tPerClause parentPerClause = (parent != null ? parent.getPerClause() : null);\n   364\t\t\tif (parentPerClause != null) {\n   365\t\t\t\tperclauseKind = parentPerClause.getKind();\n   366\t\t\t}\n   367\t\t\tString perclauseString = null;\n   368\t\n   369\t\t\tif (concreteAspect.perclause != null) {\n   370\t\t\t\tperclauseString = concreteAspect.perclause;\n   371\t\t\t\tif (perclauseString.startsWith(\"persingleton\")) {\n   372\t\t\t\t\tperclauseKind = PerClause.SINGLETON;\n   373\t\t\t\t} else if (perclauseString.startsWith(\"percflow\")) {\n   374\t\t\t\t\tperclauseKind = PerClause.PERCFLOW;\n   375\t\t\t\t} else if (perclauseString.startsWith(\"pertypewithin\")) {\n   376\t\t\t\t\tperclauseKind = PerClause.PERTYPEWITHIN;\n   377\t\t\t\t} else if (perclauseString.startsWith(\"perthis\")) {\n   378\t\t\t\t\tperclauseKind = PerClause.PEROBJECT;\n   379\t\t\t\t} else if (perclauseString.startsWith(\"pertarget\")) {\n   380\t\t\t\t\tperclauseKind = PerClause.PEROBJECT;\n   381\t\t\t\t} else if (perclauseString.startsWith(\"percflowbelow\")) {\n   382\t\t\t\t\tperclauseKind = PerClause.PERCFLOW;\n   383\t\t\t\t}\n   384\t\t\t}\n   385\t\n   386\t\t\t// @Aspect //inherit clause from m_parent\n   387\t\t\t// @DeclarePrecedence(\"....\") // if any\n   388\t\t\t// public class xxxName [extends xxxExtends] {\n   389\t\t\t// [@Pointcut(xxxExpression-n)\n   390\t\t\t// public void xxxName-n() {}]\n   391\t\t\t// }\n   392\t\t\tString parentName = \"java/lang/Object\";\n   393\t\t\tif (parent != null) {\n   394\t\t\t\tif (parent.isParameterizedType()) {\n   395\t\t\t\t\tparentName = parent.getGenericType().getName().replace('.', '/');\n   396\t\t\t\t} else {\n   397\t\t\t\t\tparentName = parent.getName().replace('.', '/');\n   398\t\t\t\t}\n   399\t\t\t}\n   400\t\t\t// @Aspect public class ...\n   401\t\t\t// TODO AV - we could point to the aop.xml that defines it and use JSR-45\n   402\t\t\tLazyClassGen cg = new LazyClassGen(concreteAspect.name.replace('.', '/'), parentName, null, Modifier.PUBLIC\n   403\t\t\t\t\t+ Constants.ACC_SUPER, EMPTY_STRINGS, world);\n   404\t\t\tif (parent != null && parent.isParameterizedType()) {\n   405\t\t\t\tcg.setSuperClass(parent);\n   406\t\t\t}\n   407\t\t\tif (perclauseString == null) {\n   408\t\t\t\tAnnotationGen ag = new AnnotationGen(new ObjectType(\"org/aspectj/lang/annotation/Aspect\"),\n   409\t\t\t\t\t\tCollections.<NameValuePair> emptyList(), true, cg.getConstantPool());\n   410\t\t\t\tcg.addAnnotation(ag);\n   411\t\t\t} else {\n   412\t\t\t\t// List elems = new ArrayList();\n   413\t\t\t\tList<NameValuePair> elems = new ArrayList<>();\n   414\t\t\t\telems.add(new NameValuePair(\"value\",\n   415\t\t\t\t\t\tnew SimpleElementValue(ElementValue.STRING, cg.getConstantPool(), perclauseString), cg.getConstantPool()));\n   416\t\t\t\tAnnotationGen ag = new AnnotationGen(new ObjectType(\"org/aspectj/lang/annotation/Aspect\"), elems, true,\n   417\t\t\t\t\t\tcg.getConstantPool());\n   418\t\t\t\tcg.addAnnotation(ag);\n   419\t\t\t}\n   420\t\t\tif (concreteAspect.precedence != null) {\n   421\t\t\t\tSimpleElementValue svg = new SimpleElementValue(ElementValue.STRING, cg.getConstantPool(), concreteAspect.precedence);\n   422\t\t\t\tList<NameValuePair> elems = new ArrayList<>();\n   423\t\t\t\telems.add(new NameValuePair(\"value\", svg, cg.getConstantPool()));\n   424\t\t\t\tAnnotationGen agprec = new AnnotationGen(new ObjectType(\"org/aspectj/lang/annotation/DeclarePrecedence\"), elems, true,\n   425\t\t\t\t\t\tcg.getConstantPool());\n   426\t\t\t\tcg.addAnnotation(agprec);\n   427\t\t\t}\n   428\t\n   429\t\t\t// default constructor\n   430\t\t\tLazyMethodGen init = new LazyMethodGen(Modifier.PUBLIC, Type.VOID, \"<init>\", EMPTY_TYPES, EMPTY_STRINGS, cg);\n   431\t\t\tInstructionList cbody = init.getBody();\n   432\t\t\tcbody.append(InstructionConstants.ALOAD_0);\n   433\t\n   434\t\t\tcbody.append(cg.getFactory().createInvoke(parentName, \"<init>\", Type.VOID, EMPTY_TYPES, Constants.INVOKESPECIAL));\n   435\t\t\tcbody.append(InstructionConstants.RETURN);\n   436\t\t\tcg.addMethodGen(init);\n   437\t\n   438\t\t\tfor (Definition.Pointcut abstractPc : concreteAspect.pointcuts) {\n   439\t\t\t\t// TODO AV - respect visibility instead of opening up as public?\n   440\t\t\t\tLazyMethodGen mg = new LazyMethodGen(Modifier.PUBLIC, Type.VOID, abstractPc.name, EMPTY_TYPES, EMPTY_STRINGS, cg);\n   441\t\t\t\tSimpleElementValue svg = new SimpleElementValue(ElementValue.STRING, cg.getConstantPool(), abstractPc.expression);\n   442\t\t\t\tList<NameValuePair> elems = new ArrayList<>();\n   443\t\t\t\telems.add(new NameValuePair(\"value\", svg, cg.getConstantPool()));\n   444\t\t\t\tAnnotationGen mag = new AnnotationGen(new ObjectType(\"org/aspectj/lang/annotation/Pointcut\"), elems, true,\n   445\t\t\t\t\t\tcg.getConstantPool());\n   446\t\t\t\tAnnotationAJ max = new BcelAnnotation(mag, world);\n   447\t\t\t\tmg.addAnnotation(max);\n   448\t\n   449\t\t\t\tInstructionList body = mg.getBody();\n   450\t\t\t\tbody.append(InstructionConstants.RETURN);\n   451\t\t\t\tcg.addMethodGen(mg);\n   452\t\t\t}\n   453\t\n   454\t\t\t// Construct any defined declare error/warnings\n   455\t\t\tif (concreteAspect.deows.size() > 0) {\n   456\t\t\t\tint counter = 1;\n   457\t\t\t\tfor (Definition.DeclareErrorOrWarning deow : concreteAspect.deows) {\n   458\t\t\t\t\t// Building this:\n   459\t\t\t\t\t// @DeclareWarning(\"call(* javax.sql..*(..)) && !within(org.xyz.daos..*)\")\n   460\t\t\t\t\t// static final String aMessage = \"Only DAOs should be calling JDBC.\";\n   461\t\n   462\t\t\t\t\tFieldGen field = new FieldGen(Modifier.FINAL, ObjectType.STRING, \"rule\" + (counter++), cg.getConstantPool());\n   463\t\t\t\t\tSimpleElementValue svg = new SimpleElementValue(ElementValue.STRING, cg.getConstantPool(), deow.pointcut);\n   464\t\t\t\t\tList<NameValuePair> elems = new ArrayList<>();\n   465\t\t\t\t\telems.add(new NameValuePair(\"value\", svg, cg.getConstantPool()));\n   466\t\t\t\t\tAnnotationGen mag = new AnnotationGen(new ObjectType(\"org/aspectj/lang/annotation/Declare\"\n   467\t\t\t\t\t\t\t+ (deow.isError ? \"Error\" : \"Warning\")), elems, true, cg.getConstantPool());\n   468\t\t\t\t\tfield.addAnnotation(mag);\n   469\t\n   470\t\t\t\t\tfield.setValue(deow.message);\n   471\t\t\t\t\tcg.addField(field, null);\n   472\t\t\t\t}\n   473\t\t\t}\n   474\t\n   475\t\t\tif (concreteAspect.pointcutsAndAdvice.size() > 0) {\n   476\t\t\t\tint adviceCounter = 1;\n   477\t\t\t\tfor (PointcutAndAdvice paa : concreteAspect.pointcutsAndAdvice) {\n   478\t\t\t\t\tgenerateAdviceMethod(paa, adviceCounter, cg);\n   479\t\t\t\t\tadviceCounter++;\n   480\t\t\t\t}\n   481\t\t\t}\n   482\t\n   483\t\t\tif (concreteAspect.declareAnnotations.size()>0) {\n   484\t\t\t\tint decCounter = 1;\n   485\t\t\t\tfor (Definition.DeclareAnnotation da: concreteAspect.declareAnnotations) {\n   486\t\t\t\t\tgenerateDeclareAnnotation(da,decCounter++,cg);\n   487\t\t\t\t}\n   488\t\t\t}\n   489\t\n   490\t\t\t// handle the perClause\n   491\t\t\tReferenceType rt = new ReferenceType(ResolvedType.forName(concreteAspect.name).getSignature(), world);\n   492\t\t\tGeneratedReferenceTypeDelegate grtd = new GeneratedReferenceTypeDelegate(rt);\n   493\t\t\tgrtd.setSuperclass(parent);\n   494\t\t\trt.setDelegate(grtd);\n   495\t\n   496\t\t\tBcelPerClauseAspectAdder perClauseMunger = new BcelPerClauseAspectAdder(rt, perclauseKind);\n   497\t\t\tperClauseMunger.forceMunge(cg, false);\n   498\t\n   499\t\t\t// TODO AV - unsafe cast\n   500\t\t\t// register the fresh new class into the world repository as it does not\n   501\t\t\t// exist on the classpath anywhere\n   502\t\t\tJavaClass jc = cg.getJavaClass((BcelWorld) world);\n   503\t\t\t((BcelWorld) world).addSourceObjectType(jc, true);\n   504\t\n   505\t\t\tbytes = jc.getBytes();\n   506\t\t\treturn bytes;\n   507\t\t}\n   508\t\n   509\t\t/**\n   510\t\t * The DeclareAnnotation object encapsulates an method/field/type descriptor and an annotation. This uses a DeclareAnnotation object\n   511\t\t * captured from the XML (something like '<declare-annotation field=\"* field1(..)\" annotation=\"@Annot(a='a',fred=false,'abc')\"/>')\n   512\t\t * and builds the same construct that would have existed if the code style variant was used.  This involves creating a member upon\n   513\t\t * which to hang the real annotation and then creating a classfile level attribute indicating a declare annotation is present\n   514\t\t * (that includes the signature pattern and a pointer to the real member holding the annotation).\n   515\t\t *\n   516\t\t */\n   517\t\tprivate void generateDeclareAnnotation(Definition.DeclareAnnotation da, int decCounter, LazyClassGen cg) {\n   518\t\n   519\t\t\t// Here is an example member from a code style declare annotation:\n   520\t\t\t//void ajc$declare_at_method_1();\n   521\t\t\t//  RuntimeInvisibleAnnotations: length = 0x6\n   522\t\t\t//   00 01 00 1B 00 00\n   523\t\t\t//  RuntimeVisibleAnnotations: length = 0x15\n   524\t\t\t//   00 01 00 1D 00 03 00 1E 73 00 1F 00 20 73 00 21\n   525\t\t\t//   00 22 73 00 23\n   526\t\t\t//  org.aspectj.weaver.MethodDeclarationLineNumber: length = 0x8\n   527\t\t\t//   00 00 00 02 00 00 00 16\n   528\t\t\t//  org.aspectj.weaver.AjSynthetic: length = 0x\n   529\t\t\t//\n   530\t\t\t//  Code:\n   531\t\t\t//   Stack=0, Locals=1, Args_size=1\n   532\t\t\t//   0:\treturn\n   533\t\n   534\t\t\t// and at the class level a Declare attribute:\n   535\t\t\t//\t\t  org.aspectj.weaver.Declare: length = 0x51\n   536\t\t\t//\t\t   05 00 00 00 03 01 00 05 40 41 6E 6E 6F 01 00 17\n   537\t\t\t//\t\t   61 6A 63 24 64 65 63 6C 61 72 65 5F 61 74 5F 6D\n   538\t\t\t//\t\t   65 74 68 6F 64 5F 31 01 01 00 00 00 00 05 05 00\n   539\t\t\t//\t\t   08 73 61 79 48 65 6C 6C 6F 00 01 04 00 00 00 00\n   540\t\t\t//\t\t   07 00 00 00 27 00 00 00 34 00 00 00 16 00 00 00\n   541\t\t\t//\t\t   3C\n   542\t\n   543\t\t\tAnnotationAJ constructedAnnotation = buildDeclareAnnotation_actualAnnotation(cg, da);\n   544\t\t\tif (constructedAnnotation==null) {\n   545\t\t\t\treturn; // error occurred (and was reported), do not continue\n   546\t\t\t}\n   547\t\n   548\t\t\tString nameComponent = da.declareAnnotationKind.name().toLowerCase();\n   549\t\t\tString declareName = new StringBuilder(\"ajc$declare_at_\").append(nameComponent).append(\"_\").append(decCounter).toString();\n   550\t\t\tLazyMethodGen declareMethod = new LazyMethodGen(Modifier.PUBLIC, Type.VOID, declareName, Type.NO_ARGS, EMPTY_STRINGS, cg);\n   551\t\t\tInstructionList declareMethodBody = declareMethod.getBody();\n   552\t\t\tdeclareMethodBody.append(InstructionFactory.RETURN);\n   553\t\t\tdeclareMethod.addAnnotation(constructedAnnotation);\n   554\t\n   555\t\t\tDeclareAnnotation deca = null;\n   556\t\t\tITokenSource tokenSource = BasicTokenSource.makeTokenSource(da.pattern,null);\n   557\t\t\tPatternParser pp = new PatternParser(tokenSource);\n   558\t\n   559\t\t\tif (da.declareAnnotationKind==DeclareAnnotationKind.Method || da.declareAnnotationKind==DeclareAnnotationKind.Field) {\n   560\t\t\t\tISignaturePattern isp = (da.declareAnnotationKind==DeclareAnnotationKind.Method?pp.parseCompoundMethodOrConstructorSignaturePattern(true):pp.parseCompoundFieldSignaturePattern());\n     1\t/*******************************************************************************\n     2\t * Copyright (c) 2005 Contributors.\n     3\t * All rights reserved.\n     4\t * This program and the accompanying materials are made available\n     5\t * under the terms of the Eclipse Public License v 2.0\n     6\t * which accompanies this distribution and is available at\n     7\t * https://www.eclipse.org/org/documents/epl-2.0/EPL-2.0.txt\n     8\t *\n     9\t * Contributors:\n    10\t *   Alexandre Vasseur         initial implementation\n    11\t *******************************************************************************/\n    12\tpackage org.aspectj.weaver.loadtime.definition;\n    13\t\n    14\timport java.util.ArrayList;\n    15\timport java.util.HashMap;\n    16\timport java.util.List;\n    17\timport java.util.Map;\n    18\t\n    19\t/**\n    20\t * A POJO that contains raw strings from the XML (sort of XMLBean for our simple LTW DTD)\n    21\t *\n    22\t * @author Alexandre Vasseur (alex AT gnilux DOT com)\n    23\t */\n    24\tpublic class Definition {\n    25\t\n    26\t\tprivate final StringBuffer weaverOptions;\n    27\t\tprivate final List<String> dumpPatterns;\n    28\t\tprivate boolean dumpBefore;\n    29\t\tprivate boolean perClassloaderDumpDir;\n    30\t\tprivate final List<String> includePatterns;\n    31\t\tprivate final List<String> excludePatterns;\n    32\t\tprivate final List<String> aspectClassNames;\n    33\t\tprivate final List<String> aspectExcludePatterns;\n    34\t\tprivate final List<String> aspectIncludePatterns;\n    35\t\tprivate final List<Definition.ConcreteAspect> concreteAspects;\n    36\t\n    37\t\t/**\n    38\t\t * When aspects are defined, they can specify a scope type pattern and then will only apply to types matching that pattern.\n    39\t\t */\n    40\t\tprivate final Map<String, String> scopedAspects;\n    41\t\n    42\t\t/**\n    43\t\t * Some aspects (from aspect libraries) will describe a type that must be around for them to function properly\n    44\t\t */\n    45\t\tprivate final Map<String, String> requiredTypesForAspects;\n    46\t\n    47\t\tpublic Definition() {\n    48\t\t\tweaverOptions = new StringBuffer();\n    49\t\t\tdumpBefore = false;\n    50\t\t\tperClassloaderDumpDir = false;\n    51\t\t\tdumpPatterns = new ArrayList<>();\n    52\t\t\tincludePatterns = new ArrayList<>();\n    53\t\t\texcludePatterns = new ArrayList<>();\n    54\t\t\taspectClassNames = new ArrayList<>();\n    55\t\t\taspectExcludePatterns = new ArrayList<>();\n    56\t\t\taspectIncludePatterns = new ArrayList<>();\n    57\t\t\tconcreteAspects = new ArrayList<>();\n    58\t\t\tscopedAspects = new HashMap<>();\n    59\t\t\trequiredTypesForAspects = new HashMap<>();\n    60\t\t}\n    61\t\n    62\t\tpublic String getWeaverOptions() {\n    63\t\t\treturn weaverOptions.toString();\n    64\t\t}\n    65\t\n    66\t\tpublic List<String> getDumpPatterns() {\n    67\t\t\treturn dumpPatterns;\n    68\t\t}\n    69\t\n    70\t\tpublic void setDumpBefore(boolean b) {\n    71\t\t\tdumpBefore = b;\n    72\t\t}\n    73\t\n    74\t\tpublic boolean shouldDumpBefore() {\n    75\t\t\treturn dumpBefore;\n    76\t\t}\n    77\t\n    78\t\tpublic void setCreateDumpDirPerClassloader(boolean b) {\n    79\t\t\tperClassloaderDumpDir = b;\n    80\t\t}\n    81\t\n    82\t\tpublic boolean createDumpDirPerClassloader() {\n    83\t\t\treturn perClassloaderDumpDir;\n    84\t\t}\n    85\t\n    86\t\tpublic List<String> getIncludePatterns() {\n    87\t\t\treturn includePatterns;\n    88\t\t}\n    89\t\n    90\t\tpublic List<String> getExcludePatterns() {\n    91\t\t\treturn excludePatterns;\n    92\t\t}\n    93\t\n    94\t\tpublic List<String> getAspectClassNames() {\n    95\t\t\treturn aspectClassNames;\n    96\t\t}\n    97\t\n    98\t\tpublic List<String> getAspectExcludePatterns() {\n    99\t\t\treturn aspectExcludePatterns;\n   100\t\t}\n   101\t\n   102\t\tpublic List<String> getAspectIncludePatterns() {\n   103\t\t\treturn aspectIncludePatterns;\n   104\t\t}\n   105\t\n   106\t\tpublic List<Definition.ConcreteAspect> getConcreteAspects() {\n   107\t\t\treturn concreteAspects;\n   108\t\t}\n   109\t\n   110\t\tpublic static class ConcreteAspect {\n   111\t\t\tpublic final String name;\n   112\t\t\tpublic final String extend;\n   113\t\t\tpublic final String precedence;\n   114\t\t\tpublic final List<Definition.Pointcut> pointcuts;\n   115\t\t\tpublic final List<Definition.DeclareAnnotation> declareAnnotations;\n   116\t\t\tpublic final List<Definition.PointcutAndAdvice> pointcutsAndAdvice;\n   117\t\t\tpublic final String perclause;\n   118\t\t\tpublic List<Definition.DeclareErrorOrWarning> deows;\n   119\t\n   120\t\t\tpublic ConcreteAspect(String name, String extend) {\n   121\t\t\t\tthis(name, extend, null, null);\n   122\t\t\t}\n   123\t\n   124\t\t\tpublic ConcreteAspect(String name, String extend, String precedence, String perclause) {\n   125\t\t\t\tthis.name = name;\n   126\t\t\t\t// make sure extend set to null if \"\"\n   127\t\t\t\tif (extend == null || extend.length() == 0) {\n   128\t\t\t\t\tthis.extend = null;\n   129\t\t\t\t\tif (precedence == null || precedence.length() == 0) {\n   130\t\t\t\t\t\t// if (pointcutsAndAdvice.size() == 0) {\n   131\t\t\t\t\t\t// throw new RuntimeException(\"Not allowed\");\n   132\t\t\t\t\t\t// }\n   133\t\t\t\t\t}\n   134\t\t\t\t} else {\n   135\t\t\t\t\tthis.extend = extend;\n   136\t\t\t\t}\n   137\t\t\t\tthis.precedence = precedence;\n   138\t\t\t\tthis.pointcuts = new ArrayList<>();\n   139\t\t\t\tthis.declareAnnotations = new ArrayList<>();\n   140\t\t\t\tthis.pointcutsAndAdvice = new ArrayList<>();\n   141\t\t\t\tthis.deows = new ArrayList<>();\n   142\t\t\t\tthis.perclause = perclause;\n   143\t\t\t}\n   144\t\t}\n   145\t\n   146\t\tpublic static class Pointcut {\n   147\t\t\tpublic final String name;\n   148\t\t\tpublic final String expression;\n   149\t\n   150\t\t\tpublic Pointcut(String name, String expression) {\n   151\t\t\t\tthis.name = name;\n   152\t\t\t\tthis.expression = expression;\n   153\t\t\t}\n   154\t\t}\n   155\t\n   156\t\tpublic enum AdviceKind {\n   157\t\t\tBefore, After, AfterReturning, AfterThrowing, Around;\n   158\t\t}\n   159\t\n   160\t\tpublic enum DeclareAnnotationKind {\n   161\t\t\tMethod, Field, Type;\n   162\t\t}\n   163\t\n   164\t\tpublic static class DeclareAnnotation {\n   165\t\t\tpublic final DeclareAnnotationKind declareAnnotationKind;\n   166\t\t\tpublic final String pattern;\n   167\t\t\tpublic final String annotation;\n   168\t\n   169\t\t\tpublic DeclareAnnotation(DeclareAnnotationKind kind, String pattern, String annotation) {\n   170\t\t\t\tthis.declareAnnotationKind = kind;\n   171\t\t\t\tthis.pattern = pattern;\n   172\t\t\t\tthis.annotation = annotation;\n   173\t\t\t}\n   174\t\t}\n   175\t\n   176\t\tpublic static class PointcutAndAdvice {\n   177\t\t\tpublic final AdviceKind adviceKind;\n   178\t\t\tpublic final String pointcut;\n   179\t\t\tpublic final String adviceClass; // com.foo.Bar\n   180\t\t\tpublic final String adviceMethod; // foo(java.lang.String,org.aspectj.lang.JoinPoint)\n   181\t\n   182\t\t\tpublic PointcutAndAdvice(AdviceKind adviceKind, String pointcut, String adviceClass, String adviceMethod) {\n   183\t\t\t\tthis.adviceKind = adviceKind;\n   184\t\t\t\tthis.pointcut = pointcut;\n   185\t\t\t\tthis.adviceClass = adviceClass;\n   186\t\t\t\tthis.adviceMethod = adviceMethod;\n   187\t\t\t}\n   188\t\t}\n   189\t\n   190\t\tpublic static class DeclareErrorOrWarning {\n   191\t\t\tpublic final boolean isError;\n   192\t\t\tpublic final String pointcut;\n   193\t\t\tpublic final String message;\n   194\t\n   195\t\t\tpublic DeclareErrorOrWarning(boolean isError, String pointcut, String message) {\n   196\t\t\t\tthis.isError = isError;\n   197\t\t\t\tthis.pointcut = pointcut;\n   198\t\t\t\tthis.message = message;\n   199\t\t\t}\n   200\t\t}\n   201\t\n   202\t\tpublic void appendWeaverOptions(String option) {\n   203\t\t\tweaverOptions.append(option.trim()).append(' ');\n   204\t\t}\n   205\t\n   206\t\tpublic void addScopedAspect(String name, String scopePattern) {\n   207\t\t\tscopedAspects.put(name, scopePattern);\n   208\t\t}\n   209\t\n   210\t\tpublic String getScopeForAspect(String name) {\n   211\t\t\treturn scopedAspects.get(name);\n   212\t\t}\n   213\t\n   214\t\tpublic void setAspectRequires(String name, String requiredType) {\n   215\t\t\trequiredTypesForAspects.put(name, requiredType);\n   216\t\t}\n   217\t\n   218\t\tpublic String getAspectRequires(String name) {\n   219\t\t\treturn requiredTypesForAspects.get(name);\n   220\t\t}\n   250\t\t\t\t} else if (!isNull(typePat)) {\n   251\t\t\t\t\t// declare @type\n   252\t\t\t\t\tactiveConcreteAspectDefinition.declareAnnotations.add(new Definition.DeclareAnnotation(DeclareAnnotationKind.Type,\n   253\t\t\t\t\t\t\ttypePat, anno));\n   254\t\t\t\t}\n   255\t\t\t} else if (BEFORE_ELEMENT.equals(qName) && activeConcreteAspectDefinition != null) {\n   256\t\t\t\tString pointcut = attributes.getValue(POINTCUT_ELEMENT);\n   257\t\t\t\tString adviceClass = attributes.getValue(\"invokeClass\");\n   258\t\t\t\tString adviceMethod = attributes.getValue(\"invokeMethod\");\n   259\t\t\t\tif (!isNull(pointcut) && !isNull(adviceClass) && !isNull(adviceMethod)) {\n   260\t\t\t\t\tactiveConcreteAspectDefinition.pointcutsAndAdvice.add(new Definition.PointcutAndAdvice(AdviceKind.Before,\n   261\t\t\t\t\t\t\treplaceXmlAnd(pointcut), adviceClass, adviceMethod));\n   262\t\t\t\t} else {\n   263\t\t\t\t\tthrow new SAXException(\"Badly formed <before> element\");\n   264\t\t\t\t}\n   265\t\t\t} else if (AFTER_ELEMENT.equals(qName) && activeConcreteAspectDefinition != null) {\n   266\t\t\t\tString pointcut = attributes.getValue(POINTCUT_ELEMENT);\n   267\t\t\t\tString adviceClass = attributes.getValue(\"invokeClass\");\n   268\t\t\t\tString adviceMethod = attributes.getValue(\"invokeMethod\");\n   269\t\t\t\tif (!isNull(pointcut) && !isNull(adviceClass) && !isNull(adviceMethod)) {\n   270\t\t\t\t\tactiveConcreteAspectDefinition.pointcutsAndAdvice.add(new Definition.PointcutAndAdvice(AdviceKind.After,\n   271\t\t\t\t\t\t\treplaceXmlAnd(pointcut), adviceClass, adviceMethod));\n   272\t\t\t\t} else {\n   273\t\t\t\t\tthrow new SAXException(\"Badly formed <after> element\");\n   274\t\t\t\t}\n   275\t\t\t} else if (AROUND_ELEMENT.equals(qName) && activeConcreteAspectDefinition != null) {\n   276\t\t\t\tString pointcut = attributes.getValue(POINTCUT_ELEMENT);\n   277\t\t\t\tString adviceClass = attributes.getValue(\"invokeClass\");\n   278\t\t\t\tString adviceMethod = attributes.getValue(\"invokeMethod\");\n   279\t\t\t\tif (!isNull(pointcut) && !isNull(adviceClass) && !isNull(adviceMethod)) {\n   280\t\t\t\t\tactiveConcreteAspectDefinition.pointcutsAndAdvice.add(new Definition.PointcutAndAdvice(AdviceKind.Around,\n   281\t\t\t\t\t\t\treplaceXmlAnd(pointcut), adviceClass, adviceMethod));\n   282\t\t\t\t} else {\n   283\t\t\t\t\tthrow new SAXException(\"Badly formed <before> element\");\n   284\t\t\t\t}\n   285\t\t\t} else if (ASPECTJ_ELEMENT.equals(qName)) {\n   286\t\t\t\tif (inAspectJ) {\n   287\t\t\t\t\tthrow new SAXException(\"Found nested <aspectj> element\");\n   288\t\t\t\t}\n   289\t\t\t\tinAspectJ = true;\n   290\t\t\t} else if (ASPECTS_ELEMENT.equals(qName)) {\n   291\t\t\t\tinAspects = true;\n   292\t\t\t} else if (INCLUDE_ELEMENT.equals(qName) && inWeaver) {\n   293\t\t\t\tString typePattern = getWithinAttribute(attributes);\n   294\t\t\t\tif (!isNull(typePattern)) {\n   295\t\t\t\t\tdefinition.getIncludePatterns().add(typePattern);\n   296\t\t\t\t}\n   297\t\t\t} else if (EXCLUDE_ELEMENT.equals(qName) && inWeaver) {\n   298\t\t\t\tString typePattern = getWithinAttribute(attributes);\n   299\t\t\t\tif (!isNull(typePattern)) {\n   300\t\t\t\t\tdefinition.getExcludePatterns().add(typePattern);\n   301\t\t\t\t}\n   302\t\t\t} else if (DUMP_ELEMENT.equals(qName) && inWeaver) {\n   303\t\t\t\tString typePattern = getWithinAttribute(attributes);\n   304\t\t\t\tif (!isNull(typePattern)) {\n   305\t\t\t\t\tdefinition.getDumpPatterns().add(typePattern);\n   306\t\t\t\t}\n   307\t\t\t\tString beforeAndAfter = attributes.getValue(DUMP_BEFOREANDAFTER_ATTRIBUTE);\n   308\t\t\t\tif (isTrue(beforeAndAfter)) {\n   309\t\t\t\t\tdefinition.setDumpBefore(true);\n   310\t\t\t\t}\n   311\t\t\t\tString perWeaverDumpDir = attributes.getValue(DUMP_PERCLASSLOADERDIR_ATTRIBUTE);\n   312\t\t\t\tif (isTrue(perWeaverDumpDir)) {\n   313\t\t\t\t\tdefinition.setCreateDumpDirPerClassloader(true);\n   314\t\t\t\t}\n   315\t\t\t} else if (EXCLUDE_ELEMENT.equals(qName) && inAspects) {\n   316\t\t\t\tString typePattern = getWithinAttribute(attributes);\n   317\t\t\t\tif (!isNull(typePattern)) {\n   318\t\t\t\t\tdefinition.getAspectExcludePatterns().add(typePattern);\n   319\t\t\t\t}\n   320\t\t\t} else if (INCLUDE_ELEMENT.equals(qName) && inAspects) {\n   321\t\t\t\tString typePattern = getWithinAttribute(attributes);\n   322\t\t\t\tif (!isNull(typePattern)) {\n   323\t\t\t\t\tdefinition.getAspectIncludePatterns().add(typePattern);\n   324\t\t\t\t}\n   325\t\t\t} else {\n   326\t\t\t\tthrow new SAXException(\"Unknown element while parsing <aspectj> element: \" + qName);\n   327\t\t\t}\n   328\t\t\tsuper.startElement(uri, localName, qName, attributes);\n   329\t\t}\n   330\t\n   331\t\tprivate String getWithinAttribute(Attributes attributes) {\n   332\t\t\treturn replaceXmlAnd(attributes.getValue(WITHIN_ATTRIBUTE));\n   333\t\t}\n   334\t\n   335\t\tpublic void endElement(String uri, String localName, String qName) throws SAXException {\n   336\t\t\tif (CONCRETE_ASPECT_ELEMENT.equals(qName)) {\n   337\t\t\t\tactiveConcreteAspectDefinition = null;\n   338\t\t\t} else if (ASPECTJ_ELEMENT.equals(qName)) {\n   339\t\t\t\tinAspectJ = false;\n   340\t\t\t} else if (WEAVER_ELEMENT.equals(qName)) {\n   341\t\t\t\tinWeaver = false;\n   342\t\t\t} else if (ASPECTS_ELEMENT.equals(qName)) {\n   343\t\t\t\tinAspects = false;\n   344\t\t\t}\n   345\t\t\tsuper.endElement(uri, localName, qName);\n   346\t\t}\n   347\t\n   348\t\t// TODO AV - define what we want for XML parser error - for now stderr\n   349\t\tpublic void warning(SAXParseException e) throws SAXException {\n   350\t\t\tsuper.warning(e);\n   351\t\t}\n   352\t\n   353\t\tpublic void error(SAXParseException e) throws SAXException {\n   354\t\t\tsuper.error(e);\n   355\t\t}\n   356\t\n   357\t\tpublic void fatalError(SAXParseException e) throws SAXException {\n   358\t\t\tsuper.fatalError(e);\n   359\t\t}\n   360\t\n   361\t\tprivate static String replaceXmlAnd(String expression) {\n   362\t\t\t// TODO AV do we need to handle \"..)AND\" or \"AND(..\" ?\n   363\t\t\treturn LangUtil.replace(expression, \" AND \", \" && \");\n   364\t\t}\n   365\t\n   366\t\tprivate boolean isNull(String s) {\n   367\t\t\treturn (s == null || s.length() <= 0);\n   368\t\t}\n   369\t\n   370\t\tprivate boolean isTrue(String s) {\n   371\t\t\treturn (s != null && s.equals(\"true\"));\n   372\t\t}\n   373\t\n   374\t\t/**\n   375\t\t * Turn off caching\n   376\t\t */\n   377\t\tpublic static void deactivateCaching() {\n   378\t\t\tCACHE = false;\n   379\t\t}\n   380\t\n"}], "isError": false, "timestamp": 1777431160586}}
[recv] {"type": "message_end", "message": {"role": "toolResult", "toolCallId": "call_GtrC3vwBng9seJhal1TYlo2e|fc_0417ab6ecc6edbf40169f1727788708192a3cb6ad4a97fac5d", "toolName": "bash", "content": [{"type": "text", "text": "   260\t\t\tfor (String elligiblePc : elligibleAbstractions) {\n   261\t\t\t\tif (!pointcutNames.contains(elligiblePc)) {\n   262\t\t\t\t\treportError(\"Abstract pointcut '\" + elligiblePc + \"' not configured: \" + stringify());\n   263\t\t\t\t\treturn false;\n   264\t\t\t\t}\n   265\t\t\t}\n   266\t\n   267\t\t\tif (concreteAspect.perclause != null) {\n   268\t\t\t\tString perclauseString = concreteAspect.perclause;\n   269\t\t\t\tif (perclauseString.startsWith(\"persingleton\")) {\n   270\t\t\t\t} else if (perclauseString.startsWith(\"percflow\")) {\n   271\t\t\t\t} else if (perclauseString.startsWith(\"pertypewithin\")) {\n   272\t\t\t\t} else if (perclauseString.startsWith(\"perthis\")) {\n   273\t\t\t\t} else if (perclauseString.startsWith(\"pertarget\")) {\n   274\t\t\t\t} else if (perclauseString.startsWith(\"percflowbelow\")) {\n   275\t\t\t\t} else {\n   276\t\t\t\t\treportError(\"Unrecognized per clause specified \" + stringify());\n   277\t\t\t\t\treturn false;\n   278\t\t\t\t}\n   279\t\t\t}\n   280\t\t\tisValid = true;\n   281\t\t\treturn isValid;\n   282\t\t}\n   283\t\n   284\t\tprivate Collection<ResolvedMember> getOutstandingAbstractMethods(ResolvedType type) {\n   285\t\t\tMap<String, ResolvedMember> collector = new HashMap<>();\n   286\t\t\t// let's get to the top of the hierarchy and then walk down ...\n   287\t\t\t// recording abstract methods then removing\n   288\t\t\t// them if they get defined further down the hierarchy\n   289\t\t\tgetOutstandingAbstractMethodsHelper(type, collector);\n   290\t\t\treturn collector.values();\n   291\t\t}\n   292\t\n   293\t\t// We are trying to determine abstract methods left over at the bottom of a\n   294\t\t// hierarchy that have not been concretized.\n   295\t\tprivate void getOutstandingAbstractMethodsHelper(ResolvedType type, Map<String, ResolvedMember> collector) {\n   296\t\t\tif (type == null) {\n   297\t\t\t\treturn;\n   298\t\t\t}\n   299\t\t\t// Get to the top\n   300\t\t\tif (!type.equals(ResolvedType.OBJECT)) {\n   301\t\t\t\tif (type.getSuperclass() != null) {\n   302\t\t\t\t\tgetOutstandingAbstractMethodsHelper(type.getSuperclass(), collector);\n   303\t\t\t\t}\n   304\t\t\t}\n   305\t\t\tResolvedMember[] rms = type.getDeclaredMethods();\n   306\t\t\tif (rms != null) {\n   307\t\t\t\tfor (ResolvedMember member : rms) {\n   308\t\t\t\t\tString key = member.getName() + member.getSignature();\n   309\t\t\t\t\tif (member.isAbstract()) {\n   310\t\t\t\t\t\tcollector.put(key, member);\n   311\t\t\t\t\t} else {\n   312\t\t\t\t\t\tcollector.remove(key);\n   313\t\t\t\t\t}\n   314\t\t\t\t}\n   315\t\t\t}\n   316\t\t}\n   317\t\n   318\t\t/**\n   319\t\t * Rebuild the XML snip that defines this concrete aspect, for log error purpose\n   320\t\t *\n   321\t\t * @return string repr.\n   322\t\t */\n   323\t\tprivate String stringify() {\n   324\t\t\tStringBuffer sb = new StringBuffer(\"<concrete-aspect name='\");\n   325\t\t\tsb.append(concreteAspect.name);\n   326\t\t\tsb.append(\"' extends='\");\n   327\t\t\tsb.append(concreteAspect.extend);\n   328\t\t\tsb.append(\"' perclause='\");\n   329\t\t\tsb.append(concreteAspect.perclause);\n   330\t\t\tsb.append(\"'/> in aop.xml\");\n   331\t\t\t// TODO needs the extra state from the definition (concretized pointcuts and advice definitions)\n   332\t\t\treturn sb.toString();\n   333\t\t}\n   334\t\n   335\t\tprivate boolean hasPointcutAnnotation(ResolvedMember member) {\n   336\t\t\tAnnotationAJ[] as = member.getAnnotations();\n   337\t\t\tif (as == null || as.length == 0) {\n   338\t\t\t\treturn false;\n   339\t\t\t}\n   340\t\t\tfor (AnnotationAJ a : as) {\n   341\t\t\t\tif (a.getTypeSignature().equals(\"Lorg/aspectj/lang/annotation/Pointcut;\")) {\n   342\t\t\t\t\treturn true;\n   343\t\t\t\t}\n   344\t\t\t}\n   345\t\t\treturn false;\n   346\t\t}\n   347\t\n   348\t\tpublic String getClassName() {\n   349\t\t\treturn concreteAspect.name;\n   350\t\t}\n   351\t\n   352\t\t/**\n   353\t\t * @return the bytecode for the concrete aspect\n   354\t\t */\n   355\t\tpublic byte[] getBytes() {\n   356\t\t\tif (!isValid) {\n   357\t\t\t\tthrow new RuntimeException(\"Must validate first\");\n   358\t\t\t}\n   359\t\t\tif (bytes != null) {\n   360\t\t\t\treturn bytes;\n   361\t\t\t}\n   362\t\t\tPerClause.Kind perclauseKind = PerClause.SINGLETON;\n   363\t\t\tPerClause parentPerClause = (parent != null ? parent.getPerClause() : null);\n   364\t\t\tif (parentPerClause != null) {\n   365\t\t\t\tperclauseKind = parentPerClause.getKind();\n   366\t\t\t}\n   367\t\t\tString perclauseString = null;\n   368\t\n   369\t\t\tif (concreteAspect.perclause != null) {\n   370\t\t\t\tperclauseString = concreteAspect.perclause;\n   371\t\t\t\tif (perclauseString.startsWith(\"persingleton\")) {\n   372\t\t\t\t\tperclauseKind = PerClause.SINGLETON;\n   373\t\t\t\t} else if (perclauseString.startsWith(\"percflow\")) {\n   374\t\t\t\t\tperclauseKind = PerClause.PERCFLOW;\n   375\t\t\t\t} else if (perclauseString.startsWith(\"pertypewithin\")) {\n   376\t\t\t\t\tperclauseKind = PerClause.PERTYPEWITHIN;\n   377\t\t\t\t} else if (perclauseString.startsWith(\"perthis\")) {\n   378\t\t\t\t\tperclauseKind = PerClause.PEROBJECT;\n   379\t\t\t\t} else if (perclauseString.startsWith(\"pertarget\")) {\n   380\t\t\t\t\tperclauseKind = PerClause.PEROBJECT;\n   381\t\t\t\t} else if (perclauseString.startsWith(\"percflowbelow\")) {\n   382\t\t\t\t\tperclauseKind = PerClause.PERCFLOW;\n   383\t\t\t\t}\n   384\t\t\t}\n   385\t\n   386\t\t\t// @Aspect //inherit clause from m_parent\n   387\t\t\t// @DeclarePrecedence(\"....\") // if any\n   388\t\t\t// public class xxxName [extends xxxExtends] {\n   389\t\t\t// [@Pointcut(xxxExpression-n)\n   390\t\t\t// public void xxxName-n() {}]\n   391\t\t\t// }\n   392\t\t\tString parentName = \"java/lang/Object\";\n   393\t\t\tif (parent != null) {\n   394\t\t\t\tif (parent.isParameterizedType()) {\n   395\t\t\t\t\tparentName = parent.getGenericType().getName().replace('.', '/');\n   396\t\t\t\t} else {\n   397\t\t\t\t\tparentName = parent.getName().replace('.', '/');\n   398\t\t\t\t}\n   399\t\t\t}\n   400\t\t\t// @Aspect public class ...\n   401\t\t\t// TODO AV - we could point to the aop.xml that defines it and use JSR-45\n   402\t\t\tLazyClassGen cg = new LazyClassGen(concreteAspect.name.replace('.', '/'), parentName, null, Modifier.PUBLIC\n   403\t\t\t\t\t+ Constants.ACC_SUPER, EMPTY_STRINGS, world);\n   404\t\t\tif (parent != null && parent.isParameterizedType()) {\n   405\t\t\t\tcg.setSuperClass(parent);\n   406\t\t\t}\n   407\t\t\tif (perclauseString == null) {\n   408\t\t\t\tAnnotationGen ag = new AnnotationGen(new ObjectType(\"org/aspectj/lang/annotation/Aspect\"),\n   409\t\t\t\t\t\tCollections.<NameValuePair> emptyList(), true, cg.getConstantPool());\n   410\t\t\t\tcg.addAnnotation(ag);\n   411\t\t\t} else {\n   412\t\t\t\t// List elems = new ArrayList();\n   413\t\t\t\tList<NameValuePair> elems = new ArrayList<>();\n   414\t\t\t\telems.add(new NameValuePair(\"value\",\n   415\t\t\t\t\t\tnew SimpleElementValue(ElementValue.STRING, cg.getConstantPool(), perclauseString), cg.getConstantPool()));\n   416\t\t\t\tAnnotationGen ag = new AnnotationGen(new ObjectType(\"org/aspectj/lang/annotation/Aspect\"), elems, true,\n   417\t\t\t\t\t\tcg.getConstantPool());\n   418\t\t\t\tcg.addAnnotation(ag);\n   419\t\t\t}\n   420\t\t\tif (concreteAspect.precedence != null) {\n   421\t\t\t\tSimpleElementValue svg = new SimpleElementValue(ElementValue.STRING, cg.getConstantPool(), concreteAspect.precedence);\n   422\t\t\t\tList<NameValuePair> elems = new ArrayList<>();\n   423\t\t\t\telems.add(new NameValuePair(\"value\", svg, cg.getConstantPool()));\n   424\t\t\t\tAnnotationGen agprec = new AnnotationGen(new ObjectType(\"org/aspectj/lang/annotation/DeclarePrecedence\"), elems, true,\n   425\t\t\t\t\t\tcg.getConstantPool());\n   426\t\t\t\tcg.addAnnotation(agprec);\n   427\t\t\t}\n   428\t\n   429\t\t\t// default constructor\n   430\t\t\tLazyMethodGen init = new LazyMethodGen(Modifier.PUBLIC, Type.VOID, \"<init>\", EMPTY_TYPES, EMPTY_STRINGS, cg);\n   431\t\t\tInstructionList cbody = init.getBody();\n   432\t\t\tcbody.append(InstructionConstants.ALOAD_0);\n   433\t\n   434\t\t\tcbody.append(cg.getFactory().createInvoke(parentName, \"<init>\", Type.VOID, EMPTY_TYPES, Constants.INVOKESPECIAL));\n   435\t\t\tcbody.append(InstructionConstants.RETURN);\n   436\t\t\tcg.addMethodGen(init);\n   437\t\n   438\t\t\tfor (Definition.Pointcut abstractPc : concreteAspect.pointcuts) {\n   439\t\t\t\t// TODO AV - respect visibility instead of opening up as public?\n   440\t\t\t\tLazyMethodGen mg = new LazyMethodGen(Modifier.PUBLIC, Type.VOID, abstractPc.name, EMPTY_TYPES, EMPTY_STRINGS, cg);\n   441\t\t\t\tSimpleElementValue svg = new SimpleElementValue(ElementValue.STRING, cg.getConstantPool(), abstractPc.expression);\n   442\t\t\t\tList<NameValuePair> elems = new ArrayList<>();\n   443\t\t\t\telems.add(new NameValuePair(\"value\", svg, cg.getConstantPool()));\n   444\t\t\t\tAnnotationGen mag = new AnnotationGen(new ObjectType(\"org/aspectj/lang/annotation/Pointcut\"), elems, true,\n   445\t\t\t\t\t\tcg.getConstantPool());\n   446\t\t\t\tAnnotationAJ max = new BcelAnnotation(mag, world);\n   447\t\t\t\tmg.addAnnotation(max);\n   448\t\n   449\t\t\t\tInstructionList body = mg.getBody();\n   450\t\t\t\tbody.append(InstructionConstants.RETURN);\n   451\t\t\t\tcg.addMethodGen(mg);\n   452\t\t\t}\n   453\t\n   454\t\t\t// Construct any defined declare error/warnings\n   455\t\t\tif (concreteAspect.deows.size() > 0) {\n   456\t\t\t\tint counter = 1;\n   457\t\t\t\tfor (Definition.DeclareErrorOrWarning deow : concreteAspect.deows) {\n   458\t\t\t\t\t// Building this:\n   459\t\t\t\t\t// @DeclareWarning(\"call(* javax.sql..*(..)) && !within(org.xyz.daos..*)\")\n   460\t\t\t\t\t// static final String aMessage = \"Only DAOs should be calling JDBC.\";\n   461\t\n   462\t\t\t\t\tFieldGen field = new FieldGen(Modifier.FINAL, ObjectType.STRING, \"rule\" + (counter++), cg.getConstantPool());\n   463\t\t\t\t\tSimpleElementValue svg = new SimpleElementValue(ElementValue.STRING, cg.getConstantPool(), deow.pointcut);\n   464\t\t\t\t\tList<NameValuePair> elems = new ArrayList<>();\n   465\t\t\t\t\telems.add(new NameValuePair(\"value\", svg, cg.getConstantPool()));\n   466\t\t\t\t\tAnnotationGen mag = new AnnotationGen(new ObjectType(\"org/aspectj/lang/annotation/Declare\"\n   467\t\t\t\t\t\t\t+ (deow.isError ? \"Error\" : \"Warning\")), elems, true, cg.getConstantPool());\n   468\t\t\t\t\tfield.addAnnotation(mag);\n   469\t\n   470\t\t\t\t\tfield.setValue(deow.message);\n   471\t\t\t\t\tcg.addField(field, null);\n   472\t\t\t\t}\n   473\t\t\t}\n   474\t\n   475\t\t\tif (concreteAspect.pointcutsAndAdvice.size() > 0) {\n   476\t\t\t\tint adviceCounter = 1;\n   477\t\t\t\tfor (PointcutAndAdvice paa : concreteAspect.pointcutsAndAdvice) {\n   478\t\t\t\t\tgenerateAdviceMethod(paa, adviceCounter, cg);\n   479\t\t\t\t\tadviceCounter++;\n   480\t\t\t\t}\n   481\t\t\t}\n   482\t\n   483\t\t\tif (concreteAspect.declareAnnotations.size()>0) {\n   484\t\t\t\tint decCounter = 1;\n   485\t\t\t\tfor (Definition.DeclareAnnotation da: concreteAspect.declareAnnotations) {\n   486\t\t\t\t\tgenerateDeclareAnnotation(da,decCounter++,cg);\n   487\t\t\t\t}\n   488\t\t\t}\n   489\t\n   490\t\t\t// handle the perClause\n   491\t\t\tReferenceType rt = new ReferenceType(ResolvedType.forName(concreteAspect.name).getSignature(), world);\n   492\t\t\tGeneratedReferenceTypeDelegate grtd = new GeneratedReferenceTypeDelegate(rt);\n   493\t\t\tgrtd.setSuperclass(parent);\n   494\t\t\trt.setDelegate(grtd);\n   495\t\n   496\t\t\tBcelPerClauseAspectAdder perClauseMunger = new BcelPerClauseAspectAdder(rt, perclauseKind);\n   497\t\t\tperClauseMunger.forceMunge(cg, false);\n   498\t\n   499\t\t\t// TODO AV - unsafe cast\n   500\t\t\t// register the fresh new class into the world repository as it does not\n   501\t\t\t// exist on the classpath anywhere\n   502\t\t\tJavaClass jc = cg.getJavaClass((BcelWorld) world);\n   503\t\t\t((BcelWorld) world).addSourceObjectType(jc, true);\n   504\t\n   505\t\t\tbytes = jc.getBytes();\n   506\t\t\treturn bytes;\n   507\t\t}\n   508\t\n   509\t\t/**\n   510\t\t * The DeclareAnnotation object encapsulates an method/field/type descriptor and an annotation. This uses a DeclareAnnotation object\n   511\t\t * captured from the XML (something like '<declare-annotation field=\"* field1(..)\" annotation=\"@Annot(a='a',fred=false,'abc')\"/>')\n   512\t\t * and builds the same construct that would have existed if the code style variant was used.  This involves creating a member upon\n   513\t\t * which to hang the real annotation and then creating a classfile level attribute indicating a declare annotation is present\n   514\t\t * (that includes the signature pattern and a pointer to the real member holding the annotation).\n   515\t\t *\n   516\t\t */\n   517\t\tprivate void generateDeclareAnnotation(Definition.DeclareAnnotation da, int decCounter, LazyClassGen cg) {\n   518\t\n   519\t\t\t// Here is an example member from a code style declare annotation:\n   520\t\t\t//void ajc$declare_at_method_1();\n   521\t\t\t//  RuntimeInvisibleAnnotations: length = 0x6\n   522\t\t\t//   00 01 00 1B 00 00\n   523\t\t\t//  RuntimeVisibleAnnotations: length = 0x15\n   524\t\t\t//   00 01 00 1D 00 03 00 1E 73 00 1F 00 20 73 00 21\n   525\t\t\t//   00 22 73 00 23\n   526\t\t\t//  org.aspectj.weaver.MethodDeclarationLineNumber: length = 0x8\n   527\t\t\t//   00 00 00 02 00 00 00 16\n   528\t\t\t//  org.aspectj.weaver.AjSynthetic: length = 0x\n   529\t\t\t//\n   530\t\t\t//  Code:\n   531\t\t\t//   Stack=0, Locals=1, Args_size=1\n   532\t\t\t//   0:\treturn\n   533\t\n   534\t\t\t// and at the class level a Declare attribute:\n   535\t\t\t//\t\t  org.aspectj.weaver.Declare: length = 0x51\n   536\t\t\t//\t\t   05 00 00 00 03 01 00 05 40 41 6E 6E 6F 01 00 17\n   537\t\t\t//\t\t   61 6A 63 24 64 65 63 6C 61 72 65 5F 61 74 5F 6D\n   538\t\t\t//\t\t   65 74 68 6F 64 5F 31 01 01 00 00 00 00 05 05 00\n   539\t\t\t//\t\t   08 73 61 79 48 65 6C 6C 6F 00 01 04 00 00 00 00\n   540\t\t\t//\t\t   07 00 00 00 27 00 00 00 34 00 00 00 16 00 00 00\n   541\t\t\t//\t\t   3C\n   542\t\n   543\t\t\tAnnotationAJ constructedAnnotation = buildDeclareAnnotation_actualAnnotation(cg, da);\n   544\t\t\tif (constructedAnnotation==null) {\n   545\t\t\t\treturn; // error occurred (and was reported), do not continue\n   546\t\t\t}\n   547\t\n   548\t\t\tString nameComponent = da.declareAnnotationKind.name().toLowerCase();\n   549\t\t\tString declareName = new StringBuilder(\"ajc$declare_at_\").append(nameComponent).append(\"_\").append(decCounter).toString();\n   550\t\t\tLazyMethodGen declareMethod = new LazyMethodGen(Modifier.PUBLIC, Type.VOID, declareName, Type.NO_ARGS, EMPTY_STRINGS, cg);\n   551\t\t\tInstructionList declareMethodBody = declareMethod.getBody();\n   552\t\t\tdeclareMethodBody.append(InstructionFactory.RETURN);\n   553\t\t\tdeclareMethod.addAnnotation(constructedAnnotation);\n   554\t\n   555\t\t\tDeclareAnnotation deca = null;\n   556\t\t\tITokenSource tokenSource = BasicTokenSource.makeTokenSource(da.pattern,null);\n   557\t\t\tPatternParser pp = new PatternParser(tokenSource);\n   558\t\n   559\t\t\tif (da.declareAnnotationKind==DeclareAnnotationKind.Method || da.declareAnnotationKind==DeclareAnnotationKind.Field) {\n   560\t\t\t\tISignaturePattern isp = (da.declareAnnotationKind==DeclareAnnotationKind.Method?pp.parseCompoundMethodOrConstructorSignaturePattern(true):pp.parseCompoundFieldSignaturePattern());\n     1\t/*******************************************************************************\n     2\t * Copyright (c) 2005 Contributors.\n     3\t * All rights reserved.\n     4\t * This program and the accompanying materials are made available\n     5\t * under the terms of the Eclipse Public License v 2.0\n     6\t * which accompanies this distribution and is available at\n     7\t * https://www.eclipse.org/org/documents/epl-2.0/EPL-2.0.txt\n     8\t *\n     9\t * Contributors:\n    10\t *   Alexandre Vasseur         initial implementation\n    11\t *******************************************************************************/\n    12\tpackage org.aspectj.weaver.loadtime.definition;\n    13\t\n    14\timport java.util.ArrayList;\n    15\timport java.util.HashMap;\n    16\timport java.util.List;\n    17\timport java.util.Map;\n    18\t\n    19\t/**\n    20\t * A POJO that contains raw strings from the XML (sort of XMLBean for our simple LTW DTD)\n    21\t *\n    22\t * @author Alexandre Vasseur (alex AT gnilux DOT com)\n    23\t */\n    24\tpublic class Definition {\n    25\t\n    26\t\tprivate final StringBuffer weaverOptions;\n    27\t\tprivate final List<String> dumpPatterns;\n    28\t\tprivate boolean dumpBefore;\n    29\t\tprivate boolean perClassloaderDumpDir;\n    30\t\tprivate final List<String> includePatterns;\n    31\t\tprivate final List<String> excludePatterns;\n    32\t\tprivate final List<String> aspectClassNames;\n    33\t\tprivate final List<String> aspectExcludePatterns;\n    34\t\tprivate final List<String> aspectIncludePatterns;\n    35\t\tprivate final List<Definition.ConcreteAspect> concreteAspects;\n    36\t\n    37\t\t/**\n    38\t\t * When aspects are defined, they can specify a scope type pattern and then will only apply to types matching that pattern.\n    39\t\t */\n    40\t\tprivate final Map<String, String> scopedAspects;\n    41\t\n    42\t\t/**\n    43\t\t * Some aspects (from aspect libraries) will describe a type that must be around for them to function properly\n    44\t\t */\n    45\t\tprivate final Map<String, String> requiredTypesForAspects;\n    46\t\n    47\t\tpublic Definition() {\n    48\t\t\tweaverOptions = new StringBuffer();\n    49\t\t\tdumpBefore = false;\n    50\t\t\tperClassloaderDumpDir = false;\n    51\t\t\tdumpPatterns = new ArrayList<>();\n    52\t\t\tincludePatterns = new ArrayList<>();\n    53\t\t\texcludePatterns = new ArrayList<>();\n    54\t\t\taspectClassNames = new ArrayList<>();\n    55\t\t\taspectExcludePatterns = new ArrayList<>();\n    56\t\t\taspectIncludePatterns = new ArrayList<>();\n    57\t\t\tconcreteAspects = new ArrayList<>();\n    58\t\t\tscopedAspects = new HashMap<>();\n    59\t\t\trequiredTypesForAspects = new HashMap<>();\n    60\t\t}\n    61\t\n    62\t\tpublic String getWeaverOptions() {\n    63\t\t\treturn weaverOptions.toString();\n    64\t\t}\n    65\t\n    66\t\tpublic List<String> getDumpPatterns() {\n    67\t\t\treturn dumpPatterns;\n    68\t\t}\n    69\t\n    70\t\tpublic void setDumpBefore(boolean b) {\n    71\t\t\tdumpBefore = b;\n    72\t\t}\n    73\t\n    74\t\tpublic boolean shouldDumpBefore() {\n    75\t\t\treturn dumpBefore;\n    76\t\t}\n    77\t\n    78\t\tpublic void setCreateDumpDirPerClassloader(boolean b) {\n    79\t\t\tperClassloaderDumpDir = b;\n    80\t\t}\n    81\t\n    82\t\tpublic boolean createDumpDirPerClassloader() {\n    83\t\t\treturn perClassloaderDumpDir;\n    84\t\t}\n    85\t\n    86\t\tpublic List<String> getIncludePatterns() {\n    87\t\t\treturn includePatterns;\n    88\t\t}\n    89\t\n    90\t\tpublic List<String> getExcludePatterns() {\n    91\t\t\treturn excludePatterns;\n    92\t\t}\n    93\t\n    94\t\tpublic List<String> getAspectClassNames() {\n    95\t\t\treturn aspectClassNames;\n    96\t\t}\n    97\t\n    98\t\tpublic List<String> getAspectExcludePatterns() {\n    99\t\t\treturn aspectExcludePatterns;\n   100\t\t}\n   101\t\n   102\t\tpublic List<String> getAspectIncludePatterns() {\n   103\t\t\treturn aspectIncludePatterns;\n   104\t\t}\n   105\t\n   106\t\tpublic List<Definition.ConcreteAspect> getConcreteAspects() {\n   107\t\t\treturn co