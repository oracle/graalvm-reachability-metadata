   125\t\t */\n   126\t\tpublic boolean validate() {\n   127\t\t\tif (!(world instanceof BcelWorld)) {\n   128\t\t\t\treportError(\"Internal error: world must be of type BcelWorld\");\n   129\t\t\t\treturn false;\n   130\t\t\t}\n   131\t\n   132\t\t\t// name must be undefined so far\n   133\t\t\t// TODO only convert the name to signature once, probably earlier than this\n   134\t\t\tResolvedType current = world.lookupBySignature(UnresolvedType.forName(concreteAspect.name).getSignature());\n   135\t\n   136\t\t\tif (current != null && !current.isMissing()) {\n   137\t\t\t\treportError(\"Attempt to concretize but chosen aspect name already defined: \" + stringify());\n   138\t\t\t\treturn false;\n   139\t\t\t}\n   140\t\n   141\t\t\tif (concreteAspect.pointcutsAndAdvice.size() != 0) {\n   142\t\t\t\tisValid = true;\n   143\t\t\t\treturn true;\n   144\t\t\t}\n   145\t\n   146\t\t\tif (concreteAspect.declareAnnotations.size()!=0) {\n   147\t\t\t\tisValid = true;\n   148\t\t\t\treturn true;\n   149\t\t\t}\n   150\t\n   151\t\t\t// it can happen that extends is null, for precedence only declaration\n   152\t\t\tif (concreteAspect.extend == null && concreteAspect.precedence != null) {\n   153\t\t\t\tif (concreteAspect.pointcuts.isEmpty()) {\n   154\t\t\t\t\tisValid = true;\n   155\t\t\t\t\t// m_perClause = new PerSingleton();\n   156\t\t\t\t\tparent = null;\n   157\t\t\t\t\treturn true;// no need to checks more in that special case\n   158\t\t\t\t} else {\n   159\t\t\t\t\treportError(\"Attempt to use nested pointcuts without extends clause: \" + stringify());\n   160\t\t\t\t\treturn false;\n   161\t\t\t\t}\n   162\t\t\t}\n   163\t\n   164\t\t\tString parentAspectName = concreteAspect.extend;\n   165\t\n   166\t\t\tif (parentAspectName.contains(\"<\")) {\n   167\t\t\t\t// yikes, generic parent\n   168\t\t\t\tparent = world.resolve(UnresolvedType.forName(parentAspectName), true);\n   169\t\t\t\tif (parent.isMissing()) {\n   170\t\t\t\t\treportError(\"Unable to resolve type reference: \" + stringify());\n   171\t\t\t\t\treturn false;\n   172\t\t\t\t}\n   173\t\t\t\tif (parent.isParameterizedType()) {\n   174\t\t\t\t\tUnresolvedType[] typeParameters = parent.getTypeParameters();\n   175\t\t\t\t\tfor (UnresolvedType typeParameter : typeParameters) {\n   176\t\t\t\t\t\tif (typeParameter instanceof ResolvedType && ((ResolvedType) typeParameter).isMissing()) {\n   177\t\t\t\t\t\t\treportError(\"Unablet to resolve type parameter '\" + typeParameter.getName() + \"' from \" + stringify());\n   178\t\t\t\t\t\t\treturn false;\n   179\t\t\t\t\t\t}\n   180\t\t\t\t\t}\n   181\t\t\t\t}\n   182\t\t\t} else {\n   183\t\t\t\tparent = world.resolve(concreteAspect.extend, true);\n   184\t\t\t}\n   185\t\t\t// handle inner classes\n   186\t\t\tif (parent.isMissing()) {\n   187\t\t\t\t// fallback on inner class lookup mechanism\n   188\t\t\t\tString fixedName = concreteAspect.extend;\n   189\t\t\t\tint hasDot = fixedName.lastIndexOf('.');\n   190\t\t\t\twhile (hasDot > 0) {\n   191\t\t\t\t\tchar[] fixedNameChars = fixedName.toCharArray();\n   192\t\t\t\t\tfixedNameChars[hasDot] = '$';\n   193\t\t\t\t\tfixedName = new String(fixedNameChars);\n   194\t\t\t\t\thasDot = fixedName.lastIndexOf('.');\n   195\t\t\t\t\tparent = world.resolve(UnresolvedType.forName(fixedName), true);\n   196\t\t\t\t\tif (!parent.isMissing()) {\n   197\t\t\t\t\t\tbreak;\n   198\t\t\t\t\t}\n   199\t\t\t\t}\n   200\t\t\t}\n   201\t\n   202\t\t\tif (parent.isMissing()) {\n   203\t\t\t\treportError(\"Cannot find parent aspect for: \" + stringify());\n   204\t\t\t\treturn false;\n   205\t\t\t}\n   206\t\n   207\t\t\t// extends must be abstract (allow for special case of Object where just using aspect for deows)\n   208\t\t\tif (!(parent.isAbstract() || parent.equals(ResolvedType.OBJECT))) {\n   209\t\t\t\treportError(\"Attempt to concretize a non-abstract aspect: \" + stringify());\n   210\t\t\t\treturn false;\n   211\t\t\t}\n   212\t\n   213\t\t\t// m_parent must be aspect (allow for special case of Object where just using aspect for deows)\n   214\t\t\tif (!(parent.isAspect() || parent.equals(ResolvedType.OBJECT))) {\n   215\t\t\t\treportError(\"Attempt to concretize a non aspect: \" + stringify());\n   216\t\t\t\treturn false;\n   217\t\t\t}\n   218\t\n   219\t\t\t// must have all abstractions defined\n   220\t\t\tList<String> elligibleAbstractions = new ArrayList<>();\n   221\t\n   222\t\t\tCollection<ResolvedMember> abstractMethods = getOutstandingAbstractMethods(parent);\n   223\t\t\tfor (ResolvedMember method : abstractMethods) {\n   224\t\t\t\tif (\"()V\".equals(method.getSignature())) {\n   225\t\t\t\t\tString n = method.getName();\n   226\t\t\t\t\t// Allow for the abstract pointcut being from a code style\n   227\t\t\t\t\t// aspect compiled with -1.5 (see test for 128744)\n   228\t\t\t\t\tif (n.startsWith(\"ajc$pointcut\")) {\n   229\t\t\t\t\t\tn = n.substring(14);\n   230\t\t\t\t\t\tn = n.substring(0, n.indexOf(\"$\"));\n   231\t\t\t\t\t\telligibleAbstractions.add(n);\n   232\t\t\t\t\t} else if (hasPointcutAnnotation(method)) {\n   233\t\t\t\t\t\telligibleAbstractions.add(method.getName());\n   234\t\t\t\t\t} else {\n   235\t\t\t\t\t\t// error, an outstanding abstract method that can't be\n   236\t\t\t\t\t\t// concretized in XML\n   237\t\t\t\t\t\treportError(\"Abstract method '\" + method.toString() + \"' cannot be concretized in XML: \" + stringify());\n   238\t\t\t\t\t\treturn false;\n   239\t\t\t\t\t}\n   240\t\t\t\t} else {\n   241\t\t\t\t\tif (method.getName().startsWith(\"ajc$pointcut\") || hasPointcutAnnotation(method)) {\n   242\t\t\t\t\t\t// it may be a pointcut but it doesn't meet the requirements for XML concretization\n   243\t\t\t\t\t\treportError(\"Abstract method '\"\n   244\t\t\t\t\t\t\t\t+ method.toString()\n   245\t\t\t\t\t\t\t\t+ \"' cannot be concretized as a pointcut (illegal signature, must have no arguments, must return void): \"\n   246\t\t\t\t\t\t\t\t+ stringify());\n   247\t\t\t\t\t\treturn false;\n   248\t\t\t\t\t} else {\n   249\t\t\t\t\t\t// error, an outstanding abstract method that can't be\n   250\t\t\t\t\t\t// concretized in XML\n   251\t\t\t\t\t\treportError(\"Abstract method '\" + method.toString() + \"' cannot be concretized in XML: \" + stringify());\n   252\t\t\t\t\t\treturn false;\n   253\t\t\t\t\t}\n   254\t\t\t\t}\n   255\t\t\t}\n   256\t\t\tList<String> pointcutNames = new ArrayList<>();\n   257\t\t\tfor (Definition.Pointcut abstractPc : concreteAspect.pointcuts) {\n   258\t\t\t\tpointcutNames.add(abstractPc.name);\n   259\t\t\t}\n   260\t\t\tfor (String elligiblePc : elligibleAbstractions) {\n"}], "isError": false, "timestamp": 1777431158094}}
