     129		class SimpleGeneratedClassHandler implements GeneratedClassHandler {
     130			private BcelWeakClassLoaderReference loaderRef;
     131	
     132			SimpleGeneratedClassHandler(ClassLoader loader) {
     133				loaderRef = new BcelWeakClassLoaderReference(loader);
     134			}
     135	
     136			/**
     137			 * Callback when we need to define a Closure in the JVM
     138			 *
     139			 */
     140			@Override
     141			public void acceptClass (String name, byte[] originalBytes, byte[] wovenBytes) {
     142				try {
     143					if (shouldDump(name.replace('/', '.'), false)) {
     144						dump(name, wovenBytes, false);
     145					}
     146				} catch (Throwable throwable) {
     147					throwable.printStackTrace();
     148				}
     149				if (activeProtectionDomain != null) {
     150					defineClass(loaderRef.getClassLoader(), name, wovenBytes, activeProtectionDomain);
     151				} else {
     152					defineClass(loaderRef.getClassLoader(), name, wovenBytes); // could be done lazily using the hook
     153				}
     154			}
     155		}
