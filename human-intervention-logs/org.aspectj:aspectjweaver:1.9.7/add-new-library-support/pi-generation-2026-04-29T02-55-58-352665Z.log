     335		public void endElement(String uri, String localName, String qName) throws SAXException {
     336			if (CONCRETE_ASPECT_ELEMENT.equals(qName)) {
     337				activeConcreteAspectDefinition = null;
     338			} else if (ASPECTJ_ELEMENT.equals(qName)) {
     339				inAspectJ = false;
     340			} else if (WEAVER_ELEMENT.equals(qName)) {
     341				inWeaver = false;
     342			} else if (ASPECTS_ELEMENT.equals(qName)) {
     343				inAspects = false;
     344			}
     345			super.endElement(uri, localName, qName);
     346		}
