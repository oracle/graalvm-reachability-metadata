     110		public static class ConcreteAspect {
     111			public final String name;
     112			public final String extend;
     113			public final String precedence;
     114			public final List<Definition.Pointcut> pointcuts;
     115			public final List<Definition.DeclareAnnotation> declareAnnotations;
     116			public final List<Definition.PointcutAndAdvice> pointcutsAndAdvice;
     117			public final String perclause;
     118			public List<Definition.DeclareErrorOrWarning> deows;
     119	
     120			public ConcreteAspect(String name, String extend) {
     121				this(name, extend, null, null);
     122			}
     123	
     124			public ConcreteAspect(String name, String extend, String precedence, String perclause) {
     125				this.name = name;
     126				// make sure extend set to null if ""
     127				if (extend == null || extend.length() == 0) {
     128					this.extend = null;
     129					if (precedence == null || precedence.length() == 0) {
     130						// if (pointcutsAndAdvice.size() == 0) {
     131						// throw new RuntimeException("Not allowed");
     132						// }
     133					}
     134				} else {
     135					this.extend = extend;
     136				}
     137				this.precedence = precedence;
     138				this.pointcuts = new ArrayList<>();
     139				this.declareAnnotations = new ArrayList<>();
     140				this.pointcutsAndAdvice = new ArrayList<>();
     141				this.deows = new ArrayList<>();
     142				this.perclause = perclause;
     143			}
     144		}
