     231		/**
     232		 * Load and cache the aop.xml/properties according to the classloader visibility rules
     233		 *
     234		 * @param loader
     235		 */
     236		List<Definition> parseDefinitions(final ClassLoader loader) {
     237			if (trace.isTraceEnabled()) {
     238				trace.enter("parseDefinitions", this);
     239			}
     240	
     241			List<Definition> definitions = new ArrayList<>();
     242			try {
     243				info("register classloader " + getClassLoaderName(loader));
     244				// TODO av underoptimized: we will parse each XML once per CL that see it
     245	
     246				// TODO av dev mode needed ? TBD -Daj5.def=...
     247				if (loader.equals(ClassLoader.getSystemClassLoader())) {
     248					String file = System.getProperty("aj5.def", null);
     249					if (file != null) {
     250						info("using (-Daj5.def) " + file);
     251						definitions.add(DocumentParser.parse((new File(file)).toURI().toURL()));
     252					}
     253				}
     254	
     255				String resourcePath = System.getProperty("org.aspectj.weaver.loadtime.configuration", AOP_XML);
     256				if (trace.isTraceEnabled()) {
     257					trace.event("parseDefinitions", this, resourcePath);
     258				}
     259	
     260				StringTokenizer st = new StringTokenizer(resourcePath, ";");
     261	
     262				while (st.hasMoreTokens()) {
     263					String nextDefinition = st.nextToken();
     264					if (nextDefinition.startsWith("file:")) {
     265						try {
     266							String fpath = new URL(nextDefinition).getFile();
     267							File configFile = new File(fpath);
     268							if (!configFile.exists()) {
     269								warn("configuration does not exist: " + nextDefinition);
     270							} else {
     271								definitions.add(DocumentParser.parse(configFile.toURI().toURL()));
     272							}
     273						} catch (MalformedURLException mue) {
     274							error("malformed definition url: " + nextDefinition);
     275						}
     276					} else {
     277						Enumeration<URL> xmls = weavingContext.getResources(nextDefinition);
     278						// System.out.println("? registerDefinitions: found-aop.xml=" + xmls.hasMoreElements() + ", loader=" + loader);
     279	
     280						Set<URL> seenBefore = new HashSet<>();
     281						while (xmls.hasMoreElements()) {
     282							URL xml = xmls.nextElement();
     283							if (trace.isTraceEnabled()) {
     284								trace.event("parseDefinitions", this, xml);
     285							}
     286							if (!seenBefore.contains(xml)) {
     287								info("using configuration " + weavingContext.getFile(xml));
     288								definitions.add(DocumentParser.parse(xml));
     289								seenBefore.add(xml);
     290							} else {
     291								debug("ignoring duplicate definition: " + xml);
     292							}
     293						}
     294					}
     295				}
     296				if (definitions.isEmpty()) {
     297					info("no configuration found. Disabling weaver for class loader " + getClassLoaderName(loader));
     298				}
     299			} catch (Exception e) {
     300				definitions.clear();
     301				warn("parse definitions failed", e);
     302			}
     303	
     304			if (trace.isTraceEnabled()) {
     305				trace.exit("parseDefinitions", definitions);
     306			}
     307			return definitions;
     308		}
     309	
     310		private boolean registerDefinitions(final BcelWeaver weaver, final ClassLoader loader, List<Definition> definitions) {
     311			if (trace.isTraceEnabled()) {
     312				trace.enter("registerDefinitions", this, definitions);
     313			}
     314			boolean success = true;
     315	
     316			try {
     317				registerOptions(weaver, loader, definitions);
     318				registerAspectExclude(weaver, loader, definitions);
     319				registerAspectInclude(weaver, loader, definitions);
     320				success = registerAspects(weaver, loader, definitions);
     321				registerIncludeExclude(weaver, loader, definitions);
     322				registerDump(weaver, loader, definitions);
     323			} catch (Exception ex) {
     324				trace.error("register definition failed", ex);
     325				success = false;
     326				warn("register definition failed", (ex instanceof AbortException) ? null : ex);
     327			}
     328	
     329			if (trace.isTraceEnabled()) {
     330				trace.exit("registerDefinitions", success);
     420					if (weaverOption.lint.equals("ignore")) {
     421						bcelWorld.setAllLintIgnored();
     422					}
     423				}
     424			}
     425			// TODO proceedOnError option
     426		}
