     428		private void registerAspectExclude(final BcelWeaver weaver, final ClassLoader loader, final List<Definition> definitions) {
     429			String fastMatchInfo = null;
     430			for (Definition definition : definitions) {
     431				for (String exclude : definition.getAspectExcludePatterns()) {
     432					TypePattern excludePattern = new PatternParser(exclude).parseTypePattern();
     433					aspectExcludeTypePattern.add(excludePattern);
     434					fastMatchInfo = looksLikeStartsWith(exclude);
     435					if (fastMatchInfo != null) {
     436						aspectExcludeStartsWith.add(fastMatchInfo);
     437					}
     438				}
     439			}
     440		}
     441	
     442		private void registerAspectInclude(final BcelWeaver weaver, final ClassLoader loader, final List<Definition> definitions) {
     443			String fastMatchInfo = null;
     444			for (Definition definition : definitions) {
     445				for (String include : definition.getAspectIncludePatterns()) {
     446					TypePattern includePattern = new PatternParser(include).parseTypePattern();
     447					aspectIncludeTypePattern.add(includePattern);
     448					fastMatchInfo = looksLikeStartsWith(include);
     449					if (fastMatchInfo != null) {
     450						aspectIncludeStartsWith.add(fastMatchInfo);
     451					}
     452				}
     453			}
     454		}
