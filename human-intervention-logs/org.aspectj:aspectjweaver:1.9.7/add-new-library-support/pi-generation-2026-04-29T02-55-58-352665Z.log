     323		private String stringify() {
     324			StringBuffer sb = new StringBuffer("<concrete-aspect name='");
     325			sb.append(concreteAspect.name);
     326			sb.append("' extends='");
     327			sb.append(concreteAspect.extend);
     328			sb.append("' perclause='");
     329			sb.append(concreteAspect.perclause);
     330			sb.append("'/> in aop.xml");
     331			// TODO needs the extra state from the definition (concretized pointcuts and advice definitions)
     332			return sb.toString();
     333		}
