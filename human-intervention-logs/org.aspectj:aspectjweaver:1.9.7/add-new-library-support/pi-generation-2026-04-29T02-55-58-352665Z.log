n   366\t\t\t\tAj.loadersToSkip = LangUtil.anySplit(weaverOption.loadersToSkip, \",\");\n   367\t\t\t}\n   368\t\t\tif (Aj.loadersToSkip != null) {\n   369\t\t\t\tMessageUtil.info(world.getMessageHandler(),\"no longer creating weavers for these classloaders: \"+Aj.loadersToSkip);\n   370\t\t\t}\n   371\t\t\tworld.performExtraConfiguration(weaverOption.xSet);\n   372\t\t\tworld.setXnoInline(weaverOption.noInline);\n   373\t\t\t// AMC - autodetect as per line below, needed for AtAjLTWTests.testLTWUnweavable\n   374\t\t\tworld.setBehaveInJava5Way(true);\n   375\t\t\tworld.setAddSerialVerUID(weaverOption.addSerialVersionUID);\n   376\t\n   377\t\t\t/* First load defaults */\n   378\t\t\tbcelWorld.getLint().loadDefaultProperties();\n   379\t\n   380\t\t\t/* Second overlay LTW defaults */\n   381\t\t\tbcelWorld.getLint().adviceDidNotMatch.setKind(null);\n   382\t\n   383\t\t\t/* Third load user file using -Xlintfile so that -Xlint wins */\n   384\t\t\tif (weaverOption.lintFile != null) {\n   385\t\t\t\tInputStream resource = null;\n   386\t\t\t\ttry {\n   387\t\t\t\t\tresource = loader.getResourceAsStream(weaverOption.lintFile);\n   388\t\t\t\t\tException failure = null;\n   389\t\t\t\t\tif (resource != null) {\n   390\t\t\t\t\t\ttry {\n   391\t\t\t\t\t\t\tProperties properties = new Properties();\n   392\t\t\t\t\t\t\tproperties.load(resource);\n   393\t\t\t\t\t\t\tworld.getLint().setFromProperties(properties);\n   394\t\t\t\t\t\t} catch (IOException e) {\n   395\t\t\t\t\t\t\tfailure = e;\n   396\t\t\t\t\t\t}\n   397\t\t\t\t\t}\n   398\t\t\t\t\tif (failure != null || resource == null) {\n   399\t\t\t\t\t\twarn(\"Cannot access resource for -Xlintfile:\" + weaverOption.lintFile, failure);\n   400\t\t\t\t\t\t// world.getMessageHandler().handleMessage(new Message(\n   401\t\t\t\t\t\t// \"Cannot access resource for -Xlintfile:\"+weaverOption.lintFile,\n   402\t\t\t\t\t\t// IMessage.WARNING,\n   403\t\t\t\t\t\t// failure,\n   404\t\t\t\t\t\t// null));\n   405\t\t\t\t\t}\n   406\t\t\t\t} finally {\n   407\t\t\t\t\ttry {\n   408\t\t\t\t\t\tresource.close();\n   409\t\t\t\t\t} catch (Throwable t) {\n   410\t\t\t\t\t}\n   411\t\t\t\t}\n   412\t\t\t}\n   413\t\n   414\t\t\t/* Fourth override with -Xlint */\n   415\t\t\tif (weaverOption.lint != null) {\n   416\t\t\t\tif (weaverOption.lint.equals(\"default\")) {// FIXME should be AjBuildConfig.AJLINT_DEFAULT but yetanother deps..\n   417\t\t\t\t\tbcelWorld.getLint().loadDefaultProperties();\n   418\t\t\t\t} else {\n   419\t\t\t\t\tbcelWorld.getLint().setAll(weaverOption.lint);\n   420\t\t\t\t\tif (weaverOption.lint.equals(\"ignore\")) {\n  1010\t\t * remove any entries related to this name - so the class itself plus\n  1011\t\t * and inner classes.\n  1012\t\t * @param className a slashed classname (e.g. com/foo/Bar)\n  1013\t\t */\n  1014\t\tpublic void flushGeneratedClassesFor(String className) {\n  1015\t\t\ttry {\n  1016\t\t\t\tString dottedClassName = className.replace('/', '.');\n  1017\t\t\t\tString dottedClassNameDollar = dottedClassName+\"$\"; // to pickup inner classes\n  1018\t\t\t\tIterator<Map.Entry<String, IUnwovenClassFile>> iter = generatedClasses.entrySet().iterator();\n  1019\t\t\t\twhile (iter.hasNext()) {\n  1020\t\t\t\t\tEntry<String, IUnwovenClassFile> next = iter.next();\n  1021\t\t\t\t\tString existingGeneratedName = next.getKey();\n  1022\t\t\t\t\tif (existingGeneratedName.equals(dottedClassName) ||\n  1023\t\t\t\t\t\t\texistingGeneratedName.startsWith(dottedClassNameDollar)) {\n  1024\t\t\t\t\t\titer.remove();\n  1025\t\t\t\t\t}\n  1026\t\t\t\t}\n  1027\t\t\t} catch (Throwable t) {\n  1028\t\t\t\tnew RuntimeException(\"Unexpected problem tidying up generated classes for \"+className,t).printStackTrace();\n  1029\t\t\t}\n  1030\t\t}\n  1031\t\n  1032\t\tprivate Unsafe unsafe;\n  1033\t\n  1034\t\tprivate Unsafe getUnsafe() throws NoSuchFieldException, IllegalAccessException {\n  1035\t\t\tif (unsafe == null) {\n  1036\t\t        Field theUnsafeField = Unsafe.class.getDec