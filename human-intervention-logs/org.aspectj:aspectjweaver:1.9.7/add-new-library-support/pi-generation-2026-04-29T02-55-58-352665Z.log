     943	
     944			// TODO AV - optimize for className.startWith only
     945			ResolvedType classInfo = weaver.getWorld().resolve(UnresolvedType.forName(className), true);
     946			// dump
     947			for (TypePattern typePattern : dumpTypePattern) {
     948				if (typePattern.matchesStatically(classInfo)) {
     949					// dump match
     950					return true;
     951				}
     952			}
     953			return false;
     954		}
