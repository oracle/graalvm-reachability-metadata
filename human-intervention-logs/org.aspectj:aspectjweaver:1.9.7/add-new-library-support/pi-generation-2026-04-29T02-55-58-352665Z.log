erence: \" + stringify());\n   171\t\t\t\t\treturn false;\n   172\t\t\t\t}\n   173\t\t\t\tif (parent.isParameterizedType()) {\n   174\t\t\t\t\tUnresolvedType[] typeParameters = parent.getTypeParameters();\n   175\t\t\t\t\tfor (UnresolvedType typeParameter : typeParameters) {\n   176\t\t\t\t\t\tif (typeParameter instanceof ResolvedType && ((ResolvedType) typeParameter).isMissing()) {\n   177\t\t\t\t\t\t\treportError(\"Unablet to resolve type parameter '\" + typeParameter.getName() + \"' from \" + stringify());\n   178\t\t\t\t\t\t\treturn false;\n   179\t\t\t\t\t\t}\n   180\t\t\t\t\t}\n   181\t\t\t\t}\n   182\t\t\t} else {\n   183\t\t\t\tparent = world.resolve(concreteAspect.extend, true);\n   184\t\t\t}\n   185\t\t\t// handle inner classes\n   186\t\t\tif (parent.isMissing()) {\n   187\t\t\t\t// fallback on inner class lookup mechanism\n   188\t\t\t\tString fixedName = concreteAspect.extend;\n   189\t\t\t\tint hasDot = fixedName.lastIndexOf('.');\n   190\t\t\t\twhile (hasDot > 0) {\n   191\t\t\t\t\tchar[] fixedNameChars = fixedName.toCharArray();\n   192\t\t\t\t\tfixedNameChars[hasDot] = '$';\n   193\t\t\t\t\tfixedName = new String(fixedNameChars);\n   194\t\t\t\t\thasDot = fixedName.lastIndexOf('.');\n   195\t\t\t\t\tparent = world.resolve(UnresolvedType.forName(fixedName), true);\n   196\t\t\t\t\tif (!parent.isMissing()) {\n   197\t\t\t\t\t\tbreak;\n   198\t\t\t\t\t}\n   199\t\t\t\t}\n   200\t\t\t}\n   201\t\n   202\t\t\tif (parent.isMissing()) {\n   203\t\t\t\treportError(\"Cannot find parent aspect for: \" + stringify());\n   204\t\t\t\treturn false;\n   205\t\t\t}\n   206\t\n   207\t\t\t// extends must be abstract (allow for special case of Object where just using aspect for deows)\n   208\t\t\tif (!(parent.isAbstract() || parent.equals(ResolvedType.OBJECT))) {\n   209\t\t\t\treportError(\"Attempt to concretize a non-abstract aspect: \" + stringify());\n   210\t\t\t\treturn false;\n   211\t\t\t}\n   212\t\n   213\t\t\t// m_parent must be aspect (allow for specia