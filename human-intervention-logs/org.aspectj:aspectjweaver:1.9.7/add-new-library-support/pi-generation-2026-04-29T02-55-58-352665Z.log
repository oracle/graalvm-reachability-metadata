     284		private Collection<ResolvedMember> getOutstandingAbstractMethods(ResolvedType type) {
     285			Map<String, ResolvedMember> collector = new HashMap<>();
     286			// let's get to the top of the hierarchy and then walk down ...
     287			// recording abstract methods then removing
     288			// them if they get defined further down the hierarchy
     289			getOutstandingAbstractMethodsHelper(type, collector);
     290			return collector.values();
     291		}
     292	
     293		// We are trying to determine abstract methods left over at the bottom of a
     294		// hierarchy that have not been concretized.
     295		private void getOutstandingAbstractMethodsHelper(ResolvedType type, Map<String, ResolvedMember> collector) {
     296			if (type == null) {
     297				return;
     298			}
     299			// Get to the top
     300			if (!type.equals(ResolvedType.OBJECT)) {
     301				if (type.getSuperclass() != null) {
     302					getOutstandingAbstractMethodsHelper(type.getSuperclass(), collector);
     303				}
     304			}
     305			ResolvedMember[] rms = type.getDeclaredMethods();
     306			if (rms != null) {
     307				for (ResolvedMember member : rms) {
     308					String key = member.getName() + member.getSignature();
     309					if (member.isAbstract()) {
     310						collector.put(key, member);
     311					} else {
     312						collector.remove(key);
     313					}
     314				}
     315			}
     316		}
