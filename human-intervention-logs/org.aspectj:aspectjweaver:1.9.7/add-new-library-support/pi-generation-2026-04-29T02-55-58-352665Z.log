t of XMLBean for our simple LTW DTD)\n    21\t *\n    22\t * @author Alexandre Vasseur (alex AT gnilux DOT com)\n    23\t */\n    24\tpublic class Definition {\n    25\t\n    26\t\tprivate final StringBuffer weaverOptions;\n    27\t\tprivate final List<String> dumpPatterns;\n    28\t\tprivate boolean dumpBefore;\n    29\t\tprivate boolean perClassloaderDumpDir;\n    30\t\tprivate final List<String> includePatterns;\n    31\t\tprivate final List<String> excludePatterns;\n    32\t\tprivate final List<String> aspectClassNames;\n    33\t\tprivate final List<String> aspectExcludePatterns;\n    34\t\tprivate final List<String> aspectIncludePatterns;\n    35\t\tprivate final List<Definition.ConcreteAspect> concreteAspects;\n    36\t\n    37\t\t/**\n    38\t\t * When aspects are defined, they can specify a scope type pattern and then will only apply to types matching that pattern.\n    39\t\t */\n    40\t\tprivate final Map<String, String> scopedAspects;\n    41\t\n    42\t\t/**\n    43\t\t * Some aspects (from aspect libraries) will describe a type that must be around for them to function properly\n    44\t\t */\n    45\t\tprivate final Map<String, String> requiredTypesForAspects;\n    46\t\n    47\t\tpublic Definition() {\n    48\t\t\tweaverOptions = new StringBuffer();\n    49\t\t\tdumpBefore = false;\n    50\t\t\tperClassloaderDumpDir = false;\n    51\t\t\tdumpPatterns = new ArrayList<>();\n    52\t\t\tincludePatterns = new ArrayList<>();\n    53\t\t\texcludePatterns = new ArrayList<>();\n    54\t\t\taspectClassNames = new ArrayList<>();\n    55\t\t\taspectExcludePatterns = new ArrayList<>();\n    56\t\t\taspectIncludePatterns = new ArrayList<>();\n    57\t\t\tconcreteAspects = new ArrayList<>();\n    58\t\t\tscopedAspects = new HashMap<>();\n    59\t\t\trequiredTypesForAspects = new HashMap<>();\n    60\t\t}\n    61\t\n    62\t\tpublic String getWeaverOptions() {\n    63\t\t\treturn weaverOptions.toString();\n    64\t\t}\n    65\t\n    66\t\tpublic List<String> getDump