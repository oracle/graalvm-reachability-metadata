     250				} else if (!isNull(typePat)) {
     251					// declare @type
     252					activeConcreteAspectDefinition.declareAnnotations.add(new Definition.DeclareAnnotation(DeclareAnnotationKind.Type,
     253							typePat, anno));
     254				}
     255			} else if (BEFORE_ELEMENT.equals(qName) && activeConcreteAspectDefinition != null) {
     256				String pointcut = attributes.getValue(POINTCUT_ELEMENT);
     257				String adviceClass = attributes.getValue("invokeClass");
     258				String adviceMethod = attributes.getValue("invokeMethod");
     259				if (!isNull(pointcut) && !isNull(adviceClass) && !isNull(adviceMethod)) {
     260					activeConcreteAspectDefinition.pointcutsAndAdvice.add(new Definition.PointcutAndAdvice(AdviceKind.Before,
     261							replaceXmlAnd(pointcut), adviceClass, adviceMethod));
     262				} else {
     263					throw new SAXException("Badly formed <before> element");
     264				}
     265			} else if (AFTER_ELEMENT.equals(qName) && activeConcreteAspectDefinition != null) {
     266				String pointcut = attributes.getValue(POINTCUT_ELEMENT);
     267				String adviceClass = attributes.getValue("invokeClass");
     268				String adviceMethod = attributes.getValue("invokeMethod");
     269				if (!isNull(pointcut) && !isNull(adviceClass) && !isNull(adviceMethod)) {
     270					activeConcreteAspectDefinition.pointcutsAndAdvice.add(new Definition.PointcutAndAdvice(AdviceKind.After,
     271							replaceXmlAnd(pointcut), adviceClass, adviceMethod));
     272				} else {
     273					throw new SAXException("Badly formed <after> element");
     274				}
     275			} else if (AROUND_ELEMENT.equals(qName) && activeConcreteAspectDefinition != null) {
     276				String pointcut = attributes.getValue(POINTCUT_ELEMENT);
     277				String adviceClass = attributes.getValue("invokeClass");
     278				String adviceMethod = attributes.getValue("invokeMethod");
     279				if (!isNull(pointcut) && !isNull(adviceClass) && !isNull(adviceMethod)) {
     280					activeConcreteAspectDefinition.pointcutsAndAdvice.add(new Definition.PointcutAndAdvice(AdviceKind.Around,
     281							replaceXmlAnd(pointcut), adviceClass, adviceMethod));
     282				} else {
     283					throw new SAXException("Badly formed <before> element");
     284				}
     285			} else if (ASPECTJ_ELEMENT.equals(qName)) {
     286				if (inAspectJ) {
     287					throw new SAXException("Found nested <aspectj> element");
     288				}
     289				inAspectJ = true;
     290			} else if (ASPECTS_ELEMENT.equals(qName)) {
     291				inAspects = true;
     292			} else if (INCLUDE_ELEMENT.equals(qName) && inWeaver) {
     293				String typePattern = getWithinAttribute(attributes);
     294				if (!isNull(typePattern)) {
     295					definition.getIncludePatterns().add(typePattern);
     296				}
     297			} else if (EXCLUDE_ELEMENT.equals(qName) && inWeaver) {
     298				String typePattern = getWithinAttribute(attributes);
     299				if (!isNull(typePattern)) {
     300					definition.getExcludePatterns().add(typePattern);
     301				}
     302			} else if (DUMP_ELEMENT.equals(qName) && inWeaver) {
     303				String typePattern = getWithinAttribute(attributes);
     304				if (!isNull(typePattern)) {
     305					definition.getDumpPatterns().add(typePattern);
     306				}
     307				String beforeAndAfter = attributes.getValue(DUMP_BEFOREANDAFTER_ATTRIBUTE);
     308				if (isTrue(beforeAndAfter)) {
     309					definition.setDumpBefore(true);
     310				}
     311				String perWeaverDumpDir = attributes.getValue(DUMP_PERCLASSLOADERDIR_ATTRIBUTE);
     312				if (isTrue(perWeaverDumpDir)) {
     313					definition.setCreateDumpDirPerClassloader(true);
     314				}
     315			} else if (EXCLUDE_ELEMENT.equals(qName) && inAspects) {
     316				String typePattern = getWithinAttribute(attributes);
     317				if (!isNull(typePattern)) {
     318					definition.getAspectExcludePatterns().add(typePattern);
     319				}
     320			} else if (INCLUDE_ELEMENT.equals(qName) && inAspects) {
     321				String typePattern = getWithinAttribute(attributes);
     322				if (!isNull(typePattern)) {
     323					definition.getAspectIncludePatterns().add(typePattern);
     324				}
     325			} else {
     326				throw new SAXException("Unknown element while parsing <aspectj> element: " + qName);
     327			}
     328			super.startElement(uri, localName, qName, attributes);
     329		}
     330	
     331		private String getWithinAttribute(Attributes attributes) {
     332			return replaceXmlAnd(attributes.getValue(WITHIN_ATTRIBUTE));
     333		}
     334	
     335		public void endElement(String uri, String localName, String qName) throws SAXException {
     336			if (CONCRETE_ASPECT_ELEMENT.equals(qName)) {
     337				activeConcreteAspectDefinition = null;
     338			} else if (ASPECTJ_ELEMENT.equals(qName)) {
     339				inAspectJ = false;
     340			} else if (WEAVER_ELEMENT.equals(qName)) {
     341				inWeaver = false;
     342			} else if (ASPECTS_ELEMENT.equals(qName)) {
     343				inAspects = false;
     344			}
     345			super.endElement(uri, localName, qName);
     346		}
