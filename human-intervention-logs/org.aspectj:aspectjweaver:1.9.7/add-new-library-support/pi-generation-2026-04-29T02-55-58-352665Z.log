{\n   271\t\t\t\t} else if (perclauseString.startsWith(\"pertypewithin\")) {\n   272\t\t\t\t} else if (perclauseString.startsWith(\"perthis\")) {\n   273\t\t\t\t} else if (perclauseString.startsWith(\"pertarget\")) {\n   274\t\t\t\t} else if (perclauseString.startsWith(\"percflowbelow\")) {\n   275\t\t\t\t} else {\n   276\t\t\t\t\treportError(\"Unrecognized per clause specified \" + stringify());\n   277\t\t\t\t\treturn false;\n   278\t\t\t\t}\n   279\t\t\t}\n   280\t\t\tisValid = true;\n   281\t\t\treturn isValid;\n   282\t\t}\n   283\t\n   284\t\tprivate Collection<ResolvedMember> getOutstandingAbstractMethods(ResolvedType type) {\n   285\t\t\tMap<String, ResolvedMember> collector = new HashMap<>();\n   286\t\t\t// let's get to the top of the hierarchy and then walk down ...\n   287\t\t\t// recording abstract methods then removing\n   288\t\t\t// them if they get defined further down the hierarchy\n   289\t\t\tgetOutstandingAbstractMethodsHelper(type, collector);\n   290\t\t\treturn collector.values();\n   291\t\t}\n   292\t\n   293\t\t// We are trying to determine abstract methods left over at the bottom of a\n   294\t\t// hierarchy that have not been concretized.\n   295\t\tprivate void getOutstandingAbstractMethodsHelper(ResolvedType type, Map<String, ResolvedMember> collector) {\n   296\t\t\tif (type == null) {\n   297\t\t\t\treturn;\n   298\t\t\t}\n   299\t\t\t// Get to the top\n   300\t\t\tif (!type.equals(ResolvedType.OBJECT)) {\n   301\t\t\t\tif (type.getSuperclass() != null) {\n   302\t\t\t\t\tgetOutstandingAbstractMethodsHelper(type.getSuperclass(), collector);\n   303\t\t\t\t}\n   304\t\t\t}\n   305\t\t\tResolvedMember[] rms = type.getDeclaredMethods();\n   306\t\t\tif (rms != null) {\n   307\t\t\t\tfor (ResolvedMember member : rms) {\n   308\t\t\t\t\tString key = member.getName() + member.getSignature();\n   309\t\t\t\t\tif (member.isAbstract()) {\n   310\t\t\t\t\t\tcollector.put(key, member);\n   311\t\t\t\t\t} else {\n   312\t\t\t\t\t\tcollector.remove(key);\n   313\t\t\t\t\t}\n   314\t\t\t\t}\n   315\t\t\t}\n   316\t\t}\n   317\t\n   318\t\t/**\n   319\t\t * Rebuild the XML snip that defines this concrete aspect, for log error purpose\n   320\t\t *\n   321\t\t * @return string repr.\n   322\t\t */\n   323\t\tprivate String stringify() {\n   324\t\t\tStringBuffer sb = new StringBuffer(\"<concrete-aspect name='\");\n   325\t\t\tsb.append(concreteAspect.name);\n   326\t\t\tsb.append(\"' extends='\");\n   327\t\t\tsb.append(concreteAspect.extend);\n   328\t\t\tsb.append(\"' perclause='\");\n   329\t\t\tsb.append(concreteAspect.perclause);\n   330\t\t\tsb.append(\"'/> in aop.xml\");\n   331\t\t\t// TODO needs the extra state from the definition (concretized pointcuts and advice definitions)\n   332\t\t\treturn sb.toString();\n   333\t\t}\n   334\t\n   335\t\tprivate boolean hasPointcutAnnotation(ResolvedMember member) {\n   336\t\t\tAnnotationAJ[] as = member.getAnnotations();\n   337\t\t\tif (as == null || as.length == 0) {\n   338\t\t\t\treturn false;\n   339\t\t\t}\n   340\t\t\tfor (AnnotationAJ a : as) {\n   341\t\t\t\tif (a.getTypeSignature().equals(\"Lorg/aspectj/lang/annotation/Pointcut;\")) {\n   342\t\t\t\t\treturn true;\n   343\t\t\t\t}\n   344\t\t\t}\n   345\t\t\treturn false;\n   346\t\t}\n   347\t\n   348\t\tpublic String getClassName() {\n   349\t\t\treturn concreteAspect.name;\n   350\t\t}\n   351\t\n   352\t\t/**\n   353\t\t * @return the bytecode for the concrete aspect\n   354\t\t */\n   355\t\tpublic byte[] getBytes() {\n   356\t\t\tif (!isValid) {\n   357\t\t\t\tthrow new RuntimeException(\"Must validate first\");\n   358\t\t\t}\n   359\t\t\tif (bytes != null) {\n   360\t\t\t\treturn bytes;\n   361\t\t\t}\n   362\t\t\tPerClause.Kind perclauseKind = PerClause.SINGLETON;\n   363\t\t\tPerClause parentPerClause = (parent != null ? parent.getPerClause() : null);\n   364\t\t\tif (parentPerClause != null) {\n   365\t\t\t\tperclauseKind = parentPerClause.getKind();\n   366\t\t\t}\n   367\t\t\tString perclauseString = null;\n   368\t\n   369\t\t\tif (concreteAspect.perclause != null) {\n   370\t\t\t\tperclauseString = concreteAspect.perclause;\n   371\t\t\t\tif (perclauseString.startsWith(\"persingleton\")) {\n   372\t\t\t\t\tperclauseKind = PerClause.SINGLETON;\n   373\t\t\t\t} else if (perclauseString.startsWith(\"percflow\")) {\n   374\t\t\t\t\tperclauseKind = PerClause.PERCFLOW;\n   375\t\t\t\t} else if (perclauseString.startsWith(\"pertypewithin\")) {\n   376\t\t\t\t\tperclauseKind = PerClause.PERTYPEWITHIN;\n   377\t\t\t\t} else if (perclauseString.startsWith(\"perthis\")) {\n   378\t\t\t\t\tperclauseKind = PerClause.PEROBJECT;\n   379\t\t\t\t} else if (perclauseString.startsWith(\"pertarget\")) {\n   380\t\t\t\t\tperclauseKind = PerClause.PEROBJECT;\n   381\t\t\t\t} else if (perclauseString.startsWith(\"percflowbelow\")) {\n   382\t\t\t\t\tperclauseKind = PerClause.PERCFLOW;\n   383\t\t\t\t}\n   384\t\t\t}\n   385\t\n   386\t\t\t// @Aspect //inherit clause from m_parent\n   387\t\t\t// @DeclarePrecedence(\"....\") // if any\n   388\t\t\t// public class xxxName [extends xxxExtends] {\n   389\t\t\t// [@Pointcut(xxxExpression-n)\n   390\t\t\t// public void xxxName-n() {}]\n   391\t\t\t// }\n   392\t\t\tString parentName = \"java/lang/Object\";\n   393\t\t\tif (parent != null) {\n   394\t\t\t\tif (parent.isParameterizedType()) {\n   395\t\t\t\t\tparentName = parent.getGenericType().getName().replace('.', '/');\n   396\t\t\t\t} else {\n   397\t\t\t\t\tparentName = parent.getName().replace('.', '/');\n   398\t\t\t\t}\n   399\t\t\t}\n   400\t\t\t// @Aspect public class ...\n   401\t\t\t// TODO AV - we could point to the aop.xml that defines it and use JSR-45\n   402\t\t\tLazyClassGen cg = new LazyClassGen(concreteAspect.name.replace('.', '/'), parentName, null, Modifier.PUBLIC\n   403\t\t\t\t\t+ Constants.ACC_SUPER, EMPTY_STRINGS, world);\n   404\t\t\tif (parent != null && parent.isParameterizedType()) {\n   405\t\t\t\tcg.setSuperClass(parent);\n   406\t\t\t}\n   407\t\t\tif (perclauseString == null) {\n   408\t\t\t\tAnnotationGen ag = new AnnotationGen(new ObjectType(\"org/aspectj/lang/annotation/Aspect\"),\n   409\t\t\t\t\t\tCollections.<NameValuePair> emptyList(), true, cg.getConstantPool());\n   410\t\t\t\tcg.addAnnotation(ag);\n   411\t\t\t} else {\n   412\t\t\t\t// List elems = new ArrayList();\n   413\t\t\t\tList<NameValuePair> elems = new ArrayList<>();\n   414\t\t\t\telems.add(new NameValuePair(\"value\",\n   415\t\t\t\t\t\tnew SimpleElementValue(ElementValue.STRING, cg.getConstantPool(), perclauseString), cg.getConstantPool()));\n   416\t\t\t\tAnnotationGen ag = new AnnotationGen(new ObjectType(\"org/aspectj/lang/annotation/Aspect\"), elems, true,\n   417\t\t\t\t\t\tcg.getConstantPool());\n   418\t\t\t\tcg.addAnnotation(ag);\n   419\t\t\t}\n   420\t\t\tif (concreteAspect.precedence != null) {\n   421\t\t\t\tSimpleElementValue svg = new SimpleElementValue(ElementValue.STRING, cg.getConstantPool(), concreteAspect.precedence);\n   422\t\t\t\tList<NameValuePair> elems = new ArrayList<>();\n   423\t\t\t\telems.add(new NameValuePair(\"value\", svg, cg.getConstantPool()));\n   424\t\t\t\tAnnotationGen agprec = new AnnotationGen(new ObjectType(\"org/aspectj/lang/annotation/DeclarePrecedence\"), elems, true,\n   425\t\t\t\t\t\tcg.getConstantPool());\n   426\t\t\t\tcg.addAnnotation(agprec);\n   427\t\t\t}\n   428\t\n   429\t\t\t// default constructor\n   430\t\t\tLazyMethodGen init = new LazyMethodGen(Modifier.PUBLIC, Type.VOID, \"<init>\", EMPTY_TYPES, EMPTY_STRINGS, cg);\n   431\t\t\tInstructionList cbody = init.getBody();\n   432\t\t\tcbody.append(InstructionConstants.ALOAD_0);\n   433\t\n   434\t\t\tcbody.append(cg.getFactory().createInvoke(parentName, \"<init>\", Type.VOID, EMPTY_TYPES, Constants.INVOKESPECIAL));\n   435\t\t\tcbody.append(InstructionConstants.RETURN);\n   436\t\t\tcg.addMethodGen(init);\n   437\t\n   438\t\t\tfor (Definition.Pointcut abstractPc : concreteAspect.pointcuts) {\n   439\t\t\t\t// TODO AV - respect visibility instead of opening up as public?\n   440\t\t\t\tLazyMethodGen mg = new LazyMethodGen(Modifier.PUBLIC, Type.VOID, abstractPc.name, EMPTY_TYPES, EMPTY_STRINGS, cg);\n   441\t\t\t\tSimpleElementValue svg = new SimpleElementValue(ElementValue.STRING, cg.getConstantPool(), abstractPc.expression);\n   442\t\t\t\tList<NameValuePair> elems = new ArrayList<>();\n   443\t\t\t\telems.add(new NameValuePair(\"value\", svg, cg.getConstantPool()));\n   444\t\t\t\tAnnotationGen mag = new AnnotationGen(new ObjectType(\"org/aspectj/lang/annotation/Pointcut\"), elems, true,\n   445\t\t\t\t\t\tcg.getConstantPool());\n   446\t\t\t\tAnnotationAJ max = new BcelAnnotation(mag, world);\n   447\t\t\t\tmg.addAnnotation(max);\n   448\t\n   449\t\t\t\tInstructionList body = mg.getBody();\n   450\t\t\t\tbody.append(InstructionConstants.RETURN);\n   451\t\t\t\tcg.addMethodGen(mg);\n   452\t\t\t}\n   453\t\n   454\t\t\t// Construct any defined declare error/warnings\n   455\t\t\tif (concreteAspect.deows.size() > 0) {\n   456\t\t\t\tint counter = 1;\n   457\t\t\t\tfor (Definition.DeclareErrorOrWarning deow : concreteAspect.deows) {\n   458\t\t\t\t\t// Building this:\n   459\t\t\t\t\t// @DeclareWarning(\"call(* javax.sql..*(..)) && !within(org.xyz.daos..*)\")\n   460\t\t\t\t\t// static final String aMessage = \"Only DAOs should be calling JDBC.\";\n   461\t\n   462\t\t\t\t\tFieldGen field = new FieldGen(Modifier.FINAL, ObjectType.STRING, \"rule\" + (counter++), cg.getConstantPool());\n   463\t\t\t\t\tSimpleElementValue svg = new SimpleElementValue(ElementValue.STRING, cg.getConstantPool(), deow.pointcut);\n   464\t\t\t\t\tList<NameValuePair> elems = new ArrayList<>();\n   465\t\t\t\t\telems.add(new NameValuePair(\"value\", svg, cg.getConstantPool()));\n   466\t\t\t\t\tAnnotationGen mag = new AnnotationGen(new ObjectType(\"org/aspectj/lang/annotation/Declare\"\n   467\t\t\t\t\t\t\t+ (deow.isError ? \"Error\" : \"Warning\")), elems, true, cg.getConstantPool());\n   468\t\t\t\t\tfield.addAnnotation(mag);\n   469\t\n   470\t\t\t\t\tfield.setValue(deow.message);\n   471\t\t\t\t\tcg.addField(field, null);\n   472\t\t\t\t}\n   473\t\t\t}\n   474\t\n   475\t\t\tif (concreteAspect.pointcutsAndAdvice.size() > 0) {\n   476\t\t\t\tint adviceCounter = 1;\n   477\t\t\t\tfor (PointcutAndAdvice paa : concreteAspect.pointcutsAndAdvice) {\n   478\t\t\t\t\tgenerateAdviceMethod(paa, adviceCounter, cg);\n   479\t\t\t\t\tadviceCounter++;\n   480\t\t\t\t}\n   481\t\t\t}\n   482\t\n   483\t\t\tif (concreteAspect.declareAnnotations.size()>0) {\n   484\t\t\t\tint decCounter = 1;\n   485\t\t\t\tfor (Definition.DeclareAnnotation da: concreteAspect.declareAnnotations) {\n   486\t\t\t\t\tgenerateDeclareAnnotation(da,decCounter++,cg);\n   487\t\t\t\t}\n   488\t\t\t}\n   489\t\n   490\t\t\t// handle the perClause\n   491\t\t\tReferenceType rt = new ReferenceType(ResolvedType.forName(concreteAspect.name).getSignature(), world);\n   492\t\t\tGeneratedReferenceTypeDelegate grtd = new GeneratedReferenceTypeDelegate(rt);\n   493\t\t\tgrtd.setSuperclass(parent);\n   494\t\t\trt.setDelegate(grtd);\n   495\t\n   496\t\t\tBcelPerClauseAspectAdder perClauseMunger = new BcelPerClauseAspectAdder(rt, perclauseKind);\n   497\t\t\tperClauseMunger.forceMunge(cg, false);\n   498\t\n   499\t\t\t// TODO AV - unsafe cast\n   500\t\t\t// register the fresh new class into the world repository as it does not\n   501\t\t\t// exist on the classpath anywhere\n   502\t\t\tJavaClass jc = cg.getJavaClass((BcelWorld) world);\n   503\t\t\t((BcelWorld) world).addSourceObjectType(jc, true);\n   504\t\n   505\t\t\tbytes = jc.getBytes();\n   506\t\t\treturn bytes;\n   507\t\t}\n   508\t\n   509\t\t/**\n   510\t\t * The DeclareAnnotation object encapsulates an method/field/type descriptor and an annotation. This uses a DeclareAnnotation object\n   511\t\t * captured from the XML (something like '<declare-annotation field=\"* field1(..)\" annotation=\"@Annot(a='a',fred=false,'abc')\"/>')\n   512\t\t * and builds the same construct that would have existed if the code style variant was used.  This involves creating a member upon\n   513\t\t * which to hang the real annotation and then creating a classfile level attribute indicating a declare annotation is present\n   514\t\t * (that includes the signature pattern and a pointer to the real member holding the annotation).\n   515\t\t *\n   516\t\t */\n   517\t\tprivate void generateDeclareAnnotation(Definition.DeclareAnnotation da, int decCounter, LazyClassGen cg) {\n   518\t\n   519\t\t\t// Here is an example member from a code style declare annotation:\n   520\t\t\t//void ajc$declare_at_method_1();\n   521\t\t\t//  RuntimeInvisibleAnnotations: length = 0x6\n   522\t\t\t//   00 01 00 1B 00 00\n   523\t\t\t//  RuntimeVisibleAnnotations: length = 0x15\n   524\t\t\t//   00 01 00 1D 00 03 00 1E 73 00 1F 00 20 73 00 21\n   525\t\t\t//   00 22 73 00 23\n   526\t\t\t//  org.aspectj.weaver.MethodDeclarationLineNumber: length = 0x8\n   527\t\t\t//   00 00 00 02 00 00 00 16\n   528\t\t\t//  org.aspectj.weaver.AjSynthetic: length = 0x\n   529\t\t\t//\n   530\t\t\t//  Code:\n   531\t\t\t//   Stack=0, Locals=1, Args_size=1\n   532\t\t\t//   0:\treturn\n   533\t\n   534\t\t\t// and at the class level a Declare attribute:\n   535\t\t\t//\t\t  org.aspectj.weaver.Declare: length = 0x51\n   536\t\t\t//\t\t   05 00 00 00 03 01 00 05 40 41 6E 6E 6F 01 00 17\n   537\t\t\t//\t\t   61 6A 63 24 64 65 63 6C 61 72 65 5F 61 74 5F 6D\n   538\t\t\t//\t\t   65 74 68 6F 64 5F 31 01 01 00 00 00 00 05 05 00\n   539\t\t\t//\t\t   08 73 61 79 48 65 6C 6C 6F 00 01 04 00 00 00 00\n   540\t\t\t//\t\t   07 00 00 00 27 00 00 00 34 00 00 00 16 00 00 00\n   541\t\t\t//\t\t   3C\n   542\t\n   543\t\t\tAnnotationAJ constructedAnnotation = buildDeclareAnnotation_actualAnnotation(cg, da);\n   544\t\t\tif (constructedAnnotation==null) {\n   545\t\t\t\treturn; // error occurred (and was reported), do not continue\n   546\t\t\t}\n   547\t\n   548\t\t\tString nameComponent 