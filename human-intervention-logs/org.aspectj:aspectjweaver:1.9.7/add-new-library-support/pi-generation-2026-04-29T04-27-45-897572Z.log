      43		protected String createToString(StringMaker sm) {
      44			StringBuffer buf = new StringBuffer();
      45			buf.append(sm.makeModifiersString(getModifiers()));
      46			if (sm.includeArgs)
      47				buf.append(sm.makeTypeName(getReturnType()));
