      68				} catch (NoSuchMethodException nsmEx) {
      69					// pr154427 - search
      70					Set searched = new HashSet();
      71					searched.add(dtype); // avoids another getDeclaredMethod() on dtype
      72					method = search(dtype, getName(), getParameterTypes(), searched);
      73				}
