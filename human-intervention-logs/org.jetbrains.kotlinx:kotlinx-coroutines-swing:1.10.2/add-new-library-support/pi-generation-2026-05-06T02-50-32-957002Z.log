          val proxyMaker: ProxyMaker = ProxyMaker(
              logger,
              null,
              NoopSubclassInstrumentation,
              UnusedInstantiator,
              handlers,
          )
  
          val result: Cancelable<ProxyMakerCompanionOpenTarget> = proxyMaker.proxy(
              ProxyMakerCompanionOpenTarget::class.java,
              emptyArray(),
              NoopInvocationHandler,
