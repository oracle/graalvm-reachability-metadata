          assertThat(logger.debugMessages).anySatisfy { message: String ->
              assertThat(message)
                  .contains("ProxyMakerCompanionOpenTarget.finalMessage")
                  .contains("because it is final")
          }
  
          result.cancel()
  
          assertThat(handlers).doesNotContainKey(target)
      }
  
