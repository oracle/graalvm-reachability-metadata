fs.optional.junit.AggregateTransformer;\\nimport org.apache.tools.ant.taskdefs.optional.junit.XMLResultAggregator;\\nimport org.apache.tools.ant.types.FileSet;\\nimport org.apache.tools.ant.types.Resource;\\nimport org.apache.tools.ant.types.resources.URLResource;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\nimport static org.assertj.core.api.Assertions.assertThatThrownBy;\\n\\npublic class AggregateTransformerTest {\\n    @TempDir\\n    Path temporaryDirectory;\\n\\n    @org.junit.jupiter.api.Test\\n    void transformsAggregatedResultsWithBundledNoFramesStylesheet() throws IOException {\\n        Project project = newProject();\\n        Path inputDirectory = Files.createDirectory(temporaryDirectory.resolve(\\\"input\\\"));\\n        Path aggregateDirectory = Files.createDirectory(temporaryDirectory.resolve(\\\"aggregate\\\"));\\n        Path reportDirectory = Files.createDirectory(temporaryDirectory.resolve(\\\"report\\\"));\\n        Files.writeString(inputDirectory.resolve(\\\"TEST-sample.xml\\\"), \\\"\\\"\\\"\\n                <?xml version=\\\"1.0\\\" encoding=\\\"UTF-8\\\"?>\\n                <testsuite name=\\\"sample.SampleTest\\\" tests=\\\"1\\\" failures=\\\"0\\\" errors=\\\"0\\\" skipped=\\\"0\\\"\\n                    timestamp=\\\"2026-01-01T00:00:00\\\" hostname=\\\"localhost\\\" time=\\\"0.001\\\">\\n                  <properties/>\\n                  <testcase classname=\\\"sample.SampleTest\\\" name=\\\"passes\\\" time=\\\"0.001\\\"/>\\n                  <system-out/>\\n                  <system-err/>\\n                </testsuite>\\n                \\\"\\\"\\\", StandardCharsets.UTF_8);\\n\\n        XMLResultAggregator aggregator = new XMLResultAggregator();\\n        aggregator.setProject(project);\\n        aggregator.init();\\n        aggregator.setTodir(aggregateDirectory.toFile());\\n        FileSet files = new FileSet();\\n        files.setDir(inputDirectory.toFile());\\n        files.setIncludes(\\\"*.xml\\\");\\n        aggregator.addFileSet(files);\\n\\n        AggregateTransformer report = aggregator.createReport();\\n        AggregateTransformer.Format format = new AggregateTransformer.Format();\\n        format.setValue(AggregateTransformer.NOFRAMES);\\n        report.setFormat(format);\\n        report.setTodir(reportDirectory.toFile());\\n\\n        aggregator.execute();\\n\\n        Path reportFile = reportDirectory.resolve(\\\"junit-noframes.html\\\");\\n        assertThat(reportFile).exists();\\n        assertThat(Files.readString(reportFile)).contains(\\\"sample.SampleTest\\\");\\n    }\\n\\n    @org.junit.jupiter.api.Test\\n    void resolvesBundledStylesheetAsClasspathResource() {\\n        InspectableAggregateTransformer transformer = new InspectableAggregateTransformer(newTask());\\n        AggregateTransformer.Format format = new AggregateTransformer.Format();\\n        format.setValue(AggregateTransformer.NOFRAMES);\\n        transformer.setFormat(format);\\n\\n        Resource stylesheet = transformer.stylesheet();\\n\\n        assertThat(stylesheet).isInstanceOf(URLResource.class);\\n        assertThat(stylesheet.isExists()).isTrue();\\n    }\\n\\n    @org.junit.jupiter.api.Test\\n    void reportsMissingRelativeStylesheetSystemIdForSubclassResourceLookup() {\\n        InspectableAggregateTransformer transformer = new InspectableAggregateTransformer(newTask());\\n        AggregateTransformer.Format format = new AggregateTransformer.Format();\\n        format.setValue(AggregateTransformer.NOFRAMES);\\n        transformer.setFormat(format);\\n\\n        assertThatThrownBy(transformer::stylesheetSystemId)\\n                .isInstanceOf(FileNotFoundException.class)\\n                .hasMessageContaining(\\\"junit-noframes.xsl\\\");\\n    }\\n\\n    private static Project newProject() {\\n        Project project = new Project();\\n        project.init();\\n        return project;\\n    }\\n\\n    private static Task newTask() {\\n        Task task = new Task();\\n        task.setProject(newProject());\\n        task.init();\\n        return task;\\n    }\\n\\n    private static final class InspectableAggregateTransformer extends AggregateTransformer {\\n        InspectableAggregateTransformer(Task task) {\\n            super(task);\\n        }\\n\\n        Resource stylesheet() {\\n            return getStylesheet();\\n        }\\n\\n        String stylesheetSystemId() throws IOException {\\n            return getStylesheetSystemId();\\n        }\\n    }\\n}\\n\"}\n../2471-ebd1b0ae/human-intervention-logs/org.apache.ant:ant-junit:1.10.15/add-new-library-support/pi-generation-2026-06-08T03-53-24-554518Z.log:1583:[tool-call] end id=call_h53x1r1Tp2uV9nFbexhrR0q5|fc_08e5b7320191e34b016a263c8ec3548194ab8d171824a599f5 name=write args={\"path\": \"tests/src/org.apache.ant/ant-junit/1.10.15/src/test/java/org_apache_ant/ant_junit/AggregateTransformerTest.java\", \"content\": \"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage org_apache_ant.ant_junit;\\n\\nimport java.io.File;\\nimport java.io.FileNotFoundException;\\nimport java.io.IOException;\\nimport java.nio.charset.StandardCharsets;\\nimport java.nio.file.Files;\\nimport java.nio.file.Path;\\n\\nimport org.junit.jupiter.api.io.TempDir;\\n\\nimport org.apache.tools.ant.Project;\\nimport org.apache.tools.ant.Task;\\nimport org.apache.tools.ant.taskdefs.optional.junit.AggregateTransformer;\\nimport org.apache.tools.ant.taskdefs.optional.junit.XMLResultAggregator;\\nimport org.apache.tools.ant.types.FileSet;\\nimport org.apache.tools.ant.types.Resource;\\nimport org.apache.tools.ant.types.resources.URLResource;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\nimport static org.assertj.core.api.Assertions.assertThatThrownBy;\\n\\npublic class AggregateTransformerTest {\\n    @TempDir\\n    Path tempo