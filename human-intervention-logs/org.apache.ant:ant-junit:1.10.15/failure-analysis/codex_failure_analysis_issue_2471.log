ttp://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage org_apache_ant.ant_junit;\\n\\nimport java.io.ByteArrayOutputStream;\\nimport java.io.IOException;\\nimport java.io.InputStream;\\n\\nimport junit.framework.TestSuite;\\n\\nimport org.apache.tools.ant.taskdefs.optional.junit.JUnitTask;\\nimport org.apache.tools.ant.taskdefs.optional.junit.JUnitTaskMirrorImpl;\\nimport org.apache.tools.ant.taskdefs.optional.junit.JUnitTest;\\nimport org.apache.tools.ant.taskdefs.optional.junit.TearDownOnVmCrash;\\n\\nimport org.graalvm.internal.tck.NativeImageSupport;\\nimport org.junit.jupiter.api.Test;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\n\\npublic class TearDownOnVmCrashTest {\\n    @Test\\n    void invokesTearDownForVmExitError() throws Exception {\\n        TearDownTarget.reset();\\n\\n        reportVmExit(TearDownTarget.class.getName(), new TearDownOnVmCrash());\\n\\n        assertThat(TearDownTarget.tearDownCalls).isEqualTo(1);\\n    }\\n\\n    @Test\\n    void fallsBackToFormatterClassLoaderWhenContextClassLoaderCannotLoadSuite() throws Exception {\\n        TearDownTarget.reset();\\n        Thread thread = Thread.currentThread();\\n        ClassLoader previousClassLoader = thread.getContextClassLoader();\\n        ClassLoader hidingClassLoader = new HidingClassLoader(\\n                previousClassLoader,\\n                TearDownTarget.class.getName());\\n\\n        try {\\n            thread.setContextClassLoader(hidingClassLoader);\\n\\n            reportVmExit(TearDownTarget.class.getName(), new TearDownOnVmCrash());\\n        } finally {\\n            thread.setContextClassLoader(previousClassLoader);\\n        }\\n\\n        assertThat(TearDownTarget.tearDownCalls).isEqualTo(1);\\n    }\\n\\n    @Test\\n    void fallsBackToClassForNameWhenRuntimeFormatterClassLoaderCannotLoadSuite() throws Exception {\\n        TearDownTarget.reset();\\n        Thread thread = Thread.currentThread();\\n        ClassLoader previousClassLoader = thread.getContextClassLoader();\\n        String formatterClassName = ShadowedFormatter.class.getName();\\n        ClassLoader shadowingClassLoader = new ShadowingFormatterClassLoader(\\n                previousClassLoader,\\n                formatterClassName,\\n                TearDownTarget.class.getName());\\n\\n        try {\\n            Class<?> formatterClass = shadowingClassLoader.loadClass(formatterClassName);\\n            TearDownOnVmCrash formatter = formatterClass\\n                    .asSubclass(TearDownOnVmCrash.class)\\n                    .getConstructor()\\n                    .newInstance();\\n            thread.setContextClassLoader(shadowingClassLoader);\\n\\n            reportVmExit(TearDownTarget.class.getName(), formatter);\\n\\n            assertThat(TearDownTarget.tearDownCalls).isEqualTo(1);\\n        } catch (Error error) {\\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\\n                throw error;\\n            }\\n        } finally {\\n            thread.setContextClassLoader(previousClassLoader);\\n        }\\n    }\\n\\n    @Test\\n    void ignoresVmExitForSuiteMethodTarget() throws Exception {\\n        SuiteMethodTarget.reset();\\n\\n        reportVmExit(SuiteMethodTarget.class.getName(), new TearDownOnVmCrash());\\n\\n        assertThat(SuiteMethodTarget.tearDownCalls).isZero();\\n    }\\n\\n    @Test\\n    void ignoresVmExitWhenSuiteClassCannotBeLoaded() throws Exception {\\n        TearDownTarget.reset();\\n\\n        reportVmExit(\\\"org_apache_ant.ant_junit.DoesNotExist\\\", new TearDownOnVmCrash());\\n\\n        assertThat(TearDownTarget.tearDownCalls).isZero();\\n    }\\n\\n    private static void reportVmExit(\\n            String suiteName,\\n            TearDownOnVmCrash formatter) throws Exception {\\n        JUnitTaskMirrorImpl mirror = new JUnitTaskMirrorImpl(new JUnitTask());\\n        JUnitTest suite = new JUnitTest(suiteName);\\n\\n        mirror.addVmExit(suite, formatter, new ByteArrayOutputStream(), \\\"vm exited\\\", \\\"testMethod\\\");\\n    }\\n\\n    public static class TearDownTarget {\\n        private static int tearDownCalls;\\n\\n        public static void reset() {\\n            tearDownCalls = 0;\\n        }\\n\\n        public void tearDown() {\\n            tearDownCalls++;\\n        }\\n    }\\n\\n    public static class SuiteMethodTarget {\\n        private static int tearDownCalls;\\n\\n        public static void reset() {\\n            tearDownCalls = 0;\\n        }\\n\\n        public static junit.framework.Test suite() {\\n            return new TestSuite(\\\"suite-method-target\\\");\\n        }\\n\\n        public void tearDown() {\\n            tearDownCalls++;\\n        }\\n    }\\n\\n    public static class ShadowedFormatter extends TearDownOnVmCrash {\\n    }\\n\\n    private static final class HidingClassLoader extends ClassLoader {\\n        private final String hiddenClassName;\\n\\n        private HidingClassLoader(ClassLoader parent, String hiddenClassName) {\\n            super(parent);\\n            this.hiddenClassName = hiddenClassName;\\n        }\\n\\n        @Override\\n        public Class<?> loadClass(String name) throws ClassNotFoundException {\\n            if (hiddenClassName.equals(name)) {\\n                throw new ClassNotFoundException(name);\\n            }\\n            return super.loadClass(name);\\n        }\\n    }\\n\\n    private static final class ShadowingFormatterClassLoader extends ClassLoader {\\n        private final String formatterClassName;\\n        private final String hiddenClassName;\\n\\n        private ShadowingFormatterClassLoader(\\n                ClassLoader parent,\\n                String formatterClassName,\\n                String hiddenClassName) {\\n            super(parent);\\n            this.formatterClassName = formatterClassName;\\n            this.hiddenClassName = hiddenClassName;\\n        }\\n\\n        @Override\\n        public Class<?> loadClass(St