  package org_apache_ant.ant_junit;
  
  import junit.framework.JUnit4TestAdapterCache;
  import junit.framework.TestResult;
  
  import org.apache.tools.ant.taskdefs.optional.junit.JUnitVersionHelper;
  import org.junit.runner.Description;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class JUnitVersionHelperTest {
      @Test
      void readsNameFromCustomTestGetNameMethod() {
          junit.framework.Test test = new GetNameOnlyTest();
  
          String testCaseName = JUnitVersionHelper.getTestCaseName(test);
  
          assertThat(testCaseName).isEqualTo("custom-get-name");
      }
  
      @Test
      void readsNameFromCustomTestNameMethod() {
          junit.framework.Test test = new NameOnlyTest();
  
          String testCaseName = JUnitVersionHelper.getTestCaseName(test);
  
          assertThat(testCaseName).isEqualTo("custom-name");
      }
  
      @Test
      void readsIgnoreMessageFromJUnit4Facade() {
          junit.framework.Test test = singleJUnit4Facade(IgnoredJUnit4Test.class);
  
          String ignoreMessage = JUnitVersionHelper.getIgnoreMessage(test);
  
          assertThat(ignoreMessage).isEqualTo("ignored by JUnit4 annotation");
      }
  
      private static junit.framework.Test singleJUnit4Facade(Class<?> testClass) {
          Description description = Description.createTestDescription(testClass, "ignoredTest");
  
          return JUnit4TestAdapterCache.getDefault().asTest(description);
      }
  
      public static final class GetNameOnlyTest implements junit.framework.Test {
          @Override
          public int countTestCases() {
              return 1;
          }
  
          @Override
          public void run(TestResult result) {
          }
  
          public String getName() {
              return "custom-get-name";
          }
      }
  
      public static final class NameOnlyTest implements junit.framework.Test {
          @Override
          public int countTestCases() {
              return 1;
          }
  
          @Override
          public void run(TestResult result) {
          }
  
          public String name() {
              return "custom-name";
          }
      }
  
      public static final class IgnoredJUnit4Test {
          @org.junit.Test
          @org.junit.Ignore("ignored by JUnit4 annotation")
          public void ignoredTest() {
          }
      }
  }
