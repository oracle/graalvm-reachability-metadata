  package org_apache_ant.ant_junit;
  
  import java.io.OutputStream;
  
  import junit.framework.AssertionFailedError;
  
  import org.apache.tools.ant.Project;
  import org.apache.tools.ant.taskdefs.optional.junit.FormatterElement;
  import org.apache.tools.ant.taskdefs.optional.junit.JUnitResultFormatter;
  import org.apache.tools.ant.taskdefs.optional.junit.JUnitTask;
  import org.apache.tools.ant.taskdefs.optional.junit.JUnitTest;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class FormatterElementTest {
      @org.junit.jupiter.api.Test
      void createsFormatterWithApplicationClassLoader() throws Exception {
          Project project = newProject();
  
          executeJUnitTask(project, false);
  
          assertThat(ProjectAwareFormatter.projectAssigned).isSameAs(project);
          assertThat(ProjectAwareFormatter.setProjectCalls).isEqualTo(1);
      }
  
      @org.junit.jupiter.api.Test
      void createsFormatterWithAntClassLoader() throws Exception {
          Project project = newProject();
  
          executeJUnitTask(project, true);
  
          assertThat(ProjectAwareFormatter.projectAssigned).isSameAs(project);
          assertThat(ProjectAwareFormatter.setProjectCalls).isEqualTo(1);
      }
  
      @org.junit.Test
      public void antJUnitCanRunThisClass() {
      }
  
      private static Project newProject() {
          Project project = new Project();
          project.init();
          return project;
      }
  
      private static void executeJUnitTask(Project project, boolean useAntClassLoader) throws Exception {
          ProjectAwareFormatter.reset();
  
          JUnitTask task = new JUnitTask();
          task.setProject(project);
          task.init();
          task.setFork(false);
          task.setIncludeantruntime(false);
          task.addTest(new JUnitTest(FormatterElementTest.class.getName()));
          if (useAntClassLoader) {
              task.createClasspath();
          }
  
          FormatterElement formatter = new FormatterElement();
          formatter.setProject(project);
          formatter.setUseFile(false);
          formatter.setClassname(ProjectAwareFormatter.class.getName());
          task.addFormatter(formatter);
  
          task.execute();
      }
  
      public static class ProjectAwareFormatter implements JUnitResultFormatter {
          public Object project;
          private static int setProjectCalls;
          private static Project projectAssigned;
  
          public static void reset() {
              setProjectCalls = 0;
              projectAssigned = null;
          }
  
          public void setProject(Project project) {
              this.project = project;
              projectAssigned = project;
              setProjectCalls++;
          }
  
          @Override
          public void startTestSuite(JUnitTest suite) {
          }
  
          @Override
          public void endTestSuite(JUnitTest suite) {
          }
  
          @Override
          public void setOutput(OutputStream out) {
          }
  
          @Override
          public void setSystemOutput(String out) {
          }
  
          @Override
          public void setSystemError(String err) {
          }
  
          @Override
          public void addError(junit.framework.Test test, Throwable throwable) {
          }
  
          @Override
          public void addFailure(junit.framework.Test test, AssertionFailedError throwable) {
          }
  
          @Override
          public void endTest(junit.framework.Test test) {
          }
  
          @Override
          public void startTest(junit.framework.Test test) {
          }
      }
  }
