rors=\"0\" skipped=\"0\"\n                    timestamp=\"2026-01-01T00:00:00\" hostname=\"localhost\" time=\"0.001\">\n                  <properties/>\n                  <testcase classname=\"sample.SampleTest\" name=\"passes\" time=\"0.001\"/>\n                  <system-out/>\n                  <system-err/>\n                </testsuite>\n                \"\"\", StandardCharsets.UTF_8);\n\n        XMLResultAggregator aggregator = new XMLResultAggregator();\n        aggregator.setProject(project);\n        aggregator.init();\n        aggregator.setTodir(aggregateDirectory.toFile());\n        FileSet files = new FileSet();\n        files.setDir(inputDirectory.toFile());\n        files.setIncludes(\"*.xml\");\n        aggregator.addFileSet(files);\n\n        AggregateTransformer report = aggregator.createReport();\n        AggregateTransformer.Format format = new AggregateTransformer.Format();\n        format.setValue(AggregateTransformer.NOFRAMES);\n        report.setFormat(format);\n        report.setTodir(reportDirectory.toFile());\n\n        aggregator.execute();\n\n        Path reportFile = reportDirectory.resolve(\"junit-noframes.html\");\n        assertThat(reportFile).exists();\n        assertThat(Files.readString(reportFile)).contains(\"sample.SampleTest\");\n    }\n\n    @org.junit.jupiter.api.Test\n    void resolvesBundledStylesheetAsClasspathResource() {\n        InspectableAggregateTransformer transformer = new InspectableAggregateTransformer(newTask());\n        AggregateTransformer.Format format = new AggregateTransformer.Format();\n        format.setValue(AggregateTransformer.NOFRAMES);\n        transformer.setFormat(format);\n\n        Resource stylesheet = transformer.stylesheet();\n\n        assertThat(stylesheet).isInstanceOf(URLResource.class);\n        assertThat(stylesheet.isExists()).isTrue();\n    }\n\n    @org.junit.jupiter.api.Test\n    void reportsMissingRelativeStylesheetSystemIdForSubclassResourceLookup() {\n        InspectableAggregateTransformer transformer = new InspectableAggregateTransformer(newTask());\n        AggregateTransformer.Format format = new AggregateTransformer.Format();\n        format.setValue(AggregateTransformer.NOFRAMES);\n        transformer.setFormat(format);\n\n        assertThatThrownBy(transformer::stylesheetSystemId)\n                .isInstanceOf(FileNotFoundException.class)\n                .hasMessageContaining(\"junit-noframes.xsl\");\n    }\n\n    private static Project newProject() {\n        Project project = new Project();\n        project.init();\n        return project;\n    }\n\n    private static Task newTask() {\n        Task task = new Task();\n        task.setProject(newProject());\n        task.init();\n        return task;\n    }\n\n    private static final class InspectableAggregateTransformer extends AggregateTransformer {\n        InspectableAggregateTransformer(Task task) {\n            super(task);\n        }\n\n        Resource stylesheet() {\n            return getStylesheet();\n        }\n\n        String stylesheetSystemId() throws IOException {\n            return getStylesheetSystemId();\n        }\n    }\n}\n"}
