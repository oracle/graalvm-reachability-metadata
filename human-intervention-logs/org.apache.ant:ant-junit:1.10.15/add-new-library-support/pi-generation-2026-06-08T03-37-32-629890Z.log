unit.framework.TestSuite;\n\nimport org.apache.tools.ant.taskdefs.optional.junit.JUnitTask;\n"}, {"oldText": "import org.apache.tools.ant.taskdefs.optional.junit.JUnitTest;\nimport org.apache.tools.ant.taskdefs.optional.junit.TearDownOnVmCrash;\nimport org.junit.jupiter.api.Test;\n", "newText": "import org.apache.tools.ant.taskdefs.optional.junit.JUnitTest;\nimport org.apache.tools.ant.taskdefs.optional.junit.TearDownOnVmCrash;\n\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\n"}, {"oldText": "    @Test\n    void ignoresVmExitWhenSuiteClassCannotBeLoaded() throws Exception {\n        TearDownTarget.reset();\n\n        reportVmExit(\"org_apache_ant.ant_junit.DoesNotExist\", new TearDownOnVmCrash());\n\n        assertThat(TearDownTarget.tearDownCalls).isZero();\n    }\n\n    private static void reportVmExit(String suiteName, TearDownOnVmCrash formatter) throws Exception {\n", "newText": "    @Test\n    void fallsBackToClassForNameWhenRuntimeFormatterClassLoaderCannotLoadSuite() throws Exception {\n        TearDownTarget.reset();\n        Thread thread = Thread.currentThread();\n        ClassLoader previousClassLoader = thread.getContextClassLoader();\n        ClassLoader shadowingClassLoader = new ShadowingFormatterClassLoader(\n                previousClassLoader,\n                ShadowedFormatter.class.getName(),\n                TearDownTarget.class.getName());\n\n        try {\n            Class<?> formatterClass = shadowingClassLoader.loadClass(ShadowedFormatter.class.getName());\n            TearDownOnVmCrash formatter = formatterClass\n                    .asSubclass(TearDownOnVmCrash.class)\n                    .getConstructor()\n                    .newInstance();\n            thread.setContextClassLoader(shadowingClassLoader);\n\n            reportVmExit(TearDownTarget.class.getName(), formatter);\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        } finally {\n            thread.setContextClassLoader(previousClassLoader);\n        }\n\n        assertThat(TearDownTarget.tearDownCalls).isEqualTo(1);\n    }\n\n    @Test\n    void ignoresVmExitForSuiteMethodTarget() throws Exception {\n        SuiteMethodTarget.reset();\n\n        reportVmExit(SuiteMethodTarget.class.getName(), new TearDownOnVmCrash());\n\n        assertThat(SuiteMethodTarget.tearDownCalls).isZero();\n    }\n\n    @Test\n    void ignoresVmExitWhenSuiteClassCannotBeLoaded() throws Exception {\n        TearDownTarget.reset();\n\n        reportVmExit(\"org_apache_ant.ant_junit.DoesNotExist\", new TearDownOnVmCrash());\n\n        assertThat(TearDownTarget.tearDownCalls).isZero();\n    }\n\n    private static void reportVmExit(String suiteName, TearDownOnVmCrash formatter) throws Exception {\n"}, {"oldText": "    public static class TearDownTarget {\n        private static int tearDownCalls;\n\n        public static void reset() {\n            tearDownCalls = 0;\n        }\n\n        public void tearDown() {\n            tearDownCalls++;\n        }\n    }\n\n    private static final class HidingClassLoader extends ClassLoader {\n", "newText": "    public static class TearDownTarget {\n        private static int tearDownCalls;\n\n        public static void reset() {\n            tearDownCalls = 0;\n        }\n\n        public void tearDown() {\n            tearDownCalls++;\n        }\n    }\n\n    public static class SuiteMethodTarget {\n        private static int tearDownCalls;\n\n        public static void reset() {\n            tearDownCalls = 0;\n        }\n\n        public static junit.framework.Test suite() {\n            return new TestSuite(SuiteMethodTarget.class);\n        }\n\n        public void tearDown() {\n            tearDownCalls++;\n        }\n    }\n\n    public static class ShadowedFormatter extends TearDownOnVmCrash {\n    }\n\n    private static final class HidingClassLoader extends ClassLoa