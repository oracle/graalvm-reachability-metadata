  package org_apache_ant.ant_junit;
  
  import java.io.ByteArrayOutputStream;
  import java.io.IOException;
  import java.io.InputStream;
  
  import junit.framework.TestSuite;
  
  import org.apache.tools.ant.taskdefs.optional.junit.JUnitTask;
  import org.apache.tools.ant.taskdefs.optional.junit.JUnitTaskMirrorImpl;
  import org.apache.tools.ant.taskdefs.optional.junit.JUnitTest;
  import org.apache.tools.ant.taskdefs.optional.junit.TearDownOnVmCrash;
  
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class TearDownOnVmCrashTest {
      @Test
      void invokesTearDownForVmExitError() throws Exception {
          TearDownTarget.reset();
  
          reportVmExit(TearDownTarget.class.getName(), new TearDownOnVmCrash());
  
          assertThat(TearDownTarget.tearDownCalls).isEqualTo(1);
      }
  
      @Test
      void fallsBackToFormatterClassLoaderWhenContextClassLoaderCannotLoadSuite() throws Exception {
          TearDownTarget.reset();
          Thread thread = Thread.currentThread();
          ClassLoader previousClassLoader = thread.getContextClassLoader();
          ClassLoader hidingClassLoader = new HidingClassLoader(
                  previousClassLoader,
                  TearDownTarget.class.getName());
  
          try {
              thread.setContextClassLoader(hidingClassLoader);
  
              reportVmExit(TearDownTarget.class.getName(), new TearDownOnVmCrash());
          } finally {
              thread.setContextClassLoader(previousClassLoader);
          }
  
          assertThat(TearDownTarget.tearDownCalls).isEqualTo(1);
      }
  
      @Test
      void fallsBackToClassForNameWhenRuntimeFormatterClassLoaderCannotLoadSuite() throws Exception {
          TearDownTarget.reset();
          Thread thread = Thread.currentThread();
          ClassLoader previousClassLoader = thread.getContextClassLoader();
          ClassLoader shadowingClassLoader = new ShadowingFormatterClassLoader(
                  previousClassLoader,
                  ShadowedFormatter.class.getName(),
                  TearDownTarget.class.getName());
  
          try {
              Class<?> formatterClass = shadowingClassLoader.loadClass(ShadowedFormatter.class.getName());
              TearDownOnVmCrash formatter = formatterClass
                      .asSubclass(TearDownOnVmCrash.class)
                      .getConstructor()
                      .newInstance();
              thread.setContextClassLoader(shadowingClassLoader);
  
              reportVmExit(TearDownTarget.class.getName(), formatter);
  
              assertThat(TearDownTarget.tearDownCalls).isEqualTo(1);
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          } finally {
              thread.setContextClassLoader(previousClassLoader);
          }
      }
  
      @Test
      void ignoresVmExitForSuiteMethodTarget() throws Exception {
          SuiteMethodTarget.reset();
  
          reportVmExit(SuiteMethodTarget.class.getName(), new TearDownOnVmCrash());
  
          assertThat(SuiteMethodTarget.tearDownCalls).isZero();
      }
  
      @Test
      void ignoresVmExitWhenSuiteClassCannotBeLoaded() throws Exception {
          TearDownTarget.reset();
  
          reportVmExit("org_apache_ant.ant_junit.DoesNotExist", new TearDownOnVmCrash());
  
          assertThat(TearDownTarget.tearDownCalls).isZero();
      }
  
      private static void reportVmExit(String suiteName, TearDownOnVmCrash formatter) throws Exception {
          JUnitTaskMirrorImpl mirror = new JUnitTaskMirrorImpl(new JUnitTask());
          JUnitTest suite = new JUnitTest(suiteName);
  
          mirror.addVmExit(suite, formatter, new ByteArrayOutputStream(), "vm exited", "testMethod");
      }
  
      public static class TearDownTarget {
          private static int tearDownCalls;
  
          public static void reset() {
              tearDownCalls = 0;
          }
  
          public void tearDown() {
              tearDownCalls++;
          }
      }
  
      public static class SuiteMethodTarget {
          private static int tearDownCalls;
  
          public static void reset() {
              tearDownCalls = 0;
          }
  
          public static junit.framework.Test suite() {
              return new TestSuite(SuiteMethodTarget.class);
          }
  
          public void tearDown() {
              tearDownCalls++;
          }
      }
  
      public static class ShadowedFormatter extends TearDownOnVmCrash {
      }
  
      private static final class HidingClassLoader extends ClassLoader {
          private final String hiddenClassName;
  
          private HidingClassLoader(ClassLoader parent, String hiddenClassName) {
              super(parent);
              this.hiddenClassName = hiddenClassName;
          }
  
          @Override
          public Class<?> loadClass(String name) throws ClassNotFoundException {
              if (hiddenClassName.equals(name)) {
                  throw new ClassNotFoundException(name);
              }
              return super.loadClass(name);
          }
      }
  
      private static final class ShadowingFormatterClassLoader extends ClassLoader {
          private final String formatterClassName;
          private final String hiddenClassName;
  
          private ShadowingFormatterClassLoader(
                  ClassLoader parent,
                  String formatterClassName,
                  String hiddenClassName) {
              super(parent);
              this.formatterClassName = formatterClassName;
              this.hiddenClassName = hiddenClassName;
          }
  
          @Override
          public Class<?> loadClass(String name) throws ClassNotFoundException {
              if (hiddenClassName.equals(name)) {
                  throw new ClassNotFoundException(name);
              }
              if (formatterClassName.equals(name)) {
                  Class<?> loadedClass = findLoadedClass(name);
                  if (loadedClass != null) {
                      return loadedClass;
                  }
                  return defineFormatterClass(name);
              }
              return super.loadClass(name);
          }
  
          private Class<?> defineFormatterClass(String name) throws ClassNotFoundException {
              String resourceName = name.replace('.', '/') + ".class";
              try (InputStream inputStream = getParent().getResourceAsStream(resourceName)) {
                  if (inputStream == null) {
                      throw new ClassNotFoundException(name);
                  }
                  byte[] bytes = inputStream.readAllBytes();
                  return defineClass(name, bytes, 0, bytes.length);
              } catch (IOException exception) {
                  throw new ClassNotFoundException(name, exception);
              }
          }
      }
  }
