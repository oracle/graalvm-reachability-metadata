              while ((line = br.readLine()) != null) {
                  if (firstLine || !filterLine(line)) {
                      pw.write(line);
                      pw.newLine();
                  }
                  firstLine = false;
              }
          } catch (final Exception e) {
              return stack; // return the stack unfiltered
          } finally {
              FileUtils.close(pw);
  
