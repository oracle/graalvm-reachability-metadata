[tool-call] delta {"command":"tmp=$(mktemp -d)\npython3 - <<'PY' \"$tmp\"\nimport sys, urllib.request, zipfile, os, xml.etree.ElementTree as ET\nbase=sys.argv[1]\nfor ext in ['pom','jar','-javadoc.jar','-sources.jar']:\n    name=f'lucene-core-6.0.0{ext}' if ext.startswith('-') else f'lucene-core-6.0.0.{ext}'\n    url=f'https://repo1.maven.org/maven2/org/apache/lucene/lucene-core/6.0.0/{name}'\n    try:\n        data=urllib.request.urlopen(url, timeout=30).read()\n        open(os.path.join(base,name),'wb').write(data)\n        print('downloaded', name, len(data))\n    except Exception as e:\n        print('failed', name, e)\n\npom=os.path.join(base,'lucene-core-6.0.0.pom')\nroot=ET.parse(pom).getroot(); ns={'m':'http://maven.apache.org/POM/4.0.0'}\nprint('\\nPOM dependencies:')\ndeps=root.findall('m:dependencies/m:dependency', ns)\nif not deps: print('(none)')\nfor d in deps:\n    print(':'.join((d.findtext('m:groupId', default='', namespaces=ns), d.findtext('m:artifactId', default='', namespaces=ns), d.findtext('m:version', default='', namespaces=ns), d.findtext('m:scope', default='', namespaces=ns))))\n\njar=os.path.join(base,'lucene-core-6.0.0.jar')\nwith zipfile.ZipFile(jar) as z:\n    names=z.namelist()\n    print('\\nManifest:')\n    print(z.read('META-INF/MANIFEST.MF').decode('utf-8','replace')[:2000])\n    print('\\nServices:', [n for n in names if n.startswith('META-INF/services/')][:20])\n    for prefix in ['org/apache/lucene/analysis/','org/apache/lucene/index/','org/apache/lucene/search/','org/apache/lucene/store/']:\n        classes=[n for n in names if n.startswith(prefix) and n.endswith('.class')]\n        print(prefix, len(classes), 'sample', classes[:8])\nPY\nrm -rf \"$tmp\"","timeout":60}
[tool-call] end id=call_bF2QqJfPkrxkCfLI1cWzGmMy|fc_0c6a6be384ce2de2016a3fa909dcb081908f42bc1d15bda50f name=bash args={"command": "tmp=$(mktemp -d)\npython3 - <<'PY' \"$tmp\"\nimport sys, urllib.request, zipfile, os, xml.etree.ElementTree as ET\nbase=sys.argv[1]\nfor ext in ['pom','jar','-javadoc.jar','-sources.jar']:\n    name=f'lucene-core-6.0.0{ext}' if ext.startswith('-') else f'lucene-core-6.0.0.{ext}'\n    url=f'https://repo1.maven.org/maven2/org/apache/lucene/lucene-core/6.0.0/{name}'\n    try:\n        data=urllib.request.urlopen(url, timeout=30).read()\n        open(os.path.join(base,name),'wb').write(data)\n        print('downloaded', name, len(data))\n    except Exception as e:\n        print('failed', name, e)\n\npom=os.path.join(base,'lucene-core-6.0.0.pom')\nroot=ET.parse(pom).getroot(); ns={'m':'http://maven.apache.org/POM/4.0.0'}\nprint('\\nPOM dependencies:')\ndeps=root.findall('m:dependencies/m:dependency', ns)\nif not deps: print('(none)')\nfor d in deps:\n    print(':'.join((d.findtext('m:groupId', default='', namespaces=ns), d.findtext('m:artifactId', default='', namespaces=ns), d.findtext('m:version', default='', namespaces=ns), d.findtext('m:scope', default='', namespaces=ns))))\n\njar=os.path.join(base,'lucene-core-6.0.0.jar')\nwith zipfile.ZipFile(jar) as z:\n    names=z.namelist()\n    print('\\nManifest:')\n    print(z.read('META-INF/MANIFEST.MF').decode('utf-8','replace')[:2000])\n    print('\\nServices:', [n for n in names if n.startswith('META-INF/services/')][:20])\n    for prefix in ['org/apache/lucene/analysis/','org/apache/lucene/index/','org/apache/lucene/search/','org/apache/lucene/store/']:\n        classes=[n for n in names if n.startswith(prefix) and n.endswith('.class')]\n        print(prefix, len(classes), 'sample', classes[:8])\nPY\nrm -rf \"$tmp\"", "timeout": 60}
