[tool-call] delta {"command":"python3 - <<'PY'\nimport urllib.request,re,html\nfor u in ['https://pekko.apache.org/docs/pekko/2.0.0-M1/actors.html','https://pekko.apache.org/docs/pekko/2.0.0-M1/typed/guide/introduction.html','https://pekko.apache.org/docs/pekko/2.0.0-M1/project/migration-guides.html','https://pekko.apache.org/docs/pekko/current/project/migration-guides.html','https://pekko.apache.org/docs/pekko/2.0.0-M1/serialization.html']:\n print('\\nURL',u)\n try:\n  text=urllib.request.urlopen(u,timeout=10).read().decode('utf-8','ignore')\n  for pat in ['libraryDependencies','pekko-actor','typed','dependency','classic','TypedActor','pekko-actor-typed','ActorSystem']:\n   if pat in text: print('contains',pat)\n  # print snippets around dependency\n  for m in re.finditer('pekko-actor[^<\\s]*|libraryDependencies|TypedActor|classic actors|ActorSystem', text):\n   s=max(0,m.start()-150); e=min(len(text),m.end()+200)\n   print(re.sub('<[^>]+>',' ',text[s:e]).replace('\\n',' ')[:500])\n   break\n except Exception as e: print('ERR',e)\nPY","timeout":30}
