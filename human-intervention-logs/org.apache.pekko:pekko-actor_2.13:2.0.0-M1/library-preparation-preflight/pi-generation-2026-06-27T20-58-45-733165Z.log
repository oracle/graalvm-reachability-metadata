  171:   private val inetSocketAddress = """(.*?)(?::(\d+))?""".r
  172: 
  173:   /**
  174:    * INTERNAL API
  175:    */
  176:   @InternalApi private[pekko] def parseNameserverAddress(str: String): InetSocketAddress =
  177:     str match {
  178:       case inetSocketAddress(host, port) =>
  179:         new InetSocketAddress(host, Option(port).fold(DnsFallbackPort)(_.toInt))
  180:       case unexpected =>
  181:         throw new IllegalArgumentException(s"Unparseable address string: $unexpected") // will not happen, for exhaustiveness check
  182:     }
  183: 
  184:   /**
  185:    * INTERNAL API
  186:    * Find out the default search lists that Java would use normally, e.g. when using InetAddress to resolve domains.
  187:    *
  188:    * The default nameservers are attempted to be obtained from: jndi-dns and from `sun.net.dnsResolverConfiguration`
  189:    * as a fallback (which is expected to fail though when running on JDK9+ due to the module encapsulation of sun packages).
  190:    *
  191:    * Based on: https://github.com/netty/netty/blob/4.1/resolver-dns/src/main/java/io/netty/resolver/dns/DefaultDnsServerAddressStreamProvider.java#L58-L146
  192:    */
  193:   private[pekko] def getDefaultNameServers(system: ExtendedActorSystem): Try[List[InetSocketAddress]] = {
  194:     def asInetSocketAddress(server: String): Try[InetSocketAddress] = {
  195:       Try {
  196:         val uri = new URI(server)
  197:         val host = uri.getHost
  198:         val port = uri.getPort match {
  199:           case -1       => DnsFallbackPort
  200:           case selected => selected
  201:         }
  202:         new InetSocketAddress(host, port)
  203:       }
  204:     }
  205: 
  206:     def getNameserversUsingJNDI: Try[List[InetSocketAddress]] = {
  207:       import java.util
  208:       import javax.naming.Context
  209:       import javax.naming.directory.InitialDirContext
  210:       // Using jndi-dns to obtain the default name servers.
  211:       //
  212:       // See:
  213:       // - https://docs.oracle.com/javase/8/docs/technotes/guides/jndi/jndi-dns.html
  214:       // - https://mail.openjdk.java.net/pipermail/net-dev/2017-March/010695.html
  215:       val env = new util.Hashtable[String, String]
  216:       env.put(Context.INITIAL_CONTEXT_FACTORY, "com.sun.jndi.dns.DnsContextFactory")
  217:       env.put("java.naming.provider.url", "dns://")
  218: 
  219:       Try {
  220:         val ctx = new InitialDirContext(env)
  221:         val dnsUrls = ctx.getEnvironment.get("java.naming.provider.url").asInstanceOf[String]
  222:         // Only try if not empty as otherwise we will produce an exception
  223:         if ((dnsUrls ne null) && !dnsUrls.isEmpty) {
  224:           val servers = dnsUrls.split(" ")
  225:           servers.flatMap { server =>
  226:             asInetSocketAddress(server).toOption
  227:           }.toList
  228:         } else Nil
  229:       }
  230:     }
  231: 
  232:     // this method is used as a fallback in case JNDI results in an empty list
  233:     // this method will not work when running modularised of course since it needs access to internal sun classes
  234:     def getNameserversUsingReflection: Try[List[InetSocketAddress]] = {
  235:       system.dynamicAccess.getClassFor[Any]("sun.net.dns.ResolverConfiguration").flatMap { c =>
  236:         Try {
  237:           val open = c.getMethod("open")
  238:           val nameservers = c.getMethod("nameservers")
  239:           val instance = open.invoke(null)
  240:           val ns = nameservers.invoke(instance).asInstanceOf[util.List[String]]
  241:           val res = if (ns.isEmpty)
  242:             throw new IllegalStateException(
  243:               "Empty nameservers list discovered using reflection. Consider configuring default nameservers manually!")
  244:           else ns.asScala.toList
  245:           res.flatMap(s => asInetSocketAddress(s).toOption)
  246:         }
  247:       }
  248:     }
  249: 
  250:     getNameserversUsingJNDI.orElse(getNameserversUsingReflection)
  251:   }
  252: }
