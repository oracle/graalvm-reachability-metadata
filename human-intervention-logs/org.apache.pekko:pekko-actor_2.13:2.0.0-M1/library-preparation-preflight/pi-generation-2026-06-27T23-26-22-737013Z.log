[tool-call] delta {"command":"python3 - <<'PY'\nimport urllib.request, re\nfor url in ['https://pekko.apache.org/docs/pekko/current/project/migration-guides.html','https://pekko.apache.org/docs/pekko/current/project/migration-guide-1.1.x-2.0.x.html','https://pekko.apache.org/docs/pekko/current/general/configuration.html','https://pekko.apache.org/docs/pekko/current/actors.html']:\n    print('\\n====',url)\n    try:\n      text=urllib.request.urlopen(url,timeout=15).read().decode('utf-8','ignore')\n    except Exception as e:\n      print(e); continue\n    # strip tags crude around matching lines\n    for pat in ['TypedActor','typed actor','2.0','dependency','pekko-actor']:\n      if pat.lower() in text.lower(): print('has', pat)\n    txt=re.sub('<[^>]+>',' ',text)\n    txt=re.sub('\\s+',' ',txt)\n    for m in re.finditer('TypedActor|typed actor|pekko-actor|dependency', txt, re.I):\n      print(txt[max(0,m.start()-180):m.start()+300])\n      break\nPY","timeout":30}
