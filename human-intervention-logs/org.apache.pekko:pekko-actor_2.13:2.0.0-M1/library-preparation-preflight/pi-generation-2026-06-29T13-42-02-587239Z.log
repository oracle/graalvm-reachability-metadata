[tool-call] delta {"command":"python3 - <<'PY'\nimport urllib.request, re\nurls=[\n 'https://pekko.apache.org/docs/pekko/2.0.0-M1/typed/index.html',\n 'https://pekko.apache.org/docs/pekko/2.0.0-M1/project/migration-guides.html',\n 'https://pekko.apache.org/docs/pekko/2.0.0-M1/project/migration-guides/migration-guide-2.0.x.html',\n 'https://pekko.apache.org/docs/pekko/2.0.0-M1/index.html',\n]\nfor url in urls:\n print('\\nURL',url)\n try:\n  txt=urllib.request.urlopen(url, timeout=20).read().decode('utf-8','ignore')\n  print('len',len(txt),'title', re.search(r'<title>(.*?)</title>', txt, re.S).group(1) if re.search(r'<title>(.*?)</title>', txt, re.S) else '')\n  for pat in ['typed', 'dependency', 'pekko-actor-typed', 'pekko-actor_2.13', 'testkit', 'Docker', 'system property']:\n   i=txt.lower().find(pat.lower())\n   if i>=0: print(pat, re.sub('<[^>]+>',' ',txt[max(0,i-200):i+500])[:500].replace('\\n',' '))\n except Exception as e: print('ERR', e)\nPY","timeout":60}
