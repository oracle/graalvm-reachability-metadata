ent/project/migration-guides.html',\n 'https://pekko.apache.org/docs/pekko/current/project/migration-guides.html#migration-guide-1-2-x-to-2-0-x',\n 'https://pekko.apache.org/docs/pekko/current/project/migration-guides.html#migration-guide-1-1-x-to-2-0-x',\n 'https://pekko.apache.org/docs/pekko/current/typed/guide/introduction.html',\n 'https://pekko.apache.org/docs/pekko/current/actors.html'\n]\nfor url in urls:\n print('\\n---',url)\n try:\n  s=urllib.request.urlopen(url,timeout=30).read().decode(errors='ignore')\n  for pat in ['TypedActor','typed actor','Classic','2.0','removed','deprecated','artifact']:\n   m=re.search(pat,s,re.I)\n   if m:\n    start=max(0,m.start()-400); end=min(len(s),m.end()+800)\n    txt=re.sub('<[^>]+>',' ',s[start:end])\n    txt=re.sub(r'\\s+',' ',txt)\n    print(pat,':',txt[:1200])\n except Exception as e: print('ERR',type(e),e)\nPY", "timeout": 120}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 2710, "output": 545, "cacheRead": 22016, "cacheWrite": 0, "totalTokens": 25271, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1782708964395, "responseId": "resp_0f4be0ef9f40edc5016a41fae4e7288195b8ed6072a84b7acf"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_hcJf4JHlHw9oU7q69NtyXC1n|fc_0f4be0ef9f40edc5016a41faea33d08195b994756294c0fd00", "toolName": "bash", "content": [{"type": "text", "text": "\n--- https://pekko.apache.org/docs/pekko/current/project/migration-guides.html\nClassic :  Dispatchers Mailboxes Testing Coexistence Style guide Learning Pekko Typed from Classic Cluster Cluster Usage Cluster Specification Cluster Membership Service Phi Accrual Failure Detector Distributed Data Cluster Singleton Cluster Sharding <a hr\n2.0 : l-config\">ssl-config has been updated to 0.6.1 in order to bring in bug/security fixes. Note that ssl-config 0.6.1 is binary and source compatible with 0.4.1. Pekko TestKit users will f