        executor = "default-executor"
        # This will be used if you have set "executor = "default-executor"".
        # ExecutionContext will be used as the default executor for all
        # executor = "default-executor". Note that "default-executor"
        # is the default value for executor, and therefore used if not
        # the executor configured in "fallback" will be used.
        default-executor {
          fallback = "fork-join-executor"
        # This will be used if you have set "executor = "affinity-pool-executor""
        # This executor is classified as "ApiMayChange".
        affinity-pool-executor {
        # This will be used if you have set "executor = "fork-join-executor""
        fork-join-executor {
          # When set to `on` but the underlying runtime does not support virtual threads, an Exception will be thrown.
          # Virtualize this dispatcher as a virtual-thread-executor
          virtual-thread-start-number = -1
