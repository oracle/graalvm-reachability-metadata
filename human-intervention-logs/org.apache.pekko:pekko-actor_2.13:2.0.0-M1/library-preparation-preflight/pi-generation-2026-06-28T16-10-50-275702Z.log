[tool-call] delta {"command":"python3 - <<'PY'\nimport urllib.request, re\nurls=[\n 'https://pekko.apache.org/docs/pekko/current/typed/index.html',\n 'https://pekko.apache.org/docs/pekko/current/general/actor-systems.html',\n 'https://pekko.apache.org/docs/pekko/current/project/migration-guides.html',\n 'https://pekko.apache.org/docs/pekko/current/project/migration-guides-2.0.x.html',\n]\nfor url in urls:\n    print('\\n---', url)\n    try:\n        txt=urllib.request.urlopen(url, timeout=20).read().decode('utf-8','ignore')\n        print('len', len(txt))\n        for pat in ['pekko-actor-typed', 'TypedActor', 'Typed actors', 'removed', 'classic']:\n            print(pat, txt.lower().find(pat.lower()))\n        snippets=[]\n        for m in re.finditer('pekko-actor-typed|TypedActor|removed|classic', txt, re.I):\n            snippets.append(re.sub('<[^>]+>',' ',txt[max(0,m.start()-120):m.end()+160]).replace('\\n',' ')[:300])\n            if len(snippets)>=3: break\n        for s in snippets: print(' ', ' '.join(s.split()))\n    except Exception as e:\n        print('ERR', e)\nPY","timeout":60}
