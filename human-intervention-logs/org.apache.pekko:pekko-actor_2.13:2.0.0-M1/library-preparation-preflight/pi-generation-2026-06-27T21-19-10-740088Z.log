la.binary.version}</artifactId>\\n      <version>2.0.0-M1</version>\\n      <type>pom</type>\\n      <scope>import</scope>\\n    </dependency>\\n  </dependencies>\\n</dependencyManagement>\\n<dependencies>\\n  <dependency>\\n    <groupId>org.apache.pekko</groupId>\\n    <artifactId>pekko-actor_${scala.binar\n4206997 > Gradle def versions = [\\n  ScalaBinary: \\\"2.13\\\"\\n]\\ndependencies {\\n  implementation platform(\\\"org.apache.pekko:pekko-bom_${versions.ScalaBinary}:2.0.0-M1\\\")\\n\\n  implementation \\\"org.apache.pekko:pekko-actor_${versions.ScalaBinary}\\\"\\n  testImplementation \\\"org.apache.pekko:pekko-testkit_${versions.ScalaBinary}\\\"\\n}\\nClassic Event Bus Classifiers Event Stream Classic Logging Module info Intro\n4234196 e Pekko actors dependency in your project, and will most likely want to configure logging via the SLF4J module (see below).\\nsbt val PekkoVersion = \\\"2.0.0-M1\\\"\\nlibraryDependencies += \\\"org.apache.pekko\\\" %% \\\"pekko-actor\\\" % PekkoVersion Maven <properties>\\n  <scala.binary.version>2.13</scala.binary.version>\\n</properties>\\n<dependencyManagement>\\n  <dependencies>\\n    <dependency>\\n      <group\n4234558 ncies>\\n    <dependency>\\n      <groupId>org.apache.pekko</groupId>\\n      <artifactId>pekko-bom_${scala.binary.version}</artifactId>\\n      <version>2.0.0-M1</version>\\n      <type>pom</type>\\n      <scope>import</scope>\\n    </dependency>\\n  </dependencies>\\n</dependencyManagement>\\n<dependencies>\\n  <dependency>\\n    <groupId>org.apache.pekko</groupId>\\n    <artifactId>pekko-actor_${scala.binar\n4235014 > Gradle def versions = [\\n  ScalaBinary: \\\"2.13\\\"\\n]\\ndependencies {\\n  implementation platform(\\\"org.apache.pekko:pekko-bom_${versions.ScalaBinary}:2.0.0-M1\\\")\\n\\n  implementation \\\"org.apache.pekko:pekko-actor_${versions.ScalaBinary}\\\"\\n}\\nProject Info: Pekko Logging (classic) Artifact org.apache.pekko pekko-slf4j 2.0.0-M1 Snapshots are available JDK versions OpenJDK 17 OpenJDK 21 OpenJDK 25 Sc\n4235183 plementation \\\"org.apache.pekko:pekko-actor_${versions.ScalaBinary}\\\"\\n}\\nProject Info: Pekko Logging (classic) Artifact org.apache.pekko pekko-slf4j 2.0.0-M1 Snapshots are available JDK versions OpenJDK 17 OpenJDK 21 OpenJDK 25 Scala versions 2.13.18, 3.3.7 JPMS module name pekko.slf4j License Apache-2.0 Home page https://pekko.apache.org/ API documentation API (Scaladoc) API (Javadoc) Forums Apa\n4235336 .0-M1 Snapshots are available JDK versions OpenJDK 17 OpenJDK 21 OpenJDK 25 Scala versions 2.13.18, 3.3.7 JPMS module name pekko.slf4j License Apache-2.0 Home page https://pekko.apache.org/ API documentation API (Scaladoc) API (Javadoc) Forums Apache Pekko User mailing list Apache Pekko Dev mailing list apache/pekko discussion Release notes Release Notes Issues Github issues Sources https://github\n4249789 .jar’. It has a single dependency: the slf4j-api jar. In your runtime, you also need a SLF4J backend. We recommend Logback:\\nsbt val PekkoVersion = \\\"2.0.0-M1\\\"\\nlibraryDependencies ++= Seq(\\n  \\\"org.apache.pekko\\\" %% \\\"pekko-slf4j\\\" % PekkoVersion,\\n  \\\"ch.qos.logback\\\" % \\\"logback-classic\\\" % \\\"1.5.23\\\"\\n) Maven <properties>\\n  <scala.binary.version>2.13</scala.binary.version>\\n</properties>\\n<d\n4250221 ncies>\\n    <dependency>\\n      <groupId>org.apache.pekko</groupId>\\n      <artifactId>pekko-bom_${scala.binary.version}</artifactId>\\n      <version>2.0.0-M1</version>\\n      <type>pom</type>\\n      <scope>import</scope>\\n    </dependency>\\n  </dependencies>\\n</dependencyManagement>\\n<dependencies>\\n  <dependency>\\n    <groupId>org.apache.pekko</groupId>\\n    <artifactId>pekko-slf4j_${scala.binar\n4250826 > Gradle def versions = [\\n  ScalaBinary: \\\"2.13\\\"\\n]\\ndependencies {\\n  implementation platform(\\\"org.apache.pekko:pekko-bom_${versions.ScalaBinary}:2.0.0-M1\\\")\\n\\n  implementation \\\"org.apache.pekko:pekko-slf4j_${versions.ScalaBinary}\\\"\\n  implementation \\\"ch.qos.logback:logback-classic:1.5.23\\\"\\n}\\nYou need to enable the Slf4jLogger in the loggers element in the configuration. Here you can also\n4264317 \"},{\"location\":\"scheduler.html#dependency\",\"text\":\"To use Scheduler, you must add the following dependency in your project:\\nsbt val PekkoVersion = \\\"2.0.0-M1\\\"\\nlibraryDependencies += \\\"org.apache.pekko\\\" %% \\\"pekko-actor\\\" % PekkoVersion Maven <properties>\\n  <scala.binary.version>2.13</scala.binary.version>\\n</properties>\\n<dependencyManagement>\\n  <dependencies>\\n    <dependency>\\n      <group\n4264679 ncies>\\n    <dependency>\\n      <groupId>org.apache.pekko</groupId>\\n      <artifactId>pekko-bom_${scala.binary.version}</artifactId>\\n      <version>2.0.0-M1</version>\\n      <type>pom</type>\\n      <scope>import</scope>\\n    </dependency>\\n  </dependencies>\\n</dependencyManagement>\\n<dependencies>\\n  <dependency>\\n    <groupId>org.apache.pekko</groupId>\\n    <artifactId>pekko-actor_${scala.binar\n4265135 > Gradle def versions = [\\n  ScalaBinary: \\\"2.13\\\"\\n]\\ndependencies {\\n  implementation platform(\\\"org.apache.pekko:pekko-bom_${versions.ScalaBinary}:2.0.0-M1\\\")\\n\\n  implementation \\\"org.apache.pekko:pekko-actor_${versions.ScalaBinary}\\\"\\n}\",\"title\":\"Dependency\"},{\"location\":\"scheduler.html#introduction\",\"text\":\"Sometimes, the need for making things happen in the future arises, and where do you g\n4272172  delay for a subsequent task if the previous tasks took too long to execute. For example, if the given interval is 1000 milliseconds and a task takes 200 milliseconds to execute the next task will be scheduled to run after 800 milliseconds. In such cases, the actual execution interval will differ from the interval passed to the scheduleAtFixedRate method.\\nIf the execution of the tasks takes longe\n4280618 gs. A good practice is to place those settings in an Extension.\\nSample configuration:\\ncopysourcemyapp {\\n  db {\\n    uri = \\\"mongodb://example1.com:27017,example2.com:27017\\\"\\n  }\\n  circuit-breaker {\\n    timeout = 30 seconds\\n  }\\n}\\nThe ExtensionExtension:\\nScala copysourceimport org.apache.pekko\\nimport pekko.actor.ActorSystem\\nimport pekko.actor.Extension\\nimport pekko.actor.ExtensionId\\nim\n4280637  is to place those settings in an Extension.\\nSample configuration:\\ncopysourcemyapp {\\n  db {\\n    uri = \\\"mongodb://example1.com:27017,example2.com:27017\\\"\\n  }\\n  circuit-breaker {\\n    timeout = 30 seconds\\n  }\\n}\\nThe ExtensionExtension:\\nScala copysourceimport org.apache.pekko\\nimport pekko.actor.ActorSystem\\nimport pekko.actor.Extension\\nimport pekko.actor.ExtensionId\\nimport pekko.actor.Ex\n4284365 nding as this will break the library-extension mechanism and make behavior depend on class path ordering.\",\"title\":\"Library extensions\"},{\"location\":\"migration/index.html\",\"text\":\"\",\"title\":\"Migration Guides\"},{\"location\":\"migration/index.html#migration-guides\",\"text\":\"Migration from Akka to Apache Pekko Migration from Apache Pekko 1.0.x to 1.1.x\",\"title\":\"Migration Guides\"},{\"location\":\"migration\n4284406 nsion mechanism and make behavior depend on class path ordering.\",\"title\":\"Library extensions\"},{\"location\":\"migration/index.html\",\"text\":\"\",\"title\":\"Migration Guides\"},{\"location\":\"migration/index.html#migration-guides\",\"text\":\"Migration from Akka to Apache Pekko Migration from Apache Pekko 1.0.x to 1.1.x\",\"title\":\"Migration Guides\"},{\"location\":\"migration/migration-guide-akka-1.0.x.html\",\"text\":\n4284438 r depend on class path ordering.\",\"title\":\"Library extensions\"},{\"location\":\"migration/index.html\",\"text\":\"\",\"title\":\"Migration Guides\"},{\"location\":\"migration/index.html#migration-guides\",\"text\":\"Migration from Akka to Apache Pekko Migration from Apache Pekko 1.0.x to 1.1.x\",\"title\":\"Migration Guides\"},{\"location\":\"migration/migration-guide-akka-1.0.x.html\",\"text\":\"Apache Pekko is based on the la\n4284459 h ordering.\",\"title\":\"Library extensions\"},{\"location\":\"migration/index.html\",\"text\":\"\",\"title\":\"Migration Guides\"},{\"location\":\"migration/index.html#migration-guides\",\"text\":\"Migration from Akka to Apache Pekko Migration from Apache Pekko 1.0.x to 1.1.x\",\"title\":\"Migration Guides\"},{\"location\":\"migration/migration-guide-akka-1.0.x.html\",\"text\":\"Apache Pekko is based on the latest version of Akka \n4284485 ary extensions\"},{\"location\":\"migration/index.html\",\"text\":\"\",\"title\":\"Migration Guides\"},{\"location\":\"migration/index.html#migration-guides\",\"text\":\"Migration from Akka to Apache Pekko Migration from Apache Pekko 1.0.x to 1.1.x\",\"title\":\"Migration Guides\"},{\"location\":\"migration/migration-guide-akka-1.0.x.html\",\"text\":\"Apache Pekko is based on the latest version of Akka in the v2.6.x series. If m\n4284521 ion/index.html\",\"text\":\"\",\"title\":\"Migration Guides\"},{\"location\":\"migration/index.html#migration-guides\",\"text\":\"Migration from Akka to Apache Pekko Migration from Apache Pekko 1.0.x to 1.1.x\",\"title\":\"Migration Guides\"},{\"location\":\"migration/migration-guide-akka-1.0.x.html\",\"text\":\"Apache Pekko is based on the latest version of Akka in the v2.6.x series. If migrating from an earlier version of \n4284574 ,{\"location\":\"migration/index.html#migration-guides\",\"text\":\"Migration from Akka to Apache Pekko Migration from Apache Pekko 1.0.x to 1.1.x\",\"title\":\"Migration Guides\"},{\"location\":\"migration/migration-guide-akka-1.0.x.html\",\"text\":\"Apache Pekko is based on the latest version of Akka in the v2.6.x series. If migrating from an earlier version of Akka, please migrate to Akka 2.6 before migrating to \n4284606 ml#migration-guides\",\"text\":\"Migration from Akka to Apache Pekko Migration from Apache Pekko 1.0.x to 1.1.x\",\"title\":\"Migration Guides\"},{\"location\":\"migration/migration-guide-akka-1.0.x.html\",\"text\":\"Apache Pekko is based on the latest version of Akka in the v2.6.x series. If migrating from an earlier version of Akka, please migrate to Akka 2.6 before migrating to Pekko.\",\"title\":\"Migration from \n4284616 on-guides\",\"text\":\"Migration from Akka to Apache Pekko Migration from Apache Pekko 1.0.x to 1.1.x\",\"title\":\"Migration Guides\"},{\"location\":\"migration/migration-guide-akka-1.0.x.html\",\"text\":\"Apache Pekko is based on the latest version of Akka in the v2.6.x series. If migrating from an earlier version of Akka, please migrate to Akka 2.6 before migrating to Pekko.\",\"title\":\"Migration from Akka to Ap\n4284841 t version of Akka in the v2.6.x series. If migrating from an earlier version of Akka, please migrate to Akka 2.6 before migrating to Pekko.\",\"title\":\"Migration from Akka to Apache Pekko\"},{\"location\":\"migration/migration-guide-akka-1.0.x.html#migration-from-akka-to-apache-pekko\",\"text\":\"These migration notes are designed for users migrating from Akka 2.6 to Pekko 1.0 and assume a basic level of Ak\n4284892 g from an earlier version of Akka, please migrate to Akka 2.6 before migrating to Pekko.\",\"title\":\"Migration from Akka to Apache Pekko\"},{\"location\":\"migration/migration-guide-akka-1.0.x.html#migration-from-akka-to-apache-pekko\",\"text\":\"These migration notes are designed for users migrating from Akka 2.6 to Pekko 1.0 and assume a basic level of Akka experience. Please feel free to submit an issue \n4284902 earlier version of Akka, please migrate to Akka 2.6 before migrating to Pekko.\",\"title\":\"Migration from Akka to Apache Pekko\"},{\"location\":\"migration/migration-guide-akka-1.0.x.html#migration-from-akka-to-apache-pekko\",\"text\":\"These migration notes are designed for users migrating from Akka 2.6 to Pekko 1.0 and assume a basic level of Akka experience. Please feel free to submit an issue or a patch\n4284934 migrate to Akka 2.6 before migrating to Pekko.\",\"title\":\"Migration from Akka to Apache Pekko\"},{\"location\":\"migration/migration-guide-akka-1.0.x.html#migration-from-akka-to-apache-pekko\",\"text\":\"These migration notes are designed for users migrating from Akka 2.6 to Pekko 1.0 and assume a basic level of Akka experience. Please feel free to submit an issue or a patch if you feel like the notes can \n4284985 tle\":\"Migration from Akka to Apache Pekko\"},{\"location\":\"migration/migration-guide-akka-1.0.x.html#migration-from-akka-to-apache-pekko\",\"text\":\"These migration notes are designed for users migrating from Akka 2.6 to Pekko 1.0 and assume a basic level of Akka experience. Please feel free to submit an issue or a patch if you feel like the notes can be improved.\\nfor Pekko jar dependencies, the group\n4286303 aults to 7355. With Artery Remoting, Akka defaults to 25520, while Pekko defaults to 17355. Cluster Management users should read the pekko-management migration guide\",\"title\":\"Migration from Akka to Apache Pekko\"},{\"location\":\"migration/migration-guide-akka-1.0.x.html#dependency-changes\",\"text\":\"The Scala 2.13/Scala 3 versions of Pekko no longer include scala-java8-compat as a dependency. This mea\n4286329  Remoting, Akka defaults to 25520, while Pekko defaults to 17355. Cluster Management users should read the pekko-management migration guide\",\"title\":\"Migration from Akka to Apache Pekko\"},{\"location\":\"migration/migration-guide-akka-1.0.x.html#dependency-changes\",\"text\":\"The Scala 2.13/Scala 3 versions of Pekko no longer include scala-java8-compat as a dependency. This means if you were relying on \n4286380 ults to 17355. Cluster Management users should read the pekko-management migration guide\",\"title\":\"Migration from Akka to Apache Pekko\"},{\"location\":\"migration/migration-guide-akka-1.0.x.html#dependency-changes\",\"text\":\"The Scala 2.13/Scala 3 versions of Pekko no longer include scala-java8-compat as a dependency. This means if you were relying on scala-java8-compat along with Scala 2.12/Scala 3 as\n4286390 355. Cluster Management users should read the pekko-management migration guide\",\"title\":\"Migration from Akka to Apache Pekko\"},{\"location\":\"migration/migration-guide-akka-1.0.x.html#dependency-changes\",\"text\":\"The Scala 2.13/Scala 3 versions of Pekko no longer include scala-java8-compat as a dependency. This means if you were relying on scala-java8-compat along with Scala 2.12/Scala 3 as a transit\n4287613 aded to 2.14.3. reactivestreams is upgraded to 1.0.4. pekko-protobuf-v3 is based on protobuf-java 3.16.3.\",\"title\":\"Dependency Changes\"},{\"location\":\"migration/migration-guide-akka-1.0.x.html#miscellaneous-notes\",\"text\":\"Data persisted with “akka-persistence” is usable with “pekko-persistence” and vice versa (Persistence). There is one issue that is fixed in v1.0.3 (related to persisted snapshots \n4287623 14.3. reactivestreams is upgraded to 1.0.4. pekko-protobuf-v3 is based on protobuf-java 3.16.3.\",\"title\":\"Dependency Changes\"},{\"location\":\"migration/migration-guide-akka-1.0.x.html#miscellaneous-notes\",\"text\":\"Data persisted with “akka-persistence” is usable with “pekko-persistence” and vice versa (Persistence). There is one issue that is fixed in v1.0.3 (related to persisted snapshots - for whic\n4288171 es have experimental support that we would appreciate users to try out in test environments (wiki page).\",\"title\":\"Miscellaneous Notes\"},{\"location\":\"migration/migration-guide-1.0.x-1.1.x.html\",\"text\":\"\",\"title\":\"Migration from Apache Pekko 1.0.x to 1.1.x\"},{\"location\":\"migration/migration-guide-1.0.x-1.1.x.html#migration-from-apache-pekko-1-0-x-to-1-1-x\",\"text\":\"Apache Pekko 1.1.x is binary backw\n4288181 perimental support that we would appreciate users to try out in test environments (wiki page).\",\"title\":\"Miscellaneous Notes\"},{\"location\":\"migration/migration-guide-1.0.x-1.1.x.html\",\"text\":\"\",\"title\":\"Migration from Apache Pekko 1.0.x to 1.1.x\"},{\"location\":\"migration/migration-guide-1.0.x-1.1.x.html#migration-from-apache-pekko-1-0-x-to-1-1-x\",\"text\":\"Apache Pekko 1.1.x is binary backwards compa\n4288234 try out in test environments (wiki page).\",\"title\":\"Miscellaneous Notes\"},{\"location\":\"migration/migration-guide-1.0.x-1.1.x.html\",\"text\":\"\",\"title\":\"Migration from Apache Pekko 1.0.x to 1.1.x\"},{\"location\":\"migration/migration-guide-1.0.x-1.1.x.html#migration-from-apache-pekko-1-0-x-to-1-1-x\",\"text\":\"Apache Pekko 1.1.x is binary backwards compatible with 1.0.x with the ordinary exceptions listed \n4288292 laneous Notes\"},{\"location\":\"migration/migration-guide-1.0.x-1.1.x.html\",\"text\":\"\",\"title\":\"Migration from Apache Pekko 1.0.x to 1.1.x\"},{\"location\":\"migration/migration-guide-1.0.x-1.1.x.html#migration-from-apache-pekko-1-0-x-to-1-1-x\",\"text\":\"Apache Pekko 1.1.x is binary backwards compatible with 1.0.x with the ordinary exceptions listed in the Binary Compatibility Rules.\\nThis means that updati\n4288302 tes\"},{\"location\":\"migration/migration-guide-1.0.x-1.1.x.html\",\"text\":\"\",\"title\":\"Migration from Apache Pekko 1.0.x to 1.1.x\"},{\"location\":\"migration/migration-guide-1.0.x-1.1.x.html#migration-from-apache-pekko-1-0-x-to-1-1-x\",\"text\":\"Apache Pekko 1.1.x is binary backwards compatible with 1.0.x with the ordinary exceptions listed in the Binary Compatibility Rules.\\nThis means that updating an appl\n4288335 ation-guide-1.0.x-1.1.x.html\",\"text\":\"\",\"title\":\"Migration from Apache Pekko 1.0.x to 1.1.x\"},{\"location\":\"migration/migration-guide-1.0.x-1.1.x.html#migration-from-apache-pekko-1-0-x-to-1-1-x\",\"text\":\"Apache Pekko 1.1.x is binary backwards compatible with 1.0.x with the ordinary exceptions listed in the Binary Compatibility Rules.\\nThis means that updating an application from Apache Pekko 1.0.x t\n4289028 e new Apache Pekko version in your build.\\nThat said, there are some changes to configuration and behavior that should be considered, so reading this migration guide and testing your application thoroughly is recommended.\",\"title\":\"Migration from Apache Pekko 1.0.x to 1.1.x\"},{\"location\":\"migration/migration-guide-1.0.x-1.1.x.html#splitwhen-splitafter-behavior-change\",\"text\":\"In Apache Pekko 1.0.x\n4289110 nfiguration and behavior that should be considered, so reading this migration guide and testing your application thoroughly is recommended.\",\"title\":\"Migration from Apache Pekko 1.0.x to 1.1.x\"},{\"location\":\"migration/migration-guide-1.0.x-1.1.x.html#splitwhen-splitafter-behavior-change\",\"text\":\"In Apache Pekko 1.0.x, the splitWhen/splitAfter stream operators on Source/Flow had an optional Substre\n4289168 ding this migration guide and testing your application thoroughly is recommended.\",\"title\":\"Migration from Apache Pekko 1.0.x to 1.1.x\"},{\"location\":\"migration/migration-guide-1.0.x-1.1.x.html#splitwhen-splitafter-behavior-change\",\"text\":\"In Apache Pekko 1.0.x, the splitWhen/splitAfter stream operators on Source/Flow had an optional SubstreamCancelStrategy parameter which defaulted to SubstreamCan\n4289178 migration guide and testing your application thoroughly is recommended.\",\"title\":\"Migration from Apache Pekko 1.0.x to 1.1.x\"},{\"location\":\"migration/migration-guide-1.0.x-1.1.x.html#splitwhen-splitafter-behavior-change\",\"text\":\"In Apache Pekko 1.0.x, the splitWhen/splitAfter stream operators on Source/Flow had an optional SubstreamCancelStrategy parameter which defaulted to SubstreamCancelStrateg\n\n\n[Showing lines 50-175 of 175 (50.0KB limit). Full output: /tmp/pi-bash-82c8663535c5db11.log]"}], "details": {"truncation": {"content": "3838363 nternal types that include state transition information.\\nBefore reading the migration guide it is advised to understand Persistence Typed.\",\"title\":\"Migration to EventSourcedBehavior\"},{\"location\":\"persistence-fsm.html#migration-steps\",\"text\":\"