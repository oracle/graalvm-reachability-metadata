g number for virtual threads created by this dispatcher.\n583:        virtual-thread-start-number = -1\n628:        # When set to `on` but the underlying runtime does not support virtual threads, an Exception will be thrown.\n629:        # Virtualize this dispatcher as a virtual-thread-executor\n637:        virtualize = off\n639:        # When virtualize = on, you can set the starting number for virtual threads created by this dispatcher.\n641:        virtual-thread-start-number = -1\n775:    # SECURITY BEST-PRACTICE is to disable java serialization for its multiple\n781:    # Completely disable the use of `org.apache.pekko.serialization.JavaSerialization` by the\n783:    # be inserted which will fail explicitly if attempts to use java serialization are made.\n787:    # attempting to send malicious messages intending to use java serialization as attack vector.\n790:    # Please note that this option does not stop you from manually invoking java serialization\n792:    allow-java-serialization = off\n794:    # Log warnings when the Java serialization is used to serialize messages.\n795:    # Java serialization is not very performant and should not be used in production\n801:    # When warn-about-java-serializer-usage = on, and this warn-on-no-serialization-verification = off,\n804:    warn-on-no-serialization-verification = on\n808:      java = \"org.apache.pekko.serialization.JavaSerializer\"\n809:      bytes = \"org.apache.pekko.serialization.ByteArraySerializer\"\n810:      primitive-long = \"org.apache.pekko.serialization.LongSerializer\"\n811:      primitive-int = \"org.apache.pekko.serialization.IntSerializer\"\n812:      primitive-string = \"org.apache.pekko.serialization.StringSerializer\"\n813:      primitive-bytestring = \"org.apache.pekko.serialization.ByteStringSerializer\"\n814:      primitive-boolean = \"org.apache.pekko.serialization.BooleanSerializer\"\n824:    serialization-bindings {\n840:    # Configuration namespace of serialization identifiers.\n8