pache.pekko.event.Logging$DefaultLogger\"]\n30:  # Specifies the default loggers dispatcher\n31:  loggers-dispatcher = \"pekko.actor.default-dispatcher\"\n38:  # Log level used by the configured loggers (see \"loggers\") as soon\n129:    # Serializes and deserializes (non-primitive) messages to ensure immutability,\n131:    serialize-messages = off\n133:    # Serializes and deserializes creators (in Props) to ensure that they can be\n136:    serialize-creators = off\n138:    # If serialize-messages or serialize-creators are enabled classes that starts with\n213:        # number of virtual nodes per node for consistent-hashing router\n214:        virtual-nodes-factor = 10\n222:          # Alternatively to giving nr-of-instances you can specify the full\n352:      \"/IO-DNS/async-dns\" {\n372:      #  - \"virtual-thread-executor\" requires a \"virtual-thread-executor\" section\n485:        # When set to `on` but the underlying runtime does not support virtual threads, an Exception will be thrown.\n486:        # Virtualize this dispatcher as a virtual-thread-executor\n494:        virtualize = off\n496:        # When virtualize = on, you can set the starting id for virtual threads created by this dispatcher.\n498:        virtual-thread-start-number = -1\n552:        # When set to `on` but the underlying runtime does not support virtual threads, an Exception will be thrown.\n553:        # Virtualize this dispatcher as a virtual-thread-executor\n561:        virtualize = off\n563:        # When virtualize = on, you can set the starting number for virtual threads created by this dispatcher.\n565:        virtual-thread-start-number = -1\n568:      # This will be used if you have set \"executor = \"virtual-thread-executor\"\n569:      # This executor will execute the every task on a new virtual thread.\n571:      # If the current runtime does not support virtual thread,\n573:      virtual-thread-executor {\n575:        #jdk.virtualThreadScheduler.parallelism\n576:        #jdk