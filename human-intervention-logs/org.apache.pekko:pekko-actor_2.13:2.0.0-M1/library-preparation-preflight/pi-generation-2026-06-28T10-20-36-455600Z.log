[tool-call] delta {"command":"python3 - <<'PY'\nimport urllib.request,re\nfrom html import unescape\nurls=['https://pekko.apache.org/docs/pekko/2.0.0-M1/project/migration-guides.html','https://pekko.apache.org/docs/pekko/2.0.0-M1/typed/guide/introduction.html','https://pekko.apache.org/docs/pekko/2.0.0-M1/actors.html']\nfor u in urls:\n    try:\n        html=urllib.request.urlopen(u,timeout=10).read().decode('utf-8','ignore')\n        text=re.sub('<[^<]+?>',' ',html)\n        text=unescape(re.sub(r'\\s+',' ',text))\n        print('\\nURL',u)\n        for term in ['TypedActor','typed actor','actor-typed','Classic Actors','dependency','sbt']:\n            i=text.lower().find(term.lower())\n            if i>=0: print(term,':',text[max(0,i-300):i+500])\n    except Exception as e: print('ERR',u,e)\nPY","timeout":30}
