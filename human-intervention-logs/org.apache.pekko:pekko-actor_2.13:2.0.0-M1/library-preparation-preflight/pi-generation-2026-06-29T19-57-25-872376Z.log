tadata/org.apache.directory.server/apacheds-kerberos-codec/index.json:13:      \"2.0.0-M15\",\n./metadata/org.apache.directory.server/apacheds-kerberos-codec/index.json:14:      \"2.0.0-M16\",\n./metadata/org.apache.directory.server/apacheds-kerberos-codec/index.json:15:      \"2.0.0-M17\",\n./metadata/org.apache.directory.server/apacheds-kerberos-codec/index.json:16:      \"2.0.0-M18\",\n./metadata/org.apache.directory.server/apacheds-kerberos-codec/index.json:17:      \"2.0.0-M19\",\n./metadata/com.softwaremill.sttp.shared/pekko_3/index.json:9:    \"description\" : \"sttp-shared provides common abstractions used across the sttp Scala HTTP ecosystem, including capabilities and streaming support. The pekko_3 module supplies the Pekko Streams capability implementation, modeling binary streams and pipes with Pekko Source and Flow types.\",\n./metadata/com.softwaremill.sttp.shared/pekko_3/1.5.1/reachability-metadata.json:87:      \"type\" : \"org.apache.pekko.dispatch.PekkoJdk9ForkJoinPool\",\n./metadata/io.scalaland/chimney_3/index.json:4:    \"metadata-version\" : \"2.0.0-M1\",\n./metadata/io.scalaland/chimney_3/index.json:15:      \"2.0.0-M1\",\n./metadata/org.apache.pekko/pekko-parsing_3/index.json:9:    \"description\" : \"Apache Pekko Parsing is a Scala-specific internal support module for Pekko HTTP that provides compile-time logging guards and cross-Scala-version compatibility annotations used by the HTTP parsing implementation. It is published as a JVM JAR for each Scala binary version, including Scala 3, so downstream Pekko HTTP modules can share those internal helpers without duplicating them.\",\n./metadata/org.apache.pekko/pekko-parsing_2.13/index.json:9:    \"description\" : \"Apache Pekko Parsing is a Scala-specific internal support module for Pekko HTTP that provides compile-time logging guards and cross-Scala-version compatibility annotations used by the HTTP parsing implementation. It is published as a JVM JAR for each Scala binary version, including Scala 2.13, so downstream Pekko HTTP modules can share those internal helpers without duplicating them.\",\n./metadata/org.apache.pekko/pekko-actor_2.13/1.1.5/reachability-metadata.json:303:      \"type\" : \"org.apache.pekko.dispatch.PekkoJdk9ForkJoinPool\",\n./metadata/org.apache.pekko/pekko-actor_2.13/index.json:5:    \"source-code-url\" : \"https://repo.maven.apache.org/maven2/org/apache/pekko/pekko-actor_2.13/$version$/pekko-actor_2.13-$version$-sources.jar\",\n./metadata/org.apache.pekko/pekko-actor_2.13/index.json:8:    \"documentation-url\" : \"https://repo.maven.apache.org/maven2/org/apache/pekko/pekko-actor_2.13/$version$/pekko-actor_2.13-$version$-javadoc.jar\",\n./metadata/org.apache.pekko/pekko-actor_2.13/index.json:9:    \"description\" : \"Apache Pekko Actor provides the core actor-system runtime for building concurrent, distributed, resilient message-driven JVM applications in Java and Scala. It includes the classic actor APIs, dispatching, supervision, routing, scheduling, event streams, configuration integration, and foundational utilities used by other Pekko modules.\",\n./metadata/org.apache.pekko/pekko-protobuf-v3_2.13/index.json:8:    \"description\" : \"Apache Pekko Protobuf V3 packages a shaded Google Protocol Buffers v3 Java runtime under the org.apache.pekko.protobufv3.internal namespace for Pekko modules. It lets Pekko use protobuf serialization without exposing or conflicting with application-level protobuf dependencies.\",\n./metadata/org.apache.pekko/pekko-protobuf-v3_2.13/index.json:15:      \"2.0.0-M1\"\n./metadata/org.apache.pekko/pekko-protobuf-v3_2.13/index.json:28:    \"description\" : \"Apache Pekko Protobuf V3 packages a shaded Google Protocol Buffers v3 Java runtime under the org.apache.pekko.protobufv3.internal namespace for Pekko modules. It lets Pekko use protobuf serialization without exposing or conflicting with application-level protobuf dependencies.\",\n./metadata/org.apache.pekko/pekko-protobuf-v3_2.13/index.json:47:  