lse(trackedFiles.contains(AbsoluteFile(untrackedFile)))\n   325\t\n   326\t      val dirtyFiles: Set[AbsoluteFile] = gitOps.status().toSet\n   327\t      assertEquals(Set(AbsoluteFile(trackedFile), AbsoluteFile(untrackedFile)), dirtyFiles)\n   328\t      assertEquals(dirtyFiles, gitOps.status(AbsoluteFile(sourceDirectory)).toSet)\n   329\t\n   330\t      val filesChangedFromBaseline: Seq[AbsoluteFile] = gitOps.diff(baselineBranch)\n   331\t      assertEquals(Seq(AbsoluteFile(trackedFile)), filesChangedFromBaseline)\n   332\t      assertEquals(filesChangedFromBaseline, gitOps.diff(baselineBranch, AbsoluteFile(sourceDirectory)))\n   333\t    }\n   334\t  }\n   335\t\n   336\t  @Test\n   337\t  def gitOpsExtensionMethodsResolveRootAndProposedConfigurationFiles(): Unit = {\n   338\t    import org.scalafmt.sysops.GitOps._\n   339\t\n   340\t    withTempDirectory { tempDirectory: Path =>\n   341\t      implicit val codec: Codec = Codec.UTF8\n   342\t      val workspace: AbsoluteFile = AbsoluteFile(tempDirectory)\n   343\t      val gitRoot: AbsoluteFile = workspace / \"repo\"\n   344\t      val cwd: AbsoluteFile = gitRoot / \"module\"\n   345\t      cwd.mkdirs()\n   346\t      val rootConfig: AbsoluteFile = gitRoot / FileOps.defaultConfigFileName\n   347\t      rootConfig.writeFile(\"version = 3\\n\")\n   348\t      val localConfig: AbsoluteFile = cwd / FileOps.defaultConfigFileName\n   349\t      localConfig.writeFile(\"runner.dialect = scala213\\n\")\n   350\t\n   351\t      val gitWithRoot = new RecordingGitOps(rootOption = Some(gitRoot))\n   352\t      val gitWithoutRoot = new RecordingGitOps(rootOption = None)\n   353\t\n   354\t      assertEquals(Success(localConfig.path), gitWithRoot.getCanonicalConfigFile(cwd).get)\n   355\t      Files.delete(localConfig.path)\n   356\t      assertEquals(Success(rootConfig.path), gitWithRoot.getCanonicalConfigFile(cwd).get)\n   357\t      assertEquals(Success(rootConfig.path), gitWithRoot.getRootConfigFile.get)\n   358\t      assertEquals(gitRoot.path.resolve(FileOps.defaultConfigFileName), gitWithRoot.getProposedConfigFile(cwd).path)\n   359\t      assertEquals(cwd.path.resolve(\"custom.conf\"), gitWithRoot.getProposedConfigFile(cwd, Some(Paths.get(\"custom.conf\"))).path)\n   360\t      assertEquals(cwd.path.resolve(FileOps.defaultConfigFileName), gitWithoutRoot.getProposedConfigFile(cwd).path)\n   361\t      assertTrue(gitWithoutRoot.getRootConfigFile.isEmpty)\n   362\t\n   363\t      val created: GitOps = GitOps.FactoryImpl(workspace)\n   364\t      assertNotNull(created)\n   365\t    }\n   366\t  }\n   367\t\n   368\t  @Test\n   369\t  def osSpecificHelpersReflectCurrentPlatformSeparator(): Unit = {\n   370\t    import org.scalafmt.sysops.OsSpecific.XtensionStringAsFilename\n   371\t\n   372\t    assertEquals(File.separatorChar == '\\\\', OsSpecific.isWindows)\n   373\t    val pattern: String = \"src/main/scala/*.scala\"\n   374\t    val expectedPattern: String =\n   375\t      if (OsSpecific.isWindows) \"src\\\\\\\\main\\\\\\\\scala\\\\\\\\*.scala\" else pattern\n   376\t\n   377\t    assertEquals(expectedPattern, OsSpecific.fixSeparatorsInPathPattern(pattern))\n   378\t    assertEquals(expectedPattern, pattern.asFilename)\n   379\t  }\n   380\t\n   381\t  private def withTempDirectory(testBody: Path => Unit): Unit = {\n   382\t    val directory: Path = Files.createTempDirectory(\"scalafmt-sysops-test-\")\n   383\t    try testBody(directory)\n   384\t    finally deleteRecursively(directory)\n   385\t  }\n   386\t\n   387\t  private def runCommand(workingDirectory: Path, command: String*): Unit = {\n   388\t    val process = new ProcessBuilder(command: _*)\n   389\t      .directory(workingDirectory.toFile)\n   390\t      .redirectErrorStream(true)\n   391\t      .start()\n   392\t    val finished: Boolean = process.waitFor(30, TimeUnit.SECONDS)\n   393\t    if (!finished) {\n   394\t      process.destroyForcibly()\n   395\t      process.waitFor(5, TimeUnit.SECONDS)\n   396\t    }\n   397\t    val output: String =\n   398\t      if (process.isAlive) \"\" else new String(process.getInputStream.readAllBytes(), StandardCharsets.UTF_8)\n   399\t    assertTrue(finished, s\"Command timed out: ${command.mkString(\" \")}\\n$output\")\n   400\t    assertEquals(0, process.exitValue(), s\"Command failed: ${command.mkString(\" \")}\\n$output\")\n   401\t  }\n   402\t\n   403\t  private def deleteRecursively(path: Path): Unit = {\n   404\t    if (Files.exists(path)) {\n   405\t      val stream = Files.walk(path)\n   406\t      try stream.iterator().asScala.toSeq.reverse.foreach(Files.deleteIfExists)\n   407\t      finally stream.close()\n   408\t    }\n   409\t  }\n   410\t\n   411\t  private final class RecordingGitOps(\n   412\t      rootOption: Option[AbsoluteFile],\n   413\t      statusResult: Seq[AbsoluteFile] = Seq.empty,\n   414\t      diffResult: Seq[AbsoluteFile] = Seq.empty,\n   415\t      lsTreeResult: Seq[AbsoluteFile] = Seq.empty\n   416\t  ) extends GitOps {\n   417\t    var lastStatusDirs: Seq[AbsoluteFile] = Seq.empty\n   418\t    var lastDiffBranch: String = \"\"\n   419\t    var lastDiffDirs: Seq[AbsoluteFile] = Seq.empty\n   420\t    var lastLsTreeDirs: Seq[AbsoluteFile] = Seq.empty\n   421\t\n   422\t    override def status(dir: AbsoluteFile*): Seq[AbsoluteFile] = {\n   423\t      lastStatusDirs = dir\n   424\t      statusResult\n   425\t    }\n   426\t\n   427\t    override def diff(branch: String, dir: AbsoluteFile*): Seq[AbsoluteFile] = {\n   428\t      lastDiffBranch = branch\n   429\t      lastDiffDirs = dir\n   430\t      diffResult\n   431\t    }\n   432\t\n   433\t    override def lsTree(dir: AbsoluteFile*): Seq[AbsoluteFile] = {\n   434\t      lastLsTreeDirs = dir\n   435\t      lsTreeResult\n   436\t    }\n   437\t\n   438\t    override def rootDir: Option[AbsoluteFile] = rootOption\n   439\t\n   440\t    override def getAutoCRLF: Option[String] = Some(\"false\")\n   441\t  }\n   442\t}\n","exit_code":0,"status":"completed"}}
