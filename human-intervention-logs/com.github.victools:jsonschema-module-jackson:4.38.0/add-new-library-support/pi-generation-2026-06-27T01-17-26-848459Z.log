       7	package com_github_victools.jsonschema_module_jackson;
       8	
       9	import com.fasterxml.jackson.annotation.JsonProperty;
      10	import com.fasterxml.jackson.annotation.JsonValue;
      11	import com.fasterxml.jackson.databind.JsonNode;
      12	import com.github.victools.jsonschema.generator.OptionPreset;
      13	import com.github.victools.jsonschema.generator.SchemaGenerator;
      14	import com.github.victools.jsonschema.generator.SchemaGeneratorConfig;
      15	import com.github.victools.jsonschema.generator.SchemaGeneratorConfigBuilder;
      16	import com.github.victools.jsonschema.generator.SchemaVersion;
      17	import com.github.victools.jsonschema.module.jackson.JacksonModule;
      18	import com.github.victools.jsonschema.module.jackson.JacksonOption;
      19	import java.util.ArrayList;
      20	import java.util.List;
      21	import org.junit.jupiter.api.Test;
      22	
      23	import static org.assertj.core.api.Assertions.assertThat;
      24	
      25	public class CustomEnumDefinitionProviderTest {
      26	
      27	    @Test
      28	    void jsonValueAnnotatedEnumMethodDefinesFlattenedEnumValues() {
      29	        JsonNode schema = generateSchema(JsonValueStatus.class, JacksonOption.FLATTENED_ENUMS_FROM_JSONVALUE);
      30	
      31	        assertThat(schema.path("type").asText()).isEqualTo("string");
      32	        assertThat(enumValues(schema)).containsExactly("new-ticket", "closed-ticket");
      33	    }
      34	
      35	    @Test
      36	    void jsonPropertyAnnotatedEnumConstantsDefineFlattenedEnumValues() {
      37	        JsonNode schema = generateSchema(JsonPropertyStatus.class, JacksonOption.FLATTENED_ENUMS_FROM_JSONPROPERTY);
      38	
      39	        assertThat(schema.path("type").asText()).isEqualTo("string");
      40	        assertThat(enumValues(schema)).containsExactly("PENDING", "done-ticket");
      41	    }
      42	
      43	    private static JsonNode generateSchema(Class<?> targetType, JacksonOption option) {
      44	        SchemaGeneratorConfigBuilder configBuilder = new SchemaGeneratorConfigBuilder(SchemaVersion.DRAFT_2020_12,
      45	                OptionPreset.PLAIN_JSON);
      46	        configBuilder.with(new JacksonModule(option));
      47	        SchemaGeneratorConfig config = configBuilder.build();
      48	        SchemaGenerator generator = new SchemaGenerator(config);
      49	        return generator.generateSchema(targetType);
      50	    }
      51	
      52	    private static List<String> enumValues(JsonNode schema) {
      53	        List<String> values = new ArrayList<>();
      54	        for (JsonNode enumValue : schema.path("enum")) {
      55	            values.add(enumValue.asText());
      56	        }
      57	        return values;
      58	    }
      59	
      60	    public enum JsonValueStatus {
      61	        NEW("new-ticket"),
      62	        CLOSED("closed-ticket");
      63	
      64	        private final String serializedValue;
      65	
      66	        JsonValueStatus(String serializedValue) {
      67	            this.serializedValue = serializedValue;
      68	        }
      69	
      70	        @JsonValue
      71	        public String getSerializedValue() {
      72	            return this.serializedValue;
      73	        }
      74	    }
      75	
      76	    public enum JsonPropertyStatus {
      77	        @JsonProperty
      78	        PENDING,
      79	        @JsonProperty("done-ticket")
      80	        DONE
      81	    }
      82	}
