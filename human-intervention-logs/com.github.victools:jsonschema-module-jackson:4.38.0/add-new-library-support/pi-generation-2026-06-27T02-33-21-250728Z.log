turn new SchemaGenerator(configBuilder.build()).generateSchema(schemaType);\n    }\n\n    @JsonNaming(PropertyNamingStrategies.SnakeCaseStrategy.class)\n    public static class SnakeCasePayload {\n        public String firstName;\n        public String postalCode;\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 3582, "output": 1267, "cacheRead": 15872, "cacheWrite": 0, "totalTokens": 20721, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1782527556743, "responseId": "resp_0be5d4e7d599cc2c016a3f364513bc81978677d92cca60c849"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_WlChSk9X0ZXQ4sqIPZG1vveJ|fc_0be5d4e7d599cc2c016a3f3654d7c481978f4749ba468300fb", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1887 bytes to tests/src/com.github.victools/jsonschema-module-jackson/4.38.0/src/test/java/com_github_victools/jsonschema_module_jackson/JacksonModuleTest.java"}], "isError": false, "timestamp": 1782527574644}]}
