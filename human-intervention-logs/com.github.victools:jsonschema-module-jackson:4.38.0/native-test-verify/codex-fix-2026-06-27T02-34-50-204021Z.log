ild()).generateSchema(schemaType);\n    }\n\n    @JsonNaming(PropertyNamingStrategies.SnakeCaseStrategy.class)\n    public static class SnakeCasePayload {\n        public String firstName;\n        public String postalCode;\n    }\n}\n","exit_code":0,"status":"completed"}}
