              </plugin>
              <plugin>
                  <artifactId>maven-source-plugin</artifactId>
              </plugin>
              <plugin>
                  <artifactId>maven-javadoc-plugin</artifactId>
              </plugin>
              <plugin>
                  <groupId>org.moditect</groupId>
                  <artifactId>moditect-maven-plugin</artifactId>
              </plugin>
          </plugins>
      </build>
  
  </project>
