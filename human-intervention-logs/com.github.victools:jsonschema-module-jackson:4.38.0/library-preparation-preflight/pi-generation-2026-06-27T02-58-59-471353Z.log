rtifactId>\n                <version>${version.classgraph}</version>\n            </dependency>\n        </dependencies>\n    </dependencyManagement>\n    <dependencies>\n        <!-- slf4j api is included to define trace/debug logging -->\n        <dependency>\n            <groupId>org.slf4j</groupId>\n            <artifactId>slf4j-api</artifactId>\n            <version>${version.slf4j}</version>\n        </dependency>\n        <!-- slf4j implementation is optional and left up to the library users to determine whether it is desired -->\n        <dependency>\n            <groupId>ch.qos.logback</groupId>\n            <artifactId>logback-classic</artifactId>\n            <version>${version.logback}</version>\n            <scope>test</scope>\n        </dependency>\n        <dependency>\n            <groupId>org.junit.jupiter</groupId>\n            <artifactId>junit-jupiter-engine</artifactId>\n            <version>${version.junit}</version>\n            <scope>test</scope>\n        </dependency>\n        <dependency>\n            <groupId>org.junit.jupiter</groupId>\n            <artifactId>junit-jupiter-params</artifactId>\n            <version>${version.junit}</version>\n            <scope>test</scope>\n        </dependency>\n        <dependency>\n            <groupId>org.mockito</groupId>\n            <artifactId>mockito-core</artifactId>\n            <version>${version.mockito}</version>\n            <scope>test</scope>\n        </dependency>\n        <dependency>\n            <groupId>org.skyscreamer</groupId>\n            <artifactId>jsonassert</artifactId>\n            <version>${version.jsonassert}</version>\n            <scope>test</scope>\n        </dependency>\n        <dependency>\n            <groupId>com.networknt</groupId>\n            <artifactId>json-schema-validator</artifactId>\n            <version>${version.validator}</version>\n            <scope>test</scope>\n            <exclusions>\n                <exclusion>\n                    <groupId>com