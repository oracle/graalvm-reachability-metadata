[tool-call] delta {"path":"tests/src/org.bouncycastle/bcutil-jdk15to18/1.77/src/test/java/org_bouncycastle/bcutil_jdk15to18/ItsUtilsAnonymous1Test.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcutil_jdk15to18;\n\nimport java.math.BigInteger;\nimport java.util.List;\n\nimport org.bouncycastle.asn1.ASN1Enumerated;\nimport org.bouncycastle.asn1.ASN1Sequence;\nimport org.bouncycastle.oer.its.ItsUtils;\nimport org.bouncycastle.oer.its.etsi102941.AuthorizationResponseCode;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ItsUtilsAnonymous1Test {\n    @Test\n    @SuppressWarnings(\"deprecation\")\n    public void fillListUsesTargetTypeGetInstanceForEachSequenceItem() {\n        ASN1Sequence sequence = ItsUtils.toSequence(\n                new ASN1Enumerated(BigInteger.ZERO),\n                new ASN1Enumerated(BigInteger.valueOf(26L)));\n\n        List<AuthorizationResponseCode> decodedValues = ItsUtils.fillList(AuthorizationResponseCode.class, sequence);\n\n        assertThat(decodedValues)\n                .hasSize(2)\n                .extracting(AuthorizationResponseCode::getValue)\n                .containsExactly(BigInteger.ZERO, BigInteger.valueOf(26L));\n        assertThat(decodedValues)\n                .allSatisfy(value -> assertThat(value).isInstanceOf(AuthorizationResponseCode.class));\n    }\n}\n"}
