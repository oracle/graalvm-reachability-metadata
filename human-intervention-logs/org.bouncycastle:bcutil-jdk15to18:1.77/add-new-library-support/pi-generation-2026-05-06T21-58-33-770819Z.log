[tool-call] delta {"path":"tests/src/org.bouncycastle/bcutil-jdk15to18/1.77/src/test/java/org_bouncycastle/bcutil_jdk15to18/OpaqueAnonymous1Test.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcutil_jdk15to18;\n\nimport java.math.BigInteger;\n\nimport org.bouncycastle.asn1.ASN1Integer;\nimport org.bouncycastle.oer.Element;\nimport org.bouncycastle.oer.OERDefinition;\nimport org.bouncycastle.oer.OEREncoder;\nimport org.bouncycastle.oer.its.ieee1609dot2.Opaque;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class OpaqueAnonymous1Test {\n    @Test\n    public void getValueInvokesTargetTypeGetInstanceForParsedOpaqueContent() {\n        Element uint8Definition = OERDefinition.integer(0, 255).typeName(\"Uint8\").build();\n        ASN1Integer expectedValue = new ASN1Integer(BigInteger.valueOf(127L));\n        Opaque opaque = new Opaque(OEREncoder.toByteArray(expectedValue, uint8Definition));\n\n        ASN1Integer decodedValue = Opaque.getValue(ASN1Integer.class, uint8Definition, opaque);\n\n        assertThat(decodedValue.getValue()).isEqualTo(expectedValue.getValue());\n    }\n}\n"}
