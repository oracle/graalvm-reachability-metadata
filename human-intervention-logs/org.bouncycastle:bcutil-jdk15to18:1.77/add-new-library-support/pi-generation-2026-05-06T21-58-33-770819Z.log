  package org_bouncycastle.bcutil_jdk15to18;
  
  import java.math.BigInteger;
  import java.util.concurrent.atomic.AtomicInteger;
  
  import org.bouncycastle.asn1.ASN1Encodable;
  import org.bouncycastle.asn1.ASN1Integer;
  import org.bouncycastle.oer.Element;
  import org.bouncycastle.oer.OERDefinition;
  import org.bouncycastle.oer.OEREncoder;
  import org.bouncycastle.oer.its.ieee1609dot2.Opaque;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class OpaqueAnonymous1Test {
      @Test
      public void getValueInvokesTargetTypeGetInstanceForParsedOpaqueContent() {
          ParsedOpaqueValue.reset();
          Element uint8Definition = OERDefinition.integer(0, 255).typeName("Uint8").build();
          ASN1Integer expectedValue = new ASN1Integer(BigInteger.valueOf(127L));
          Opaque opaque = new Opaque(OEREncoder.toByteArray(expectedValue, uint8Definition));
  
          ParsedOpaqueValue decodedValue = Opaque.getValue(ParsedOpaqueValue.class, uint8Definition, opaque);
  
          assertThat(ParsedOpaqueValue.invocationCount()).isEqualTo(1);
          assertThat(ASN1Integer.getInstance(decodedValue.sourceValue()).getValue()).isEqualTo(expectedValue.getValue());
      }
  
      public static final class ParsedOpaqueValue {
          private static final AtomicInteger INVOCATION_COUNT = new AtomicInteger();
  
          private final ASN1Encodable sourceValue;
  
          private ParsedOpaqueValue(ASN1Encodable sourceValue) {
              this.sourceValue = sourceValue;
          }
  
          public static ParsedOpaqueValue getInstance(Object sourceValue) {
              INVOCATION_COUNT.incrementAndGet();
              return new ParsedOpaqueValue((ASN1Encodable) sourceValue);
          }
  
          static void reset() {
              INVOCATION_COUNT.set(0);
          }
  
          static int invocationCount() {
              return INVOCATION_COUNT.get();
          }
  
          ASN1Encodable sourceValue() {
              return sourceValue;
          }
      }
  }
