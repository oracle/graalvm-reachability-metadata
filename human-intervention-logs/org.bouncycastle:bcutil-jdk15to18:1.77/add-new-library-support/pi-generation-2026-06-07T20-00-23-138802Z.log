.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ItsUtilsAnonymous1Test {\n    private final BigInteger value;\n\n    public ItsUtilsAnonymous1Test() {\n        this.value = null;\n    }\n\n    private ItsUtilsAnonymous1Test(BigInteger value) {\n        this.value = value;\n    }\n\n    public static ItsUtilsAnonymous1Test getInstance(Object value) {\n        return new ItsUtilsAnonymous1Test(ASN1Integer.getInstance(value).getValue());\n    }\n\n    public BigInteger getValue() {\n        return value;\n    }\n\n    @Test\n    @SuppressWarnings(\"deprecation\")\n    public void fillListInvokesElementGetInstanceForEachSequenceValue() {\n        ASN1Sequence sequence = new DERSequence(new ASN1Encodable[] {\n            new ASN1Integer(1),\n            new ASN1Integer(2),\n            new ASN1Integer(255)\n        });\n        assertThat(getInstance(new ASN1Integer(0)).getValue()).isEqualTo(BigInteger.ZERO);\n\n        List<ItsUtilsAnonymous1Test> decodedValues = ItsUtils.fillList(ItsUtilsAnonymous1Test.class, sequence);\n\n        assertThat(decodedValues).hasSize(3);\n        assertThat(decodedValues)\n            .extracting(ItsUtilsAnonymous1Test::getValue)\n            .containsExactly(BigInteger.ONE, BigInteger.TWO, BigInteger.valueOf(255));\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 11470, "output": 2617, "cacheRead": 22528, "cacheWrite": 0, "totalTokens": 36615, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780862799442, "responseId": "resp_046dc510cb1c89d0016a25cf50ad808195b55ba301ad85174d"}}
