                  Map<String, String> properties,
                  String layer,
                  String appContext,
                  String description) {
              return "class-registration";
          }
  
          @Override
          public String registerConfigProvider(
                  AuthConfigProvider provider,
                  String layer,
                  String appContext,
                  String description) {
  
