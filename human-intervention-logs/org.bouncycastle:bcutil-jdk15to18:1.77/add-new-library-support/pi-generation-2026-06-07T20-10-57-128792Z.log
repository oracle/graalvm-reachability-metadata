  package org_bouncycastle.bcutil_jdk15to18;
  
  import java.math.BigInteger;
  
  import org.bouncycastle.asn1.ASN1Integer;
  import org.bouncycastle.oer.Element;
  import org.bouncycastle.oer.OERDefinition;
  import org.bouncycastle.oer.OEREncoder;
  import org.bouncycastle.oer.its.ieee1609dot2.Opaque;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class OpaqueAnonymous1Test {
      private final ASN1Integer value;
  
      public OpaqueAnonymous1Test() {
          this.value = null;
      }
  
      private OpaqueAnonymous1Test(ASN1Integer value) {
          this.value = value;
      }
  
      public static OpaqueAnonymous1Test getInstance(Object src) {
          return new OpaqueAnonymous1Test(ASN1Integer.getInstance(src));
      }
  
      @Test
      public void getValueParsesOpaqueContentAndInvokesTargetGetInstance() {
          BigInteger expectedValue = BigInteger.valueOf(200);
          Element uint8Definition = OERDefinition.integer(0, 255).build();
          byte[] encodedContent = OEREncoder.toByteArray(new ASN1Integer(expectedValue), uint8Definition);
          Opaque opaque = new Opaque(encodedContent);
  
          OpaqueAnonymous1Test decodedValue = Opaque.getValue(OpaqueAnonymous1Test.class, uint8Definition, opaque);
  
          assertThat(decodedValue).isNotNull();
          assertThat(decodedValue.value).isNotNull();
          assertThat(decodedValue.value.getValue()).isEqualTo(expectedValue);
      }
  }
