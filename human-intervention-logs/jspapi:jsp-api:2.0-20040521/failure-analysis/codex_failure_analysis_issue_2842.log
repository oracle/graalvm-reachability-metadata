ategies.json:462:      \\\\\\\"dynamic-access-iteration\\\\\\\": \\\\\\\"prompt_templates/dynamic_access/dynamic-access-iteration.md\\\\\\\"\\\\nforge/strategies/predefined_strategies.json:512:    \\\\\\\"description\\\\\\\": \\\\\\\"Pi bulk dynamic-access strategy. Unlike the regular dynamic-access strategy, which iterates through uncovered classes and refines coverage class by class, this strategy gives the agent the full dynamic-access report in one prompt and asks it to cover the missing accesses in a single broad pass.\\\\\\\",\\\\nforge/strategies/predefined_strategies.json:517:      \\\\\\\"optimistic-dynamic-access-iteration\\\\\\\": \\\\\\\"prompt_templates/dynamic_access/optimistic-dynamic-access-iteration.md\\\\\\\"\\\\nforge/strategies/predefined_strategies.json:530:    \\\\\\\"description\\\\\\\": \\\\\\\"Codex bulk dynamic-access strategy. Unlike the regular dynamic-access strategy, which iterates through uncovered classes and refines coverage class by class, this strategy gives the agent the full dynamic-access report in one prompt and asks it to cover the missing accesses in a single broad pass.\\\\\\\",\\\\nforge/strategies/predefined_strategies.json:535:      \\\\\\\"optimistic-dynamic-access-iteration\\\\\\\": \\\\\\\"prompt_templates/dynamic_access/optimistic-dynamic-access-iteration.md\\\\\\\"\\\\nforge/strategies/predefined_strategies.json:548:    \\\\\\\"description\\\\\\\": \\\\\\\"Pi graphify-assisted bulk dynamic-access strategy. It first builds graphify context from downloaded source artifacts, then gives the agent the full dynamic-access report in one broad pass. Unlike the regular dynamic-access strategy, it does not run the class-by-class refinement loop.\\\\\\\",\\\\nforge/strategies/predefined_strategies.json:553:      \\\\\\\"optimistic-dynamic-access-iteration\\\\\\\": \\\\\\\"prompt_templates/dynamic_access/optimistic-dynamic-access-iteration.md\\\\\\\"\\\\nforge/strategies/predefined_strategies.json:567:    \\\\\\\"description\\\\\\\": \\\\\\\"Codex graphify-assisted bulk dynamic-access strategy. It first builds graphify context from downloaded source artifacts, then gives the agent the full dynamic-access report in one broad pass. Unlike the regular dynamic-access strategy, it does not run the class-by-class refinement loop.\\\\\\\",\\\\nforge/strategies/predefined_strategies.json:572:      \\\\\\\"optimistic-dynamic-access-iteration\\\\\\\": \\\\\\\"prompt_templates/dynamic_access/optimistic-dynamic-access-iteration.md\\\\\\\"\\\\nforge/strategies/predefined_strategies.json:592:      \\\\\\\"optimistic-dynamic-access-iteration\\\\\\\": \\\\\\\"prompt_templates/dynamic_access/optimistic-dynamic-access-iteration.md\\\\\\\",\\\\nforge/strategies/predefined_strategies.json:593:      \\\\\\\"dynamic-access-iteration\\\\\\\": \\\\\\\"prompt_templates/dynamic_access/dynamic-access-iteration.md\\\\\\\"\\\\nforge/strategies/predefined_strategies.json:614:      \\\\\\\"optimistic-dynamic-access-iteration\\\\\\\": \\\\\\\"prompt_templates/dynamic_access/optimistic-dynamic-access-iteration.md\\\\\\\",\\\\nforge/strategies/predefined_strategies.json:615:      \\\\\\\"dynamic-access-iteration\\\\\\\": \\\\\\\"prompt_templates/dynamic_access/dynamic-access-iteration.md\\\\\\\"\\\\nforge/strategies/predefined_strategies.json:636:      \\\\\\\"optimistic-dynamic-access-iteration\\\\\\\": \\\\\\\"prompt_templates/dynamic_access/optimistic-dynamic-access-iteration.md\\\\\\\",\\\\nforge/strategies/predefined_strategies.json:637:      \\\\\\\"dynamic-access-iteration\\\\\\\": \\\\\\\"prompt_templates/dynamic_access/dynamic-access-iteration.md\\\\\\\"\\\\nforge/strategies/predefined_strategies.json:658:      \\\\\\\"optimistic-dynamic-access-iteration\\\\\\\": \\\\\\\"prompt_templates/dynamic_access/optimistic-dynamic-access-iteration.md\\\\\\\",\\\\nforge/strategies/predefined_strategies.json:659:      \\\\\\\"dynamic-access-iteration\\\\\\\": \\\\\\\"prompt_templates/dynamic_access/dynamic-access-iteration.md