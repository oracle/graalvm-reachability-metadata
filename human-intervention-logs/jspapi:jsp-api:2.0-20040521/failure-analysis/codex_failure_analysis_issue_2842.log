er.class);\n\n        assertThat(ancestor).isSameAs(adaptee);\n    }\n\n    @Test\n    void returnsNullWhenNoMatchingAncestorExists() {\n        SimpleTagSupport tag = new SimpleTagSupport();\n\n        Object ancestor = SimpleTagSupport.findAncestorWithClass(tag, SimpleTagSupport.class);\n\n        assertThat(ancestor).isNull();\n    }\n\n    @Test\n    void returnsNullForTargetThatIsNotJspTagOrInterface() {\n        SimpleTagSupport tag = new SimpleTagSupport();\n\n        Object ancestor = SimpleTagSupport.findAncestorWithClass(tag, String.class);\n\n        assertThat(ancestor).isNull();\n    }\n\n    interface Marker {\n    }\n\n    static final class MarkedSimpleTag extends SimpleTagSupport implements Marker {\n    }\n}\n","exit_code":0,"status":"completed"}}
