TagSupport.findAncestorWithClass(child, TagSupport.class);\n\n        assertThat(ancestor).isSameAs(parent);\n        assertThat(TagSupport.findAncestorWithClass(parent, TagSupport.class)).isSameAs(grandparent);\n    }\n\n    @Test\n    @Order(3)\n    void findsAncestorUsingInterfaceTarget() {\n        MarkedTag grandparent = new MarkedTag();\n        TagSupport parent = new TagSupport();\n        TagSupport child = new TagSupport();\n        parent.setParent(grandparent);\n        child.setParent(parent);\n\n        Tag ancestor = TagSupport.findAncestorWithClass(child, Marker.class);\n\n        assertThat(ancestor).isSameAs(grandparent);\n    }\n\n    @Test\n    @Order(4)\n    void skipsNonMatchingClassicTagsBeforeFindingAncestor() {\n        MarkedTag grandparent = new MarkedTag();\n        TagSupport parent = new TagSupport();\n        TagSupport child = new TagSupport();\n        parent.setParent(grandparent);\n        child.setParent(parent);\n\n        Tag ancestor = TagSupport.findAncestorWithClass(child, MarkedTag.class);\n\n        assertThat(ancestor).isSameAs(grandparent);\n    }\n\n    @Test\n    @Order(5)\n    void returnsNullWhenAncestorCannotMatchTargetClass() {\n        TagSupport tag = new TagSupport();\n        tag.setParent(new TagSupport());\n\n        Tag ancestor = TagSupport.findAncestorWithClass(tag, String.class);\n\n        assertThat(ancestor).isNull();\n    }\n\n    @Test\n    @Order(6)\n    void managesTagStateAndLifecycleThroughPublicMethods() throws Exception {\n        TagSupport parent = new TagSupport();\n        TagSupport tag = new TagSupport();\n        tag.setParent(parent);\n        tag.setId(\"current\");\n        tag.setValue(\"alpha\", \"one\");\n        tag.setValue(\"beta\", 2);\n\n        assertThat(tag.getParent()).isSameAs(parent);\n        assertThat(tag.getId()).isEqualTo(\"current\");\n        assertThat(tag.getValue(\"alpha\")).isEqualTo(\"one\");\n        assertThat(tag.getValue(\"beta\")).isEqualTo(2);\n        assertThat(Collections.list(tag.getValues())).containsExactlyInAnyOrder(\"alpha\", \"beta\");\n        assertThat(tag.doStartTag()).isEqualTo(Tag.SKIP_BODY);\n        assertThat(tag.doAfterBody()).isEqualTo(Tag.SKIP_BODY);\n        assertThat(tag.doEndTag()).isEqualTo(Tag.EVAL_PAGE);\n\n        tag.removeValue(\"alpha\");\n        assertThat(tag.getValue(\"alpha\")).isNull();\n        assertThat(Collections.list(tag.getValues())).containsExactly(\"beta\");\n\n        tag.release();\n        assertThat(tag.getParent()).isNull();\n        assertThat(tag.getId()).isNull();\n        assertThat(tag.getValues()).isNull();\n    }\n\n    interface Marker {\n    }\n\n    static final class MarkedTag extends TagSupport implements Marker {\n    }\n}\n","exit_code":0,"status":"completed"}}
