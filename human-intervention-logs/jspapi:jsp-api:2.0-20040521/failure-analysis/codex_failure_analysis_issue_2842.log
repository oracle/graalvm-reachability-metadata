ass(\\\"javax.servlet.jsp.tagext.Tag\\\");\\n                Constructor<?> constructor = tagSupportClass.getConstructor();\\n                Object parent = constructor.newInstance();\\n                Object child = constructor.newInstance();\\n                Method setParent = tagSupportClass.getMethod(\\\"setParent\\\", tagClass);\\n                Method findAncestorWithClass = tagSupportClass.getMethod(\\n                        \\\"findAncestorWithClass\\\",\\n                        tagClass,\\n                        Class.class);\\n\\n                setParent.invoke(child, parent);\\n                Object ancestor = findAncestorWithClass.invoke(null, child, tagClass);\\n\\n                assertThat(ancestor).isSameAs(parent);\\n            }\\n        } catch (Error error) {\\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\\n                throw error;\\n            }\\n        }\\n    }\\n\\n    @Test\\n    void managesTagStateAndScopedValues() {\\n\",\"newText\":\"        Tag invalidAncestorType = TagSupport.findAncestorWithClass(child, Object.class);\\n        Tag nearestTagAncestor = TagSupport.findAncestorWithClass(child, Tag.class);\\n        Tag nearestConcreteAncestor = TagSupport.findAncestorWithClass(child, parent.getClass());\\n        Tag missingAncestor = TagSupport.findAncestorWithClass(child, BodyTag.class);\\n\\n        assertThat(invalidAncestorType).isNull();\\n        assertThat(nearestTagAncestor).isSameAs(parent);\\n        assertThat(nearestConcreteAncestor).isSameAs(parent);\\n        assertThat(missingAncestor).isNull();\\n    }\\n\\n    @Test\\n    void managesTagStateAndScopedValues() {\\n\"},{\"oldText\":\"\\n    private static final class ChildFirstJspClassLoader extends URLClassLoader {\\n        private ChildFirstJspClassLoader(URL libraryUrl) {\\n            super(new URL[] {libraryUrl}, TagSupportTest.class.getClassLoader());\\n        }\\n\\n        @Override\\n        protected synchronized Cl