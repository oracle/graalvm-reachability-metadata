  package jspapi.jsp_api;
  
  import javax.servlet.jsp.tagext.SimpleTagSupport;
  import javax.servlet.jsp.tagext.TagAdapter;
  
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class SimpleTagSupportTest {
  
      @Test
      void findsAncestorUsingPublicSimpleTagParentChain() {
          SimpleTagSupport grandparent = new SimpleTagSupport();
          SimpleTagSupport parent = new SimpleTagSupport();
          SimpleTagSupport child = new SimpleTagSupport();
          parent.setParent(grandparent);
          child.setParent(parent);
  
          Object ancestor = SimpleTagSupport.findAncestorWithClass(child, SimpleTagSupport.class);
  
          assertThat(ancestor).isSameAs(parent);
          assertThat(SimpleTagSupport.findAncestorWithClass(parent, SimpleTagSupport.class)).isSameAs(grandparent);
      }
  
      @Test
      void findsAncestorUsingInterfaceTarget() {
          MarkedSimpleTag parent = new MarkedSimpleTag();
          SimpleTagSupport child = new SimpleTagSupport();
          child.setParent(parent);
  
          Object ancestor = SimpleTagSupport.findAncestorWithClass(child, Marker.class);
  
          assertThat(ancestor).isSameAs(parent);
      }
  
      @Test
      void findsAncestorAdaptedFromClassicTagParent() {
          MarkedSimpleTag adaptee = new MarkedSimpleTag();
          SimpleTagSupport child = new SimpleTagSupport();
          child.setParent(new TagAdapter(adaptee));
  
          Object ancestor = SimpleTagSupport.findAncestorWithClass(child, Marker.class);
  
          assertThat(ancestor).isSameAs(adaptee);
      }
  
      @Test
      void returnsNullWhenNoMatchingAncestorExists() {
          SimpleTagSupport tag = new SimpleTagSupport();
  
          Object ancestor = SimpleTagSupport.findAncestorWithClass(tag, SimpleTagSupport.class);
  
          assertThat(ancestor).isNull();
      }
  
      @Test
      void returnsNullForTargetThatIsNotJspTagOrInterface() {
          SimpleTagSupport tag = new SimpleTagSupport();
  
          Object ancestor = SimpleTagSupport.findAncestorWithClass(tag, String.class);
  
          assertThat(ancestor).isNull();
      }
  
      interface Marker {
      }
  
      static final class MarkedSimpleTag extends SimpleTagSupport implements Marker {
      }
  }
