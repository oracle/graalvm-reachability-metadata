t.findAncestorWithClass(child, UnrelatedTag.class);\n\n        assertThat(ancestor).isNull();\n    }\n\n    @Test\n    void findAncestorWithClassComparesAdapteeForTagAdapterParents() {\n        SimpleTagSupport adaptedParent = new SimpleTagSupport();\n        TagAdapter parentAdapter = new TagAdapter(adaptedParent);\n        SimpleTagSupport child = new SimpleTagSupport();\n\n        child.setParent(parentAdapter);\n\n        JspTag ancestor = SimpleTagSupport.findAncestorWithClass(child, SimpleTagSupport.class);\n\n        assertThat(ancestor).isSameAs(adaptedParent);\n    }\n\n    private static final class UnrelatedTag implements JspTag {\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1202, "output": 1034, "cacheRead": 14848, "cacheWrite": 0, "totalTokens": 17084, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777977815015, "responseId": "resp_097f3f43eadebb780169f9c9d75dd881909f0dbb7f679f8c8b"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_rUcEb8oiM9nu3Skdl8bQeCRv|fc_097f3f43eadebb780169f9c9de75288190be518f20e213b509", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1878 bytes to tests/src/jspapi/jsp-api/2.0-20040521/src/test/java/jspapi/jsp_api/SimpleTagSupportTest.java"}], "isError": false, "timestamp": 1777977825657}]}
