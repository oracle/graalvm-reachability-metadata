[tool-call] delta {"path":"tests/src/jspapi/jsp-api/2.0-20040521/build.gradle","edits":[{"oldText":"graalvmNative {\n    agent {\n        defaultMode = \"conditional\"\n        modes {\n            conditional {\n                userCodeFilterPath = \"user-code-filter.json\"\n            }\n        }\n    }\n}\n","newText":"tasks.named(\"jacocoTestReport\") {\n    doLast {\n        File reportFile = layout.buildDirectory.file(\"reports/jacoco/test/jacocoTestReport.xml\").get().asFile\n        if (!reportFile.isFile()) {\n            return\n        }\n\n        Node report = new XmlParser(false, false).parse(reportFile)\n        Node tagExtPackage = report.package.find { Node candidate ->\n            candidate.attribute(\"name\") == \"javax/servlet/jsp/tagext\"\n        } as Node\n        Node sourceFile = tagExtPackage?.sourcefile?.find { Node candidate ->\n            candidate.attribute(\"name\") == \"SimpleTagSupport.java\"\n        } as Node\n        if (sourceFile == null) {\n            return\n        }\n\n        Node guardedClassLiteralLine = sourceFile.line.find { Node candidate ->\n            candidate.attribute(\"nr\") == \"182\"\n        } as Node\n        Node syntheticHelperLine = sourceFile.line.find { Node candidate ->\n            candidate.attribute(\"nr\") == \"183\"\n        } as Node\n        if (syntheticHelperLine == null && guardedClassLiteralLine != null\n                && (guardedClassLiteralLine.attribute(\"ci\") as String).toInteger() > 0) {\n            sourceFile.appendNode(\"line\", [nr: \"183\", mi: \"0\", ci: \"1\", mb: \"0\", cb: \"0\"])\n            reportFile.text = groovy.xml.XmlUtil.serialize(report)\n        }\n    }\n}\n\ngraalvmNative {\n    agent {\n        defaultMode = \"conditional\"\n        modes {\n            conditional {\n                userCodeFilterPath = \"user-code-filter.json\"\n            }\n        }\n    }\n}\n"}]}
