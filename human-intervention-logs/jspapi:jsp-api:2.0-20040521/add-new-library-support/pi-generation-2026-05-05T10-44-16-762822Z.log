          }
  
          return new LibraryStatsModels.VersionStats(
                  versionStats.version(),
                  normalizeDynamicAccessStatsValue(versionStats.dynamicAccess()),
                  normalizeLibraryCoverage(versionStats.libraryCoverage())
          );
      }
  
