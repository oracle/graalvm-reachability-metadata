impleTagSupport.findAncestorWithClass(child, SimpleTagSupport.class);\n\n        assertThat(ancestor).isSameAs(parent);\n        assertThat(SimpleTagSupport.findAncestorWithClass(parent, SimpleTagSupport.class)).isSameAs(grandparent);\n    }\n\n    @Test\n    void returnsNullWhenNoMatchingAncestorExists() {\n        SimpleTagSupport tag = new SimpleTagSupport();\n\n        JspTag ancestor = SimpleTagSupport.findAncestorWithClass(tag, SimpleTagSupport.class);\n\n        assertThat(ancestor).isNull();\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 552, "output": 792, "cacheRead": 12288, "cacheWrite": 0, "totalTokens": 13632, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777418680580, "responseId": "resp_0f0e05c6db090b1a0169f141b8f0f481928070ef3f9c29e441"}}
