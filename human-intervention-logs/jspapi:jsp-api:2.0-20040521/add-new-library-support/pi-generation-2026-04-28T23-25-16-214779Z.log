leTagSupport.findAncestorWithClass(child, SimpleTagSupport.class);\n\n        assertThat(ancestor).isSameAs(parent);\n        assertThat(SimpleTagSupport.findAncestorWithClass(parent, SimpleTagSupport.class)).isSameAs(grandparent);\n    }\n\n    @Test\n    void returnsNullWhenNoMatchingAncestorExists() {\n        SimpleTagSupport tag = new SimpleTagSupport();\n\n        JspTag ancestor = SimpleTagSupport.findAncestorWithClass(tag, SimpleTagSupport.class);\n\n        assertThat(ancestor).isNull();\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 552, "output": 792, "cacheRead": 12288, "cacheWrite": 0, "totalTokens": 13632, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777418680580, "responseId": "resp_0f0e05c6db090b1a0169f141b8f0f481928070ef3f9c29e441"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_URzF3CU8egs7Uxa0lHVyjItn|fc_0f0e05c6db090b1a0169f141c1d9c88192ab97e4d8b1fb90ea", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1298 bytes to tests/src/jspapi/jsp-api/2.0-20040521/src/test/java/jspapi/jsp_api/SimpleTagSupportTest.java"}], "isError": false, "timestamp": 1777418691086}]}
