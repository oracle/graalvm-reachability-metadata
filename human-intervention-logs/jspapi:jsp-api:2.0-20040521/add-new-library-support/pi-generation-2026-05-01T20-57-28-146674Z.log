[tool-call] delta {"path":"tests/src/jspapi/jsp-api/2.0-20040521/src/test/java/jspapi/jsp_api/SimpleTagSupportTest.java","edits":[{"oldText":"import org.junit.jupiter.api.Test;\n\npublic class SimpleTagSupportTest {\n    @Test\n    public void findAncestorWithClassChecksJspTagTypeBeforeWalkingParents() {\n        JspTag ancestor = SimpleTagSupport.findAncestorWithClass(new SimpleTagSupport(), Object.class);\n\n        assertThat(ancestor).isNull();\n    }\n","newText":"import org.junit.jupiter.api.BeforeAll;\nimport org.junit.jupiter.api.Test;\n\npublic class SimpleTagSupportTest {\n    @BeforeAll\n    public static void exerciseLegacyJspTagClassLookup() {\n        JspTag ancestor = SimpleTagSupport.findAncestorWithClass(new SimpleTagSupport(), Object.class);\n\n        assertThat(ancestor).isNull();\n    }\n\n    @Test\n    public void testFindAncestorWithClassChecksJspTagTypeBeforeWalkingParents() {\n        JspTag ancestor = SimpleTagSupport.findAncestorWithClass(new SimpleTagSupport(), Object.class);\n\n        assertThat(ancestor).isNull();\n    }\n"}]}
