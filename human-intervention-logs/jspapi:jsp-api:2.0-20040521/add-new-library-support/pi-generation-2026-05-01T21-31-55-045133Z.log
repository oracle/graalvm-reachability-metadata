edClassLoaderFindsAncestorWithTagInterfaceClass() throws Exception {\n        try {\n            URL libraryUrl = TagSupport.class.getProtectionDomain().getCodeSource().getLocation();\n\n            try (ChildFirstJspClassLoader classLoader = new ChildFirstJspClassLoader(libraryUrl)) {\n                Class<?> tagSupportClass = classLoader.loadClass(\"javax.servlet.jsp.tagext.TagSupport\");\n                Class<?> tagClass = classLoader.loadClass(\"javax.servlet.jsp.tagext.Tag\");\n                Constructor<?> constructor = tagSupportClass.getConstructor();\n                Object parent = constructor.newInstance();\n                Object child = constructor.newInstance();\n                Method setParent = tagSupportClass.getMethod(\"setParent\", tagClass);\n                Method findAncestorWithClass = tagSupportClass.getMethod(\n                        \"findAncestorWithClass\",\n                        tagClass,\n                        Class.class);\n\n                setParent.invoke(child, parent);\n                Object ancestor = findAncestorWithClass.invoke(null, child, tagClass);\n\n                assertThat(ancestor).isSameAs(parent);\n            }\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    @Test\n    void managesTagStateAndScopedValues() {\n", "newText": "        Tag invalidAncestorType = TagSupport.findAncestorWithClass(child, Object.class);\n        Tag nearestTagAncestor = TagSupport.findAncestorWithClass(child, Tag.class);\n        Tag nearestConcreteAncestor = TagSupport.findAncestorWithClass(child, parent.getClass());\n        Tag missingAncestor = TagSupport.findAncestorWithClass(child, BodyTag.class);\n\n        assertThat(invalidAncestorType).isNull();\n        assertThat(nearestTagAncestor).isSameAs(parent);\n        assertThat(nearestConcreteAncestor).isSameAs(parent);\n        assertThat(missingAncestor).isNull();\n    }\n\n    @Test\n    void managesTagStateAndScopedValues() {\n"}, {"oldText": "\n    private static final class ChildFirstJspClassLoader extends URLClassLoader {\n        private ChildFirstJspClassLoader(URL libraryUrl) {\n            super(new URL[] {libraryUrl}, TagSupportTest.class.getClassLoader());\n        }\n\n        @Override\n        protected synchronized Class<?> loadClass(String name, boolean resolve)\n                throws ClassNotFoundException {\n            if (name.startsWith(\"javax.servlet.jsp.\")) {\n                Class<?> loadedClass = findLoadedClass(name);\n                if (loadedClass == null) {\n                    try {\n                        loadedClass = findClass(name);\n                    } catch (ClassNotFoundException ignored) {\n                        loadedClass = super.loadClass(name, false);\n                    }\n                }\n                if (resolve) {\n                    resolveClass(loadedClass);\n                }\n                return loadedClass;\n            }\n            return super.loadClass(name, resolve);\n        }\n    }\n", "newText": ""}]}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1402, "output": 1551, "cacheRead": 32256, "cacheWrite": 0, "totalTokens": 35209, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777671419399, "responseId": "resp_081c2300878dfc8c0169f51cfbfda48190a1e8ca9bdf3d585c"}}
