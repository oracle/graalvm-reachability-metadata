As(parent);\n        assertThat(missingAncestor).isNull();\n    }\n\n    @Test\n    void managesTagStateAndScopedValues() {\n        TagSupport tag = new TagSupport();\n        TagSupport parent = new TagSupport();\n        tag.setParent(parent);\n        tag.setId(\"summary\");\n        tag.setValue(\"first\", \"alpha\");\n        tag.setValue(\"second\", \"beta\");\n\n        assertThat(tag.getParent()).isSameAs(parent);\n        assertThat(tag.getId()).isEqualTo(\"summary\");\n        assertThat(tag.getValue(\"first\")).isEqualTo(\"alpha\");\n        assertThat(tag.getValues()).toIterable().containsExactlyInAnyOrder(\"first\", \"second\");\n\n        tag.removeValue(\"first\");\n        assertThat(tag.getValue(\"first\")).isNull();\n        assertThat(tag.getValues()).toIterable().containsExactly(\"second\");\n\n        tag.release();\n        assertThat(tag.getParent()).isNull();\n        assertThat(tag.getId()).isNull();\n        assertThat(tag.getValues()).isNull();\n    }\n\n    private interface BodylessTag extends Tag {\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 2463, "output": 809, "cacheRead": 8192, "cacheWrite": 0, "totalTokens": 11464, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777671075564, "responseId": "resp_081c2300878dfc8c0169f51ba3e4e88190941fd582aacea32e"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_McpIxz03JkmUOT7I6WQ6s67A|fc_081c2300878dfc8c0169f51ba8bd7881909c312aa339e7d680", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2088 bytes to tests/src/jspapi/jsp-api/2.0-20040521/src/test/java/jspapi/jsp_api/TagSupportTest.java"}], "isError": false, "timestamp": 1777671083603}]}
