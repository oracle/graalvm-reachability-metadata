ryUrl) {\n            super(new URL[] {libraryUrl}, TagSupportTest.class.getClassLoader());\n        }\n\n        @Override\n        protected synchronized Class<?> loadClass(String name, boolean resolve)\n                throws ClassNotFoundException {\n            if (name.startsWith(\"javax.servlet.jsp.\")) {\n                Class<?> loadedClass = findLoadedClass(name);\n                if (loadedClass == null) {\n                    try {\n                        loadedClass = findClass(name);\n                    } catch (ClassNotFoundException ignored) {\n                        loadedClass = super.loadClass(name, false);\n                    }\n                }\n                if (resolve) {\n                    resolveClass(loadedClass);\n                }\n                return loadedClass;\n            }\n            return super.loadClass(name, resolve);\n        }\n    }\n}\n"}]}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 896, "output": 1320, "cacheRead": 24576, "cacheWrite": 0, "totalTokens": 26792, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777671257028, "responseId": "resp_081c2300878dfc8c0169f51c59bbe88190857700f593c0ee93"}}
