tagext.Tag;\nimport javax.servlet.jsp.tagext.TagSupport;\n\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class TagSupportTest {\n    @Test\n    void findsAncestorOfRequestedTagSupportClass() {\n        TagSupport child = new TagSupport();\n        TagSupport parent = new TagSupport();\n        child.setParent(parent);\n\n        Tag ancestor = TagSupport.findAncestorWithClass(child, TagSupport.class);\n\n        assertThat(ancestor).isSameAs(parent);\n    }\n\n    @Test\n    void findsAncestorByTagInterface() {\n        TagSupport child = new TagSupport();\n        TagSupport parent = new TagSupport();\n        child.setParent(parent);\n\n        Tag ancestor = TagSupport.findAncestorWithClass(child, Tag.class);\n\n        assertThat(ancestor).isSameAs(parent);\n    }\n\n    @Test\n    void returnsNullWhenRequestedClassIsNotATagType() {\n        TagSupport child = new TagSupport();\n        child.setParent(new TagSupport());\n\n        Tag ancestor = TagSupport.findAncestorWithClass(child, Object.class);\n\n        assertThat(ancestor).isNull();\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 2403, "output": 873, "cacheRead": 17408, "cacheWrite": 0, "totalTokens": 20684, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777674139208, "responseId": "resp_0311e6f268442dbc0169f5279b8b6c819ea9ce09582e11aec8"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_JkDAMGhuTl2vQwen8LfzZA3Y|fc_0311e6f268442dbc0169f527a91734819eac6b678ad5b0a48e", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1347 bytes to tests/src/jspapi/jsp-api/2.0-20040521/src/test/java/jspapi/jsp_api/TagSupportTest.java"}], "isError": false, "timestamp": 1777674154240}]}
