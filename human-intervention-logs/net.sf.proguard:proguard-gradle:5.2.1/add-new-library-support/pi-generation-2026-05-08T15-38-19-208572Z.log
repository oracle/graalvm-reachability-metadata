[tool-call] delta {"path":"tests/src/net.sf.proguard/proguard-gradle/5.2.1/src/test/java/net_sf_proguard/proguard_gradle/Proguard_gradleTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage net_sf_proguard.proguard_gradle;\n\nimport org.gradle.api.DefaultTask;\nimport org.gradle.api.tasks.TaskInstantiationException;\nimport org.junit.jupiter.api.Test;\nimport proguard.gradle.ProGuardTask;\n\nimport static org.assertj.core.api.Assertions.assertThat;\nimport static org.assertj.core.api.Assertions.assertThatThrownBy;\n\npublic class Proguard_gradleTest {\n\n    @Test\n    void proGuardTaskIsAGradleTaskType() {\n        assertThat(DefaultTask.class).isAssignableFrom(ProGuardTask.class);\n    }\n\n    @Test\n    void directConstructionRequiresGradleTaskCreationInfrastructure() {\n        assertThatThrownBy(ProGuardTask::new)\n                .isInstanceOf(TaskInstantiationException.class)\n                .hasMessageContaining(ProGuardTask.class.getName())\n                .hasMessageContaining(\"Tasks can only be created using the DSL\");\n    }\n}\n"}
