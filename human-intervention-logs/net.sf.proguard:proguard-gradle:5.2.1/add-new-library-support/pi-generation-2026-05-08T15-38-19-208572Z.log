lCall", "id": "call_3XXodbIsUNYZFiipd1HPjjeB|fc_0b261ae36c6e8a600169fe02710cc4819687d454d97b678c45", "name": "write", "arguments": {"path": "tests/src/net.sf.proguard/proguard-gradle/5.2.1/src/test/java/net_sf_proguard/proguard_gradle/Proguard_gradleTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage net_sf_proguard.proguard_gradle;\n\nimport org.gradle.api.Project;\nimport org.gradle.testfixtures.ProjectBuilder;\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\nimport org.junit.jupiter.api.io.TempDir;\nimport proguard.ParseException;\nimport proguard.gradle.ProGuardTask;\n\nimport java.io.IOException;\nimport java.nio.file.Files;\nimport java.nio.file.Path;\nimport java.util.Base64;\nimport java.util.LinkedHashMap;\nimport java.util.Map;\nimport java.util.Set;\nimport java.util.TreeSet;\nimport java.util.jar.JarEntry;\nimport java.util.jar.JarFile;\nimport java.util.jar.JarOutputStream;\n\nimport static org.assertj.core.api.Assertions.assertThat;\nimport static org.assertj.core.api.Assertions.assertThatThrownBy;\n\npublic class Proguard_gradleTest {\n\n    private static final byte[] HELLO_CLASS_BYTES = Base64.getDecoder().decode(\"\"\"\n            yv66vgAAADQAEAEADWV4YW1wbGUvSGVsbG8HAAEBABBqYXZhL2xhbmcvT2JqZWN0BwADAQAGPGluaXQ+\n            AQADKClWAQAEQ29kZQwABQAGCgAEAAgBAAVncmVldAEAFCgpTGphdmEvbGFuZy9TdHJpbmc7AQAFaGVs\n            bG8IAAwBAApTb3VyY2VGaWxlAQAKSGVsbG8uamF2YQAhAAIABAAAAAAAAgABAAUABgABAAcAAAARAAEA\n            AQAAAAUqtwAJsQAAAAAAAQAKAAsAAQAHAAAADwABAAEAAAADEg2wAAAAAAABAA4AAAACAA8=\n            \"\"\".replaceAll(\"\\\\s\", \"\"));\n\n    @TempDir\n    Path tempDir;\n\n    @Test\n    void recordsProgramOutputLibraryAndConfigurationInputs() throws Exception {\n        runGradleBackedTaskTest(() -> {\n            final ProGuardTask task = createTask(tempDir);\n            final Path firstInput = tempDir.resolve(\"first-input.jar\");\n            final Path secondInput = tempDir.resolve(\"second-input.jar\");\n            final Path firstOutput = tempDir.resolve(\"first-output.jar\");\n            final Path secondOutput = tempDir.resolve(\"second-output.jar\");\n            final Path libraryJar = tempDir.resolve(\"library.jar\");\n            final Path configurationFile = tempDir.resolve(\"proguard.pro\");\n            final Map<String, String> programFilters = new LinkedHashMap<>();\n            programFilters.put(\"filter\", \"!META-INF/**,**.class\");\n            programFilters.put(\"jarfilter\", \"**.jar\");\n            final Map<String, String> libraryFilters = new LinkedHashMap<>();\n            libraryFilters.put(\"filter\", \"java/**\");\n\n            task.injars(firstInput.toFile());\n            task.injars(programFilters, secondInput.toFile());\n            task.outjars(firstOutput.toFile());\n            task.injars(\"later-input.jar\");\n            task.outjars(secondOutput.toFile());\n            task.libraryjars(libraryFilters, libraryJar.toFile());\n            task.configuration(configurationFile.toFile());\n\n            assertThat(task.getInJarFiles()).containsExactly(firstInput.toFile(), secondInput.toFile(), \"later-input.jar\");\n            assertThat(task.getInJarFilters()).containsExactly(null, programFilters, null);\n            assertThat(task.getOutJarFiles()).containsExactly(firstOutput.toFile(), secondOutput.toFile());\n            assertThat(task.getOutJarFilters()).containsExactly(null, null);\n            assertThat(task.getInJarCounts()).containsExactly(2, 3);\n            assertThat(task.getLibraryJarFiles()).containsExactly(libraryJar.toFile());\n            assertThat(task.getLibraryJarFilters()).containsExactly(libraryFilters);\n            assertThat(task.getConfigurationFiles()).containsExactly(configurationFile.toFile());\n        });\n    }\n\n    @Test\n    void executesProGuardForASmallProgramJarAndWritesConfiguration() throws Exception {\n        runGradleBackedTaskTest(() -> {\n            final ProGuardTask task = createTask(tempDir);\n            final Path inputJar = tempDir.resolve(\"input.jar\");\n            final Path outputJar = tempDir.resolve(\"output.jar\");\n            final Path configurationDump = tempDir.resolve(\"effective-proguard.pro\");\n            writeHelloJar(inputJar);\n\n            task.injars(inputJar.toFile());\n            task.outjars(outputJar.toFile());\n            task.dontshrink();\n            task.dontoptimize();\n            task.dontobfuscate();\n            task.dontpreverify();\n            task.dontwarn();\n            task.ignorewarnings();\n            task.keep(\"public class example.Hello { public *; }\");\n            task.printconfiguration(configurationDump.toFile());\n            task.proguard();\n\n            assertThat(outputJar).exists().isRegularFile();\n            assertThat(jarEntries(outputJar)).contains(\"example/Hello.class\");\n            assertThat(configurationDump).exists().isRegularFile();\n            assertThat(Files.readString(configurationDump))\n                    .contains(\"-injars\")\n                    .contains(\"-outjars\")\n                    .contains(\"-dontshrink\")\n                    .contains(\"-dontoptimize\")\n                    .contains(\"-dontobfuscate\")\n                    .contains(\"example.Hello\");\n        });\n    }\n\n    @Test\n    void parsesKeepRulesAndRejectsInvalidClassSpecifications() throws Exception {\n        runGradleBackedTaskTest(() -> {\n            final ProGuardTask task = createTask(tempDir);\n\n            task.keep(\"public class example.Hello { public java.lang.String greet(); }\");\n            task.keepnames(Map.of(\"allowshrinking\", true), \"class example.**\");\n            task.whyareyoukeeping(\"class example.Hello\");\n\n            assertThatThrownBy(() -> task.keep(\"public class\"))\n                    .isInstanceOf(ParseException.class);\n        });\n    }\n\n    @Test\n    void acceptsProcessingAndObfuscationOptionsThroughTaskApi() throws Exception {\n        runGradleBackedTaskTest(() -> {\n            final ProGuardTask task = createTask(tempDir);\n            final Path printSeeds = tempDir.resolve(\"seeds.txt\");\n            final Path printUsage = tempDir.resolve(\"usage.txt\");\n            final Path printMapping = tempDir.resolve(\"mapping.txt\");\n\n            assertThat(task.getskipnonpubliclibraryclasses()).isNull();\n            assertThat(task.getdontskipnonpubliclibraryclassmembers()).isNull();\n            assertThat(task.getforceprocessing()).isNull();\n            assertThat(task.getallowaccessmodification()).isNull();\n            assertThat(task.getmergeinterfacesaggressively()).isNull();\n            assertThat(task.getoverloadaggressively()).isNull();\n            assertThat(task.getuseuniqueclassmembernames()).isNull();\n            assertThat(task.getdontusemixedcaseclassnames()).isNull();\n            assertThat(task.getkeepparameternames()).isNull();\n            assertThat(task.getadaptclassstrings()).isNull();\n            assertThat(task.getadaptresourcefilenames()).isNull();\n            assertThat(task.getadaptresourcefilecontents()).isNull();\n            assertThat(task.getverbose()).isNull();\n            task.keepdirectories(\"resources/**\");\n            task.target(\"1.8\");\n            task.optimizations(\"!code/simplification/arithmetic\");\n            task.optimizationpasses(1);\n            task.printseeds(printSeeds.toFile());\n            task.printusage(printUsage.toFile());\n            task.printmapping(printMapping.toFile());\n            task.keeppackagenames(\"example.**\");\n            task.flattenpackagehierarchy(\"flattened\");\n            task.repackageclasses(\"repackaged\");\n            task.keepattributes(\"SourceFile,LineNumberTable\");\n            task.renamesourcefileattribute(\"SourceFile\");\n            task.adaptclassstrings(\"example.**\");\n            task.adaptresourcefilenames(\"**.properties\");\n            task.adaptresourcefilecontents(\"**.properties\");\n            task.dontnote(\"example.internal.**\");\n            task.dontwarn(\"example.missing.**\");\n\n            assertThat(task.getprintseeds()).isNull();\n            assertThat(task.getprintusage()).isNull();\n            assertThat(task.getprintmapping()).isNull();\n            assertThat(task.getkeeppackagenames()).isNull();\n            assertThat(task.getflattenpackagehierarchy()).isNull();\n            assertThat(task.getrepackageclasses()).isNull();\n            assertThat(task.getkeepattributes()).isNull();\n            assertThat(task.getrenamesourcefileattribute()).isNull();\n            assertThat(task.getdontnote()).isNull();\n            assertThat(task.getdontwarn()).isNull();\n        });\n    }\n\n    private static ProGuardTask createTask(Path projectDir) {\n        final Project project = ProjectBuilder.builder()\n                .withProjectDir(projectDir.toFile())\n                .build();\n        return project.getTasks().create(\"proguardUnderTest\", ProGuardTask.class);\n    }\n\n    private static void writeHelloJar(Path jar) throws IOException {\n        try (JarOutputStream output = new JarOutputStream(Files.newOutputStream(jar))) {\n            final JarEntry entry = new JarEntry(\"example/Hello.class\");\n            output.putNextEntry(entry);\n            output.write(HELLO_CLASS_BYTES);\n            output.closeEntry();\n        }\n    }\n\n    private static Set<String> jarEntries(Path jar) throws IOException {\n        final Set<String> entries = new TreeSet<>();\n        try (JarFile jarFile = new JarFile(jar.toFile())) {\n            jarFile.stream()\n                    .map(JarEntry::getName)\n                    .forEach(entries::add);\n        }\n        return entries;\n    }\n\n    private static void runGradleBackedTaskTest(CheckedRunnable runnable) throws Exception {\n        try {\n            runnable.run();\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    @FunctionalInterface\n    private interface CheckedRunnable {\n        void run() throws Exception;\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1237, "output": 3759, "cacheRead": 30720, "cacheWrite": 0, "totalTokens": 35716, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778254429218, "responseId": "resp_0b261ae36c6e8a600169fe025e5ce48196b8a93a6ff65e242d"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_3XXodbIsUNYZFiipd1HPjjeB|fc_0b261ae36c6e8a600169fe02710cc4819687d454d97b678c45", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 9799 bytes to tests/src/net.sf.proguard/proguard-gradle/5.2.1/src/test/java/net_sf_proguard/proguard_gradle/Proguard_gradleTest.java"}], "isError": false, "timestamp": 1778254465928}]}
