  +        assertThat(task.getOutJarFilters()).containsExactly((Object) null);
  +        assertThat(task.getInJarCounts()).containsExactly(1);
  +        assertThat(task.getLibraryJarFiles()).containsExactly(libraryJar);
  +        assertThat(task.getLibraryJarFilters()).containsExactly(libraryFilter);
  +        assertThat(task.getConfigurationFiles()).containsExactly(configurationFile);
  +    }
  +
  +    private static ProGuardTask createProGuardTask() {
  +        final Project project = ProjectBuilder.builder().withName("proguard-project").build();
  +
  +        return project.getTasks().create("minify", ProGuardTask.class);
  +    }
