  +        libraryFilter.put("filter", "!module-info.class");
  +
  +        task.injars(inputFilter, inputJar);
  +        task.outjars(outputJar);
  +        task.libraryjars(libraryFilter, libraryJar);
  +        task.configuration(configurationFile);
  +
  +        assertThat(task.getInJarFiles()).containsExactly(inputJar);
