plication\", ProGuardTask.class);\n                    final File firstInputJar = temporaryDirectory.resolve(\"application.jar\").toFile();\n                    final File secondInputJar = temporaryDirectory.resolve(\"support.jar\").toFile();\n                    final File outputJar = temporaryDirectory.resolve(\"application-minified.jar\").toFile();\n                    final File libraryJar = temporaryDirectory.resolve(\"runtime.jar\").toFile();\n                    final File configurationFile = temporaryDirectory.resolve(\"proguard.pro\").toFile();\n                    final Map<String, String> inputFilters = new LinkedHashMap<>();\n                    inputFilters.put(\"filter\", \"!META-INF/**\");\n                    inputFilters.put(\"jarfilter\", \"**.class\");\n                    final Map<String, String> outputFilters = new LinkedHashMap<>();\n                    outputFilters.put(\"filter\", \"**.class\");\n                    final Map<String, String> libraryFilters = new LinkedHashMap<>();\n                    libraryFilters.put(\"zipfilter\", \"**.class\");\n\n                    task.injars(firstInputJar);\n                    task.injars(inputFilters, secondInputJar);\n                    task.outjars(outputFilters, outputJar);\n                    task.libraryjars(libraryFilters, libraryJar);\n                    task.configuration(configurationFile);\n\n                    assertEquals(Arrays.asList(firstInputJar, secondInputJar), task.getInJarFiles(), \"input jars\");\n                    assertEquals(Arrays.asList(null, inputFilters), task.getInJarFilters(), \"input filters\");\n                    assertEquals(List.of(outputJar), task.getOutJarFiles(), \"output jars\");\n                    assertEquals(List.of(outputFilters), task.getOutJarFilters(), \"output filters\");\n                    assertEquals(List.of(2), task.getInJarCounts(), \"input jar counts\");\n                    assertEquals(List.of(libraryJar), task.getLibraryJarFiles(), \"library jars\");\n                    assertEquals(List.of(libraryFilters), task.getLibraryJarFilters(), \"library filters\");\n                    assertEquals(List.of(configurationFile), task.getConfigurationFiles(), \"configuration files\");\n                }\n\n                private static void assertEquals(Object expected, Object actual, String label) {\n                    if (!expected.equals(actual)) {\n                        throw new AssertionError(label + \" expected <\" + expected + \"> but was <\" + actual + \">\");\n                    }\n                }\n            }\n            \"\"\";\n\n    @TempDir\n    private Path temporaryDirectory;\n\n    @Test\n    @Timeout(60)\n    void proGuardTaskDslTracksProgramLibraryAndConfigurationFiles() throws Exception {\n        final Path sourceFile = temporaryDirectory.resolve(\"ProGuardTaskDslProbe.java\");\n        final Path classesDirectory = Files.createDirectories(temporaryDirectory.resolve(\"classes\"));\n        final String testClasspath = System.getProperty(TEST_CLASSPATH_PROPERTY);\n        assertThat(testClasspath).isNotBlank();\n        Files.writeString(sourceFile, PROBE_SOURCE, StandardCharsets.UTF_8);\n\n        runProcess(List.of(javaExecutable(\"javac\"), \"-classpath\", testClasspath,\n                \"-d\", classesDirectory.toString(), sourceFile.toString()), \"compile probe\");\n        runProcess(List.of(javaExecutable(\"java\"), \"-classpath\",\n                classesDirectory + System.getProperty(\"path.separator\") + testClasspath,\n                \"ProGuardTaskDslProbe\"), \"run probe\");\n    }\n\n    private static String javaExecutable(String executableName) {\n        final String javaHome = System.getenv().getOrDefault(\"JAVA_HOME\", System.getProperty(\"java.home\"));\n        return Path.of(javaHome, \"bin\", executableName).toString();\n    }\n\n    private static void runProcess(List<String> command, String description) throws IOException, InterruptedException {\n        final Process process = new ProcessBuilder(command)\n                .redirectErrorStream(true)\n                .start();\n        final boolean finished = process.waitFor(30, TimeUnit.SECONDS);\n        final String output = new String(process.getInputStream().readAllBytes(), StandardCharsets.UTF_8);\n        if (!finished) {\n            process.destroyForcibly();\n        }\n        assertThat(finished)\n                .withFailMessage(\"Timed out while trying to %s. Output:%n%s\", description, output)\n                .isTrue();\n        assertThat(process.exitValue())\n                .withFailMessage(\"Failed to %s. Output:%n%s\", description, output)\n                .isZero();\n    }\n}\n"}
