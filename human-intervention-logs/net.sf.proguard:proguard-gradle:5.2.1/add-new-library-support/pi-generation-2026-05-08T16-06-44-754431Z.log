put(\"filter\", \"!META-INF/**\");\n        inputFilters.put(\"jarfilter\", \"**.class\");\n        final Map<String, String> outputFilters = new LinkedHashMap<>();\n        outputFilters.put(\"filter\", \"**.class\");\n        final Map<String, String> libraryFilters = new LinkedHashMap<>();\n        libraryFilters.put(\"zipfilter\", \"**.class\");\n\n        task.injars(firstInputJar);\n        task.injars(inputFilters, secondInputJar);\n        task.outjars(outputFilters, outputJar);\n        task.libraryjars(libraryFilters, libraryJar);\n        task.configuration(configurationFile);\n\n        assertThat(task.getInJarFiles()).containsExactly(firstInputJar, secondInputJar);\n        assertThat(task.getInJarFilters()).containsExactly(null, inputFilters);\n        assertThat(task.getOutJarFiles()).containsExactly(outputJar);\n        assertThat(task.getOutJarFilters()).containsExactly(outputFilters);\n        assertThat(task.getInJarCounts()).containsExactly(2);\n        assertThat(task.getLibraryJarFiles()).containsExactly(libraryJar);\n        assertThat(task.getLibraryJarFilters()).containsExactly(libraryFilters);\n        assertThat(task.getConfigurationFiles()).containsExactly(configurationFile);\n    }\n}\n"}]}
