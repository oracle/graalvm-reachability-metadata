  ).asPath
  
  tasks.withType(Test).configureEach {
      systemProperty 'proguard.gradle.test.classpath', sourceSets.test.runtimeClasspath.asPath
      systemProperty 'proguard.gradle.current.classpath', gradleRuntimeClasspath
  }
  
  graalvmNative {
