r import from gradle-core. That's good! However, I’m also considering that while `Project.getTasks().create(String, Class)` may not be deprecated in 2.2.1, it might be in newer Gradle versions. It’s a bit confusing whether the compile dependency 2.2.1 has any deprecated aspects. I’ll have to explore this further.\n7538:[tool-call] delta {\"path\":\"tests/src/net.sf.proguard/proguard-gradle/5.2.1/src/test/java/net_sf_proguard/proguard_gradle/Proguard_gradleTest.java\",\"edits\":[{\"oldText\":\"package net_sf_proguard.proguard_gradle;\\n\\nimport org.gradle.api.tasks.TaskInstantiationException;\\nimport org.junit.jupiter.api.Test;\\nimport org.junit.jupiter.api.Timeout;\\nimport proguard.gradle.ProGuardTask;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\nimport static org.assertj.core.api.Assertions.assertThatThrownBy;\\n\",\"newText\":\"package net_sf_proguard.proguard_gradle;\\n\\nimport org.gradle.api.Project;\\nimport org.gradle.api.tasks.TaskInstantiationException;\\nimport org.gradle.testfixtures.ProjectBuilder;\\nimport org.junit.jupiter.api.Test;\\nimport org.junit.jupiter.api.Timeout;\\nimport proguard.gradle.ProGuardTask;\\n\\nimport java.io.File;\\nimport java.util.LinkedHashMap;\\nimport java.util.Map;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\nimport static org.assertj.core.api.Assertions.assertThatThrownBy;\\n\"},{\"oldText\":\"public class Proguard_gradleTest {\\n\\n    @Test\\n    @Timeout(60)\\n    void proGuardTaskRejectsDirectInstantiationOutsideGradleDsl() {\\n        assertThatThrownBy(ProGuardTask::new)\\n                .isInstanceOf(TaskInstantiationException.class)\\n                .satisfies(exception -> assertThat(exception)\\n                        .hasMessageContaining(ProGuardTask.class.getName())\\n                        .hasMessageContaining(\\\"instantiated directly\\\")\\n                        .hasMessageContaining(\\\"DSL\\\"));\\n    }\\n}\\n\",\"newText\":\"public class Proguard_gradleTest {\\n\\n    @Test\\n    @Timeout(60)\\n    void proGuardTaskRejectsDirectInstantiationOutsideGradleDsl() {\\n        assertThatThrownBy(ProGuardTask::new)\\n                .isInstanceOf(TaskInstantiationException.class)\\n                .satisfies(exception -> assertThat(exception)\\n                        .hasMessageContaining(ProGuardTask.class.getName())\\n                        .hasMessageContaining(\\\"instantiated directly\\\")\\n                        .hasMessageContaining(\\\"DSL\\\"));\\n    }\\n\\n    @Test\\n    @Timeout(60)\\n    void gradleTaskDslRecordsConfiguredProgramLibraryAndConfigurationFiles() throws Exception {\\n        final ProGuardTask task = createProGuardTask();\\n        final File inputJar = new File(\\\"build/input/application.jar\\\");\\n        final File outputJar = new File(\\\"build/output/application-minified.jar\\\");\\n        final File libraryJar = new File(\\\"build/library/runtime.jar\\\");\\n        final File configurationFile = new File(\\\"proguard-rules.pro\\\");\\n        final Map<String, String> inputFilter = new LinkedHashMap<>();\\n        inputFilter.put(\\\"filter\\\", \\\"!META-INF/MANIFEST.MF\\\");\\n        final Map<String, String> libraryFilter = new LinkedHashMap<>();\\n        libraryFilter.put(\\\"filter\\\", \\\"!module-info.class\\\");\\n\\n        task.injars(inputFilter, inputJar);\\n        task.outjars(outputJar);\\n        task.libraryjars(libraryFilter, libraryJar);\\n        task.configuration(configurationFile);\\n\\n        assertThat(task.getInJarFiles()).containsExactly(inputJar);\\n        assertThat(task.getInJarFilters()).containsExactly(inputFilter);\\n        assertThat(task.getOutJarFiles()).containsExactly(outputJar);\\n        assertThat(task.getOutJarFilters()).containsExactly((Object) null);\\n        assertThat(task.getInJarCounts()).containsExactly(1);\\n        assertThat(task.getLibraryJarFiles()).containsExactly(libraryJar);\\n        assertThat(task.getLibraryJarFilters