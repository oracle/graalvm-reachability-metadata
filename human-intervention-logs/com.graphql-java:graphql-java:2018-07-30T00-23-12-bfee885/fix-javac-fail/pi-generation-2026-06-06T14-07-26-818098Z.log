alueHelper.astFromValue(inputValue, inputType);\n\n    assertThat(value).isInstanceOf(ObjectValue.class);\n    Map<String, ObjectField> fieldsByName = ((ObjectValue) value).getObjectFields().stream()\n        .collect(Collectors.toMap(ObjectField::getName, Function.identity()));\n    assertThat(fieldsByName).containsOnlyKeys(\"title\", \"pages\");\n    assertThat(((StringValue) fieldsByName.get(\"title\").getValue()).getValue()).isEqualTo(\"Native GraphQL\");\n    assertThat(((IntValue) fieldsByName.get(\"pages\").getValue()).getValue()).isEqualTo(BigInteger.valueOf(321));\n  }\n\n  public static class BookInputValue {\n\n    private final String title;\n    private final int pages;\n\n    public BookInputValue(String title, int pages) {\n      this.title = title;\n      this.pages = pages;\n    }\n\n    public String getTitle() {\n      return title;\n    }\n\n    public int getPages() {\n      return pages;\n    }\n  }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 640, "output": 805, "cacheRead": 29696, "cacheWrite": 0, "totalTokens": 31141, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780754766872, "responseId": "resp_0900a7e098134b60016a24294f92e08195aea41b6dadb95584"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_P1Hx8lAgTWXrSZJORXNbZ7eu|fc_0900a7e098134b60016a242953dd688195bf2206bac0ccaf1d", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2292 bytes to tests/src/com.graphql-java/graphql-java/2018-07-30T00-23-12-bfee885/src/test/java/com_graphql_java/graphql_java/AstValueHelperTest.java"}], "isError": false, "timestamp": 1780754778393}]}
