{"type":"item.completed","item":{"id":"item_30","type":"command_execution","command":"/usr/bin/bash -lc \"nl -ba tests/src/io.javaslang/javaslang-match/2.0.6/src/test/java/io_javaslang/javaslang_match/Javaslang_matchTest.java | sed -n '1,260p'\"","aggregated_output":"     1\t/*\n     2\t * Copyright and related rights waived via CC0\n     3\t *\n     4\t * You should have received a copy of the CC0 legalcode along with this\n     5\t * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n     6\t */\n     7\tpackage io_javaslang.javaslang_match;\n     8\t\n     9\timport javaslang.Tuple;\n    10\timport javaslang.Tuple0;\n    11\timport javaslang.Tuple1;\n    12\timport javaslang.Tuple2;\n    13\timport javaslang.Tuple3;\n    14\timport javaslang.Tuple4;\n    15\timport javaslang.Tuple5;\n    16\timport javaslang.control.Option;\n    17\timport javaslang.match.annotation.Patterns;\n    18\timport javaslang.match.annotation.Unapply;\n    19\timport org.junit.jupiter.api.Test;\n    20\t\n    21\timport java.util.Objects;\n    22\t\n    23\timport static javaslang.API.$;\n    24\timport static javaslang.API.Case;\n    25\timport static javaslang.API.Match;\n    26\timport static org.assertj.core.api.Assertions.assertThat;\n    27\t\n    28\t@Patterns\n    29\tpublic class Javaslang_matchTest {\n    30\t    @Test\n    31\t    void generatedPatternDeconstructsObjectInsideMatchCase() {\n    32\t        Person person = new Person(\"Ada\", 37);\n    33\t\n    34\t        String description = Match(person).of(\n    35\t                Case(Javaslang_matchTestPatterns.person($(\"Grace\"), $()), (name, age) -> \"unexpected\"),\n    36\t                Case(Javaslang_matchTestPatterns.person($(\"Ada\"), $((Integer age) -> age >= 30)),\n    37\t                        (name, age) -> name + \" is \" + age),\n    38\t                Case($(), ignored -> \"unknown\"));\n    39\t\n    40\t        assertThat(description).isEqualTo(\"Ada is 37\");\n    41\t    }\n    42\t\n    43\t    @Test\n    44\t    void generatedPatternReportsDefinedAndEmptyOptionsForAcceptedParts() {\n    45\t        Person person = new Person(\"Edsger\", 72);\n    46\t\n    47\t        Option<Tuple2<String, Integer>> matched = Javaslang_matchTestPatterns\n    48\t                .person($((String name) -> name.startsWith(\"E\")), $((Integer age) -> age > 70))\n    49\t                .apply(person);\n    50\t        Option<Tuple2<String, Integer>> rejected = Javaslang_matchTestPatterns\n    51\t                .person($(\"Edsger\"), $((Integer age) -> age < 70))\n    52\t                .apply(person);\n    53\t\n    54\t        assertThat(matched.isDefined()).isTrue();\n    55\t        assertThat(matched.get()._1).isEqualTo(\"Edsger\");\n    56\t        assertThat(matched.get()._2).isEqualTo(72);\n    57\t        assertThat(rejected.isEmpty()).isTrue();\n    58\t    }\n    59\t\n    60\t    @Test\n    61\t    void generatedGenericPatternComposesWithNestedGeneratedPattern() {\n    62\t        Envelope<Person> envelope = new Envelope<>(\"primary\", new Person(\"Barbara\", 44));\n    63\t\n    64\t        String routed = Match(envelope).of(\n    65\t                Case(Javaslang_matchTestPatterns.envelope(\n    66\t                                $(\"secondary\"),\n    67\t                                Javaslang_matchTestPatterns.person($(), $())),\n    68\t                        (label, person) -> \"wrong route\"),\n    69\t                Case(Javaslang_matchTestPatterns.envelope(\n    70\t                                $(\"primary\"),\n    71\t                                Javaslang_matchTestPatterns.person($(\"Barbara\"), $((Integer age) -> age > 40))),\n    72\t                        (label, person) -> label + \":\" + person.name()),\n    73\t                Case($(), ignored -> \"unrouted\"));\n    74\t\n    75\t        assertThat(routed).isEqualTo(\"primary:Barbara\");\n    76\t    }\n    77\t\n    78\t    @Test\n    79\t    void generatedSingleArityGenericPatternExtractsBoxValue() {\n    80\t        Box<String> box = new Box<>(\"token-42\");\n    81\t\n    82\t        String value = Match(box).of(\n    83\t                Case(Javaslang_matchTestPatterns.box($(\"other\")), ignored -> \"wrong\"),\n    84\t                Case(Javaslang_matchTestPatterns.box($((String text) -> text.startsWith(\"token\"))),\n    85\t                        String::toUpperCase),\n    86\t                Case($(), ignored -> \"missing\"));\n    87\t\n    88\t        assertThat(value).isEqualTo(\"TOKEN-42\");\n    89\t    }\n    90\t\n    91\t    @Test\n    92\t    void generatedZeroArityPatternMatchesByRuntimeType() {\n    93\t        Heartbeat heartbeat = new Heartbeat(\"node-a\");\n    94\t\n    95\t        String result = Match(heartbeat).of(\n    96\t                Case(Javaslang_matchTestPatterns.heartbeat, value -> \"heartbeat from \" + value.node()),\n    97\t                Case($(), ignored -> \"other\"));\n    98\t\n    99\t        assertThat(result).isEqualTo(\"heartbeat from node-a\");\n   100\t        assertThat(Javaslang_matchTestPatterns.heartbeat.apply(heartbeat).isDefined()).isTrue();\n   101\t        assertThat(Javaslang_matchTestPatterns.heartbeat.apply(null).isEmpty()).isTrue();\n   102\t    }\n   103\t\n   104\t    @Test\n   105\t    void generatedThreeArityPatternCanFilterEveryExtractedPart() {\n   106\t        Point3 point = new Point3(2, 3, 5);\n   107\t\n   108\t        Integer product = Match(point).of(\n   109\t                Case(Javaslang_matchTestPatterns.point3($(1), $(), $()), (x, y, z) -> -1),\n   110\t                Case(Javaslang_matchTestPatterns.point3($(2), $((Integer y) -> y % 2 == 1), $(5)),\n   111\t                        (x, y, z) -> x * y * z),\n   112\t                Case($(), ignored -> 0));\n   113\t\n   114\t        assertThat(product).isEqualTo(30);\n   115\t    }\n   116\t\n   117\t    @Test\n   118\t    void generatedFourArityPatternCanMatchHigherArityExtractor() {\n   119\t        Rectangle rectangle = new Rectangle(2, 3, 5, 7);\n   120\t\n   121\t        Integer perimeter = Match(rectangle).of(\n   122\t                Case(Javaslang_matchTestPatterns.rectangle($(0), $(), $(), $()), (left, top, right, bottom) -> -1),\n   123\t                Case(Javaslang_matchTestPatterns.rectangle(\n   124\t                                $(2),\n   125\t                                $((Integer top) -> top > 0),\n   126\t                                $(5),\n   127\t                                $((Integer bottom) -> bottom > 6)),\n   128\t                        (left, top, right, bottom) -> 2 * ((right - left) + (bottom - top))),\n   129\t                Case($(), ignored -> 0));\n   130\t\n   131\t        assertThat(perimeter).isEqualTo(14);\n   132\t    }\n   133\t\n   134\t    @Test\n   135\t    void generatedFiveArityPatternSupportsHigherArityExtractor() {\n   136\t        Event event = new Event(\"orders\", \"created\", 12, true, \"eu-central\");\n   137\t\n   138\t        String summary = Match(event).of(\n   139\t                Case(Javaslang_matchTestPatterns.event($(\"billing\"), $(), $(), $(), $()),\n   140\t                        (topic, type, sequence, replayed, region) -> \"wrong topic\"),\n   141\t                Case(Javaslang_matchTestPatterns.event(\n   142\t                                $(\"orders\"),\n   143\t                                $(\"created\"),\n   144\t                                $((Integer sequence) -> sequence > 10),\n   145\t                                $(true),\n   146\t                                $(\"eu-central\")),\n   147\t                        (topic, type, sequence, replayed, region) -> topic + \":\" + type + \"#\" + sequence + \"@\"\n   148\t                                + region + \":\" + replayed),\n   149\t                Case($(), ignored -> \"unmatched\"));\n   150\t\n   151\t        assertThat(summary).isEqualTo(\"orders:created#12@eu-central:true\");\n   152\t    }\n   153\t\n   154\t    @Unapply\n   155\t    static Tuple2<String, Integer> person(Person person) {\n   156\t        return Tuple.of(person.name(), person.age());\n   157\t    }\n   158\t\n   159\t    @Unapply\n   160\t    static <T> Tuple2<String, T> envelope(Envelope<T> envelope) {\n   161\t        return Tuple.of(envelope.label(), envelope.value());\n   162\t    }\n   163\t\n   164\t    @Unapply\n   165\t    static Tuple0 heartbeat(Heartbeat heartbeat) {\n   166\t        return Tuple.empty();\n   167\t    }\n   168\t\n   169\t    @Unapply\n   170\t    static Tuple3<Integer, Integer, Integer> point3(Point3 point) {\n   171\t        return Tuple.of(point.x(), point.y(), point.z());\n   172\t    }\n   173\t\n   174\t    @Unapply\n   175\t    static <T> Tuple1<T> box(Box<T> box) {\n   176\t        return Tuple.of(box.value());\n   177\t    }\n   178\t\n   179\t    @Unapply\n   180\t    static Tuple4<Integer, Integer, Integer, Integer> rectangle(Rectangle rectangle) {\n   181\t        return Tuple.of(rectangle.left(), rectangle.top(), rectangle.right(), rectangle.bottom());\n   182\t    }\n   183\t\n   184\t    @Unapply\n   185\t    static Tuple5<String, String, Integer, Boolean, String> event(Event event) {\n   186\t        return Tuple.of(event.topic(), event.type(), event.sequence(), event.replayed(), event.region());\n   187\t    }\n   188\t\n   189\t    static final class Person {\n   190\t        private final String name;\n   191\t        private final int age;\n   192\t\n   193\t        Person(String name, int age) {\n   194\t            this.name = Objects.requireNonNull(name, \"name\");\n   195\t            this.age = age;\n   196\t        }\n   197\t\n   198\t        String name() {\n   199\t            return name;\n   200\t        }\n   201\t\n   202\t        int age() {\n   203\t            return age;\n   204\t        }\n   205\t    }\n   206\t\n   207\t    static final class Envelope<T> {\n   208\t        private final String label;\n   209\t        private final T value;\n   210\t\n   211\t        Envelope(String label, T value) {\n   212\t            this.label = Objects.requireNonNull(label, \"label\");\n   213\t            this.value = Objects.requireNonNull(value, \"value\");\n   214\t        }\n   215\t\n   216\t        String label() {\n   217\t            return label;\n   218\t        }\n   219\t\n   220\t        T value() {\n   221\t            return value;\n   222\t        }\n   223\t    }\n   224\t\n   225\t    static final class Heartbeat {\n   226\t        private final String node;\n   227\t\n   228\t        Heartbeat(String node) {\n   229\t            this.node = Objects.requireNonNull(node, \"node\");\n   230\t        }\n   231\t\n   232\t        String node() {\n   233\t            return node;\n   234\t        }\n   235\t    }\n   236\t\n   237\t    static final class Point3 {\n   238\t        private final int x;\n   239\t        private final int y;\n   240\t        private final int z;\n   241\t\n   242\t        Point3(int x, int y, int z) {\n   243\t            this.x = x;\n   244\t            this.y = y;\n   245\t            this.z = z;\n   246\t        }\n   247\t\n   248\t        int x() {\n   249\t            return x;\n   250\t        }\n   251\t\n   252\t        int y() {\n   253\t            return y;\n   254\t        }\n   255\t\n   256\t        int z() {\n   257\t            return z;\n   258\t        }\n   259\t    }\n   260\t\n","exit_code":0,"status":"completed"}}
