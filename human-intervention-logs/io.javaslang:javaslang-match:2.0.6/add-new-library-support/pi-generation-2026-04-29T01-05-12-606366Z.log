[tool-call] delta {"path":"tests/src/io.javaslang/javaslang-match/2.0.6/src/test/java/io_javaslang/javaslang_match/Javaslang_matchTest.java","edits":[{"oldText":"import javaslang.Tuple4;\nimport javaslang.control.Option;","newText":"import javaslang.Tuple4;\nimport javaslang.Tuple5;\nimport javaslang.control.Option;"},{"oldText":"    void generatedFourArityPatternCanMatchHigherArityExtractor() {\n        Rectangle rectangle = new Rectangle(2, 3, 5, 7);\n\n        Integer perimeter = Match(rectangle).of(\n                Case(Javaslang_matchTestPatterns.rectangle($(0), $(), $(), $()), (left, top, right, bottom) -> -1),\n                Case(Javaslang_matchTestPatterns.rectangle(\n                                $(2),\n                                $((Integer top) -> top > 0),\n                                $(5),\n                                $((Integer bottom) -> bottom > 6)),\n                        (left, top, right, bottom) -> 2 * ((right - left) + (bottom - top))),\n                Case($(), ignored -> 0));\n\n        assertThat(perimeter).isEqualTo(14);\n    }\n\n    @Unapply","newText":"    void generatedFourArityPatternCanMatchHigherArityExtractor() {\n        Rectangle rectangle = new Rectangle(2, 3, 5, 7);\n\n        Integer perimeter = Match(rectangle).of(\n                Case(Javaslang_matchTestPatterns.rectangle($(0), $(), $(), $()), (left, top, right, bottom) -> -1),\n                Case(Javaslang_matchTestPatterns.rectangle(\n                                $(2),\n                                $((Integer top) -> top > 0),\n                                $(5),\n                                $((Integer bottom) -> bottom > 6)),\n                        (left, top, right, bottom) -> 2 * ((right - left) + (bottom - top))),\n                Case($(), ignored -> 0));\n\n        assertThat(perimeter).isEqualTo(14);\n    }\n\n    @Test\n    void generatedFiveArityPatternSupportsHigherArityExtractor() {\n        Event event = new Event(\"orders\", 