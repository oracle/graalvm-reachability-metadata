  package org_glassfish.jakarta_el;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.lang.reflect.Method;
  
  import org.junit.jupiter.api.Test;
  
  import com.sun.el.lang.FunctionMapperImpl;
  
  public class ComSunElLangFunctionMapperImplInnerFunctionTest {
  
      @Test
      void resolvesSerializedFunctionMethodByOwnerAndParameterTypes() throws Exception {
          FunctionMapperImpl originalMapper = new FunctionMapperImpl();
          Method greetingMethod = FixtureFunctions.class.getMethod("greeting", String.class);
          originalMapper.addFunction("fixture", "greeting", greetingMethod);
  
          FunctionMapperImpl deserializedMapper = deserialize(serialize(originalMapper));
  
          Method resolvedMethod = deserializedMapper.resolveFunction("fixture", "greeting");
          assertThat(resolvedMethod).isEqualTo(greetingMethod);
      }
  
      private static byte[] serialize(FunctionMapperImpl mapper) throws Exception {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {
              output.writeObject(mapper);
          }
          return bytes.toByteArray();
      }
  
      private static FunctionMapperImpl deserialize(byte[] bytes) throws Exception {
          try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(bytes))) {
              return (FunctionMapperImpl) input.readObject();
          }
      }
  
      public static final class FixtureFunctions {
          public static String greeting(String name) {
              return "Hello " + name;
          }
      }
  }
