reamHandler;\nimport java.net.URLStreamHandlerFactory;\nimport java.nio.charset.StandardCharsets;\nimport java.util.Collections;\nimport java.util.Enumeration;\nimport java.util.List;\nimport java.util.concurrent.atomic.AtomicBoolean;\n\nimport org.glassfish.jersey.server.internal.scanning.PackageNamesScanner;\nimport org.junit.jupiter.api.Test;\n\npublic class VfsSchemeResourceFinderFactoryInnerVfsResourceFinderTest {\n    private static final AtomicBoolean URL_HANDLER_FACTORY_REGISTERED = new AtomicBoolean();\n    private static final String PACKAGE_NAME = \"example.vfs\";\n    private static final String PACKAGE_PATH = \"example/vfs\";\n    private static final String RESOURCE_NAME = \"resource.txt\";\n    private static final byte[] RESOURCE_CONTENT = \"vfs resource\".getBytes(StandardCharsets.UTF_8);\n\n    @Test\n    void packageScannerReadsLeafResourceFromVfsUrl() throws Exception {\n        installVfsUrlHandlerFactory();\n        VfsUrlStreamHandlerFactory.root = new VirtualFile(\"root\", false, List.of(\n                new VirtualFile(RESOURCE_NAME, true, RESOURCE_CONTENT)));\n        PackageNamesScanner.setResourcesProvider(new TestResourcesProvider());\n\n        PackageNamesScanner scanner = new PackageNamesScanner(\n                getClass().getClassLoader(), new String[] {PACKAGE_NAME}, false);\n        try {\n            assertThat(scanner.hasNext()).isTrue();\n            assertThat(scanner.next()).isEqualTo(RESOURCE_NAME);\n            try (InputStream input = scanner.open()) {\n                assertThat(input.readAllBytes()).isEqualTo(RESOURCE_CONTENT);\n            }\n            assertThat(scanner.hasNext()).isFalse();\n        } finally {\n            scanner.close();\n        }\n    }\n\n    private static void installVfsUrlHandlerFactory() {\n        if (URL_HANDLER_FACTORY_REGISTERED.compareAndSet(false, true)) {\n            URL.setURLStreamHandlerFactory(new VfsUrlStreamHandlerFactory());\n        }\n    }\n\n    private static final class TestResourcesProvider extends PackageNamesScanner.ResourcesProvider {\n        @Override\n        public Enumeration<URL> getResources(String name, ClassLoader classLoader) throws IOException {\n            if (PACKAGE_PATH.equals(name)) {\n                return Collections.enumeration(List.of(new URL(\"vfs:/virtual-scan-root\")));\n            }\n            return classLoader.getResources(name);\n        }\n    }\n\n    private static final class VfsUrlStreamHandlerFactory implements URLStreamHandlerFactory {\n        private static volatile VirtualFile root;\n\n        @Override\n        public URLStreamHandler createURLStreamHandler(String protocol) {\n            if (\"vfs\".equals(protocol)) {\n                return new VfsUrlStreamHandler();\n            }\n            return null;\n        }\n    }\n\n    private static final class VfsUrlStreamHandler extends URLStreamHandler {\n        @Override\n        protected URLConnection openConnection(URL url) {\n            return new URLConnection(url) {\n                @Override\n                public void connect() {\n                }\n\n                @Override\n                public Object getContent() {\n                    return VfsUrlStreamHandlerFactory.root;\n                }\n            };\n        }\n    }\n\n    public static final class VirtualFile {\n        private final String name;\n        private final boolean leaf;\n        private final byte[] content;\n        private final List<VirtualFile> children;\n\n        private VirtualFile(String name, boolean leaf, byte[] content) {\n            this.name = name;\n            this.leaf = leaf;\n            this.content = content.clone();\n            this.children = Collections.emptyList();\n        }\n\n        private VirtualFile(String name, boolean leaf, List<VirtualFile> children) {\n            this.name = name;\n            this.leaf = leaf;\n            this.content = new byte[0];\n            this.children = List.copyOf(children);\n        }\n\n        public InputStream openStream() {\n            return new ByteArrayInputStream(content);\n        }\n\n        public String getName() {\n            return name;\n        }\n\n        public boolean isLeaf() {\n            return leaf;\n        }\n\n        public List<VirtualFile> getChildren() {\n            return children;\n        }\n\n        public List<VirtualFile> getChildrenRecursively() {\n            return children;\n        }\n    }\n}\n=== tests/src/org.glassfish.jersey.core/jersey-server/2.34/src/test/java/org_glassfish_jersey_core/jersey_server/WadlGeneratorLoaderTest.java ===\n/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_glassfish_jersey_core.jersey_server;\n\nimport static org.assertj.core.api.Assertions.assertThatThrownBy;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.File;\nimport java.io.InputStream;\nimport java.lang.annotation.Annotation;\nimport java.lang.reflect.Type;\nimport java.nio.charset.StandardCharsets;\nimport java.util.Collections;\nimport java.util.List;\n\nimport javax.ws.rs.ProcessingException;\n\nimport org.glassfish.jersey.internal.inject.Binder;\nimport org.glassfish.jersey.internal.inject.Binding;\nimport org.glassfish.jersey.internal.inject.ForeignDescriptor;\nimport org.glassfish.jersey.internal.inject.InjectionManager;\nimport org.glassfish.jersey.internal.inject.ServiceHolder;\nimport org.glassfish.jersey.server.wadl.config.WadlGeneratorConfig;\nimport org.glassfish.jersey.server.wadl.internal.generators.WadlGeneratorApplicationDoc;\nimport org.glassfish.jersey.server.wadl.internal.generators.WadlGeneratorGrammarsSupport;\nimport org.junit.jupiter.api.Test;\n\npublic class WadlGeneratorLoaderTest {\n    @Test\n    void setPropertyUsesDirectAssignmentAndStringConstructorConversion() {\n        WadlGeneratorConfig config = WadlGeneratorConfig\n                .generator(WadlGeneratorGrammarsSupport.class)\n                .prop(\"grammarsFile\", new File(\"src/test/resources/wadl-loader-grammars.xml\"))\n                .prop(\"overrideGrammars\", \"true\")\n                .build();\n\n        loadUntilGeneratorInitialization(config);\n    }\n\n    @Test\n    void setPropertyResolvesClasspathFileProperty() {\n        WadlGeneratorConfig config = WadlGeneratorConfig\n                .generator(WadlGeneratorApplicationDoc.class)\n                .prop(\"applicationDocsFile\", \"classpath:/wadl-loader-application-doc.xml\")\n                .build();\n\n        loadUntilGeneratorInitialization(config);\n    }\n\n    @Test\n    void setPropertyCreatesNonClasspathFileProperty() {\n        WadlGeneratorConfig config = WadlGeneratorConfig\n                .generator(WadlGeneratorApplicationDoc.class)\n                .prop(\"applicationDocsFile\", \"build/tmp/wadl-loader-application-doc.xml\")\n                .build();\n\n        loadUntilGeneratorInitialization(config);\n    }\n\n    @Test\n    void setPropertyLoadsInputStreamPropertyFromClasspath() {\n        WadlGeneratorConfig config = WadlGeneratorConfig\n                .generator(WadlGeneratorApplicationDoc.class)\n                .prop(\"applicationDocsStream\", \"wadl-loader-application-doc.xml\")\n                .build();\n        ClassLoader originalLoader = Thread.currentThread().getContextClassLoader();\n        Thread.currentThread().setContextClassLoader(new InMemoryResourceClassLoader(originalLoader));\n        try {\n            loadUntilGeneratorInitialization(config);\n        } finally {\n            Thread.currentThread().setContextClassLoader(originalLoader);\n        }\n    }\n\n    private static void loadUntilGeneratorInitialization(WadlGeneratorConfig config) {\n        assertThatThrownBy(() -> config.createWadlGenerator(new MinimalInjectionManager()))\n                .isInstanceOf(ProcessingException.class)\n                .hasCauseInstanceOf(Exception.class);\n    }\n\n    private static final class InMemoryResourceClassLoader extends ClassLoader {\n        private static final byte[] APPLICATION_DOC = \"<applicationDocs />\".getBytes(StandardCharsets.UTF_8);\n\n        private InMemoryResourceClassLoader(ClassLoader parent) {\n            super(parent);\n        }\n\n        @Override\n        public InputStream getResourceAsStream(String name) {\n            if (\"wadl-loader-application-doc.xml\".equals(name)) {\n                return new ByteArrayInputStream(APPLICATION_DOC);\n            }\n            return super.getResourceAsStream(name);\n        }\n    }\n\n    private static final class MinimalInjectionManager implements InjectionManager {\n        @Override\n        public void completeRegistration() {\n        }\n\n        @Override\n        public void shutdown() {\n        }\n\n        @Override\n        public void register(Binding binding) {\n            throw new UnsupportedOperationException();\n        }\n\n        @Override\n        public void register(Iterable<Binding> descriptors) {\n            throw new UnsupportedOperationException();\n        }\n\n        @Override\n        public void register(Binder binder) {\n            throw new UnsupportedOperationException();\n        }\n\n        @Override\n        public void register(Object provider) throws IllegalArgumentException {\n            throw new UnsupportedOperationException();\n        }\n\n        @Override\n        public boolean isRegistrable(Class<?> clazz) {\n            return false;\n        }\n\n        @Override\n        public <T> T createAndInitialize(Class<T> createMe) {\n            if (WadlGeneratorGrammarsSupport.class.equals(createMe)) {\n                return createMe.cast(new WadlGeneratorGrammarsSupport());\n            }\n            if (WadlGeneratorApplicationDoc.class.equals(createMe)) {\n                return createMe.cast(new WadlGeneratorApplicationDoc());\n            }\n            throw new IllegalArgumentException(\"Unsupported generator class: \" + createMe.getName());\n        }\n\n        @Override\n        public <T> List<ServiceHolder<T>> getAllServiceHolders(Class<T> contractOrImpl, Annotation... qualifiers) {\n            return Collections.emptyList();\n        }\n\n        @Override\n        public <T> T getInstance(Class<T> contractOrImpl, Annotation... qualifiers) {\n            return null;\n        }\n\n        @Override\n        public <T> T getInstance(Class<T> contractOrImpl, String classAnalyzer) {\n            return null;\n        }\n\n        @Override\n        public <T> T getInstance(Class<T> contractOrImpl) {\n            return null;\n        }\n\n        @Override\n        public <T> T getInstance(Type contractOrImpl) {\n            return null;\n        }\n\n        @Override\n        public Object getInstance(ForeignDescriptor foreignDescriptor) {\n            return null;\n        }\n\n        @Override\n        public ForeignDescriptor createForeignDescriptor(Binding binding) {\n            throw new UnsupportedOperationException();\n        }\n\n        @Override\n        public <T> List<T> getAllInstances(Type contractOrImpl) {\n            return Collections.emptyList();\n        }\n\n        @Override\n        public void inject(Object injectMe) {\n        }\n\n        @Override\n        public void inject(Object injectMe, String classAnalyzer) {\n        }\n\n        @Override\n        public void preDestroy(Object preDestroyMe) {\n        }\n    }\n}\n","exit_code":0,"status":"completed"}}
