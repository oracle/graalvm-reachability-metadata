  package org_glassfish_jersey_core.jersey_server;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import jersey.repackaged.org.objectweb.asm.ClassWriter;
  
  import org.junit.jupiter.api.Test;
  
  public class ClassWriterTest {
      @Test
      void getCommonSuperClassLoadsBothTypesAndFindsNearestCommonParent() {
          ExposedClassWriter writer = new ExposedClassWriter();
  
          String commonSuperClass = writer.commonSuperClass("java/util/ArrayList", "java/util/LinkedList");
  
          assertThat(commonSuperClass).isEqualTo("java/util/AbstractList");
      }
  
      private static final class ExposedClassWriter extends ClassWriter {
          private ExposedClassWriter() {
              super(0);
          }
  
          private String commonSuperClass(String type1, String type2) {
              return getCommonSuperClass(type1, type2);
          }
