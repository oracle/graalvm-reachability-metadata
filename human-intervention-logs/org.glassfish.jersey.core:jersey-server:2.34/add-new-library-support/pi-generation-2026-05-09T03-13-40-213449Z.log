assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayOutputStream;\nimport java.net.URI;\nimport java.nio.charset.StandardCharsets;\nimport java.util.Arrays;\nimport java.util.Collection;\nimport java.util.LinkedHashMap;\nimport java.util.Map;\nimport java.util.concurrent.TimeUnit;\n\nimport javax.ws.rs.DefaultValue;\nimport javax.ws.rs.GET;\nimport javax.ws.rs.Path;\nimport javax.ws.rs.Produces;\nimport javax.ws.rs.QueryParam;\nimport javax.ws.rs.core.MediaType;\n\nimport org.glassfish.jersey.internal.PropertiesDelegate;\nimport org.glassfish.jersey.server.ApplicationHandler;\nimport org.glassfish.jersey.server.ContainerRequest;\nimport org.glassfish.jersey.server.ContainerResponse;\nimport org.glassfish.jersey.server.ResourceConfig;\nimport org.junit.jupiter.api.Test;\n\npublic class ArrayExtractorTest {\n    private static final URI BASE_URI = URI.create(\"http://localhost/\");\n\n    @Test\n    void queryParameterArrayUsesAllRequestValues() throws Exception {\n        String response = invoke(\"arrays/present?number=4&number=8\");\n\n        assertThat(response).isEqualTo(\"[4, 8]\");\n    }\n\n    @Test\n    void queryParameterArrayUsesConfiguredDefaultValue() throws Exception {\n        String response = invoke(\"arrays/default\");\n\n        assertThat(response).isEqualTo(\"[21]\");\n    }\n\n    @Test\n    void missingQueryParameterWithoutDefaultProducesEmptyArray() throws Exception {\n        String response = invoke(\"arrays/missing\");\n\n        assertThat(response).isEqualTo(\"0\");\n    }\n\n    private static String invoke(String requestPath) throws Exception {\n        ApplicationHandler handler = new ApplicationHandler(new ResourceConfig(ArrayResource.class));\n        try {\n            ContainerRequest request = new ContainerRequest(\n                    BASE_URI,\n                    BASE_URI.resolve(requestPath),\n                    \"GET\",\n                    null,\n                    new TestPropertiesDelegate(),\n                    handler.getConfiguration());\n            ByteArrayOutputStream output = new ByteArrayOutputStream();\n            ContainerResponse response = handler.apply(request, output).get(10, TimeUnit.SECONDS);\n\n            assertThat(response.getStatus()).isEqualTo(200);\n            return output.toString(StandardCharsets.UTF_8);\n        } finally {\n            handler.onShutdown(null);\n        }\n    }\n\n    @Path(\"arrays\")\n    @Produces(MediaType.TEXT_PLAIN)\n    public static class ArrayResource {\n        @GET\n        @Path(\"present\")\n        public String present(@QueryParam(\"number\") int[] numbers) {\n            return Arrays.toString(numbers);\n        }\n\n        @GET\n        @Path(\"default\")\n        public String defaulted(@DefaultValue(\"21\") @QueryParam(\"number\") int[] numbers) {\n            return Arrays.toString(numbers);\n        }\n\n        @GET\n        @Path(\"missing\")\n        public String missing(@QueryParam(\"value\") String[] values) {\n            return Integer.toString(values.length);\n        }\n    }\n\n    private static final class TestPropertiesDelegate implements PropertiesDelegate {\n        private final Map<String, Object> properties = new LinkedHashMap<>();\n\n        @Override\n        public Object getProperty(String name) {\n            return properties.get(name);\n        }\n\n        @Override\n        public Collection<String> getPropertyNames() {\n            return properties.keySet();\n        }\n\n        @Override\n        public void setProperty(String name, Object object) {\n            properties.put(name, object);\n        }\n\n        @Override\n        public void removeProperty(String name) {\n            properties.remove(name);\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778296400478}, {"role": "toolResult", "toolCallId": "call_6ZwHvRuTOkOfBea9beZghH3o|fc_02ae3a3c13b3bd7d0169fea65042c88196a4e80e3138671d6c", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_glassfish_jersey_core.jersey_server;\n\nimport static org.assertj.core.api.Assertions.assertThatThrownBy;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.File;\nimport java.io.InputStream;\nimport java.lang.annotation.Annotation;\nimport java.lang.reflect.Type;\nimport java.nio.charset.StandardCharsets;\nimport java.util.Collections;\nimport java.util.List;\n\nimport javax.ws.rs.ProcessingException;\n\nimport org.glassfish.jersey.internal.inject.Binder;\nimport org.glassfish.jersey.internal.inject.Binding;\nimport org.glassfish.jersey.internal.inject.ForeignDescriptor;\nimport org.glassfish.jersey.internal.inject.InjectionManager;\nimport org.glassfish.jersey.internal.inject.ServiceHolder;\nimport org.glassfish.jersey.server.wadl.config.WadlGeneratorConfig;\nimport org.glassfish.jersey.server.wadl.internal.generators.WadlGeneratorApplicationDoc;\nimport org.glassfish.jersey.server.wadl.internal.generators.WadlGeneratorGrammarsSupport;\nimport org.junit.jupiter.api.Test;\n\npublic class WadlGeneratorLoaderTest {\n    @Test\n    void setPropertyUsesDirectAssignmentAndStringConstructorConversion() {\n        WadlGeneratorConfig config = WadlGeneratorConfig\n                .generator(WadlGeneratorGrammarsSupport.class)\n                .prop(\"grammarsFile\", new File(\"src/test/resources/wadl-loader-grammars.xml\"))\n                .prop(\"overrideGrammars\", \"true\")\n                .build();\n\n        loadUntilGeneratorInitialization(config);\n    }\n\n    @Test\n    void setPropertyResolvesClasspathFileProperty() {\n        WadlGeneratorConfig config = WadlGeneratorConfig\n                .generator(WadlGeneratorApplicationDoc.class)\n                .prop(\"applicationDocsFile\", \"classpath:/wadl-loader-application-doc.xml\")\n                .build();\n\n        loadUntilGeneratorInitialization(config);\n    }\n\n    @Test\n    void setPropertyCreatesNonClasspathFileProperty() {\n        WadlGeneratorConfig config = WadlGeneratorConfig\n                .generator(WadlGeneratorApplicationDoc.class)\n                .prop(\"applicationDocsFile\", \"build/tmp/wadl-loader-application-doc.xml\")\n                .build();\n\n        loadUntilGeneratorInitialization(config);\n    }\n\n    @Test\n    void setPropertyLoadsInputStreamPropertyFromClasspath() {\n        WadlGeneratorConfig config = WadlGeneratorConfig\n                .generator(WadlGeneratorApplicationDoc.class)\n                .prop(\"applicationDocsStream\", \"wadl-loader-application-doc.xml\")\n                .build();\n        ClassLoader originalLoader = Thread.currentThread().getContextClassLoader();\n        Thread.currentThread().setContextClassLoader(new InMemoryResourceClassLoader(originalLoader));\n        try {\n            loadUntilGeneratorInitialization(config);\n        } finally {\n            Thread.currentThread().setContextClassLoader(originalLoader);\n        }\n    }\n\n    private static void loadUntilGeneratorInitialization(WadlGeneratorConfig config) {\n        assertThatThrownBy(() -> config.createWadlGenerator(new MinimalInjectionManager()))\n                .isInstanceOf(ProcessingException.class)\n                .hasCauseInstanceOf(Exception.class);\n    }\n\n    private static final class InMemoryResourceClassLoader extends ClassLoader {\n        private static final byte[] APPLICATION_DOC = \"<applicationDocs />\".getBytes(StandardCharsets.UTF_8);\n\n        private InMemoryResourceClassLoader(ClassLoader parent) {\n            super(parent);\n        }\n\n        @Override\n        public InputStream getResourceAsStream(String name) {\n            if (\"wadl-loader-application-doc.xml\".equals(name)) {\n                return new ByteArrayInputStream(APPLICATION_DOC);\n            }\n            return super.getResourceAsStream(name);\n        }\n    }\n\n    private static final class MinimalInjectionManager implements InjectionManager {\n        @Override\n        public void completeRegistration() {\n        }\n\n        @Override\n        public void shutdown() {\n        }\n\n        @Override\n        public void register(Binding binding) {\n            throw new UnsupportedOperationException();\n        }\n\n        @Override\n        public void register(Iterable<Binding> descriptors) {\n            throw new UnsupportedOperationException();\n        }\n\n        @Override\n        public void register(Binder binder) {\n            throw new UnsupportedOperationException();\n        }\n\n        @Override\n        public void register(Object provider) throws IllegalArgumentException {\n            throw new UnsupportedOperationException();\n        }\n\n        @Override\n        public boolean isRegistrable(Class<?> clazz) {\n            return false;\n        }\n\n        @Override\n        public <T> T createAndInitialize(Class<T> createMe) {\n            if (WadlGeneratorGrammarsSupport.class.equals(createMe)) {\n                return createMe.cast(new WadlGeneratorGrammarsSupport());\n            }\n            if (WadlGeneratorApplicationDoc.class.equals(createMe)) {\n                return createMe.cast(new WadlGeneratorApplicationDoc());\n            }\n            throw new IllegalArgumentException(\"Unsupported generator class: \" + createMe.getName());\n        }\n\n        @Override\n        public <T> List<ServiceHolder<T>> getAllServiceHolders(Class<T> contractOrImpl, Annotation... qualifiers) {\n            return Collections.emptyList();\n        }\n\n        @Override\n        public <T> T getInstance(Class<T> contractOrImpl, Annotation... qualifiers) {\n            return null;\n        }\n\n        @Override\n        public <T> T getInstance(Class<T> contractOrImpl, String classAnalyzer) {\n            return null;\n        }\n\n        @Override\n        public <T> T getInstance(Class<T> contractOrImpl) {\n            return null;\n        }\n\n        @Override\n        public <T> T getInstance(Type contractOrImpl) {\n            return null;\n        }\n\n        @Override\n        public Object getInstance(ForeignDescriptor foreignDescriptor) {\n            return null;\n        }\n\n        @Override\n        public ForeignDescriptor createForeignDescriptor(Binding binding) {\n            throw new UnsupportedOperationException();\n        }\n\n        @Override\n        public <T> List<T> getAllInstances(Type contractOrImpl) {\n            return Collections.emptyList();\n        }\n\n        @Override\n        public void inject(Object injectMe) {\n        }\n\n        @Override\n        public void inject(Object injectMe, String classAnalyzer) {\n        }\n\n        @Override\n        public void preDestroy(Object preDestroyMe) {\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778296400478}, {"role": "toolResult", "toolCallId": "call_LVyiNmN5MyD6sdUcK1SnJbuj|fc_02ae3a3c13b3bd7d0169fea65042d081969bb1483069c2a914", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_glassfish_jersey_core.jersey_server;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.IOException;\nimport java.io.InputStream;\nimport java.net.URL;\nimport java.net.URLConnection;\nimport java.net.URLStreamHandler;\nimport java.net.URLStreamHandlerFactory;\nimport java.nio.charset.StandardCharsets;\nimport java.util.Collections;\nimport java.util.Enumeration;\nimport java.util.List;\nimport java.util.concurrent.atomic.AtomicBoolean;\n\nimport org.glassfish.jersey.server.internal.scanning.PackageNamesScanner;\nimport org.junit.jupiter.api.Test;\n\npublic class VfsSchemeResourceFinderFactoryInnerVfsResourceFinderTest {\n    private static final AtomicBoolean URL_HANDLER_FACTORY_REGISTERED = new AtomicBoolean();\n    private static final String PACKAGE_NAME = \"example.vfs\";\n    private static final String PACKAGE_PATH = \"example/vfs\";\n    private static final String RESOURCE_NAME = \"resource.txt\";\n    private static final byte[] RESOURCE_CONTENT = \"vfs resource\".getBytes(StandardCharsets.UTF_8);\n\n    @Test\n    void packageScannerReadsLeafResourceFromVfsUrl() throws Exception {\n        installVfsUrlHandlerFactory();\n        VfsUrlStreamHandlerFactory.root = new VirtualFile(\"root\", false, List.of(\n                new VirtualFile(RESOURCE_NAME, true, RESOURCE_CONTENT)));\n        PackageNamesScanner.setResourcesProvider(new TestResourcesProvider());\n\n        PackageNamesScanner scanner = new PackageNamesScanner(\n                getClass().getClassLoader(), new String[] {PACKAGE_NAME}, false);\n        try {\n            assertThat(scanner.hasNext()).isTrue();\n            assertThat(scanner.next()).isEqualTo(RESOURCE_NAME);\n            try (InputStream input = scanner.open()) {\n                assertThat(input.readAllBytes()).isEqualTo(RESOURCE_CONTENT);\n            }\n            assertThat(scanner.hasNext()).isFalse();\n        } finally {\n            scanner.close();\n        }\n    }\n\n    private static void installVfsUrlHandlerFactory() {\n        if (URL_HANDLER_FACTORY_REGISTERED.compareAndSet(false, true)) {\n            URL.setURLStreamHandlerFactory(new VfsUrlStreamHandlerFactory());\n        }\n    }\n\n    private static final class TestResourcesProvider extends PackageNamesScanner.ResourcesProvider {\n        @Override\n        public Enumeration<URL> getResources(String name, ClassLoader classLoader) throws IOException {\n            if (PACKAGE_PATH.equals(name)) {\n                return Collections.enumeration(List.of(new URL(\"vfs:/virtual-scan-root\")));\n            }\n            return classLoader.getResources(name);\n        }\n    }\n\n    private static final class VfsUrlStreamHandlerFactory implements URLStreamHandlerFactory {\n        private static volatile VirtualFile root;\n\n        @Override\n        public URLStreamHandler createURLStreamHandler(String protocol) {\n            if (\"vfs\".equals(protocol)) {\n                return new VfsUrlStreamHandler();\n            }\n            return null;\n        }\n    }\n\n    private static final class VfsUrlStreamHandler extends URLStreamHandler {\n        @Override\n        protected URLConnection openConnection(URL url) {\n            return new URLConnection(url) {\n                @Override\n                public void connect() {\n                }\n\n                @Override\n                public Object getContent() {\n                    return VfsUrlStreamHandlerFactory.root;\n                }\n            };\n        }\n    }\n\n    public static final class VirtualFile {\n        private final String name;\n        private final boolean leaf;\n        private final byte[] content;\n        private final List<VirtualFile> children;\n\n        private VirtualFile(String name, boolean leaf, byte[] content) {\n            this.name = name;\n            this.leaf = leaf;\n            this.content = content.clone();\n            this.children = Collections.emptyList();\n        }\n\n        private VirtualFile(String name, boolean leaf, List<VirtualFile> children) {\n            this.name = name;\n            this.leaf = leaf;\n            this.content = new byte[0];\n            this.children = List.copyOf(children);\n        }\n\n        public InputStream openStream() {\n            return new ByteArrayInputStream(content);\n        }\n\n        public String getName() {\n            return name;\n        }\n\n        public boolean isLeaf() {\n            return leaf;\n        }\n\n        public List<VirtualFile> getChildren() {\n     