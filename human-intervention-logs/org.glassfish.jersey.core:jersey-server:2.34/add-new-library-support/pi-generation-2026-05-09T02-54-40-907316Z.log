icDrbun2tq9fqQqfYfHwrobnx2CM=\",\"summary\":[]}"}, {"type": "toolCall", "id": "call_7mZzFEAaUXZSSlv2vKKmxW9n|fc_02ca462744e31f3a0169fea1a9b7e88195999409269e6021cf", "name": "write", "arguments": {"path": "tests/src/org.glassfish.jersey.core/jersey-server/2.34/src/test/java/org_glassfish_jersey_core/jersey_server/WadlGeneratorLoaderTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_glassfish_jersey_core.jersey_server;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.File;\nimport java.lang.annotation.Annotation;\nimport java.lang.reflect.Type;\nimport java.util.Collections;\nimport java.util.List;\n\nimport javax.ws.rs.ProcessingException;\n\nimport org.glassfish.jersey.internal.inject.Binder;\nimport org.glassfish.jersey.internal.inject.Binding;\nimport org.glassfish.jersey.internal.inject.ForeignDescriptor;\nimport org.glassfish.jersey.internal.inject.InjectionManager;\nimport org.glassfish.jersey.internal.inject.ServiceHolder;\nimport org.glassfish.jersey.server.wadl.WadlGenerator;\nimport org.glassfish.jersey.server.wadl.config.WadlGeneratorConfig;\nimport org.glassfish.jersey.server.wadl.internal.generators.WadlGeneratorApplicationDoc;\nimport org.glassfish.jersey.server.wadl.internal.generators.WadlGeneratorGrammarsSupport;\nimport org.junit.jupiter.api.Test;\n\npublic class WadlGeneratorLoaderTest {\n    @Test\n    void setPropertyUsesDirectAssignmentAndStringConstructorConversion() {\n        WadlGeneratorConfig config = WadlGeneratorConfig\n                .generator(WadlGeneratorGrammarsSupport.class)\n                .prop(\"grammarsFile\", new File(\"src/test/resources/wadl-loader-grammars.xml\"))\n                .prop(\"overrideGrammars\", \"true\")\n                .build();\n\n        loadUntilGeneratorInitialization(config);\n    }\n\n    @Test\n    void setPropertyResolvesClasspathFileProperty() {\n        WadlGeneratorConfig config = WadlGeneratorConfig\n                .generator(WadlGeneratorApplicationDoc.class)\n                .prop(\"applicationDocsFile\", \"classpath:/wadl-loader-application-doc.xml\")\n                .build();\n\n        loadUntilGeneratorInitialization(config);\n    }\n\n    @Test\n    void setPropertyCreatesNonClasspathFileProperty() {\n        WadlGeneratorConfig config = WadlGeneratorConfig\n                .generator(WadlGeneratorApplicationDoc.class)\n                .prop(\"applicationDocsFile\", \"build/tmp/wadl-loader-application-doc.xml\")\n                .build();\n\n        loadUntilGeneratorInitialization(config);\n    }\n\n    @Test\n    void setPropertyLoadsInputStreamPropertyFromClasspath() {\n        WadlGeneratorConfig config = WadlGeneratorConfig\n                .generator(WadlGeneratorApplicationDoc.class)\n                .prop(\"applicationDocsStream\", \"wadl-loader-application-doc.xml\")\n                .build();\n\n        loadUntilGeneratorInitialization(config);\n    }\n\n    private static void loadUntilGeneratorInitialization(WadlGeneratorConfig config) {\n        try {\n            WadlGenerator generator = config.createWadlGenerator(new MinimalInjectionManager());\n            assertThat(generator).isNotNull();\n        } catch (ProcessingException expected) {\n            assertThat(expected.getCause()).isNotNull();\n        }\n    }\n\n    private static final class MinimalInjectionManager implements InjectionManager {\n        @Override\n        public void completeRegistration() {\n        }\n\n        @Override\n        public void shutdown() {\n        }\n\n        @Override\n        public void register(Binding binding) {\n            throw new UnsupportedOperationException();\n        }\n\n        @Override\n        public void register(Iterable<Binding> descriptors) {\n            throw new UnsupportedOperationException();\n        }\n\n        @Override\n        public void register(Binder binder) {\n            throw new UnsupportedOperationException();\n        }\n\n        @Override\n        public void register(Object provider) throws IllegalArgumentException {\n            throw new UnsupportedOperationException();\n        }\n\n        @Override\n        public boolean isRegistrable(Class<?> clazz) {\n            return false;\n        }\n\n        @Override\n        public <T> T createAndInitialize(Class<T> createMe) {\n            if (WadlGeneratorGrammarsSupport.class.equals(createMe)) {\n                return createMe.cast(new WadlGeneratorGrammarsSupport());\n            }\n            if (WadlGeneratorApplicationDoc.class.equals(createMe)) {\n                return createMe.cast(new WadlGeneratorApplicationDoc());\n            }\n            throw new IllegalArgumentException(\"Unsupported generator class: \" + createMe.getName());\n        }\n\n        @Override\n        public <T> List<ServiceHolder<T>> getAllServiceHolders(Class<T> contractOrImpl, Annotation... qualifiers) {\n            return Collections.emptyList();\n        }\n\n        @Override\n        public <T> T getInstance(Class<T> contractOrImpl, Annotation... qualifiers) {\n            return null;\n        }\n\n        @Override\n        public <T> T getInstance(Class<T> contractOrImpl, String classAnalyzer) {\n            return null;\n        }\n\n        @Override\n        public <T> T getInstance(Class<T> contractOrImpl) {\n            return null;\n        }\n\n        @Override\n        public <T> T getInstance(Type contractOrImpl) {\n            return null;\n        }\n\n        @Override\n        public Object getInstance(ForeignDescriptor foreignDescriptor) {\n            return null;\n        }\n\n        @Override\n        public ForeignDescriptor createForeignDescriptor(Binding binding) {\n            throw new UnsupportedOperationException();\n        }\n\n        @Override\n        public <T> List<T> getAllInstances(Type contractOrImpl) {\n            return Collections.emptyList();\n        }\n\n        @Override\n        public void inject(Object injectMe) {\n        }\n\n        @Override\n        public void inject(Object injectMe, String classAnalyzer) {\n        }\n\n        @Override\n        public void preDestroy(Object preDestroyMe) {\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1164, "output": 1502, "cacheRead": 41984, "cacheWrite": 0, "totalTokens": 44650, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778295205289, "responseId": "resp_02ca462744e31f3a0169fea1a5dc688195b2393f236a36db0a"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_7mZzFEAaUXZSSlv2vKKmxW9n|fc_02ca462744e31f3a0169fea1a9b7e88195999409269e6021cf", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 5830 bytes to tests/src/org.glassfish.jersey.core/jersey-server/2.34/src/test/java/org_glassfish_jersey_core/jersey_server/WadlGeneratorLoaderTest.java"}], "isError": false, "timestamp": 1778295218359}]}
