ERY_PARAM);\n\n        if (simple != null) {\n            if (simple.size() == 0) {\n                return true;\n            }\n\n            final String value = simple.get(0).trim();\n            return value.isEmpty() || value.toUpperCase(Locale.ROOT).equals(\"TRUE\");\n        }\n        return false;\n    }\n\n}\n"}], "isError": false, "timestamp": 1778295316009}}
