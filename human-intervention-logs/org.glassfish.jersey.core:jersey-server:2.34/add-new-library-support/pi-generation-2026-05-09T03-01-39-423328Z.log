ublic InputStream getResourceAsStream(String name) {\n            if (\"wadl-loader-application-doc.xml\".equals(name)) {\n                return new ByteArrayInputStream(APPLICATION_DOC);\n            }\n            return super.getResourceAsStream(name);\n        }\n    }\n\n    private static final class MinimalInjectionManager implements InjectionManager {\n        @Override\n        public void completeRegistration() {\n        }\n\n        @Override\n        public void shutdown() {\n        }\n\n        @Override\n        public void register(Binding binding) {\n            throw new UnsupportedOperationException();\n        }\n\n        @Override\n        public void register(Iterable<Binding> descriptors) {\n            throw new UnsupportedOperationException();\n        }\n\n        @Override\n        public void register(Binder binder) {\n            throw new UnsupportedOperationException();\n        }\n\n        @Override\n        public void register(Object provider) throws IllegalArgumentException {\n            throw new UnsupportedOperationException();\n        }\n\n        @Override\n        public boolean isRegistrable(Class<?> clazz) {\n            return false;\n        }\n\n        @Override\n        public <T> T createAndInitialize(Class<T> createMe) {\n            if (WadlGeneratorGrammarsSupport.class.equals(createMe)) {\n                return createMe.cast(new WadlGeneratorGrammarsSupport());\n            }\n            if (WadlGeneratorApplicationDoc.class.equals(createMe)) {\n                return createMe.cast(new WadlGeneratorApplicationDoc());\n            }\n            throw new IllegalArgumentException(\"Unsupported generator class: \" + createMe.getName());\n        }\n\n        @Override\n        public <T> List<ServiceHolder<T>> getAllServiceHolders(Class<T> contractOrImpl, Annotation... qualifiers) {\n            return Collections.emptyList();\n        }\n\n        @Override\n        public <T> T getInstance(Class<T> contractOrImpl, Annotation... qualifiers) {\n            return null;\n        }\n\n        @Override\n        public <T> T getInstance(Class<T> contractOrImpl, String classAnalyzer) {\n            return null;\n        }\n\n        @Override\n        public <T> T getInstance(Class<T> contractOrImpl) {\n            return null;\n        }\n\n        @Override\n        public <T> T getInstance(Type contractOrImpl) {\n            return null;\n        }\n\n        @Override\n        public Object getInstance(ForeignDescriptor foreignDescriptor) {\n            return null;\n        }\n\n        @Override\n        public ForeignDescriptor createForeignDescriptor(Binding binding) {\n            throw new UnsupportedOperationException();\n        }\n\n        @Override\n        public <T> List<T> getAllInstances(Type contractOrImpl) {\n            return Collections.emptyList();\n        }\n\n        @Override\n        public void inject(Object injectMe) {\n        }\n\n        @Override\n        public void inject(Object injectMe, String classAnalyzer) {\n        }\n\n        @Override\n        public void preDestroy(Object preDestroyMe) {\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778295565341}}
