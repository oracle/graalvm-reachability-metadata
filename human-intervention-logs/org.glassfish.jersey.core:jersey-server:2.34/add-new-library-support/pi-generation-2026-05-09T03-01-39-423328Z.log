ng response = invoke(\"arrays/missing\");\n\n        assertThat(response).isEqualTo(\"0\");\n    }\n\n    private static String invoke(String requestPath) throws Exception {\n        ApplicationHandler handler = new ApplicationHandler(new ResourceConfig(ArrayResource.class));\n        try {\n            ContainerRequest request = new ContainerRequest(\n                    BASE_URI,\n                    BASE_URI.resolve(requestPath),\n                    \"GET\",\n                    null,\n                    new TestPropertiesDelegate(),\n                    handler.getConfiguration());\n            ByteArrayOutputStream output = new ByteArrayOutputStream();\n            ContainerResponse response = handler.apply(request, output).get(10, TimeUnit.SECONDS);\n\n            assertThat(response.getStatus()).isEqualTo(200);\n            return output.toString(StandardCharsets.UTF_8);\n        } finally {\n            handler.onShutdown(null);\n        }\n    }\n\n    @Path(\"arrays\")\n    @Produces(MediaType.TEXT_PLAIN)\n    public static class ArrayResource {\n        @GET\n        @Path(\"present\")\n        public String present(@QueryParam(\"number\") int[] numbers) {\n            return Arrays.toString(numbers);\n        }\n\n        @GET\n        @Path(\"default\")\n        public String defaulted(@DefaultValue(\"21\") @QueryParam(\"number\") int[] numbers) {\n            return Arrays.toString(numbers);\n        }\n\n        @GET\n        @Path(\"missing\")\n        public String missing(@QueryParam(\"value\") String[] values) {\n            return Integer.toString(values.length);\n        }\n    }\n\n    private static final class TestPropertiesDelegate implements PropertiesDelegate {\n        private final Map<String, Object> properties = new LinkedHashMap<>();\n\n        @Override\n        public Object getProperty(String name) {\n            return properties.get(name);\n        }\n\n        @Override\n        public Collection<String> getPropertyNames() {\n