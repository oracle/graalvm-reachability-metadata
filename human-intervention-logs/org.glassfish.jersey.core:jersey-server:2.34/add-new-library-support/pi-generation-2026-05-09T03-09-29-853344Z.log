  package org_glassfish_jersey_core.jersey_server;
  
  import static org.assertj.core.api.Assertions.assertThatThrownBy;
  
  import java.io.ByteArrayInputStream;
  import java.io.File;
  import java.io.InputStream;
  import java.lang.annotation.Annotation;
  import java.lang.reflect.Type;
  import java.nio.charset.StandardCharsets;
  import java.util.Collections;
  import java.util.List;
  
  import javax.ws.rs.ProcessingException;
  
  import org.glassfish.jersey.internal.inject.Binder;
  import org.glassfish.jersey.internal.inject.Binding;
  import org.glassfish.jersey.internal.inject.ForeignDescriptor;
  import org.glassfish.jersey.internal.inject.InjectionManager;
  import org.glassfish.jersey.internal.inject.ServiceHolder;
  import org.glassfish.jersey.server.wadl.config.WadlGeneratorConfig;
  import org.glassfish.jersey.server.wadl.internal.generators.WadlGeneratorApplicationDoc;
  import org.glassfish.jersey.server.wadl.internal.generators.WadlGeneratorGrammarsSupport;
  import org.junit.jupiter.api.Test;
  
  public class WadlGeneratorLoaderTest {
      @Test
      void setPropertyUsesDirectAssignmentAndStringConstructorConversion() {
          WadlGeneratorConfig config = WadlGeneratorConfig
                  .generator(WadlGeneratorGrammarsSupport.class)
                  .prop("grammarsFile", new File("src/test/resources/wadl-loader-grammars.xml"))
                  .prop("overrideGrammars", "true")
                  .build();
  
          loadUntilGeneratorInitialization(config);
      }
  
      @Test
      void setPropertyResolvesClasspathFileProperty() {
          WadlGeneratorConfig config = WadlGeneratorConfig
                  .generator(WadlGeneratorApplicationDoc.class)
                  .prop("applicationDocsFile", "classpath:/wadl-loader-application-doc.xml")
                  .build();
  
          loadUntilGeneratorInitialization(config);
      }
  
      @Test
      void setPropertyCreatesNonClasspathFileProperty() {
          WadlGeneratorConfig config = WadlGeneratorConfig
                  .generator(WadlGeneratorApplicationDoc.class)
                  .prop("applicationDocsFile", "build/tmp/wadl-loader-application-doc.xml")
                  .build();
  
          loadUntilGeneratorInitialization(config);
      }
  
      @Test
      void setPropertyLoadsInputStreamPropertyFromClasspath() {
          WadlGeneratorConfig config = WadlGeneratorConfig
                  .generator(WadlGeneratorApplicationDoc.class)
                  .prop("applicationDocsStream", "wadl-loader-application-doc.xml")
                  .build();
          ClassLoader originalLoader = Thread.currentThread().getContextClassLoader();
          Thread.currentThread().setContextClassLoader(new InMemoryResourceClassLoader(originalLoader));
          try {
              loadUntilGeneratorInitialization(config);
          } finally {
              Thread.currentThread().setContextClassLoader(originalLoader);
          }
      }
  
      private static void loadUntilGeneratorInitialization(WadlGeneratorConfig config) {
          assertThatThrownBy(() -> config.createWadlGenerator(new MinimalInjectionManager()))
                  .isInstanceOf(ProcessingException.class)
                  .hasCauseInstanceOf(Exception.class);
      }
  
      private static final class InMemoryResourceClassLoader extends ClassLoader {
          private static final byte[] APPLICATION_DOC = "<applicationDocs />".getBytes(StandardCharsets.UTF_8);
  
          private InMemoryResourceClassLoader(ClassLoader parent) {
              super(parent);
          }
  
          @Override
          public InputStream getResourceAsStream(String name) {
              if ("wadl-loader-application-doc.xml".equals(name)) {
                  return new ByteArrayInputStream(APPLICATION_DOC);
              }
              return super.getResourceAsStream(name);
          }
      }
  
      private static final class MinimalInjectionManager implements InjectionManager {
          @Override
          public void completeRegistration() {
          }
  
          @Override
          public void shutdown() {
          }
  
          @Override
          public void register(Binding binding) {
              throw new UnsupportedOperationException();
          }
  
          @Override
          public void register(Iterable<Binding> descriptors) {
              throw new UnsupportedOperationException();
          }
  
          @Override
          public void register(Binder binder) {
              throw new UnsupportedOperationException();
          }
  
          @Override
          public void register(Object provider) throws IllegalArgumentException {
              throw new UnsupportedOperationException();
          }
  
          @Override
          public boolean isRegistrable(Class<?> clazz) {
              return false;
          }
  
          @Override
          public <T> T createAndInitialize(Class<T> createMe) {
              if (WadlGeneratorGrammarsSupport.class.equals(createMe)) {
                  return createMe.cast(new WadlGeneratorGrammarsSupport());
              }
              if (WadlGeneratorApplicationDoc.class.equals(createMe)) {
                  return createMe.cast(new WadlGeneratorApplicationDoc());
              }
              throw new IllegalArgumentException("Unsupported generator class: " + createMe.getName());
          }
  
          @Override
          public <T> List<ServiceHolder<T>> getAllServiceHolders(Class<T> contractOrImpl, Annotation... qualifiers) {
              return Collections.emptyList();
          }
  
          @Override
          public <T> T getInstance(Class<T> contractOrImpl, Annotation... qualifiers) {
              return null;
          }
  
          @Override
          public <T> T getInstance(Class<T> contractOrImpl, String classAnalyzer) {
              return null;
          }
  
          @Override
          public <T> T getInstance(Class<T> contractOrImpl) {
              return null;
          }
  
          @Override
          public <T> T getInstance(Type contractOrImpl) {
              return null;
          }
  
          @Override
          public Object getInstance(ForeignDescriptor foreignDescriptor) {
              return null;
          }
  
          @Override
          public ForeignDescriptor createForeignDescriptor(Binding binding) {
              throw new UnsupportedOperationException();
          }
  
          @Override
          public <T> List<T> getAllInstances(Type contractOrImpl) {
              return Collections.emptyList();
          }
  
          @Override
          public void inject(Object injectMe) {
          }
  
          @Override
          public void inject(Object injectMe, String classAnalyzer) {
          }
  
          @Override
          public void preDestroy(Object preDestroyMe) {
          }
      }
  }
