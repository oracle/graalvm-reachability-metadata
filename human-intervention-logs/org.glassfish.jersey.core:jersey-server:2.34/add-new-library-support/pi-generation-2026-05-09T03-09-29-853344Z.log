ey_server;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.IOException;\nimport java.io.InputStream;\nimport java.net.URL;\nimport java.net.URLConnection;\nimport java.net.URLStreamHandler;\nimport java.net.URLStreamHandlerFactory;\nimport java.nio.charset.StandardCharsets;\nimport java.util.Collections;\nimport java.util.Enumeration;\nimport java.util.List;\nimport java.util.concurrent.atomic.AtomicBoolean;\n\nimport org.glassfish.jersey.server.internal.scanning.PackageNamesScanner;\nimport org.junit.jupiter.api.Test;\n\npublic class VfsSchemeResourceFinderFactoryInnerVfsResourceFinderTest {\n    private static final AtomicBoolean URL_HANDLER_FACTORY_REGISTERED = new AtomicBoolean();\n    private static final String PACKAGE_NAME = \"example.vfs\";\n    private static final String PACKAGE_PATH = \"example/vfs\";\n    private static final String RESOURCE_NAME = \"resource.txt\";\n    private static final byte[] RESOURCE_CONTENT = \"vfs resource\".getBytes(StandardCharsets.UTF_8);\n\n    @Test\n    void packageScannerReadsLeafResourceFromVfsUrl() throws Exception {\n        installVfsUrlHandlerFactory();\n        VfsUrlStreamHandlerFactory.root = new VirtualFile(\"root\", false, List.of(\n                new VirtualFile(RESOURCE_NAME, true, RESOURCE_CONTENT)));\n        PackageNamesScanner.setResourcesProvider(new TestResourcesProvider());\n\n        PackageNamesScanner scanner = new PackageNamesScanner(\n                getClass().getClassLoader(), new String[] {PACKAGE_NAME}, false);\n        try {\n            assertThat(scanner.hasNext()).isTrue();\n            assertThat(scanner.next()).isEqualTo(RESOURCE_NAME);\n            try (InputStream input = scanner.open()) {\n                assertThat(input.readAllBytes()).isEqualTo(RESOURCE_CONTENT);\n            }\n            assertThat(scanner.hasNext()).isFalse();\n        } finally {\n            scanner.close();\n        }\n    }\n\n    private static void installVfsUrlHandlerFactory() {\n        if (URL_HANDLER_FACTORY_REGISTERED.compareAndSet(false, true)) {\n            URL.setURLStreamHandlerFactory(new VfsUrlStreamHandlerFactory());\n        }\n    }\n\n    private static final class TestResourcesProvider extends PackageNamesScanner.ResourcesProvider {\n        @Override\n        public Enumeration<URL> getResources(String name, ClassLoader classLoader) throws IOException {\n            if (PACKAGE_PATH.equals(name)) {\n                return Collections.enumeration(List.of(new URL(\"vfs:/virtual-scan-root\")));\n            }\n            return classLoader.getResources(name);\n        }\n    }\n\n    private static final class VfsUrlStreamHandlerFactory implements URLStreamHandlerFactory {\n        private static volatile VirtualFile root;\n\n        @Override\n        public URLStreamHandler createURLStreamHandler(String protocol) {\n            if (\"vfs\".equals(protocol)) {\n                return new VfsUrlStreamHandler();\n            }\n            return null;\n        }\n    }\n\n    private static final class VfsUrlStreamHandler extends URLStreamHandler {\n        @Override\n        protected URLConnection openConnection(URL url) {\n            return new URLConnection(url) {\n                @Override\n                public void connect() {\n                }\n\n                @Override\n                public Object getContent() {\n                    return VfsUrlStreamHandlerFactory.root;\n                }\n            };\n        }\n    }\n\n    public static final class VirtualFile {\n        private final String name;\n        private final boolean leaf;\n        private final byte[] content;\n        private final List<VirtualFile> children;\n\n        private VirtualFile(String name, boolean leaf, byte[] content) {\n            this.name = name;\n            this.leaf = leaf;\n            this.content = content.clone();\n            this.children = Collections.emptyList();\n        }\n\n        private VirtualFile(String name, boolean leaf, List<VirtualFile> children) {\n            this.name = name;\n            this.leaf = leaf;\n            this.content = new byte[0];\n            this.children = List.copyOf(children);\n        }\n\n        public InputStream openStream() {\n            return new ByteArrayInputStream(content);\n        }\n\n        public String getName() {\n            return name;\n        }\n\n        public boolean isLeaf() {\n            return leaf;\n        }\n\n        public List<VirtualFile> getChildren() {\n            return children;\n        }\n\n        public List<VirtualFile> getChildrenRecursively() {\n            return children;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 865, "output": 1669, "cacheRead": 19456, "cacheWrite": 0, "totalTokens": 21990, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778296134172, "responseId": "resp_0c34d9f2d2866ef70169fea5469a2c8197a7dedefb8a921252"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_tZQjLu6DS7VBed21r4cYCc8T|fc_0c34d9f2d2866ef70169fea55110248197a13951bfa6832b9f", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 4822 bytes to tests/src/org.glassfish.jersey.core/jersey-server/2.34/src/test/java/org_glassfish_jersey_core/jersey_server/VfsSchemeResourceFinderFactoryInnerVfsResourceFinderTest.java"}], "isError": false, "timestamp": 1778296150148}]}
