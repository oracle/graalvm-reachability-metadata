    \"parentOnly\",\n                new Class[] {String.class}\n        );\n\n        assertThat(method.getName()).isEqualTo(\"parentOnly\");\n        assertThat(method.getDeclaringClass()).isEqualTo(MethodParent.class);\n    }\n\n    @Test\n    void collectsDeclaredMethodsFromTypeHierarchy() {\n        final List methods = ReflectUtils.addAllMethods(MethodChild.class, new ArrayList());\n\n        assertThat(methods)\n                .extracting(method -> ((Method) method).getName())\n                .contains(\"childOnly\", \"parentOnly\", \"interfaceOnly\");\n    }\n\n    @Test\n    void findsTheOnlyInterfaceMethod() {\n        final Method method = ReflectUtils.findInterfaceMethod(SingleMethodInterface.class);\n\n        assertThat(method.getName()).isEqualTo(\"newInstance\");\n        assertThat(method.getDeclaringClass()).isEqualTo(SingleMethodInterface.class);\n    }\n\n    @Test\n    void definesClassWithSuppliedClassLoader() throws Exception {\n        final byte[] bytes = Base64.getDecoder().decode(GENERATED_CLASS_BYTES);\n        try {\n            final Class<?> definedClass = ReflectUtils.defineClass(\n                    GENERATED_CLASS_NAME,\n                    bytes,\n                    ReflectUtilsTest.class.getClassLoader()\n            );\n\n            assertThat(definedClass.getName()).isEqualTo(GENERATED_CLASS_NAME);\n            assertThat(definedClass.getClassLoader()).isEqualTo(ReflectUtilsTest.class.getClassLoader());\n        } catch (Exception exception) {\n            rethrowIfNotNativeImageDynamicClassLoadingFailure(exception);\n        } catch (Error error) {\n            rethrowIfNotNativeImageDynamicClassLoadingFailure(error);\n        }\n    }\n\n    private static void rethrowIfNotNativeImageDynamicClassLoadingFailure(Exception exception) throws Exception {\n        final Throwable cause = exception.getCause();\n        if (cause instanceof Error) {\n            rethrowIfNotNativeImageDynamicClassLoadingFailure((Error) cause);\n 