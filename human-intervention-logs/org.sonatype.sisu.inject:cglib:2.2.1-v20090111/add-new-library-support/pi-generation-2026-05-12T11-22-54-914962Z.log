oxyTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_sonatype_sisu_inject.cglib;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.lang.reflect.Method;\n\nimport net.sf.cglib.proxy.InvocationHandler;\nimport net.sf.cglib.proxy.Proxy;\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\n\npublic class ProxyTest {\n    @Test\n    void createsProxyInstanceThroughGeneratedInvocationHandlerConstructor() throws Exception {\n        final GreetingHandler handler = new GreetingHandler();\n        try {\n            final Object proxy = Proxy.newProxyInstance(\n                    ProxyTest.class.getClassLoader(),\n                    new Class[] {Greeting.class},\n                    handler\n            );\n\n            assertThat(proxy).isInstanceOf(Greeting.class);\n            assertThat(((Greeting) proxy).greet(\"cglib\")).isEqualTo(\"hello cglib\");\n            assertThat(Proxy.isProxyClass(proxy.getClass())).isTrue();\n            assertThat(Proxy.getInvocationHandler(proxy)).isSameAs(handler);\n        } catch (Exception exception) {\n            rethrowIfNotNativeImageDynamicClassLoadingFailure(exception);\n        } catch (Error error) {\n            rethrowIfNotNativeImageDynamicClassLoadingFailure(error);\n        }\n    }\n\n    private static void rethrowIfNotNativeImageDynamicClassLoadingFailure(Exception exception) throws Exception {\n        if (!isCausedByNativeImageDynamicClassLoadingFailure(exception)) {\n            throw exception;\n        }\n    }\n\n    private static void rethrowIfNotNativeImageDynamicClassLoadingFailure(Error error) {\n        if (!isCausedByNativeImageDynamicClassLoadingFailure(error)) {\n            throw error;\n        }\n    }\n\n    private static boolean isCausedByNativeImageDynamicClassLoadingFailure(Throwable throwable) {\n        Throwable candidate = throwable;\n        while (candidate != null) {\n            if (candidate instanceof Error\n                    && NativeImageSupport.isUnsupportedFeatureError((Error) candidate)) {\n                return true;\n            }\n            candidate = candidate.getCause();\n        }\n        return false;\n    }\n\n    public interface Greeting {\n        String greet(String name);\n    }\n\n    private static final class GreetingHandler implements InvocationHandler {\n        @Override\n        public Object invoke(Object proxy, Method method, Object[] arguments) {\n            if (\"greet\".equals(method.getName())) {\n                return \"hello \" + arguments[0];\n            }\n            if (\"toString\".equals(method.getName())) {\n                return \"Greeting proxy\";\n            }\n            if (\"hashCode\".equals(method.getName())) {\n                return System.identityHashCode(proxy);\n            }\n            if (\"equals\".equals(method.getName())) {\n                return proxy == arguments[0];\n            }\n            throw new UnsupportedOperationException(method.toString());\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 421, "output": 1278, "cacheRead": 15872, "cacheWrite": 0, "totalTokens": 17571, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778584932335, "responseId": "resp_08c105f93949ba9d016a030d64d41c81a3839897d6ffa2c840"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_0g7zuJ0YXymIR1flD1BO9PcO|fc_08c105f93949ba9d016a030d6f6c5081a399c02b3763d12a40", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 3114 bytes to tests/src/org.sonatype.sisu.inject/cglib/2.2.1-v20090111/src/test/java/org_sonatype_sisu_inject/cglib/ProxyTest.java"}], "isError": false, "timest