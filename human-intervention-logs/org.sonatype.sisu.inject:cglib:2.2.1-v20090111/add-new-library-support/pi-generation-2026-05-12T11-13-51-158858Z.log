ic void rethrowIfNotNativeImageDynamicClassLoadingFailure(Error error) {\n        if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n            throw error;\n        }\n    }\n\n    public static class GreetingService {\n        public String message(String name) {\n            return \"plain:\" + name;\n        }\n    }\n\n    private static final class GreetingInterceptor implements MethodInterceptor {\n        @Override\n        public Object intercept(Object object, Method method, Object[] arguments, MethodProxy proxy) throws Throwable {\n            if (\"message\".equals(method.getName())) {\n                return \"enhanced:\" + arguments[0];\n            }\n            return proxy.invokeSuper(object, arguments);\n        }\n    }\n}\n"}
