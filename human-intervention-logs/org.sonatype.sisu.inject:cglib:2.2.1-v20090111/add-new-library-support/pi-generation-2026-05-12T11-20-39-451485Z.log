ansform.impl.AddDelegateTransformer;\nimport org.junit.jupiter.api.Test;\nimport org.objectweb.asm.ClassReader;\nimport org.objectweb.asm.ClassWriter;\n"}, {"oldText": "    void emitsDelegateFieldAndForwardingMethodsForAbstractInterfaceMethods() {\n        final AddDelegateTransformer transformer = new AddDelegateTransformer(\n                new Class[] {GreetingContract.class},\n                GreetingDelegate.class\n        );\n        final ClassWriter writer = new ClassWriter(ClassWriter.COMPUTE_MAXS);\n        transformer.setTarget(writer);\n\n        transformer.begin_class(\n                Constants.V1_5,\n                Constants.ACC_PUBLIC,\n                \"org_sonatype_sisu_inject.cglib.GeneratedDelegatingService\",\n                Type.getType(PlainService.class),\n                Constants.TYPES_EMPTY,\n                \"GeneratedDelegatingService.java\"\n        );\n        transformer.end_class();\n\n        final byte[] generatedClass = writer.toByteArray();\n", "newText": "    void emitsDelegateFieldAndForwardingMethodsForAbstractInterfaceMethods() throws Exception {\n        final AddDelegateTransformer transformer = new AddDelegateTransformer(\n                new Class[] {GreetingContract.class},\n                GreetingDelegate.class\n        );\n        final ClassReader reader = readClass(PlainService.class);\n        final ClassWriter writer = new ClassWriter(ClassWriter.COMPUTE_MAXS);\n        final TransformingClassGenerator generator = new TransformingClassGenerator(\n                new ClassReaderGenerator(reader, 0),\n                transformer\n        );\n\n        generator.generateClass(writer);\n\n        final byte[] generatedClass = writer.toByteArray();\n"}, {"oldText": "    public interface GreetingContract {\n", "newText": "    private static ClassReader readClass(Class<?> type) throws Exception {\n        final String resourceName = type.getName().replace('.', '/') + \".class\";\n        try (InputStream input = type.