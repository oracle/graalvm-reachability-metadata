[tool-call] delta {"path":"tests/src/org.sonatype.sisu.inject/cglib/2.2.1-v20090111/src/test/java/org_sonatype_sisu_inject/cglib/AddDelegateTransformerTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_sonatype_sisu_inject.cglib;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport net.sf.cglib.core.Constants;\nimport net.sf.cglib.transform.impl.AddDelegateTransformer;\nimport org.junit.jupiter.api.Test;\nimport org.objectweb.asm.ClassWriter;\nimport org.objectweb.asm.Type;\n\npublic class AddDelegateTransformerTest {\n    @Test\n    void emitsDelegateFieldAndForwardingMethodsForAbstractInterfaceMethods() {\n        final AddDelegateTransformer transformer = new AddDelegateTransformer(\n                new Class[] {GreetingContract.class},\n                GreetingDelegate.class\n        );\n        final ClassWriter writer = new ClassWriter(ClassWriter.COMPUTE_MAXS);\n        transformer.setTarget(writer);\n\n        transformer.begin_class(\n                Constants.V1_5,\n                Constants.ACC_PUBLIC,\n                \"org_sonatype_sisu_inject.cglib.GeneratedDelegatingService\",\n                Type.getType(PlainService.class),\n                Constants.TYPES_EMPTY,\n                \"GeneratedDelegatingService.java\"\n        );\n        transformer.end_class();\n\n        assertThat(writer.toByteArray()).startsWith(new byte[] {(byte) 0xCA, (byte) 0xFE, (byte) 0xBA, (byte) 0xBE});\n    }\n\n    public interface GreetingContract {\n        String greet(String name);\n\n        int nameLength(String name);\n    }\n\n    public static class GreetingDelegate {\n        private final Object owner;\n\n        public GreetingDelegate(Object owner) {\n            this.owner = owner;\n        }\n\n        public String greet(String name) {\n            return owner.getClass().getSimpleName() + \":\" + name;\n        }\n\n        public int nameLength(String name) {\n            return name.length();\n        }\n    }\n\n    public static class PlainService {\n    }\n}\n"}
