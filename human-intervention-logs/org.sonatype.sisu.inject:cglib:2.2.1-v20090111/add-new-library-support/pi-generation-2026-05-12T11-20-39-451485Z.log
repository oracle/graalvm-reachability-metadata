  package org_sonatype_sisu_inject.cglib;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.InputStream;
  import java.nio.charset.StandardCharsets;
  
  import net.sf.cglib.transform.ClassReaderGenerator;
  import net.sf.cglib.transform.TransformingClassGenerator;
  import net.sf.cglib.transform.impl.AddDelegateTransformer;
  import org.junit.jupiter.api.Test;
  import org.objectweb.asm.ClassReader;
  import org.objectweb.asm.ClassWriter;
  
  public class AddDelegateTransformerTest {
      @Test
      void emitsDelegateFieldAndForwardingMethodsForAbstractInterfaceMethods() throws Exception {
          final AddDelegateTransformer transformer = new AddDelegateTransformer(
                  new Class[] {GreetingContract.class},
                  GreetingDelegate.class
          );
          final ClassReader reader = readClass(PlainService.class);
          final ClassWriter writer = new ClassWriter(ClassWriter.COMPUTE_MAXS);
          final TransformingClassGenerator generator = new TransformingClassGenerator(
                  new ClassReaderGenerator(reader, 0),
                  transformer
          );
  
          generator.generateClass(writer);
  
          final byte[] generatedClass = writer.toByteArray();
          final String generatedConstantPool = new String(generatedClass, StandardCharsets.ISO_8859_1);
          assertThat(generatedClass).startsWith(new byte[] {(byte) 0xCA, (byte) 0xFE, (byte) 0xBA, (byte) 0xBE});
          assertThat(generatedConstantPool)
                  .contains("$CGLIB_DELEGATE")
                  .contains("greet")
                  .contains("nameLength");
      }
  
      private static ClassReader readClass(Class<?> type) throws Exception {
          final String resourceName = type.getName().replace('.', '/') + ".class";
          try (InputStream input = type.getClassLoader().getResourceAsStream(resourceName)) {
              assertThat(input).isNotNull();
              return new ClassReader(input);
          }
      }
  
      public interface GreetingContract {
          String greet(String name);
  
          int nameLength(String name);
      }
  
      public static class GreetingDelegate {
          private final Object owner;
  
          public GreetingDelegate(Object owner) {
              this.owner = owner;
          }
  
          public String greet(String name) {
              return owner.getClass().getSimpleName() + ":" + name;
          }
  
          public int nameLength(String name) {
              return name.length();
          }
      }
  
      public static class PlainService {
      }
  }
