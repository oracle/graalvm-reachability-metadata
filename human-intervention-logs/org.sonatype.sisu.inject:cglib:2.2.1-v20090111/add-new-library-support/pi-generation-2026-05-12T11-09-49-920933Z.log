[tool-call] delta {"path":"tests/src/org.sonatype.sisu.inject/cglib/2.2.1-v20090111/src/test/java/org_sonatype_sisu_inject/cglib/ReflectUtilsTest.java","edits":[{"oldText":"        final Constructor arrayListConstructor = ReflectUtils.findConstructor(\"java.util.ArrayList()\");\n        final Constructor stringConstructor = ReflectUtils.findConstructor(\"String(byte[])\");","newText":"        final Constructor<?> arrayListConstructor = ReflectUtils.findConstructor(\"java.util.ArrayList()\");\n        final Constructor<?> stringConstructor = ReflectUtils.findConstructor(\"String(byte[])\");"},{"oldText":"            final Class definedClass = ReflectUtils.defineClass(\n                    GENERATED_CLASS_NAME,\n                    bytes,\n                    ReflectUtilsTest.class.getClassLoader()\n            );\n\n            assertThat(definedClass.getName()).isEqualTo(GENERATED_CLASS_NAME);\n            assertThat(definedClass.getClassLoader()).isEqualTo(ReflectUtilsTest.class.getClassLoader());\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    public interface SingleMethodInterface {","newText":"            final Class<?> definedClass = ReflectUtils.defineClass(\n                    GENERATED_CLASS_NAME,\n                    bytes,\n                    ReflectUtilsTest.class.getClassLoader()\n            );\n\n            assertThat(definedClass.getName()).isEqualTo(GENERATED_CLASS_NAME);\n            assertThat(definedClass.getClassLoader()).isEqualTo(ReflectUtilsTest.class.getClassLoader());\n        } catch (Exception exception) {\n            rethrowIfNotNativeImageDynamicClassLoadingFailure(exception);\n        } catch (Error error) {\n            rethrowIfNotNativeImageDynamicClassLoadingFailure(error);\n        }\n    }\n\n    private static void rethrowIfNotNativeImageDynamicClassLoadingFailure(Exception exception) throws Exception {\n        final Throwable cause = exception.getCause();\n        if (cause instanceof Error) {\n            rethrowIfNotNativeImageDynamicClassLoadingFailure((Error) cause);\n            return;\n        }\n        throw exception;\n    }\n\n    private static void rethrowIfNotNativeImageDynamicClassLoadingFailure(Error error) {\n        if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n            throw error;\n        }\n    }\n\n    public interface SingleMethodInterface {"}]}
