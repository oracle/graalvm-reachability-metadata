RATED_CLASS_NAME =\n            \"org_sonatype_sisu_inject.cglib.GeneratedByReflectUtils\";\n    private static final String GENERATED_CLASS_BYTES = \"\"\"\n            yv66vgAAADQADAoAAwAIBwAJBwAKAQAGPGluaXQ+AQADKClWAQAEQ29kZQEAClNvdXJjZUZp\\\n            bGUMAAQABQEANm9yZ19zb25hdHlwZV9zaXN1X2luamVjdC9jZ2xpYi9HZW5lcmF0ZWRCeVJlZm\\\n            xlY3RVdGlscwEAEGphdmEvbGFuZy9PYmplY3QBABxHZW5lcmF0ZWRCeVJlZmxlY3RVdGlscy5q\\\n            YXZhACEAAgADAAAAAAABAAEABAAFAAEABgAAAAAAEQABAAEAAAAFKrcAAbEAAAAAAAEABwAAAA\\\n            AAAgAL\\\n            \"\"\";\n\n    @Test\n    void findsConstructorsFromQualifiedSimpleAndPrimitiveArrayTypeNames() {\n        final Constructor arrayListConstructor = ReflectUtils.findConstructor(\"java.util.ArrayList()\");\n        final Constructor stringConstructor = ReflectUtils.findConstructor(\"String(byte[])\");\n\n        assertThat(arrayListConstructor.getDeclaringClass()).isEqualTo(ArrayList.class);\n        assertThat(stringConstructor.getDeclaringClass()).isEqualTo(String.class);\n        assertThat(stringConstructor.getParameterTypes()).containsExactly(byte[].class);\n    }\n\n    @Test\n    void findsDeclaredMethodFromDescriptor() {\n        final Method method = ReflectUtils.findMethod(\"java.util.ArrayList.size()\");\n\n        assertThat(method.getName()).isEqualTo(\"size\");\n        assertThat(method.getDeclaringClass()).isEqualTo(ArrayList.class);\n    }\n\n    @Test\n    void createsInstanceThroughDeclaredConstructor() {\n        final Object value = ReflectUtils.newInstance(\n                PrivateConstructed.class,\n                new Class[] {String.class},\n                new Object[] {\"created\"}\n        );\n\n        assertThat(value).isInstanceOf(PrivateConstructed.class);\n        assertThat(((PrivateConstructed) value).value()).isEqualTo(\"created\");\n    }\n\n    @Test\n    void findsDeclaredMethodOnSuperclass() throws NoSuchMethodException {\n        final Method method = ReflectUtils.findDeclaredMethod(\n                MethodChild.class,\n                \"parentOnly\",\n                new Class[] {String.class}\n        );\n\n        assertThat(method.getName()).isEqualTo(\"parentOnly\");\n        assertThat(method.getDeclaringClass()).isEqualTo(MethodParent.class);\n    }\n\n    @Test\n    void collectsDeclaredMethodsFromTypeHierarchy() {\n        final List methods = ReflectUtils.addAllMethods(MethodChild.class, new ArrayList());\n\n        assertThat(methods)\n                .extracting(method -> ((Method) method).getName())\n                .contains(\"childOnly\", \"parentOnly\", \"interfaceOnly\");\n    }\n\n    @Test\n    void findsTheOnlyInterfaceMethod() {\n        final Method method = ReflectUtils.findInterfaceMethod(SingleMethodInterface.class);\n\n        assertThat(method.getName()).isEqualTo(\"newInstance\");\n        assertThat(method.getDeclaringClass()).isEqualTo(SingleMethodInterface.class);\n    }\n\n    @Test\n    void definesClassWithSuppliedClassLoader() throws Exception {\n        final byte[] bytes = Base64.getDecoder().decode(GENERATED_CLASS_BYTES);\n        try {\n            final Class definedClass = ReflectUtils.defineClass(\n                    GENERATED_CLASS_NAME,\n                    bytes,\n                    ReflectUtilsTest.class.getClassLoader()\n            );\n\n            assertThat(definedClass.getName()).isEqualTo(GENERATED_CLASS_NAME);\n            assertThat(definedClass.getClassLoader()).isEqualTo(ReflectUtilsTest.class.getClassLoader());\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    public interface SingleMethodInterface {\n        Object newInstance();\n    }\n\n    public interface MethodContract {\n        void interfaceOnly();\n    }\n\n    public static class MethodParent {\n        public String parentOnly(String value) {\n            return \"parent:\" + value;\n        }\n    }\n\n    public static class MethodChild extends MethodParent implements MethodContract {\n        public int childOnly() {\n            return 42;\n        }\n\n        @Override\n        public void interfaceOnly() {\n        }\n    }\n\n    public static class PrivateConstructed {\n        private final String value;\n\n        private PrivateConstructed(String value) {\n            this.value = value;\n        }\n\n        String value() {\n            return value;\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778584116360}]}
