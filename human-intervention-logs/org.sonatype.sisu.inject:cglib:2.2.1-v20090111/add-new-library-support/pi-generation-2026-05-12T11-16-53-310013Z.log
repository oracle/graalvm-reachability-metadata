e": "toolCall", "id": "call_bANR93vwFTYA51iDptke4HF2|fc_03ad5d81f3ef8475016a030c026a1081958d326fc575f3d0e6", "name": "write", "arguments": {"path": "tests/src/org.sonatype.sisu.inject/cglib/2.2.1-v20090111/src/test/java/org_sonatype_sisu_inject/cglib/AbstractClassLoaderTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_sonatype_sisu_inject.cglib;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.InputStream;\nimport java.util.ArrayList;\nimport java.util.Base64;\nimport java.util.List;\n\nimport net.sf.cglib.transform.AbstractClassLoader;\nimport net.sf.cglib.transform.ClassFilter;\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\n\npublic class AbstractClassLoaderTest {\n    private static final String TRANSFORMED_CLASS_NAME =\n            \"org_sonatype_sisu_inject.cglib.GeneratedByReflectUtils\";\n    private static final String TRANSFORMED_RESOURCE_NAME =\n            \"org_sonatype_sisu_inject/cglib/GeneratedByReflectUtils.class\";\n    private static final String TRANSFORMED_CLASS_BYTES = \"\"\"\n            yv66vgAAADQADQoAAgADBwAEDAAFAAYBABBqYXZhL2xhbmcvT2JqZWN0AQAGPGluaXQ+AQ\\\n            ADKClWBwAIAQA2b3JnX3NvbmF0eXBlX3Npc3VfaW5qZWN0L2NnbGliL0dlbmVyYXRlZEJ5Um\\\n            VmbGVjdFV0aWxzAQAEQ29kZQEAD0xpbmVOdW1iZXJUYWJsZQEAClNvdXJjZUZpbGUBABxH\\\n            ZW5lcmF0ZWRCeVJlZmxlY3RVdGlscy5qYXZhACEABwACAAAAAAABAAEABQAGAAEACQAA\\\n            AB0AAQABAAAABSq3AAGxAAAAAQAKAAAABgABAAAAAgABAAsAAAACAAw=\\\n            \"\"\";\n\n    @Test\n    void delegatesRejectedClassNamesToParentLoader() throws Exception {\n        final InMemoryClassPath classPath = new InMemoryClassPath(transformedClassBytes());\n        final PassthroughClassLoader loader = new PassthroughClassLoader(classPath, transformedClassFilter());\n\n        final Class loadedClass = loader.loadClass(\"java.lang.String\");\n\n        assertThat(loadedClass).isSameAs(String.class);\n        assertThat(loader.wasPostProcessed()).isFalse();\n        assertThat(classPath.requestedResources()).isEmpty();\n    }\n\n    @Test\n    void transformsAcceptedClassBytesAndReturnsAlreadyLoadedClass() throws Exception {\n        final InMemoryClassPath classPath = new InMemoryClassPath(transformedClassBytes());\n        final PassthroughClassLoader loader = new PassthroughClassLoader(classPath, transformedClassFilter());\n\n        try {\n            final Class firstLoad = loader.loadClass(TRANSFORMED_CLASS_NAME);\n            final Class secondLoad = loader.loadClass(TRANSFORMED_CLASS_NAME);\n\n            assertThat(firstLoad.getName()).isEqualTo(TRANSFORMED_CLASS_NAME);\n            assertThat(firstLoad.getClassLoader()).isSameAs(loader);\n            assertThat(secondLoad).isSameAs(firstLoad);\n            assertThat(loader.wasPostProcessed()).isTrue();\n            assertThat(classPath.requestedResources()).containsExactly(TRANSFORMED_RESOURCE_NAME);\n        } catch (Exception exception) {\n            rethrowIfNotNativeImageDynamicClassLoadingFailure(exception);\n        } catch (Error error) {\n            rethrowIfNotNativeImageDynamicClassLoadingFailure(error);\n        }\n    }\n\n    private static ClassFilter transformedClassFilter() {\n        return className -> TRANSFORMED_CLASS_NAME.equals(className);\n    }\n\n    private static byte[] transformedClassBytes() {\n        final byte[] bytes = Base64.getMimeDecoder().decode(TRANSFORMED_CLASS_BYTES);\n        bytes[6] = 0;\n        bytes[7] = 49;\n        return bytes;\n    }\n\n    private static void rethrowIfNotNativeImageDynamicClassLoadingFailure(Exception exception) throws Exception {\n        if (!isCausedByNativeImageDynamicClassLoadingFailure(exception)) {\n            throw exception;\n        }\n    }\n\n    private static void rethrowIfNotNativeImageDynamicClassLoadingFailure(Error error) {\n        if (!isCausedByNativeImageDynamicClassLoadingFailure(error)) {\n            throw error;\n        }\n    }\n\n    private static boolean isCausedByNativeImageDynamicClassLoadingFailure(Throwable throwable) {\n        Throwable candidate = throwable;\n        while (candidate != null) {\n            if (candidate instanceof Error\n                    && NativeImageSupport.isUnsupportedFeatureError((Error) candidate)) {\n                return true;\n            }\n            candidate = candidate.getCause();\n        }\n        return false;\n    }\n\n    private static final class PassthroughClassLoader extends AbstractClassLoader {\n        private boolean postProcessed;\n\n        private PassthroughClassLoader(ClassLoader classPath, ClassFilter filter) {\n            super(AbstractClassLoaderTest.class.getClassLoader(), classPath, filter);\n        }\n\n        @Override\n        protected void postProcess(Class transformedClass) {\n            postProcessed = true;\n        }\n\n        private boolean wasPostProcessed() {\n            return postProcessed;\n        }\n    }\n\n    private static final class InMemoryClassPath extends ClassLoader {\n        private final byte[] classBytes;\n        private final List requestedResources = new ArrayList();\n\n        private InMemoryClassPath(byte[] classBytes) {\n            super(null);\n            this.classBytes = classBytes;\n        }\n\n        @Override\n        public InputStream getResourceAsStream(String name) {\n            requestedResources.add(name);\n            if (TRANSFORMED_RESOURCE_NAME.equals(name)) {\n                return new ByteArrayInputStream(classBytes);\n            }\n            return null;\n        }\n\n        private List requestedResources() {\n            return requestedResources;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "u