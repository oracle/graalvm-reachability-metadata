  package org_sonatype_sisu_inject.cglib;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.lang.reflect.Constructor;
  import java.lang.reflect.Method;
  import java.util.ArrayList;
  import java.util.Base64;
  import java.util.List;
  
  import net.sf.cglib.core.ReflectUtils;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  
  public class ReflectUtilsTest {
      private static final String GENERATED_CLASS_NAME =
              "org_sonatype_sisu_inject.cglib.GeneratedByReflectUtils";
      private static final String GENERATED_CLASS_BYTES = """
              yv66vgAAADQADQoAAgADBwAEDAAFAAYBABBqYXZhL2xhbmcvT2JqZWN0AQAGPGluaXQ+AQ\
              ADKClWBwAIAQA2b3JnX3NvbmF0eXBlX3Npc3VfaW5qZWN0L2NnbGliL0dlbmVyYXRlZEJ5Um\
              VmbGVjdFV0aWxzAQAEQ29kZQEAD0xpbmVOdW1iZXJUYWJsZQEAClNvdXJjZUZpbGUBABxH\
              ZW5lcmF0ZWRCeVJlZmxlY3RVdGlscy5qYXZhACEABwACAAAAAAABAAEABQAGAAEACQAA\
              AB0AAQABAAAABSq3AAGxAAAAAQAKAAAABgABAAAAAgABAAsAAAACAAw=\
              """;
  
      @Test
      void findsConstructorsFromQualifiedSimpleAndPrimitiveArrayTypeNames() {
          final Constructor<?> arrayListConstructor = ReflectUtils.findConstructor("java.util.ArrayList()");
          final Constructor<?> stringConstructor = ReflectUtils.findConstructor("String(byte[])");
  
          assertThat(arrayListConstructor.getDeclaringClass()).isEqualTo(ArrayList.class);
          assertThat(stringConstructor.getDeclaringClass()).isEqualTo(String.class);
          assertThat(stringConstructor.getParameterTypes()).containsExactly(byte[].class);
      }
  
      @Test
      void findsDeclaredMethodFromDescriptor() {
          final Method method = ReflectUtils.findMethod("java.util.ArrayList.size()");
  
          assertThat(method.getName()).isEqualTo("size");
          assertThat(method.getDeclaringClass()).isEqualTo(ArrayList.class);
      }
  
      @Test
      void createsInstanceThroughDeclaredConstructor() {
          final Object value = ReflectUtils.newInstance(
                  PrivateConstructed.class,
                  new Class[] {String.class},
                  new Object[] {"created"}
          );
  
          assertThat(value).isInstanceOf(PrivateConstructed.class);
          assertThat(((PrivateConstructed) value).value()).isEqualTo("created");
      }
  
      @Test
      void findsDeclaredMethodOnSuperclass() throws NoSuchMethodException {
          final Method method = ReflectUtils.findDeclaredMethod(
                  MethodChild.class,
                  "parentOnly",
                  new Class[] {String.class}
          );
  
          assertThat(method.getName()).isEqualTo("parentOnly");
          assertThat(method.getDeclaringClass()).isEqualTo(MethodParent.class);
      }
  
      @Test
      void collectsDeclaredMethodsFromTypeHierarchy() {
          final List methods = ReflectUtils.addAllMethods(MethodChild.class, new ArrayList());
  
          assertThat(methods)
                  .extracting(method -> ((Method) method).getName())
                  .contains("childOnly", "parentOnly", "interfaceOnly");
      }
  
      @Test
      void findsTheOnlyInterfaceMethod() {
          final Method method = ReflectUtils.findInterfaceMethod(SingleMethodInterface.class);
  
          assertThat(method.getName()).isEqualTo("newInstance");
          assertThat(method.getDeclaringClass()).isEqualTo(SingleMethodInterface.class);
      }
  
      @Test
      void definesClassWithSuppliedClassLoader() throws Exception {
          final byte[] bytes = Base64.getDecoder().decode(GENERATED_CLASS_BYTES);
          try {
              final Class<?> definedClass = ReflectUtils.defineClass(
                      GENERATED_CLASS_NAME,
                      bytes,
                      ReflectUtilsTest.class.getClassLoader()
              );
  
              assertThat(definedClass.getName()).isEqualTo(GENERATED_CLASS_NAME);
              assertThat(definedClass.getClassLoader()).isEqualTo(ReflectUtilsTest.class.getClassLoader());
          } catch (Exception exception) {
              rethrowIfNotNativeImageDynamicClassLoadingFailure(exception);
          } catch (Error error) {
              rethrowIfNotNativeImageDynamicClassLoadingFailure(error);
          }
      }
  
      private static void rethrowIfNotNativeImageDynamicClassLoadingFailure(Exception exception) throws Exception {
          final Throwable cause = exception.getCause();
          if (cause instanceof Error) {
              rethrowIfNotNativeImageDynamicClassLoadingFailure((Error) cause);
              return;
          }
          throw exception;
      }
  
      private static void rethrowIfNotNativeImageDynamicClassLoadingFailure(Error error) {
          if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
              throw error;
          }
      }
  
      public interface SingleMethodInterface {
          Object newInstance();
      }
  
      public interface MethodContract {
          void interfaceOnly();
      }
  
      public static class MethodParent {
          public String parentOnly(String value) {
              return "parent:" + value;
          }
      }
  
      public static class MethodChild extends MethodParent implements MethodContract {
          public int childOnly() {
              return 42;
          }
  
          @Override
          public void interfaceOnly() {
          }
      }
  
      public static class PrivateConstructed {
          private final String value;
  
          private PrivateConstructed(String value) {
              this.value = value;
          }
  
          String value() {
              return value;
          }
      }
  }
