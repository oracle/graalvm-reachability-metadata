{"type":"item.completed","item":{"id":"item_24","type":"command_execution","command":"/usr/bin/bash -lc \"sed -n '1,220p' tests/src/org.sonatype.sisu.inject/cglib/2.2.1-v20090111/src/test/java/org_sonatype_sisu_inject/cglib/EnhancerTest.java\"","aggregated_output":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_sonatype_sisu_inject.cglib;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.lang.reflect.Method;\n\nimport net.sf.cglib.proxy.Enhancer;\nimport net.sf.cglib.proxy.MethodInterceptor;\nimport net.sf.cglib.proxy.MethodProxy;\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\n\npublic class EnhancerTest {\n    @Test\n    void createsEnhancedSubclassAndRegistersCallbacksThroughGeneratedSetters() throws Exception {\n        try {\n            final Enhancer enhancer = new Enhancer();\n            enhancer.setSuperclass(GreetingService.class);\n            enhancer.setCallback(new GreetingInterceptor());\n\n            final GreetingService service = (GreetingService) enhancer.create();\n\n            assertThat(service.message(\"cglib\")).isEqualTo(\"enhanced:cglib\");\n            assertThat(Enhancer.isEnhanced(service.getClass())).isTrue();\n        } catch (Exception exception) {\n            rethrowIfNotNativeImageDynamicClassLoadingFailure(exception);\n        } catch (Error error) {\n            rethrowIfNotNativeImageDynamicClassLoadingFailure(error);\n        }\n    }\n\n    private static void rethrowIfNotNativeImageDynamicClassLoadingFailure(Exception exception) throws Exception {\n        if (!isCausedByNativeImageDynamicClassLoadingFailure(exception)) {\n            throw exception;\n        }\n    }\n\n    private static void rethrowIfNotNativeImageDynamicClassLoadingFailure(Error error) {\n        if (!isCausedByNativeImageDynamicClassLoadingFailure(error)) {\n            throw error;\n        }\n    }\n\n    private static boolean isCausedByNativeImageDynamicClassLoadingFailure(Throwable throwable) {\n        Throwable candidate = throwable;\n        while (candidate != null) {\n            if (candidate instanceof Error\n                    && NativeImageSupport.isUnsupportedFeatureError((Error) candidate)) {\n                return true;\n            }\n            candidate = candidate.getCause();\n        }\n        return false;\n    }\n\n    public static class GreetingService {\n        public String message(String name) {\n            return \"plain:\" + name;\n        }\n    }\n\n    private static final class GreetingInterceptor implements MethodInterceptor {\n        @Override\n        public Object intercept(\n                Object object,\n                Method method,\n                Object[] arguments,\n                MethodProxy proxy\n        ) throws Throwable {\n            if (\"message\".equals(method.getName())) {\n                return \"enhanced:\" + arguments[0];\n            }\n            return proxy.invokeSuper(object, arguments);\n        }\n    }\n}\n","exit_code":0,"status":"completed"}}
