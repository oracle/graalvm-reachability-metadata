, transformedClassFilter());\n\n        final Class loadedClass = loader.loadClass(\"java.lang.String\");\n\n        assertThat(loadedClass).isSameAs(String.class);\n        assertThat(loader.wasPostProcessed()).isFalse();\n        assertThat(classPath.requestedResources()).isEmpty();\n    }\n\n    @Test\n    void transformsAcceptedClassBytesAndReturnsAlreadyLoadedClass() throws Exception {\n        final InMemoryClassPath classPath = new InMemoryClassPath(transformedClassBytes());\n        final PassthroughClassLoader loader = new PassthroughClassLoader(classPath, transformedClassFilter());\n\n        try {\n            final Class firstLoad = loader.loadClass(TRANSFORMED_CLASS_NAME);\n            final Class secondLoad = loader.loadClass(TRANSFORMED_CLASS_NAME);\n\n            assertThat(firstLoad.getName()).isEqualTo(TRANSFORMED_CLASS_NAME);\n            assertThat(firstLoad.getClassLoader()).isSameAs(loader);\n            assertThat(secondLoad).isSameAs(firstLoad);\n            assertThat(loader.wasPostProcessed()).isTrue();\n            assertThat(classPath.requestedResources()).containsExactly(TRANSFORMED_RESOURCE_NAME);\n        } catch (Exception exception) {\n            rethrowIfNotNativeImageDynamicClassLoadingFailure(exception);\n        } catch (Error error) {\n            rethrowIfNotNativeImageDynamicClassLoadingFailure(error);\n        }\n    }\n\n    private static ClassFilter transformedClassFilter() {\n        return className -> TRANSFORMED_CLASS_NAME.equals(className);\n    }\n\n    private static byte[] transformedClassBytes() {\n        final byte[] bytes = Base64.getMimeDecoder().decode(TRANSFORMED_CLASS_BYTES);\n        bytes[6] = 0;\n        bytes[7] = 49;\n        return bytes;\n    }\n\n    private static void rethrowIfNotNativeImageDynamicClassLoadingFailure(Exception exception) throws Exception {\n        if (!isCausedByNativeImageDynamicClassLoadingFailure(exception)) {\n            throw exception;\n        }\n    }\n\n    private static void rethrowIfNotNativeImageDynamicClassLoadingFailure(Error error) {\n        if (!isCausedByNativeImageDynamicClassLoadingFailure(error)) {\n            throw error;\n        }\n    }\n\n    private static boolean isCausedByNativeImageDynamicClassLoadingFailure(Throwable throwable) {\n        Throwable candidate = throwable;\n        while (candidate != null) {\n            if (candidate instanceof Error\n                    && NativeImageSupport.isUnsupportedFeatureError((Error) candidate)) {\n                return true;\n            }\n            candidate = candidate.getCause();\n        }\n        return false;\n    }\n\n    private static final class PassthroughClassLoader extends AbstractClassLoader {\n        private boolean postProcessed;\n\n        private PassthroughClassLoader(ClassLoader classPath, ClassFilter filter) {\n            super(AbstractClassLoaderTest.class.getClassLoader(), classPath, filter);\n        }\n\n        @Override\n        protected void postProcess(Class transformedClass) {\n            postProcessed = true;\n        }\n\n        private boolean wasPostProcessed() {\n            return postProcessed;\n        }\n    }\n\n    private static final class InMemoryClassPath extends ClassLoader {\n        private final byte[] classBytes;\n        private final List requestedResources = new ArrayList();\n\n        private InMemoryClassPath(byte[] classBytes) {\n            super(null);\n            this.classBytes = classBytes;\n        }\n\n        @Override\n        public InputStream getResourceAsStream(String name) {\n            requestedResources.add(name);\n            if (TRANSFORMED_RESOURCE_NAME.equals(name)) {\n                return new ByteArrayInputStream(classBytes);\n            }\n            return null;\n        }\n\n        private List requestedResources() {\n            return requestedResources;\n        }\n    }\n}\n","exit_code":0,"status":"completed"}}
