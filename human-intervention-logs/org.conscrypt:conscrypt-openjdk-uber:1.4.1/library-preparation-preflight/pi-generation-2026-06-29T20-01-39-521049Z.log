  583:     /**
  584:      * Check if SCT verification is required for a given hostname.
  585:      *
  586:      * SCT Verification is enabled using {@code Security} properties.
  587:      * The "conscrypt.ct.enable" property must be true, as well as a per domain property.
  588:      * The reverse notation of the domain name, prefixed with "conscrypt.ct.enforce."
  589:      * is used as the property name.
  590:      * Basic globbing is also supported.
  591:      *
  592:      * For example, for the domain foo.bar.com, the following properties will be
  593:      * looked up, in order of precedence.
  594:      * - conscrypt.ct.enforce.com.bar.foo
  595:      * - conscrypt.ct.enforce.com.bar.*
  596:      * - conscrypt.ct.enforce.com.*
  597:      * - conscrypt.ct.enforce.*
  598:      */
  599:     static boolean isCTVerificationRequired(String hostname) {
  600:         if (hostname == null) {
  601:             return false;
  602:         }
  603: 
  604:         String property = Security.getProperty("conscrypt.ct.enable");
  605:         if (property == null || !Boolean.valueOf(property.toLowerCase())) {
  606:             return false;
  607:         }
  608: 
  609:         List<String> parts = Arrays.asList(hostname.split("\\."));
  610:         Collections.reverse(parts);
  611: 
  612:         boolean enable = false;
  613:         StringBuilder propertyName = new StringBuilder("conscrypt.ct.enforce");
  614:         // The loop keeps going on even once we've found a match
  615:         // This allows for finer grained settings on subdomains
  616:         for (String part : parts) {
  617:             property = Security.getProperty(propertyName + ".*");
  618:             if (property != null) {
  619:                 enable = Boolean.valueOf(property.toLowerCase());
  620:             }
  621: 
  622:             propertyName.append(".").append(part);
  623:         }
  624: 
  625:         property = Security.getProperty(propertyName.toString());
