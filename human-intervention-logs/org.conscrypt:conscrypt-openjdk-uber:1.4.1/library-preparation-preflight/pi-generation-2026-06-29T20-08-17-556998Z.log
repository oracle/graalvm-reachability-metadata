[assistant]   "deterministic_setup": [],
[assistant]   "agent_guidance": "Configure generated tests to pass these options both to JVM test execution and to GraalVM native-image build arguments: --add-opens=java.base/java.lang=ALL-UNNAMED, --add-opens=java.base/java.net=ALL-UNNAMED, and --add-opens=java.base/sun.nio.ch=ALL-UNNAMED. Tests should call Conscrypt.checkAvailability(), create a provider with Conscrypt.newProvider(), and prefer loopback/local TLS or JCA operations rather than external network services.",
[assistant]   "risks": [
[assistant]     "The artifact bundles platform native libraries under META-INF/native and extracts/loads them at runtime; failures in native-image are more likely reachability/JNI/resource metadata issues than missing dependencies.",
[assistant]     "If the module opens are omitted, coverage that touches SSLSocket/SocketChannel or native library helper loading can fail on strongly encapsulated JDKs before it reaches the intended Conscrypt behavior.",
[assistant]     "No Docker image appears necessary unless the generated tests deliberately choose to validate against an external TLS service, which is not required for meaningful coverage."
[assistant]   ]
