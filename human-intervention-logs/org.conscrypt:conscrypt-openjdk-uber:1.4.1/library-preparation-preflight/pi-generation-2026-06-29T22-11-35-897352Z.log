      static boolean loadFirstAvailable(
              ClassLoader loader, List<LoadResult> results, String... names) {
          for (String name : names) {
              if (load(name, loader, results)) {
                  // Successfully loaded
                  return true;
              }
          }
          return false;
      }
  
      /**
       * A result of a single attempt to load a library.
