              Field f_fd = SocketImpl.class.getDeclaredField("fd");
              f_fd.setAccessible(true);
              return (FileDescriptor) f_fd.get(socketImpl);
          } catch (Exception e) {
              throw new RuntimeException("Can't get FileDescriptor from socket", e);
