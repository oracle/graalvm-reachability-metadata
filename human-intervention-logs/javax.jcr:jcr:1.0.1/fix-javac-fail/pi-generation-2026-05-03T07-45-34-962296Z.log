[tool-call] delta {"path":"tests/src/javax.jcr/jcr/1.0.1/build.gradle","edits":[{"oldText":"String libraryVersion = tck.testedLibraryVersion.get()\n\ndependencies {\n    testImplementation \"javax.jcr:jcr:$libraryVersion\"\n    testImplementation 'org.assertj:assertj-core:3.22.0'\n}\n","newText":"String libraryVersion = tck.testedLibraryVersion.get()\nString sourceArchiveName = \"content_repository-${libraryVersion.replace('.', '_')}-mr-source.zip\"\nFile sourceContextArchive = file(\"../../../../../../../source_context/javax.jcr/jcr/$libraryVersion/main/$sourceArchiveName\")\nFile downloadedSourceArchive = layout.buildDirectory.file(\"downloads/$sourceArchiveName\").get().asFile\nProvider<Directory> extractedSources = layout.buildDirectory.dir(\"generated/jcr-api-sources\")\n\nTaskProvider<Task> downloadJcrSources = tasks.register('downloadJcrSources') {\n    outputs.file downloadedSourceArchive\n\n    doLast {\n        downloadedSourceArchive.parentFile.mkdirs()\n        URI sourceUri = new URI(\"https://download.oracle.com/otn-pub/jcp/content_repository-${libraryVersion}-mr-oth-JSpec/$sourceArchiveName\")\n        sourceUri.toURL().withInputStream { InputStream inputStream ->\n            downloadedSourceArchive.withOutputStream { OutputStream outputStream ->\n                outputStream << inputStream\n            }\n        }\n    }\n}\n\nTaskProvider<Copy> extractJcrSources = tasks.register('extractJcrSources', Copy) {\n    File sourceArchive = sourceContextArchive.exists() ? sourceContextArchive : downloadedSourceArchive\n\n    if (!sourceContextArchive.exists()) {\n        dependsOn downloadJcrSources\n    }\n\n    from zipTree(sourceArchive)\n    include 'src/java/**/*.java'\n    into extractedSources\n}\n\nsourceSets {\n    test {\n        java.srcDir extractedSources.map { Directory directory -> directory.dir('src/java') }\n    }\n}\n\ntasks.named('compileTestJava') {\n    dependsOn extractJcrSources\n}\n\ndependencies {\n    testImplementation 'org.assertj:assertj-core:3.22.0'\n}\n"}]}
