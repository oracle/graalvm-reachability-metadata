[tool-call] delta {"path":"tests/src/javax.jcr/jcr/1.0.1/build.gradle","edits":[{"oldText":"plugins {\n    id \"org.graalvm.internal.tck\"\n}\n\nString libraryVersion = tck.testedLibraryVersion.get()\n\ndependencies {\n    testImplementation \"javax.jcr:jcr:$libraryVersion\"\n    testImplementation 'org.assertj:assertj-core:3.22.0'\n}\n","newText":"import java.net.URI\n\nplugins {\n    id \"org.graalvm.internal.tck\"\n}\n\nString libraryVersion = tck.testedLibraryVersion.get()\nString archiveVersion = libraryVersion.replace('.', '_')\nProvider<RegularFile> jcrSourceArchive = layout.buildDirectory.file(\"downloads/content_repository-${libraryVersion}-source.zip\")\nProvider<Directory> jcrSourceDirectory = layout.buildDirectory.dir(\"generated/sources/jcr\")\n\nTaskProvider<Task> downloadJcrSources = tasks.register(\"downloadJcrSources\") {\n    outputs.file(jcrSourceArchive)\n\n    doLast {\n        File archive = jcrSourceArchive.get().asFile\n        archive.parentFile.mkdirs()\n        URI.create(\"https://download.oracle.com/otn-pub/jcp/content_repository-${libraryVersion}-mr-oth-JSpec/content_repository-${archiveVersion}-mr-source.zip\")\n                .toURL()\n                .withInputStream { input ->\n                    archive.withOutputStream { output ->\n                        output << input\n                    }\n                }\n    }\n}\n\nTaskProvider<Sync> extractJcrSources = tasks.register(\"extractJcrSources\", Sync) {\n    dependsOn downloadJcrSources\n    from(zipTree(jcrSourceArchive)) {\n        include \"src/java/**/*.java\"\n        eachFile { fileCopyDetails ->\n            fileCopyDetails.path = fileCopyDetails.path.replaceFirst(\"^src/java/\", \"\")\n        }\n        includeEmptyDirs = false\n    }\n    into(jcrSourceDirectory)\n}\n\nsourceSets {\n    main {\n        java.srcDir(extractJcrSources)\n    }\n}\n\ndependencies {\n    testImplementation 'org.assertj:assertj-core:3.22.0'\n}\n"}]}
