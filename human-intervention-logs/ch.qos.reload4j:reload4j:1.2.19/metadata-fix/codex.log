SSING_CLASS_NAME, \"missing\", \"MissingThrowableFrame.java\", 3)\n        });\n\n        Thread thread = Thread.currentThread();\n        ClassLoader previousClassLoader = thread.getContextClassLoader();\n        RejectingClassLoader classLoader = new RejectingClassLoader(\n                EnhancedThrowableRendererTest.class.getClassLoader(),\n                Set.of(EnhancedThrowableRendererTest.class.getName(), MISSING_CLASS_NAME)\n        );\n        thread.setContextClassLoader(classLoader);\n\n        String[] renderedLines;\n        try {\n            renderedLines = new EnhancedThrowableRenderer().doRender(throwable);\n        } finally {\n            thread.setContextClassLoader(previousClassLoader);\n        }\n\n        assertThat(renderedLines).hasSize(4);\n        assertThat(renderedLines[0]).isEqualTo(throwable.toString());\n        assertThat(renderedLines[1])\n                .startsWith(\"\\tat java.lang.String.valueOf(String.java:1)[\")\n                .endsWith(\"]\");\n        assertThat(renderedLines[2])\n                .startsWith(\"\\tat \" + EnhancedThrowableRendererTest.class.getName() + \".exerciseFallback(Test.java:2)[\")\n                .endsWith(\"]\");\n        assertThat(renderedLines[3])\n                .isEqualTo(\"\\tat \" + MISSING_CLASS_NAME + \".missing(MissingThrowableFrame.java:3)\");\n        assertThat(classLoader.getRequestedClassNames()).containsExactly(\n                String.class.getName(),\n                EnhancedThrowableRendererTest.class.getName(),\n                MISSING_CLASS_NAME\n        );\n    }\n\n    @Test\n    void rendersThrowableStackTraceWhenRendererClassLoaderFallbackFindsClass() throws Exception {\n        Thread thread = Thread.currentThread();\n        ClassLoader previousClassLoader = thread.getContextClassLoader();\n        RejectingClassLoader contextClassLoader = new RejectingClassLoader(\n                EnhancedThrowableRendererTest.class.getClassLoader(),\n                Set.of(RENDERER_FALLBACK_CLASS_NAME)\n        );\n        thread.setContextClassLoader(contextClassLoader);\n\n        try (ClassForNameRejectingClassLoader classLoader = new ClassForNameRejectingClassLoader(new URL[] {\n                codeSourceUrl(EnhancedThrowableRenderer.class),\n                codeSourceUrl(EnhancedThrowableRendererTest.class),\n                resourceRootUrl(SERVICE_RESOURCE)\n        }, EnhancedThrowableRendererTest.class.getClassLoader(), RENDERER_FALLBACK_CLASS_NAME)) {\n            Callable<?> action = ServiceLoader.load(Callable.class, classLoader).stream()\n                    .filter(provider -> provider.type().getName().equals(ISOLATED_ACTION_CLASS_NAME))\n                    .map(ServiceLoader.Provider::get)\n                    .findFirst()\n                    .orElseThrow(() -> new AssertionError(\"Expected an isolated renderer callable provider\"));\n\n            Object result = action.call();\n\n            assertThat(result).isInstanceOf(String.class);\n            assertThat((String) result)\n                    .startsWith(\"\\tat \" + RENDERER_FALLBACK_CLASS_NAME + \".fallbackFromRendererLoader\")\n                    .endsWith(\"]\");\n            assertThat(contextClassLoader.getRequestedClassNames())\n                    .contains(RENDERER_FALLBACK_CLASS_NAME);\n            assertThat(classLoader.getRejectedClassForNameLookups())\n                    .contains(RENDERER_FALLBACK_CLASS_NAME);\n            assertThat(classLoader.getRendererLoaderFallbacks())\n                    .contains(RENDERER_FALLBACK_CLASS_NAME);\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        } finally {\n            thread.setContextClassLoader(previousClassLoader);\n        }\n    }\n\n    private static URL codeSourceUrl(Class<?> type) {\n        CodeSource codeSource = type.getProtectionDomain().getCodeSource();\n\n        assertThat(codeSource).isNotNull();\n        return codeSource.getLocation();\n    }\n\n    private static URL resourceRootUrl(String resourceName) throws IOException {\n        URL resourceUrl = EnhancedThrowableRendererTest.class.getClassLoader().getResource(resourceName);\n\n        assertThat(resourceUrl).isNotNull();\n        if (\"jar\".equals(resourceUrl.getProtocol())) {\n            JarURLConnection connection = (JarURLConnection) resourceUrl.openConnection();\n            return connection.getJarFileURL();\n        }\n        String externalForm = resourceUrl.toExternalForm();\n        assertThat(externalForm).endsWith(resourceName);\n        return new URL(externalForm.substring(0, externalForm.length() - resourceName.length()));\n    }\n\n    public static final class IsolatedEnhancedThrowableRendererAction implements Callable<String> {\n\n        @Override\n        public String call() {\n            Throwable throwable = new IllegalStateException(\"renderer class loader fallback\");\n            throwable.setStackTrace(new StackTraceElement[] {\n                    new StackTraceElement(\n                            RENDERER_FALLBACK_CLASS_NAME,\n                            \"fallbackFromRendererLoader\",\n                            \"EnhancedThrowableRendererTest.java\",\n                            1\n                    )\n            });\n\n            return new EnhancedThrowableRenderer().doRender(throwable)[1];\n        }\n    }\n\n    private static final class RejectingClassLoader extends ClassLoader {\n\n        private final Set<String> requestedClassNames = new LinkedHashSet<>();\n        private final Set<String> rejectedClassNames;\n\n        private RejectingClassLoader(ClassLoader parent, Set<String> rejectedClassNames) {\n            super(parent);\n            this.rejectedClassNames = rejectedClassNames;\n        }\n\n        @Override\n        public Class<?> loadClass(String name) throws ClassNotFoundException {\n            requestedClassNames.add(name);\n            if (rejectedClassNames.contains(name)) {\n                throw new ClassNotFoundException(name);\n            }\n            return super.loadClass(name);\n        }\n\n        private Set<String> getRequestedClassNames() {\n            return requestedClassNames;\n        }\n    }\n\n    private static final class ClassForNameRejectingClassLoader extends URLClassLoader {\n\n        private static final String RENDERER_CLASS_NAME = EnhancedThrowableRenderer.class.getName();\n\n        private final Set<String> rejectedClassForNameLookups = new LinkedHashSet<>();\n        private final Set<String> rendererLoaderFallbacks = new LinkedHashSet<>();\n        private final String fallbackClassName;\n\n        private ClassForNameRejectingClassLoader(URL[] urls, ClassLoader parent, String fallbackClassName) {\n            super(urls, parent);\n            this.fallbackClassName = fallbackClassName;\n        }\n\n        @Override\n        public Class<?> loadClass(String name) throws ClassNotFoundException {\n            if (shouldRejectClassForNameLookup(name)) {\n                rejectedClassForNameLookups.add(name);\n                throw new ClassNotFoundException(name);\n            }\n            if (fallbackClassName.equals(name) && isRendererFindClassLookup()) {\n                rendererLoaderFallbacks.add(name);\n                return getParent().loadClass(name);\n            }\n            return super.loadClass(name);\n        }\n\n        @Override\n        protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {\n            if (shouldRejectClassForNameLookup(name)) {\n                rejectedClassForNameLookups.add(name);\n                throw new ClassNotFoundException(name);\n            }\n            synchronized (getClassLoadingLock(name)) {\n                Class<?> loadedClass = findLoadedClass(name);\n                if (loadedClass == null) {\n                    if (isChildFirst(name)) {\n                        try {\n                            loadedClass = findClass(name);\n                        } catch (ClassNotFoundException ignored) {\n                            loadedClass = super.loadClass(name, false);\n                        }\n                    } else {\n                        loadedClass = super.loadClass(name, false);\n                    }\n                }\n","exit_code":0,"status":"completed"}}
