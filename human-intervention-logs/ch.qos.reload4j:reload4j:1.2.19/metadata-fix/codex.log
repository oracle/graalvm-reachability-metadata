            loadedClass = findClass(name);\n                        } catch (ClassNotFoundException ignored) {\n                            loadedClass = super.loadClass(name, false);\n                        }\n                    } else {\n                        loadedClass = super.loadClass(name, false);\n                    }\n                }\n                if (resolve) {\n                    resolveClass(loadedClass);\n                }\n                return loadedClass;\n            }\n        }\n\n        private boolean isChildFirst(String className) {\n            return RENDERER_CLASS_NAME.equals(className) || ISOLATED_ACTION_CLASS_NAME.equals(className);\n        }\n\n        private boolean shouldRejectClassForNameLookup(String className) {\n            return fallbackClassName.equals(className) && rejectedClassForNameLookups.isEmpty();\n        }\n\n        private boolean isRendererFindClassLookup() {\n            for (StackTraceElement frame : Thread.currentThread().getStackTrace()) {\n                if (RENDERER_CLASS_NAME.equals(frame.getClassName()) && \"findClass\".equals(frame.getMethodName())) {\n                    return true;\n                }\n            }\n            return false;\n        }\n\n        private Set<String> getRejectedClassForNameLookups() {\n            return rejectedClassForNameLookups;\n        }\n\n        private Set<String> getRendererLoaderFallbacks() {\n            return rendererLoaderFallbacks;\n        }\n    }\n}\n","exit_code":0,"status":"completed"}}
