[tool-call] delta {"path":"tests/src/ch.qos.reload4j/reload4j/1.2.19/src/test/java/ch_qos_reload4j/reload4j/EnhancedThrowableRendererTest.java","edits":[{"oldText":"import java.io.IOException;\nimport java.io.InputStream;\n\nimport org.apache.log4j.EnhancedThrowableRenderer;\n","newText":"import java.net.URL;\nimport java.net.URLClassLoader;\nimport java.security.CodeSource;\n\nimport org.apache.log4j.EnhancedThrowableRenderer;\n"},{"oldText":"        AlternatingEnhancedThrowableRendererClassLoader rendererClassLoader =\n                new AlternatingEnhancedThrowableRendererClassLoader();\n        try {\n","newText":"        try (AlternatingEnhancedThrowableRendererClassLoader rendererClassLoader =\n                new AlternatingEnhancedThrowableRendererClassLoader()) {\n"},{"oldText":"        } finally {\n            Thread.currentThread().setContextClassLoader(originalClassLoader);\n        }\n","newText":"        } finally {\n            Thread.currentThread().setContextClassLoader(originalClassLoader);\n        }\n"},{"oldText":"    private static final class AlternatingEnhancedThrowableRendererClassLoader extends ClassLoader {\n        private boolean classForNameLoadRejected;\n        private boolean rendererFallbackLoadAttempted;\n\n        private AlternatingEnhancedThrowableRendererClassLoader() {\n            super(EnhancedThrowableRendererTest.class.getClassLoader());\n        }\n\n        @Override\n        protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {\n            synchronized (getClassLoadingLock(name)) {\n                if (EnhancedThrowableRenderer.class.getName().equals(name)) {\n                    Class<?> loadedClass = findLoadedClass(name);\n                    if (loadedClass == null) {\n                        loadedClass = defineEnhancedThrowableRenderer();\n                    }\n                    if (resolve) {\n                        resolveClass(loadedClass);\n                    }\n                    return loadedClass;\n                }\n                if (TEST_CLASS_NAME.equals(name)) {\n                    if (!classForNameLoadRejected) {\n                        classForNameLoadRejected = true;\n                        throw new ClassNotFoundException(name);\n                    }\n                    rendererFallbackLoadAttempted = true;\n                    return EnhancedThrowableRendererTest.class;\n                }\n                return super.loadClass(name, resolve);\n            }\n        }\n\n        private Class<?> defineEnhancedThrowableRenderer() throws ClassNotFoundException {\n            String resourceName = EnhancedThrowableRenderer.class.getName().replace('.', '/') + \".class\";\n            try (InputStream input = getParent().getResourceAsStream(resourceName)) {\n                if (input == null) {\n                    throw new ClassNotFoundException(EnhancedThrowableRenderer.class.getName());\n                }\n                byte[] classBytes = input.readAllBytes();\n                return defineClass(EnhancedThrowableRenderer.class.getName(), classBytes, 0, classBytes.length);\n            } catch (IOException exception) {\n                throw new ClassNotFoundException(EnhancedThrowableRenderer.class.getName(), exception);\n            }\n        }\n    }\n","newText":"    private static final class AlternatingEnhancedThrowableRendererClassLoader extends URLClassLoader {\n        private boolean classForNameLoadRejected;\n        private boolean rendererFallbackLoadAttempted;\n\n        private AlternatingEnhancedThrowableRendererClassLoader() {\n            super(reload4jUrls(), EnhancedThrowableRendererTest.class.getClassLoader());\n        }\n\n        @Override\n        protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {\n            synchronized (getClassLoadingLock(name)) {\n                if (EnhancedThrowableRenderer.class.getName().equals(name)) {\n          