      public void getMDCCopy() {
  	if (mdcCopyLookupRequired) {
  	    mdcCopyLookupRequired = false;
  	    // the clone call is required for asynchronous logging.
  	    // See also bug #5932.
  	    Hashtable t = (Hashtable) MDC.getContext();
  	    if (t != null) {
