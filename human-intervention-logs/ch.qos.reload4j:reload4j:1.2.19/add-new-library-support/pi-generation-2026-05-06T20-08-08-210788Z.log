      public Level getLevel() {
  	return (Level) level;
      }
  
      /**
       * Return the name of the logger. Use this form instead of directly accessing
       * the <code>categoryName</code> field.
       */
      public String getLoggerName() {
  	return categoryName;
      }
  
      /**
       * Gets the logger of the event. Use should be restricted to cloning events.
