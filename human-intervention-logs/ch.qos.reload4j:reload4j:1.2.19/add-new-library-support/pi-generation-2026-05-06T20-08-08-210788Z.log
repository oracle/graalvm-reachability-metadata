      public Object getMDC(String key) {
  	Object r;
  	// Note the mdcCopy is used if it exists. Otherwise we use the MDC
  	// that is associated with the thread.
  	if (mdcCopy != null) {
  	    r = mdcCopy.get(key);
  	    if (r != null) {
  		return r;
  	    }
