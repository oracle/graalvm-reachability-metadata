      public void emitNoAppenderWarning(Category cat) {
  	// No appenders in hierarchy, warn user only once.
  	if (!this.emittedNoAppenderWarning) {
  	    LogLog.warn("No appenders could be found for logger (" + cat.getName() + ").");
