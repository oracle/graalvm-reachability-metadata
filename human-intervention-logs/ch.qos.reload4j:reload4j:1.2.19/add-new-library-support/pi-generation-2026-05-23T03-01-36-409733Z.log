  package ch_qos_reload4j.reload4j;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.IOException;
  import java.io.ObjectInputStream;
  import java.net.InetAddress;
  import java.net.InetSocketAddress;
  import java.net.ServerSocket;
  import java.net.Socket;
  import java.util.concurrent.CountDownLatch;
  import java.util.concurrent.TimeUnit;
  import org.apache.log4j.Level;
  import org.apache.log4j.LogManager;
  import org.apache.log4j.Logger;
  import org.apache.log4j.net.SocketHubAppender;
  import org.apache.log4j.spi.LoggingEvent;
  import org.junit.jupiter.api.AfterEach;
  import org.junit.jupiter.api.Test;
  
  public class SocketHubAppenderTest {
      private static final String APPLICATION_NAME = "reload4j-socket-hub-test";
  
      @AfterEach
      void resetLogging() {
          LogManager.shutdown();
          LogManager.resetConfiguration();
      }
  
      @Test
      void publishesLoggingEventsToConnectedClients() throws Exception {
          TestableSocketHubAppender appender = new TestableSocketHubAppender();
          appender.setName("socket-hub-appender-test");
          appender.setPort(0);
          appender.setBufferSize(1);
          appender.setApplication(APPLICATION_NAME);
          appender.activateOptions();
  
          Logger logger = Logger.getLogger("reload4j.socketHubAppenderTest");
          logger.setAdditivity(false);
          logger.setLevel(Level.INFO);
          logger.addAppender(appender);
  
          try {
              logger.info("cached event");
  
              try (Socket socket = connectToAppender(appender.awaitListeningPort());
                      ObjectInputStream inputStream = new ObjectInputStream(socket.getInputStream())) {
                  LoggingEvent cachedEvent = readLoggingEvent(inputStream);
                  assertThat(cachedEvent.getMessage()).isEqualTo("cached event");
  
                  Thread.sleep(100L);
                  logger.info("first live event");
                  Thread.sleep(100L);
                  logger.info("second live event");
  
                  LoggingEvent liveEvent = readLoggingEvent(inputStream);
                  assertThat(liveEvent.getLoggerName()).isEqualTo(logger.getName());
                  assertThat(liveEvent.getMessage()).isIn("first live event", "second live event");
                  assertThat(liveEvent.getLevel()).isSameAs(Level.INFO);
                  assertThat(liveEvent.getProperty("application")).isEqualTo(APPLICATION_NAME);
              }
          } finally {
              logger.removeAppender(appender);
              appender.close();
          }
      }
  
      private static Socket connectToAppender(int port) throws IOException {
          Socket socket = new Socket();
          socket.connect(new InetSocketAddress(InetAddress.getLoopbackAddress(), port), 1000);
          socket.setSoTimeout(5000);
          return socket;
      }
  
      private static LoggingEvent readLoggingEvent(ObjectInputStream inputStream) throws Exception {
          Object object = inputStream.readObject();
          assertThat(object).isInstanceOf(LoggingEvent.class);
          return (LoggingEvent) object;
      }
  
      private static final class TestableSocketHubAppender extends SocketHubAppender {
          private final CountDownLatch serverSocketReady = new CountDownLatch(1);
          private volatile ServerSocket serverSocket;
  
          @Override
          protected ServerSocket createServerSocket(int socketPort) throws IOException {
              ServerSocket createdServerSocket = super.createServerSocket(socketPort);
              serverSocket = createdServerSocket;
              serverSocketReady.countDown();
              return createdServerSocket;
          }
  
          int awaitListeningPort() throws InterruptedException {
              assertThat(serverSocketReady.await(5, TimeUnit.SECONDS)).isTrue();
              return serverSocket.getLocalPort();
          }
      }
  }
