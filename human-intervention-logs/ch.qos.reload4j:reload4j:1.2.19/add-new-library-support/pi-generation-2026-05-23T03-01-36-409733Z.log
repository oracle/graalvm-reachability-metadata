  package ch_qos_reload4j.reload4j;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import org.apache.log4j.Level;
  import org.apache.log4j.LogManager;
  import org.apache.log4j.Logger;
  import org.apache.log4j.helpers.UtilLoggingLevel;
  import org.apache.log4j.spi.LoggingEvent;
  import org.junit.jupiter.api.AfterEach;
  import org.junit.jupiter.api.Test;
  
  public class LoggingEventTest {
  
      @AfterEach
      void resetLogging() {
          LogManager.shutdown();
          LogManager.resetConfiguration();
      }
  
      @Test
      void serializesAndDeserializesStandardAndSubclassedLevels() throws Exception {
          Logger logger = Logger.getLogger(LoggingEventTest.class);
  
          LoggingEvent standardLevelEvent = serializeAndDeserialize(new LoggingEvent(
                  LoggingEventTest.class.getName(),
                  logger,
                  Level.INFO,
                  "standard level message",
                  null
          ));
          LoggingEvent subclassedLevelEvent = serializeAndDeserialize(new LoggingEvent(
                  LoggingEventTest.class.getName(),
                  logger,
                  UtilLoggingLevel.WARNING,
                  "util logging level message",
                  null
          ));
  
          assertThat(standardLevelEvent.getLoggerName()).isEqualTo(logger.getName());
          assertThat(standardLevelEvent.getLevel()).isSameAs(Level.INFO);
          assertThat(standardLevelEvent.getMessage()).isEqualTo("standard level message");
          assertThat(subclassedLevelEvent.getLoggerName()).isEqualTo(logger.getName());
          assertThat(subclassedLevelEvent.getLevel()).isSameAs(UtilLoggingLevel.WARNING);
          assertThat(subclassedLevelEvent.getMessage()).isEqualTo("util logging level message");
      }
  
      private static LoggingEvent serializeAndDeserialize(LoggingEvent event) throws Exception {
          ByteArrayOutputStream output = new ByteArrayOutputStream();
          try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(output)) {
              objectOutputStream.writeObject(event);
          }
  
          try (ObjectInputStream objectInputStream = new ObjectInputStream(
                  new ByteArrayInputStream(output.toByteArray()))) {
              Object deserialized = objectInputStream.readObject();
  
              assertThat(deserialized).isInstanceOf(LoggingEvent.class);
              return (LoggingEvent) deserialized;
          }
      }
  }
