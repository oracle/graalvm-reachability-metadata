?> loadClass(String name) throws ClassNotFoundException {\n+            if (fallbackClassName.equals(name) && isClassForNameLookup()) {\n+                rejectedClassForNameLookups.add(name);\n+                throw new ClassNotFoundException(name);\n+            }\n+            if (fallbackClassName.equals(name) && isRendererFindClassLookup()) {\n+                rendererLoaderFallbacks.add(name);\n+                return getParent().loadClass(name);\n+            }\n+            return super.loadClass(name);\n+        }\n+\n+        @Override\n+        protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {\n+            if (fallbackClassName.equals(name) && isClassForNameLookup()) {\n+                rejectedClassForNameLookups.add(name);\n+                throw new ClassNotFoundException(name);\n+            }\n+            synchronized (getClassLoadingLock(name)) {\n+                Class<?> loadedClass = findLoadedClass(name);\n+                if (loadedClass == null) {\n+                    if (isChildFirst(name)) {\n+                        try {\n+                            loadedClass = findClass(name);\n+                        } catch (ClassNotFoundException ignored) {\n+                            loadedClass = super.loadClass(name, false);\n+                        }\n+                    } else {\n+                        loadedClass = super.loadClass(name, false);\n+                    }\n+                }\n+                if (resolve) {\n+                    resolveClass(loadedClass);\n+                }\n+                return loadedClass;\n+            }\n+        }\n+\n+        private boolean isChildFirst(String className) {\n+            return RENDERER_CLASS_NAME.equals(className) || ISOLATED_ACTION_CLASS_NAME.equals(className);\n+        }\n+\n+        private boolean isClassForNameLookup() {\n+            for (StackTraceElement frame : Thread.currentThread().getStackTrace()) {\n+                if (Class.class.getName().equals(frame.getClassName()) && \"forName\".equals(frame.getMethodName())) {\n+                    return true;\n+                }\n+            }\n+            return false;\n+        }\n+\n+        private boolean isRendererFindClassLookup() {\n+            for (StackTraceElement frame : Thread.currentThread().getStackTrace()) {\n+                if (RENDERER_CLASS_NAME.equals(frame.getClassName()) && \"findClass\".equals(frame.getMethodName())) {\n+                    return true;\n+                }\n+            }\n+            return false;\n+        }\n+\n+        private Set<String> getRejectedClassForNameLookups() {\n+            return rejectedClassForNameLookups;\n+        }\n+\n+        private Set<String> getRendererLoaderFallbacks() {\n+            return rendererLoaderFallbacks;\n+        }\n+    }\n }\ndiff --git i/tests/src/ch.qos.reload4j/reload4j/1.2.19/src/test/resources/META-INF/services/java.util.concurrent.Callable w/tests/src/ch.qos.reload4j/reload4j/1.2.19/src/test/resources/META-INF/services/java.util.concurrent.Callable\nindex aa33b9bbb1..cee6321ed8 100644\n--- i/tests/src/ch.qos.reload4j/reload4j/1.2.19/src/test/resources/META-INF/services/java.util.concurrent.Callable\n+++ w/tests/src/ch.qos.reload4j/reload4j/1.2.19/src/test/resources/META-INF/services/java.util.concurrent.Callable\n@@ -1 +1,2 @@\n ch_qos_reload4j.reload4j.LoaderTest$IsolatedLoaderAction\n+ch_qos_reload4j.reload4j.EnhancedThrowableRendererTest$IsolatedEnhancedThrowableRendererAction\n"}], "isError": false, "timestamp": 1779501574625}]}
