port java.net.URL;\n+import java.net.URLClassLoader;\n+import java.security.CodeSource;\n import java.util.LinkedHashSet;\n+import java.util.ServiceLoader;\n import java.util.Set;\n+import java.util.concurrent.Callable;\n import org.apache.log4j.EnhancedThrowableRenderer;\n+import org.graalvm.internal.tck.NativeImageSupport;\n import org.junit.jupiter.api.Test;\n \n public class EnhancedThrowableRendererTest {\n \n     private static final String MISSING_CLASS_NAME = \"ch_qos_reload4j.reload4j.MissingThrowableFrame\";\n+    private static final String SERVICE_RESOURCE = \"META-INF/services/java.util.concurrent.Callable\";\n+    private static final String ISOLATED_ACTION_CLASS_NAME = IsolatedEnhancedThrowableRendererAction.class.getName();\n \n     @Test\n     void rendersThrowableStackTraceWithEnhancedClassDetailsAndClassLoaderFallbacks() {\n@@ -58,6 +68,86 @@ public class EnhancedThrowableRendererTest {\n         );\n     }\n \n+    @Test\n+    void rendersThrowableStackTraceWhenRendererClassLoaderFallbackFindsClass() throws Exception {\n+        Thread thread = Thread.currentThread();\n+        ClassLoader previousClassLoader = thread.getContextClassLoader();\n+        RejectingClassLoader contextClassLoader = new RejectingClassLoader(\n+                EnhancedThrowableRendererTest.class.getClassLoader(),\n+                Set.of(EnhancedThrowableRendererTest.class.getName())\n+        );\n+        thread.setContextClassLoader(contextClassLoader);\n+\n+        try (ClassForNameRejectingClassLoader classLoader = new ClassForNameRejectingClassLoader(new URL[] {\n+                codeSourceUrl(EnhancedThrowableRenderer.class),\n+                codeSourceUrl(EnhancedThrowableRendererTest.class),\n+                resourceRootUrl(SERVICE_RESOURCE)\n+        }, EnhancedThrowableRendererTest.class.getClassLoader(), EnhancedThrowableRendererTest.class.getName())) {\n+            Callable<?> action = ServiceLoader.load(Callable.class, classLoader).stream()\n+           