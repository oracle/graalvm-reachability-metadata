r(throwable);\n        } finally {\n            thread.setContextClassLoader(previousClassLoader);\n        }\n\n        assertThat(renderedLines).hasSize(4);\n        assertThat(renderedLines[0]).isEqualTo(throwable.toString());\n        assertThat(renderedLines[1])\n                .startsWith(\"\\tat java.lang.String.valueOf(String.java:1)[\")\n                .endsWith(\"]\");\n        assertThat(renderedLines[2])\n                .startsWith(\"\\tat \" + EnhancedThrowableRendererTest.class.getName() + \".exerciseFallback(Test.java:2)[\")\n                .endsWith(\"]\");\n        assertThat(renderedLines[3])\n                .isEqualTo(\"\\tat \" + MISSING_CLASS_NAME + \".missing(MissingThrowableFrame.java:3)\");\n        assertThat(classLoader.getRequestedClassNames()).containsExactly(\n                String.class.getName(),\n                EnhancedThrowableRendererTest.class.getName(),\n                MISSING_CLASS_NAME\n        );\n    }\n\n    private static final class RejectingClassLoader extends ClassLoader {\n\n        private final Set<String> requestedClassNames = new LinkedHashSet<>();\n        private final Set<String> rejectedClassNames;\n\n        private RejectingClassLoader(ClassLoader parent, Set<String> rejectedClassNames) {\n            super(parent);\n            this.rejectedClassNames = rejectedClassNames;\n        }\n\n        @Override\n        public Class<?> loadClass(String name) throws ClassNotFoundException {\n            requestedClassNames.add(name);\n            if (rejectedClassNames.contains(name)) {\n                throw new ClassNotFoundException(name);\n            }\n            return super.loadClass(name);\n        }\n\n        private Set<String> getRequestedClassNames() {\n            return requestedClassNames;\n        }\n    }\n}\n"}
