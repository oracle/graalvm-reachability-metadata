ssLoader = new ClassForNameRejectingClassLoader(new URL[] {\n                codeSourceUrl(EnhancedThrowableRenderer.class),\n                codeSourceUrl(EnhancedThrowableRendererTest.class),\n                resourceRootUrl(SERVICE_RESOURCE)\n        }, EnhancedThrowableRendererTest.class.getClassLoader(), EnhancedThrowableRendererTest.class.getName())) {\n            Callable<?> action = ServiceLoader.load(Callable.class, classLoader).stream()\n                    .filter(provider -> provider.type().getName().equals(ISOLATED_ACTION_CLASS_NAME))\n                    .map(ServiceLoader.Provider::get)\n                    .findFirst()\n                    .orElseThrow(() -> new AssertionError(\"Expected an isolated renderer callable provider\"));\n\n            Object result = action.call();\n\n            assertThat(result).isInstanceOf(String.class);\n            assertThat((String) result)\n                    .startsWith(\"\\tat \" + EnhancedThrowableRendererTest.class.getName() + \".fallbackFromRendererLoader\")\n                    .endsWith(\"]\");\n            assertThat(contextClassLoader.getRequestedClassNames())\n                    .contains(EnhancedThrowableRendererTest.class.getName());\n            assertThat(classLoader.getRejectedClassForNameLookups())\n                    .contains(EnhancedThrowableRendererTest.class.getName());\n            assertThat(classLoader.getRendererLoaderFallbacks())\n                    .contains(EnhancedThrowableRendererTest.class.getName());\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        } finally {\n            thread.setContextClassLoader(previousClassLoader);\n        }\n    }\n\n    private static URL codeSourceUrl(Class<?> type) {\n        CodeSource codeSource = type.getProtectionDomain().getCodeSource();\n\n        assertThat(codeSource).isNotNull();\n        return codeSource.getLocation();\n    }\n\n    private static URL resourceRootUrl(String resourceName) throws IOException {\n        URL resourceUrl = EnhancedThrowableRendererTest.class.getClassLoader().getResource(resourceName);\n\n        assertThat(resourceUrl).isNotNull();\n        if (\"jar\".equals(resourceUrl.getProtocol())) {\n            JarURLConnection connection = (JarURLConnection) resourceUrl.openConnection();\n            return connection.getJarFileURL();\n        }\n        String externalForm = resourceUrl.toExternalForm();\n        assertThat(externalForm).endsWith(resourceName);\n        return new URL(externalForm.substring(0, externalForm.length() - resourceName.length()));\n    }\n\n    public static final class IsolatedEnhancedThrowableRendererAction implements Callable<String> {\n\n        @Override\n        public String call() {\n            Throwable throwable = new IllegalStateException(\"renderer class loader fallback\");\n            throwable.setStackTrace(new StackTraceElement[] {\n                    new StackTraceElement(\n                            \"ch_qos_reload4j.reload4j.EnhancedThrowableRendererTest\",\n                            \"fallbackFromRendererLoader\",\n                            \"EnhancedThrowableRendererTest.java\",\n                            1\n                    )\n            });\n\n            return new EnhancedThrowableRenderer().doRender(throwable)[1];\n        }\n    }\n\n    private static final class RejectingClassLoader extends ClassLoader {\n"}]}
