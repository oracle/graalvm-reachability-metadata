led\", true)\n                .containsEntry(\"log4j.appender.console.bufferSize\", 128)\n                .containsEntry(\"log4j.appender.console.maxEvents\", 4096L)\n                .containsEntry(\"log4j.appender.console.threshold\", Level.INFO)\n                .doesNotContainKey(\"log4j.appender.console.ratio\")\n                .doesNotContainKey(\"log4j.appender.console.nullValue\");\n    }\n\n    public static final class ConfigBean {\n\n        public String getName() {\n            return \"console\";\n        }\n\n        public boolean isEnabled() {\n            return true;\n        }\n\n        public int getBufferSize() {\n            return 128;\n        }\n\n        public long getMaxEvents() {\n            return 4096L;\n        }\n\n        public Level getThreshold() {\n            return Level.INFO;\n        }\n\n        public double getRatio() {\n            return 0.5D;\n        }\n\n        public String getNullValue() {\n            return null;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1400, "output": 790, "cacheRead": 12800, "cacheWrite": 0, "totalTokens": 14990, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1779504610904, "responseId": "resp_08a41555b7030826016a1115e33e4c8194ab6924764a2d603d"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_PpjeYFlvYozv0dl3Hq5hxMAU|fc_08a41555b7030826016a1115e7356c819481d172ff4ea93dbf", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2017 bytes to tests/src/ch.qos.reload4j/reload4j/1.2.19/src/test/java/ch_qos_reload4j/reload4j/PropertyGetterTest.java"}], "isError": false, "timestamp": 1779504619907}]}
