[tool-call] delta {"path":"tests/src/ch.qos.reload4j/reload4j/1.2.19/src/test/java/ch_qos_reload4j/reload4j/PropertyGetterTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage ch_qos_reload4j.reload4j;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.util.LinkedHashMap;\nimport java.util.Map;\n\nimport org.apache.log4j.Level;\nimport org.apache.log4j.config.PropertyGetter;\nimport org.junit.jupiter.api.Test;\n\npublic class PropertyGetterTest {\n\n    @Test\n    void reportsHandledJavaBeanProperties() {\n        ConfigBean configBean = new ConfigBean();\n        Map<String, Object> properties = new LinkedHashMap<>();\n\n        PropertyGetter.getProperties(configBean, (object, prefix, name, value) -> {\n            assertThat(object).isSameAs(configBean);\n            properties.put(prefix + name, value);\n        }, \"log4j.appender.console.\");\n\n        assertThat(properties)\n                .containsEntry(\"log4j.appender.console.name\", \"console\")\n                .containsEntry(\"log4j.appender.console.enabled\", true)\n                .containsEntry(\"log4j.appender.console.bufferSize\", 128)\n                .containsEntry(\"log4j.appender.console.maxEvents\", 4096L)\n                .containsEntry(\"log4j.appender.console.threshold\", Level.INFO)\n                .doesNotContainKey(\"log4j.appender.console.ratio\")\n                .doesNotContainKey(\"log4j.appender.console.nullValue\");\n    }\n\n    public static final class ConfigBean {\n\n        public String getName() {\n            return \"console\";\n        }\n\n        public boolean isEnabled() {\n            return true;\n        }\n\n        public int getBufferSize() {\n            return 128;\n        }\n\n        public long getMaxEvents() {\n            return 4096L;\n        }\n\n        public Level getThreshold() {\n            return Level.INFO;\n        }\n\n        public double getRatio() {\n            return 0.5D;\n        }\n\n        public String getNullValue() {\n            return null;\n        }\n    }\n}\n"}
