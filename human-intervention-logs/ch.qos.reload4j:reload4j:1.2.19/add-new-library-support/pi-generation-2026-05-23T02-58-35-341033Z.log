  /*
   * Copyright and related rights waived via CC0
   *
   * You should have received a copy of the CC0 legalcode along with this
   * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.
   */
  package ch_qos_reload4j.reload4j;
  
  import java.io.IOException;
  import java.util.LinkedHashMap;
  import java.util.Map;
  
  import javax.jmdns.JmDNS;
  
  import org.apache.log4j.net.ZeroConfSupport;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ZeroConfSupportTest {
      private static final String LOG4J_TCP_CONNECT_ZONE = "_log4j_obj_tcpconnect_appender.local.";
  
      @Test
      void advertisesAndUnadvertisesServiceWithJmDns() throws IOException {
          Map<String, String> properties = new LinkedHashMap<>();
          properties.put("application", "reload4j-zero-conf-test");
          properties.put("protocol", "tcp");
  
          ZeroConfSupport zeroConfSupport = new ZeroConfSupport(
                  LOG4J_TCP_CONNECT_ZONE,
                  4560,
                  "reload4j-zero-conf-test",
                  properties);
          Object jmDnsInstance = ZeroConfSupport.getJMDNSInstance();
  
          assertThat(jmDnsInstance).isInstanceOf(JmDNS.class);
          JmDNS jmDNS = (JmDNS) jmDnsInstance;
          try {
              zeroConfSupport.advertise();
              zeroConfSupport.unadvertise();
          } finally {
              jmDNS.unregisterAllServices();
              jmDNS.close();
          }
      }
  }
