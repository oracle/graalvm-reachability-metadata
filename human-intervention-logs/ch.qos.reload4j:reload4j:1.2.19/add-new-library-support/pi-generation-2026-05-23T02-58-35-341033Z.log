ption creating output stream on socket.\", e);\r\n\t\t\t}\r\n\t\t    }\r\n\t\t}\r\n\t    } finally {\r\n\t\t// close the socket\r\n\t\ttry {\r\n\t\t    serverSocket.close();\r\n\t\t} catch (InterruptedIOException e) {\r\n\t\t    Thread.currentThread().interrupt();\r\n\t\t} catch (IOException e) {\r\n\t\t    // do nothing with it?\r\n\t\t}\r\n\t    }\r\n\t}\r\n    }\r\n}\r\n"}], "isError": false, "timestamp": 1779505028585}]}
