  	case WARNING_INT:
  	    return WARNING;
  
  	case INFO_INT:
  	    return INFO;
  
  	case CONFIG_INT:
  	    return CONFIG;
  
  	case FINE_INT:
  	    return FINE;
  
  	case FINER_INT:
  	    return FINER;
  
  	case FINEST_INT:
  	    return FINEST;
  
  	default:
  	    return defaultLevel;
  	}
      }
  
      /**
