  	String s = sArg.toUpperCase();
  
  	if (s.equals("ALL"))
  	    return Level.ALL;
  	if (s.equals("DEBUG"))
  	    return Level.DEBUG;
  	if (s.equals("INFO"))
  	    return Level.INFO;
  	if (s.equals("WARN"))
  	    return Level.WARN;
  	if (s.equals("ERROR"))
  	    return Level.ERROR;
  	if (s.equals("FATAL"))
