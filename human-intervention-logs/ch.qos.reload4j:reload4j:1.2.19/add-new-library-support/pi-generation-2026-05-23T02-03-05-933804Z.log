hat(standardLevelEvent.getMessage()).isEqualTo(\"standard level message\");\n        assertThat(subclassedLevelEvent.getLoggerName()).isEqualTo(logger.getName());\n        assertThat(subclassedLevelEvent.getLevel()).isSameAs(UtilLoggingLevel.WARNING);\n        assertThat(subclassedLevelEvent.getMessage()).isEqualTo(\"util logging level message\");\n    }\n\n    private static LogEvent serializeAndDeserialize(LogEvent event) throws Exception {\n        ByteArrayOutputStream output = new ByteArrayOutputStream();\n        try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(output)) {\n            objectOutputStream.writeObject(event);\n        }\n\n        try (ObjectInputStream objectInputStream = new ObjectInputStream(\n                new ByteArrayInputStream(output.toByteArray()))) {\n            Object deserialized = objectInputStream.readObject();\n\n            assertThat(deserialized).isInstanceOf(LogEvent.class);\n            return (LogEvent) deserialized;\n        }\n    }\n}\n"}
