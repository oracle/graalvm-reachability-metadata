java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport org.apache.log4j.Level;\nimport org.apache.log4j.LogManager;\nimport org.apache.log4j.Logger;\nimport org.apache.log4j.helpers.UtilLoggingLevel;\nimport org.apache.log4j.pattern.LogEvent;\nimport org.junit.jupiter.api.AfterEach;\nimport org.junit.jupiter.api.Test;\n\npublic class LogEventTest {\n\n    @AfterEach\n    void resetLogging() {\n        LogManager.shutdown();\n        LogManager.resetConfiguration();\n    }\n\n    @Test\n    void serializesAndDeserializesStandardAndSubclassedLevels() throws Exception {\n        Logger logger = Logger.getLogger(LogEventTest.class);\n\n        LogEvent standardLevelEvent = serializeAndDeserialize(new LogEvent(\n                LogEventTest.class.getName(),\n                logger,\n                Level.INFO,\n                \"standard level message\",\n                null\n        ));\n        LogEvent subclassedLevelEvent = serializeAndDeserialize(new LogEvent(\n                LogEventTest.class.getName(),\n                logger,\n                UtilLoggingLevel.WARNING,\n                \"util logging level message\",\n                null\n        ));\n\n        assertThat(standardLevelEvent.getLoggerName()).isEqualTo(logger.getName());\n        assertThat(standardLevelEvent.getLevel()).isSameAs(Level.INFO);\n        assertThat(standardLevelEvent.getMessage()).isEqualTo(\"standard level message\");\n        assertThat(subclassedLevelEvent.getLoggerName()).isEqualTo(logger.getName());\n        assertThat(subclassedLevelEvent.getLevel()).isSameAs(UtilLoggingLevel.WARNING);\n        assertThat(subclassedLevelEvent.getMessage()).isEqualTo(\"util logging level message\");\n    }\n\n    private static LogEvent serializeAndDeserialize(LogEvent event) throws Exception {\n        ByteArrayOutputStream output = new ByteArrayOutputStream();\n        try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(output)) {\n            objectOutputStream.writeObject(event);\n        }\n\n        try (ObjectInputStream objectInputStream = new ObjectInputStream(\n                new ByteArrayInputStream(output.toByteArray()))) {\n            Object deserialized = objectInputStream.readObject();\n\n            assertThat(deserialized).isInstanceOf(LogEvent.class);\n            return (LogEvent) deserialized;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1482, "output": 1263, "cacheRead": 20480, "cacheWrite": 0, "totalTokens": 23225, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1779501755194, "responseId": "resp_0c4d618b470715e4016a110abbe0b88194a021721aaae1fe10"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_1nbUdvA50moJ2UI9kzjErc0l|fc_0c4d618b470715e4016a110ac827008194a96c2c1e93e852e1", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2694 bytes to tests/src/ch.qos.reload4j/reload4j/1.2.19/src/test/java/ch_qos_reload4j/reload4j/LogEventTest.java"}], "isError": false, "timestamp": 1779501769919}]}
