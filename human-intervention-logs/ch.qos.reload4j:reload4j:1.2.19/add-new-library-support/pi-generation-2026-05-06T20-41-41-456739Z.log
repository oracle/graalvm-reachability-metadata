 RecordingAppender extends AppenderSkeleton {\n        private final List<LoggingEvent> events = new ArrayList<>();\n\n        @Override\n        protected void append(LoggingEvent event) {\n            events.add(event);\n        }\n\n        @Override\n        public void close() {\n            closed = true;\n        }\n\n        @Override\n        public boolean requiresLayout() {\n            return false;\n        }\n    }\n}\n"}
