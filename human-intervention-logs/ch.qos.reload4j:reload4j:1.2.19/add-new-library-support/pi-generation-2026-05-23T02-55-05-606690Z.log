  package ch_qos_reload4j.reload4j;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.util.Properties;
  
  import org.apache.log4j.config.PropertySetter;
  import org.apache.log4j.spi.OptionHandler;
  import org.junit.jupiter.api.Test;
  
  public class PropertySetterTest {
  
      @Test
      void setsNestedOptionHandlerPropertyFromProperties() {
          ConfigBean configBean = new ConfigBean();
          Properties properties = new Properties();
          String prefix = "log4j.appender.example.";
          properties.setProperty(prefix + "handler", ConfigurableOptionHandler.class.getName());
          properties.setProperty(prefix + "handler.name", "nested");
          properties.setProperty(prefix + "handler.enabled", "true");
  
          PropertySetter.setProperties(configBean, properties, prefix);
  
          assertThat(configBean.getHandler()).isNotNull();
          assertThat(configBean.getHandler().getName()).isEqualTo("nested");
          assertThat(configBean.getHandler().isEnabled()).isTrue();
          assertThat(configBean.getHandler().isActivated()).isTrue();
          assertThat(configBean.isHandlerSetterCalled()).isTrue();
      }
  
      public static final class ConfigBean {
          private ConfigurableOptionHandler handler;
          private boolean handlerSetterCalled;
  
          public ConfigurableOptionHandler getHandler() {
              return handler;
          }
  
          public void setHandler(ConfigurableOptionHandler handler) {
              this.handler = handler;
              this.handlerSetterCalled = true;
          }
  
          public boolean isHandlerSetterCalled() {
              return handlerSetterCalled;
          }
      }
  
      public static final class ConfigurableOptionHandler implements OptionHandler {
          private String name;
          private boolean enabled;
          private boolean activated;
  
          public String getName() {
              return name;
          }
  
          public void setName(String name) {
              this.name = name;
          }
  
          public boolean isEnabled() {
              return enabled;
          }
  
          public void setEnabled(boolean enabled) {
              this.enabled = enabled;
          }
  
          public boolean isActivated() {
              return activated;
          }
  
          @Override
          public void activateOptions() {
              this.activated = true;
          }
      }
  }
