[tool-call] delta {"path":"tests/src/ch.qos.reload4j/reload4j/1.2.19/src/test/java/ch_qos_reload4j/reload4j/OptionConverterTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage ch_qos_reload4j.reload4j;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport org.apache.log4j.Level;\nimport org.apache.log4j.helpers.OptionConverter;\nimport org.junit.jupiter.api.Test;\n\npublic class OptionConverterTest {\n\n    @Test\n    void convertsCustomLevelThroughConfiguredLevelClass() {\n        Level defaultLevel = Level.ERROR;\n\n        Level convertedLevel = OptionConverter.toLevel(\"AUDIT#\" + CustomLevel.class.getName(), defaultLevel);\n\n        assertThat(convertedLevel).isSameAs(CustomLevel.AUDIT);\n    }\n\n    @Test\n    void instantiatesClassNameWhenItIsAssignableToRequestedType() {\n        Object defaultValue = new Object();\n\n        Object convertedObject = OptionConverter.instantiateByClassName(\n                InstantiableOption.class.getName(),\n                InstantiableOption.class,\n                defaultValue);\n\n        assertThat(convertedObject).isInstanceOf(InstantiableOption.class);\n        assertThat(convertedObject).isNotSameAs(defaultValue);\n    }\n\n    public static class CustomLevel extends Level {\n\n        static final Level AUDIT = new CustomLevel(35000, \"AUDIT\", 6);\n\n        public CustomLevel(int level, String levelStr, int syslogEquivalent) {\n            super(level, levelStr, syslogEquivalent);\n        }\n\n        public static Level toLevel(String levelName, Level defaultLevel) {\n            if (\"AUDIT\".equalsIgnoreCase(levelName)) {\n                return AUDIT;\n            }\n            return defaultLevel;\n        }\n    }\n\n    public static class InstantiableOption {\n    }\n}\n"}
