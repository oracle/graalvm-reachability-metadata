[tool-call] delta {"path":"tests/src/ch.qos.reload4j/reload4j/1.2.19/src/test/java/ch_qos_reload4j/reload4j/PatternParserTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage ch_qos_reload4j.reload4j;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.util.ArrayList;\nimport java.util.HashMap;\nimport java.util.List;\nimport java.util.Map;\nimport org.apache.log4j.pattern.FormattingInfo;\nimport org.apache.log4j.pattern.PatternConverter;\nimport org.apache.log4j.pattern.PatternParser;\nimport org.junit.jupiter.api.Test;\n\npublic class PatternParserTest {\n\n    @Test\n    void createsRegisteredConvertersWithFactoryMethodAndDefaultConstructorFallback() {\n        Map<String, Class<? extends PatternConverter>> converterRegistry = new HashMap<>();\n        converterRegistry.put(\"factory\", FactoryPatternConverter.class);\n        converterRegistry.put(\"legacy\", LegacyPatternConverter.class);\n        List<PatternConverter> patternConverters = new ArrayList<>();\n        List<FormattingInfo> formattingInfos = new ArrayList<>();\n\n        PatternParser.parse(\n                \"%factory{alpha}{beta} %legacy\",\n                patternConverters,\n                formattingInfos,\n                converterRegistry,\n                PatternParser.getPatternLayoutRules());\n\n        assertThat(patternConverters)\n                .hasSize(3)\n                .element(0)\n                .isInstanceOf(FactoryPatternConverter.class);\n        assertThat(patternConverters.get(2)).isInstanceOf(LegacyPatternConverter.class);\n        assertThat(formattingInfos).hasSameSizeAs(patternConverters);\n\n        StringBuffer output = new StringBuffer();\n        for (PatternConverter patternConverter : patternConverters) {\n            patternConverter.format(new Object(), output);\n        }\n        assertThat(output).hasToString(\"factory:alpha,beta legacy\");\n    }\n\n    public static final class FactoryPatternConverter extends PatternConverter {\n\n        private final String[] options;\n\n        private FactoryPatternConverter(String[] options) {\n            super(\"factory\", \"factory\");\n            this.options = options.clone();\n        }\n\n        public static FactoryPatternConverter newInstance(String[] options) {\n            return new FactoryPatternConverter(options);\n        }\n\n        @Override\n        public void format(Object obj, StringBuffer toAppendTo) {\n            toAppendTo.append(getName()).append(':').append(String.join(\",\", options));\n        }\n    }\n\n    public static final class LegacyPatternConverter extends PatternConverter {\n\n        public LegacyPatternConverter() {\n            super(\"legacy\", \"legacy\");\n        }\n\n        @Override\n        public void format(Object obj, StringBuffer toAppendTo) {\n            toAppendTo.append(getName());\n        }\n    }\n}\n"}
