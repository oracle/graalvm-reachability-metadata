  package ch_qos_reload4j.reload4j;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import org.apache.log4j.Level;
  import org.apache.log4j.helpers.OptionConverter;
  import org.junit.jupiter.api.Test;
  
  public class OptionConverterTest {
  
      @Test
      void convertsCustomLevelThroughConfiguredLevelClass() {
          Level defaultLevel = Level.ERROR;
  
          Level convertedLevel = OptionConverter.toLevel("AUDIT#" + CustomLevel.class.getName(), defaultLevel);
  
          assertThat(convertedLevel).isSameAs(CustomLevel.AUDIT);
      }
  
      @Test
      void instantiatesClassNameWhenItIsAssignableToRequestedType() {
          Object defaultValue = new Object();
  
          Object convertedObject = OptionConverter.instantiateByClassName(
                  InstantiableOption.class.getName(),
                  InstantiableOption.class,
                  defaultValue);
  
          assertThat(convertedObject).isInstanceOf(InstantiableOption.class);
          assertThat(convertedObject).isNotSameAs(defaultValue);
      }
  
      public static final class CustomLevel extends Level {
  
          private static final Level AUDIT = new CustomLevel(35000, "AUDIT", 6);
  
          public CustomLevel(int level, String levelStr, int syslogEquivalent) {
              super(level, levelStr, syslogEquivalent);
          }
  
          public static Level toLevel(String levelName, Level defaultLevel) {
              if ("AUDIT".equalsIgnoreCase(levelName)) {
                  return AUDIT;
              }
              return defaultLevel;
          }
      }
  
      public static final class InstantiableOption {
      }
  }
