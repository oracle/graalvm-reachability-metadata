  	if (currentLocale != dateLocale || dateFormat == null) {
  	    dateLocale = currentLocale;
  	    dateFormat = DateFormat.getDateTimeInstance(DateFormat.SHORT, DateFormat.SHORT, currentLocale);
  	}
  	return dateFormat.format(d);
      }
  
