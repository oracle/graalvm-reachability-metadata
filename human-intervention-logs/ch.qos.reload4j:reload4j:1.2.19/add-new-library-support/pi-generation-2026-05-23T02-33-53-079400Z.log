[tool-call] delta {"path":"tests/src/ch.qos.reload4j/reload4j/1.2.19/src/test/java/ch_qos_reload4j/reload4j/LogSFTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage ch_qos_reload4j.reload4j;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.util.ArrayList;\nimport java.util.List;\nimport org.apache.log4j.AppenderSkeleton;\nimport org.apache.log4j.Level;\nimport org.apache.log4j.LogManager;\nimport org.apache.log4j.LogSF;\nimport org.apache.log4j.Logger;\nimport org.apache.log4j.spi.LoggingEvent;\nimport org.junit.jupiter.api.AfterEach;\nimport org.junit.jupiter.api.Test;\n\npublic class LogSFTest {\n\n    private static final String BUNDLE_NAME = \"ch_qos_reload4j.reload4j.LogSFMessages\";\n\n    @AfterEach\n    void resetLogging() {\n        LogManager.shutdown();\n        LogManager.resetConfiguration();\n    }\n\n    @Test\n    void formatsLogMessageFromResourceBundle() {\n        Logger logger = Logger.getLogger(LogSFTest.class);\n        logger.setAdditivity(false);\n        logger.setLevel(Level.INFO);\n        CapturingAppender appender = new CapturingAppender();\n        logger.addAppender(appender);\n\n        LogSF.logrb(logger, Level.INFO, BUNDLE_NAME, \"greeting\", new Object[] {\"native image\"});\n\n        assertThat(appender.events()).hasSize(1);\n        LoggingEvent event = appender.events().get(0);\n        assertThat(event.getLevel()).isSameAs(Level.INFO);\n        assertThat(event.getMessage()).isEqualTo(\"Hello native image\");\n    }\n\n    private static final class CapturingAppender extends AppenderSkeleton {\n\n        private final List<LoggingEvent> events = new ArrayList<>();\n\n        @Override\n        protected void append(LoggingEvent event) {\n            events.add(event);\n        }\n\n        @Override\n        public void close() {\n        }\n\n        @Override\n        public boolean requiresLayout() {\n            return false;\n        }\n\n        private List<LoggingEvent> events() {\n            return events;\n        }\n    }\n}\n"}
