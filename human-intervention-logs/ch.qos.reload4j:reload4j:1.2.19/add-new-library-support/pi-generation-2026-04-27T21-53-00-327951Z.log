actor.INSTANCE.getPropertyKeySet(event);\n\n            assertThat(propertyKeys).containsExactlyInAnyOrder(\"operation\", \"component\");\n        } finally {\n            MDC.clear();\n            keySetMethodField.set(MDCKeySetExtractor.INSTANCE, originalKeySetMethod);\n        }\n    }\n"}]}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 617, "output": 1133, "cacheRead": 36864, "cacheWrite": 0, "totalTokens": 38614, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777326900388, "responseId": "resp_05ae78fccf4f79d70169efdb34d63c81a0b935f2c72a5e4bd8"}}
