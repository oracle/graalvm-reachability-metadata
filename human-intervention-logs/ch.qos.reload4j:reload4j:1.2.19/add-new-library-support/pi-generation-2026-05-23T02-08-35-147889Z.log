ger,\n                System.currentTimeMillis(),\n                Level.INFO,\n                \"message with properties\",\n                Thread.currentThread().getName(),\n                null,\n                null,\n                null,\n                properties\n        );\n\n        Set<?> propertyKeys = MDCKeySetExtractor.INSTANCE.getPropertyKeySet(event);\n\n        assertThat(propertyKeys).containsExactlyInAnyOrder(\"requestId\", \"tenant\");\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1068, "output": 508, "cacheRead": 33792, "cacheWrite": 0, "totalTokens": 35368, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1779502061326, "responseId": "resp_0643568f61f4f3c9016a110bede49081918893bbc05abf0ebf"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_NnJMmH0oJISP9RzRDmIjbNHG|fc_0643568f61f4f3c9016a110bf1e6bc819185b182c2442f3b6c", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1635 bytes to tests/src/ch.qos.reload4j/reload4j/1.2.19/src/test/java/ch_qos_reload4j/reload4j/MDCKeySetExtractorTest.java"}], "isError": false, "timestamp": 1779502068107}]}
