 {"path": "tests/src/ch.qos.reload4j/reload4j/1.2.19/src/test/java/ch_qos_reload4j/reload4j/MDCKeySetExtractorTest.java"}}, {"type": "toolCall", "id": "call_IG2UbUbEggaw49AzkYJdkJfl|fc_0643568f61f4f3c9016a110cc9b4c481919c6ce5ca2bddff66", "name": "read", "arguments": {"path": "tests/src/ch.qos.reload4j/reload4j/1.2.19/build.gradle"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 803, "output": 357, "cacheRead": 46080, "cacheWrite": 0, "totalTokens": 47240, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1779502275345, "responseId": "resp_0643568f61f4f3c9016a110cc3fbfc8191b946c730fec69667"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_YnydCrWsarh1zVdaKaWfhOei|fc_0643568f61f4f3c9016a110cc9b4ac8191a018f8889c3635cf", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage ch_qos_reload4j.reload4j;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.File;\nimport java.lang.reflect.Constructor;\nimport java.lang.reflect.Field;\nimport java.lang.reflect.Method;\nimport java.net.URL;\nimport java.net.URLClassLoader;\nimport java.util.Map;\nimport java.util.Set;\nimport org.apache.log4j.Level;\nimport org.apache.log4j.LogManager;\nimport org.apache.log4j.Logger;\nimport org.apache.log4j.helpers.MDCKeySetExtractor;\nimport org.apache.log4j.spi.LoggingEvent;\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.AfterEach;\nimport org.junit.jupiter.api.Test;\n\npublic class MDCKeySetExtractorTest {\n\n    @AfterEach\n    void resetLogging() {\n        LogManager.shutdown();\n        LogManager.resetConfiguration();\n    }\n\n    @Test\n    void extractsPropertyKeysFromLoggingEvent() throws Exception {\n        Logger logger = Logger.getLogger(MDCKeySetExtractorTest.class);\n        Map<String, String> properties = Map.of(\n                \"requestId\", \"request-123\",\n                \"tenant\", \"test-tenant\"\n        );\n        LoggingEvent event = new LoggingEvent(\n                MDCKeySetExtractorTest.class.getName(),\n                logger,\n                System.currentTimeMillis(),\n                Level.INFO,\n                \"message with properties\",\n                Thread.currentThread().getName(),\n                null,\n                null,\n                null,\n                properties\n        );\n\n        Set<?> propertyKeys = MDCKeySetExtractor.INSTANCE.getPropertyKeySet(event);\n\n        assertThat(propertyKeys).isEqualTo(Set.of(\"requestId\", \"tenant\"));\n    }\n\n    @Test\n    void extractsPropertyKeysFromLegacyLoggingEventBySerialization() throws Exception {\n        try {\n            Set<?> propertyKeys = extractPropertyKeysFromLegacyLoggingEvent();\n\n            assertThat(propertyKeys).isEqualTo(Set.of(\"requestId\", \"tenant\"));\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    private static Set<?> extractPropertyKeysFromLegacyLoggingEvent() throws Exception {\n        File legacyLog4jJar = new File(System.getProperty(\"reload4j.legacy.log4j.jar\"));\n        File reload4jJar = new File(System.getProperty(\"reload4j.jar\"));\n        URL[] urls = {legacyLog4jJar.toURI().toURL(), reload4jJar.toURI().toURL()};\n\n        try (URLClassLoader classLoader = new URLClassLoader(urls, null)) {\n            Class<?> loggerClass = classLoader.loadClass(\"org.apache.log4j.Logger\");\n            Class<?> categoryClass = classLoader.loadClass(\"org.apache.log4j.Category\");\n            Class<?> priorityClass = classLoader.loadClass(\"org.apache.log4j.Priority\");\n            Class<?> levelClass = classLoader.loadClass(\"org.apache.log4j.Level\");\n            Class<?> mdcClass = classLoader.loadClass(\"org.apache.log4j.MDC\");\n            Class<?> loggingEventClass = classLoader.loadClass(\"org.apache.log4j.spi.LoggingEvent\");\n            Class<?> extractorClass = classLoader.loadClass(\"org.apache.log4j.helpers.MDCKeySetExtractor\");\n\n            Method getLoggerMethod = loggerClass.getMethod(\"getLogger\", String.class);\n            Object logger = getLoggerMethod.invoke(null, MDCKeySetExtractorTest.class.getName());\n            Field infoLevelField = levelClass.getField(\"INFO\");\n            Object infoLevel = infoLevelField.get(null);\n            Method mdcPutMethod = mdcClass.getMethod(\"put\", String.class, Object.class);\n            mdcPutMethod.invoke(null, \"requestId\", \"request-123\");\n            mdcPutMethod.invoke(null, \"tenant\", \"test-tenant\");\n\n            Constructor<?> constructor = loggingEventClass.getConstructor(\n                    String.class,\n                    categoryClass,\n                    priorityClass,\n                    Object.class,\n                    Throwable.class\n            );\n            Object event = constructor.newInstance(\n                    MDCKeySetExtractorTest.class.getName(),\n                    logger,\n                    infoLevel,\n                    \"message with legacy properties\",\n                    null\n            );\n\n            Field instanceField = extractorClass.getField(\"INSTANCE\");\n            Object extractor = instanceField.get(null);\n            Method getPropertyKeySetMethod = extractorClass.getMethod(\"getPropertyKeySet\", loggingEventClass);\n            Object propertyKeys = getPropertyKeySetMethod.invoke(extractor, event);\n\n            Method mdcRemoveMethod = mdcClass.getMethod(\"remove\", String.class);\n            mdcRemoveMethod.invoke(null, \"requestId\");\n            mdcRemoveMethod.invoke(null, \"tenant\");\n\n            assertThat(propertyKeys).isInstanceOf(Set.class);\n            return (Set<?>) propertyKeys;\n        }\n    }\n}\n\n"}], "isError": false, "timestamp": 1779502281908}, {"role": "toolResult", "toolCallId": "call_IG2UbUbEggaw49AzkYJdkJfl|fc_0643568f61f4f3c9016a110cc9b4c481919c6ce5ca2bddff66", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\nimport java.net.Inet4Address\nimport java.net.InetAddress\nimport java.net.NetworkInterface\n\nplugins {\n    id \"org.graalvm.internal.tck\"\n}\n\nString libraryVersion = tck.testedLibraryVersion.get()\nFile jmdnsHostsFile = layout.buildDirectory.file(\"generated/jmdns/hosts\").get().asFile\n\nString findNonLoopbackIpv4Address() {\n    Enumeration<NetworkInterface> networkInterfaces = NetworkInterface.getNetworkInterfaces()\n    while (networkInterfaces.hasMoreElements()) {\n        NetworkInterface networkInterface = networkInterfaces.nextElement()\n        if (!networkInterface.isUp() || networkInterface.isLoopback() || networkInterface.isVirtual()) {\n            continue\n        }\n        Enumeration<InetAddress> inetAddresses = networkInterface.getInetAddresses()\n        while (inetAddresses.hasMoreElements()) {\n            InetAddress inetAddress = inetAddresses.nextElement()\n            if (inetAddress instanceof Inet4Address && !inetAddress.isLoopbackAddress() && !inetAddress.isLinkLocalAddress()) {\n                return inetAddress.getHostAddress()\n            }\n        }\n    }\n    throw new GradleException(\"No non-loopback IPv4 address available for JmDNS test\")\n}\n\nvoid writeJmDnsHostsFile(File hostsFile) {\n    InetAddress localHost = InetAddress.getLocalHost()\n    Set<String> hostNames = new LinkedHashSet<>()\n    hostNames.add(localHost.getHostName())\n    hostNames.add(localHost.getCanonicalHostName())\n    hostNames.add(System.getenv(\"HOSTNAME\"))\n    hostNames.removeAll([null, \"\", \"localhost\", \"localhost.localdomain\"])\n    if (hostNames.isEmpty()) {\n        throw new GradleException(\"No host name available for JmDNS test\")\n    }\n\n    hostsFile.parentFile.mkdirs()\n    hostsFile.text = \"${findNonLoopbackIpv4Address()} ${hostNames.join(' ')}\\n127.0.0.1 localhost\\n\"\n}\n\nClosure<String> reload4jJarPath = {\n    File reload4jJar = configurations.testRuntimeClasspath.files.find { File file ->\n        file.name == \"reload4j-${libraryVersion}.jar\"\n    }\n    if (reload4jJar == null) {\n        throw new GradleException(\"Could not find reload4j runtime JAR\")\n    }\n    return reload4jJar.absolutePath\n}\n\nconfigurations {\n    jmdnsVersion1Runtime\n    jmdnsVersion3Runtime\n    legacyLog4jRuntime\n}\n\ndependencies {\n    testImplementation \"ch.qos.reload4j:reload4j:$libraryVersion\"\n    testImplementation 'org.assertj:assertj-core:3.22.0'\n    testImplementation 'jmdns:jmdns:1.0'\n    legacyLog4jRuntime 'log4j:log4j:1.2.14'\n    jmdnsVersion1Runtime 'jmdns:jmdns:1.0'\n    jmdnsVersion3Runtime 'org.jmdns:jmdns:3.5.8'\n}\n\ntasks.withType(Test).configureEach {\n    systemProperty \"jdk.net.hosts.file\", jmdnsHostsFile.absolutePath\n    systemProperty \"reload4j.jar\", reload4jJarPath()\n    systemProperty \"reload4j.legacy.log4j.jar\", configurations.legacyLog4jRuntime.singleFile.absolutePath\n    doFirst {\n        writeJmDnsHostsFile(jmdnsHostsFile)\n    }\n}\n\ntasks.register(\"zeroConfSupportJmDns3Test\", Test) {\n    description = \"Exercises ZeroConfSupport with the JmDNS version 3 API.\"\n    group = \"verification\"\n    testClassesDirs = sourceSets.test.output.classesDirs\n    classpath = sourceSets.test.runtimeClasspath\n            .minus(configurations.jmdnsVersion1Runtime)\n            .plus(configurations.jmdnsVersion3Runtime)\n    include \"**/ZeroConfSupportTest.class\"\n    useJUnitPlatform()\n}\n\ntasks.named(\"test\") {\n    dependsOn tasks.named(\"zeroConfSupportJmDns3Test\")\n}\n\ntasks.named(\"jacocoTestReport\") {\n    dependsOn tasks.named(\"zeroConfSupportJmDns3Test\")\n    executionData fileTree(dir: layout.buildDirectory.dir(\"jacoco\").get().asFile, include: \"*.exec\")\n}\n\ntasks.named(\"nativeTest\") {\n    runtimeArgs.add(\"-Djdk.net.hosts.file=${jmdnsHostsFile.absolutePath}\")\n    runtimeArgs.add(\"-Dreload4j.jar=${reload4jJarPath()}\")\n    runtimeArgs.add(\"-Dreload4j.legacy.log4j.jar=${configurations.legacyLog4jRuntime.singleFile.absolutePath}\")\n    doFirst {\n        writeJmDnsHostsFile(jmdnsHostsFile)\n    }\n}\n\ngraalvmNative {\n    agent {\n        defaultMode = \"conditional\"\n        modes {\n            conditional {\n                userCodeFilterPath = \"user-code-filter.json\"\n            }\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1779502281908}]}
