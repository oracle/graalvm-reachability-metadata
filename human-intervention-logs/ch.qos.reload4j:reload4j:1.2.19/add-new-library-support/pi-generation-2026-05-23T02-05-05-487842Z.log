  public class DOMConfiguratorTest {
  
      private PrintStream originalOut;
      private ByteArrayOutputStream capturedOut;
  
      @BeforeEach
      void captureConsoleOutput() {
          LogManager.resetConfiguration();
          originalOut = System.out;
          capturedOut = new ByteArrayOutputStream();
          System.setOut(new PrintStream(capturedOut, true, StandardCharsets.UTF_8));
      }
  
      @AfterEach
      void restoreLoggingAndConsoleOutput() {
          LogManager.shutdown();
          LogManager.resetConfiguration();
          System.setOut(originalOut);
      }
  
      @Test
      void configuresXmlAppenderLayoutThrowableRendererLoggerSubclassAndLevelSubclass() throws Exception {
          String loggerName = DOMConfiguratorTest.class.getName() + ".configured." + System.nanoTime();
          Element configurationElement = parseElement("""
                  <log4j:configuration xmlns:log4j="http://jakarta.apache.org/log4j/" reset="true">
                    <appender name="console" class="org.apache.log4j.ConsoleAppender">
                      <param name="Target" value="System.out"/>
                      <layout class="org.apache.log4j.PatternLayout">
                        <param name="ConversionPattern" value="%p:%c:%m%n"/>
                      </layout>
                    </appender>
                    <throwableRenderer class="org.apache.log4j.DefaultThrowableRenderer"/>
                    <logger name="${loggerName}" class="org.apache.log4j.Logger" additivity="false">
                      <level value="INFO" class="org.apache.log4j.Level"/>
                      <appender-ref ref="console"/>
                    </logger>
                    <root>
                      <priority value="WARN" class="org.apache.log4j.Level"/>
                    </root>
                  </log4j:configuration>
                  """.replace("${loggerName}", loggerName));
  
          new DOMConfigurator().doConfigure(configurationElement, LogManager.getLoggerRepository());
  
          Logger logger = LogManager.getLogger(loggerName);
          Appender appender = logger.getAppender("console");
          ThrowableRendererSupport rendererSupport = (ThrowableRendererSupport) LogManager.getLoggerRepository();
  
          assertThat(logger.getLevel()).isEqualTo(Level.INFO);
