inal List<ServiceInfo> registeredServices = new ArrayList<>();\n\n                    public JmDNS() {\n                    }\n\n                    public void registerService(ServiceInfo serviceInfo) {\n                        registeredServices.add(serviceInfo);\n                    }\n\n                    public void unregisterService(ServiceInfo serviceInfo) {\n                        registeredServices.remove(serviceInfo);\n                    }\n\n                    public List<ServiceInfo> getRegisteredServices() {\n                        return Collections.unmodifiableList(registeredServices);\n                    }\n                }\n                \"\"\";\n    }\n\n    private static String version1ServiceInfoSource() {\n        return \"\"\"\n                package javax.jmdns;\n\n                import java.util.Hashtable;\n\n                public class ServiceInfo {\n                    private final String type;\n                    private final String name;\n                    private final int port;\n                    private final Hashtable<?, ?> properties;\n\n                    public ServiceInfo(String type, String name, int port, int weight, int priority,\n                            Hashtable<?, ?> properties) {\n                        this.type = type;\n                        this.name = name;\n                        this.port = port;\n                        this.properties = properties;\n                    }\n\n                    @Override\n                    public String toString() {\n                        return type + \":\" + name + \":\" + port + \":\" + properties;\n                    }\n                }\n                \"\"\";\n    }\n\n", "newText": ""}]}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 3960, "output": 1139, "cacheRead": 48128, "cacheWrite": 0, "totalTokens": 53227, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReas