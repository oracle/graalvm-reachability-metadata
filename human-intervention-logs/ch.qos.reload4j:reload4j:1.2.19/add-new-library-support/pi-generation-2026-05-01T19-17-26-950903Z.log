  package javax.jmdns;
  
  import java.util.Collections;
  import java.util.LinkedHashMap;
  import java.util.Map;
  
  public class ServiceInfo {
      private final String type;
      private final String name;
      private final int port;
      private final int weight;
      private final int priority;
      private final Map<Object, Object> properties;
  
      private ServiceInfo(String type, String name, int port, int weight, int priority, Map<?, ?> properties) {
          this.type = type;
          this.name = name;
          this.port = port;
          this.weight = weight;
          this.priority = priority;
          Map<Object, Object> copiedProperties = new LinkedHashMap<>();
          copiedProperties.putAll(properties);
          this.properties = Collections.unmodifiableMap(copiedProperties);
      }
  
      public static ServiceInfo create(
              String type, String name, int port, int weight, int priority, Map<?, ?> properties) {
          return new ServiceInfo(type, name, port, weight, priority, properties);
      }
  
      public String getType() {
          return type;
      }
  
      public String getName() {
          return name;
      }
  
      public int getPort() {
          return port;
      }
  
      public int getWeight() {
          return weight;
      }
  
      public int getPriority() {
          return priority;
      }
  
      public Map<Object, Object> getProperties() {
          return properties;
      }
  }
