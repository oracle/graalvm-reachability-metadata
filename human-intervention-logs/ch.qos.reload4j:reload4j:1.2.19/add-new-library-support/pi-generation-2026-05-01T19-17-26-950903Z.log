mdns.ServiceInfo;\n\nimport org.apache.log4j.net.ZeroConfSupport;\nimport org.junit.jupiter.api.Test;\n\npublic class ZeroConfSupportTest {\n    @Test\n    void advertisesAndUnadvertisesServiceThroughJmDnsVersion3Api() {\n        JmDNS jmDNS = (JmDNS) ZeroConfSupport.getJMDNSInstance();\n        jmDNS.clear();\n\n        Map<String, String> properties = new LinkedHashMap<>();\n        properties.put(\"endpoint\", \"integration-test\");\n        properties.put(\"transport\", \"tcp\");\n\n        ZeroConfSupport zeroConfSupport = new ZeroConfSupport(\"_log4j._tcp.local.\", 4560, \"reload4j-test\", properties);\n\n        zeroConfSupport.advertise();\n\n        assertThat(jmDNS.getRegisteredServices()).hasSize(1);\n        ServiceInfo serviceInfo = jmDNS.getRegisteredServices().get(0);\n        assertThat(serviceInfo.getType()).isEqualTo(\"_log4j._tcp.local.\");\n        assertThat(serviceInfo.getName()).isEqualTo(\"reload4j-test\");\n        assertThat(serviceInfo.getPort()).isEqualTo(4560);\n        assertThat(serviceInfo.getWeight()).isZero();\n        assertThat(serviceInfo.getPriority()).isZero();\n        assertThat(serviceInfo.getProperties()).containsExactlyEntriesOf(properties);\n\n        zeroConfSupport.unadvertise();\n\n        assertThat(jmDNS.getRegisteredServices()).isEmpty();\n        assertThat(jmDNS.getUnregisteredServices()).containsExactly(serviceInfo);\n    }\n}\n"}], "isError": false, "timestamp": 1777663032453}, {"role": "toolResult", "toolCallId": "call_YwaBvIeTvz8re1KALRPDS2nR|fc_0c77dd3e4a71f1640169f4fc37f94881a0bba5bb1a30eadfc0", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage javax.jmdns;\n\nimport java.util.ArrayList;\nimport java.util.Collections;\nimport java.util.List;\n\npublic class JmDNS {\n    private final List<ServiceInfo> registeredServices = new ArrayList<>();\n    private final List<ServiceInfo> unregisteredServices = new ArrayList<>();\n\n    public static JmDNS create() {\n        return new JmDNS();\n    }\n\n    public void registerService(ServiceInfo serviceInfo) {\n        if (serviceInfo == null) {\n            throw new IllegalArgumentException(\"serviceInfo must not be null\");\n        }\n        registeredServices.add(serviceInfo);\n    }\n\n    public void unregisterService(ServiceInfo serviceInfo) {\n        if (serviceInfo == null) {\n            throw new IllegalArgumentException(\"serviceInfo must not be null\");\n        }\n        registeredServices.remove(serviceInfo);\n        unregisteredServices.add(serviceInfo);\n    }\n\n    public List<ServiceInfo> getRegisteredServices() {\n        return Collections.unmodifiableList(registeredServices);\n    }\n\n    public List<ServiceInfo> getUnregisteredServices() {\n        return Collections.unmodifiableList(unregisteredServices);\n    }\n\n    public void clear() {\n        registeredServices.clear();\n        unregisteredServices.clear();\n    }\n}\n"}], "isError": false, "timestamp": 1777663032453}, {"role": "toolResult", "toolCallId": "call_ongzjlckzE5GRh4R7yO1mUOL|fc_0c77dd3e4a71f1640169f4fc37f95481a0bfc4ad18a9fd6769", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage javax.jmdns;\n\nimport java.util.Collections;\nimport java.util.LinkedHashMap;\nimport java.util.Map;\n\npublic class ServiceInfo {\n    private final String type;\n    private final String name;\n    private final int port;\n    private final int weight;\n    private final int priority;\n    private final Map<Object, Object> properties;\n\n    private ServiceInfo(String type, String name, int port, int weight, int priority, Map<?, ?> properties) {\n        this.type = type;\n        this.name = name;\n        this.port = port;\n        this.weight = weight;\n        this.priority = priority;\n        Map<Object, Object> copiedProperties = new LinkedHashMap<>();\n        copiedProperties.putAll(properties);\n        this.properties = Collections.unmodifiableMap(copiedProperties);\n    }\n\n    public static ServiceInfo create(\n            String type, String name, int port, int weight, int priority, Map<?, ?> properties) {\n        return new ServiceInfo(type, name, port, weight, priority, properties);\n    }\n\n    public String getType() {\n        return type;\n    }\n\n    public String getName() {\n        return name;\n    }\n\n    public int getPort() {\n        return port;\n    }\n\n    public int getWeight() {\n        return weight;\n    }\n\n    public int getPriority() {\n        return priority;\n    }\n\n    public Map<Object, Object> getProperties() {\n        return properties;\n    }\n}\n"}], "isError": false, "timestamp": 1777663032454}, {"role": "toolResult", "toolCallId": "call_0xhOUfnF9qxa13SzgXQAIOZD|fc_0c77dd3e4a71f1640169f4fc37f95c81a08b306de91472caa2", "toolName": "read", "content": [{"type": "text", "text": "{\n  \"reflection\" : [\n    {\n      \"condition\" : {\n        \"typeReached\" : \"org.apache.log4j.net.ZeroConfSupport\"\n      },\n      \"type\" : \"javax.jmdns.JmDNS\",\n      \"methods\" : [\n        {\n          \"name\" : \"create\",\n          \"parameterTypes\" : [ ]\n        },\n        {\n          \"name\" : \"registerService\",\n          \"parameterTypes\" : [ \"javax.jmdns.ServiceInfo\" ]\n        },\n        {\n          \"name\" : \"unregisterService\",\n          \"parameterTypes\" : [ \"javax.jmdns.ServiceInfo\" ]\n        }\n      ]\n    },\n    {\n      \"condition\" : {\n        \"typeReached\" : \"org.apache.log4j.net.ZeroConfSupport\"\n      },\n      \"type\" : \"javax.jmdns.ServiceInfo\",\n      \"methods\" : [\n  