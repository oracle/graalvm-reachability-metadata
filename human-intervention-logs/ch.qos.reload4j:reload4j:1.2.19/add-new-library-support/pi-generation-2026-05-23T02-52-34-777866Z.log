= true;\n        }\n\n        public boolean isHandlerSetterCalled() {\n            return handlerSetterCalled;\n        }\n    }\n\n    public static final class ConfigurableOptionHandler implements OptionHandler {\n        private String name;\n        private boolean enabled;\n        private boolean activated;\n\n        public String getName() {\n            return name;\n        }\n\n        public void setName(String name) {\n            this.name = name;\n        }\n\n        public boolean isEnabled() {\n            return enabled;\n        }\n\n        public void setEnabled(boolean enabled) {\n            this.enabled = enabled;\n        }\n\n        public boolean isActivated() {\n            return activated;\n        }\n\n        @Override\n        public void activateOptions() {\n            this.activated = true;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 2622, "output": 757, "cacheRead": 15872, "cacheWrite": 0, "totalTokens": 19251, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1779504743848, "responseId": "resp_0926d32aff610b7e016a111668a660819da2d22114575059c6"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_pgwnvdlaYYpUhvmQUTiZISo4|fc_0926d32aff610b7e016a11166ad510819d92ff6311b1690ca2", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2548 bytes to tests/src/ch.qos.reload4j/reload4j/1.2.19/src/test/java/ch_qos_reload4j/reload4j/PropertySetterTest.java"}], "isError": false, "timestamp": 1779504750390}]}
