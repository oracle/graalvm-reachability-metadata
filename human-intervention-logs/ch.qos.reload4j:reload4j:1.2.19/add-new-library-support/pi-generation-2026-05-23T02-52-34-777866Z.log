  /*
   * Copyright and related rights waived via CC0
   *
   * You should have received a copy of the CC0 legalcode along with this
   * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.
   */
  import java.net.Inet4Address
  import java.net.InetAddress
  import java.net.NetworkInterface
  
  plugins {
      id "org.graalvm.internal.tck"
  }
  
  String libraryVersion = tck.testedLibraryVersion.get()
  File jmdnsHostsFile = layout.buildDirectory.file("generated/jmdns/hosts").get().asFile
  
  String findNonLoopbackIpv4Address() {
      Enumeration<NetworkInterface> networkInterfaces = NetworkInterface.getNetworkInterfaces()
      while (networkInterfaces.hasMoreElements()) {
          NetworkInterface networkInterface = networkInterfaces.nextElement()
          if (!networkInterface.isUp() || networkInterface.isLoopback() || networkInterface.isVirtual()) {
              continue
          }
          Enumeration<InetAddress> inetAddresses = networkInterface.getInetAddresses()
          while (inetAddresses.hasMoreElements()) {
              InetAddress inetAddress = inetAddresses.nextElement()
              if (inetAddress instanceof Inet4Address && !inetAddress.isLoopbackAddress() && !inetAddress.isLinkLocalAddress()) {
                  return inetAddress.getHostAddress()
              }
          }
      }
      throw new GradleException("No non-loopback IPv4 address available for JmDNS test")
  }
  
  void writeJmDnsHostsFile(File hostsFile) {
      InetAddress localHost = InetAddress.getLocalHost()
      Set<String> hostNames = new LinkedHashSet<>()
      hostNames.add(localHost.getHostName())
      hostNames.add(localHost.getCanonicalHostName())
      hostNames.add(System.getenv("HOSTNAME"))
      hostNames.removeAll([null, "", "localhost", "localhost.localdomain"])
      if (hostNames.isEmpty()) {
          throw new GradleException("No host name available for JmDNS test")
      }
  
      hostsFile.parentFile.mkdirs()
      hostsFile.text = "${findNonLoopbackIpv4Address()} ${hostNames.join(' ')}\n127.0.0.1 localhost\n"
  }
  
  Closure<String> reload4jJarPath = {
      File reload4jJar = configurations.testRuntimeClasspath.files.find { File file ->
          file.name == "reload4j-${libraryVersion}.jar"
      }
      if (reload4jJar == null) {
          throw new GradleException("Could not find reload4j runtime JAR")
      }
      return reload4jJar.absolutePath
  }
  
  configurations {
      jmdnsVersion1Runtime
      jmdnsVersion3Runtime
      legacyLog4jRuntime
  }
  
  dependencies {
      testImplementation "ch.qos.reload4j:reload4j:$libraryVersion"
      testImplementation 'org.assertj:assertj-core:3.22.0'
      testImplementation 'jmdns:jmdns:1.0'
      legacyLog4jRuntime 'log4j:log4j:1.2.14'
      jmdnsVersion1Runtime 'jmdns:jmdns:1.0'
      jmdnsVersion3Runtime 'org.jmdns:jmdns:3.5.8'
  }
  
  tasks.withType(Test).configureEach {
      systemProperty "jdk.net.hosts.file", jmdnsHostsFile.absolutePath
      systemProperty "reload4j.jar", reload4jJarPath()
      systemProperty "reload4j.legacy.log4j.jar", configurations.legacyLog4jRuntime.singleFile.absolutePath
      doFirst {
          writeJmDnsHostsFile(jmdnsHostsFile)
      }
  }
  
  tasks.register("zeroConfSupportJmDns3Test", Test) {
      description = "Exercises ZeroConfSupport with the JmDNS version 3 API."
      group = "verification"
      testClassesDirs = sourceSets.test.output.classesDirs
      classpath = sourceSets.test.runtimeClasspath
              .minus(configurations.jmdnsVersion1Runtime)
              .plus(configurations.jmdnsVersion3Runtime)
      include "**/ZeroConfSupportTest.class"
      useJUnitPlatform()
  }
  
  tasks.named("test") {
      dependsOn tasks.named("zeroConfSupportJmDns3Test")
  }
  
  tasks.named("jacocoTestReport") {
      dependsOn tasks.named("zeroConfSupportJmDns3Test")
      executionData fileTree(dir: layout.buildDirectory.dir("jacoco").get().asFile, include: "*.exec")
  }
  
  tasks.named("nativeTest") {
      runtimeArgs.add("-Djdk.net.hosts.file=${jmdnsHostsFile.absolutePath}")
      runtimeArgs.add("-Dreload4j.jar=${reload4jJarPath()}")
      runtimeArgs.add("-Dreload4j.legacy.log4j.jar=${configurations.legacyLog4jRuntime.singleFile.absolutePath}")
      doFirst {
          writeJmDnsHostsFile(jmdnsHostsFile)
      }
  }
  
  graalvmNative {
      agent {
          defaultMode = "conditional"
          modes {
              conditional {
                  userCodeFilterPath = "user-code-filter.json"
              }
          }
      }
  }
