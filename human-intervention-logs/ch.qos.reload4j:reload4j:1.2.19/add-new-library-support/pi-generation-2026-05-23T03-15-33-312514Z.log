http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage ch_qos_reload4j.reload4j;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport org.apache.log4j.Level;\nimport org.apache.log4j.LogManager;\nimport org.apache.log4j.Logger;\nimport org.apache.log4j.rewrite.ReflectionRewritePolicy;\nimport org.apache.log4j.spi.LoggingEvent;\nimport org.junit.jupiter.api.AfterEach;\nimport org.junit.jupiter.api.Test;\n\npublic class ReflectionRewritePolicyTest {\n\n    @AfterEach\n    void resetLogging() {\n        LogManager.shutdown();\n        LogManager.resetConfiguration();\n    }\n\n    @Test\n    void rewritesBeanMessageIntoLoggingEventProperties() {\n        Logger logger = Logger.getLogger(ReflectionRewritePolicyTest.class);\n        StructuredMessage message = new StructuredMessage(\"rewritten message\", \"alice\", 42);\n        LoggingEvent source = new LoggingEvent(\n                ReflectionRewritePolicyTest.class.getName(),\n                logger,\n                Level.INFO,\n                message,\n                null\n        );\n        source.setProperty(\"accountId\", \"original value\");\n        source.setProperty(\"requestId\", \"request-1\");\n\n        LoggingEvent rewritten = new ReflectionRewritePolicy().rewrite(source);\n\n        assertThat(rewritten).isNotSameAs(source);\n        assertThat(rewritten.getMessage()).isEqualTo(\"rewritten message\");\n        assertThat(rewritten.getProperty(\"requestId\")).isEqualTo(\"request-1\");\n        assertThat(rewritten.getProperties())\n                .containsEntry(\"accountId\", 42)\n                .containsEntry(\"userName\", \"alice\");\n    }\n\n    public static final class StructuredMessage {\n        private final String message;\n        private final String userName;\n        private final int accountId;\n\n        StructuredMessage(String message, String userName, int accountId) {\n            this.message = message;\n            this.userName = userName;\n            this.accountId = accountId;\n        }\n\n        public String getMessage() {\n            return message;\n        }\n\n        public String getUserName() {\n            return userName;\n        }\n\n        public int getAccountId() {\n            return accountId;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1433, "output": 966, "cacheRead": 15360, "cacheWrite": 0, "totalTokens": 17759, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1779506115987, "responseId": "resp_0bdac73d61457ace016a111bc4670081a398083f671fe21a4d"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_fWS8sJeIqn4CklyjCoRVo59O|fc_0bdac73d61457ace016a111bcaf83481a39a65501493f30269", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2350 bytes to tests/src/ch.qos.reload4j/reload4j/1.2.19/src/test/java/ch_qos_reload4j/reload4j/ReflectionRewritePolicyTest.java"}], "isError": false, "timestamp": 1779506126551}]}
