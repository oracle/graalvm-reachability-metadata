  	    errorHandler.error("No remote host is set for SocketAppender named \"" + this.name + "\".");
  	    return;
  	}
  
  	if (oos != null) {
  	    try {
  
  		if (locationInfo) {
  		    event.getLocationInformation();
  		}
  		if (application != null) {
  		    event.setProperty("application", application);
  		}
  		event.getNDC();
  		event.getThreadName();
  		event.getMDCCopy();
  		event.getRenderedMessage();
  		event.getThrowableStrRep();
  
