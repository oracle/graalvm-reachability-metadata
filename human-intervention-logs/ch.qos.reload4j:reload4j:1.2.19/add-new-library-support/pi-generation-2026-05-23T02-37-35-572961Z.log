[tool-call] delta {"path":"tests/src/ch.qos.reload4j/reload4j/1.2.19/src/test/java/ch_qos_reload4j/reload4j/LoggingReceiverInnerSlurperTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage ch_qos_reload4j.reload4j;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.awt.Frame;\nimport java.net.InetAddress;\nimport java.net.ServerSocket;\nimport java.util.concurrent.CountDownLatch;\nimport java.util.concurrent.TimeUnit;\nimport org.apache.log4j.AppenderSkeleton;\nimport org.apache.log4j.Level;\nimport org.apache.log4j.LogManager;\nimport org.apache.log4j.Logger;\nimport org.apache.log4j.chainsaw.Main;\nimport org.apache.log4j.net.SocketAppender;\nimport org.apache.log4j.spi.LoggingEvent;\nimport org.junit.jupiter.api.AfterEach;\nimport org.junit.jupiter.api.Test;\n\npublic class LoggingReceiverInnerSlurperTest {\n\n    private static final String EOF_MESSAGE = \"Reached EOF, closing connection\";\n\n    @AfterEach\n    void resetLoggingAndCloseChainsawWindows() {\n        for (Frame frame : Frame.getFrames()) {\n            frame.dispose();\n        }\n        LogManager.shutdown();\n        LogManager.resetConfiguration();\n    }\n\n    @Test\n    void receivesSerializedLoggingEventsFromSocketAppender() throws Exception {\n        int port = findAvailablePort();\n        String previousPort = System.getProperty(Main.PORT_PROP_NAME);\n        EofAppender eofAppender = new EofAppender();\n\n        try {\n            System.setProperty(Main.PORT_PROP_NAME, Integer.toString(port));\n            Main.main(new String[0]);\n            LogManager.getRootLogger().addAppender(eofAppender);\n\n            Logger sender = Logger.getLogger(LoggingReceiverInnerSlurperTest.class.getName() + \".sender\");\n            sender.setAdditivity(false);\n            sender.setLevel(Level.INFO);\n\n            SocketAppender socketAppender = new SocketAppender(InetAddress.getLoopbackAddress(), port);\n            socketAppender.setName(\"chainsaw-client\");\n            sender.addAppender(socketAppender);\n\n            sender.info(\"message sent to chainsaw receiver\");\n            socketAppender.close();\n            sender.removeAppender(socketAppender);\n\n            assertThat(eofAppender.awaitEof()).isTrue();\n        } finally {\n            restorePortProperty(previousPort);\n        }\n    }\n\n    private static int findAvailablePort() throws Exception {\n        try (ServerSocket serverSocket = new ServerSocket(0)) {\n            return serverSocket.getLocalPort();\n        }\n    }\n\n    private static void restorePortProperty(String previousPort) {\n        if (previousPort == null) {\n            System.clearProperty(Main.PORT_PROP_NAME);\n        } else {\n            System.setProperty(Main.PORT_PROP_NAME, previousPort);\n        }\n    }\n\n    private static final class EofAppender extends AppenderSkeleton {\n\n        private final CountDownLatch eofReached = new CountDownLatch(1);\n\n        @Override\n        protected void append(LoggingEvent event) {\n            if (EOF_MESSAGE.equals(event.getRenderedMessage())) {\n                eofReached.countDown();\n            }\n        }\n\n        boolean awaitEof() throws InterruptedException {\n            return eofReached.await(5, TimeUnit.SECONDS);\n        }\n\n        @Override\n        public void close() {\n        }\n\n        @Override\n        public boolean requiresLayout() {\n            return false;\n        }\n    }\n}\n"}
