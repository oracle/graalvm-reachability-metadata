\n        }\n    }\n\n    @SuppressWarnings(\"deprecation\")\n    private static void stopReceiver(LoggingReceiver receiver, int port) throws InterruptedException {\n        receiver.stop();\n        unblockAccept(port);\n        receiver.join(TIMEOUT.toMillis());\n    }\n\n    private static void unblockAccept(int port) {\n        try (Socket ignored = new Socket(\"127.0.0.1\", port)) {\n            // Unblocks the receiver thread so the pending stop request can be delivered.\n        } catch (IOException ignored) {\n            // The receiver may already have stopped.\n        }\n    }\n\n    public interface ReceiverClient {\n        boolean exchangeWithReceiver(int port) throws Exception;\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 574, "output": 1214, "cacheRead": 25088, "cacheWrite": 0, "totalTokens": 26876, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778100567102, "responseId": "resp_013225cee0bc20b60169fba957dd888194ba7a5d02e1a97c23"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_ECASQWKwtpV3MdGMpAVH9LIF|fc_013225cee0bc20b60169fba962e3248194848aa829d751f9e3", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1737 bytes to tests/src/ch.qos.reload4j/reload4j/1.2.19/src/test/java/org/apache/log4j/chainsaw/LoggingReceiverHarness.java"}], "isError": false, "timestamp": 1778100582417}]}
