  package org.apache.log4j.chainsaw;
  
  import java.io.IOException;
  import java.net.ServerSocket;
  import java.net.Socket;
  import java.time.Duration;
  
  public final class LoggingReceiverHarness {
      private static final Duration TIMEOUT = Duration.ofSeconds(5);
  
      private LoggingReceiverHarness() {
      }
  
      public static boolean runWithReceiver(ReceiverClient client) throws Exception {
          int port = findAvailablePort();
          LoggingReceiver receiver = new LoggingReceiver(new MyTableModel(), port);
          receiver.start();
  
          try {
              return client.exchangeWithReceiver(port);
          } finally {
              stopReceiver(receiver, port);
          }
      }
  
      private static int findAvailablePort() throws IOException {
          try (ServerSocket socket = new ServerSocket(0)) {
              return socket.getLocalPort();
          }
      }
  
      @SuppressWarnings("deprecation")
      private static void stopReceiver(LoggingReceiver receiver, int port) throws InterruptedException {
          receiver.stop();
          unblockAccept(port);
          receiver.join(TIMEOUT.toMillis());
      }
  
      private static void unblockAccept(int port) {
          try (Socket ignored = new Socket("127.0.0.1", port)) {
              // Unblocks the receiver thread so the pending stop request can be delivered.
          } catch (IOException ignored) {
              // The receiver may already have stopped.
          }
      }
  
      public interface ReceiverClient {
          boolean exchangeWithReceiver(int port) throws Exception;
