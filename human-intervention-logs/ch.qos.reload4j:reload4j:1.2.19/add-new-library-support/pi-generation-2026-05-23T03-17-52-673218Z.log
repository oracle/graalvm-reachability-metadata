tream();\n        System.setOut(new PrintStream(capturedOut, true, StandardCharsets.UTF_8));\n    }\n\n    @AfterEach\n    void restoreLoggingAndConsoleOutput() {\n        LogManager.shutdown();\n        LogManager.resetConfiguration();\n        System.setOut(originalOut);\n    }\n\n    @Test\n    void configuresXmlAppenderLayoutThrowableRendererLoggerSubclassAndLevelSubclass() throws Exception {\n        String loggerName = DOMConfiguratorTest.class.getName() + \".configured.\" + System.nanoTime();\n        Element configurationElement = parseElement(\"\"\"\n                <log4j:configuration xmlns:log4j=\"http://jakarta.apache.org/log4j/\" reset=\"true\">\n                  <appender name=\"console\" class=\"org.apache.log4j.ConsoleAppender\">\n                    <param name=\"Target\" value=\"System.out\"/>\n                    <layout class=\"org.apache.log4j.PatternLayout\">\n                      <param name=\"ConversionPattern\" value=\"%p:%c:%m%n\"/>\n                    </layout>\n                  </appender>\n                  <throwableRenderer class=\"org.apache.log4j.DefaultThrowableRenderer\"/>\n                  <logger name=\"${loggerName}\" class=\"org.apache.log4j.Logger\" additivity=\"false\">\n                    <level value=\"INFO\" class=\"org.apache.log4j.Level\"/>\n                    <appender-ref ref=\"console\"/>\n                  </logger>\n                  <root>\n                    <priority value=\"WARN\" class=\"org.apache.log4j.Level\"/>\n                  </root>\n                </log4j:configuration>\n                \"\"\".replace(\"${loggerName}\", loggerName));\n\n        new DOMConfigurator().doConfigure(configurationElement, LogManager.getLoggerRepository());\n\n        Logger logger = LogManager.getLogger(loggerName);\n        Appender appender = logger.getAppender(\"console\");\n        ThrowableRendererSupport rendererSupport = (ThrowableRendererSupport) LogManager.getLoggerRepository();\n\n        assertThat(logger.getLevel()).isEqualTo(Level.INFO);\n        assertThat(logger.getAdditivity()).isFalse();\n        assertThat(appender).isInstanceOf(ConsoleAppender.class);\n        assertThat(appender.getLayout()).isInstanceOf(PatternLayout.class);\n        assertThat(rendererSupport.getThrowableRenderer()).isInstanceOf(DefaultThrowableRenderer.class);\n        assertThat(LogManager.getRootLogger().getLevel()).isEqualTo(Level.WARN);\n\n        logger.info(\"configured message\");\n\n        assertThat(capturedOut.toString(StandardCharsets.UTF_8)).contains(\"INFO:\" + loggerName + \":configured message\");\n    }\n\n    private static Element parseElement(String xml) throws Exception {\n        DocumentBuilderFactory documentBuilderFactory = DocumentBuilderFactory.newInstance();\n        documentBuilderFactory.setNamespaceAware(false);\n        documentBuilderFactory.setValidating(false);\n        DocumentBuilder documentBuilder = documentBuilderFactory.newDocumentBuilder();\n        return documentBuilder.parse(new ByteArrayInputStream(xml.getBytes(StandardCharsets.UTF_8))).getDocumentElement();\n    }\n}\n"}], "isError": false, "timestamp": 1779506213139}, {"role": "toolResult", "toolCallId": "call_pubvWCvq5NApzrLaVhPznAvi|fc_0065c257a8f76590016a111c24f12c81a1ac590bfabab61b72", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_apache_logging_log4j.log4j_1_2_api;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.IOException;\nimport java.io.InputStream;\nimport org.apache.log4j.xml.Log4jEntityResolver;\nimport org.junit.jupiter.api.Test;\nimport org.xml.sax.InputSource;\n\npublic class Log4jEntityResolverTest {\n\n    @Test\n    void resolvesLog4jDtdFromClasspathResource() throws IOException {\n        Log4jEntityResolver resolver = new Log4jEntityResolver();\n\n        InputSource inputSource = resolver.resolveEntity(null, \"https://example.invalid/log4j.dtd\");\n\n        assertThat(inputSource).isNotNull();\n        try (InputStream byteStream = inputSource.getByteStream()) {\n            assertThat(byteStream).isNotNull();\n            assertThat(byteStream.readAllBytes()).isNotNull();\n        }\n    }\n\n    @Test\n    void ignoresUnrelatedExternalEntity() {\n        Log4jEntityResolver resolver = new Log4jEntityResolver();\n\n        InputSource inputSource = resolver.resolveEntity(null, \"https://example.invalid/not-logging.dtd\");\n\n        assertThat(inputSource).isNull();\n    }\n}\n"}], "isError": false, "timestamp": 1779506213139}, {"role": "toolResult", "toolCallId": "call_A4FvZEBHKdgbYhYsEdj9KV3r|fc_0065c257a8f76590016a111c24f13881a1b04c54f22b8432e0", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\nimport java.net.Inet4Address\nimport java.net.InetAddress\nimport java.net.NetworkInterface\n\nplugins {\n    id \"org.graalvm.internal.tck\"\n}\n\nString libraryVersion = tck.testedLibraryVersion.get()\nFile jmdnsHostsFile = layout.buildDirectory.file(\"generated/jmdns/hosts\").get().asFile\n\nString findNonLoopbackIpv4Address() {\n    Enumeration<NetworkInterface> networkInterfaces = NetworkInterface.getNetworkInterfaces()\n    while (networkInterfaces.hasMoreElements()) {\n        NetworkInterface networkInterface = networkInterfaces.nextElement()\n        if (!networkInterface.isUp() || networkInterface.isLoopback() || networkInterface.isVirtual()) {\n            continue\n        }\n        Enumeration<InetAddress> inetAddresses = networkInterface.getInetAddresses()\n        while (inetAddresses.hasMoreElements()) {\n            InetAddress inetAddress = inetAddresses.nextElement()\n            if (inetAddress instanceof Inet4Address && !inetAddress.isLoopbackAddress() && !inetAddress.isLinkLocalAddress()) {\n                return inetAddress.getHostAddress()\n            }\n        }\n    }\n    throw new GradleException(\"No non-loopback IPv4 address available for JmDNS test\")\n}\n\nvoid writeJmDnsHostsFile(File hostsFile) {\n    InetAddress localHost = InetAddress.getLocalHost()\n    Set<String> hostNames = new LinkedHashSet<>()\n    hostNames.add(localHost.getHostName())\n    hostNames.add(localHost.getCanonicalHostName())\n    hostNames.add(System.getenv(\"HOSTNAME\"))\n    hostNames.removeAll([null, \"\", \"localhost\", \"localhost.localdomain\"])\n    if (hostNames.isEmpty()) {\n        throw new GradleException(\"No host name available for JmDNS test\")\n    }\n\n    hostsFile.parentFile.mkdirs()\n    hostsFile.text = \"${findNonLoopbackIpv4Address()} ${hostNames.join(' ')}\\n127.0.0.1 localhost\\n\"\n}\n\nClosure<String> reload4jJarPath = {\n    File reload4jJar = configurations.testRuntimeClasspath.files.find { File file ->\n        file.name == \"reload4j-${libraryVersion}.jar\"\n    }\n    if (reload4jJar == null) {\n        throw new GradleException(\"Could not find reload4j runtime JAR\")\n    }\n    return reload4jJar.absolutePath\n}\n\nconfigurations {\n    jmdnsVersion1Runtime\n    jmdnsVersion3Runtime\n    legacyLog4jRuntime\n}\n\ndependencies {\n    testImplementation \"ch.qos.reload4j:reload4j:$libraryVersion\"\n    testImplementation 'org.assertj:assertj-core:3.22.0'\n    testImplementation 'jmdns:jmdns:1.0'\n    legacyLog4jRuntime 'log4j:log4j:1.2.14'\n    jmdnsVersion1Runtime 'jmdns:jmdns:1.0'\n    jmdnsVersion3Runtime 'org.jmdns:jmdns:3.5.8'\n}\n\ntasks.withType(Test).configureEach {\n    systemProperty \"jdk.net.hosts.file\", jmdnsHostsFile.absolutePath\n    systemProperty \"reload4j.jar\", reload4jJarPath()\n    systemProperty \"reload4j.legacy.log4j.jar\", configurations.legacyLog4jRuntime.singleFile.absolutePath\n    doFirst {\n        writeJmDnsHostsFile(jmdnsHostsFile)\n    }\n}\n\ntasks.register(\"zeroConfSupportJmDns3Test\", Test) {\n    description = \"Exercises ZeroConfSupport with the JmDNS version 3 API.\"\n    group = \"verification\"\n    testClassesDirs = sourceSets.test.output.classesDirs\n    classpath = sourceSets.test.runtimeClasspath\n            .minus(configurations.jmdnsVersion1Runtime)\n            .plus(configurations.jmdnsVersion3Runtime)\n    include \"**/ZeroConfSupportTest.class\"\n    useJUnitPlatform()\n}\n\ntasks.named(\"test\") {\n    dependsOn tasks.named(\"zeroConfSupportJmDns3Test\")\n}\n\ntasks.named(\"jacocoTestReport\") {\n    dependsOn tasks.named(\"zeroConfSupportJmDns3Test\")\n    executionData fileTree(dir: layout.buildDirectory.dir(\"jacoco\").get().asFile, include: \"*.exec\")\n}\n\ntasks.named(\"nativeTest\") {\n    runtimeArgs.add(\"-Djdk.net.hosts.file=${jmdnsHostsFile.absolutePath}\")\n    runtimeArgs.add(\"-Dreload4j.jar=${reload4jJarPath()}\")\n    runtimeArgs.add(\"-Dreload4j.legacy.log4j.jar=${configurations.legacyLog4jRuntime.singleFile.absolutePath}\")\n    doFirst {\n        writeJmDnsHostsFile(jmdnsHostsFile)\n    }\n}\n\ngraalvmNative {\n    agent {\n        defaultMode = \"conditional\"\n        modes {\n            conditional {\n                userCodeFilterPath = \"user-code-filter.json\"\n            }\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1779506213139}]}
