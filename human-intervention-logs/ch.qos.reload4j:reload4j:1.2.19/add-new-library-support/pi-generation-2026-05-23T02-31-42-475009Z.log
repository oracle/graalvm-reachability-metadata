, "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\nimport java.net.Inet4Address\nimport java.net.InetAddress\nimport java.net.NetworkInterface\n\nplugins {\n    id \"org.graalvm.internal.tck\"\n}\n\nString libraryVersion = tck.testedLibraryVersion.get()\nFile jmdnsHostsFile = layout.buildDirectory.file(\"generated/jmdns/hosts\").get().asFile\n\nString findNonLoopbackIpv4Address() {\n    Enumeration<NetworkInterface> networkInterfaces = NetworkInterface.getNetworkInterfaces()\n    while (networkInterfaces.hasMoreElements()) {\n        NetworkInterface networkInterface = networkInterfaces.nextElement()\n        if (!networkInterface.isUp() || networkInterface.isLoopback() || networkInterface.isVirtual()) {\n            continue\n        }\n        Enumeration<InetAddress> inetAddresses = networkInterface.getInetAddresses()\n        while (inetAddresses.hasMoreElements()) {\n            InetAddress inetAddress = inetAddresses.nextElement()\n            if (inetAddress instanceof Inet4Address && !inetAddress.isLoopbackAddress() && !inetAddress.isLinkLocalAddress()) {\n                return inetAddress.getHostAddress()\n            }\n        }\n    }\n    throw new GradleException(\"No non-loopback IPv4 address available for JmDNS test\")\n}\n\nvoid writeJmDnsHostsFile(File hostsFile) {\n    InetAddress localHost = InetAddress.getLocalHost()\n    Set<String> hostNames = new LinkedHashSet<>()\n    hostNames.add(localHost.getHostName())\n    hostNames.add(localHost.getCanonicalHostName())\n    hostNames.add(System.getenv(\"HOSTNAME\"))\n    hostNames.removeAll([null, \"\", \"localhost\", \"localhost.localdomain\"])\n    if (hostNames.isEmpty()) {\n        throw new GradleException(\"No host name available for JmDNS test\")\n    }\n\n    hostsFile.parentFile.mkdirs()\n    hostsFile.text = \"${findNonLoopbackIpv4Address()} ${hostNames.join(' ')}\\n127.0.0.1 localhost\\n\"\n}\n\nClosure<String> reload4jJarPath = {\n    File reload4jJar = configurations.testRuntimeClasspath.files.find { File file ->\n        file.name == \"reload4j-${libraryVersion}.jar\"\n    }\n    if (reload4jJar == null) {\n        throw new GradleException(\"Could not find reload4j runtime JAR\")\n    }\n    return reload4jJar.absolutePath\n}\n\nconfigurations {\n    jmdnsVersion1Runtime\n    jmdnsVersion3Runtime\n    legacyLog4jRuntime\n}\n\ndependencies {\n    testImplementation \"ch.qos.reload4j:reload4j:$libraryVersion\"\n    testImplementation 'org.assertj:assertj-core:3.22.0'\n    testImplementation 'jmdns:jmdns:1.0'\n    legacyLog4jRuntime 'log4j:log4j:1.2.14'\n    jmdnsVersion1Runtime 'jmdns:jmdns:1.0'\n    jmdnsVersion3Runtime 'org.jmdns:jmdns:3.5.8'\n}\n\ntasks.withType(Test).configureEach {\n    systemProperty \"jdk.net.hosts.file\", jmdnsHostsFile.absolutePath\n    systemProperty \"reload4j.jar\", reload4jJarPath()\n    systemProperty \"reload4j.legacy.log4j.jar\", configurations.legacyLog4jRuntime.singleFile.absolutePath\n    doFirst {\n        writeJmDnsHostsFile(jmdnsHostsFile)\n    }\n}\n\ntasks.register(\"zeroConfSupportJmDns3Test\", Test) {\n    description = \"Exercises ZeroConfSupport with the JmDNS version 3 API.\"\n    group = \"verification\"\n    testClassesDirs = sourceSets.test.output.classesDirs\n    classpath = sourceSets.test.runtimeClasspath\n            .minus(configurations.jmdnsVersion1Runtime)\n            .plus(configurations.jmdnsVersion3Runtime)\n    include \"**/ZeroConfSupportTest.class\"\n    useJUnitPlatform()\n}\n\ntasks.named(\"test\") {\n    dependsOn tasks.named(\"zeroConfSupportJmDns3Test\")\n}\n\ntasks.named(\"jacocoTestReport\") {\n    dependsOn tasks.named(\"zeroConfSupportJmDns3Test\")\n    executionData fileTree(dir: layout.buildDirectory.dir(\"jacoco\").get().asFile, include: \"*.exec\")\n}\n\ntasks.named(\"nativeTest\") {\n    runtimeArgs.add(\"-Djdk.net.hosts.file=${jmdnsHostsFile.absolutePath}\")\n    runtimeArgs.add(\"-Dreload4j.jar=${reload4jJarPath()}\")\n    runtimeArgs.add(\"-Dreload4j.legacy.log4j.jar=${configurations.legacyLog4jRuntime.singleFile.absolutePath}\")\n    doFirst {\n        writeJmDnsHostsFile(jmdnsHostsFile)\n    }\n}\n\ngraalvmNative {\n    agent {\n        defaultMode = \"conditional\"\n        modes {\n            conditional {\n                userCodeFilterPath = \"user-code-filter.json\"\n            }\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1779503477129}, {"role": "toolResult", "toolCallId": "call_fHCxBeTVEadggy8jxkNa33sU|fc_0ca58116e7c0b3eb016a111174e944819e8763ac8fe613dd82", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage ch_qos_reload4j.reload4j;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport org.apache.log4j.Level;\nimport org.apache.log4j.LogManager;\nimport org.apache.log4j.Logger;\nimport org.apache.log4j.helpers.UtilLoggingLevel;\nimport org.apache.log4j.pattern.LogEvent;\nimport org.junit.jupiter.api.AfterEach;\nimport org.junit.jupiter.api.Test;\n\npublic class LogEventTest {\n\n    @AfterEach\n    void resetLogging() {\n        LogManager.shutdown();\n        LogManager.resetConfiguration();\n    }\n\n    @Test\n    void serializesAndDeserializesStandardAndSubclassedLevels() throws Exception {\n        Logger logger = Logger.getLogger(LogEventTest.class);\n\n        LogEvent standardLevelEvent = serializeAndDeserialize(new LogEvent(\n                LogEventTest.class.getName(),\n                logger,\n                Level.INFO,\n                \"standard level message\",\n                null\n        ));\n        LogEvent subclassedLevelEvent = serializeAndDeserialize(new LogEvent(\n                LogEventTest.class.getName(),\n                logger,\n                UtilLoggingLevel.WARNING,\n                \"util logging level message\",\n                null\n        ));\n\n        assertThat(standardLevelEvent.getLoggerName()).isEqualTo(logger.getName());\n        assertThat(standardLevelEvent.getLevel()).isSameAs(Level.INFO);\n        assertThat(standardLevelEvent.getMessage()).isEqualTo(\"standard level message\");\n        assertThat(subclassedLevelEvent.getLoggerName()).isEqualTo(logger.getName());\n        assertThat(subclassedLevelEvent.getLevel()).isSameAs(UtilLoggingLevel.WARNING);\n        assertThat(subclassedLevelEvent.getMessage()).isEqualTo(\"util logging level message\");\n    }\n\n    private static LogEvent serializeAndDeserialize(LogEvent event) throws Exception {\n        ByteArrayOutputStream output = new ByteArrayOutputStream();\n        try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(output)) {\n            objectOutputStream.writeObject(event);\n        }\n\n        try (ObjectInputStream objectInputStream = new ObjectInputStream(\n                new ByteArrayInputStream(output.toByteArray()))) {\n            Object deserialized = objectInputStream.readObject();\n\n            assertThat(deserialized).isInstanceOf(LogEvent.class);\n            return (LogEvent) deserialized;\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1779503477129}, {"role": "toolResult", "toolCallId": "call_HLyGBZVmB11IuwxUCOMnMOsK|fc_0ca58116e7c0b3eb016a111174e954819e8b421072ac3491cb", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage ch_qos_reload4j.reload4j;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport org.apache.log4j.Level;\nimport org.apache.log4j.LogManager;\nimport org.apache.log4j.Logger;\nimport org.apache.log4j.helpers.UtilLoggingLevel;\nimport org.apache.log4j.spi.LoggingEvent;\nimport org.junit.jupiter.api.AfterEach;\nimport org.junit.jupiter.api.Test;\n\npublic class LoggingEventTest {\n\n    @AfterEach\n    void resetLogging() {\n        LogManager.shutdown();\n        LogManager.resetConfiguration();\n    }\n\n    @Test\n    void serializesAndDeserializesStandardAndSubclassedLevels() throws Exception {\n        Logger logger = Logger.getLogger(LoggingEventTest.class);\n\n        LoggingEvent standardLevelEvent = serializeAndDeserialize(new LoggingEvent(\n                LoggingEventTest.class.getName(),\n                logger,\n                Level.INFO,\n                \"standard level message\",\n                null\n        ));\n        LoggingEvent subclassedLevelEvent = serializeAndDeserialize(new LoggingEvent(\n                LoggingEventTest.class.getName(),\n                logger,\n                UtilLoggingLevel.WARNING,\n                \"util logging level message\",\n                null\n        ));\n\n        assertThat(standardLevelEvent.getLoggerName()).isEqualTo(logger.getName());\n        assertThat(standardLevelEvent.getLevel()).isSameAs(Level.INFO);\n        assertThat(standardLevelEvent.getMessage()).isEqualTo(\"standard level message\");\n        assertThat(subclassedLevelEvent.getLoggerName()).isEqualTo(logger.getName());\n        assertThat(subclassedLevelEvent.getLevel()).isSameAs(UtilLoggingLevel.WARNING);\n        assertThat(subclassedLevelEvent.getMessage()).isEqualTo(\"util logging level message\");\n    }\n\n    private static LoggingEvent serializeAndDeserialize(LoggingEvent event) throws Exception {\n        ByteArrayOutputStream output = new ByteArrayOutputStream();\n        try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(output)) {\n            objectOutputStream.writeObject(event);\n        }\n\n        try (ObjectInputStream objectInputStream = new ObjectInputStream(\n                new ByteArrayInputStream(output.toByteArray()))) {\n            Object deserialized = objectInputStream.readObject();\n\n            assertThat(deserialized).isInstanceOf(LoggingEvent.class);\n            return (LoggingEvent) deserialized;\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1779503477129}, {"role": "toolResult", "toolCallId": "call_JT04WVACuzONNcVM0Yce4dpF|fc_0ca58116e7c0b3eb016a111174e960819e904ed092c8773339", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage ch_qos_reload4j.reload4j;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.util.ArrayList;\nimport java.util.HashMap;\nimport java.util.List;\nimport java.util.Map;\nimport org.apache.log4j.pattern.FormattingInfo;\nimport org.apache.log4j.pattern.PatternConverter;\nimport org.apache.log4j.pattern.PatternParser;\nimport org.junit.jupiter.api.Test;\n\npublic class PatternParserTest {\n\n    @Test\n    void createsRegisteredConvertersWithFactoryMethodAndDefaultConstructorFallback() {\n        Map<String, Class<? extends PatternConverter>> converterRegistry = new HashMap<>();\n        converterRegistry.put(\"factory\", FactoryPatternConverter.class);\n        converterRegistry.put(\"legacy\", LegacyPatternConverter.class);\n        List<PatternConverter> patternConverters = new ArrayList<>();\n        List<FormattingInfo> formattingInfos = new ArrayList<>();\n\n        PatternParser.parse(\n                \"%factory{alpha}{beta} %legacy\",\n                patternConverters,\n                formattingInfos,\n                converterRegistry,\n                PatternParser.getPatternLayoutRules());\n\n        assertThat(patternConverters)\n                .hasSize(3)\n                .element(0)\n                .isInstanceOf(FactoryPatternConverter.class);\n        assertThat(patternConverters.get(2)).isInstanceOf(LegacyPatternConverter.class);\n        assertThat(formattingInfos).hasSameSizeAs(patternConverters);\n\n        StringBuffer output = new StringBuffer();\n        for (PatternConverter patternConverter : patternConverters) {\n            patternConverter.format(new Object(), output);\n        }\n        assertThat(output).hasToString(\"factory:alpha,beta legacy\");\n    }\n\n    public static final class FactoryPatternConverter extends PatternConverter {\n\n        private final String[] options;\n\n        private FactoryPatternConverter(String[] options) {\n            super(\"factory\", \"factory\");\n            this.options = options.clone();\n        }\n\n        public static FactoryPatternConverter newInstance(String[] options) {\n            return new FactoryPatternConverter(options);\n        }\n\n        @Override\n        public void format(Object obj, StringBuffer toAppendTo) {\n            toAppendTo.append(getName()).append(':').append(String.join(\",\", options));\n        }\n    }\n\n    public static final class LegacyPatternConverter extends PatternConverter {\n\n        public LegacyPatternConverter() {\n            super(\"legacy\", \"legacy\");\n        }\n\n        @Override\n        public void format(Object obj, StringBuffer toAppendTo) {\n            toAppendTo.append(getName());\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1779503477129}]}
