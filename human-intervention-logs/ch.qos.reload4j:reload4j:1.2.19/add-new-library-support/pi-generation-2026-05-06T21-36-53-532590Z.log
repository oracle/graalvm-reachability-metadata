.Assertions.assertThat;\n\npublic class Log4jEntityResolverTest {\n    @Test\n    void resolvesBundledLog4jDtdResource() throws Exception {\n        Log4jEntityResolver resolver = new Log4jEntityResolver();\n\n        InputSource source = resolver.resolveEntity(\"-//APACHE//DTD LOG4J 1.2//EN\", \"log4j.dtd\");\n\n        assertThat(source).isNotNull();\n        try (InputStream byteStream = source.getByteStream()) {\n            assertThat(byteStream).isNotNull();\n            String dtd = new String(byteStream.readAllBytes(), StandardCharsets.UTF_8);\n            assertThat(dtd).contains(\"<!ELEMENT log4j:configuration\");\n        }\n    }\n\n    @Test\n    void ignoresUnrecognizedEntities() {\n        Log4jEntityResolver resolver = new Log4jEntityResolver();\n\n        InputSource source = resolver.resolveEntity(\"-//EXAMPLE//DTD OTHER//EN\", \"other.dtd\");\n\n        assertThat(source).isNull();\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1032, "output": 768, "cacheRead": 16384, "cacheWrite": 0, "totalTokens": 18184, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778103389045, "responseId": "resp_015027d6aa7f53f20169fbb45dc3dc81a1b2af8b1c97df679f"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_4zANi1QknTOQqmqK8nG1NbuW|fc_015027d6aa7f53f20169fbb464d46881a1b184811c9a68829d", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1349 bytes to tests/src/ch.qos.reload4j/reload4j/1.2.19/src/test/java/ch_qos_reload4j/reload4j/Log4jEntityResolverTest.java"}], "isError": false, "timestamp": 1778103400191}]}
