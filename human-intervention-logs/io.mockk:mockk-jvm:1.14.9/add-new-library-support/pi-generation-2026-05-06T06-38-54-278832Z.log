          self: Any,
          method: Method,
          args: Array<Any?>,
          otherwise: () -> Any?,
      ): Any? {
          if (self is Class<*>) {
              if (method.isHashCode()) {
                  return System.identityHashCode(self)
              } else if (method.isEquals()) {
                  return self === args[0]
              }
          }
          return otherwise()
      }
  
