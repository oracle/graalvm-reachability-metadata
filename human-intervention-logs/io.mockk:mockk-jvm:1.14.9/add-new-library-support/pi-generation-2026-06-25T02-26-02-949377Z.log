[tool-call] delta {"path":"tests/src/io.mockk/mockk-jvm/1.14.9/src/test/kotlin/io_mockk/mockk_jvm/InjectionHelpersTest.kt","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_mockk.mockk_jvm\n\nimport io.mockk.MockKAnnotations\nimport io.mockk.impl.annotations.InjectMockKs\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\n\npublic class InjectionHelpersTest {\n    @Test\n    fun injectsMatchedValueIntoImmutableProperty(): Unit {\n        val holder: ImmutableInjectionHolder = ImmutableInjectionHolder()\n\n        MockKAnnotations.init(holder)\n\n        assertThat(holder.subject.collaborator).isSameAs(holder.collaborator)\n        assertThat(holder.subject.describe()).isEqualTo(\"injected dependency\")\n    }\n}\n\npublic class ImmutableInjectionHolder {\n    public val collaborator: ImmutableInjectionCollaborator = ImmutableInjectionCollaborator(\"injected dependency\")\n\n    @InjectMockKs(injectImmutable = true)\n    public lateinit var subject: ImmutableInjectionTarget\n}\n\npublic class ImmutableInjectionTarget {\n    public val collaborator: ImmutableInjectionCollaborator? = null\n\n    public fun describe(): String = requireNotNull(collaborator).description\n}\n\npublic class ImmutableInjectionCollaborator(\n    public val description: String,\n)\n"}
