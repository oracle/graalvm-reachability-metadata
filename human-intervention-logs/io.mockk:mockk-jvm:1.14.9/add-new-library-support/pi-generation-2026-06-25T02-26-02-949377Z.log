d dependency\")\n    }\n}\n\npublic class ImmutableInjectionHolder {\n    public val collaborator: ImmutableInjectionCollaborator = ImmutableInjectionCollaborator(\"injected dependency\")\n\n    @InjectMockKs(injectImmutable = true)\n    public lateinit var subject: ImmutableInjectionTarget\n}\n\npublic class ImmutableInjectionTarget {\n    public val collaborator: ImmutableInjectionCollaborator? = null\n\n    public fun describe(): String = requireNotNull(collaborator).description\n}\n\npublic class ImmutableInjectionCollaborator(\n    public val description: String,\n)\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 584, "output": 1195, "cacheRead": 27648, "cacheWrite": 0, "totalTokens": 29427, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1782354279057, "responseId": "resp_0548f02dd2a30021016a3c9167cd908190a86a7503f0031761"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_Ng1LRSoPSriU2m0omoo0Pv6g|fc_0548f02dd2a30021016a3c917727c08190aea439c2244366dd", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1312 bytes to tests/src/io.mockk/mockk-jvm/1.14.9/src/test/kotlin/io_mockk/mockk_jvm/InjectionHelpersTest.kt"}], "isError": false, "timestamp": 1782354296828}]}
