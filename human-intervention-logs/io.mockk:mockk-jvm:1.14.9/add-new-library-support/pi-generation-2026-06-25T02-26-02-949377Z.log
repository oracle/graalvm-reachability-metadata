[tool-call] delta {"path":"tests/src/io.mockk/mockk-jvm/1.14.9/src/test/kotlin/io_mockk/mockk_jvm/InjectionHelpersTest.kt","edits":[{"oldText":"import io.mockk.MockKAnnotations\nimport io.mockk.impl.annotations.InjectMockKs\n","newText":"import io.mockk.impl.annotations.InjectionLookupType\nimport io.mockk.impl.annotations.MockInjector\n"},{"oldText":"    fun injectsMatchedValueIntoImmutableProperty(): Unit {\n        val holder: ImmutableInjectionHolder = ImmutableInjectionHolder()\n\n        MockKAnnotations.init(holder)\n\n        assertThat(holder.subject.collaborator).isSameAs(holder.collaborator)\n        assertThat(holder.subject.describe()).isEqualTo(\"injected dependency\")\n    }\n}\n\npublic class ImmutableInjectionHolder {\n    public val collaborator: ImmutableInjectionCollaborator = ImmutableInjectionCollaborator(\"injected dependency\")\n\n    @InjectMockKs(injectImmutable = true)\n    public lateinit var subject: ImmutableInjectionTarget\n}\n","newText":"    fun injectsMatchedValueIntoImmutableProperty(): Unit {\n        val holder: ImmutableInjectionHolder = ImmutableInjectionHolder()\n        val target: ImmutableInjectionTarget = ImmutableInjectionTarget()\n        val injector: MockInjector = MockInjector(\n            mockHolder = holder,\n            lookupType = InjectionLookupType.BOTH,\n            injectImmutable = true,\n            overrideValues = false,\n        )\n\n        injector.propertiesInjection(target)\n\n        assertThat(target.collaborator).isSameAs(holder.collaborator)\n        assertThat(target.describe()).isEqualTo(\"injected dependency\")\n    }\n}\n\npublic class ImmutableInjectionHolder {\n    public val collaborator: ImmutableInjectionCollaborator = ImmutableInjectionCollaborator(\"injected dependency\")\n}\n"}]}
