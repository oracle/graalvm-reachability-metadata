uments": {"path": "tests/src/io.mockk/mockk-jvm/1.14.9/build.gradle"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 3078, "output": 160, "cacheRead": 11264, "cacheWrite": 0, "totalTokens": 14502, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1782354562720, "responseId": "resp_07a434a34122b0e8016a3c92833a708195aee67bb147b64589"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_j1YRgBt0vBomxC8FlY1aBPK8|fc_07a434a34122b0e8016a3c92858dd88195b3fecd9d70ef063d", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_mockk.mockk_jvm\n\nimport io.mockk.impl.InternalPlatform\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\n\npublic class InternalPlatformTest {\n    @Test\n    fun copiesDeclaredAndInheritedFields(): Unit {\n        val source: InternalPlatformCopyTarget = InternalPlatformCopyTarget(\n            parentValue = \"source-parent\",\n            childValue = \"source-child\",\n            count = 42,\n        )\n        val target: InternalPlatformCopyTarget = InternalPlatformCopyTarget(\n            parentValue = \"target-parent\",\n            childValue = \"target-child\",\n            count = -1,\n        )\n\n        InternalPlatform.copyFields(target, source)\n\n        assertThat(target.snapshot()).isEqualTo(source.snapshot())\n    }\n\n    @Test\n    fun loadsPluginWithDefaultMessage(): Unit {\n        val plugin: InternalPlatformPluginProbe = InternalPlatform.loadPlugin<InternalPlatformPluginProbe>(\n            InternalPlatformPluginProbe::class.java.name,\n        )\n\n        assertThat(plugin.description()).isEqualTo(\"loaded\")\n    }\n\n    @Test\n    fun loadsPluginWithExplicitMessage(): Unit {\n        val plugin: InternalPlatformPluginProbe = InternalPlatform.loadPlugin<InternalPlatformPluginProbe>(\n            InternalPlatformPluginProbe::class.java.name,\n            \"while testing plugin loading\",\n        )\n\n        assertThat(plugin.description()).isEqualTo(\"loaded\")\n    }\n}\n\nprivate open class InternalPlatformCopyParent(\n    private var parentValue: String,\n) {\n    protected fun parentSnapshot(): String = parentValue\n}\n\nprivate class InternalPlatformCopyTarget(\n    parentValue: String,\n    private var childValue: String,\n    private var count: Int,\n) : InternalPlatformCopyParent(parentValue) {\n    fun snapshot(): List<Any> = listOf(parentSnapshot(), childValue, count)\n}\n\npublic class InternalPlatformPluginProbe {\n    fun description(): String = \"loaded\"\n}\n"}], "isError": false, "timestamp": 1782354565870}, {"role": "toolResult", "toolCallId": "call_2qCVSGSZpG5YGlSBaVAheTvg|fc_07a434a34122b0e8016a3c92858dec81958955dd2a219ebfd9", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_mockk.mockk_jvm\n\nimport io.mockk.impl.annotations.InjectionLookupType\nimport io.mockk.impl.annotations.MockInjector\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\n\npublic class InjectionHelpersTest {\n    @Test\n    fun injectsMatchedValueIntoImmutableProperty(): Unit {\n        val holder: ImmutableInjectionHolder = ImmutableInjectionHolder()\n        val target: ImmutableInjectionTarget = ImmutableInjectionTarget()\n        val injector: MockInjector = MockInjector(\n            mockHolder = holder,\n            lookupType = InjectionLookupType.BOTH,\n            injectImmutable = true,\n            overrideValues = false,\n        )\n\n        injector.propertiesInjection(target)\n\n        assertThat(target.collaborator).isSameAs(holder.collaborator)\n        assertThat(target.describe()).isEqualTo(\"injected dependency\")\n    }\n}\n\npublic class ImmutableInjectionHolder {\n    public val collaborator: ImmutableInjectionCollaborator = ImmutableInjectionCollaborator(\n        \"injected dependency\",\n    )\n}\n\npublic class ImmutableInjectionTarget {\n    public val collaborator: ImmutableInjectionCollaborator? = null\n\n    public fun describe(): String = requireNotNull(collaborator).description\n}\n\npublic class ImmutableInjectionCollaborator(\n    public val description: String,\n)\n"}], "isError": false, "timestamp": 1782354565870}, {"role": "toolResult", "toolCallId": "call_zoeii6RpAYKs8ZrCWM9H2Lg8|fc_07a434a34122b0e8016a3c92858df48195868b6716148ae075", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\nplugins {\n    id \"org.graalvm.internal.tck\"\n    alias(libs.plugins.kotlin.jvm)\n}\n\nString libraryVersion = tck.testedLibraryVersion.get()\nint testJvmVersion = tck.testJvmVersion.get()\n\ndependencies {\n    testImplementation \"io.mockk:mockk-jvm:$libraryVersion\"\n    testImplementation 'org.assertj:assertj-core:3.22.0'\n}\n\nkotlin {\n    jvmToolchain(testJvmVersion)\n}\n\ncompileTestKotlin {\n    kotlinOptions.jvmTarget = testJvmVersion.toString()\n}\n\ngraalvmNative {\n    agent {\n        defaultMode = \"conditional\"\n        modes {\n            conditional {\n                userCodeFilterPath = \"user-code-filter.json\"\n            }\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1782354565870}]}
