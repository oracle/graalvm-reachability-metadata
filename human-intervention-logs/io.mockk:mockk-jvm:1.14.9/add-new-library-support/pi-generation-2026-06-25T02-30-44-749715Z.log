  package io_mockk.mockk_jvm
  
  import io.mockk.impl.instantiation.JvmAnyValueGenerator
  import org.assertj.core.api.Assertions.assertThat
  import org.junit.jupiter.api.Test
  
  public class JvmAnyValueGeneratorInnerAnyValueAnonymous2Test {
      @Test
      fun createsEmptyObjectArrayValue(): Unit {
          val generator: JvmAnyValueGenerator = JvmAnyValueGenerator(Unit)
          val arrayType = emptyArray<String>()::class
  
          val value: Any? = generator.anyValue(arrayType, isNullable = false) {
              throw AssertionError("Object array values should be created without fallback instantiation")
          }
  
          val arrayValue: Array<*> = value as Array<*>
          assertThat(arrayValue).isEmpty()
          assertThat(arrayValue.javaClass.componentType).isEqualTo(String::class.java)
      }
  }
