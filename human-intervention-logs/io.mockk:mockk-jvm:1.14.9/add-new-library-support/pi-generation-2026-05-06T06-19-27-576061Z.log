[tool-call] delta {"path":"tests/src/io.mockk/mockk-jvm/1.14.9/src/test/kotlin/io_mockk/mockk_jvm/JvmMockKGatewayTest.kt","edits":[{"oldText":"import io.mockk.impl.JvmMockKGateway\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\n","newText":"import io.mockk.impl.JvmMockKGateway\nimport org.assertj.core.api.Assertions.assertThat\nimport org.graalvm.internal.tck.NativeImageSupport\nimport org.junit.jupiter.api.Test\n"},{"oldText":"    fun defaultGatewayInitializesJvmAgentPlugin(): Unit {\n        val gateway: JvmMockKGateway = JvmMockKGateway.defaultImplementation\n\n        assertThat(gateway.mockFactory).isNotNull()\n        assertThat(gateway.staticMockFactory).isNotNull()\n        assertThat(gateway.objectMockFactory).isNotNull()\n        assertThat(gateway.constructorMockFactory).isNotNull()\n        assertThat(JvmMockKGateway.defaultImplementationBuilder()).isSameAs(gateway)\n    }\n","newText":"    fun defaultGatewayInitializesJvmAgentPlugin(): Unit {\n        try {\n            val gateway: JvmMockKGateway = JvmMockKGateway.defaultImplementation\n\n            assertThat(gateway.mockFactory).isNotNull()\n            assertThat(gateway.staticMockFactory).isNotNull()\n            assertThat(gateway.objectMockFactory).isNotNull()\n            assertThat(gateway.constructorMockFactory).isNotNull()\n            assertThat(JvmMockKGateway.defaultImplementationBuilder()).isSameAs(gateway)\n        } catch (error: Error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error\n            }\n        }\n    }\n"}]}
