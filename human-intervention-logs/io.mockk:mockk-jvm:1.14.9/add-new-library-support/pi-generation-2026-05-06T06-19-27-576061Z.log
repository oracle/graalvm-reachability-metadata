[tool-call] delta {"path":"tests/src/io.mockk/mockk-jvm/1.14.9/src/test/kotlin/io_mockk/mockk_jvm/JvmMockKGatewayTest.kt","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_mockk.mockk_jvm\n\nimport io.mockk.impl.JvmMockKGateway\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\n\npublic class JvmMockKGatewayTest {\n    @Test\n    fun defaultGatewayInitializesJvmAgentPlugin(): Unit {\n        val gateway: JvmMockKGateway = JvmMockKGateway.defaultImplementation\n\n        assertThat(gateway.mockFactory).isNotNull()\n        assertThat(gateway.staticMockFactory).isNotNull()\n        assertThat(gateway.objectMockFactory).isNotNull()\n        assertThat(gateway.constructorMockFactory).isNotNull()\n        assertThat(JvmMockKGateway.defaultImplementationBuilder()).isSameAs(gateway)\n    }\n}\n"}
