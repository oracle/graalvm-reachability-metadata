ted rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_mockk.mockk_jvm\n\nimport io.mockk.MockKException\nimport io.mockk.mockk\nimport org.assertj.core.api.Assertions.assertThatThrownBy\nimport org.junit.jupiter.api.Test\nimport java.util.ArrayList\n\npublic class MockkValidatorTest {\n    @Test\n    fun rejectsMockingClassAssignableToDefaultRestrictedClassWhenConfiguredToThrow(): Unit {\n        val previousValue: String? = System.getProperty(THROW_EXCEPTION_ON_BAD_MOCK_PROPERTY)\n        System.setProperty(THROW_EXCEPTION_ON_BAD_MOCK_PROPERTY, \"true\")\n\n        try {\n            assertThatThrownBy { mockk<ArrayList<String>>() }\n                .isInstanceOf(MockKException::class.java)\n                .hasMessage(\"Mocking java.util.ArrayList is not allowed!\")\n        } finally {\n            if (previousValue == null) {\n                System.clearProperty(THROW_EXCEPTION_ON_BAD_MOCK_PROPERTY)\n            } else {\n                System.setProperty(THROW_EXCEPTION_ON_BAD_MOCK_PROPERTY, previousValue)\n            }\n        }\n    }\n\n    private companion object {\n        private const val THROW_EXCEPTION_ON_BAD_MOCK_PROPERTY: String = \"mockk.throwExceptionOnBadMock\"\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 2723, "output": 1037, "cacheRead": 23552, "cacheWrite": 0, "totalTokens": 27312, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1782356169836, "responseId": "resp_0a27ac91cf6802e5016a3c98ca80b48196833ff000328f8fd3"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_DxNMrgwI2ItPoDd5n4Aq5pKF|fc_0a27ac91cf6802e5016a3c98d8c9508196abd6955584aafc97", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1338 bytes to tests/src/io.mockk/mockk-jvm