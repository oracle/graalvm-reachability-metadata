  package io_mockk.mockk_jvm
  
  import io.mockk.impl.InternalPlatform
  import org.assertj.core.api.Assertions.assertThat
  import org.junit.jupiter.api.Test
  
  public class InternalPlatformTest {
      @Test
      fun copiesDeclaredAndInheritedFields(): Unit {
          val source: InternalPlatformCopyTarget = InternalPlatformCopyTarget(
              parentValue = "source-parent",
              childValue = "source-child",
              count = 42,
          )
          val target: InternalPlatformCopyTarget = InternalPlatformCopyTarget(
              parentValue = "target-parent",
              childValue = "target-child",
              count = -1,
          )
  
          InternalPlatform.copyFields(target, source)
  
          assertThat(target.snapshot()).isEqualTo(source.snapshot())
      }
  
      @Test
      fun loadsPluginWithDefaultMessage(): Unit {
          val plugin: InternalPlatformPluginProbe = InternalPlatform.loadPlugin<InternalPlatformPluginProbe>(
              InternalPlatformPluginProbe::class.java.name,
          )
  
