[recv] {"type": "message_start", "message": {"role": "toolResult", "toolCallId": "call_uqEDq4W7QzvbwUg0m2hVQNum|fc_0a27ac91cf6802e5016a3c98b4f2cc8196bcb000ceea6fa248", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_mockk.mockk_jvm\n\nimport io.mockk.Invocation\nimport io.mockk.Matcher\nimport io.mockk.MockKGateway\nimport io.mockk.RecordedCall\nimport io.mockk.impl.recording.JvmAutoHinter\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\nimport kotlin.reflect.KClass\n\npublic class JvmAutoHinterTest {\n    @Test\n    fun retriesRecordingWithReturnTypeHintExtractedFromClassCastException(): Unit {\n        val callRecorder: HintRecordingCallRecorder = HintRecordingCallRecorder()\n        val autoHinter: JvmAutoHinter = JvmAutoHinter()\n        var attempts: Int = 0\n\n        autoHinter.autoHint(callRecorder, 0, 64) {\n            attempts += 1\n            if (attempts == 1) {\n                throw ClassCastException(\"cannot be cast to java.lang.String\")\n            }\n        }\n\n        assertThat(attempts).isEqualTo(2)\n        assertThat(callRecorder.rounds).containsExactly(0 to 64, 0 to 64)\n        assertThat(callRecorder.discardedRounds).isEqualTo(1)\n        assertThat(callRecorder.hints).containsExactly(ReturnTypeHint(String::class, 1))\n    }\n\n    private data class ReturnTypeHint(\n        val type: KClass<*>,\n        val callNumber: Int,\n    )\n\n    private class HintRecordingCallRecorder : MockKGateway.CallRecorder {\n        override val calls: List<RecordedCall> = emptyList()\n        val rounds: MutableList<Pair<Int, Int>> = mutableListOf()\n        val hints: MutableList<ReturnTypeHint> = mutableListOf()\n        var discardedRounds: Int = 0\n            private set\n\n        