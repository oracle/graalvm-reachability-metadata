  +/*
  + * Copyright and related rights waived via CC0
  + *
  + * You should have received a copy of the CC0 legalcode along with this
  + * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.
  + */
  +package io_mockk.mockk_jvm
  +
  +import io.mockk.Invocation
  +import io.mockk.Matcher
  +import io.mockk.MockKGateway
  +import io.mockk.RecordedCall
  +import io.mockk.impl.recording.JvmAutoHinter
  +import org.assertj.core.api.Assertions.assertThat
  +import org.junit.jupiter.api.Test
  +import kotlin.reflect.KClass
  +
  +public class JvmAutoHinterTest {
  +    @Test
  +    fun retriesRecordingWithReturnTypeHintExtractedFromClassCastException(): Unit {
  +        val callRecorder: HintRecordingCallRecorder = HintRecordingCallRecorder()
  +        val autoHinter: JvmAutoHinter = JvmAutoHinter()
  +        var attempts: Int = 0
  +
  +        autoHinter.autoHint(callRecorder, 0, 64) {
  +            attempts += 1
  +            if (attempts == 1) {
  +                throw ClassCastException("cannot be cast to java.lang.String")
  +            }
  +        }
  +
  +        assertThat(attempts).isEqualTo(2)
  +        assertThat(callRecorder.rounds).containsExactly(0 to 64, 0 to 64)
  +        assertThat(callRecorder.discardedRounds).isEqualTo(1)
  +        assertThat(callRecorder.hints).containsExactly(ReturnTypeHint(String::class, 1))
  +    }
  +
  +    private data class ReturnTypeHint(
  +        val type: KClass<*>,
  +        val callNumber: Int,
  +    )
  +
  +    private class HintRecordingCallRecorder : MockKGateway.CallRecorder {
  +        override val calls: List<RecordedCall> = emptyList()
  +        val rounds: MutableList<Pair<Int, Int>> = mutableListOf()
  +        val hints: MutableList<ReturnTypeHint> = mutableListOf()
  +        var discardedRounds: Int = 0
  +            private set
  +
  +        override fun startStubbing(): Unit = unused()
  +
  +        override fun startVerification(params: MockKGateway.VerificationParameters): Unit = unused()
  +
  +        override fun startExclusion(params: MockKGateway.ExclusionParameters): Unit = unused()
  +
  +        override fun round(
  +            n: Int,
  +            total: Int,
  +        ): Unit {
  +            rounds += n to total
  +        }
  +
  +        override fun <T : Any> matcher(
  +            matcher: Matcher<*>,
  +            cls: KClass<T>,
  +        ): T = unused()
  +
  +        override fun call(invocation: Invocation): Any? = unused()
  +
  +        override fun answerOpportunity(): MockKGateway.AnswerOpportunity<*> = unused()
  +
  +        override fun done(): Unit = unused()
  +
  +        override fun hintNextReturnType(
  +            cls: KClass<*>,
  +            n: Int,
  +        ): Unit {
  +            hints += ReturnTypeHint(cls, n)
  +        }
  +
  +        override fun reset(): Unit = unused()
  +
  +        override fun estimateCallRounds(): Int = unused()
  +
  +        override fun nCalls(): Int = 1
  +
  +        override fun wasNotCalled(list: List<Any>): Unit = unused()
  +
  +        override fun discardLastCallRound(): Unit {
  +            discardedRounds += 1
  +        }
  +
  +        override fun isLastCallReturnsNothing(): Boolean = unused()
  +
  +        private fun unused(): Nothing = throw UnsupportedOperationException("Not used by this test")
  +    }
  +}
