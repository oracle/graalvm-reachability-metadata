\n        val callNumber: Int,\n    )\n\n    private class HintRecordingCallRecorder : MockKGateway.CallRecorder {\n        override val calls: List<RecordedCall> = emptyList()\n        val rounds: MutableList<Pair<Int, Int>> = mutableListOf()\n        val hints: MutableList<ReturnTypeHint> = mutableListOf()\n        var discardedRounds: Int = 0\n            private set\n\n        override fun startStubbing(): Unit = unused()\n\n        override fun startVerification(params: MockKGateway.VerificationParameters): Unit = unused()\n\n        override fun startExclusion(params: MockKGateway.ExclusionParameters): Unit = unused()\n\n        override fun round(\n            n: Int,\n            total: Int,\n        ): Unit {\n            rounds += n to total\n        }\n\n        override fun <T : Any> matcher(\n            matcher: Matcher<*>,\n            cls: KClass<T>,\n        ): T = unused()\n\n        override fun call(invocation: Invocation): Any? = unused()\n\n        override fun answerOpportunity(): MockKGateway.AnswerOpportunity<*> = unused()\n\n        override fun done(): Unit = unused()\n\n        override fun hintNextReturnType(\n            cls: KClass<*>,\n            n: Int,\n        ): Unit {\n            hints += ReturnTypeHint(cls, n)\n        }\n\n        override fun reset(): Unit = unused()\n\n        override fun estimateCallRounds(): Int = unused()\n\n        override fun nCalls(): Int = 1\n\n        override fun wasNotCalled(list: List<Any>): Unit = unused()\n\n        override fun discardLastCallRound(): Unit {\n            discardedRounds += 1\n        }\n\n        override fun isLastCallReturnsNothing(): Boolean = unused()\n\n        private fun unused(): Nothing = throw UnsupportedOperationException(\"Not used by this test\")\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 1568, "output": 1368, "cacheRead": 34816, "cacheWrite": 0, "totalTokens": 37752, "cost": {"input": 0, "output": 0