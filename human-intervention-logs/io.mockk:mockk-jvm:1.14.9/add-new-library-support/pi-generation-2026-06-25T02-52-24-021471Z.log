   * verify { navigator.navigateTo(any()) }
   * ```
   * @see [coVerify] Coroutine version
   */
  fun verify(
      ordering: Ordering = Ordering.UNORDERED,
      inverse: Boolean = false,
      atLeast: Int = 1,
      atMost: Int = Int.MAX_VALUE,
      exactly: Int = -1,
      timeout: Long = 0,
      verifyBlock: MockKVerificationScope.() -> Unit,
