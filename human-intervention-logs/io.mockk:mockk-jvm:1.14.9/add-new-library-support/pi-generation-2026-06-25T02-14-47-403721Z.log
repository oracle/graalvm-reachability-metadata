              gatewayAccessWithFactory,
          )
  
      override val constructorMockFactory =
          JvmConstructorMockFactory(
              agentFactory.constructorProxyMaker,
              clearer,
              mockFactory,
              agentFactory.proxyMaker,
              gatewayAccessWithFactory,
          )
  
      override val mockTypeChecker =
