  package io_mockk.mockk_jvm
  
  import io.mockk.impl.annotations.InjectionLookupType
  import io.mockk.impl.annotations.MockInjector
  import org.assertj.core.api.Assertions.assertThat
  import org.junit.jupiter.api.Test
  
  public class InjectionHelpersTest {
      @Test
      fun injectsMatchedValueIntoImmutableProperty(): Unit {
          val holder: ImmutableInjectionHolder = ImmutableInjectionHolder()
          val target: ImmutableInjectionTarget = ImmutableInjectionTarget()
          val injector: MockInjector = MockInjector(
              mockHolder = holder,
              lookupType = InjectionLookupType.BOTH,
              injectImmutable = true,
              overrideValues = false,
          )
  
          injector.propertiesInjection(target)
  
          assertThat(target.collaborator).isSameAs(holder.collaborator)
          assertThat(target.describe()).isEqualTo("injected dependency")
      }
  }
  
  public class ImmutableInjectionHolder {
      public val collaborator: ImmutableInjectionCollaborator = ImmutableInjectionCollaborator(
          "injected dependency",
      )
  }
  
  public class ImmutableInjectionTarget {
      public val collaborator: ImmutableInjectionCollaborator? = null
  
      public fun describe(): String = requireNotNull(collaborator).description
  }
  
  public class ImmutableInjectionCollaborator(
      public val description: String,
  )
