oxy.MockKInvocationHandler\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\nimport java.lang.reflect.Method\nimport java.util.concurrent.Callable\nimport kotlin.reflect.KClass\nimport kotlin.reflect.jvm.javaMethod\n\npublic class JvmMockFactoryHelperInnerFindBackingFieldAnonymous2Anonymous1Anonymous1Test {\n    @Test\n    fun readsBackingFieldForPropertyGetterInvocation(): Unit {\n        val target: BackingFieldTarget = BackingFieldTarget(\"stored-value\")\n        val getterMethod: Method = checkNotNull(BackingFieldTarget::storedValue.getter.javaMethod)\n        val stub: FieldReadingStub = FieldReadingStub(BackingFieldTarget::class)\n        val handler: MockKInvocationHandler = JvmMockFactoryHelper.mockHandler(stub)\n\n        val result: Any? = handler.invocation(\n            target,\n            getterMethod,\n            Callable { \"original-value\" },\n            emptyArray(),\n        )\n\n        assertThat(result).isEqualTo(\"stored-value\")\n        assertThat(stub.observedFieldName).isEqualTo(\"storedValue\")\n    }\n\n    private class BackingFieldTarget(\n        val storedValue: String,\n    )\n\n    private class FieldReadingStub(\n        override val type: KClass<*>,\n    ) : Stub {\n        override val name: String = \"field-reading-stub\"\n        override val threadId: Long = Thread.currentThread().id\n        var observedFieldName: String? = null\n            private set\n\n        override fun handleInvocation(\n            self: Any,\n            method: MethodDescription,\n            originalCall: () -> Any?,\n            args: Array<out Any?>,\n            fieldValueProvider: BackingFieldValueProvider,\n        ): Any? {\n            val backingField: BackingFieldValue = checkNotNull(fieldValueProvider())\n            observedFieldName = backingField.name\n            return backingField.getter.invoke()\n        }\n\n        override fun addAnswer(\n            matcher: InvocationMatcher,\n       