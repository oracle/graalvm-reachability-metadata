  			}
  			if (!pattern.endsWith(SLASH)) {
  				pattern += SLASH;
  			}
  			pattern += "**";
  			runtimeHints.resources().registerPattern(pattern);
  		}
  	}
  
  	private static Class<?> loadWebMergedContextConfigurationClass() {
  		try {
  			return ClassUtils.forName(WEB_MERGED_CONTEXT_CONFIGURATION_CLASS_NAME,
