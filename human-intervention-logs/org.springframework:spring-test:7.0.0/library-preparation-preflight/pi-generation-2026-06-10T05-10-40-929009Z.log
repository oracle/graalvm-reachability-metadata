  description = "Spring TestContext Framework"
  
  apply plugin: "kotlin"
  
  dependencies {
  	api(project(":spring-core"))
  	compileOnly("com.google.code.findbugs:jsr305") // for Reactor
  	optional(project(":spring-aop"))
