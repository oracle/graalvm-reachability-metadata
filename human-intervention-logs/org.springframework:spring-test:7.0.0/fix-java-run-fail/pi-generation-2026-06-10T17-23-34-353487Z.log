[tool-call] delta {"path":"tests/src/org.springframework/spring-test/7.0.0/src/test/java/org_springframework/spring_test/TestBeanOverrideHandlerTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_springframework.spring_test;\n\nimport org.junit.jupiter.api.Test;\nimport org.junit.jupiter.api.extension.ExtendWith;\n\nimport org.springframework.context.annotation.Bean;\nimport org.springframework.context.annotation.Configuration;\nimport org.springframework.test.context.ContextConfiguration;\nimport org.springframework.test.context.bean.override.convention.TestBean;\nimport org.springframework.test.context.junit.jupiter.SpringExtension;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class TestBeanOverrideHandlerTest {\n    @TestBean\n    private GreetingService greetingService;\n\n    @Test\n    void invokesFactoryMethodForTestBeanOverride() {\n        assertThat(this.greetingService.message()).isEqualTo(\"test bean\");\n    }\n\n    private static GreetingService greetingService() {\n        return () -> \"test bean\";\n    }\n\n    interface GreetingService {\n        String message();\n    }\n\n    @Configuration(proxyBeanMethods = false)\n    static class Config {\n        @Bean\n        GreetingService greetingService() {\n            return () -> \"production bean\";\n        }\n    }\n\n    @ExtendWith(SpringExtension.class)\n    @ContextConfiguration(classes = Config.class)\n    static class TestBeanOverrideTestCase extends TestBeanOverrideHandlerTest {\n    }\n}\n"}
