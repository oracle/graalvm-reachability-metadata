  		if (directory.startsWith(CLASSPATH_URL_PREFIX)) {
  			String pattern = directory.substring(CLASSPATH_URL_PREFIX.length());
  			if (pattern.startsWith(SLASH)) {
  				pattern = pattern.substring(1);
  			}
  			if (!pattern.endsWith(SLASH)) {
  				pattern += SLASH;
  			}
  			pattern += "**";
