rivate static Path resolveTestClasspathRoot() throws URISyntaxException {\n        CodeSource codeSource = TestClassScannerTest.class.getProtectionDomain().getCodeSource();\n        if (codeSource != null && codeSource.getLocation() != null) {\n            Path location = Path.of(codeSource.getLocation().toURI());\n            if (Files.exists(location)) {\n                return location;\n            }\n        }\n\n        String classResourceName = TestClassScannerTest.class.getName().replace('.', '/') + \".class\";\n        URL classResource = TestClassScannerTest.class.getClassLoader().getResource(classResourceName);\n        assertThat(classResource).isNotNull();\n        Path classFile = Path.of(classResource.toURI());\n        Path classpathRoot = classFile;\n        int nameCount = classResourceName.split(\"/\").length;\n        for (int i = 0; i < nameCount; i++) {\n            classpathRoot = classpathRoot.getParent();\n        }\n        return classpathRoot;\n    }\n\n    static class ScanningTestAotProcessor extends TestAotProcessor {\n        ScanningTestAotProcessor(Set<Path> classpathRoots, Path outputDirectory) {\n            super(classpathRoots, Settings.builder()\n                    .sourceOutput(outputDirectory.resolve(\"source\"))\n                    .resourceOutput(outputDirectory.resolve(\"resources\"))\n                    .classOutput(outputDirectory.resolve(\"classes\"))\n                    .groupId(\"org.example\")\n                    .artifactId(\"test-class-scanner\")\n                    .build());\n        }\n\n        List<Class<?>> scan() {\n            try (Stream<Class<?>> testClasses = scanClasspathRoots()) {\n                return testClasses.toList();\n            }\n        }\n    }\n\n    @ClassTemplate\n    @ExtendWith(SpringExtension.class)\n    @ContextConfiguration(classes = EmptyConfiguration.class)\n    static class ClassTemplateTestCase {\n        @Test\n        void outerTest() {\n        }\n\n        @Nested\n