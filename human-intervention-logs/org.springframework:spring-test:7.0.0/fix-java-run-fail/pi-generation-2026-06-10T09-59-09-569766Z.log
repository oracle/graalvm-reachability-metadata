  +                .getResource(classResourceName);
  +        assertThat(classResource).isNotNull();
  +        Path classFile = Path.of(classResource.toURI());
  +        Path classpathRoot = classFile;
  +        int nameCount = classResourceName.split("/").length;
  +        for (int i = 0; i < nameCount; i++) {
  +            classpathRoot = classpathRoot.getParent();
  +        }
  +        return classpathRoot;
  +    }
