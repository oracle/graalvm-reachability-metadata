[tool-call] delta {"path":"tests/src/org.springframework/spring-test/7.0.0/src/test/java/org_springframework/spring_test/TestClassScannerTest.java","edits":[{"oldText":"import java.nio.file.Files;\nimport java.nio.file.Path;\n","newText":"import java.nio.file.Path;\n"},{"oldText":"import org.junit.jupiter.api.ClassTemplate;\n","newText":"import org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.ClassTemplate;\n"},{"oldText":"        ScanningTestAotProcessor processor = new ScanningTestAotProcessor(Set.of(classpathRoot), outputDirectory);\n\n        Set<Class<?>> scannedTestClasses = processor.scanForTestClasses()\n                .filter(testClass -> testClass.getName().startsWith(TestClassScannerTest.class.getName()))\n                .collect(Collectors.toCollection(LinkedHashSet::new));\n\n        if (Files.isDirectory(classpathRoot)) {\n            assertThat(scannedTestClasses)\n                    .contains(\n                            ClassTemplateSpringTestCase.class,\n                            ClassTemplateSpringTestCase.NestedSpringTestCase.class,\n                            BaseSpringClassTemplateTestCase.InheritedNestedSpringTestCase.class)\n                    .doesNotContain(\n                            ClassTemplateSpringTestCase.PlainInnerClass.class,\n                            ClassTemplateSpringTestCase.AbstractNestedSpringTestCase.class);\n        }\n        else {\n            assertThat(scannedTestClasses).isEmpty();\n        }\n","newText":"        assertThat(classpathRoot).isDirectory();\n        ScanningTestAotProcessor processor = new ScanningTestAotProcessor(Set.of(classpathRoot), outputDirectory);\n\n        ScanResult scanResult = scanForTestClasses(processor);\n\n        if (scanResult.unsupportedDynamicClassLoading()) {\n            assertThat(scanResult.scannedTestClasses()).isEmpty();\n        }\n        else {\n            assertThat(scanResult.scannedTestClasses())\n                    .contains(\n                            ClassTemplateSpringTestCase.class,\n                            ClassTemplateSpringTestCase.NestedSpringTestCase.class,\n                            BaseSpringClassTemplateTestCase.InheritedNestedSpringTestCase.class)\n                    .doesNotContain(\n                            ClassTemplateSpringTestCase.PlainInnerClass.class,\n                            ClassTemplateSpringTestCase.AbstractNestedSpringTestCase.class);\n        }\n    }\n\n    private static ScanResult scanForTestClasses(ScanningTestAotProcessor processor) {\n        try {\n            Set<Class<?>> scannedTestClasses = processor.scanForTestClasses()\n                    .filter(testClass -> testClass.getName().startsWith(TestClassScannerTest.class.getName()))\n                    .collect(Collectors.toCollection(LinkedHashSet::new));\n            return new ScanResult(scannedTestClasses, false);\n        }\n        catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n            return new ScanResult(Set.of(), true);\n        }\n    }\n\n    record ScanResult(Set<Class<?>> scannedTestClasses, boolean unsupportedDynamicClassLoading) {\n"}]}
