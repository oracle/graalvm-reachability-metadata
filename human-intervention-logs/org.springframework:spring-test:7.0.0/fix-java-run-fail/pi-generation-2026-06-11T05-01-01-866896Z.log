  	public void registerHints(RuntimeHints runtimeHints, MergedContextConfiguration mergedConfig, ClassLoader classLoader) {
  		// @ContextConfiguration(loader = ...)
  		ContextLoader contextLoader = mergedConfig.getContextLoader();
