  	private static final String GET_RESOURCE_BASE_PATH_METHOD_NAME = "getResourceBasePath";
  
  	private static final Class<?> WEB_MERGED_CONTEXT_CONFIGURATION_CLASS = loadWebMergedContextConfigurationClass();
  
