(field == null) {\n\t\t\treturn \"\";\n\t\t}\n\t\treturn \" (as required by field '%s.%s')\".formatted(\n\t\t\t\tfield.getDeclaringClass().getSimpleName(), field.getName());\n\t}\n\n}\n"}], "isError": false, "timestamp": 1781070840657}]}
