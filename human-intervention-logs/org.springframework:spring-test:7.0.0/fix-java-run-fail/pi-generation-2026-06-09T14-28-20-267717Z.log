  package org_springframework.spring_test;
  
  import java.lang.reflect.Method;
  
  import org.junit.jupiter.api.Test;
  
  import org.springframework.test.context.MethodInvoker;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class DefaultMethodInvokerTest {
      @Test
      void invokesAccessibleNoArgumentMethod() throws Exception {
          RecordingTestCase target = new RecordingTestCase();
          Method method = RecordingTestCase.class.getDeclaredMethod("markInvoked");
  
          Object result = MethodInvoker.DEFAULT_INVOKER.invoke(method, target);
  
          assertThat(result).isEqualTo("invoked");
          assertThat(target.invoked).isTrue();
      }
  
      static class RecordingTestCase {
          private boolean invoked;
  
          private String markInvoked() {
              this.invoked = true;
              return "invoked";
          }
      }
  }
