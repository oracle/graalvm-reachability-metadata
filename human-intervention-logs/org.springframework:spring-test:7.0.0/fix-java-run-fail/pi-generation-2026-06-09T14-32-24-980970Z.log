  		return this.beanType;
  	}
  
  	/**
  	 * Get the bean name to override, or {@code null} to look for a single
  	 * matching bean of type {@link #getBeanType()}.
  	 */
  	public final @Nullable String getBeanName() {
  		return this.beanName;
  	}
  
  	/**
