es = GreetingConfiguration.class)\n    static class FactoryMethodTestCase {\n        @TestBean\n        GreetingService greetingService;\n\n        static GreetingService greetingService() {\n            return new TestGreetingService(\"test bean override\");\n        }\n    }\n\n    @Configuration(proxyBeanMethods = false)\n    static class GreetingConfiguration {\n        @Bean\n        GreetingService greetingService() {\n            return new TestGreetingService(\"application bean\");\n        }\n    }\n\n    interface GreetingService {\n        String greeting();\n    }\n\n    static class TestGreetingService implements GreetingService {\n        private final String greeting;\n\n        TestGreetingService(String greeting) {\n            this.greeting = greeting;\n        }\n\n        @Override\n        public String greeting() {\n            return this.greeting;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 798, "output": 1164, "cacheRead": 23040, "cacheWrite": 0, "totalTokens": 25002, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1781105565772, "responseId": "resp_09a992a90d0c65cc016a29839e49f08194be7a9c36efbb2a51"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_LTq0A09EqVeN4IMd8rMudUWh|fc_09a992a90d0c65cc016a2983afeb80819488c62eb987e9b68f", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2305 bytes to tests/src/org.springframework/spring-test/7.0.0/src/test/java/org_springframework/spring_test/TestBeanOverrideHandlerTest.java"}], "isError": false, "timestamp": 1781105588022}]}
