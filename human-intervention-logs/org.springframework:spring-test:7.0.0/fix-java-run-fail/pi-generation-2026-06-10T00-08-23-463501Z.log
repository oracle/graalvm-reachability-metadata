  	 *     // ...
  	 * }
  	 *
  	 * &#064;ContextConfiguration(initializers = ExtendedInitializer.class)
  	 * public class ExtendedTest extends BaseTest {
  	 *     // ...
  	 * }
  	 * </pre>
  	 * @since 3.2
  	 */
