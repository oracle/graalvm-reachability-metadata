\n        private MessageService messageService;\n\n        private static MessageService overrideMessageService() {\n            return new MessageService(\"test override\");\n        }\n    }\n\n    @Configuration(proxyBeanMethods = false)\n    static class TestConfiguration {\n        @Bean\n        MessageService messageService() {\n            return new MessageService(\"production\");\n        }\n    }\n\n    record MessageService(String message) {\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 1163, "output": 892, "cacheRead": 32768, "cacheWrite": 0, "totalTokens": 34823, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1781019637085, "responseId": "resp_03a8d6d9012414ca016a2833f5864c8195b6566d4ea376bc34"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_gCJhW6BSKj7wIpFYzySawJfc|fc_03a8d6d9012414ca016a2834017b0c8195a06a2cff87a7745b", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2057 bytes to tests/src/org.springframework/spring-test/7.0.0/src/test/java/org_springframework/spring_test/TestBeanOverrideHandlerTest.java"}], "isError": false, "timestamp": 1781019654948}]}
