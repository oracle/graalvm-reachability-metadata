  	private static boolean isJUnit4SpringTestClass(Class<?> clazz) {
  		MergedAnnotation<Annotation> mergedAnnotation =
  				MergedAnnotations.from(clazz, INHERITED_ANNOTATIONS).get(RUN_WITH_ANNOTATION_NAME);
