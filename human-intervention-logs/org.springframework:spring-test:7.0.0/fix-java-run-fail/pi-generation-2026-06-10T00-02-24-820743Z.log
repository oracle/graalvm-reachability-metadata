  			for (Class<?> nestedClass : testClass.getDeclaredClasses()) {
  				if (isJupiterNestedClass(nestedClass)) {
  					testClasses.add(nestedClass);
  					collectNestedTestClasses(nestedClass, testClasses, visited);
