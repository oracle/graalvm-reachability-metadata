ework/spring-test/7.0.0/src/test/java/org_springframework/spring_test/DefaultMethodInvokerTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_springframework.spring_test;\n\nimport java.lang.reflect.Method;\n\nimport org.junit.jupiter.api.Test;\n\nimport org.springframework.test.context.MethodInvoker;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class DefaultMethodInvokerTest {\n    @Test\n    void invokesNoArgumentMethodThroughDefaultMethodInvoker() throws Exception {\n        InvokedTestCase testCase = new InvokedTestCase();\n        Method method = InvokedTestCase.class.getDeclaredMethod(\"recordInvocation\");\n\n        Object result = MethodInvoker.DEFAULT_INVOKER.invoke(method, testCase);\n\n        assertThat(result).isEqualTo(\"invoked\");\n        assertThat(testCase.invoked).isTrue();\n    }\n\n    static class InvokedTestCase {\n        private boolean invoked;\n\n        private String recordInvocation() {\n            this.invoked = true;\n            return \"invoked\";\n        }\n    }\n}\n"}, "partialJson": "{\"path\":\"tests/src/org.springframework/spring-test/7.0.0/src/test/java/org_springframework/spring_test/DefaultMethodInvokerTest.java\",\"content\":\"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage org_springframework.spring_test;\\n\\nimport java.lang.reflect.Method;\\n\\nimport org.junit.jupiter.api.Test;\\n\\nimport org.springframework.test.context.MethodInvoker;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\n\\npublic class DefaultMethodInvokerTest {\\n    @Test\\n    void invokesNoArgumentMethodThroughDefaultMethodInvoker() throws Exc