{"type":"item.started","item":{"id":"item_74","type":"command_execution","command":"/usr/bin/bash -lc 'export GRAALVM_HOME=/home/vjovanov/c/graalvm-reachability-metadata/vj/forge/ce/sdk/latest_graalvm_home\nexport JAVA_HOME=/home/vjovanov/c/graalvm-reachability-metadata/vj/forge/ce/sdk/latest_graalvm_home\nexport PATH=\"$GRAALVM_HOME/bin:$PATH\"\nINIT=$(mktemp /tmp/spring-test-aot-scan-XXXX.init.gradle)\ncat > \"$INIT\" <<'\"'EOF'\nallprojects {\n    tasks.register('printScannedTestClasses') {\n        dependsOn 'testClasses'\n        doLast {\n            def sourceSets = project.extensions.getByName('sourceSets')\n            def testSourceSet = sourceSets.getByName('test')\n            URL[] urls = testSourceSet.runtimeClasspath.files.collect { it.toURI().toURL() } as URL[]\n            URLClassLoader cl = new URLClassLoader(urls, ClassLoader.systemClassLoader)\n            def oldCl = Thread.currentThread().contextClassLoader\n            Thread.currentThread().contextClassLoader = cl\n            try {\n                def scannerClass = cl.loadClass('org.springframework.test.context.aot.TestClassScanner')\n                def roots = testSourceSet.output.classesDirs.files.collect { it.toPath() } as Set\n                def scanner = scannerClass.getConstructor(Set.class).newInstance(roots)\n                def stream = scannerClass.getMethod('scan').invoke(scanner)\n                def toList = cl.loadClass('java.util.stream.Stream').getMethod('toList')\n                def scanned = toList.invoke(stream)\n                println '=== SCANNED ==='\n                scanned.each { println it.getName() }\n            } finally {\n                Thread.currentThread().contextClassLoader = oldCl\n                cl.close()\n            }\n        }\n    }\n}\nEOF\n./gradlew -p tests/src/org.springframework/spring-test/7.0.0 -I \\\"\"'$INIT\" printScannedTestClasses'","aggregated_output":"","exit_code":null,"status":"in_progress"}}
