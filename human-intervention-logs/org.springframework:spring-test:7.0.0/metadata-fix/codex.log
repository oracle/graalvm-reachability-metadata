ScannerTest')\n                ] as Object[]\n                def stream = streamClass.getMethod('of', Object[].class).invoke(null, [classes] as Object[])\n                generatorClass.getMethod('processAheadOfTime', streamClass).invoke(generator, stream)\n\n                def kindClass = cl.loadClass('org.springframework.aot.generate.GeneratedFiles\"'$Kind'\"')\n                def sourceKind = java.lang.Enum.valueOf(kindClass, 'SOURCE')\n                def resourceKind = java.lang.Enum.valueOf(kindClass, 'RESOURCE')\n                def classKind = java.lang.Enum.valueOf(kindClass, 'CLASS')\n                def inMemoryClass = cl.loadClass('org.springframework.aot.generate.InMemoryGeneratedFiles')\n                println '=== SOURCE FILES ==='\n                inMemoryClass.getMethod('getGeneratedFiles', kindClass).invoke(generatedFiles, sourceKind).keySet().sort().each { println it }\n                println '=== RESOURCE FILES ==='\n                inMemoryClass.getMethod('getGeneratedFiles', kindClass).invoke(generatedFiles, resourceKind).keySet().sort().each { println it }\n                println '=== CLASS FILES ==='\n                inMemoryClass.getMethod('getGeneratedFiles', kindClass).invoke(generatedFiles, classKind).keySet().sort().each { println it }\n\n                def getContent = inMemoryClass.getMethod('getGeneratedFileContent', kindClass, String.class)\n                ['org/springframework/test/context/aot/AotTestContextInitializers__Generated.java',\n                 'org/springframework/test/context/aot/AotTestAttributes__Generated.java'].each { path ->\n                    println \\\"=== CONTENT \"'${path} ===\"\n                    println getContent.invoke(generatedFiles, sourceKind, path)\n                }\n            } finally {\n                Thread.currentThread().contextClassLoader = oldCl\n                cl.close()\n            }\n        }\n    }\n}\nEOF\n./gradlew -p tests/src/org.springframework/spring-test/7.0.0 -I \"$INIT\" inspectTestAot'","aggregated_output":"","exit_code":null,"status":"in_progress"}}
