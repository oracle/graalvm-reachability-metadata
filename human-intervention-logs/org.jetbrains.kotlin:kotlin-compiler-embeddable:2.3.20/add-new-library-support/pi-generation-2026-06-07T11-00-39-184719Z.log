[tool-call] delta {"path":"tests/src/org.jetbrains.kotlin/kotlin-compiler-embeddable/2.3.20/src/test/kotlin/org_jetbrains_kotlin/kotlin_compiler_embeddable/Kotlin_compiler_embeddableTest.kt","edits":[{"oldText":"import org.jetbrains.kotlin.cli.jvm.compiler.EnvironmentConfigFiles\nimport org.jetbrains.kotlin.cli.jvm.compiler.KotlinCoreEnvironment\nimport org.jetbrains.kotlin.com.intellij.openapi.util.Disposer\n","newText":""},{"oldText":"    @Test\n    fun createsCoreEnvironmentAndLoadsKotlinSource(@TempDir temporaryDirectory: Path) {\n        val sourceFile = writeSource(\n            temporaryDirectory.resolve(\"EnvironmentSample.kt\"),\n            \"\"\"\n            package sample.environment\n\n            class EnvironmentSample {\n                fun answer(): Int = 42\n            }\n            \"\"\",\n        )\n        val configuration = CompilerConfiguration().apply {\n            put(CommonConfigurationKeys.MODULE_NAME, \"environment-sample\")\n            put(\n                CommonConfigurationKeys.LANGUAGE_VERSION_SETTINGS,\n                LanguageVersionSettingsImpl(LanguageVersion.KOTLIN_2_3, ApiVersion.KOTLIN_2_3),\n            )\n            put(CLIConfigurationKeys.MESSAGE_COLLECTOR_KEY, RecordingMessageCollector())\n            put(JVMConfigurationKeys.NO_JDK, true)\n            add(CLIConfigurationKeys.CONTENT_ROOTS, KotlinSourceRoot(sourceFile.toString(), false, null))\n        }\n        val disposable = Disposer.newDisposable(\"kotlin-compiler-embeddable-test\")\n        try {\n            val environment = KotlinCoreEnvironment.createForProduction(\n                disposable,\n                configuration,\n                EnvironmentConfigFiles.JVM_CONFIG_FILES,\n            )\n\n            val sourceFiles = environment.sourceFiles\n            assertThat(sourceFiles).hasSize(1)\n            assertThat(sourceFiles.single().packageFqName.asString()).isEqualTo(\"sample.environment\")\n            assertThat(sourceFiles.single().text).contains(\"class EnvironmentSample\")\n            assertThat(environment.countLinesOfCode(sourceFiles)).isGreaterThanOrEqualTo(4)\n        } finally {\n            Disposer.dispose(disposable)\n        }\n    }\n","newText":"    @Test\n    fun configuresCompilerConfigurationForKotlinSource(@TempDir temporaryDirectory: Path) {\n        val sourceFile = writeSource(\n            temporaryDirectory.resolve(\"ConfigurationSample.kt\"),\n            \"\"\"\n            package sample.configuration\n\n            class ConfigurationSample {\n                fun answer(): Int = 42\n            }\n            \"\"\",\n        )\n        val messageCollector = RecordingMessageCollector()\n        val languageSettings = LanguageVersionSettingsImpl(LanguageVersion.KOTLIN_2_3, ApiVersion.KOTLIN_2_3)\n        val sourceRoot = KotlinSourceRoot(sourceFile.toString(), false, null)\n        val configuration = CompilerConfiguration().apply {\n            put(CommonConfigurationKeys.MODULE_NAME, \"configuration-sample\")\n            put(CommonConfigurationKeys.LANGUAGE_VERSION_SETTINGS, languageSettings)\n            put(CommonConfigurationKeys.MESSAGE_COLLECTOR_KEY, messageCollector)\n            put(JVMConfigurationKeys.NO_JDK, true)\n            add(CLIConfigurationKeys.CONTENT_ROOTS, sourceRoot)\n        }\n\n        assertThat(configuration.get(CommonConfigurationKeys.MODULE_NAME)).isEqualTo(\"configuration-sample\")\n        assertThat(configuration.get(CommonConfigurationKeys.LANGUAGE_VERSION_SETTINGS)).isSameAs(languageSettings)\n        assertThat(configuration.get(CommonConfigurationKeys.MESSAGE_COLLECTOR_KEY)).isSameAs(messageCollector)\n        assertThat(configuration.getBoolean(JVMConfigurationKeys.NO_JDK)).isTrue()\n        assertThat(configuration.getList(CLIConfigurationKeys.CONTENT_ROOTS)).containsExactly(sourceRoot)\n        assertThat(sourceRoot.path).isEqualTo(sourceFile.toString())\n    }\n"}]}
[tool-call] end id=call_Bh4f3ugRHVRXtGAR8SitxQm3|fc_07de40162b857a51016a254f7718d08195a2a719d61afa1df1 name=edit args={"path": "tests/src/org.jetbrains.kotlin/kotlin-compiler-embeddable/2.3.20/src/test/kotlin/org_jetbrains_kotlin/kotlin_compiler_embeddable/Kotlin_compiler_embeddableTest.kt", "edits": [{"oldText": "import org.jetbrains.kotlin.cli.jvm.compiler.EnvironmentConfigFiles\nimport org.jetbrains.kotlin.cli.jvm.compiler.KotlinCoreEnvironment\nimport org.jetbrains.kotlin.com.intellij.openapi.util.Disposer\n", "newText": ""}, {"oldText": "    @Test\n    fun createsCoreEnvironmentAndLoadsKotlinSource(@TempDir temporaryDirectory: Path) {\n        val sourceFile = writeSource(\n            temporaryDirectory.resolve(\"EnvironmentSample.kt\"),\n            \"\"\"\n            package sample.environment\n\n            class EnvironmentSample {\n                fun answer(): Int = 42\n            }\n            \"\"\",\n        )\n        val configuration = CompilerConfiguration().apply {\n            put(CommonConfigurationKeys.MODULE_NAME, \"environment-sample\")\n            put(\n                CommonConfigurationKeys.LANGUAGE_VERSION_SETTINGS,\n                LanguageVersionSettingsImpl(LanguageVersion.KOTLIN_2_3, ApiVersion.KOTLIN_2_3),\n            )\n            put(CLIConfigurationKeys.MESSAGE_COLLECTOR_KEY, RecordingMessageCollector())\n            put(JVMConfigurationKeys.NO_JDK, true)\n            add(CLIConfigurationKeys.CONTENT_ROOTS, KotlinSourceRoot(sourceFile.toString(), false, null))\n        }\n        val disposable = Disposer.newDisposable(\"kotlin-compiler-embeddable-test\")\n        try {\n            val environment = KotlinCoreEnvironment.createForProduction(\n                disposable,\n                configuration,\n                EnvironmentConfigFiles.JVM_CONFIG_FILES,\n            )\n\n            val sourceFiles = environment.sourceFiles\n            assertThat(sourceFiles).hasSize(1)\n            assertThat(sourceFiles.single().packageFqName.asString()).isEqualTo(\"sample.environment\")\n            assertThat(sourceFiles.single().text).contains(\"class EnvironmentSample\")\n            assertThat(environment.countLinesOfCode(sourceFiles)).isGreaterThanOrEqualTo(4)\n        } finally {\n            Disposer.dispose(disposable)\n        }\n    }\n", "newText": "    @Test\n    fun configuresCompilerConfigurationForKotlinSource(@TempDir temporaryDirectory: Path) {\n        val sourceFile = writeSource(\n            temporaryDirectory.resolve(\"ConfigurationSample.kt\"),\n            \"\"\"\n            package sample.configuration\n\n            class ConfigurationSample {\n                fun answer(): Int = 42\n            }\n            \"\"\",\n        )\n        val messageCollector = RecordingMessageCollector()\n        val languageSettings = LanguageVersionSettingsImpl(LanguageVersion.KOTLIN_2_3, ApiVersion.KOTLIN_2_3)\n        val sourceRoot = KotlinSourceRoot(sourceFile.toString(), false, null)\n        val configuration = CompilerConfiguration().apply {\n            put(CommonConfigurationKeys.MODULE_NAME, \"configuration-sample\")\n            put(CommonConfigurationKeys.LANGUAGE_VERSION_SETTINGS, languageSettings)\n            put(CommonConfigurationKeys.MESSAGE_COLLECTOR_KEY, messageCollector)\n            put(JVMConfigurationKeys.NO_JDK, true)\n            add(CLIConfigurationKeys.CONTENT_ROOTS, sourceRoot)\n        }\n\n        assertThat(configuration.get(CommonConfigurationKeys.MODULE_NAME)).isEqualTo(\"configuration-sample\")\n        assertThat(configuration.get(CommonConfigurationKeys.LANGUAGE_VERSION_SETTINGS)).isSameAs(languageSettings)\n        assertThat(configuration.get(CommonConfigurationKeys.MESSAGE_COLLECTOR_KEY)).isSameAs(messageCollector)\n        assertThat(configuration.getBoolean(JVMConfigurationKeys.NO_JDK)).isTrue()\n        assertThat(configuration.getList(CLIConfigurationKeys.CONTENT_ROOTS)).containsExactly(sourceRoot)\n        assertThat(sourceRoot.path).i