    </scm>
  
    <build>
      <plugins>
        <plugin>
          <groupId>org.apache.felix</groupId>
          <artifactId>maven-bundle-plugin</artifactId>
          <extensions>true</extensions>
          <configuration>
            <instructions>
              <Export-Package>
                org.apache.jackrabbit.*;version=${pom.version}
              </Export-Package>
            </instructions>
          </configuration>
        </plugin>
      </plugins>
    </build>
  
    <dependencies>
