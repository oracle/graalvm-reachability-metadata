>test</scope>\n    </dependency>\n    <dependency>\n      <groupId>org.slf4j</groupId>\n      <artifactId>slf4j-log4j12</artifactId>\n      <scope>test</scope>\n    </dependency>\n  </dependencies>\n</project>\n\nURL https://repo1.maven.org/maven2/org/apache/jackrabbit/jackrabbit-webdav/2.0-beta4/jackrabbit-webdav-2.0-beta4-sources.jar\nPK\u0003\u0004\n\u0000\u0000\u0000\u0000\u0000�z�;\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\t\u0000\u0000\u0000META-INF/PK\u0003\u0004\n\u0000\u0000\u0000\b\u0000�z�;�#��\\\u0000\u0000\u0000j\u0000\u0000\u0000\u0014\u0000\u0000\u0000META-INF/MANIFEST.MF�M��LK-.�\rK-*��ϳR0�3��r,J��,K-B\b\u0007�V�\u0016+�$x���R\u0013KRSt�*�zL�t�\f\f\u00154�K�\u0014|3���+�KRs�\u0015<��4y�x�\u0000PK\u0003\u0004\n\u0000\u0000\u0000\u0000\u0000�y�;\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0004\u0000\u0000\u0000org/PK\u0003\u0004\n\u0000\u0000\u0000\u0000\u0000�y�;\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u000b\u0000\u0000\u0000org/apache/PK\u0003\u0004\n\u0000\u0000\u0000\u0000\u0000�y�;\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0016\u0000\u0000\u0000org/apache/jackrabbit/PK\u0003\u0004\n\u0000\u0000\u0000\u0000\u0000�y�;\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u001d\u0000\u0000\u0000org/apache/jackrabbit/webdav/PK\u0003\u0004\n\u0000\u0000\u0000\u0000\u0000�y�;\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000%\u0000\u0000\u0000org/apache/jackrabbit/webdav/version/PK\u0003\u0004\n\u0000\u0000\u0000\u0000\u0000�y�;\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000,\u0000\u0000\u0000org/apache/jackrabbit/webdav/version/report/PK\u0003\u0004\n\u0000\u0000\u0000\u0000\u0000�y�;\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000$\u0000\u0000\u0000org/apache/jackrabbit/webdav/client/PK\u0003\u0004\n\u0000\u0000\u0000\u0000\u0000�y�;\u0000\u000