    </scm>
  
    <build>
      <plugins>
        <plugin>
          <artifactId>maven-surefire-plugin</artifactId>
          <configuration>
            <includes>
              <include>**/*TestAll.java</include>
            </includes>
            <forkMode>once</forkMode>
            <argLine>-Xmx128m -enableassertions</argLine>
          </configuration>
        </plugin>
      </plugins>
    </build>
  
