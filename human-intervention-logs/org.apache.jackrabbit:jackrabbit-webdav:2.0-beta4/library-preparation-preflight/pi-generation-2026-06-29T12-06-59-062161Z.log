[tool-call] delta {"command":"python - <<'PY'\nimport urllib.request, zipfile, io, re\nv='2.0-beta4'\nfor fname in [f'jackrabbit-webdav-{v}-sources.jar', f'jackrabbit-webdav-{v}.jar']:\n url=f'https://repo1.maven.org/maven2/org/apache/jackrabbit/jackrabbit-webdav/{v}/{fname}'\n data=urllib.request.urlopen(url, timeout=30).read()\n z=zipfile.ZipFile(io.BytesIO(data))\n print('###', fname, 'entries', len(z.namelist()))\n for n in z.namelist():\n  if n.endswith('README.txt') or 'META-INF/MANIFEST' in n or n.endswith('.properties'):\n   print(n)\n if fname.endswith('sources.jar'):\n  servlet=[]; main_classes=[]\n  for n in z.namelist():\n   if n.endswith('.java'):\n    txt=z.read(n).decode('utf-8','ignore')\n    if 'javax.servlet' in txt: servlet.append(n)\n    if 'public class' in txt or 'public interface' in txt: main_classes.append(n)\n  print('servlet refs', len(servlet), servlet[:20])\nPY","timeout":40}
