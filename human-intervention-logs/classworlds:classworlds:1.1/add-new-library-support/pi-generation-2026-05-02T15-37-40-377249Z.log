[tool-call] delta {"path":"tests/src/classworlds/classworlds/1.1/src/test/java/classworlds/classworlds/LauncherTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage classworlds.classworlds;\n\nimport static org.junit.jupiter.api.Assertions.assertArrayEquals;\nimport static org.junit.jupiter.api.Assertions.assertEquals;\nimport static org.junit.jupiter.api.Assertions.assertSame;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.InputStream;\nimport java.nio.charset.StandardCharsets;\nimport org.codehaus.classworlds.ClassWorld;\nimport org.codehaus.classworlds.Launcher;\nimport org.junit.jupiter.api.BeforeEach;\nimport org.junit.jupiter.api.Test;\n\npublic class LauncherTest {\n    private static final String REALM_NAME = \"application\";\n    private static final String CLASSPATH_CONFIGURATION = \"classworlds.conf\";\n    private static final String UBERJAR_CONFIGURATION = \"WORLDS-INF/conf/classworlds.conf\";\n    private static final int ENHANCED_EXIT_CODE = 37;\n    private static final int STANDARD_EXIT_CODE = 19;\n\n    @BeforeEach\n    void resetApplications() {\n        EnhancedApplication.reset();\n        StandardApplication.reset();\n    }\n\n    @Test\n    void launchInvokesEnhancedMainMethodWithClassWorld() throws Exception {\n        Launcher launcher = configuredLauncherFor(EnhancedApplication.class);\n        ClassWorld world = launcher.getWorld();\n\n        launchAndRestoreContextClassLoader(launcher, \"enhanced\", \"argument\");\n\n        assertEquals(1, EnhancedApplication.invocationCount);\n        assertArrayEquals(new String[] {\"enhanced\", \"argument\"}, EnhancedApplication.receivedArgs);\n        assertSame(world, EnhancedApplication.receivedWorld);\n        assertEquals(ENHANCED_EXIT_CODE, launcher.getExitCode());\n    }\n\n    @Test\n    void launchFallsBackToStandardMainMethod() throws Exception {\n        Launcher launcher = configuredLauncherFor(StandardApplication.class);\n\n        launchAndRestoreContextClassLoader(launcher, \"standard\", \"argument\");\n\n        assertEquals(1, StandardApplication.invocationCount);\n        assertArrayEquals(new String[] {\"standard\", \"argument\"}, StandardApplication.receivedArgs);\n        assertEquals(STANDARD_EXIT_CODE, launcher.getExitCode());\n    }\n\n    @Test\n    void mainWithExitCodeReadsClasspathConfigurationResource() throws Exception {\n        int exitCode = callMainWithResourceConfiguration(\n                CLASSPATH_CONFIGURATION,\n                EnhancedApplication.class,\n                false,\n                \"classpath-resource\");\n\n        assertEquals(ENHANCED_EXIT_CODE, exitCode);\n        assertEquals(1, EnhancedApplication.invocationCount);\n        assertArrayEquals(new String[] {\"classpath-resource\"}, EnhancedApplication.receivedArgs);\n    }\n\n    @Test\n    void mainWithExitCodeReadsBootstrappedConfigurationResource() throws Exception {\n        int exitCode = callMainWithResourceConfiguration(\n                UBERJAR_CONFIGURATION,\n                StandardApplication.class,\n                true,\n                \"bootstrapped-resource\");\n\n        assertEquals(STANDARD_EXIT_CODE, exitCode);\n        assertEquals(1, StandardApplication.invocationCount);\n        assertArrayEquals(new String[] {\"bootstrapped-resource\"}, StandardApplication.receivedArgs);\n    }\n\n    private static Launcher configuredLauncherFor(Class<?> applicationClass) throws Exception {\n        ClassWorld world = new ClassWorld();\n        world.newRealm(REALM_NAME, LauncherTest.class.getClassLoader());\n\n        Launcher launcher = new Launcher();\n        launcher.setWorld(world);\n        launcher.setAppMain(applicationClass.getName(), REALM_NAME);\n        return launcher;\n    }\n\n    private static void launchAndRestoreContextClassLoader(Launcher launcher, String... args) throws Exception {\n        ClassLoader previousClassLoader = Thread.currentThread().getContextClassLoader();\n        try {\n            launcher.launch(args);\n        } finally {\n            Thread.currentThread().setContextClassLoader(previousClassLoader);\n        }\n    }\n\n    private static int callMainWithResourceConfiguration(\n            String resourceName,\n            Class<?> applicationClass,\n            boolean bootstrapped,\n            String... args) throws Exception {\n        ClassLoader previousClassLoader = Thread.currentThread().getContextClassLoader();\n        String previousConfiguration = System.getProperty(\"classworlds.conf\");\n        String previousBootstrapped = System.getProperty(\"classworlds.bootstrapped\");\n        ClassLoader resourceClassLoader = new ConfigurationResourceClassLoader(\n                previousClassLoader,\n                resourceName,\n                configurationFor(applicationClass));\n\n        try {\n            System.clearProperty(\"classworlds.conf\");\n            if (bootstrapped) {\n                System.setProperty(\"classworlds.bootstrapped\", \"true\");\n            } else {\n                System.clearProperty(\"classworlds.bootstrapped\");\n            }\n            Thread.currentThread().setContextClassLoader(resourceClassLoader);\n            return Launcher.mainWithExitCode(args);\n        } finally {\n            restoreProperty(\"classworlds.conf\", previousConfiguration);\n            restoreProperty(\"classworlds.bootstrapped\", previousBootstrapped);\n            Thread.currentThread().setContextClassLoader(previousClassLoader);\n        }\n    }\n\n    private static String configurationFor(Class<?> applicationClass) {\n        return \"main is \" + applicationClass.getName() + \" from \" + REALM_NAME + \"\\n\"\n                + \"[\" + REALM_NAME + \"]\\n\";\n    }\n\n    private static void restoreProperty(String name, String value) {\n        if (value == null) {\n            System.clearProperty(name);\n        } else {\n            System.setProperty(name, value);\n        }\n    }\n\n    public static class EnhancedApplication {\n        static int invocationCount;\n        static String[] receivedArgs;\n        static ClassWorld receivedWorld;\n\n        public static int main(String[] args, ClassWorld world) {\n            invocationCount++;\n            receivedArgs = args;\n            receivedWorld = world;\n            return ENHANCED_EXIT_CODE;\n        }\n\n        static void reset() {\n            invocationCount = 0;\n            receivedArgs = null;\n            receivedWorld = null;\n        }\n    }\n\n    public static class StandardApplication {\n        static int invocationCount;\n        static String[] receivedArgs;\n\n        public static int main(String[] args) {\n            invocationCount++;\n            receivedArgs = args;\n            return STANDARD_EXIT_CODE;\n        }\n\n        static void reset() {\n            invocationCount = 0;\n            receivedArgs = null;\n        }\n    }\n\n    private static class ConfigurationResourceClassLoader extends ClassLoader {\n        private final String resourceName;\n        private final byte[] configurationBytes;\n\n        ConfigurationResourceClassLoader(ClassLoader parent, String resourceName, String configuration) {\n            super(parent);\n            this.resourceName = resourceName;\n            this.configurationBytes = configuration.getBytes(StandardCharsets.UTF_8);\n        }\n\n        @Override\n        public InputStream getResourceAsStream(String name) {\n            if (resourceName.equals(name)) {\n                return new ByteArrayInputStream(configurationBytes);\n            }\n            return super.getResourceAsStream(name);\n        }\n    }\n}\n"}
