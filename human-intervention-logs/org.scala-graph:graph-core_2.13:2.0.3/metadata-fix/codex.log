{"type":"item.completed","item":{"id":"item_94","type":"command_execution","command":"/usr/bin/bash -lc \"sed -n '1,220p' tests/src/org.scala-graph/graph-core_2.13/2.0.3/src/test/scala/org_scala_graph/graph_core_2_13/AdjacencyListBaseTest.scala\"","aggregated_output":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_scala_graph.graph_core_2_13\n\nimport java.io.ByteArrayInputStream\nimport java.io.ByteArrayOutputStream\nimport java.io.ObjectInputStream\nimport java.io.ObjectOutputStream\n\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\n\nimport scalax.collection.edges.UnDiEdge\nimport scalax.collection.immutable.Graph\n\nclass AdjacencyListBaseTest {\n  @Test\n  def serializesEdgesAndIsolatedNodes(): Unit = {\n    val graph: Graph[Int, UnDiEdge[Int]] = Graph.from(Set(3), Set(UnDiEdge(1, 2)))\n\n    val bytes: Array[Byte] = serialize(graph)\n    val restored: Graph[Int, UnDiEdge[Int]] = deserialize(bytes)\n\n    assertThat(bytes.length).isGreaterThan(0)\n    assertThat(restored).isEqualTo(graph)\n    assertThat(restored.order).isEqualTo(3)\n    assertThat(restored.size).isEqualTo(1)\n  }\n\n  private def serialize(graph: Graph[Int, UnDiEdge[Int]]): Array[Byte] = {\n    val buffer: ByteArrayOutputStream = new ByteArrayOutputStream()\n    val out: ObjectOutputStream = new ObjectOutputStream(buffer)\n    try out.writeObject(graph)\n    finally out.close()\n    buffer.toByteArray\n  }\n\n  private def deserialize(bytes: Array[Byte]): Graph[Int, UnDiEdge[Int]] = {\n    val in: ObjectInputStream = new ObjectInputStream(new ByteArrayInputStream(bytes))\n    try in.readObject().asInstanceOf[Graph[Int, UnDiEdge[Int]]]\n    finally in.close()\n  }\n}\n","exit_code":0,"status":"completed"}}
