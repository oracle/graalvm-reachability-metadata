ts/src/io.suzaku\n/home/vjovanov/c/forge/forge10/graalvm-reachability-metadata/forge/local_repositories/forge_worktrees/5430-014f15ab/tests/src/org.eclipse.jetty.websocket\n/home/vjovanov/c/forge/forge10/graalvm-reachability-metadata/forge/local_repositories/forge_worktrees/5430-014f15ab/tests/src/org.apache.yetus\n/home/vjovanov/c/forge/forge10/graalvm-reachability-metadata/forge/local_repositories/forge_worktrees/5430-014f15ab/tests/src/net.sourceforge.htmlunit\n/home/vjovanov/c/forge/forge10/graalvm-reachability-metadata/forge/local_repositories/forge_worktrees/5430-014f15ab/tests/src/io.github.oshai\n/home/vjovanov/c/forge/forge10/graalvm-reachability-metadata/forge/local_repositories/forge_worktrees/5430-014f15ab/tests/src/biz.aQute.bnd\n/home/vjovanov/c/forge/forge10/graalvm-reachability-metadata/forge/local_repositories/forge_worktrees/5430-014f15ab/tests/src/com.aayushatharva.brotli4j\n/home/vjovanov/c/forge/forge10/graalvm-reachability-metadata/forge/local_repositories/forge_worktrees/5430-014f15ab/tests/tck-build-logic\n/home/vjovanov/c/forge/forge10/graalvm-reachability-metadata/forge/local_repositories/forge_worktrees/5430-014f15ab/tests/tck-build-logic/scripts\n/home/vjovanov/c/forge/forge10/graalvm-reachability-metadata/forge/local_repositories/forge_worktrees/5430-014f15ab/tests/tck-build-logic/src\n/home/vjovanov/c/forge/forge10/graalvm-reachability-metadata/forge/local_repositories/forge_worktrees/5430-014f15ab/tests/tck-build-logic/settings.gradle\n/home/vjovanov/c/forge/forge10/graalvm-reachability-metadata/forge/local_repositories/forge_worktrees/5430-014f15ab/tests/tck-build-logic/.gradle\n/home/vjovanov/c/forge/forge10/graalvm-reachability-metadata/forge/local_repositories/forge_worktrees/5430-014f15ab/tests/tck-build-logic/build\n/home/vjovanov/c/forge/forge10/graalvm-reachability-metadata/forge/local_repositories/forge_worktrees/5430-014f15ab/tests/tck-build-logic/build.gradle\n/home/vjovanov/c/forge/forge10/graalvm-reachability-metadata/forg