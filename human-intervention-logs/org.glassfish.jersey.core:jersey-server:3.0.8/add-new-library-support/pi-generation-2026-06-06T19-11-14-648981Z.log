           this.text = text;\n        }\n\n        public void setFile(File file) {\n            this.file = file;\n        }\n\n        public void setStream(InputStream stream) throws IOException {\n            this.streamFirstByte = stream.read();\n        }\n\n        public void setHolder(Holder holder) {\n            this.holder = holder;\n        }\n\n        @Override\n        public void init() throws Exception {\n            initialized = true;\n            super.init();\n        }\n    }\n\n    public static final class FileClasspathGenerator extends BaseGenerator {\n        private File file;\n\n        public FileClasspathGenerator() {\n        }\n\n        public void setFile(File file) {\n            this.file = file;\n        }\n    }\n\n    public static final class Holder {\n        private final String value;\n\n        public Holder(String value) {\n            this.value = value;\n        }\n    }\n\n    public abstract static class BaseGenerator implements WadlGenerator {\n        private WadlGenerator delegate;\n\n        @Override\n        public void setWadlGeneratorDelegate(WadlGenerator delegate) {\n            this.delegate = delegate;\n        }\n\n        @Override\n        public void init() throws Exception {\n            if (delegate != null) {\n                delegate.init();\n            }\n        }\n\n        @Override\n        public String getRequiredJaxbContextPath() {\n            return delegate == null ? null : delegate.getRequiredJaxbContextPath();\n        }\n\n        @Override\n        public Application createApplication() {\n            return delegate == null ? new Application() : delegate.createApplication();\n        }\n\n        @Override\n        public Resources createResources() {\n            return delegate == null ? new Resources() : delegate.createResources();\n        }\n\n        @Override\n        public Resource createResource(org.glassfish.jersey.server.model.Resource resource, String path) {\n            return delegate == null ? new Resource() : delegate.createResource(resource, path);\n        }\n\n        @Override\n        public com.sun.research.ws.wadl.Method createMethod(org.glassfish.jersey.server.model.Resource resource,\n                org.glassfish.jersey.server.model.ResourceMethod method) {\n            return delegate == null ? new com.sun.research.ws.wadl.Method() : delegate.createMethod(resource, method);\n        }\n\n        @Override\n        public Request createRequest(org.glassfish.jersey.server.model.Resource resource,\n                org.glassfish.jersey.server.model.ResourceMethod method) {\n            return delegate == null ? new Request() : delegate.createRequest(resource, method);\n        }\n\n        @Override\n        public Representation createRequestRepresentation(org.glassfish.jersey.server.model.Resource resource,\n                org.glassfish.jersey.server.model.ResourceMethod method, MediaType mediaType) {\n            return delegate == null ? new Representation() : delegate.createRequestRepresentation(resource, method, mediaType);\n        }\n\n        @Override\n        public List<Response> createResponses(org.glassfish.jersey.server.model.Resource resource,\n                org.glassfish.jersey.server.model.ResourceMethod method) {\n            return delegate == null ? Collections.emptyList() : delegate.createResponses(resource, method);\n        }\n\n        @Override\n        public Param createParam(org.glassfish.jersey.server.model.Resource resource,\n                org.glassfish.jersey.server.model.ResourceMethod method, Parameter parameter) {\n            return delegate == null ? new Param() : delegate.createParam(resource, method, parameter);\n        }\n\n        @Override\n        public ExternalGrammarDefinition createExternalGrammar() {\n            return delegate == null ? new ExternalGrammarDefinition() : delegate.createExternalGrammar();\n        }\n\n        @Override\n        public void attach