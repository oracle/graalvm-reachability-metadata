  package org_glassfish_jersey_core.jersey_server;
  
  import static org.assertj.core.api.Assertions.assertThat;
  import static org.assertj.core.api.Assertions.assertThatThrownBy;
  
  import java.io.File;
  import java.io.IOException;
  import java.io.InputStream;
  import java.util.Collections;
  import java.util.List;
  
  import jakarta.ws.rs.ProcessingException;
  import jakarta.ws.rs.core.MediaType;
  
  import org.glassfish.jersey.internal.inject.InjectionManager;
  import org.glassfish.jersey.internal.inject.Injections;
  import org.glassfish.jersey.server.model.Parameter;
  import org.glassfish.jersey.server.wadl.WadlGenerator;
  import org.glassfish.jersey.server.wadl.config.WadlGeneratorConfig;
  import org.glassfish.jersey.server.wadl.internal.ApplicationDescription;
  import org.junit.jupiter.api.Test;
  
  import com.sun.research.ws.wadl.Application;
  import com.sun.research.ws.wadl.Param;
  import com.sun.research.ws.wadl.Representation;
  import com.sun.research.ws.wadl.Request;
  import com.sun.research.ws.wadl.Resource;
  import com.sun.research.ws.wadl.Resources;
  import com.sun.research.ws.wadl.Response;
  
  public class WadlGeneratorLoaderTest {
      private static final String JERSEY_LOCALIZATION_RESOURCE =
              "org/glassfish/jersey/server/internal/localization.properties";
  
      @Test
      void createWadlGeneratorConfiguresPropertiesWithSupportedConversions() {
          final WadlGeneratorConfig config = WadlGeneratorConfig
                  .generator(ConfigurableGenerator.class)
                  .prop("text", "direct value")
                  .prop("file", "build/wadl-loader-example.txt")
                  .prop("stream", JERSEY_LOCALIZATION_RESOURCE)
                  .prop("holder", "constructed value")
                  .build();
          final InjectionManager injectionManager = createInjectionManager();
          try {
              final WadlGenerator generator = config.createWadlGenerator(injectionManager);
  
              assertThat(generator).isInstanceOf(ConfigurableGenerator.class);
              final ConfigurableGenerator configurableGenerator = (ConfigurableGenerator) generator;
              assertThat(configurableGenerator.text).isEqualTo("direct value");
              assertThat(configurableGenerator.file).isEqualTo(new File("build/wadl-loader-example.txt"));
              assertThat(configurableGenerator.streamFirstByte).isNotEqualTo(-1);
              assertThat(configurableGenerator.holder.value).isEqualTo("constructed value");
              assertThat(configurableGenerator.initialized).isTrue();
          } finally {
              injectionManager.shutdown();
          }
      }
  
      @Test
      void classpathFilePropertyReportsMissingResource() {
          final WadlGeneratorConfig config = WadlGeneratorConfig
                  .generator(FileClasspathGenerator.class)
                  .prop("file", "classpath:/missing-wadl-loader-resource.xml")
                  .build();
  
          final InjectionManager injectionManager = createInjectionManager();
          try {
              assertThatThrownBy(() -> config.createWadlGenerator(injectionManager))
                      .isInstanceOf(ProcessingException.class)
                      .hasMessageContaining("Could not load wadl generators")
                      .hasRootCauseMessage("The file '/missing-wadl-loader-resource.xml' does not exist in the classpath."
                              + " It's loaded by the generator class, so if you use a relative filename it's relative to"
                              + " the generator class, otherwise you might want to load it via an absolute classpath"
                              + " reference like classpath:/somefile.xml");
          } finally {
              injectionManager.shutdown();
          }
      }
  
      private static InjectionManager createInjectionManager() {
          final InjectionManager injectionManager = Injections.createInjectionManager();
          injectionManager.completeRegistration();
          return injectionManager;
      }
  
      public static final class ConfigurableGenerator extends BaseGenerator {
          private String text;
          private File file;
          private int streamFirstByte = -1;
          private Holder holder;
          private boolean initialized;
  
          public ConfigurableGenerator() {
          }
  
          public void setText(String text) {
              this.text = text;
          }
  
          public void setFile(File file) {
              this.file = file;
          }
  
          public void setStream(InputStream stream) throws IOException {
              this.streamFirstByte = stream.read();
          }
  
          public void setHolder(Holder holder) {
              this.holder = holder;
          }
  
          @Override
          public void init() throws Exception {
              initialized = true;
              super.init();
          }
      }
  
      public static final class FileClasspathGenerator extends BaseGenerator {
          private File file;
  
          public FileClasspathGenerator() {
          }
  
          public void setFile(File file) {
              this.file = file;
          }
      }
  
      public static final class Holder {
          private final String value;
  
          public Holder(String value) {
              this.value = value;
          }
      }
  
      public abstract static class BaseGenerator implements WadlGenerator {
          private WadlGenerator delegate;
  
          @Override
          public void setWadlGeneratorDelegate(WadlGenerator delegate) {
              this.delegate = delegate;
          }
  
          @Override
          public void init() throws Exception {
              if (delegate != null) {
                  delegate.init();
              }
          }
  
          @Override
          public String getRequiredJaxbContextPath() {
              return delegate == null ? null : delegate.getRequiredJaxbContextPath();
          }
  
          @Override
          public Application createApplication() {
              return delegate == null ? new Application() : delegate.createApplication();
          }
  
          @Override
          public Resources createResources() {
              return delegate == null ? new Resources() : delegate.createResources();
          }
  
          @Override
          public Resource createResource(org.glassfish.jersey.server.model.Resource resource, String path) {
              return delegate == null ? new Resource() : delegate.createResource(resource, path);
          }
  
          @Override
          public com.sun.research.ws.wadl.Method createMethod(org.glassfish.jersey.server.model.Resource resource,
                  org.glassfish.jersey.server.model.ResourceMethod method) {
              return delegate == null ? new com.sun.research.ws.wadl.Method() : delegate.createMethod(resource, method);
          }
  
          @Override
          public Request createRequest(org.glassfish.jersey.server.model.Resource resource,
                  org.glassfish.jersey.server.model.ResourceMethod method) {
              return delegate == null ? new Request() : delegate.createRequest(resource, method);
          }
  
          @Override
          public Representation createRequestRepresentation(org.glassfish.jersey.server.model.Resource resource,
                  org.glassfish.jersey.server.model.ResourceMethod method, MediaType mediaType) {
              if (delegate == null) {
                  return new Representation();
              }
              return delegate.createRequestRepresentation(resource, method, mediaType);
          }
  
          @Override
          public List<Response> createResponses(org.glassfish.jersey.server.model.Resource resource,
                  org.glassfish.jersey.server.model.ResourceMethod method) {
              return delegate == null ? Collections.emptyList() : delegate.createResponses(resource, method);
          }
  
          @Override
          public Param createParam(org.glassfish.jersey.server.model.Resource resource,
                  org.glassfish.jersey.server.model.ResourceMethod method, Parameter parameter) {
              return delegate == null ? new Param() : delegate.createParam(resource, method, parameter);
          }
  
          @Override
          public ExternalGrammarDefinition createExternalGrammar() {
              return delegate == null ? new ExternalGrammarDefinition() : delegate.createExternalGrammar();
          }
  
          @Override
          public void attachTypes(ApplicationDescription description) {
              if (delegate != null) {
                  delegate.attachTypes(description);
              }
          }
  
      }
  }
