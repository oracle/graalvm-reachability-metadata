etMessage()).satisfiesAnyOf(\n                    message -> assertThat(message).contains(\"does not exist in the classpath\"),\n                    message -> assertThat(message).contains(\"URI\").contains(\"file\"));\n        } finally {\n            injectionManager.shutdown();\n        }\n    }\n\n    @Test\n    void classpathFilePropertyReportsMissingResource() {"}, {"oldText": "    private static InjectionManager createInjectionManager() {\n        final InjectionManager injectionManager = Injections.createInjectionManager();\n        injectionManager.completeRegistration();\n        return injectionManager;\n    }\n\n    public static final class ConfigurableGenerator extends BaseGenerator {", "newText": "    private static InjectionManager createInjectionManager() {\n        final InjectionManager injectionManager = Injections.createInjectionManager();\n        injectionManager.completeRegistration();\n        return injectionManager;\n    }\n\n    private static Throwable rootCause(Throwable throwable) {\n        Throwable result = throwable;\n        while (result.getCause() != null) {\n            result = result.getCause();\n        }\n        return result;\n    }\n\n    public static final class ConfigurableGenerator extends BaseGenerator {"}]}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 2595, "output": 2301, "cacheRead": 53760, "cacheWrite": 0, "totalTokens": 58656, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780773298634, "responseId": "resp_02dc7e94bd399a74016a2471b36f1c819088c4e0efa1141d1f"}}
