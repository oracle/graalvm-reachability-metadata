ived a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_glassfish_jersey_core.jersey_server;\n\nimport static jersey.repackaged.org.objectweb.asm.Opcodes.ACC_PUBLIC;\nimport static jersey.repackaged.org.objectweb.asm.Opcodes.ACC_STATIC;\nimport static jersey.repackaged.org.objectweb.asm.Opcodes.ACC_SUPER;\nimport static jersey.repackaged.org.objectweb.asm.Opcodes.ALOAD;\nimport static jersey.repackaged.org.objectweb.asm.Opcodes.ARETURN;\nimport static jersey.repackaged.org.objectweb.asm.Opcodes.ASTORE;\nimport static jersey.repackaged.org.objectweb.asm.Opcodes.DUP;\nimport static jersey.repackaged.org.objectweb.asm.Opcodes.GOTO;\nimport static jersey.repackaged.org.objectweb.asm.Opcodes.IFEQ;\nimport static jersey.repackaged.org.objectweb.asm.Opcodes.ILOAD;\nimport static jersey.repackaged.org.objectweb.asm.Opcodes.INVOKESPECIAL;\nimport static jersey.repackaged.org.objectweb.asm.Opcodes.NEW;\nimport static jersey.repackaged.org.objectweb.asm.Opcodes.V1_6;\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport jersey.repackaged.org.objectweb.asm.ClassReader;\nimport jersey.repackaged.org.objectweb.asm.ClassWriter;\nimport jersey.repackaged.org.objectweb.asm.Label;\nimport jersey.repackaged.org.objectweb.asm.MethodVisitor;\nimport org.junit.jupiter.api.Test;\n\npublic class ClassWriterTest {\n    @Test\n    void computeFramesResolvesCommonSuperclassForMergedBranchTypes() {\n        final ClassWriter writer = new ClassWriter(ClassWriter.COMPUTE_FRAMES);\n        writer.visit(V1_6, ACC_PUBLIC | ACC_SUPER, \"example/GeneratedLists\", null, \"java/lang/Object\", null);\n        addChooseListMethod(writer);\n        writer.visitEnd();\n\n        final byte[] bytecode = writer.toByteArray();\n\n        assertThat(bytecode).isNotEmpty();\n        assertThat(new ClassReader(bytecode).getClassName()).isEqualTo(\"example/GeneratedLists\");\n    }\n\n    private static void addChooseListMethod(ClassWriter writer) {\n        final MethodVisitor method = writer.visitMethod(ACC_PUBLIC | ACC_STATIC, \"choose\",\n                \"(Z)Ljava/util/AbstractList;\", null, null);\n        final Label useLinkedList = new Label();\n        final Label returnList = new Label();\n\n        method.visitCode();\n        method.visitVarInsn(ILOAD, 0);\n        method.visitJumpInsn(IFEQ, useLinkedList);\n        method.visitTypeInsn(NEW, \"java/util/ArrayList\");\n        method.visitInsn(DUP);\n        method.visitMethodInsn(INVOKESPECIAL, \"java/util/ArrayList\", \"<init>\", \"()V\", false);\n        method.visitVarInsn(ASTORE, 1);\n        method.visitJumpInsn(GOTO, returnList);\n\n        method.visitLabel(useLinkedList);\n        method.visitTypeInsn(NEW, \"java/util/LinkedList\");\n        method.visitInsn(DUP);\n        method.visitMethodInsn(INVOKESPECIAL, \"java/util/LinkedList\", \"<init>\", \"()V\", false);\n        method.visitVarInsn(ASTORE, 1);\n\n        method.visitLabel(returnList);\n        method.visitVarInsn(ALOAD, 1);\n        method.visitInsn(ARETURN);\n        method.visitMaxs(0, 0);\n        method.visitEnd();\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 3970, "output": 1240, "cacheRead": 18944, "cacheWrite": 0, "totalTokens": 24154, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780773748104, "responseId": "resp_0318fb826ca69cbb016a2473748a948196b609cf4f750e9e43"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_YmWPTnhsWR4zS6XxVcCtr4f8|fc_0318fb826ca69cbb016a24737ef0608196abb4893ab235c6a9", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 3152 bytes to tests/src/org.glassfish.jersey.core/jersey-server/3.0.8/src/test/java/org_glassfish_jersey_core/jersey_server/ClassWriterTest.java"}], "isError": false, "timestamp": 1780773768193}]}
