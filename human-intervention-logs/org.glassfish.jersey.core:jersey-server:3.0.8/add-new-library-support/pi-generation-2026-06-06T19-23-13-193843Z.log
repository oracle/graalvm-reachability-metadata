jakarta.ws.rs.DefaultValue;\nimport jakarta.ws.rs.GET;\nimport jakarta.ws.rs.Path;\nimport jakarta.ws.rs.QueryParam;\n\nimport org.glassfish.jersey.internal.PropertiesDelegate;\nimport org.glassfish.jersey.server.ApplicationHandler;\nimport org.glassfish.jersey.server.ContainerRequest;\nimport org.glassfish.jersey.server.ContainerResponse;\nimport org.glassfish.jersey.server.ResourceConfig;\nimport org.glassfish.jersey.server.spi.Container;\nimport org.junit.jupiter.api.Test;\n\npublic class ArrayExtractorTest {\n    private static final URI BASE_URI = URI.create(\"http://localhost/\");\n\n    @Test\n    void queryParameterArraysAreExtractedFromPresentDefaultedAndMissingValues() throws Exception {\n        final ApplicationHandler handler = new ApplicationHandler(new ResourceConfig(ArrayResource.class));\n        try {\n            final ContainerResponse presentResponse = get(handler, \"arrays/present?value=alpha&value=beta\");\n            final ContainerResponse defaultedResponse = get(handler, \"arrays/defaulted\");\n            final ContainerResponse missingResponse = get(handler, \"arrays/missing\");\n\n            assertThat(presentResponse.getStatus()).isEqualTo(200);\n            assertThat(presentResponse.getEntity()).isEqualTo(\"alpha,beta\");\n            assertThat(defaultedResponse.getStatus()).isEqualTo(200);\n            assertThat(defaultedResponse.getEntity()).isEqualTo(\"fallback\");\n            assertThat(missingResponse.getStatus()).isEqualTo(200);\n            assertThat(missingResponse.getEntity()).isEqualTo(\"0\");\n        } finally {\n            handler.onShutdown(new HandlerContainer(handler));\n        }\n    }\n\n    private static ContainerResponse get(ApplicationHandler handler, String pathAndQuery) throws Exception {\n        final ContainerRequest request = new ContainerRequest(\n                BASE_URI,\n                BASE_URI.resolve(pathAndQuery),\n                \"GET\",\n                null,\n                new MapPropertiesDelegate(),\n                handler.getConfiguration());\n        return handler.apply(request).get(10, TimeUnit.SECONDS);\n    }\n\n    @Path(\"arrays\")\n    public static final class ArrayResource {\n        @GET\n        @Path(\"present\")\n        public String present(@QueryParam(\"value\") String[] values) {\n            return String.join(\",\", values);\n        }\n\n        @GET\n        @Path(\"defaulted\")\n        public String defaulted(@DefaultValue(\"fallback\") @QueryParam(\"value\") String[] values) {\n            return String.join(\",\", values);\n        }\n\n        @GET\n        @Path(\"missing\")\n        public String missing(@QueryParam(\"value\") String[] values) {\n            return Integer.toString(values.length);\n        }\n    }\n\n    private static final class HandlerContainer implements Container {\n        private final ApplicationHandler handler;\n\n        private HandlerContainer(ApplicationHandler handler) {\n            this.handler = handler;\n        }\n\n        @Override\n        public ResourceConfig getConfiguration() {\n            return handler.getConfiguration();\n        }\n\n        @Override\n        public ApplicationHandler getApplicationHandler() {\n            return handler;\n        }\n\n        @Override\n        public void reload() {\n        }\n\n        @Override\n        public void reload(ResourceConfig configuration) {\n        }\n    }\n\n    private static final class MapPropertiesDelegate implements PropertiesDelegate {\n        private final Map<String, Object> properties = new HashMap<>();\n\n        @Override\n        public Object getProperty(String name) {\n            return properties.get(name);\n        }\n\n        @Override\n        public Collection<String> getPropertyNames() {\n            return properties.keySet();\n        }\n\n        @Override\n        public void setProperty(String name, Object object) {\n            properties.put(name, object);\n        }\n\n        @Override\n        public void removeProperty(String name) {\n            properties.remove(name);\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1780773748098}, {"role": "toolResult", "toolCallId": "call_NmUo1Wk61HHt6RYGBFEgwpqn|fc_0318fb826ca69cbb016a247373bbbc81969cc0d73d3f0b1014", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_glassfish_jersey_core.jersey_server;\n\nimport static org.assertj.core.api.Assertions.assertThat;\nimport static org.assertj.core.api.Assertions.assertThatThrownBy;\n\nimport java.io.File;\nimport java.io.IOException;\nimport java.io.InputStream;\nimport java.util.Collections;\nimport java.util.List;\n\nimport jakarta.ws.rs.ProcessingException;\nimport jakarta.ws.rs.core.MediaType;\n\nimport org.glassfish.jersey.internal.inject.InjectionManager;\nimport org.glassfish.jersey.internal.inject.Injections;\nimport org.glassfish.jersey.server.model.Parameter;\nimport org.glassfish.jersey.server.wadl.WadlGenerator;\nimport org.glassfish.jersey.server.wadl.config.WadlGeneratorConfig;\nimport org.glassfish.jersey.server.wadl.internal.ApplicationDescription;\nimport org.junit.jupiter.api.Test;\n\nimport com.sun.research.ws.wadl.Application;\nimport com.sun.research.ws.wadl.Param;\nimport com.sun.research.ws.wadl.Representation;\nimport com.sun.research.ws.wadl.Request;\nimport com.sun.research.ws.wadl.Resource;\nimport com.sun.research.ws.wadl.Resources;\nimport com.sun.research.ws.wadl.Response;\n\npublic class WadlGeneratorLoaderTest {\n    private static final String JERSEY_LOCALIZATION_RESOURCE =\n            \"org/glassfish/jersey/server/internal/localization.properties\";\n\n    @Test\n    void createWadlGeneratorConfiguresPropertiesWithSupportedConversions() {\n        final WadlGeneratorConfig config = WadlGeneratorConfig\n                .generator(ConfigurableGenerator.class)\n                .prop(\"text\", \"direct value\")\n                .prop(\"file\", \"build/wadl-loader-example.txt\")\n                .prop(\"stream\", JERSEY_LOCALIZATION_RESOURCE)\n                .prop(\"holder\", \"constructed value\")\n                .build();\n        final InjectionManager injectionManager = createInjectionManager();\n        try {\n            final WadlGenerator generator = config.createWadlGenerator(injectionManager);\n\n            assertThat(generator).isInstanceOf(ConfigurableGenerator.class);\n            final ConfigurableGenerator configurableGenerator = (ConfigurableGenerator) generator;\n            assertThat(configurableGenerator.text).isEqualTo(\"direct value\");\n            assertThat(configurableGenerator.file).isEqualTo(new File(\"build/wadl-loader-example.txt\"));\n            assertThat(configurableGenerator.streamFirstByte).isNotEqualTo(-1);\n            assertThat(configurableGenerator.holder.value).isEqualTo(\"constructed value\");\n            assertThat(configurableGenerator.initialized).isTrue();\n        } finally {\n            injectionManager.shutdown();\n        }\n    }\n\n    @Test\n    void classpathFilePropertyUsesResolvableClassResourceWhenAvailable() {\n        final WadlGeneratorConfig config = WadlGeneratorConfig\n                .generator(FileClasspathGenerator.class)\n                .prop(\"file\", \"classpath:WadlGeneratorLoaderTest$FileClasspathGenerator.class\")\n                .build();\n\n        final InjectionManager injectionManager = createInjectionManager();\n        try {\n            final WadlGenerator generator = config.createWadlGenerator(injectionManager);\n\n            assertThat(generator).isInstanceOf(FileClasspathGenerator.class);\n            final File configuredFile = ((FileClasspathGenerator) generator).file;\n            assertThat(configuredFile).isFile();\n            assertThat(configuredFile.getName()).isEqualTo(\"WadlGeneratorLoaderTest$FileClasspathGenerator.class\");\n        } catch (ProcessingException e) {\n            final Throwable rootCause = rootCause(e);\n            assertThat(rootCause.getMessage()).satisfiesAnyOf(\n                    message -> assertThat(message).contains(\"does not exist in the classpath\"),\n                    message -> assertThat(message).contains(\"URI\"));\n        } finally {\n            injectionManager.shutdown();\n        }\n    }\n\n    @Test\n    void classpathFilePropertyReportsMissingResource() {\n        final WadlGeneratorConfig config = WadlGeneratorConfig\n                .generator(FileClasspathGenerator.class)\n                .prop(\"file\", \"classpath:/missing-wadl-loader-resource.xml\")\n                .build();\n\n        final InjectionManager injectionManager = createInjectionManager();\n        try {\n            assertThatThrownBy(() -> config.createWadlGenerator(injectionManager))\n                    .isInstanceOf(ProcessingException.class)\n                    .hasMessageContaining(\"Could not load wadl generators\")\n                    .hasRootCauseMessage(\"The file '/missing-wadl-loader-resource.xml' does not exist in the classpath.\"\n                            + \" It's loaded by the generator class, so if you use a relative filename it's relative to\"\n                            + \" the generator class, otherwise you might want to load it via an absolute classpath\"\n                            + \" reference like classpath:/somefile.xml\");\n        } finally {\n            injectionManager.shutdown();\n        }\n    }\n\n    private static InjectionManager createInjectionManager() {\n        final InjectionManager injectionManager = Injections.createInjectionManager();\n        injectionManager.completeRegistration();\n        return injectionManager;\n    }\n\n    private static Throwable rootCause(Throwable throwable) {\n        Throwable result = throwable;\n        while (result.getCause() != null) {\n            result = result.getCause();\n        }\n        return result;\n    }\n\n    public static final class ConfigurableGenerator extends BaseGenerator {\n        private String text;\n        private File file;\n        private int streamFirstByte = -1;\n        private Holder holder;\n        private boolean initialized;\n\n        public ConfigurableGenerator() {\n        }\n\n        public void setText(String text) {\n            this.text = text;\n        }\n\n        public void setFile(File file) {\n            this.file = file;\n        }\n\n        public void setStream(InputStream stream) throws IOException {\n            this.streamFirstByte = stream.read();\n        }\n\n        public void setHolder(Holder holder) {\n            this.holder = holder;\n        }\n\n        @Override\n        public void init() throws Exception {\n            initialized = true;\n            super.init();\n        }\n    }\n\n    public static final class FileClasspathGenerator extends BaseGenerator {\n        private File file;\n\n        public FileClasspathGenerator() {\n        }\n\n        public void setFile(File file) {\n            this.file = file;\n        }\n    }\n\n    public static final class Holder {\n        private final String value;\n\n        public Holder(String value) {\n            this.value = value;\n        }\n    }\n\n    public abstract static class BaseGenerator implements WadlGenerator {\n        private WadlGenerator delegate;\n\n        @Override\n        public void setWadlGeneratorDelegate(WadlGenerator delegate) {\n            this.delegate = delegate;\n        }\n\n        @Override\n        public void init() throws Exception {\n            if (delegate != null) {\n                delegate.init();\n            }\n        }\n\n        @Override\n        public String getRequiredJaxbContextPath() {\n            return delegate == null ? null : delegate.getRequiredJaxbContextPath();\n        }\n\n        @Override\n        public Application createApplication() {\n            return delegate == null ? new Application() : delegate.createApplication();\n        }\n\n        @Override\n        public Resources createResources() {\n            return delegate == null ? new Resources() : delegate.createResources();\n        }\n\n        @Override\n        public Resource createResource(org.glassfish.jersey.server.model.Resource resource, String path) {\n            return delegate == null ? new Resource() : delegate.createResource(resource, path);\n        }\n\n        @Override\n        public com.sun.research.ws.wadl.Method createMethod(org.glassfish.jersey.server.model.Resource resource,\n                org.glassfish.jersey.server.model.ResourceMethod method) {\n            return delegate == null ? new com.sun.research.ws.wadl.Method() : delegate.createMethod(resource, method);\n        }\n\n        @Override\n        public Request createRequest(org.glassfish.jersey.server.model.Resource resource,\n                org.glassfish.jersey.server.model.ResourceMethod method) {\n            return delegate == null ? new Request() : delegate.createRequest(resource, method);\n        }\n\n        @Override\n        public Representation createRequestRepresentation(org.glassfish.jersey.server.model.Resource resource,\n                org.glassfish.jersey.server.model.ResourceMethod method, MediaType mediaType) {\n            if (delegate == null) {\n                return new Representation();\n            }\n            return delegate.createRequestRepresentation(resource, method, mediaType);\n        }\n\n        @Override\n        public List<Response> createResponses(org.glassfish.jersey.server.model.Resource resource,\n                org.glassfish.jersey.server.model.ResourceMethod method) {\n            return delegate == null ? Collections.emptyList() : delegate.createResponses(resource, method);\n        }\n\n        @Override\n        public Param createParam(org.glassfish.jersey.server.model.Resource resource,\n                org.glassfish.jersey.server.model.ResourceMethod method, Parameter parameter) {\n            return delegate == null ? new Param() : delegate.createParam(resource, method, parameter);\n        }\n\n        @Override\n        public ExternalGrammarDefinition createExternalGrammar() {\n            return delegate == null ? new ExternalGrammarDefinition() : delegate.createExternalGrammar();\n        }\n\n        @Override\n        public void attachTypes(ApplicationDescription description) {\n            if (delegate != null) {\n                delegate.attachTypes(description);\n            }\n        }\n\n    }\n}\n"}], "isError": false, "timestamp": 1780773748099}, {"role": "toolResult", "toolCallId": "call_FQq2ly6a8XC36B8gC47wH17t|fc_0318fb826ca69cbb016a247373bbcc8196887dec0b1be0d542", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_eclipse_sisu.org_eclipse_sisu_inject;\n\nimport static org.assertj.core.api.Assertions.assertThat;\nimport static org.eclipse.sisu.space.asm.Opcodes.ACC_PUBLIC;\nimport static org.eclipse.sisu.space.asm.Opcodes.ACC_STATIC;\nimport static org.eclipse.sisu.space.asm.Opcodes.ACC_SUPER;\nimport static org.eclipse.sisu.space.asm.Opcodes.ALOAD;\nimport static org.eclipse.sisu.space.asm.Opcodes.ARETURN;\nimport static org.eclipse.sisu.space.asm.Opcodes.ASTORE;\nimport static org.eclipse.sisu.space.asm.Opcodes.DUP;\nimport static org.eclipse.sisu.space.asm.Opcodes.GOTO;\nimport static org.eclipse.sisu.space.asm.Opcodes.IFEQ;\nimport static org.eclipse.sisu.space.asm.Opcodes.ILOAD;\nimport static org.eclipse.sisu.space.asm.Opcodes.INVOKESPECIAL;\nimport static org.eclipse.sisu.space.asm.Opcodes.NEW;\nimport static org.eclipse.sisu.space.asm.Opcodes.V1_6;\n\nimport org.eclipse.sisu.space.asm.ClassReader;\nimport org.eclipse.sisu.space.asm.ClassWriter;\nimport org.eclipse.sisu.space.asm.Label;\nimport org.eclipse.sisu.space.asm.MethodVisitor;\nimport org.junit.jupiter.api.Test;\n\npublic class ClassWriterTest {\n    @Test\n    void computeFramesResolvesCommonSuperclassForMergedBranchTypes() {\n        ClassWriter writer = new ClassWriter(ClassWriter.COMPUTE_FRAMES);\n        writer.visit(V1_6, ACC_PUBLIC | ACC_SUPER, \"example/GeneratedLists\", null, \"java/lang/Object\", null);\n        addChooseListMethod(writer);\n        writer.visitEnd();\n\n        byte[] bytecode = writer.toByteArray();\n\n        assertThat(bytecode).isNotEmpty();\n        assertThat(new ClassReader(bytecode).getClassName()).isEqualTo(\"example/GeneratedLists\");\n    }\n\n    private static void addChooseListMethod(ClassWriter writer) {\n        MethodVisitor method = writer.visitMethod(ACC_PUBLIC | ACC_STATIC, \"choose\",\n            \"(Z)Ljava/util/AbstractList;\", null, null);\n        Label useLinkedList = new Label();\n        Label returnList = new Label();\n\n        method.visitCode();\n        method.visitVarInsn(ILOAD, 0);\n        method.visitJumpInsn(IFEQ, useLinkedList);\n        method.visitTypeInsn(NEW, \"java/util/ArrayList\");\n        method.visitInsn(DUP);\n        method.visitMethodInsn(INVOKESPECIAL, \"java/util/ArrayList\", \"<init>\", \"()V\", false);\n        method.visitVarInsn(ASTORE, 1);\n        method.visitJumpInsn(GOTO, returnList);\n\n        method.visitLabel(useLinkedList);\n        method.visitTypeInsn(NEW, \"java/util/LinkedList\");\n        method.visitInsn(DUP);\n        method.visitMethodInsn(INVOKESPECIAL, \"java/util/LinkedList\", \"<init>\", \"()V\", false);\n        method.visitVarInsn(ASTORE, 1);\n\n        method.visitLabel(returnList);\n        method.visitVarInsn(ALOAD, 1);\n        method.visitInsn(ARETURN);\n        method.visitMaxs(0, 0);\n        method.visitEnd();\n    }\n}\n"}], "is