              .prop(\"file\", \"build/wadl-loader-example.txt\")\n                .prop(\"stream\", JERSEY_LOCALIZATION_RESOURCE)\n                .prop(\"holder\", \"constructed value\")\n                .build();\n        final InjectionManager injectionManager = createInjectionManager();\n        try {\n            final WadlGenerator generator = config.createWadlGenerator(injectionManager);\n\n            assertThat(generator).isInstanceOf(ConfigurableGenerator.class);\n            final ConfigurableGenerator configurableGenerator = (ConfigurableGenerator) generator;\n            assertThat(configurableGenerator.text).isEqualTo(\"direct value\");\n            assertThat(configurableGenerator.file).isEqualTo(new File(\"build/wadl-loader-example.txt\"));\n            assertThat(configurableGenerator.streamFirstByte).isNotEqualTo(-1);\n            assertThat(configurableGenerator.holder.value).isEqualTo(\"constructed value\");\n            assertThat(configurableGenerator.initialized).isTrue();\n        } finally {\n            injectionManager.shutdown();\n        }\n    }\n\n    @Test\n    void classpathFilePropertyUsesResolvableClassResourceWhenAvailable() {\n        final WadlGeneratorConfig config = WadlGeneratorConfig\n                .generator(FileClasspathGenerator.class)\n                .prop(\"file\", \"classpath:WadlGeneratorLoaderTest$FileClasspathGenerator.class\")\n                .build();\n\n        final InjectionManager injectionManager = createInjectionManager();\n        try {\n            final WadlGenerator generator = config.createWadlGenerator(injectionManager);\n\n            assertThat(generator).isInstanceOf(FileClasspathGenerator.class);\n            final File configuredFile = ((FileClasspathGenerator) generator).file;\n            assertThat(configuredFile).isFile();\n            assertThat(configuredFile.getName()).isEqualTo(\"WadlGeneratorLoaderTest$FileClasspathGenerator.class\");\n        } catch (ProcessingException e) {\n      