                  .generator(FileClasspathGenerator.class)
                  .prop("file", "classpath:WadlGeneratorLoaderTest$FileClasspathGenerator.class")
                  .build();
  
          final InjectionManager injectionManager = createInjectionManager();
          try {
              final WadlGenerator generator = config.createWadlGenerator(injectionManager);
  
              assertThat(generator).isInstanceOf(FileClasspathGenerator.class);
              final File configuredFile = ((FileClasspathGenerator) generator).file;
              assertThat(configuredFile).isFile();
              assertThat(configuredFile.getName()).isEqualTo("WadlGeneratorLoaderTest$FileClasspathGenerator.class");
          } catch (ProcessingException e) {
              final Throwable rootCause = rootCause(e);
              assertThat(rootCause.getMessage()).satisfiesAnyOf(
                      message -> assertThat(message).contains("does not exist in the classpath"),
                      message -> assertThat(message).contains("URI"));
          } finally {
              injectionManager.shutdown();
          }
      }
  
      @Test
      void classpathFilePropertyReportsMissingResource() {
          final WadlGeneratorConfig config = WadlGeneratorConfig
                  .generator(FileClasspathGenerator.class)
                  .prop("file", "classpath:/missing-wadl-loader-resource.xml")
                  .build();
  
          final InjectionManager injectionManager = createInjectionManager();
          try {
              assertThatThrownBy(() -> config.createWadlGenerator(injectionManager))
                      .isInstanceOf(ProcessingException.class)
                      .hasMessageContaining("Could not load wadl generators")
                      .hasRootCauseMessage("The file '/missing-wadl-loader-resource.xml' does not exist in the classpath."
