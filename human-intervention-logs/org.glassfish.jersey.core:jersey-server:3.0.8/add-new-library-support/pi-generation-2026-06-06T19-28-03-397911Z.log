.nio.file.Path;\nimport java.util.Collections;\nimport java.util.Enumeration;\nimport java.util.List;\n\nimport org.glassfish.jersey.server.internal.scanning.PackageNamesScanner;\nimport org.jboss.vfs.VFS;\nimport org.jboss.vfs.VirtualFile;\nimport org.junit.jupiter.api.Test;\nimport org.junit.jupiter.api.io.TempDir;\n\npublic class VfsSchemeResourceFinderFactoryInnerVfsResourceFinderTest {\n    private static final String PACKAGE_NAME = \"sample.vfs.resources\";\n    private static final String PACKAGE_PATH = PACKAGE_NAME.replace('.', '/');\n    private static final String RESOURCE_NAME = \"GreetingResource.class\";\n    private static final String RESOURCE_CONTENT = \"vfs resource content\";\n\n    @Test\n    void packageNameScannerReadsLeafResourceFromJbossVirtualFileSystem(@TempDir Path tempDirectory) throws Exception {\n        final Path packageDirectory = Files.createDirectories(tempDirectory.resolve(PACKAGE_PATH));\n        Files.writeString(packageDirectory.resolve(RESOURCE_NAME), RESOURCE_CONTENT, StandardCharsets.UTF_8);\n\n        final VirtualFile mountPoint = VFS.getChild(\"jersey-server-test/\" + tempDirectory.getFileName());\n        try (Closeable mount = VFS.mountReal(tempDirectory.toFile(), mountPoint)) {\n            final URL packageUrl = mountPoint.getChild(PACKAGE_PATH).toURL();\n            final ClassLoader classLoader = new SingleResourceClassLoader(PACKAGE_PATH, packageUrl);\n\n            try (PackageNamesScanner scanner = new PackageNamesScanner(classLoader, new String[] {PACKAGE_NAME}, false)) {\n                assertThat(scanner.hasNext()).isTrue();\n                assertThat(scanner.next()).isEqualTo(RESOURCE_NAME);\n                try (InputStream stream = scanner.open()) {\n                    assertThat(new String(stream.readAllBytes(), StandardCharsets.UTF_8)).isEqualTo(RESOURCE_CONTENT);\n                }\n                assertThat(scanner.hasNext()).isFalse();\n            }\n        }\n    }\n\n    private static final class SingleResourceClassLoader extends ClassLoader {\n        private final String resourceName;\n        private final URL resourceUrl;\n\n        private SingleResourceClassLoader(String resourceName, URL resourceUrl) {\n            super(null);\n            this.resourceName = resourceName;\n            this.resourceUrl = resourceUrl;\n        }\n\n        @Override\n        public Enumeration<URL> getResources(String name) throws IOException {\n            if (resourceName.equals(name)) {\n                return Collections.enumeration(List.of(resourceUrl));\n            }\n            return Collections.emptyEnumeration();\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 652, "output": 1796, "cacheRead": 39936, "cacheWrite": 0, "totalTokens": 42384, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780774012424, "responseId": "resp_013668d52bbbe33c016a24747d3ef081958de205f92914a3f6"}}
[tool-exec] start id=call_aqGZ2oGSCe0MRtCiCf2H1ZK2|fc_013668d52bbbe33c016a2474950e048195b6619012478da972 name=write args={"path": "tests/src/org.glassfish.jersey.core/jersey-server/3.0.8/src/test/java/org_glassfish_jersey_core/jersey_server/VfsSchemeResourceFinderFactoryInnerVfsResourceFinderTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_glassfish_jersey_core.jersey_server;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.Closeable;\nimport java.io.IOException;\nimport java.io.InputStream;\nimport java.net.URL;\nimport java.nio.charset.StandardCharsets;\nimport java.nio.file.Files;\nimport java.nio.file.Path;\nimport java.util.Collections;\nimport java.util.Enumeration;\nimport java.util.List;\n\nimport org.glassfish.jersey.server.internal.scanning.PackageNamesScanner;\nimport org.jboss.vfs.VFS;\nimport org.jboss.vfs.VirtualFile;\nimport org.junit.jupiter.api.Test;\nimport org.junit.jupiter.api.io.TempDir;\n\npublic class VfsSchemeResourceFinderFactoryInnerVfsResourceFinderTest {\n    private static final String PACKAGE_NAME = \"sample.vfs.resources\";\n    private static final String PACKAGE_PATH = PACKAGE_NAME.replace('.', '/');\n    private static final String RESOURCE_NAME = \"GreetingResource.class\";\n    private static final String RESOURCE_CONTENT = \"vfs resource content\";\n\n    @Test\n    void packageNameScannerReadsLeafResourceFromJbossVirtualFileSystem(@TempDir Path tempDirectory) throws Exception {\n        final Path packageDirectory = Files.createDirectories(tempDirectory.resolve(PACKAGE_PATH));\n        Files.writeString(packageDirectory.resolve(RESOURCE_NAME), RESOURCE_CONTENT, StandardCharsets.UTF_8);\n\n        final VirtualFile mountPoint = VFS.getChild(\"jersey-server-test/\" + tempDirectory.getFileName());\n        try (Closeable mount = VFS.mountReal(tempDirectory.toFile(), mountPoint)) {\n            final URL packageUrl = mountPoint.getChild(PACKAGE_PATH).toURL();\n            final ClassLoader classLoader = new SingleResourceClassLoader(PACKAGE_PATH, packageUrl);\n\n            try (PackageNamesScanner scanner = new PackageNamesScanner(classLoader, new String[] {PACKAGE_NAME}, false)) {\n                assertThat(scanner.hasNext()).isTrue();\n                assertThat(scanner.next()).isEqualTo(RESOURCE_NAME);\n                try (InputStream stream = scanner.open()) {\n                    assertThat(new String(stream.readAllBytes(), StandardCharsets.UTF_8)).isEqualTo(RESOURCE_CONTENT);\n                }\n                assertThat(scanner.hasNext()).isFalse();\n            }\n        }\n    }\n\n    private static final class SingleResourceClassLoader extends ClassLoader {\n        private final String resourceName;\n        private final URL resourceUrl;\n\n        private SingleResourceClassLoader(String resourceName, URL resourceUrl) {\n            super(null);\n            this.resourceName = resourceName;\n            this.resourceUrl = resourceUrl;\n        }\n\n        @Override\n        public Enumeration<URL> getResources(String name) throws IOException {\n            if (resourceName.equals(name)) {\n                return Collections.enumeration(List.of(resourceUrl));\n            }\n            return Collections.emptyEnumeration();\n        }\n    }\n}\n"}
