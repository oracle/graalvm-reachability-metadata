  public class WadlGeneratorLoaderTest {
      private static final String JERSEY_LOCALIZATION_RESOURCE =
              "org/glassfish/jersey/server/internal/localization.properties";
  
      @Test
      void createWadlGeneratorConfiguresPropertiesWithSupportedConversions() {
          final WadlGeneratorConfig config = WadlGeneratorConfig
                  .generator(ConfigurableGenerator.class)
                  .prop("text", "direct value")
                  .prop("file", "build/wadl-loader-example.txt")
                  .prop("stream", JERSEY_LOCALIZATION_RESOURCE)
                  .prop("holder", "constructed value")
                  .build();
          final InjectionManager injectionManager = createInjectionManager();
          try {
              final WadlGenerator generator = config.createWadlGenerator(injectionManager);
  
              assertThat(generator).isInstanceOf(ConfigurableGenerator.class);
              final ConfigurableGenerator configurableGenerator = (ConfigurableGenerator) generator;
              assertThat(configurableGenerator.text).isEqualTo("direct value");
              assertThat(configurableGenerator.file).isEqualTo(new File("build/wadl-loader-example.txt"));
              assertThat(configurableGenerator.streamFirstByte).isNotEqualTo(-1);
              assertThat(configurableGenerator.holder.value).isEqualTo("constructed value");
              assertThat(configurableGenerator.initialized).isTrue();
          } finally {
              injectionManager.shutdown();
          }
      }
  
      @Test
      void classpathFilePropertyUsesResolvableClassResourceWhenAvailable() {
