                  org.glassfish.jersey.server.model.ResourceMethod method) {
              return delegate == null ? new com.sun.research.ws.wadl.Method() : delegate.createMethod(resource, method);
          }
  
          @Override
          public Request createRequest(org.glassfish.jersey.server.model.Resource resource,
                  org.glassfish.jersey.server.model.ResourceMethod method) {
              return delegate == null ? new Request() : delegate.createRequest(resource, method);
