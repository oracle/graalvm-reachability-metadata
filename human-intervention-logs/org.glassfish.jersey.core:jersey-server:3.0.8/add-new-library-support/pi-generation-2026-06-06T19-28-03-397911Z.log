      40	public abstract class AbstractURLConnection extends URLConnection {
      41	
      42	    private String contentType;
      43	
      44	    protected AbstractURLConnection(final URL url) {
      45	        super(url);
      46	    }
      47	
      48	    public String getHeaderField(String name) {
      49	        String headerField = null;
      50	        if (name.equals("content-type")) {
      51	            headerField = getContentType();
      52	        } else if (name.equals("content-length")) {
      53	            headerField = String.valueOf(getContentLength());
      54	        } else if (name.equals("last-modified")) {
      55	            long lastModified = getLastModified();
      56	            if (lastModified != 0) {
      57	                // return the last modified date formatted according to RFC 1123
      58	                Date modifiedDate = new Date(lastModified);
      59	                SimpleDateFormat sdf = new SimpleDateFormat("EEE, dd MMM yyyy HH:mm:ss 'GMT'", Locale.US);
      60	                sdf.setTimeZone(TimeZone.getTimeZone("GMT"));
      61	                headerField = sdf.format(modifiedDate);
      62	            }
      63	        } else {
      64	            headerField = super.getHeaderField(name);
      65	        }
      66	        return headerField;
      67	    }
      68	
      69	    public String getContentType() {
      70	        if (contentType != null) { return contentType; }
      71	        contentType = getFileNameMap().getContentTypeFor(getName());
      72	        if (contentType == null) {
      73	            try {
      74	                InputStream is = getInputStream();
      75	                BufferedInputStream bis = new BufferedInputStream(is);
      76	                contentType = java.net.URLConnection.guessContentTypeFromStream(bis);
      77	                bis.close();
      78	            } catch (IOException e) { /* ignore */ }
      79	        }
      80	        return contentType;
      81	    }
      82	
      83	    protected static URI toURI(URL url) throws IOException {
      84	        try {
      85	            return VFSUtils.toURI(url);
      86	        } catch (URISyntaxException e) {
      87	            IOException ioe = new IOException();
      88	            ioe.initCause(e);
      89	            throw ioe;
      90	        }
      91	    }
      92	
      93	    protected abstract String getName();
      94	}
