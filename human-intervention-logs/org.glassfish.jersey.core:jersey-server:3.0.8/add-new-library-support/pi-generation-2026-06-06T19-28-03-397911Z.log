work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_glassfish_jersey_core.jersey_server;\n\nimport org.junit.jupiter.api.Test;\n\npublic class Jersey_serverTest {\n    @Test\n    void test() throws Exception {\n        System.out.println(\"This is just a placeholder, implement your test\");\n    }\n}\n"}], "isError": false, "timestamp": 1780773885445}, {"role": "toolResult", "toolCallId": "call_t9j3wkUtQvlTDBpLM2l5ax9K|fc_013668d52bbbe33c016a2473fd35588195879343e9d80fc676", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_glassfish_jersey_core.jersey_server;\n\nimport static org.assertj.core.api.Assertions.assertThat;\nimport static org.assertj.core.api.Assertions.assertThatThrownBy;\n\nimport java.io.File;\nimport java.io.IOException;\nimport java.io.InputStream;\nimport java.util.Collections;\nimport java.util.List;\n\nimport jakarta.ws.rs.ProcessingException;\nimport jakarta.ws.rs.core.MediaType;\n\nimport org.glassfish.jersey.internal.inject.InjectionManager;\nimport org.glassfish.jersey.internal.inject.Injections;\nimport org.glassfish.jersey.server.model.Parameter;\nimport org.glassfish.jersey.server.wadl.WadlGenerator;\nimport org.glassfish.jersey.server.wadl.config.WadlGeneratorConfig;\nimport org.glassfish.jersey.server.wadl.internal.ApplicationDescription;\nimport org.junit.jupiter.api.Test;\n\nimport com.sun.research.ws.wadl.Application;\nimport com.sun.research.ws.wadl.Param;\nimport com.sun.research.ws.wadl.Representation;\nimport com.sun.research.ws.wadl.Request;\nimport com.sun.research.ws.wadl.Resource;\nimport com.sun.research.ws.wadl.Resources;\nimport com.sun.research.ws.wadl.Response;\n\npublic class WadlGeneratorLoaderTest {\n    private static final String JERSEY_LOCALIZATION_RESOURCE =\n            \"org/glassfish/jersey/server/internal/localization.properties\";\n\n    @Test\n    void createWadlGeneratorConfiguresPropertiesWithSupportedConversions() {\n        final WadlGeneratorConfig config = WadlGeneratorConfig\n                .generator(ConfigurableGenerator.class)\n                .prop(\"text\", \"direct value\")\n                .prop(\"file\", \"build/wadl-loader-example.txt\")\n                .prop(\"stream\", JERSEY_LOCALIZATION_RESOURCE)\n                .prop(\"holder\", \"constructed value\")\n                .build();\n        final InjectionManager injectionManager = createInjectionManager();\n        try {\n            final WadlGenerator generator = config.createWadlGenerator(injectionManager);\n\n            assertThat(generator).isInstanceOf(ConfigurableGenerator.class);\n            final ConfigurableGenerator configurableGenerator = (ConfigurableGenerator) generator;\n            assertThat(configurableGenerator.text).isEqualTo(\"direct value\");\n            assertThat(configurableGenerator.file).isEqualTo(new File(\"build/wadl-loader-example.txt\"));\n            assertThat(configurableGenerator.streamFirstByte).isNotEqualTo(-1);\n            assertThat(configurableGenerator.holder.value).isEqualTo(\"constructed value\");\n            assertThat(configurableGenerator.initialized).isTrue();\n        } finally {\n            injectionManager.shutdown();\n        }\n    }\n\n    @Test\n    void classpathFilePropertyUsesResolvableClassResourceWhenAvailable() {\n        final WadlGeneratorConfig config = WadlGeneratorConfig\n                .generator(FileClasspathGenerator.class)\n                .prop(\"file\", \"classpath:WadlGeneratorLoaderTest$FileClasspathGenerator.class\")\n                .build();\n\n        final InjectionManager injectionManager = createInjectionManager();\n        try {\n            final WadlGenerator generator = config.createWadlGenerator(injectionManager);\n\n            assertThat(generator).isInstanceOf(FileClasspathGenerator.class);\n            final File configuredFile = ((FileClasspathGenerator) generator).file;\n            assertThat(configuredFile).isFile();\n            assertThat(configuredFile.getName()).isEqualTo(\"WadlGeneratorLoaderTest$FileClasspathGenerator.class\");\n        } catch (ProcessingException e) {\n            final Throwable rootCause = rootCause(e);\n            assertThat(rootCause.getMessage()).satisfiesAnyOf(\n                    message -> assertThat(message).contains(\"does not exist in the classpath\"),\n                    message -> assertThat(message).contains(\"URI\"));\n        } finally {\n            injectionManager.shutdown();\n        }\n    }\n\n    @Test\n    void classpathFilePropertyReportsMissingResource() {\n        final WadlGeneratorConfig config = WadlGeneratorConfig\n                .generator(FileClasspathGenerator.class)\n                .prop(\"file\", \"classpath:/missing-wadl-loader-resource.xml\")\n                .build();\n\n        final InjectionManager injectionManager = createInjectionManager();\n        try {\n            assertThatThrownBy(() -> config.createWadlGenerator(injectionManager))\n                    .isInstanceOf(ProcessingException.class)\n                    .hasMessageContaining(\"Could not load wadl generators\")\n                    .hasRootCauseMessage(\"The file '/missing-wadl-loader-resource.xml' does not exist in the classpath.\"\n                            + \" It's loaded by the generator class, so if you use a relative filename it's relative to\"\n                            + \" the generator class, otherwise you might want to load it via an absolute classpath\"\n                            + \" reference like classpath:/somefile.xml\");\n        } finally {\n            injectionManager.shutdown();\n        }\n    }\n\n    private static InjectionManager createInjectionManager() {\n        final InjectionManager injectionManager = Injections.createInjectionManager();\n        injectionManager.completeRegistration();\n        return injectionManager;\n    }\n\n    private static Throwable rootCause(Throwable throwable) {\n        Throwable result = throwable;\n        while (result.getCause() != null) {\n            result = result.getCause();\n        }\n        return result;\n    }\n\n    public static final class ConfigurableGenerator extends BaseGenerator {\n        private String text;\n        private File file;\n        private int streamFirstByte = -1;\n        private Holder holder;\n        private boolean initialized;\n\n        public ConfigurableGenerator() {\n        }\n\n        public void setText(String text) {\n            this.text = text;\n        }\n\n        public void setFile(File file) {\n            this.file = file;\n        }\n\n        public void setStream(InputStream stream) throws IOException {\n            this.streamFirstByte = stream.read();\n        }\n\n        public void setHolder(Holder holder) {\n            this.holder = holder;\n        }\n\n        @Override\n        public void init() throws Exception {\n            initialized = true;\n            super.init();\n        }\n    }\n\n    public static final class FileClasspathGenerator extends BaseGenerator {\n        private File file;\n\n        public FileClasspathGenerator() {\n        }\n\n        public void setFile(File file) {\n            this.file = file;\n        }\n    }\n\n    public static final class Holder {\n        private final String value;\n\n        public Holder(String value) {\n            this.value = value;\n        }\n    }\n\n    public abstract static class BaseGenerator implements WadlGenerator {\n        private WadlGenerator delegate;\n\n        @Override\n        public void setWadlGeneratorDelegate(WadlGenerator delegate) {\n            this.delegate = delegate;\n        }\n\n        @Override\n        public void init() throws Exception {\n            if (delegate != null) {\n            