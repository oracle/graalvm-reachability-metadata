rtualFile file;\r\n    41\t\r\n    42\t    VirtualFileURLConnection(URL url) throws IOException {\r\n    43\t        super(url);\r\n    44\t        file = VFS.getChild(toURI(url));\r\n    45\t    }\r\n    46\t\r\n    47\t    public void connect() throws IOException {\r\n    48\t    }\r\n    49\t\r\n    50\t    public Object getContent() throws IOException {\r\n    51\t        if (JAR_CONTENT_TYPE.equals(getContentType()) || getContentType() == null) {\r\n    52\t            return file;\r\n    53\t        }\r\n    54\t        return super.getContent();\r\n    55\t    }\r\n    56\t\r\n    57\t    public int getContentLength() {\r\n    58\t        final long size = file.getSize();\r\n    59\t        return size > (long) Integer.MAX_VALUE ? -1 : (int) size;\r\n    60\t    }\r\n    61\t\r\n    62\t    public long getLastModified() {\r\n    63\t        return file.getLastModified();\r\n    64\t    }\r\n    65\t\r\n    66\t    public InputStream getInputStream() throws IOException {\r\n    67\t        return file.openStream();\r\n    68\t    }\r\n    69\t\r\n    70\t    public Permission getPermission() throws IOException {\r\n    71\t        String decodedPath = toURI(url).getPath();\r\n    72\t        if (File.separatorChar != '/') { decodedPath = decodedPath.replace('/', File.separatorChar); }\r\n    73\t\r\n    74\t        return new FilePermission(decodedPath, \"read\");\r\n    75\t    }\r\n    76\t\r\n    77\t    @Override\r\n    78\t    protected String getName() {\r\n    79\t        return file.getName();\r\n    80\t    }\r\n    81\t\r\n    82\t    @Override\r\n    83\t    public Object getContent(Class[] classes) throws IOException {\r\n    84\t        Object obj = super.getContent(classes);\r\n    85\t\r\n    86\t        for (int i = 0; i < classes.length; i++) {\r\n    87\t            if (classes[i] == VirtualFile.class) {\r\n    88\t                return file;\r\n    89\t            } else if (classes[i].isInstance(obj)) {\r\n    90\t                return ob