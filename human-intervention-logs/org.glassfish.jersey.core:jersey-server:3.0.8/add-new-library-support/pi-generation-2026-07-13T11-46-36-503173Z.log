ArrayExtractor(type, typeExtractor, parameterName, defaultValueString);\n    }\n\n    /**\n     * Get array extractor instance supporting.\n     *\n     * @param type           the type class to manage runtime generic.\n     * @param extractor  the extractor.\n     * @param parameterName  extracted parameter name.\n     * @param defaultValueString   default parameter value.\n     * @return string array extractor instance.\n     */\n    public static MultivaluedParameterExtractor<Object> getInstance(Class<?> type,\n            MultivaluedParameterExtractor<?> extractor,\n            String parameterName,\n            String defaultValueString) {\n        Function<String, Object> typeExtractor = value -> {\n            MultivaluedMap<String, String> pair = new MultivaluedHashMap<>();\n            pair.putSingle(parameterName, value);\n            return extractor.extract(pair);\n        };\n        return new ArrayExtractor(type, typeExtractor, parameterName, defaultValueString);\n    }\n}\n"}], "isError": false, "timestamp": 1783943110384}, {"role": "toolResult", "toolCallId": "call_RS9bwWCfsWySLC1HpdImz5Db|fc_0ce898a828dd7004016a54cfc59964819197922ed0cbc904a3", "toolName": "bash", "content": [{"type": "text", "text": "./build/tests/org.glassfish.jersey.core:jersey-server:3.0.8\n./tests/src/org.glassfish.jersey.core/jersey-server\n./tests/src/org.glassfish.jersey.core/jersey-server/3.0.8\n./tests/src/org.glassfish.jersey.core/jersey-server/3.0.8/.gradle\n./tests/src/org.glassfish.jersey.core/jersey-server/3.0.8/.gradle/9.1.0\n./tests/src/org.glassfish.jersey.core/jersey-server/3.0.8/.gradle/9.1.0/fileChanges\n./tests/src/org.glassfish.jersey.core/jersey-server/3.0.8/.gradle/9.1.0/fileHashes\n./tests/src/org.glassfish.jersey.core/jersey-server/3.0.8/.gradle/9.1.0/expanded\n./tests/src/org.glassfish.jersey.core/jersey-server/3.0.8/.gradle/9.1.0/vcsMetadata\n./tests/src/org.glassfish.jersey.core/jersey-server/3.0.8/.gradle/9.1.0/checksums\n./tests/src/org.glassfish.jers