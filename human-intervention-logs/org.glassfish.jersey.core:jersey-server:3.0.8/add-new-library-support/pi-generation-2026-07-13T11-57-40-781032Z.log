  /**
   * A JBoss-based "vfsfile", "vfs" and "vfszip" scheme URI scanner.
   * <p/>
   * This approach uses reflection to allow for zero-deps and support
   * for both the v2 (EAP5, AS5) and v3 VFS APIs (AS6, AS7, EAP6 & WildFly)
