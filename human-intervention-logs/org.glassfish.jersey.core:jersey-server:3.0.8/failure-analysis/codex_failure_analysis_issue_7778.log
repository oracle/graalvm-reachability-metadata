fish.jersey.internal.inject.Injections;\\nimport org.glassfish.jersey.server.model.Parameter;\\nimport org.glassfish.jersey.server.wadl.WadlGenerator;\\nimport org.glassfish.jersey.server.wadl.config.WadlGeneratorConfig;\\nimport org.glassfish.jersey.server.wadl.internal.ApplicationDescription;\\nimport org.junit.jupiter.api.Test;\\n\\nimport com.sun.research.ws.wadl.Application;\\nimport com.sun.research.ws.wadl.Param;\\nimport com.sun.research.ws.wadl.Representation;\\nimport com.sun.research.ws.wadl.Request;\\nimport com.sun.research.ws.wadl.Resource;\\nimport com.sun.research.ws.wadl.Resources;\\nimport com.sun.research.ws.wadl.Response;\\n\\npublic class WadlGeneratorLoaderTest {\\n    private static final String JERSEY_LOCALIZATION_RESOURCE =\\n            \\\"org/glassfish/jersey/server/internal/localization.properties\\\";\\n\\n    @Test\\n    void createWadlGeneratorConfiguresPropertiesWithSupportedConversions() {\\n        final WadlGeneratorConfig config = WadlGeneratorConfig\\n                .generator(ConfigurableGenerator.class)\\n                .prop(\\\"text\\\", \\\"direct value\\\")\\n                .prop(\\\"file\\\", \\\"build/wadl-loader-example.txt\\\")\\n                .prop(\\\"stream\\\", JERSEY_LOCALIZATION_RESOURCE)\\n                .prop(\\\"holder\\\", \\\"constructed value\\\")\\n                .build();\\n        final InjectionManager injectionManager = createInjectionManager();\\n        try {\\n            final WadlGenerator generator = config.createWadlGenerator(injectionManager);\\n\\n            assertThat(generator).isInstanceOf(ConfigurableGenerator.class);\\n            final ConfigurableGenerator configurableGenerator = (ConfigurableGenerator) generator;\\n            assertThat(configurableGenerator.text).isEqualTo(\\\"direct value\\\");\\n            assertThat(configurableGenerator.file).isEqualTo(new File(\\\"build/wadl-loader-example.txt\\\"));\\n            assertThat(configurableGenerator.streamFirstByte).isNotE