        final InjectionManager injectionManager = createInjectionManager();\\n        try {\\n            final WadlGenerator generator = config.createWadlGenerator(injectionManager);\\n\\n            assertThat(generator).isInstanceOf(ConfigurableGenerator.class);\\n            final ConfigurableGenerator configurableGenerator = (ConfigurableGenerator) generator;\\n            assertThat(configurableGenerator.text).isEqualTo(\\\"direct value\\\");\\n            assertThat(configurableGenerator.file).isEqualTo(new File(\\\"build/wadl-loader-example.txt\\\"));\\n            assertThat(configurableGenerator.streamFirstByte).isNotEqualTo(-1);\\n            assertThat(configurableGenerator.holder.value).isEqualTo(\\\"constructed value\\\");\\n            assertThat(configurableGenerator.initialized).isTrue();\\n        } finally {\\n            injectionManager.shutdown();\\n        }\\n    }\\n\\n    @Test\\n    void classpathFilePropertyUsesResolvableClassResourceWhenAvailable() {\\n        final WadlGeneratorConfig config = WadlGeneratorConfig\\n                .generator(FileClasspathGenerator.class)\\n                .prop(\\\"file\\\", \\\"classpath:WadlGeneratorLoaderTest$FileClasspathGenerator.class\\\")\\n                .build();\\n\\n        final InjectionManager injectionManager = createInjectionManager();\\n        try {\\n            final WadlGenerator generator = config.createWadlGenerator(injectionManager);\\n\\n            assertThat(generator).isInstanceOf(FileClasspathGenerator.class);\\n            final File configuredFile = ((FileClasspathGenerator) generator).file;\\n            assertThat(configuredFile).isFile();\\n            assertThat(configuredFile.getName()).isEqualTo(\\\"WadlGeneratorLoaderTest$FileClasspathGenerator.class\\\");\\n        } catch (ProcessingException e) {\\n            final Throwable rootCause = rootCause(e);\\n            assertThat(rootCause.getMessage()).satisfiesAnyOf(\\n                    message -> assertThat(message).contains(\\\"does not exist in the classpath\\\"),\\n                    message -> assertThat(message).contains(\\\"URI\\\"));\\n        } finally {\\n            injectionManager.shutdown();\\n        }\\n    }\\n\\n    @Test\\n    void classpathFilePropertyReportsMissingResource() {\\n        final WadlGeneratorConfig config = WadlGeneratorConfig\\n                .generator(FileClasspathGenerator.class)\\n                .prop(\\\"file\\\", \\\"classpath:/missing-wadl-loader-resource.xml\\\")\\n                .build();\\n\\n        final InjectionManager injectionManager = createInjectionManager();\\n        try {\\n            assertThatThrownBy(() -> config.createWadlGenerator(injectionManager))\\n                    .isInstanceOf(ProcessingException.class)\\n                    .hasMessageContaining(\\\"Could not load wadl generators\\\")\\n                    .hasRootCauseMessage(\\\"The file '/missing-wadl-loader-resource.xml' does not exist in the classpath.\\\"\\n                            + \\\" It's loaded by the generator class, so if you use a relative filename it's relative to\\\"\\n                            + \\\" the generator class, otherwise you might want to load it via an absolute classpath\\\"\\n                            + \\\" reference like classpath:/somefile.xml\\\");\\n        } finally {\\n            injectionManager.shutdown();\\n        }\\n    }\\n\\n    private static InjectionManager createInjectionManager() {\\n        final InjectionManager injectionManager = Injections.createInjectionManager();\\n        injectionManager.completeRegistration();\\n        return injectionManager;\\n    }\\n\\n    private static Throwable rootCause(Throwable throwable) {\\n        Throwable result = throwable;\\n        while (result.getCause() != null) {\\n            result = result.getCause();\\n        }\\n        return result;\\n    }\\n\\n    public static final class ConfigurableGenerator extends BaseGenerator {\\n        private String text;\\n        private File file;\\n        private int streamFirstByte = -1;\\n        private Holder holder;\\n        private boolean initialized;\\n\\n        public ConfigurableGenerator() {\\n        }\\n\\n        public void setText(String text) {\\n            this.text = text;\\n        }\\n\\n        public void setFile(File file) {\\n            this.file = file;\\n        }\\n\\n        public void setStream(InputStream stream) throws IOException {\\n            this.streamFirstByte = stream.read();\\n        }\\n\\n        public void setHolder(Holder holder) {\\n            this.holder = holder;\\n        }\\n\\n        @Override\\n        public void init() throws Exception {\\n            initialized = true;\\n            super.init();\\n        }\\n    }\\n\\n    public static final class FileClasspathGenerator extends BaseGenerator {\\n        private File file;\\n\\n        public FileClasspathGenerator() {\\n        }\\n\\n        public void setFile(File file) {\\n            this.file = file;\\n        }\\n    }\\n\\n    public static final class Holder {\\n        private final String value;\\n\\n        public Holder(String value) {\\n            this.value = value;\\n        }\\n    }\\n\\n    public abstract static class BaseGenerator implements WadlGenerator {\\n        private WadlGenerator delegate;\\n\\n        @Override\\n        public void setWadlGeneratorDelegate(WadlGenerator delegate) {\\n            this.delegate = delegate;\\n        }\\n\\n        @Override\\n        public void init() throws Exception {\\n            if (delegate != null) {\\n                delegate.init();\\n            }\\n        }\\n\\n        @Override\\n        public String getRequiredJaxbContextPath() {\\n            return delegate == null ? null : delegate.getRequiredJaxbContextPath();\\n        }\\n\\n        @Override\\n        public Application createApplication() {\\n            return delegate == null ? new Application() : delegate