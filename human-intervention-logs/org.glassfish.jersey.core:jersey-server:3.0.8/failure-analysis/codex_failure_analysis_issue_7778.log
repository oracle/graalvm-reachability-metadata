.valueOf(getContentLength());\\n    54\\t        } else if (name.equals(\\\"last-modified\\\")) {\\n    55\\t            long lastModified = getLastModified();\\n    56\\t            if (lastModified != 0) {\\n    57\\t                // return the last modified date formatted according to RFC 1123\\n    58\\t                Date modifiedDate = new Date(lastModified);\\n    59\\t                SimpleDateFormat sdf = new SimpleDateFormat(\\\"EEE, dd MMM yyyy HH:mm:ss 'GMT'\\\", Locale.US);\\n    60\\t                sdf.setTimeZone(TimeZone.getTimeZone(\\\"GMT\\\"));\\n    61\\t                headerField = sdf.format(modifiedDate);\\n    62\\t            }\\n    63\\t        } else {\\n    64\\t            headerField = super.getHeaderField(name);\\n    65\\t        }\\n    66\\t        return headerField;\\n    67\\t    }\\n    68\\t\\n    69\\t    public String getContentType() {\\n    70\\t        if (contentType != null) { return contentType; }\\n    71\\t        contentType = getFileNameMap().getContentTypeFor(getName());\\n    72\\t        if (contentType == null) {\\n    73\\t            try {\\n    74\\t                InputStream is = getInputStream();\\n    75\\t                BufferedInputStream bis = new BufferedInputStream(is);\\n    76\\t                contentType = java.net.URLConnection.guessContentTypeFromStream(bis);\\n    77\\t                bis.close();\\n    78\\t            } catch (IOException e) { /* ignore */ }\\n    79\\t        }\\n    80\\t        return contentType;\\n    81\\t    }\\n    82\\t\\n    83\\t    protected static URI toURI(URL url) throws IOException {\\n    84\\t        try {\\n    85\\t            return VFSUtils.toURI(url);\\n    86\\t        } catch (URISyntaxException e) {\\n    87\\t            IOException ioe = new IOException();\\n    88\\t            ioe.initCause(e);\\n    89\\t            throw ioe;\\n    90\\t        }\\n    91\\t    }\\n    92\\t\\n    93\\t    protected abstract String getName();\\n    94\\