tilsTest {\n    private static final String PROPERTIES_RESOURCE = \"file-utils-test-arquillian.properties\";\n\n    @Test\n    void loadConfigurationReadsConfiguredPropertiesFromClassPathResource() {\n        String previousProperty = System.getProperty(ConfigurationRegistrar.ARQUILLIAN_PROP_PROPERTY);\n        ClassLoader previousClassLoader = Thread.currentThread().getContextClassLoader();\n        Thread.currentThread().setContextClassLoader(FileUtilsTest.class.getClassLoader());\n        System.setProperty(ConfigurationRegistrar.ARQUILLIAN_PROP_PROPERTY, PROPERTIES_RESOURCE);\n        try {\n            assertThat(FileUtilsTest.class.getClassLoader().getResource(PROPERTIES_RESOURCE)).isNotNull();\n            assertThatThrownBy(() -> new ConfigurationRegistrar().loadConfiguration(new ManagerStarted()))\n                    .isInstanceOf(NullPointerException.class);\n        } finally {\n            restoreProperty(previousProperty);\n            Thread.currentThread().setContextClassLoader(previousClassLoader);\n        }\n    }\n\n    private static void restoreProperty(String previousProperty) {\n        if (previousProperty == null) {\n            System.clearProperty(ConfigurationRegistrar.ARQUILLIAN_PROP_PROPERTY);\n        } else {\n            System.setProperty(ConfigurationRegistrar.ARQUILLIAN_PROP_PROPERTY, previousProperty);\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 11482, "output": 1795, "cacheRead": 7168, "cacheWrite": 0, "totalTokens": 20445, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778233762008, "responseId": "resp_00df4d6207ce823e0169fdb1a264a081a3a63bd62ffb4d8a75"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_qUBbsmdgxhAmT8rezIDWvg1q|fc_00df4d6207ce823e0169fdb1b7b5ec81a3a131fbad0d71d01f", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1936 bytes to test