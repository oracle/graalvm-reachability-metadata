itSummary);\\\\n        handler.onRollbackSummary(new TestRollbackSummary());\\\\n        handler.onResetSummary(new TestResetSummary());\\\\n        handler.onRouteSummary(routeSummary);\\\\n        handler.onLogoffSummary(new TestLogoffSummary());\\\\n        handler.onLogonSummary(new TestLogonSummary());\\\\n        handler.onTelemetrySummary(new TestTelemetrySummary());\\\\n        handler.onIgnored();\\\\n        handler.onIgnored();\\\\n        handler.onComplete();\\\\n\\\\n        BasicResponseHandler.Summaries summaries = handler.summaries().toCompletableFuture().get(1, TimeUnit.SECONDS);\\\\n        assertThat(summaries.beginSummary()).isSameAs(beginSummary);\\\\n        assertThat(summaries.runSummary().queryId()).isEqualTo(7L);\\\\n        assertThat(summaries.runSummary().keys()).containsExactly(\\\\\\\"name\\\\\\\", \\\\\\\"age\\\\\\\");\\\\n        assertThat(summaries.runSummary().databaseName()).contains(\\\\\\\"customers\\\\\\\");\\\\n        assertThat(summaries.valuesList()).containsExactly(record);\\\\n\\\\n[415 more lines in file. Use offset=381 to continue.]\\\"}], \\\"isError\\\": false, \\\"timestamp\\\": 1777932750163}}\\n744:[recv] {\\\"type\\\": \\\"turn_end\\\", \\\"message\\\": {\\\"role\\\": \\\"assistant\\\", \\\"content\\\": [{\\\"type\\\": \\\"thinking\\\", \\\"thinking\\\": \\\"**Inspecting tests and sources**\\\\n\\\\nI need to fix some tests, which means I should carefully inspect the test cases and focus on the related classes in the source code. It's important that I don't run the tests right now; instead, I'll just read through them. I might need some context from the source code to understand things better. So, let’s make a list of what’s relevant for this task!\\\", \\\"thinkingSignature\\\": \\\"{\\\\\\\"id\\\\\\\":\\\\\\\"rs_038cb9714056441d0169f919cbf004819fac17359f8fce20f5\\\\\\\",\\\\\\\"type\\\\\\\":\\\\\\\"reasoning\\\\\\\",\\\\\\\"encrypted_content\\\\\\\":\\\\\\\"gAAAAABp-RnNRr3FfAVqzOt-BsD_8Bio6tIXreVvTbKrO2LhjgAZ