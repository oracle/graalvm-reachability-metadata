  				String name = "null";
  				if (clazz != null) {
  					name = clazz.getName();
  				}
  				logger.log(Level.SEVERE, "Could not initialize command " + name, e);
  			}
  		}
  	}
  
  	private void initCommand(Gateway gateway, Command cmd) {
