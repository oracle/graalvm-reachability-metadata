              if (t.getExtendsBound() != null) {
                  rv.addAll(visit(t.getExtendsBound(), p));
              }
              if (t.getSuperBound() != null) {
                  rv.addAll(visit(t.getSuperBound(), p));
              }
              return rv;
          }
  
          @Override
