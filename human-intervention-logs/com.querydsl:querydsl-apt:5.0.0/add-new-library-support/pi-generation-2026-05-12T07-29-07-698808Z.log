peCategory);\n  public abstract com.querydsl.codegen.utils.model.Type asArrayType();\n  public abstract com.querydsl.codegen.utils.model.Type getComponentType();\n  public abstract com.querydsl.codegen.utils.model.Type getEnclosingType();\n  public abstract com.querydsl.codegen.utils.model.TypeCategory getCategory();\n  public abstract java.lang.String getFullName();\n  public abstract java.lang.String getGenericName(boolean);\n  public abstract java.lang.String getGenericName(boolean, java.util.Set<java.lang.String>, java.util.Set<java.lang.String>);\n  public abstract java.lang.Class<?> getJavaClass();\n  public abstract java.lang.String getPackageName();\n  public abstract java.util.List<com.querydsl.codegen.utils.model.Type> getParameters();\n  public abstract java.lang.String getRawName(java.util.Set<java.lang.String>, java.util.Set<java.lang.String>);\n  public abstract java.lang.String getSimpleName();\n  public abstract boolean isFinal();\n  public abstract boolean isPrimitive();\n  public abstract boolean isMember();\n}\nCompiled from \"TypeExtends.java\"\npublic class com.querydsl.codegen.utils.model.TypeExtends extends com.querydsl.codegen.utils.model.TypeAdapter {\n  public com.querydsl.codegen.utils.model.TypeExtends(java.lang.String, com.querydsl.codegen.utils.model.Type);\n  public com.querydsl.codegen.utils.model.TypeExtends(com.querydsl.codegen.utils.model.Type);\n  public java.lang.String getGenericName(boolean);\n  public java.lang.String getGenericName(boolean, java.util.Set<java.lang.String>, java.util.Set<java.lang.String>);\n  public java.lang.String getVarName();\n  public boolean equals(java.lang.Object);\n}\n"}], "isError": false, "timestamp": 1778570872418}]}
