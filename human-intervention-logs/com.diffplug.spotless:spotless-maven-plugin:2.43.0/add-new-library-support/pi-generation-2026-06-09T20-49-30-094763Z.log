;\n        build.setTestSourceDirectory(testSourceDirectory.toString());\n        MavenProject project = new MavenProject();\n        project.setFile(temporaryDirectory.resolve(\"pom.xml\").toFile());\n        project.setBuild(build);\n\n        Java javaFormatter = new Java();\n\n        assertThat(javaFormatter.defaultIncludes(project))\n                .containsExactlyInAnyOrder(\n                        temporaryDirectory.relativize(sourceDirectory).resolve(\"**/*.java\").toString(),\n                        temporaryDirectory.relativize(testSourceDirectory).resolve(\"**/*.java\").toString());\n        assertThat(javaFormatter.licenseHeaderDelimiter()).isEqualTo(\"(package|import|public|class|module)\");\n    }\n\n    @Test\n    void formatterStepConfigExposesConfiguredValues() {\n        FormatterStepConfig config = stepConfig();\n"}]}
