      // Super Model Handling
      
      private static final String MAVEN_MODEL_VERSION = "4.0.0";
  
      private MavenXpp3Reader modelReader = new MavenXpp3Reader();
  
      private Model superModel;
  
      public Model getSuperModel()
      {
          if ( superModel != null )
          {
              return superModel;
          }
  
          Reader reader = null;
          
