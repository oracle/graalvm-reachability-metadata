  > mkdir ${TMP_DIR}/helidon-mp
  > cp -R * ${TMP_DIR}/helidon-mp
  > cd ${TMP_DIR}/helidon-mp/mp-native-test
  # create the database directory
  > rm -rf .h2
  > mkdir .h2
  # Force image builder on classpath for now
  # TODO: This needs to be removed in the future
  > export NATIVE_IMAGE_EXPERIMENTAL_OPTIONS_ARE_FATAL=false
  # Prepare the build - requires java 11
  # this step is needed to download h2 database driver
  # --batch-mode does not output download progress
  >[0?] mvn clean --batch-mode prepare-package -DskipTests
  # Start the database
  >[0?] ./start-db.sh
  # Build native image - requires GRAALVM_HOME env var + java 11
  # --batch-mode does not output download progress
  >[0?] mvn package --batch-mode -Pnative-image -DskipTests
  # Test with java to make sure everything is fine with our code and database
  >[0?] java -jar ./target/mp-native-test.jar
  # Test with native image
  >[0?] ./target/mp-native-test
  # Shut down the database
  >[0?] ./stop-db.sh
[tool-exec] end id=call_XIdS47tbuxSeFRT13NWQQHZg|fc_0835db99fa3e0283016a5430760d688191be45b36bb322b410 name=read status=success
