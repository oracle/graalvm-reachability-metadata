          TestELContext context = new TestELContext();
          StaticFieldELResolver resolver = new StaticFieldELResolver();
  
          Object value = resolver.invoke(
                  context,
                  new ELClass(StaticOperations.class),
                  "join",
                  null,
                  new Object[] { "prefix", "one", "two" });
  
