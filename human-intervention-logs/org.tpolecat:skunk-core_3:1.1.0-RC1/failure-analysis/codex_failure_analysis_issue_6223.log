rg.jline/jline-reader/3.22.0,/home/vjovanov/c/forge/forge9/graalvm-reachability-metadata/forge/local_repositories/forge_worktrees/6223-95b3ea1e/metadata/org.jline/jline/3.21.0,/home/vjovanov/c/forge/forge9/graalvm-reachability-metadata/forge/local_repositories/forge_worktrees/6223-95b3ea1e/metadata/org.jline/jline-terminal/3.21.0,/home/vjovanov/c/forge/forge9/graalvm-reachability-metadata/forge/local_repositories/forge_worktrees/6223-95b3ea1e/metadata/org.jline/jline-native/3.27.1,/home/vjovanov/c/forge/forge9/graalvm-reachability-metadata/forge/local_repositories/forge_worktrees/6223-95b3ea1e/metadata/org.jline/jline-terminal-jni/3.27.1 \\\n-H:Optimize@user+api=b \\\n-H:+ReportExceptionStackTraces@user \\\n-H:FutureDefaults@user+api=all \\\n-H:+AllowDeprecatedBuilderClassesOnImageClasspath@user \\\n-H:Features@user+api=org.graalvm.junit.platform.JUnitPlatformFeature \\\n","exit_code":0,"status":"completed"}}
