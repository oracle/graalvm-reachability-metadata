   val restored = mapper.readValue(json, classOf[Address])\n    38\t\n    39\t    assertThat(restored).isEqualTo(address)\n    40\t    assertThat(json).contains(\"inventory\")\n    41\t    assertThat(json).contains(\"127.0.0.1\")\n    42\t  }\n    43\t\n    44\t  @Test\n    45\t  def addressModuleRoundTripsAddressesWithoutHosts(): Unit = {\n    46\t    val mapper = new ObjectMapper()\n    47\t    mapper.registerModule(new AkkaJacksonModule())\n    48\t\n    49\t    val address = Address(\"akka\", \"cluster\")\n    50\t    val json = mapper.writeValueAsString(address)\n    51\t    val restored = mapper.readValue(json, classOf[Address])\n    52\t\n    53\t    assertThat(restored).isEqualTo(address)\n    54\t    assertThat(json).contains(\"cluster\")\n    55\t  }\n    56\t\n    57\t  @Test\n    58\t  def finiteDurationModuleRoundTripsFiniteDurations(): Unit = {\n    59\t    val mapper = new ObjectMapper()\n    60\t    mapper.registerModule(new AkkaJacksonModule())\n    61\t\n    62\t    val duration = 250.millis\n    63\t    val json = mapper.writeValueAsString(duration)\n    64\t    val restored = mapper.readValue(json, classOf[FiniteDuration])\n    65\t\n    66\t    assertThat(restored).isEqualTo(duration)\n    67\t  }\n    68\t\n    69\t  @Test\n    70\t  def jacksonMigrationCanRewriteLegacyFieldNames(): Unit = {\n    71\t    val json = new ObjectMapper().readTree(\"\"\"{\"oldName\":\"Ada Lovelace\"}\"\"\")\n    72\t    val restored = new RenameOldNameMigration().transform(1, json)\n    73\t\n    74\t    assertThat(restored.get(\"newName\").asText()).isEqualTo(\"Ada Lovelace\")\n    75\t    assertThat(restored.has(\"oldName\")).isFalse\n    76\t  }\n    77\t\n    78\t  @Test\n    79\t  def versionExtractorReturnsMajorAndMinorComponents(): Unit = {\n    80\t    val version = new Version(2, 13, 2, null, \"com.typesafe.akka\", \"akka-serialization-jackson_3\")\n    81\t    val extracted = VersionExtractor.unapply(version)\n    82\t\n    83\t    assertThat(extracted.isDefined).isTrue\n    84\t    val tuple = extracted.get\n    85\t    assertThat(tuple._1).isEqualTo(2)\n    86\t    assertThat(tuple._2).isEqualTo(13)\n    87\t  }\n    88\t\n    89\t  @Test\n    90\t  def objectMapperFactoryAppliesPerBindingJsonReadFeatureOverrides(): Unit = {\n    91\t    val factory = new JacksonObjectMapperFactory {\n    92\t      override def overrideConfiguredJsonReadFeatures(\n    93\t          bindingName: String,\n    94\t          configured: scala.collection.immutable.Seq[(JsonReadFeature, Any)]\n    95\t      ): scala.collection.immutable.Seq[(JsonReadFeature, Any)] =\n    96\t        configured :+ (JsonReadFeature.ALLOW_SINGLE_QUOTES, true)\n    97\t    }\n    98\t\n    99\t    val mapper = factory.newObjectMapper(\"jackson-json\", new JsonFactory())\n   100\t    val json = mapper.readTree(\"{'feature':'single-quotes'}\")\n   101\t\n   102\t    assertThat(json.get(\"feature\").asText()).isEqualTo(\"single-quotes\")\n   103\t  }\n   104\t}\n   105\t\n   106\tclass RenameOldNameMigration extends JacksonMigration {\n   107\t  override def currentVersion: Int = 2\n   108\t\n   109\t  override def transform(fromVersion: Int, json: JsonNode): JsonNode = {\n   110\t    if (fromVersion == 1) {\n   111\t      val objectNode = json.deepCopy().asInstanceOf[ObjectNode]\n   112\t      val oldName = objectNode.remove(\"oldName\")\n   113\t      objectNode.put(\"newName\", oldName.asText())\n   114\t      objectNode\n   115\t    } else {\n   116\t      json\n   117\t    }\n   118\t  }\n   119\t}\n","exit_code":0,"status":"completed"}}
