{"type":"item.completed","item":{"id":"item_83","type":"command_execution","command":"/usr/bin/bash -lc \"sed -n '1,220p' tests/src/com.typesafe.akka/akka-serialization-jackson_3/2.6.21/src/test/scala/com_typesafe_akka/akka_serialization_jackson_3/Akka_serialization_jackson_3Test.scala\"","aggregated_output":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_typesafe_akka.akka_serialization_jackson_3\n\nimport scala.concurrent.duration.FiniteDuration\nimport scala.concurrent.duration.DurationInt\n\nimport akka.actor.Address\nimport akka.actor.AddressFromURIString\nimport akka.serialization.jackson.AddressModule\nimport akka.serialization.jackson.FiniteDurationModule\nimport akka.serialization.jackson.JacksonMigration\nimport akka.serialization.jackson.JacksonObjectMapperFactory\nimport akka.serialization.jackson.VersionExtractor\n\nimport com.fasterxml.jackson.core.JsonFactory\nimport com.fasterxml.jackson.core.Version\nimport com.fasterxml.jackson.core.json.JsonReadFeature\nimport com.fasterxml.jackson.databind.JsonNode\nimport com.fasterxml.jackson.databind.ObjectMapper\nimport com.fasterxml.jackson.databind.node.ObjectNode\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\n\nclass Akka_serialization_jackson_3Test {\n\n  @Test\n  def addressModuleRoundTripsAddressesWithHostsAndPorts(): Unit = {\n    val mapper = new ObjectMapper()\n    mapper.registerModule(new AddressModule {})\n\n    val address = AddressFromURIString(\"akka://inventory@127.0.0.1:25520\")\n    val json = mapper.writeValueAsString(address)\n    val restored = mapper.readValue(json, classOf[Address])\n\n    assertThat(restored).isEqualTo(address)\n    assertThat(json).contains(\"inventory\")\n    assertThat(json).contains(\"127.0.0.1\")\n  }\n\n  @Test\n  def addressModuleRoundTripsAddressesWithoutHosts(): Unit = {\n    val mapper = new ObjectMapper()\n    mapper.registerModule(new AddressModule {})\n\n    val address = Address(\"akka\", \"cluster\")\n    val json = mapper.writeValueAsString(address)\n    val restored = mapper.readValue(json, classOf[Address])\n\n    assertThat(restored).isEqualTo(address)\n    assertThat(json).contains(\"cluster\")\n  }\n\n  @Test\n  def finiteDurationModuleRoundTripsFiniteDurations(): Unit = {\n    val mapper = new ObjectMapper()\n    mapper.registerModule(new FiniteDurationModule {})\n\n    val duration = 250.millis\n    val json = mapper.writeValueAsString(duration)\n    val restored = mapper.readValue(json, classOf[FiniteDuration])\n\n    assertThat(restored).isEqualTo(duration)\n  }\n\n  @Test\n  def jacksonMigrationCanRewriteLegacyFieldNames(): Unit = {\n    val json = new ObjectMapper().readTree(\"\"\"{\"oldName\":\"Ada Lovelace\"}\"\"\")\n    val restored = new RenameOldNameMigration().transform(1, json)\n\n    assertThat(restored.get(\"newName\").asText()).isEqualTo(\"Ada Lovelace\")\n    assertThat(restored.has(\"oldName\")).isFalse\n  }\n\n  @Test\n  def versionExtractorReturnsMajorAndMinorComponents(): Unit = {\n    val version = new Version(2, 13, 2, null, \"com.typesafe.akka\", \"akka-serialization-jackson_3\")\n    val extracted = VersionExtractor.unapply(version)\n\n    assertThat(extracted.isDefined).isTrue\n    val tuple = extracted.get\n    assertThat(tuple._1).isEqualTo(2)\n    assertThat(tuple._2).isEqualTo(13)\n  }\n\n  @Test\n  def objectMapperFactoryAppliesPerBindingJsonReadFeatureOverrides(): Unit = {\n    val factory = new JacksonObjectMapperFactory {\n      override def overrideConfiguredJsonReadFeatures(\n          bindingName: String,\n          configured: scala.collection.immutable.Seq[(JsonReadFeature, Any)]\n      ): scala.collection.immutable.Seq[(JsonReadFeature, Any)] =\n        configured :+ (JsonReadFeature.ALLOW_SINGLE_QUOTES, true)\n    }\n\n    val mapper = factory.newObjectMapper(\"jackson-json\", new JsonFactory())\n    val json = mapper.readTree(\"{'feature':'single-quotes'}\")\n\n    assertThat(json.get(\"feature\").asText()).isEqualTo(\"single-quotes\")\n  }\n}\n\nclass RenameOldNameMigration extends JacksonMigration {\n  override def currentVersion: Int = 2\n\n  override def transform(fromVersion: Int, json: JsonNode): JsonNode = {\n    if (fromVersion == 1) {\n      val objectNode = json.deepCopy().asInstanceOf[ObjectNode]\n      val oldName = objectNode.remove(\"oldName\")\n      objectNode.put(\"newName\", oldName.asText())\n      objectNode\n    } else {\n      json\n    }\n  }\n}\n","exit_code":0,"status":"completed"}}
