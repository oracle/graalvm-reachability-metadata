          assertThat(String.valueOf(parsedConfig)).contains("OutlierDetectionLoadBalancerConfig");
  
          try (MinimalHelper helper = new MinimalHelper()) {
              LoadBalancer loadBalancer = provider.newLoadBalancer(helper);
