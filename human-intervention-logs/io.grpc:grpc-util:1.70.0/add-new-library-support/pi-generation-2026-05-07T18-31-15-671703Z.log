y exporters that send traces and metrics to OTLP-compatible backends. This artifact packages the OTLP gRPC exporters used by Java applications to emit telemetry data to collectors and observability platforms.</details> |\n./metadata/com.google.api.grpc/proto-google-cloud-firestore-v1/index.json:5:    \"source-code-url\" : \"https://repo1.maven.org/maven2/com/google/api/grpc/proto-google-cloud-firestore-v1/$version$/proto-google-cloud-firestore-v1-$version$-sources.jar\",\n./metadata/com.google.api.grpc/proto-google-cloud-firestore-v1/index.json:7:    \"test-code-url\" : \"https://repo1.maven.org/maven2/com/google/api/grpc/proto-google-cloud-firestore-v1/$version$/proto-google-cloud-firestore-v1-$version$-tests.jar\",\n./metadata/com.google.api.grpc/proto-google-cloud-firestore-v1/index.json:8:    \"documentation-url\" : \"https://repo1.maven.org/maven2/com/google/api/grpc/proto-google-cloud-firestore-v1/$version$/proto-google-cloud-firestore-v1-$version$-javadoc.jar\",\n./metadata/com.google.api.grpc/proto-google-cloud-firestore-v1/index.json:9:    \"description\" : \"This artifact provides generated Java Protocol Buffer message classes, descriptors, and resource-name helpers for the Google Cloud Firestore v1 API. It supplies the data model used by Java Firestore clients and related gRPC libraries for documents, queries, writes, transactions, and listener messages.\",\n./metadata/com.google.api.grpc/grpc-google-common-protos/index.json:5:    \"source-code-url\" : \"https://repo1.maven.org/maven2/com/google/api/grpc/grpc-google-common-protos/$version$/grpc-google-common-protos-$version$-sources.jar\",\n./metadata/com.google.api.grpc/grpc-google-common-protos/index.json:7:    \"test-code-url\" : \"https://repo1.maven.org/maven2/com/google/api/grpc/grpc-google-common-protos/$version$/grpc-google-common-protos-$version$-tests.jar\",\n./metadata/com.google.api.grpc/grpc-google-common-protos/index.json:8:    \"documentation-url\" : \"https://repo1.maven.org/maven2/com/goo