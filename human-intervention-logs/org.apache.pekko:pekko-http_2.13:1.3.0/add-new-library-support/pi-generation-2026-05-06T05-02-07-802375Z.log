espondWithHeader(RawHeader(\"X-Service\", \"pekko-http\")) {\n                complete(StatusCodes.OK, s\"pong $name\")\n              }\n            }\n          }\n        }\n\n      val binding = Await.result(Http().newServerAt(\"127.0.0.1\", 0).bind(route), 10.seconds)\n      try {\n        val address = binding.localAddress\n        val response = Await.result(Http().singleRequest(HttpRequest(uri = s\"http://${address.getHostString}:${address.getPort}/ping?name=Apache\")), 10.seconds)\n        val responseEntity = Await.result(response.entity.toStrict(3.seconds), 5.seconds)\n\n        assertEquals(StatusCodes.OK, response.status)\n        assertEquals(Some(\"pekko-http\"), response.header[RawHeader].map(_.value))\n        assertEquals(\"pong Apache\", responseEntity.data.utf8String)\n      } finally {\n        Await.result(binding.unbind(), 10.seconds)\n        Await.result(Http().shutdownAllConnectionPools(), 10.seconds)\n      }\n    }\n  }\n\n  @Test\n  def streamingSupportSettingsAndServerSentEventsExposeExpectedPublicConfiguration(): Unit = {\n"}]}, "partialJson": "{\"path\":\"tests/src/org.apache.pekko/pekko-http_2.13/1.3.0/src/test/scala/org_apache_pekko/pekko_http_2_13/Pekko_http_2_13Test.scala\",\"edits\":[{\"oldText\":\"import org.apache.pekko.http.scaladsl.client.RequestBuilding._\\n\",\"newText\":\"import org.apache.pekko.http.scaladsl.Http\\nimport org.apache.pekko.http.scaladsl.client.RequestBuilding._\\n\"},{\"oldText\":\"  @Test\\n  def streamingSupportSettingsAndServerSentEventsExposeExpectedPublicConfiguration(): Unit = {\\n\",\"newText\":\"  @Test\\n  def httpServerBindingAndClientRequestsExchangeStrictResponses(): Unit = {\\n    withActorSystem(\\\"pekko-http-server-client\\\") { implicit system =>\\n      implicit val executionContext = system.dispatcher\\n\\n      val route: Route =\\n        path(\\\"ping\\\") {\\n          get {\\n            parameters(\\\"name\\\".?(\\\"anonymous\\\")) { name =>\\n              respondWithHeader(RawHea