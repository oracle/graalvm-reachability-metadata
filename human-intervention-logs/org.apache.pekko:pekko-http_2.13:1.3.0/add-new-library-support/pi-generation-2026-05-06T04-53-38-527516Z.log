  +    val request = HttpRequest(headers = List(Cookie(HttpCookiePair("theme", "dark"), HttpCookiePair("mode", "test"))))
  +    assertEquals(Seq("theme" -> "dark", "mode" -> "test"), request.cookies.map(pair => pair.name -> pair.value))
