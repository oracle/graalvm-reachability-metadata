  14:package org.apache.pekko.http.scaladsl.client
  15:
  16:import scala.concurrent.{ ExecutionContext, Future }
  17:import org.apache.pekko.event.{ Logging, LoggingAdapter }
  18:
  19:trait TransformerPipelineSupport {
  20:
  21:  def logValue[T](log: LoggingAdapter, level: Logging.LogLevel = Logging.DebugLevel): T => T =
  22:    logValue { value => log.log(level, value.toString) }
  23:
  24:  def logValue[T](logFun: T => Unit): T => T = { response =>
  25:    logFun(response)
  26:    response
  27:  }
  28:
  29:  implicit class WithTransformation[A](value: A) {
  30:    def ~>[B](f: A => B): B = f(value)
  31:  }
  32:
  33:  implicit class WithTransformerConcatenation[A, B](f: A => B) extends (A => B) {
  34:    def apply(input: A) = f(input)
  35:    def ~>[AA, BB, R](g: AA => BB)(implicit aux: TransformerAux[A, B, AA, BB, R]) =
  36:      new WithTransformerConcatenation[A, R](aux(f, g))
  37:  }
  38:}
  39:
  40:object TransformerPipelineSupport extends TransformerPipelineSupport
  41:
  42:trait TransformerAux[A, B, AA, BB, R] {
  43:  def apply(f: A => B, g: AA => BB): A => R
  44:}
  45:
  46:object TransformerAux {
  47:  implicit def aux1[A, B, C]: TransformerAux[A, B, B, C, C] = new TransformerAux[A, B, B, C, C] {
  48:    def apply(f: A => B, g: B => C): A => C = f.andThen(g)
  49:  }
  50:  implicit def aux2[A, B, C](implicit ec: ExecutionContext): TransformerAux[A, Future[B], B, C, Future[C]] =
  51:    new TransformerAux[A, Future[B], B, C, Future[C]] {
  52:      def apply(f: A => Future[B], g: B => C): A => Future[C] = f(_).map(g)
  53:    }
  54:  implicit def aux3[A, B, C](implicit ec: ExecutionContext): TransformerAux[A, Future[B], B, Future[C], Future[C]] =
  55:    new TransformerAux[A, Future[B], B, Future[C], Future[C]] {
  56:      def apply(f: A => Future[B], g: B => Future[C]): A => Future[C] = f(_).flatMap(g)
  57:    }
  58:}
