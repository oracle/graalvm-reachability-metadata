  +      assertEquals(StatusCodes.OK, getResponse.status)
  +      assertEquals(Some("7"), getResponse.header[RawHeader].map(_.value))
  +      assertEquals("item=7 verbose=true", strictUtf8(getResponse.entity))
  +
