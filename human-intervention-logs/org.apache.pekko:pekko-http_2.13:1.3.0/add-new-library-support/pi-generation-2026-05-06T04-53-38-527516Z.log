  +  private def withActorSystem[T](name: String)(body: ActorSystem => T): T = {
  +    val system = ActorSystem(name)
  +    try {
  +      body(system)
  +    } finally {
  +      Await.result(system.terminate(), 10.seconds)
  +    }
  +  }
