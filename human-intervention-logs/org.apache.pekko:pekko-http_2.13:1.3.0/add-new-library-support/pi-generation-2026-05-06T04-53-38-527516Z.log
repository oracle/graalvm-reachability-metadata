Aux[A, Future[B], B, C, Future[C]] =\n51:    new TransformerAux[A, Future[B], B, C, Future[C]] {\n52:      def apply(f: A => Future[B], g: B => C): A => Future[C] = f(_).map(g)\n53:    }\n54:  implicit def aux3[A, B, C](implicit ec: ExecutionContext): TransformerAux[A, Future[B], B, Future[C], Future[C]] =\n55:    new TransformerAux[A, Future[B], B, Future[C], Future[C]] {\n56:      def apply(f: A => Future[B], g: B => Future[C]): A => Future[C] = f(_).flatMap(g)\n57:    }\n58:}\n"}], "isError": false, "timestamp": 1778043146740}}
