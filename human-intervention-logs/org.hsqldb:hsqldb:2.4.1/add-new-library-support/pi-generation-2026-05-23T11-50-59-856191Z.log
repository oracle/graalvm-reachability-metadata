  package org_hsqldb.hsqldb;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.util.Locale;
  
  import org.hsqldb.lib.RefCapablePropertyResourceBundle;
  import org.junit.jupiter.api.Test;
  
  public class RefCapablePropertyResourceBundleAnonymous1Test {
      private static final String BUNDLE_NAME = "org_hsqldb.hsqldb.refcapable_with_reference";
      private static final String HSQLDB_TAR_BUNDLE_NAME = "org.hsqldb.lib.tar.rb";
  
      @Test
      void getStringLoadsEmptyPropertyValueFromReferencedTextResource() {
          ClassLoader classLoader = RefCapablePropertyResourceBundleAnonymous1Test.class.getClassLoader();
          RefCapablePropertyResourceBundle bundle =
                  RefCapablePropertyResourceBundle.getBundle(BUNDLE_NAME, Locale.ROOT, classLoader);
  
          String value = bundle.getString("help");
  
          assertThat(value).isEqualTo("loaded from referenced text resource");
      }
  
      @Test
      void getStringLoadsReferencedTextResourceFromHsqldbBundle() {
          ClassLoader classLoader = RefCapablePropertyResourceBundle.class.getClassLoader();
          RefCapablePropertyResourceBundle bundle =
                  RefCapablePropertyResourceBundle.getBundle(HSQLDB_TAR_BUNDLE_NAME, Locale.ROOT, classLoader);
  
          String value = bundle.getString("DbBackup.syntax");
  
          assertThat(value).contains("SYNTAX:").contains("java -cp path/to/hsqldb.jar");
      }
  }
