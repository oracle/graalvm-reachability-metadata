= new TimeoutRunner();\n        } catch (Throwable e) {\n            logger.close(Database.CLOSEMODE_IMMEDIATELY);\n            logger.releaseLock();\n            setState(DATABASE_SHUTDOWN);\n            clearStructures();\n            DatabaseManager.removeDatabase(this);\n\n            if (!(e instanceof HsqlException)) {\n                e = Error.error(ErrorCode.GENERAL_ERROR, e);\n            }\n\n            logger.logSevereEvent(\"could not reopen database\", e);\n\n            throw (HsqlException) e;\n        }\n\n[711 more lines in file. Use offset=260 to continue.]"}], "isError": false, "timestamp": 1779525641858}]}
