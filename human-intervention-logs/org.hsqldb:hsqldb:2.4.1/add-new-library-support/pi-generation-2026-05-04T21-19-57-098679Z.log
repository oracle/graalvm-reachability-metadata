  package org_hsqldb.hsqldb;
  
  import org.hsqldb.jdbc.JDBCSQLXML;
  import org.junit.jupiter.api.Test;
  import org.w3c.dom.Document;
  import org.xml.sax.ContentHandler;
  import org.xml.sax.helpers.AttributesImpl;
  
  import java.io.ByteArrayInputStream;
  import java.io.IOException;
  import java.io.OutputStream;
  import java.io.Reader;
  import java.io.StringReader;
  import java.nio.charset.StandardCharsets;
  import java.sql.SQLXML;
  
  import javax.xml.parsers.DocumentBuilderFactory;
  import javax.xml.stream.XMLEventReader;
  import javax.xml.stream.XMLStreamException;
  import javax.xml.stream.XMLStreamWriter;
  import javax.xml.transform.dom.DOMResult;
  import javax.xml.transform.dom.DOMSource;
  import javax.xml.transform.sax.SAXResult;
  import javax.xml.transform.sax.SAXSource;
  import javax.xml.transform.stax.StAXResult;
  import javax.xml.transform.stax.StAXSource;
  import javax.xml.transform.stream.StreamResult;
  import javax.xml.transform.stream.StreamSource;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class JDBCSQLXMLTest {
      private static final String XML = "<?xml version=\"1.0\"?><root><item>value</item></root>";
  
      @Test
      void createsStreamSourceWithReadableXml() throws Exception {
          CustomStreamSource source = readableSqlXml().getSource(CustomStreamSource.class);
  
          assertThat(source).isInstanceOf(CustomStreamSource.class);
          assertThat(read(source.getReader())).contains("<root>").contains("value");
      }
  
      @Test
      void createsDomSourceWithParsedDocument() throws Exception {
          CustomDOMSource source = readableSqlXml().getSource(CustomDOMSource.class);
  
          assertThat(source).isInstanceOf(CustomDOMSource.class);
          assertThat(source.getNode()).isInstanceOf(Document.class);
          Document document = (Document) source.getNode();
          assertThat(document.getDocumentElement().getNodeName()).isEqualTo("root");
          assertThat(document.getDocumentElement().getTextContent()).isEqualTo("value");
      }
  
      @Test
      void createsSaxSourceWithInputSource() throws Exception {
          CustomSAXSource source = readableSqlXml().getSource(CustomSAXSource.class);
  
          assertThat(source).isInstanceOf(CustomSAXSource.class);
          assertThat(source.getInputSource()).isNotNull();
          assertThat(read(source.getInputSource().getCharacterStream())).contains("<item>value</item>");
      }
  
      @Test
      void createsStaxSourceWithEventReader() throws Exception {
          CustomStAXSource source = readableSqlXml().getSource(CustomStAXSource.class);
          XMLEventReader eventReader = source.getXMLEventReader();
  
          assertThat(source).isInstanceOf(CustomStAXSource.class);
          assertThat(eventReader).isNotNull();
          assertThat(eventReader.peek().isStartDocument()).isTrue();
          eventReader.close();
      }
  
      @Test
      void createsStreamResultWithWritableOutputStream() throws Exception {
          SQLXML sqlXml = writableSqlXml();
          CustomStreamResult result = sqlXml.setResult(CustomStreamResult.class);
  
          assertThat(result).isInstanceOf(CustomStreamResult.class);
          OutputStream outputStream = result.getOutputStream();
          outputStream.write(XML.getBytes(StandardCharsets.UTF_8));
          outputStream.close();
  
          assertThat(sqlXml.getString()).contains("<root>").contains("value");
          sqlXml.free();
      }
  
      @Test
      void createsDomResultAndAcceptsAssignedDocument() throws Exception {
          SQLXML sqlXml = writableSqlXml();
          CustomDOMResult result = sqlXml.setResult(CustomDOMResult.class);
  
          assertThat(result).isInstanceOf(CustomDOMResult.class);
          Document document = parseDocument();
          result.setNode(document);
  
          assertThat(result.getNode()).isSameAs(document);
          assertThat(((Document) result.getNode()).getDocumentElement().getNodeName()).isEqualTo("root");
          sqlXml.free();
      }
  
      @Test
      void createsSaxResultWithContentHandler() throws Exception {
          SQLXML sqlXml = writableSqlXml();
          CustomSAXResult result = sqlXml.setResult(CustomSAXResult.class);
          ContentHandler handler = result.getHandler();
  
          assertThat(result).isInstanceOf(CustomSAXResult.class);
          handler.startDocument();
          handler.startElement("", "root", "root", new AttributesImpl());
          char[] value = "value".toCharArray();
          handler.characters(value, 0, value.length);
          handler.endElement("", "root", "root");
          handler.endDocument();
  
          assertThat(result.getHandler()).isSameAs(handler);
          sqlXml.free();
      }
  
      @Test
      void createsCustomStaxResultWithXmlStreamWriterConstructor() throws Exception {
          SQLXML sqlXml = writableSqlXml();
          CustomStAXResult result = sqlXml.setResult(CustomStAXResult.class);
          XMLStreamWriter writer = result.getXMLStreamWriter();
  
          writer.writeStartDocument();
          writer.writeStartElement("root");
          writer.writeCharacters("value");
          writer.writeEndElement();
          writer.writeEndDocument();
          writer.close();
  
          assertThat(result.getXMLStreamWriter()).isSameAs(writer);
          sqlXml.free();
      }
  
      private static JDBCSQLXML readableSqlXml() throws Exception {
          return new JDBCSQLXML(new StreamSource(new StringReader(XML)));
      }
  
      private static SQLXML writableSqlXml() {
          return new WritableJDBCSQLXML();
      }
  
      private static Document parseDocument() throws Exception {
          return DocumentBuilderFactory.newInstance()
                  .newDocumentBuilder()
                  .parse(new ByteArrayInputStream(XML.getBytes(StandardCharsets.UTF_8)));
      }
  
      private static String read(Reader reader) throws IOException {
          char[] buffer = new char[128];
          StringBuilder content = new StringBuilder();
          int length;
  
          while ((length = reader.read(buffer)) >= 0) {
              content.append(buffer, 0, length);
          }
  
          return content.toString();
      }
  
      public static final class WritableJDBCSQLXML extends JDBCSQLXML {
      }
  
      public static final class CustomStreamSource extends StreamSource {
      }
  
      public static final class CustomDOMSource extends DOMSource {
      }
  
      public static final class CustomSAXSource extends SAXSource {
      }
  
      public static final class CustomStAXSource extends StAXSource {
          public CustomStAXSource(XMLEventReader xmlEventReader) throws XMLStreamException {
              super(xmlEventReader);
          }
      }
  
      public static final class CustomStreamResult extends StreamResult {
      }
  
      public static final class CustomDOMResult extends DOMResult {
      }
  
      public static final class CustomSAXResult extends SAXResult {
      }
  
      public static final class CustomStAXResult extends StAXResult {
          public CustomStAXResult(XMLStreamWriter xmlStreamWriter) {
              super(xmlStreamWriter);
          }
      }
  }
