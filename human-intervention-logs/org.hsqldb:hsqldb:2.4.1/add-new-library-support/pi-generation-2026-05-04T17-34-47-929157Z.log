  package org_hsqldb.hsqldb;
  
  import static org.junit.jupiter.api.Assertions.assertEquals;
  import static org.junit.jupiter.api.Assertions.assertTrue;
  
  import java.nio.file.Files;
  import java.nio.file.Path;
  import java.sql.Connection;
  import java.sql.PreparedStatement;
  import java.sql.ResultSet;
  import java.sql.Statement;
  import java.util.Arrays;
  import java.util.Properties;
  
  import org.hsqldb.jdbc.JDBCDriver;
  import org.hsqldb.persist.HsqlDatabaseProperties;
  import org.junit.jupiter.api.Test;
  import org.junit.jupiter.api.io.TempDir;
  
  public class RAFileNIOTest {
      private static final int ROW_COUNT = 160;
      private static final int PAYLOAD_SIZE = 64 * 1024;
  
      @TempDir
      Path temporaryDirectory;
  
      @Test
      public void closesNioMappedCachedTableDataFile() throws Exception {
          Path databasePath = temporaryDirectory.resolve("nio-cached-data");
          byte[] payload = new byte[PAYLOAD_SIZE];
  
          Arrays.fill(payload, (byte) 42);
  
          try (Connection connection = openConnection(databasePath)) {
              try (Statement statement = connection.createStatement()) {
                  statement.execute("SET FILES NIO TRUE");
                  statement.execute("CREATE CACHED TABLE nio_values (id INTEGER PRIMARY KEY, payload VARBINARY(65536))");
              }
  
              insertRows(connection, payload);
  
              try (Statement statement = connection.createStatement();
                      ResultSet resultSet = statement.executeQuery(
                              "SELECT payload FROM nio_values WHERE id = " + ROW_COUNT)) {
                  assertTrue(resultSet.next());
                  assertEquals(PAYLOAD_SIZE, resultSet.getBytes(1).length);
              }
  
              try (Statement statement = connection.createStatement()) {
                  statement.execute("SHUTDOWN");
              }
          }
  
          assertTrue(Files.size(databasePath.resolveSibling(databasePath.getFileName().toString() + ".data"))
                  > 8L * 1024 * 1024);
      }
  
      private Connection openConnection(Path databasePath) throws Exception {
          Properties properties = new Properties();
  
          properties.setProperty("user", "SA");
          properties.setProperty("password", "");
          properties.setProperty(HsqlDatabaseProperties.url_shutdown, "true");
  
          String url = "jdbc:hsqldb:file:" + databasePath + ";"
                  + HsqlDatabaseProperties.hsqldb_nio_data_file + "=true";
  
          return new JDBCDriver().connect(url, properties);
      }
  
      private void insertRows(Connection connection, byte[] payload) throws Exception {
          try (PreparedStatement statement = connection.prepareStatement("INSERT INTO nio_values VALUES (?, ?)")) {
              for (int row = 1; row <= ROW_COUNT; row++) {
                  statement.setInt(1, row);
                  statement.setBytes(2, payload);
                  statement.executeUpdate();
              }
          }
      }
  }
