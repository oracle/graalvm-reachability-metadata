      void setUpIndexesAndTypes() {
  
          triggerType = 0;
  
          switch (operationType) {
  
              case StatementTypes.INSERT :
                  triggerType = Trigger.INSERT_AFTER;
                  break;
  
              case StatementTypes.DELETE_WHERE :
                  triggerType = Trigger.DELETE_AFTER;
