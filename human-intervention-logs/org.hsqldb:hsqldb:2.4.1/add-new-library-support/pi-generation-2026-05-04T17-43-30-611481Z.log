  package org_hsqldb.hsqldb;
  
  import static org.junit.jupiter.api.Assertions.assertArrayEquals;
  import static org.junit.jupiter.api.Assertions.assertEquals;
  import static org.junit.jupiter.api.Assertions.assertNotNull;
  
  import java.sql.Connection;
  import java.sql.Statement;
  import java.util.Properties;
  import java.util.concurrent.atomic.AtomicInteger;
  import java.util.concurrent.atomic.AtomicReference;
  
  import org.hsqldb.Trigger;
  import org.hsqldb.jdbc.JDBCDriver;
  import org.junit.jupiter.api.Test;
  
  public class TriggerDefTest {
      private static final AtomicInteger INSTANCES = new AtomicInteger();
      private static final AtomicInteger FIRES = new AtomicInteger();
      private static final AtomicReference<Object[]> NEW_ROW = new AtomicReference<>();
      private static final String TRIGGER_CLASS_NAME = RecordingTrigger.class.getName();
  
      @Test
      public void createsAndInvokesTriggerLoadedViaFallbackClassLookup() throws Exception {
          ClassLoader originalClassLoader = Thread.currentThread().getContextClassLoader();
          ClassLoader rejectingClassLoader = new RejectingClassLoader(TRIGGER_CLASS_NAME);
  
          INSTANCES.set(0);
          FIRES.set(0);
          NEW_ROW.set(null);
  
          try (Connection connection = openConnection("triggerdef" + System.nanoTime());
                  Statement statement = connection.createStatement()) {
              statement.execute("CREATE TABLE trigger_target (id INTEGER, name VARCHAR(32))");
              Thread.currentThread().setContextClassLoader(rejectingClassLoader);
  
              try {
                  statement.execute("""
                          CREATE TRIGGER trigger_record
                          AFTER INSERT ON trigger_target
                          FOR EACH ROW
                          CALL "%s"
                          """.formatted(TRIGGER_CLASS_NAME));
              } finally {
                  Thread.currentThread().setContextClassLoader(originalClassLoader);
              }
  
              assertEquals(1, INSTANCES.get());
  
              statement.execute("INSERT INTO trigger_target VALUES (7, 'seven')");
  
              assertEquals(1, FIRES.get());
              assertArrayEquals(new Object[] { Integer.valueOf(7), "seven" }, NEW_ROW.get());
          } finally {
              Thread.currentThread().setContextClassLoader(originalClassLoader);
          }
      }
  
      public static class RecordingTrigger implements Trigger {
          public RecordingTrigger() {
              INSTANCES.incrementAndGet();
          }
  
          @Override
          public void fire(int type, String triggerName, String tableName,
                           Object[] oldRow, Object[] newRow) {
              FIRES.incrementAndGet();
              NEW_ROW.set(newRow.clone());
          }
      }
  
      private static final class RejectingClassLoader extends ClassLoader {
          private final String rejectedClassName;
  
          private RejectingClassLoader(String rejectedClassName) {
              super(null);
              this.rejectedClassName = rejectedClassName;
          }
  
          @Override
          protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {
              if (rejectedClassName.equals(name)) {
                  throw new ClassNotFoundException(name);
              }
  
              return super.loadClass(name, resolve);
          }
      }
  
      private static Connection openConnection(String databaseName) throws Exception {
          Properties properties = new Properties();
  
          properties.setProperty("user", "SA");
          properties.setProperty("password", "");
  
          Connection connection = new JDBCDriver().connect(
                  "jdbc:hsqldb:mem:" + databaseName, properties);
  
          assertNotNull(connection);
  
          return connection;
      }
