  package org_hsqldb.hsqldb;
  
  import static org.junit.jupiter.api.Assertions.assertEquals;
  import static org.junit.jupiter.api.Assertions.assertNotNull;
  
  import java.sql.Array;
  import java.sql.CallableStatement;
  import java.sql.Connection;
  import java.sql.ResultSet;
  import java.sql.Statement;
  import java.sql.Types;
  import java.util.Properties;
  import java.util.concurrent.atomic.AtomicInteger;
  
  import org.hsqldb.jdbc.JDBCDriver;
  import org.junit.jupiter.api.Test;
  
  public class RoutineTest {
      private static final AtomicInteger AUTHENTICATION_CALLS = new AtomicInteger();
      private static final String ROUTINE_CLASS_NAME = RoutineTest.class.getName();
  
      @Test
      public void invokesJavaFunctionResolvedViaRoutineGetMethodsFallback() throws Exception {
          ClassLoader originalClassLoader = Thread.currentThread().getContextClassLoader();
  
          try (Connection connection = openConnection("routinefunction" + System.nanoTime(), "SA", "");
                  Statement statement = connection.createStatement()) {
              Thread.currentThread().setContextClassLoader(null);
  
              try {
                  statement.execute("""
                          CREATE FUNCTION ADD_ONE(P_VALUE INTEGER)
                          RETURNS INTEGER
                          LANGUAGE JAVA DETERMINISTIC NO SQL
                          EXTERNAL NAME 'CLASSPATH:%s.addOne'
                          """.formatted(ROUTINE_CLASS_NAME));
              } finally {
                  Thread.currentThread().setContextClassLoader(originalClassLoader);
              }
  
              try (ResultSet resultSet = statement.executeQuery("CALL ADD_ONE(41)")) {
                  resultSet.next();
  
                  assertEquals(42, resultSet.getInt(1));
              }
          }
      }
  
      @Test
      public void invokesJavaProcedureWithOutParameterArrayConversion() throws Exception {
          try (Connection connection = openConnection("routineprocedure" + System.nanoTime(), "SA", "");
                  Statement statement = connection.createStatement()) {
              statement.execute("""
                      CREATE PROCEDURE INCREMENT_VALUE(IN P_VALUE INTEGER, OUT P_RESULT INTEGER)
                      LANGUAGE JAVA DETERMINISTIC NO SQL
                      EXTERNAL NAME 'CLASSPATH:%s.incrementOutParameter'
                      """.formatted(ROUTINE_CLASS_NAME));
  
              try (CallableStatement call = connection.prepareCall("CALL INCREMENT_VALUE(?, ?)")) {
                  call.setInt(1, 6);
                  call.registerOutParameter(2, Types.INTEGER);
                  call.execute();
  
                  assertEquals(7, call.getInt(2));
              }
          }
      }
  
      @Test
      public void invokesDatabaseAuthenticationRoutineDirectly() throws Exception {
          String databaseName = "routineauth" + System.nanoTime();
  
          AUTHENTICATION_CALLS.set(0);
  
          try (Connection adminConnection = openConnection(databaseName, "SA", "");
                  Statement statement = adminConnection.createStatement()) {
              statement.execute("""
                      SET DATABASE AUTHENTICATION FUNCTION
                      EXTERNAL NAME 'CLASSPATH:%s.authenticate'
                      """.formatted(ROUTINE_CLASS_NAME));
  
              try (Connection externalConnection = openConnection(databaseName, "EXTERNAL_USER", "secret")) {
                  assertNotNull(externalConnection);
              }
          }
  
          assertEquals(1, AUTHENTICATION_CALLS.get());
      }
  
      public static Integer addOne(Integer value) {
          return Integer.valueOf(value.intValue() + 1);
      }
  
      public static void incrementOutParameter(Integer value, Integer[] result) {
          result[0] = Integer.valueOf(value.intValue() + 1);
      }
  
      public static Array authenticate(String databaseName, String userName, String password) {
          AUTHENTICATION_CALLS.incrementAndGet();
  
          return null;
      }
  
      private static Connection openConnection(String databaseName, String user, String password) throws Exception {
          Properties properties = new Properties();
  
          properties.setProperty("user", user);
          properties.setProperty("password", password);
  
          Connection connection = new JDBCDriver().connect("jdbc:hsqldb:mem:" + databaseName, properties);
  
          assertNotNull(connection);
  
          return connection;
      }
  }
