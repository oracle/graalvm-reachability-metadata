[tool-call] delta {"path":"tests/src/org.hsqldb/hsqldb/2.4.1/src/test/java/org_hsqldb/hsqldb/RoutineTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_hsqldb.hsqldb;\n\nimport static org.junit.jupiter.api.Assertions.assertEquals;\nimport static org.junit.jupiter.api.Assertions.assertNotNull;\n\nimport java.net.URL;\nimport java.net.URLClassLoader;\nimport java.sql.Array;\nimport java.sql.CallableStatement;\nimport java.sql.Connection;\nimport java.sql.ResultSet;\nimport java.sql.Statement;\nimport java.sql.Types;\nimport java.util.Properties;\nimport java.util.concurrent.atomic.AtomicInteger;\n\nimport org.hsqldb.jdbc.JDBCDriver;\nimport org.junit.jupiter.api.Test;\n\npublic class RoutineTest {\n    private static final AtomicInteger AUTHENTICATION_CALLS = new AtomicInteger();\n    private static final String ROUTINE_CLASS_NAME = RoutineTest.class.getName();\n\n    @Test\n    public void invokesJavaFunctionResolvedViaRoutineGetMethodsFallback() throws Exception {\n        ClassLoader originalClassLoader = Thread.currentThread().getContextClassLoader();\n        URLClassLoader emptyClassLoader = new URLClassLoader(new URL[0], null);\n\n        try (Connection connection = openConnection(\"routinefunction\" + System.nanoTime(), \"SA\", \"\")) {\n            Thread.currentThread().setContextClassLoader(emptyClassLoader);\n\n            try (Statement statement = connection.createStatement()) {\n                statement.execute(\"\"\"\n                        CREATE FUNCTION ADD_ONE(P_VALUE INTEGER)\n                        RETURNS INTEGER\n                        LANGUAGE JAVA DETERMINISTIC NO SQL\n                        EXTERNAL NAME 'CLASSPATH:%s.addOne'\n                        \"\"\".formatted(ROUTINE_CLASS_NAME));\n\n                try (ResultSet resultSet = statement.executeQuery(\"CALL ADD_ONE(41)\")) {\n                    resultSet.next();\n\n                    assertEquals(42, resultSet.getInt(1));\n                }\n            } finally {\n                Thread.currentThread().setContextClassLoader(originalClassLoader);\n                emptyClassLoader.close();\n            }\n        }\n    }\n\n    @Test\n    public void invokesJavaProcedureWithOutParameterArrayConversion() throws Exception {\n        try (Connection connection = openConnection(\"routineprocedure\" + System.nanoTime(), \"SA\", \"\");\n                Statement statement = connection.createStatement()) {\n            statement.execute(\"\"\"\n                    CREATE PROCEDURE INCREMENT_VALUE(IN P_VALUE INTEGER, OUT P_RESULT INTEGER)\n                    LANGUAGE JAVA DETERMINISTIC NO SQL\n                    EXTERNAL NAME 'CLASSPATH:%s.incrementOutParameter'\n                    \"\"\".formatted(ROUTINE_CLASS_NAME));\n\n            try (CallableStatement call = connection.prepareCall(\"CALL INCREMENT_VALUE(?, ?)\")) {\n                call.setInt(1, 6);\n                call.registerOutParameter(2, Types.INTEGER);\n                call.execute();\n\n                assertEquals(7, call.getInt(2));\n            }\n        }\n    }\n\n    @Test\n    public void invokesDatabaseAuthenticationRoutineDirectly() throws Exception {\n        String databaseName = \"routineauth\" + System.nanoTime();\n\n        AUTHENTICATION_CALLS.set(0);\n\n        try (Connection adminConnection = openConnection(databaseName, \"SA\", \"\");\n                Statement statement = adminConnection.createStatement()) {\n            statement.execute(\"\"\"\n                    SET DATABASE AUTHENTICATION FUNCTION\n                    EXTERNAL NAME 'CLASSPATH:%s.authenticate'\n                    \"\"\".formatted(ROUTINE_CLASS_NAME));\n\n            try (Connection externalConnection = openConnection(databaseName, \"EXTERNAL_USER\", \"secret\")) {\n                assertNotNull(externalConnection);\n            }\n        }\n\n        assertEquals(1, AUTHENTICATION_CALLS.get());\n    }\n\n    public static Integer addOne(Integer value) {\n        return Integer.valueOf(value.intValue() + 1);\n    }\n\n    public static void incrementOutParameter(Integer value, Integer[] result) {\n        result[0] = Integer.valueOf(value.intValue() + 1);\n    }\n\n    public static Array authenticate(String databaseName, String userName, String password) {\n        AUTHENTICATION_CALLS.incrementAndGet();\n\n        return null;\n    }\n\n    private static Connection openConnection(String databaseName, String user, String password) throws Exception {\n        Properties properties = new Properties();\n\n        properties.setProperty(\"user\", user);\n        properties.setProperty(\"password\", password);\n\n        Connection connection = new JDBCDriver().connect(\"jdbc:hsqldb:mem:\" + databaseName, properties);\n\n        assertNotNull(connection);\n\n        return connection;\n    }\n}\n"}
