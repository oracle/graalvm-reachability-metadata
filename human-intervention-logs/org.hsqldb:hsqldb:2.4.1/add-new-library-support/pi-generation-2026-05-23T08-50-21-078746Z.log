seSession(connection).getDatabase();\n                byte[] expectedBlock = \"0123456789abcdef\".getBytes(StandardCharsets.US_ASCII);\n                LobStoreRAFile lobStore = new LobStoreRAFile(database, expectedBlock.length);\n\n                InMemoryRandomAccessStorage.reset();\n                classHidingLoader.reset();\n\n                lobStore.setBlockBytes(expectedBlock, 0, 1);\n\n                assertThat(lobStore.getBlockBytes(0, 1)).isEqualTo(expectedBlock);\n                lobStore.close();\n\n                statement.execute(\"CREATE CACHED TABLE sample (id INTEGER PRIMARY KEY, name VARCHAR(32))\");\n                statement.executeUpdate(\"INSERT INTO sample VALUES (1, 'alpha')\");\n\n                try (ResultSet resultSet = statement.executeQuery(\"SELECT name FROM sample WHERE id = 1\")) {\n                    assertThat(resultSet.next()).isTrue();\n                    assertThat(resultSet.getString(1)).isEqualTo(\"alpha\");\n                }\n\n                statement.execute(\"SHUTDOWN\");\n            }\n"},{"oldText":"        assertThat(classHidingLoader.hiddenLoadAttempts()).isGreaterThanOrEqualTo(2);\n        assertThat(InMemoryRandomAccessStorage.instances()).isGreaterThanOrEqualTo(1);\n        assertThat(InMemoryRandomAccessStorage.lastName()).endsWith(\".data\");\n","newText":"        assertThat(classHidingLoader.hiddenLoadAttempts()).isGreaterThanOrEqualTo(1);\n        assertThat(InMemoryRandomAccessStorage.instances()).isGreaterThanOrEqualTo(1);\n        assertThat(InMemoryRandomAccessStorage.lastName()).endsWith(\".lobs\");\n"},{"oldText":"        int hiddenLoadAttempts() {\n            return hiddenLoadAttempts;\n        }\n\n        @Override\n","newText":"        int hiddenLoadAttempts() {\n            return hiddenLoadAttempts;\n        }\n\n        void reset() {\n            hiddenLoadAttempts = 0;\n        }\n\n        @Override\n"}]}
