       7	package org_hsqldb.hsqldb;
       8	
       9	import static org.assertj.core.api.Assertions.assertThat;
      10	
      11	import java.sql.Connection;
      12	import java.sql.DatabaseMetaData;
      13	import java.sql.ResultSet;
      14	import java.sql.Statement;
      15	import java.util.ArrayList;
      16	import java.util.List;
      17	
      18	import org.hsqldb.jdbc.JDBCDataSource;
      19	import org.junit.jupiter.api.Test;
      20	
      21	public class DatabaseInformationTest {
      22	
      23	    @Test
      24	    void openingDatabaseInstantiatesDatabaseInformationAndExposesSystemMetadata() throws Exception {
      25	        JDBCDataSource dataSource = new JDBCDataSource();
      26	
      27	        dataSource.setUrl("jdbc:hsqldb:mem:database_info_" + Long.toUnsignedString(System.nanoTime())
      28	                + ";shutdown=true");
      29	        dataSource.setUser("SA");
      30	        dataSource.setPassword("");
      31	
      32	        try (Connection connection = dataSource.getConnection(); Statement statement = connection.createStatement()) {
      33	            statement.execute("CREATE TABLE TEST_TABLE (ID INTEGER PRIMARY KEY, NAME VARCHAR(32))");
      34	
      35	            DatabaseMetaData metaData = connection.getMetaData();
      36	            List<String> tableNames = tableNames(metaData);
      37	
      38	            assertThat(tableNames).contains("TEST_TABLE");
      39	
      40	            try (ResultSet resultSet = statement.executeQuery("""
      41	                    SELECT TABLE_NAME
      42	                    FROM INFORMATION_SCHEMA.SYSTEM_TABLES
      43	                    WHERE TABLE_SCHEM = 'PUBLIC'
      44	                    """)) {
      45	                List<String> informationSchemaNames = new ArrayList<>();
      46	
      47	                while (resultSet.next()) {
      48	                    informationSchemaNames.add(resultSet.getString("TABLE_NAME"));
      49	                }
      50	
      51	                assertThat(informationSchemaNames).contains("TEST_TABLE");
      52	            }
      53	
      54	            statement.execute("SHUTDOWN");
      55	        }
      56	    }
      57	
      58	    private static List<String> tableNames(DatabaseMetaData metaData) throws Exception {
      59	        List<String> tableNames = new ArrayList<>();
      60	
      61	        try (ResultSet resultSet = metaData.getTables(null, "PUBLIC", "%", new String[]{ "TABLE" })) {
      62	            while (resultSet.next()) {
      63	                tableNames.add(resultSet.getString("TABLE_NAME"));
      64	            }
      65	        }
      66	
      67	        return tableNames;
      68	    }
      69	}
