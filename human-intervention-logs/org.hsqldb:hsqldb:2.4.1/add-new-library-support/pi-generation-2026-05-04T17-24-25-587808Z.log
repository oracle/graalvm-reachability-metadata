ption(\"read beyond end of file\");\n        }\n\n        seekPosition = position;\n    }\n\n    public long getFilePointer() throws IOException {\n        return seekPosition;\n    }\n\n    private void readIntoBuffer() throws IOException {\n\n        long filePos    = seekPosition & bufferMask;\n        long readLength = fileLength - filePos;\n\n        if (readLength > buffer.length) {\n            readLength = buffer.length;\n        }\n\n        if (readLength < 0) {\n            throw new IOException(\"read beyond end of file\");\n        }\n\n        try {\n            file.seek(filePos);\n            file.readFully(buffer, 0, (int) readLength);\n\n            bufferOffset = filePos;\n        } catch (IOException e) {\n            resetPointer();\n            logger.logWarningEvent(\"Read Error \" + filePos + \" \" + readLength,\n                                   e);\n\n            throw e;\n        }\n    }\n\n    public int read() throws IOException {\n\n        try {\n            if (seekPosition >= fileLength) {\n                return -1;\n            }\n\n            if (seekPosition < bufferOffset\n                    || seekPosition >= bufferOffset + buffer.length) {\n\n[244 more lines in file. Use offset=241 to continue.]"}], "isError": false, "timestamp": 1777915278674}}
