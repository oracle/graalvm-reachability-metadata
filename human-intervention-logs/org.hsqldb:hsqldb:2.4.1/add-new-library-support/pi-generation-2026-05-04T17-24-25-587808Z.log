  package org_hsqldb.hsqldb;
  
  import static org.junit.jupiter.api.Assertions.assertEquals;
  import static org.junit.jupiter.api.Assertions.assertTrue;
  
  import java.io.EOFException;
  import java.io.IOException;
  import java.io.InputStream;
  import java.io.OutputStream;
  import java.nio.file.Path;
  import java.sql.Connection;
  import java.sql.ResultSet;
  import java.sql.Statement;
  import java.util.Arrays;
  import java.util.Map;
  import java.util.Properties;
  import java.util.concurrent.ConcurrentHashMap;
  import java.util.concurrent.atomic.AtomicInteger;
  
  import org.hsqldb.jdbc.JDBCDriver;
  import org.hsqldb.lib.FileAccess;
  import org.hsqldb.lib.FileUtil;
  import org.hsqldb.persist.HsqlDatabaseProperties;
  import org.hsqldb.persist.RandomAccessInterface;
  import org.junit.jupiter.api.Test;
  import org.junit.jupiter.api.io.TempDir;
  
  public class RAFileTest {
      private static final AtomicInteger RANDOM_ACCESS_CONSTRUCTIONS = new AtomicInteger();
      private static final Map<String, InMemoryFile> FILES = new ConcurrentHashMap<>();
  
      @TempDir
      Path temporaryDirectory;
  
      @Test
      public void opensStoredDataFileThroughClassForNameFallback() throws Exception {
          ClassLoader originalClassLoader = Thread.currentThread().getContextClassLoader();
          ClassLoader fallbackClassLoader = new StorageFallbackClassLoader(
                  applicationClassLoader(), InMemoryRandomAccess.class.getName());
  
          resetStorageState();
          Thread.currentThread().setContextClassLoader(fallbackClassLoader);
  
          try (Connection connection = openConnection("stored-ra-file")) {
              try (Statement statement = connection.createStatement()) {
                  statement.execute("CREATE CACHED TABLE cached_values (id INTEGER PRIMARY KEY, name VARCHAR(32))");
                  statement.execute("INSERT INTO cached_values VALUES (1, 'alpha')");
  
                  try (ResultSet resultSet = statement.executeQuery("SELECT name FROM cached_values WHERE id = 1")) {
                      assertTrue(resultSet.next());
                      assertEquals("alpha", resultSet.getString(1));
                  }
  
              }
          } finally {
              Thread.currentThread().setContextClassLoader(originalClassLoader);
          }
  
          assertTrue(RANDOM_ACCESS_CONSTRUCTIONS.get() > 0);
          assertTrue(FILES.keySet().stream().anyMatch(name -> name.endsWith(".data")));
      }
  
      private void resetStorageState() {
          RANDOM_ACCESS_CONSTRUCTIONS.set(0);
          FILES.clear();
      }
  
      private Connection openConnection(String databaseName) throws Exception {
          Properties properties = new Properties();
  
          properties.setProperty("user", "SA");
          properties.setProperty("password", "");
          properties.setProperty(HsqlDatabaseProperties.url_fileaccess_class_name, DelegatingFileAccess.class.getName());
          properties.setProperty(HsqlDatabaseProperties.url_storage_class_name, InMemoryRandomAccess.class.getName());
          properties.setProperty(HsqlDatabaseProperties.url_storage_key, databaseName);
          properties.setProperty(HsqlDatabaseProperties.url_shutdown, "true");
  
          Path databasePath = temporaryDirectory.resolve(databaseName);
  
          return new JDBCDriver().connect("jdbc:hsqldb:file:" + databasePath, properties);
      }
  
      private static ClassLoader applicationClassLoader() {
          ClassLoader classLoader = RAFileTest.class.getClassLoader();
  
          return classLoader == null ? ClassLoader.getSystemClassLoader() : classLoader;
      }
  
      public static final class DelegatingFileAccess implements FileAccess {
          private static final FileAccess DELEGATE = FileUtil.getFileAccess(false);
  
          public DelegatingFileAccess(Object storageKey) {
              assertEquals("stored-ra-file", storageKey);
          }
  
          @Override
          public InputStream openInputStreamElement(String streamName) throws IOException {
              return DELEGATE.openInputStreamElement(streamName);
          }
  
          @Override
          public OutputStream openOutputStreamElement(String streamName, boolean append) throws IOException {
              return DELEGATE.openOutputStreamElement(streamName, append);
          }
  
          @Override
          public boolean isStreamElement(String elementName) {
              return DELEGATE.isStreamElement(elementName);
          }
  
          @Override
          public void createParentDirs(String filename) {
              DELEGATE.createParentDirs(filename);
          }
  
          @Override
          public void removeElement(String filename) {
              DELEGATE.removeElement(filename);
          }
  
          @Override
          public void renameElement(String oldName, String newName, boolean copyIfFailed) {
              DELEGATE.renameElement(oldName, newName, copyIfFailed);
          }
  
          @Override
          public FileSync getFileSync(OutputStream os) throws IOException {
              return DELEGATE.getFileSync(os);
          }
      }
  
      public static final class InMemoryRandomAccess implements RandomAccessInterface {
          private final InMemoryFile file;
          private final boolean readOnly;
          private long position;
  
          public InMemoryRandomAccess(String name, Boolean readOnly, Object storageKey) {
              assertEquals("stored-ra-file", storageKey);
              RANDOM_ACCESS_CONSTRUCTIONS.incrementAndGet();
              this.file = FILES.computeIfAbsent(name, ignored -> new InMemoryFile());
              this.readOnly = readOnly.booleanValue();
          }
  
          @Override
          public long length() throws IOException {
              return file.length();
          }
  
          @Override
          public void seek(long position) throws IOException {
              this.position = position;
          }
  
          @Override
          public long getFilePointer() throws IOException {
              return position;
          }
  
          @Override
          public int read() throws IOException {
              byte[] buffer = new byte[1];
              int count = file.read(position, buffer, 0, 1, false);
  
              if (count < 0) {
                  return -1;
              }
  
              position++;
  
              return buffer[0] & 0xff;
          }
  
          @Override
          public void read(byte[] b, int offset, int length) throws IOException {
              file.read(position, b, offset, length, true);
              position += length;
          }
  
          @Override
          public void write(byte[] b, int offset, int length) throws IOException {
              ensureWritable();
              file.write(position, b, offset, length);
              position += length;
          }
  
          @Override
          public int readInt() throws IOException {
              byte[] buffer = new byte[Integer.BYTES];
  
              read(buffer, 0, buffer.length);
  
              return ((buffer[0] & 0xff) << 24)
                      | ((buffer[1] & 0xff) << 16)
                      | ((buffer[2] & 0xff) << 8)
                      | (buffer[3] & 0xff);
          }
  
          @Override
          public void writeInt(int value) throws IOException {
              write(new byte[] {
                      (byte) (value >>> 24),
                      (byte) (value >>> 16),
                      (byte) (value >>> 8),
                      (byte) value
              }, 0, Integer.BYTES);
          }
  
          @Override
          public long readLong() throws IOException {
              long high = readInt() & 0xffffffffL;
              long low = readInt() & 0xffffffffL;
  
              return (high << 32) | low;
          }
  
          @Override
          public void writeLong(long value) throws IOException {
              writeInt((int) (value >>> 32));
              writeInt((int) value);
          }
  
          @Override
          public void close() throws IOException {
              // Data is retained in the in-memory file map for subsequent handles to the same database path.
          }
  
          @Override
          public boolean isReadOnly() {
              return readOnly;
          }
  
          @Override
          public void synch() {
              // In-memory writes are immediately visible to all handles.
          }
  
          @Override
          public boolean ensureLength(long newLength) {
              file.ensureLength(newLength);
  
              return true;
          }
  
          @Override
          public boolean setLength(long newLength) {
              file.setLength(newLength);
              position = 0;
  
              return true;
          }
  
          private void ensureWritable() throws IOException {
              if (readOnly) {
                  throw new IOException("read-only random access file");
              }
          }
      }
  
      private static final class InMemoryFile {
          private byte[] data = new byte[0];
          private long length;
  
          synchronized long length() {
              return length;
          }
  
          synchronized int read(long position, byte[] target, int offset, int requestedLength, boolean requireFull)
                  throws IOException {
              if (position >= length) {
                  if (requireFull && requestedLength > 0) {
                      throw new EOFException();
                  }
  
                  return -1;
              }
  
              int available = (int) Math.min(requestedLength, length - position);
  
              if (requireFull && available < requestedLength) {
                  throw new EOFException();
              }
  
              System.arraycopy(data, (int) position, target, offset, available);
  
              return available;
          }
  
          synchronized void write(long position, byte[] source, int offset, int sourceLength) {
              ensureLength(position + sourceLength);
              System.arraycopy(source, offset, data, (int) position, sourceLength);
          }
  
          synchronized void ensureLength(long newLength) {
              if (newLength > data.length) {
                  int newCapacity = Math.max((int) newLength, Math.max(1024, data.length * 2));
  
                  data = Arrays.copyOf(data, newCapacity);
              }
  
              if (newLength > length) {
                  length = newLength;
              }
          }
  
          synchronized void setLength(long newLength) {
              ensureLength(newLength);
              length = newLength;
          }
      }
  
      private static final class StorageFallbackClassLoader extends ClassLoader {
          private final String unavailableClassName;
  
          StorageFallbackClassLoader(ClassLoader parent, String unavailableClassName) {
              super(parent);
              this.unavailableClassName = unavailableClassName;
          }
  
          @Override
          public Class<?> loadClass(String name) throws ClassNotFoundException {
              if (unavailableClassName.equals(name)) {
                  throw new ClassNotFoundException(name);
              }
  
              return super.loadClass(name);
          }
      }
  }
