  package org_hsqldb.hsqldb;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.nio.file.Path;
  import java.sql.Connection;
  import java.sql.ResultSet;
  import java.sql.Statement;
  
  import org.hsqldb.Database;
  import org.hsqldb.Session;
  import org.hsqldb.jdbc.JDBCConnection;
  import org.hsqldb.jdbc.JDBCDataSource;
  import org.hsqldb.lib.DoubleIntIndex;
  import org.hsqldb.persist.BlockObjectStore;
  import org.hsqldb.persist.CachedObject;
  import org.hsqldb.persist.DataFileCache;
  import org.hsqldb.persist.IntArrayCachedObject;
  import org.hsqldb.persist.TableSpaceManager;
  import org.hsqldb.rowio.RowInputBinary;
  import org.junit.jupiter.api.Test;
  import org.junit.jupiter.api.io.TempDir;
  
  public class BlockObjectStoreTest {
  
      @TempDir
      Path temporaryDirectory;
  
      @Test
      void readsBlockObjectThroughConfiguredCachedObjectConstructor() throws Exception {
          String databasePath = temporaryDirectory.resolve("block_object_store_direct_db").toString();
          String url = "jdbc:hsqldb:file:" + databasePath
                  + ";hsqldb.lock_file=false";
  
          try (Connection connection = openConnection(url); Statement statement = connection.createStatement()) {
              statement.execute("""
                      CREATE CACHED TABLE cache_initialiser (
                          id INTEGER PRIMARY KEY,
                          label_text VARCHAR(64)
                      )
                      """);
              statement.executeUpdate("INSERT INTO cache_initialiser VALUES (1, 'alpha')");
  
              Database database = databaseSession(connection).getDatabase();
              DataFileCache cache = database.logger.getCache();
              BlockObjectStore store = new BlockObjectStore(
                      cache,
                      new NoOpTableSpaceManager(),
                      IntArrayCachedObject.class,
                      IntArrayCachedObject.fileSizeFactor * 4,
                      4);
              RowInputBinary input = new RowInputBinary(new byte[IntArrayCachedObject.fileSizeFactor * 4]);
  
              input.resetBlock(256, IntArrayCachedObject.fileSizeFactor * 4);
  
              CachedObject object = store.get(input);
  
              assertThat(object).isInstanceOf(IntArrayCachedObject.class);
              assertThat(((IntArrayCachedObject) object).getDefaultCapacity()).isEqualTo(4);
              assertThat(object.getPos()).isEqualTo(256);
  
              statement.execute("SHUTDOWN");
          }
      }
  
      @Test
      void reopensFileDatabaseUsingBlockBasedDataSpaceManager() throws Exception {
          String databasePath = temporaryDirectory.resolve("block_object_store_db").toString();
          String url = "jdbc:hsqldb:file:" + databasePath
                  + ";hsqldb.files_space=1"
                  + ";hsqldb.lock_file=false";
  
          try (Connection connection = openConnection(url); Statement statement = connection.createStatement()) {
              statement.execute("""
                      CREATE CACHED TABLE block_store_items (
                          id INTEGER PRIMARY KEY,
                          label_text VARCHAR(64)
                      )
                      """);
              statement.executeUpdate("INSERT INTO block_store_items VALUES (1, 'alpha')");
              statement.executeUpdate("INSERT INTO block_store_items VALUES (2, 'beta')");
              statement.execute("CHECKPOINT");
              statement.execute("SHUTDOWN");
          }
  
          try (Connection connection = openConnection(url); Statement statement = connection.createStatement()) {
              try (ResultSet resultSet = statement.executeQuery("SELECT COUNT(*) FROM block_store_items")) {
                  assertThat(resultSet.next()).isTrue();
                  assertThat(resultSet.getInt(1)).isEqualTo(2);
              }
  
              statement.execute("SHUTDOWN");
          }
      }
  
      private static Session databaseSession(Connection connection) throws Exception {
          JDBCConnection hsqldbConnection = connection.unwrap(JDBCConnection.class);
  
          return (Session) hsqldbConnection.getSession();
      }
  
