edObject.fileSizeFactor * 4,\n                    4);\n            RowInputBinary input = new RowInputBinary(new byte[IntArrayCachedObject.fileSizeFactor * 4]);\n\n            input.resetBlock(256, IntArrayCachedObject.fileSizeFactor * 4);\n\n            CachedObject object = store.get(input);\n\n            assertThat(object).isInstanceOf(IntArrayCachedObject.class);\n            assertThat(((IntArrayCachedObject) object).getDefaultCapacity()).isEqualTo(4);\n            assertThat(object.getPos()).isEqualTo(256);\n\n            statement.execute(\"SHUTDOWN\");\n        }\n    }\n\n    @Test\n    void reopensFileDatabaseUsingBlockBasedDataSpaceManager() throws Exception {", "newText": "    @Test\n    void reopensFileDatabaseUsingBlockBasedDataSpaceManager() throws Exception {"}, {"oldText": "        String url = \"jdbc:hsqldb:file:\" + databasePath\n                + \";hsqldb.files_space=1\"\n                + \";hsqldb.lock_file=false\";", "newText": "        String url = \"jdbc:hsqldb:file:\" + databasePath\n                + \";hsqldb.lock_file=false\";"}, {"oldText": "        try (Connection connection = openConnection(url); Statement statement = connection.createStatement()) {\n            statement.execute(\"\"\"\n                    CREATE CACHED TABLE block_store_items (", "newText": "        try (Connection connection = openConnection(url); Statement statement = connection.createStatement()) {\n            statement.execute(\"SET FILES SPACE 1\");\n            statement.execute(\"\"\"\n                    CREATE CACHED TABLE block_store_items ("}, {"oldText": "    private static Session databaseSession(Connection connection) throws Exception {\n        JDBCConnection hsqldbConnection = connection.unwrap(JDBCConnection.class);\n\n        return (Session) hsqldbConnection.getSession();\n    }\n\n    private static Connection openConnection(String url) throws Exception {", "newText": "    private static Connection openConnection(String url) throws Exception {