       }\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777434604254}, {"role": "toolResult", "toolCallId": "call_rMwWcQg9Ih1KKvHgvfdFSWl4|fc_034abd73024b62db0169f17fec075c819288ea7b9cc44610d1", "toolName": "read", "content": [{"type": "text", "text": "{\n  \"resources\": {\n    \"includes\": [\n      {\n        \"pattern\": \"lobstoreinjarcoverage\\\\.lobs\"\n      },\n      {\n        \"pattern\": \"org_hsqldb/hsqldb/RefCapablePropertyResourceBundleTestMessages/referenced\\\\.text\"\n      }\n    ]\n  },\n  \"bundles\": [\n    {\n      \"name\": \"org_hsqldb.hsqldb.RefCapablePropertyResourceBundleTestMessages\"\n    }\n  ]\n}\n"}], "isError": false, "timestamp": 1777434604254}, {"role": "toolResult", "toolCallId": "call_bKLCsQnSLRi8Gorlwx4ytRrR|fc_034abd73024b62db0169f17fec07688192a3bcfcc598255d81", "toolName": "bash", "content": [{"type": "text", "text": " M tests/src/org.hsqldb/hsqldb/2.4.1/src/test/resources/META-INF/native-image/hsqldb-tests/resource-config.json\n?? tests/src/org.hsqldb/hsqldb/2.4.1/src/test/java/org_hsqldb/hsqldb/RefCapablePropertyResourceBundleTest.java\n?? tests/src/org.hsqldb/hsqldb/2.4.1/src/test/resources/org_hsqldb/\ndiff --git i/tests/src/org.hsqldb/hsqldb/2.4.1/src/test/resources/META-INF/native-image/hsqldb-tests/resource-config.json w/tests/src/org.hsqldb/hsqldb/2.4.1/src/test/resources/META-INF/native-image/hsqldb-tests/resource-config.json\nindex fb24358885..f3176c7db6 100644\n--- i/tests/src/org.hsqldb/hsqldb/2.4.1/src/test/resources/META-INF/native-image/hsqldb-tests/resource-config.json\n+++ w/tests/src/org.hsqldb/hsqldb/2.4.1/src/test/resources/META-INF/native-image/hsqldb-tests/resource-config.json\n@@ -3,7 +3,15 @@\n     \"includes\": [\n       {\n         \"pattern\": \"lobstoreinjarcoverage\\\\.lobs\"\n+      },\n+      {\n+        \"pattern\": \"org_hsqldb/hsqldb/RefCapablePropertyResourceBundleTestMessages/referenced\\\\.text\"\n       }\n     ]\n-  }\n+  },\n+  \"bundles\": [\n+    {\n+      \"name\": \"org_