c/org.hsqldb/hsqldb/2.4.1/build/jacoco/effective/hsqldb_2_4_1_jar/org/hsqldb/types/Type$TypedComparator.class\n./tests/src/org.hsqldb/hsqldb/2.4.1/build/jacoco/effective/hsqldb_2_4_1_jar/org/hsqldb/types/LobData.class\n./tests/src/org.hsqldb/hsqldb/2.4.1/build/jacoco/effective/hsqldb_2_4_1_jar/org/hsqldb/types/BinaryData.class\n./tests/src/org.hsqldb/hsqldb/2.4.1/build/jacoco/effective/hsqldb_2_4_1_jar/org/hsqldb/types/Collation.class\n./tests/src/org.hsqldb/hsqldb/2.4.1/build/jacoco/effective/hsqldb_2_4_1_jar/org/hsqldb/types/BooleanType.class\n./tests/src/org.hsqldb/hsqldb/2.4.1/build/jacoco/effective/hsqldb_2_4_1_jar/org/hsqldb/types/ClobData.class\n./tests/src/org.hsqldb/hsqldb/2.4.1/build/jacoco/effective/hsqldb_2_4_1_jar/org/hsqldb/types/IntervalMonthData.class\n./tests/src/org.hsqldb/hsqldb/2.4.1/build/jacoco/effective/hsqldb_2_4_1_jar/org/hsqldb/types/JavaObjectData.class\n./tests/src/org.hsqldb/hsqldb/2.4.1/build/jacoco/effective/hsqldb_2_4_1_jar/org/hsqldb/types/NullType.class\n./tests/src/org.hsqldb/hsqldb/2.4.1/build/jacoco/effective/hsqldb_2_4_1_jar/org/hsqldb/types/CharacterType.class\n./tests/src/org.hsqldb/hsqldb/2.4.1/build/jacoco/effective/hsqldb_2_4_1_jar/org/hsqldb/types/Type.class\n./tests/src/org.hsqldb/hsqldb/2.4.1/build/jacoco/effective/hsqldb_2_4_1_jar/org/hsqldb/types/IntervalType.class\n./tests/src/org.hsqldb/hsqldb/2.4.1/build/jacoco/effective/hsqldb_2_4_1_jar/org/hsqldb/TableUtil.class\n./tests/src/org.hsqldb/hsqldb/2.4.1/build/jacoco/effective/hsqldb_2_4_1_jar/org/hsqldb/auth\n./tests/src/org.hsqldb/hsqldb/2.4.1/build/jacoco/effective/hsqldb_2_4_1_jar/org/hsqldb/auth/AuthBeanMultiplexer.class\n./tests/src/org.hsqldb/hsqldb/2.4.1/build/jacoco/effective/hsqldb_2_4_1_jar/org/hsqldb/auth/HsqldbSlaveAuthBean.class\n./tests/src/org.hsqldb/hsqldb/2.4.1/build/jacoco/effective/hsqldb_2_4_1_jar/org/hsqldb/auth/AuthFunctionBean.class\n./tests/src/org.hsqldb/hsqldb/2.4.1/build/jacoco/effective/hsqldb_2_4_1_jar/org/hsqldb/auth/JaasAuthBean.class\n./