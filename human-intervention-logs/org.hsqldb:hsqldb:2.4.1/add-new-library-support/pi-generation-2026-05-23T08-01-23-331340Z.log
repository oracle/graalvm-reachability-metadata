  package org_hsqldb.hsqldb;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.IOException;
  import java.io.OutputStream;
  import java.nio.charset.StandardCharsets;
  import java.sql.Connection;
  import java.sql.SQLXML;
  
  import javax.xml.parsers.DocumentBuilder;
  import javax.xml.parsers.DocumentBuilderFactory;
  import javax.xml.stream.XMLEventReader;
  import javax.xml.stream.XMLStreamException;
  import javax.xml.stream.XMLStreamWriter;
  import javax.xml.transform.Result;
  import javax.xml.transform.Source;
  import javax.xml.transform.dom.DOMResult;
  import javax.xml.transform.dom.DOMSource;
  import javax.xml.transform.sax.SAXResult;
  import javax.xml.transform.sax.SAXSource;
  import javax.xml.transform.stax.StAXResult;
  import javax.xml.transform.stax.StAXSource;
  import javax.xml.transform.stream.StreamResult;
  import javax.xml.transform.stream.StreamSource;
  
  import org.hsqldb.jdbc.JDBCDataSource;
  import org.junit.jupiter.api.Test;
  import org.w3c.dom.Document;
  import org.w3c.dom.Element;
  import org.xml.sax.ContentHandler;
  import org.xml.sax.SAXException;
  import org.xml.sax.helpers.AttributesImpl;
  
  public class JDBCSQLXMLTest {
      private static final String XML = "<root><message>hello</message></root>";
  
      @Test
      void createsSupportedSourceTypes() throws Exception {
          try (Connection connection = openConnection()) {
              assertSource(connection, XmlStreamSource.class);
              assertSource(connection, XmlDOMSource.class);
              assertSource(connection, XmlSAXSource.class);
              assertSource(connection, XmlEventStAXSource.class);
          }
      }
  
      @Test
      void createsSupportedResultTypes() throws Exception {
          try (Connection connection = openConnection()) {
              assertResult(connection, XmlStreamResult.class);
              assertResult(connection, XmlDOMResult.class);
              assertResult(connection, XmlSAXResult.class);
              assertResult(connection, XmlWriterStAXResult.class);
          }
      }
  
      private static Connection openConnection() throws Exception {
          JDBCDataSource dataSource = new JDBCDataSource();
  
          dataSource.setUrl("jdbc:hsqldb:mem:jdbc_sqlxml_" + Long.toUnsignedString(System.nanoTime()) + ";shutdown=true");
          dataSource.setUser("SA");
          dataSource.setPassword("");
  
          return dataSource.getConnection();
      }
  
      private static void assertSource(Connection connection, Class<? extends Source> sourceClass) throws Exception {
          SQLXML sqlxml = connection.createSQLXML();
  
          try {
              sqlxml.setString(XML);
  
              Source source = sqlxml.getSource(sourceClass);
  
              assertThat(source).isInstanceOf(sourceClass);
              assertReadableSource(source);
          } finally {
              sqlxml.free();
          }
      }
  
      private static void assertReadableSource(Source source) throws Exception {
          if (source instanceof StreamSource streamSource) {
              assertThat(streamSource.getReader()).isNotNull();
          } else if (source instanceof DOMSource domSource) {
              assertThat(domSource.getNode()).isNotNull();
          } else if (source instanceof SAXSource saxSource) {
              assertThat(saxSource.getInputSource()).isNotNull();
          } else if (source instanceof StAXSource staxSource) {
              assertThat(staxSource.getXMLEventReader().hasNext()).isTrue();
          }
      }
  
      private static void assertResult(Connection connection, Class<? extends Result> resultClass) throws Exception {
          SQLXML sqlxml = connection.createSQLXML();
  
          try {
              Result result = sqlxml.setResult(resultClass);
  
              assertThat(result).isInstanceOf(resultClass);
              writeXml(result);
          } finally {
              sqlxml.free();
          }
      }
  
      private static void writeXml(Result result) throws Exception {
          if (result instanceof StreamResult streamResult) {
              writeXml(streamResult);
          } else if (result instanceof DOMResult domResult) {
              domResult.setNode(newDocument());
          } else if (result instanceof SAXResult saxResult) {
              writeXml(saxResult);
          } else if (result instanceof StAXResult staxResult) {
              writeXml(staxResult);
          }
      }
  
      private static void writeXml(StreamResult result) throws IOException {
          OutputStream outputStream = result.getOutputStream();
  
          assertThat(outputStream).isNotNull();
          outputStream.write(XML.getBytes(StandardCharsets.UTF_8));
          outputStream.close();
      }
  
      private static Document newDocument() throws Exception {
          DocumentBuilderFactory factory = DocumentBuilderFactory.newInstance();
          DocumentBuilder builder = factory.newDocumentBuilder();
          Document document = builder.newDocument();
          Element root = document.createElement("root");
          Element message = document.createElement("message");
  
          message.setTextContent("hello");
          root.appendChild(message);
          document.appendChild(root);
  
          return document;
      }
  
      private static void writeXml(SAXResult result) throws SAXException {
          ContentHandler handler = result.getHandler();
  
          assertThat(handler).isNotNull();
          handler.startDocument();
          handler.startElement("", "root", "root", new AttributesImpl());
          handler.startElement("", "message", "message", new AttributesImpl());
          char[] text = "hello".toCharArray();
          handler.characters(text, 0, text.length);
          handler.endElement("", "message", "message");
          handler.endElement("", "root", "root");
          handler.endDocument();
      }
  
      private static void writeXml(StAXResult result) throws XMLStreamException {
          XMLStreamWriter writer = result.getXMLStreamWriter();
  
          assertThat(writer).isNotNull();
          writer.writeStartDocument();
          writer.writeStartElement("root");
          writer.writeStartElement("message");
          writer.writeCharacters("hello");
          writer.writeEndElement();
          writer.writeEndElement();
          writer.writeEndDocument();
          writer.close();
      }
  
      public static class XmlStreamSource extends StreamSource {
      }
  
      public static class XmlDOMSource extends DOMSource {
      }
  
      public static class XmlSAXSource extends SAXSource {
      }
  
      public static class XmlEventStAXSource extends StAXSource {
          public XmlEventStAXSource(XMLEventReader reader) throws XMLStreamException {
              super(reader);
          }
      }
  
      public static class XmlStreamResult extends StreamResult {
      }
  
      public static class XmlDOMResult extends DOMResult {
      }
  
      public static class XmlSAXResult extends SAXResult {
      }
  
      public static class XmlWriterStAXResult extends StAXResult {
          public XmlWriterStAXResult(XMLStreamWriter writer) {
              super(writer);
          }
      }
