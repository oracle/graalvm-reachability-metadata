\n        @Override\n        public OutputStream openOutputStreamElement(String streamName, boolean append) throws IOException {\n            return new ByteArrayOutputStream();\n        }\n\n        @Override\n        public boolean isStreamElement(String elementName) {\n            return false;\n        }\n\n        @Override\n        public void createParentDirs(String filename) {\n        }\n\n        @Override\n        public void removeElement(String filename) {\n        }\n\n        @Override\n        public void renameElement(String oldName, String newName, boolean copyIfFailed) {\n        }\n\n        @Override\n        public FileSync getFileSync(OutputStream os) throws IOException {\n            return () -> {\n            };\n        }\n    }\n\n    private static final class StorageFallbackClassLoader extends ClassLoader {\n        private final String unavailableClassName;\n\n        StorageFallbackClassLoader(ClassLoader parent, String unavailableClassName) {\n            super(parent);\n            this.unavailableClassName = unavailableClassName;\n        }\n\n        @Override\n        public Class<?> loadClass(String name) throws ClassNotFoundException {\n            if (unavailableClassName.equals(name)) {\n                throw new ClassNotFoundException(name);\n            }\n\n            return super.loadClass(name);\n        }\n    }\n}\n"}
