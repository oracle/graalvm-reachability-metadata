[tool-call] delta {"path":"tests/src/org.hsqldb/hsqldb/2.4.1/src/test/java/org_hsqldb/hsqldb/LoggerTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_hsqldb.hsqldb;\n\nimport static org.junit.jupiter.api.Assertions.assertEquals;\nimport static org.junit.jupiter.api.Assertions.assertNotNull;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.IOException;\nimport java.io.InputStream;\nimport java.io.OutputStream;\nimport java.sql.Connection;\nimport java.util.Properties;\nimport java.util.concurrent.atomic.AtomicInteger;\nimport java.util.concurrent.atomic.AtomicReference;\n\nimport org.hsqldb.jdbc.JDBCDriver;\nimport org.hsqldb.lib.FileAccess;\nimport org.hsqldb.persist.HsqlDatabaseProperties;\nimport org.hsqldb.persist.RandomAccessInterface;\nimport org.junit.jupiter.api.Test;\n\npublic class LoggerTest {\n    private static final AtomicInteger FILE_ACCESS_CONSTRUCTIONS = new AtomicInteger();\n    private static final AtomicReference<Object> LAST_STORAGE_KEY = new AtomicReference<>();\n\n    @Test\n    public void opensCustomFileAccessThroughContextClassLoader() throws Exception {\n        String storageKey = \"context-loader-\" + System.nanoTime();\n\n        resetFileAccessState();\n\n        try (Connection connection = openConnection(\"loggercontext\" + System.nanoTime(), storageKey)) {\n            assertNotNull(connection);\n        }\n\n        assertEquals(1, FILE_ACCESS_CONSTRUCTIONS.get());\n        assertEquals(storageKey, LAST_STORAGE_KEY.get());\n    }\n\n    @Test\n    public void fallsBackToClassForNameWhenStorageClassIsNotVisibleToContextClassLoader() throws Exception {\n        String storageKey = \"class-for-name-\" + System.nanoTime();\n        ClassLoader originalClassLoader = Thread.currentThread().getContextClass