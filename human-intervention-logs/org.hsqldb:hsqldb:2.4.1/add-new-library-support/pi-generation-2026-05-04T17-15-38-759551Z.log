ring storageKey = \"context-loader-\" + System.nanoTime();\n+\n+        resetFileAccessState();\n+\n+        try (Connection connection = openConnection(\"loggercontext\" + System.nanoTime(), storageKey)) {\n+            assertNotNull(connection);\n+        }\n+\n+        assertEquals(1, FILE_ACCESS_CONSTRUCTIONS.get());\n+        assertEquals(storageKey, LAST_STORAGE_KEY.get());\n+    }\n+\n+    @Test\n+    public void fallsBackToClassForNameWhenStorageClassIsNotVisibleToContextClassLoader() throws Exception {\n+        String storageKey = \"class-for-name-\" + System.nanoTime();\n+        ClassLoader originalClassLoader = Thread.currentThread().getContextClassLoader();\n+        ClassLoader fallbackClassLoader = new StorageFallbackClassLoader(\n+                originalClassLoader, RandomAccessInterface.class.getName());\n+\n+        resetFileAccessState();\n+        Thread.currentThread().setContextClassLoader(fallbackClassLoader);\n+\n+        try (Connection connection = openConnection(\"loggerfallback\" + System.nanoTime(), storageKey)) {\n+            assertNotNull(connection);\n+        } finally {\n+            Thread.currentThread().setContextClassLoader(originalClassLoader);\n+        }\n+\n+        assertEquals(1, FILE_ACCESS_CONSTRUCTIONS.get());\n+        assertEquals(storageKey, LAST_STORAGE_KEY.get());\n+    }\n+\n+    private static void resetFileAccessState() {\n+        FILE_ACCESS_CONSTRUCTIONS.set(0);\n+        LAST_STORAGE_KEY.set(null);\n+    }\n+\n+    private static Connection openConnection(String databaseName, String storageKey) throws Exception {\n+        Properties properties = new Properties();\n+\n+        properties.setProperty(\"user\", \"SA\");\n+        properties.setProperty(\"password\", \"\");\n+        properties.setProperty(HsqlDatabaseProperties.url_fileaccess_class_name, InMemoryFileAccess.class.getName());\n+        properties.setProperty(HsqlDatabaseProperties.url_storage_class_name, RandomAccessInterface.class.getName());\n+        properties.setProperty(HsqlDatabaseProperties.url_storage_key, storageKey);\n+        properties.setProperty(HsqlDatabaseProperties.url_shutdown, \"true\");\n+\n+        return new JDBCDriver().connect(\"jdbc:hsqldb:mem:\" + databaseName, properties);\n+    }\n+\n+    public static final class InMemoryFileAccess implements FileAccess {\n+        public InMemoryFileAccess(Object storageKey) {\n+            FILE_ACCESS_CONSTRUCTIONS.incrementAndGet();\n+            LAST_STORAGE_KEY.set(storageKey);\n+        }\n+\n+        @Override\n+        public InputStream openInputStreamElement(String streamName) throws IOException {\n+            return new ByteArrayInputStream(new byte[0]);\n+        }\n+\n+        @Override\n+        public OutputStream openOutputStreamElement(String streamName, boolean append) throws IOException {\n+            return new ByteArrayOutputStream();\n+        }\n+\n+        @Override\n+        public boolean isStreamElement(String elementName) {\n+            return false;\n+        }\n+\n+        @Override\n+        public void createParentDirs(String filename) {\n+            // In-memory elements do not have parent directories.\n+        }\n+\n+        @Override\n+        public void removeElement(String filename) {\n+            // The logger test only opens an in-memory database, so no elements are persisted.\n+        }\n+\n+        @Override\n+        public void renameElement(String oldName, String newName, boolean copyIfFailed) {\n+            // The logger test only opens an in-memory database, so no elements are persisted.\n+        }\n+\n+        @Override\n+        public FileSync getFileSync(OutputStream os) throws IOException {\n+            return os::flush;\n+        }\n+    }\n+\n+    private static final class StorageFallbackClassLoader extends ClassLoader {\n+        private final String unavailableClassName;\n+\n+        StorageFallbackClassLoader(ClassLoader parent, String unavailableClassName) {\n+            super(parent);\n+            this.unavailableClassName = unavailableClassName;\n+        }\n+\n+        @Override\n+        public Class<?> loadClass(String name) throws ClassNotFoundException {\n+            if (unavailableClassName.equals(name)) {\n+                throw new ClassNotFoundException(name);\n+            }\n+\n+            return super.loadClass(name);\n+        }\n+    }\n+}\n"}], "isError": false, "timestamp": 1777914917662}]}
