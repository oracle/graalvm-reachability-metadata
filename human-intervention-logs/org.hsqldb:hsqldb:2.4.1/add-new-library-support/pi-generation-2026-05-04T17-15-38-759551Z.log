ns.assertNotNull;\nimport static org.junit.jupiter.api.Assertions.assertNull;\nimport static org.junit.jupiter.api.Assertions.assertSame;\n\nimport java.util.List;\nimport java.util.logging.Level;\n\nimport org.apache.log4j.Logger;\nimport org.apache.log4j.Logger.LogEvent;\nimport org.hsqldb.lib.FrameworkLogger;\nimport org.junit.jupiter.api.Test;\n\npublic class FrameworkLoggerTest {\n    @Test\n    public void routesLogMessagesThroughDiscoveredLog4jApi() {\n        assertNotNull(org.apache.log4j.Level.class);\n        assertNotNull(org.apache.log4j.Priority.class);\n        assertNotNull(Logger.class);\n\n        Logger.clear();\n\n        String loggerName = \"frameworkLoggerCoverage.\" + System.nanoTime();\n        FrameworkLogger.clearLoggers(loggerName);\n\n        FrameworkLogger logger = FrameworkLogger.getLog(loggerName);\n\n        assertSame(logger, FrameworkLogger.getLog(loggerName));\n\n        IllegalStateException exception = new IllegalStateException(\"coverage\");\n\n        logger.log(Level.INFO, \"integration message\", exception);\n        logger.enduserlog(Level.WARNING, \"end user message\");\n\n        assertEquals(1, Logger.loggerNames().size());\n        assertEquals(loggerName, Logger.loggerNames().get(0));\n\n        List<String> convertedLevels = org.apache.log4j.Level.convertedLevelNames();\n\n        assertEquals(\"ALL\", convertedLevels.get(0));\n        assertEquals(\"DEBUG\", convertedLevels.get(1));\n        assertEquals(\"ERROR\", convertedLevels.get(2));\n        assertEquals(\"FATAL\", convertedLevels.get(3));\n        assertEquals(\"INFO\", convertedLevels.get(4));\n        assertEquals(\"OFF\", convertedLevels.get(5));\n        assertEquals(\"TRACE\", convertedLevels.get(6));\n        assertEquals(\"WARN\", convertedLevels.get(7));\n\n        List<LogEvent> events = Logger.events();\n\n        assertEquals(2, events.size());\n        assertEquals(loggerName, events.get(0).loggerName());\n        assertEquals(FrameworkLogger.class.getName(), events.get(0).fqcn());\n        assertEquals(\"INFO\", events.get(0).priority().name());\n        assertEquals(\"integration message\", events.get(0).message());\n        assertSame(exception, events.get(0).throwable());\n\n        assertEquals(loggerName, events.get(1).loggerName());\n        assertEquals(FrameworkLogger.class.getName(), events.get(1).fqcn());\n        assertEquals(\"WARN\", events.get(1).priority().name());\n        assertEquals(\"end user message\", events.get(1).message());\n        assertNull(events.get(1).throwable());\n    }\n}\n"}], "isError": false, "timestamp": 1777914746408}, {"role": "toolResult", "toolCallId": "call_EoBVpxSmSapKjIPbXEPkpIHl|fc_09dc1807bf85049a0169f8d37a30448196ac193bfc0198aadb", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_hsqldb.hsqldb;\n\nimport static org.junit.jupiter.api.Assertions.assertEquals;\nimport static org.junit.jupiter.api.Assertions.assertNotNull;\n\nimport java.sql.Array;\nimport java.sql.CallableStatement;\nimport java.sql.Connection;\nimport java.sql.ResultSet;\nimport java.sql.Statement;\nimport java.sql.Types;\nimport java.util.Properties;\nimport java.util.concurrent.atomic.AtomicInteger;\n\nimport org.hsqldb.jdbc.JDBCDriver;\nimport org.junit.jupiter.api.Test;\n\npublic class RoutineTest {\n    private static final AtomicInteger AUTHENTICATION_CALLS = new AtomicInteger();\n    private static final String ROUTINE_CLASS_NAME = RoutineTest.class.getName();\n\n    @Test\n    public void invokesJavaFunctionResolvedViaRoutineGetMethodsFallback() throws Exception {\n        ClassLoader originalClassLoader = Thread.currentThread().getContextClassLoader();\n\n        try (Connection connection = openConnection(\"routinefunction\" + System.nanoTime(), \"SA\", \"\");\n                Statement statement = connection.createStatement()) {\n            Thread.currentThread().setContextClassLoader(null);\n\n            try {\n                statement.execute(\"\"\"\n                        CREATE FUNCTION ADD_ONE(P_VALUE INTEGER)\n                        RETURNS INTEGER\n                        LANGUAGE JAVA DETERMINISTIC NO SQL\n                        EXTERNAL NAME 'CLASSPATH:%s.addOne'\n                        \"\"\".formatted(ROUTINE_CLASS_NAME));\n            } finally {\n                Thread.currentThread().setContextClassLoader(originalClassLoader);\n            }\n\n            try (ResultSet resultSet = statement.executeQuery(\"CALL ADD_ONE(41)\")) {\n                resultSet.next();\n\n                assertEquals(42, resultSet.getInt(1));\n            }\n        }\n    }\n\n    @Test\n    public void invokesJavaProcedureWithOutParameterArrayConversion() throws Exception {\n        try (Connection connection = openConnection(\"routineprocedure\" + System.nanoTime(), \"SA\", \"\");\n                Statement statement = connection.createStatement()) {\n            statement.execute(\"\"\"\n                    CREATE PROCEDURE INCREMENT_VALUE(IN P_VALUE INTEGER, OUT P_RESULT INTEGER)\n                    LANGUAGE JAVA DETERMINISTIC NO SQL\n                    EXTERNAL NAME 'CLASSPATH:%s.incrementOutParameter'\n                    \"\"\".formatted(ROUTINE_CLASS_NAME));\n\n            try (CallableStatement call = connection.prepareCall(\"CALL INCREMENT_VALUE(?, ?)\")) {\n                call.setInt(1, 6);\n                call.registerOutParameter(2, Types.INTEGER);\n                call.execute();\n\n                assertEquals(7, call.getInt(2));\n            }\n        }\n    }\n\n    @Test\n    public void invokesDatabaseAuthenticationRoutineDirectly() throws Exception {\n        String databaseName = \"routineauth\" + System.nanoTime();\n\n        AUTHENTICATION_CALLS.set(0);\n\n        try (Connection adminConnection = openConnection(databaseName, \"SA\", \"\");\n                Statement statement = adminConnection.createStatement()) {\n            statement.execute(\"\"\"\n                    SET DATABASE AUTHENTICATION FUNCTION\n                    EXTERNAL NAME 'CLASSPATH:%s.authenticate'\n                    \"\"\".formatted(ROUTINE_CLASS_NAME));\n\n            try (Connection externalConnection = openConnection(databaseName, \"EXTERNAL_USER\", \"secret\")) {\n                assertNotNull(externalConnection);\n            }\n        }\n\n        assertEquals(1, AUTHENTICATION_CALLS.get());\n    }\n\n    public static Integer addOne(Integer value) {\n        return Integer.valueOf(value.intValue() + 1);\n    }\n\n    public static void incrementOutParameter(Integer value, Integer[] result) {\n\n[23 more lines in file. Use offset=101 to continue.]"}], "isError": false, "timestamp": 1777914746408}, {"role": "toolResult", "toolCallId": "call_wN1MILEp7h6BNorsJnlhdiTW|fc_09dc1807bf85049a0169f8d37a304881969d542adc288faa22", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\nplugins {\n    id \"org.graalvm.internal.tck\"\n}\n\nString libraryVersion = tck.testedLibraryVersion.get()\n\ndependencies {\n    // The default HSQLDB jar is stripped of line numbers; the upstream debug classifier preserves them for\n    // dynamic-access coverage mapping.\n    testImplementation \"org.hsqldb:hsqldb:$libraryVersion:jdk8debug\"\n    testImplementation 'javax.xml.bind:jaxb-api:2.3.1'\n    testImplementation 'org.assertj:assertj-core:3.22.0'\n}\n\ntasks.named(\"nativeTest\") {\n    runtimeArgs.add(\"-Djava.home=${System.getenv('JAVA_HOME')}\")\n}\n\ngraalvmNative {\n    agent {\n        defaultMode = \"conditional\"\n        modes {\n            conditional {\n                u