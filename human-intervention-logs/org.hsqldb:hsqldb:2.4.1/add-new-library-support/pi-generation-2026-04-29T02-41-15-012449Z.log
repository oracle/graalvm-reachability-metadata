                                   new Object[]{ "DEBUG" }));
          jdkToLog4jLevels.put(Level.WARNING,
                               log4jToLevel.invoke(null,
                                   new Object[]{ "ERROR" }));
          jdkToLog4jLevels.put(Level.SEVERE,
                               log4jToLevel.invoke(null,
                                   new Object[]{ "FATAL" }));
          jdkToLog4jLevels.put(Level.INFO,
                               log4jToLevel.invoke(null,
                                   new Object[]{ "INFO" }));
          jdkToLog4jLevels.put(Level.OFF,
                               log4jToLevel.invoke(null,
                                   new Object[]{ "OFF" }));
          jdkToLog4jLevels.put(Level.FINEST,
