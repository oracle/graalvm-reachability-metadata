  package org_hsqldb.hsqldb;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.math.BigDecimal;
  import java.sql.Connection;
  import java.sql.DriverManager;
  import java.sql.ParameterMetaData;
  import java.sql.PreparedStatement;
  import java.sql.Statement;
  import java.sql.Types;
  import java.util.concurrent.atomic.AtomicInteger;
  
  import org.hsqldb.jdbc.JDBCParameterMetaData;
  import org.junit.jupiter.api.Test;
  
  public class JDBCParameterMetaDataTest {
      private static final AtomicInteger DATABASE_COUNTER = new AtomicInteger();
  
      @Test
      public void rendersPreparedStatementParameterMethodsInStringRepresentation() throws Exception {
          try (Connection connection = openConnection()) {
              try (Statement statement = connection.createStatement()) {
                  statement.execute("CREATE TABLE PARAMETER_METADATA_TEST ("
                          + "ID INTEGER, NAME VARCHAR(40), AMOUNT DECIMAL(12, 2))");
              }
  
              try (PreparedStatement statement = connection.prepareStatement(
                      "INSERT INTO PARAMETER_METADATA_TEST (ID, NAME, AMOUNT) VALUES (?, ?, ?)")) {
                  ParameterMetaData parameterMetaData = statement.getParameterMetaData();
  
                  assertThat(parameterMetaData).isInstanceOf(JDBCParameterMetaData.class);
                  assertThat(parameterMetaData.getParameterCount()).isEqualTo(3);
  
                  String rendered = parameterMetaData.toString();
  
                  assertThat(rendered)
                          .contains("parameter_1")
                          .contains("getParameterClassName=" + Integer.class.getName())
                          .contains("getParameterType=" + Types.INTEGER)
                          .contains("getParameterTypeName=INTEGER")
                          .contains("parameter_2")
                          .contains("getParameterClassName=" + String.class.getName())
                          .contains("getParameterType=" + Types.VARCHAR)
                          .contains("getParameterTypeName=VARCHAR")
                          .contains("parameter_3")
                          .contains("getParameterClassName=" + BigDecimal.class.getName())
                          .contains("getParameterType=" + Types.DECIMAL)
                          .contains("getParameterTypeName=DECIMAL")
                          .contains("getPrecision=12")
                          .contains("getScale=2")
                          .doesNotContain("toStringImpl_exception");
              }
          }
      }
  
      private static Connection openConnection() throws Exception {
          return DriverManager.getConnection("jdbc:hsqldb:mem:parametermetadata" + DATABASE_COUNTER.incrementAndGet(),
                  "SA", "");
      }
  }
