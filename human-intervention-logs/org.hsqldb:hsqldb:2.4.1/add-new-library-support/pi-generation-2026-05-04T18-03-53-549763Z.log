  package org_hsqldb.hsqldb;
  
  import static org.junit.jupiter.api.Assertions.assertArrayEquals;
  import static org.junit.jupiter.api.Assertions.assertEquals;
  import static org.junit.jupiter.api.Assertions.assertTrue;
  
  import org.hsqldb.lib.HsqlArrayList;
  import org.junit.jupiter.api.Test;
  
  public class HsqlArrayListTest {
      @Test
      public void createsTypedArraysFromListContentsAndTargets() {
          HsqlArrayList list = new HsqlArrayList(new String[] {"alpha", "beta", "gamma"}, 3);
  
          Object[] allValues = list.toArray();
          Object[] middleValues = list.toArray(1, 3);
          Object copiedValues = list.toArray(new String[1]);
  
          assertEquals(String[].class, allValues.getClass());
          assertArrayEquals(new String[] {"alpha", "beta", "gamma"}, allValues);
          assertEquals(String[].class, middleValues.getClass());
          assertArrayEquals(new String[] {"beta", "gamma"}, middleValues);
          assertTrue(copiedValues instanceof String[]);
          assertArrayEquals(new String[] {"alpha", "beta", "gamma"}, (String[]) copiedValues);
      }
  }
