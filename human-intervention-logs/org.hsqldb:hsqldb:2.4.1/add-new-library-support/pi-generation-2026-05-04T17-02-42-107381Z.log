\"DEBUG\", convertedLevels.get(1));\n        assertEquals(\"ERROR\", convertedLevels.get(2));\n        assertEquals(\"FATAL\", convertedLevels.get(3));\n        assertEquals(\"INFO\", convertedLevels.get(4));\n        assertEquals(\"OFF\", convertedLevels.get(5));\n        assertEquals(\"TRACE\", convertedLevels.get(6));\n        assertEquals(\"WARN\", convertedLevels.get(7));\n\n        List<LogEvent> events = Logger.events();\n\n        assertEquals(2, events.size());\n        assertEquals(loggerName, events.get(0).loggerName());\n        assertEquals(FrameworkLogger.class.getName(), events.get(0).fqcn());\n        assertEquals(\"INFO\", events.get(0).priority().name());\n        assertEquals(\"integration message\", events.get(0).message());\n        assertSame(exception, events.get(0).throwable());\n\n        assertEquals(loggerName, events.get(1).loggerName());\n        assertEquals(FrameworkLogger.class.getName(), events.get(1).fqcn());\n        assertEquals(\"WARN\", events.get(1).priority().name());\n        assertEquals(\"end user message\", events.get(1).message());\n        assertNull(events.get(1).throwable());\n    }\n}\n"}
