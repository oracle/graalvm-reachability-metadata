  package org_hsqldb.hsqldb;
  
  import static org.junit.jupiter.api.Assertions.assertEquals;
  import static org.junit.jupiter.api.Assertions.assertNotNull;
  import static org.junit.jupiter.api.Assertions.assertNull;
  import static org.junit.jupiter.api.Assertions.assertSame;
  
  import java.util.List;
  import java.util.logging.Level;
  
  import org.apache.logging.log4j.LogManager;
  import org.apache.logging.log4j.Logger;
  import org.apache.logging.log4j.Logger.LogEvent;
  import org.hsqldb.lib.FrameworkLogger;
  import org.junit.jupiter.api.Test;
  
  public class FrameworkLoggerTest {
      @Test
      public void routesLogMessagesThroughDiscoveredLog4j2Api() {
          assertNotNull(org.apache.logging.log4j.Level.class);
          assertNotNull(Logger.class);
          assertNotNull(LogManager.class);
  
          LogManager.clearLoggerNames();
          Logger.clearEvents();
  
          String loggerName = "frameworkLoggerCoverage." + System.nanoTime();
          FrameworkLogger.clearLoggers(loggerName);
  
          FrameworkLogger logger = FrameworkLogger.getLog(loggerName);
  
          assertSame(logger, FrameworkLogger.getLog(loggerName));
  
          IllegalStateException exception = new IllegalStateException("coverage");
  
          logger.log(Level.INFO, "integration message", exception);
          logger.enduserlog(Level.WARNING, "end user message");
  
          assertEquals(1, LogManager.loggerNames().size());
          assertEquals(loggerName, LogManager.loggerNames().get(0));
  
          List<String> convertedLevels = org.apache.logging.log4j.Level.convertedLevelNames();
  
          assertEquals("ALL", convertedLevels.get(0));
          assertEquals("DEBUG", convertedLevels.get(1));
          assertEquals("ERROR", convertedLevels.get(2));
          assertEquals("FATAL", convertedLevels.get(3));
          assertEquals("INFO", convertedLevels.get(4));
          assertEquals("OFF", convertedLevels.get(5));
          assertEquals("TRACE", convertedLevels.get(6));
          assertEquals("WARN", convertedLevels.get(7));
  
          List<LogEvent> events = Logger.events();
  
          assertEquals(2, events.size());
          assertEquals(loggerName, events.get(0).loggerName());
          assertEquals("INFO", events.get(0).level().name());
          assertEquals("integration message", events.get(0).message());
          assertSame(exception, events.get(0).throwable());
  
          assertEquals(loggerName, events.get(1).loggerName());
          assertEquals("WARN", events.get(1).level().name());
          assertEquals("end user message", events.get(1).message());
          assertNull(events.get(1).throwable());
      }
  }
