  package org.apache.logging.log4j;
  
  import java.util.ArrayList;
  import java.util.Collections;
  import java.util.List;
  
  public final class Level {
      private static final List<String> CONVERTED_LEVEL_NAMES = Collections.synchronizedList(new ArrayList<String>());
  
      private final String name;
  
      private Level(String name) {
          this.name = name;
      }
  
      public static Level toLevel(String name) {
          CONVERTED_LEVEL_NAMES.add(name);
  
          return new Level(name);
      }
  
      public String name() {
          return name;
      }
  
      public static List<String> convertedLevelNames() {
          synchronized (CONVERTED_LEVEL_NAMES) {
              return new ArrayList<String>(CONVERTED_LEVEL_NAMES);
          }
      }
  }
