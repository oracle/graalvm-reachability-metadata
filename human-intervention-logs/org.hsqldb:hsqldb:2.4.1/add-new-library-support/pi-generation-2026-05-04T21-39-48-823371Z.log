  package org_hsqldb.hsqldb;
  
  import org.hsqldb.lib.FrameworkLogger;
  import org.junit.jupiter.api.Test;
  
  import java.util.logging.Level;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class FrameworkLoggerTest {
      private static final String LOGGER_NAME = "org_hsqldb.hsqldb.FrameworkLoggerTest";
  
      @Test
      void logsThroughLog4jBackendWhenLog4jIsAvailable() {
          assertThat(org.apache.log4j.Logger.getLogger(LOGGER_NAME)).isNotNull();
  
          FrameworkLogger.clearLoggers(LOGGER_NAME);
          FrameworkLogger logger = FrameworkLogger.getLog(LOGGER_NAME);
  
          logger.info("FrameworkLogger log4j info message");
          logger.log(Level.WARNING, "FrameworkLogger log4j warning message", new IllegalStateException("warning"));
          logger.privlog(Level.FINER, "FrameworkLogger log4j private message", null, 1, FrameworkLoggerTest.class);
          logger.enduserlog(Level.SEVERE, "FrameworkLogger log4j end-user message");
  
          assertThat(FrameworkLogger.report()).contains(LOGGER_NAME);
      }
