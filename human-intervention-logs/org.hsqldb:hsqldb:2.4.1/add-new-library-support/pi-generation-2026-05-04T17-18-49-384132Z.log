  package org_hsqldb.hsqldb;
  
  import static org.junit.jupiter.api.Assertions.assertEquals;
  import static org.junit.jupiter.api.Assertions.assertNotNull;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.IOException;
  import java.io.InputStream;
  import java.io.OutputStream;
  import java.sql.Connection;
  import java.util.Properties;
  import java.util.concurrent.atomic.AtomicInteger;
  import java.util.concurrent.atomic.AtomicReference;
  
  import org.hsqldb.jdbc.JDBCDriver;
  import org.hsqldb.lib.FileAccess;
  import org.hsqldb.persist.HsqlDatabaseProperties;
  import org.hsqldb.persist.RandomAccessInterface;
  import org.junit.jupiter.api.Test;
  
  public class LoggerTest {
      private static final AtomicInteger FILE_ACCESS_CONSTRUCTIONS = new AtomicInteger();
      private static final AtomicReference<Object> LAST_STORAGE_KEY = new AtomicReference<>();
  
      @Test
      public void opensCustomFileAccessThroughContextClassLoader() throws Exception {
          String storageKey = "context-loader-" + System.nanoTime();
          ClassLoader originalClassLoader = Thread.currentThread().getContextClassLoader();
  
          resetFileAccessState();
          Thread.currentThread().setContextClassLoader(applicationClassLoader());
  
          try (Connection connection = openConnection("loggercontext" + System.nanoTime(), storageKey)) {
              assertNotNull(connection);
          } finally {
              Thread.currentThread().setContextClassLoader(originalClassLoader);
          }
  
          assertEquals(1, FILE_ACCESS_CONSTRUCTIONS.get());
          assertEquals(storageKey, LAST_STORAGE_KEY.get());
      }
  
      @Test
      public void fallsBackToClassForNameWhenStorageClassIsNotVisibleToContextClassLoader() throws Exception {
          String storageKey = "class-for-name-" + System.nanoTime();
          ClassLoader originalClassLoader = Thread.currentThread().getContextClassLoader();
          ClassLoader fallbackClassLoader = new StorageFallbackClassLoader(
                  applicationClassLoader(), RandomAccessInterface.class.getName());
  
          resetFileAccessState();
          Thread.currentThread().setContextClassLoader(fallbackClassLoader);
  
          try (Connection connection = openConnection("loggerfallback" + System.nanoTime(), storageKey)) {
              assertNotNull(connection);
          } finally {
              Thread.currentThread().setContextClassLoader(originalClassLoader);
          }
  
          assertEquals(1, FILE_ACCESS_CONSTRUCTIONS.get());
          assertEquals(storageKey, LAST_STORAGE_KEY.get());
      }
  
      private static void resetFileAccessState() {
          FILE_ACCESS_CONSTRUCTIONS.set(0);
          LAST_STORAGE_KEY.set(null);
      }
  
      private static ClassLoader applicationClassLoader() {
          ClassLoader classLoader = LoggerTest.class.getClassLoader();
  
          return classLoader == null ? ClassLoader.getSystemClassLoader() : classLoader;
      }
  
      private static Connection openConnection(String databaseName, String storageKey) throws Exception {
          Properties properties = new Properties();
  
          properties.setProperty("user", "SA");
          properties.setProperty("password", "");
          properties.setProperty(HsqlDatabaseProperties.url_fileaccess_class_name, InMemoryFileAccess.class.getName());
          properties.setProperty(HsqlDatabaseProperties.url_storage_class_name, RandomAccessInterface.class.getName());
          properties.setProperty(HsqlDatabaseProperties.url_storage_key, storageKey);
          properties.setProperty(HsqlDatabaseProperties.url_shutdown, "true");
  
          return new JDBCDriver().connect("jdbc:hsqldb:mem:" + databaseName, properties);
      }
  
      public static final class InMemoryFileAccess implements FileAccess {
          public InMemoryFileAccess(Object storageKey) {
              FILE_ACCESS_CONSTRUCTIONS.incrementAndGet();
              LAST_STORAGE_KEY.set(storageKey);
          }
  
          @Override
          public InputStream openInputStreamElement(String streamName) throws IOException {
              return new ByteArrayInputStream(new byte[0]);
          }
  
          @Override
          public OutputStream openOutputStreamElement(String streamName, boolean append) throws IOException {
              return new ByteArrayOutputStream();
          }
  
          @Override
          public boolean isStreamElement(String elementName) {
              return false;
          }
  
          @Override
          public void createParentDirs(String filename) {
              // In-memory elements do not have parent directories.
          }
  
          @Override
          public void removeElement(String filename) {
              // The logger test only opens an in-memory database, so no elements are persisted.
          }
  
          @Override
          public void renameElement(String oldName, String newName, boolean copyIfFailed) {
              // The logger test only opens an in-memory database, so no elements are persisted.
          }
  
          @Override
          public FileSync getFileSync(OutputStream os) throws IOException {
              return os::flush;
          }
      }
  
      private static final class StorageFallbackClassLoader extends ClassLoader {
          private final String unavailableClassName;
  
          StorageFallbackClassLoader(ClassLoader parent, String unavailableClassName) {
              super(parent);
              this.unavailableClassName = unavailableClassName;
          }
  
          @Override
          public Class<?> loadClass(String name) throws ClassNotFoundException {
              if (unavailableClassName.equals(name)) {
                  throw new ClassNotFoundException(name);
              }
  
              return super.loadClass(name);
          }
      }
