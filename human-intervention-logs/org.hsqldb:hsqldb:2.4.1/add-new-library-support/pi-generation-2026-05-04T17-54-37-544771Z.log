[tool-call] delta {"path":"tests/src/org.hsqldb/hsqldb/2.4.1/src/test/java/org_hsqldb/hsqldb/JDBCDataSourceFactoryTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_hsqldb.hsqldb;\n\nimport static org.junit.jupiter.api.Assertions.assertEquals;\nimport static org.junit.jupiter.api.Assertions.assertFalse;\nimport static org.junit.jupiter.api.Assertions.assertInstanceOf;\n\nimport java.sql.Connection;\nimport java.util.Properties;\n\nimport javax.naming.Reference;\nimport javax.naming.StringRefAddr;\nimport javax.sql.DataSource;\n\nimport org.hsqldb.jdbc.JDBCCommonDataSource;\nimport org.hsqldb.jdbc.JDBCDataSource;\nimport org.hsqldb.jdbc.JDBCDataSourceFactory;\nimport org.junit.jupiter.api.Test;\n\npublic class JDBCDataSourceFactoryTest {\n    @Test\n    public void createDataSourceBuildsConnectableDataSourceFromProperties() throws Exception {\n        Properties properties = new Properties();\n        String database = inMemoryDatabase(\"factory-create\");\n\n        properties.setProperty(\"database\", database);\n        properties.setProperty(\"user\", \"SA\");\n        properties.setProperty(\"password\", \"\");\n        properties.setProperty(\"loginTimeout\", \"3\");\n\n        DataSource dataSource = JDBCDataSourceFactory.createDataSource(properties);\n        JDBCDataSource jdbcDataSource = assertInstanceOf(JDBCDataSource.class, dataSource);\n\n        assertEquals(database, jdbcDataSource.getDatabase());\n        assertEquals(\"SA\", jdbcDataSource.getUser());\n        assertEquals(3, jdbcDataSource.getLoginTimeout());\n        assertCanOpenConnection(dataSource);\n    }\n\n    @Test\n    public void getObjectInstanceBuildsDataSourceFromJndiReference() throws Exception {\n        String database = inMemoryDatabase(\"factory-jndi\");\n        Reference reference = new Reference(JDBCDataSource.class.getName());\n\n        reference.add(new StringRefAddr(\"database\", database));\n        reference.add(new StringRefAddr(\"user\", \"SA\"));\n        reference.add(new StringRefAddr(\"password\", \"\"));\n        reference.add(new StringRefAddr(\"loginTimeout\", \"4\"));\n\n        Object object = new JDBCDataSourceFactory().getObjectInstance(reference, null, null, null);\n        JDBCCommonDataSource commonDataSource = assertInstanceOf(JDBCCommonDataSource.class, object);\n        DataSource dataSource = assertInstanceOf(DataSource.class, object);\n\n        assertEquals(database, commonDataSource.getDatabase());\n        assertEquals(\"SA\", commonDataSource.getUser());\n        assertEquals(4, commonDataSource.getLoginTimeout());\n        assertCanOpenConnection(dataSource);\n    }\n\n    private static String inMemoryDatabase(String name) {\n        return \"mem:\" + name + System.nanoTime() + \";shutdown=true\";\n    }\n\n    private static void assertCanOpenConnection(DataSource dataSource) throws Exception {\n        try (Connection connection = dataSource.getConnection()) {\n            assertFalse(connection.isClosed());\n        }\n    }\n}\n"}
