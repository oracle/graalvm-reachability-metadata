      public String getNetworkProtocol() {
          return networkProtocol;
      }
  
      /**
       * Retrieves the server name attribute. <p>
       *
       * @return the server name attribute
       */
      public String getServerName() {
          return serverName;
      }
  
      /**
       * Synonym for getUrl().
