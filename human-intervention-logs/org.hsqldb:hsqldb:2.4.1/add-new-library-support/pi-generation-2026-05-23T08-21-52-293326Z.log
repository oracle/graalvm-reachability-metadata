[tool-call] delta {"path":"tests/src/org.hsqldb/hsqldb/2.4.1/src/test/java/org_hsqldb/hsqldb/ArrayUtilTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_hsqldb.hsqldb;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport org.hsqldb.lib.ArrayUtil;\nimport org.junit.jupiter.api.Test;\n\npublic class ArrayUtilTest {\n    @Test\n    void duplicateArrayCreatesDistinctArrayWithSameComponentTypeAndValues() {\n        String[] source = new String[] { \"alpha\", \"beta\", \"gamma\" };\n\n        Object duplicated = ArrayUtil.duplicateArray(source);\n\n        assertThat(duplicated).isInstanceOf(String[].class);\n        assertThat(duplicated).isNotSameAs(source);\n        assertThat((String[]) duplicated).containsExactly(\"alpha\", \"beta\", \"gamma\");\n    }\n\n    @Test\n    void resizeArrayAlwaysCreatesNewArrayAndPreservesFittingElements() {\n        int[] source = new int[] { 3, 5, 8 };\n\n        Object enlarged = ArrayUtil.resizeArray(source, 5);\n        Object shortened = ArrayUtil.resizeArray(source, 2);\n\n        assertThat(enlarged).isInstanceOf(int[].class);\n        assertThat(enlarged).isNotSameAs(source);\n        assertThat((int[]) enlarged).containsExactly(3, 5, 8, 0, 0);\n        assertThat((int[]) shortened).containsExactly(3, 5);\n    }\n\n    @Test\n    void resizeArrayIfDifferentReusesSameSizedArrayAndCopiesWhenSizeChanges() {\n        Integer[] source = new Integer[] { Integer.valueOf(1), Integer.valueOf(2) };\n\n        Object sameSize = ArrayUtil.resizeArrayIfDifferent(source, source.length);\n        Object differentSize = ArrayUtil.resizeArrayIfDifferent(source, 3);\n\n        assertThat(sameSize).isSameAs(source);\n        assertThat(differentSize).isInstanceOf(Integer[].class);\n        assertThat(differentSize).isNotSameAs(source);\n        assertThat((Integer[]) differentSize).containsExactly(Integer.valueOf(1), Integer.valueOf(2), null);\n    }\n\n    @Test\n    void toAdjustedArrayAddsAndRemovesElementsWithoutChangingSourceArray() {\n        String[] source = new String[] { \"first\", \"third\" };\n\n        Object added = ArrayUtil.toAdjustedArray(source, \"second\", 1, 1);\n        Object removed = ArrayUtil.toAdjustedArray((String[]) added, null, 0, -1);\n\n        assertThat(added).isInstanceOf(String[].class);\n        assertThat((String[]) added).containsExactly(\"first\", \"second\", \"third\");\n        assertThat((String[]) removed).containsExactly(\"second\", \"third\");\n        assertThat(source).containsExactly(\"first\", \"third\");\n    }\n}\n"}
