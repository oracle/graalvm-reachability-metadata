ampleValue(\"second\");\n        SampleValue[] source = new SampleValue[] { first, second };\n\n        Object sameSize = ArrayUtil.resizeArrayIfDifferent(source, source.length);\n        Object differentSize = ArrayUtil.resizeArrayIfDifferent(source, 3);\n\n        assertThat(sameSize).isSameAs(source);\n        assertThat(differentSize).isInstanceOf(SampleValue[].class);\n        assertThat(differentSize).isNotSameAs(source);\n        assertThat((SampleValue[]) differentSize).containsExactly(first, second, null);\n    }\n\n    @Test\n    void toAdjustedArrayAddsAndRemovesElementsWithoutChangingSourceArray() {\n        SampleValue first = new SampleValue(\"first\");\n        SampleValue second = new SampleValue(\"second\");\n        SampleValue third = new SampleValue(\"third\");\n        SampleValue[] source = new SampleValue[] { first, third };\n\n        Object added = ArrayUtil.toAdjustedArray(source, second, 1, 1);\n        Object removed = ArrayUtil.toAdjustedArray((SampleValue[]) added, null, 0, -1);\n\n        assertThat(added).isInstanceOf(SampleValue[].class);\n        assertThat((SampleValue[]) added).containsExactly(first, second, third);\n        assertThat((SampleValue[]) removed).containsExactly(second, third);\n        assertThat(source).containsExactly(first, third);\n    }\n\n    private static final class SampleValue {\n        private final String name;\n\n        private SampleValue(String name) {\n            this.name = name;\n        }\n\n        @Override\n        public String toString() {\n            return name;\n        }\n    }\n}"}]}
