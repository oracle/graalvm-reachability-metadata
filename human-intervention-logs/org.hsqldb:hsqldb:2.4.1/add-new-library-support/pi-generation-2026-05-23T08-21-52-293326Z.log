Changes() {\n        Integer[] source = new Integer[] { Integer.valueOf(1), Integer.valueOf(2) };\n\n        Object sameSize = ArrayUtil.resizeArrayIfDifferent(source, source.length);\n        Object differentSize = ArrayUtil.resizeArrayIfDifferent(source, 3);\n\n        assertThat(sameSize).isSameAs(source);\n        assertThat(differentSize).isInstanceOf(Integer[].class);\n        assertThat(differentSize).isNotSameAs(source);\n        assertThat((Integer[]) differentSize).containsExactly(Integer.valueOf(1), Integer.valueOf(2), null);\n    }\n\n    @Test\n    void toAdjustedArrayAddsAndRemovesElementsWithoutChangingSourceArray() {\n        String[] source = new String[] { \"first\", \"third\" };\n\n        Object added = ArrayUtil.toAdjustedArray(source, \"second\", 1, 1);\n        Object removed = ArrayUtil.toAdjustedArray((String[]) added, null, 0, -1);\n\n        assertThat(added).isInstanceOf(String[].class);\n        assertThat((String[]) added).containsExactly(\"first\", \"second\", \"third\");\n        assertThat((String[]) removed).containsExactly(\"second\", \"third\");\n        assertThat(source).containsExactly(\"first\", \"third\");\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1010, "output": 782, "cacheRead": 17408, "cacheWrite": 0, "totalTokens": 19200, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1779524489246, "responseId": "resp_041c75c84a3d5367016a116389aad081979b440cd0e7437506"}}
