ges\";\n    private static final String PROPERTIES_NAME_IS_NULL_OR_EMPTY = \"properties name is null or empty\";\n\n    @Test\n    public void loadsBundleWithDefaultClassLoaderWhenNoClassLoaderIsSpecified() {\n        ResourceBundle bundle = ResourceBundleHandler.getBundle(SQL_STATE_MESSAGES, Locale.ROOT, null);\n\n        assertBundleContainsExpectedMessage(bundle);\n    }\n\n    @Test\n    public void loadsBundleThroughSuppliedApplicationClassLoader() {\n        ResourceBundle bundle = ResourceBundleHandler.getBundle(\n                SQL_STATE_MESSAGES,\n                Locale.ROOT,\n                ResourceBundleHandlerTest.class.getClassLoader());\n\n        assertBundleContainsExpectedMessage(bundle);\n    }\n\n    @Test\n    public void fallsBackToDefaultClassLoaderWhenSuppliedClassLoaderCannotFindBundle() {\n        ResourceBundle bundle = ResourceBundleHandler.getBundle(\n                SQL_STATE_MESSAGES,\n                Locale.ROOT,\n                ClassLoader.getPlatformClassLoader());\n\n        assertBundleContainsExpectedMessage(bundle);\n    }\n\n    @Test\n    public void usesLegacyFallbackWhenClassLoaderAwareGetBundleMethodIsUnavailable() throws Exception {\n        try (StaticFieldState ignored = replaceNewGetBundleMethod(null)) {\n            ResourceBundle bundle = ResourceBundleHandler.getBundle(\n                    SQL_STATE_MESSAGES,\n                    Locale.ROOT,\n                    ResourceBundleHandlerTest.class.getClassLoader());\n\n            assertBundleContainsExpectedMessage(bundle);\n        }\n    }\n\n    private static StaticFieldState replaceNewGetBundleMethod(Method replacement) throws Exception {\n        Field field = ResourceBundleHandler.class.getDeclaredField(\"newGetBundleMethod\");\n        field.setAccessible(true);\n\n        Unsafe unsafe = unsafe();\n        Object base = unsafe.staticFieldBase(field);\n        long offset = unsafe.staticFieldOffset(field);\n        Method previous = (Method) unsafe.getObject