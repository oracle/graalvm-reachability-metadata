  package org_hsqldb.hsqldb;
  
  import static org.junit.jupiter.api.Assertions.assertEquals;
  import static org.junit.jupiter.api.Assertions.assertNotNull;
  
  import java.lang.reflect.Field;
  import java.lang.reflect.Method;
  import java.util.Locale;
  import java.util.ResourceBundle;
  
  import org.hsqldb.resources.ResourceBundleHandler;
  import org.junit.jupiter.api.Test;
  
  import sun.misc.Unsafe;
  
  public class ResourceBundleHandlerTest {
      private static final String SQL_STATE_MESSAGES = "org.hsqldb.resources.sql-state-messages";
      private static final String PROPERTIES_NAME_IS_NULL_OR_EMPTY = "properties name is null or empty";
  
      @Test
      public void loadsBundleWithDefaultClassLoaderWhenNoClassLoaderIsSpecified() {
          ResourceBundle bundle = ResourceBundleHandler.getBundle(SQL_STATE_MESSAGES, Locale.ROOT, null);
  
          assertBundleContainsExpectedMessage(bundle);
      }
  
      @Test
      public void loadsBundleThroughSuppliedApplicationClassLoader() {
          ResourceBundle bundle = ResourceBundleHandler.getBundle(
                  SQL_STATE_MESSAGES,
                  Locale.ROOT,
                  ResourceBundleHandlerTest.class.getClassLoader());
  
          assertBundleContainsExpectedMessage(bundle);
      }
  
      @Test
      public void fallsBackToDefaultClassLoaderWhenSuppliedClassLoaderCannotFindBundle() {
          ResourceBundle bundle = ResourceBundleHandler.getBundle(
                  SQL_STATE_MESSAGES,
                  Locale.ROOT,
                  ClassLoader.getPlatformClassLoader());
  
          assertBundleContainsExpectedMessage(bundle);
      }
  
      @Test
      public void usesLegacyFallbackWhenClassLoaderAwareGetBundleMethodIsUnavailable() throws Exception {
          try (StaticFieldState ignored = replaceNewGetBundleMethod(null)) {
              ResourceBundle bundle = ResourceBundleHandler.getBundle(
                      SQL_STATE_MESSAGES,
                      Locale.ROOT,
                      ResourceBundleHandlerTest.class.getClassLoader());
  
              assertBundleContainsExpectedMessage(bundle);
          }
      }
  
      private static StaticFieldState replaceNewGetBundleMethod(Method replacement) throws Exception {
          Field field = ResourceBundleHandler.class.getDeclaredField("newGetBundleMethod");
          field.setAccessible(true);
  
          Unsafe unsafe = unsafe();
          Object base = unsafe.staticFieldBase(field);
          long offset = unsafe.staticFieldOffset(field);
          Method previous = (Method) unsafe.getObjectVolatile(base, offset);
  
          unsafe.putObjectVolatile(base, offset, replacement);
  
          return new StaticFieldState(unsafe, base, offset, previous);
      }
  
      private static Unsafe unsafe() throws Exception {
          Field unsafeField = Unsafe.class.getDeclaredField("theUnsafe");
          unsafeField.setAccessible(true);
  
          return (Unsafe) unsafeField.get(null);
      }
  
      private static void assertBundleContainsExpectedMessage(ResourceBundle bundle) {
          assertNotNull(bundle);
          assertEquals(PROPERTIES_NAME_IS_NULL_OR_EMPTY, bundle.getString("0028"));
      }
  
      private static final class StaticFieldState implements AutoCloseable {
          private final Unsafe unsafe;
          private final Object base;
          private final long offset;
          private final Method previous;
  
          private StaticFieldState(Unsafe unsafe, Object base, long offset, Method previous) {
              this.unsafe = unsafe;
              this.base = base;
              this.offset = offset;
              this.previous = previous;
          }
  
          @Override
          public void close() {
              unsafe.putObjectVolatile(base, offset, previous);
          }
      }
  }
