;\n        }\n    }\n\n    private static StaticFieldState replaceNewGetBundleMethod(Method replacement) throws Exception {\n        Field field = ResourceBundleHandler.class.getDeclaredField(\"newGetBundleMethod\");\n        field.setAccessible(true);\n\n        Unsafe unsafe = unsafe();\n        Object base = unsafe.staticFieldBase(field);\n        long offset = unsafe.staticFieldOffset(field);\n        Method previous = (Method) unsafe.getObjectVolatile(base, offset);\n\n        unsafe.putObjectVolatile(base, offset, replacement);\n\n        return new StaticFieldState(unsafe, base, offset, previous);\n    }\n\n    private static Unsafe unsafe() throws Exception {\n        Field unsafeField = Unsafe.class.getDeclaredField(\"theUnsafe\");\n        unsafeField.setAccessible(true);\n\n        return (Unsafe) unsafeField.get(null);\n    }\n\n    private static void assertBundleContainsExpectedMessage(ResourceBundle bundle) {\n        assertNotNull(bundle);\n        assertEquals(PROPERTIES_NAME_IS_NULL_OR_EMPTY, bundle.getString(\"0028\"));\n    }\n\n    private static final class StaticFieldState implements AutoCloseable {\n        private final Unsafe unsafe;\n        private final Object base;\n        private final long offset;\n        private final Method previous;\n\n        private StaticFieldState(Unsafe unsafe, Object base, long offset, Method previous) {\n            this.unsafe = unsafe;\n            this.base = base;\n            this.offset = offset;\n            this.previous = previous;\n        }\n\n        @Override\n        public void close() {\n            unsafe.putObjectVolatile(base, offset, previous);\n        }\n    }\n}\n"}]}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1552, "output": 1741, "cacheRead": 25600, "cacheWrite": 0, "totalTokens": 28893, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777918734238, "responseId": "res