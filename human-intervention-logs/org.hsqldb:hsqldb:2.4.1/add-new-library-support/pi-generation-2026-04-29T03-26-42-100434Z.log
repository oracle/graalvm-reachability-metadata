       * or reopened by the close(int closemode) method during a
       * "shutdown compact". Closes the log if there is an error.
       */
      void reopen() {
  
          boolean isNew = false;
  
          setState(DATABASE_OPENING);
  
          try {
              createObjectStructures();
  
              // completed metadata
              logger.open();
  
              isNew = logger.isNewDatabase;
  
