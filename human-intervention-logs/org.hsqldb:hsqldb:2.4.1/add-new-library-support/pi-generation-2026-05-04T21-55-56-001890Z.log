  package org_hsqldb.hsqldb;
  
  import org.hsqldb.jdbc.JDBCDriver;
  import org.hsqldb.lib.FileAccess;
  import org.hsqldb.persist.RandomAccessInterface;
  import org.junit.jupiter.api.Test;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.IOException;
  import java.io.InputStream;
  import java.io.OutputStream;
  import java.sql.Connection;
  import java.sql.ResultSet;
  import java.sql.SQLException;
  import java.sql.Statement;
  import java.util.Properties;
  import java.util.concurrent.atomic.AtomicReference;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class LoggerTest {
      private static final JDBCDriver DRIVER = new JDBCDriver();
      private static final AtomicReference<String> LAST_STORAGE_KEY = new AtomicReference<>();
      private static final String STORAGE_KEY = "custom-storage-key";
  
      @Test
      void opensDatabaseWithCustomFileAccessLoadedFromContextClassLoader() throws Exception {
          LAST_STORAGE_KEY.set(null);
  
          try (Connection connection = openDatabase()) {
              assertQueryWorks(connection);
              assertThat(LAST_STORAGE_KEY).hasValue(STORAGE_KEY);
              shutdown(connection);
          }
      }
  
      @Test
      void opensDatabaseWithCustomFileAccessAfterContextClassLoaderFallback() throws Exception {
          ClassLoader originalClassLoader = Thread.currentThread().getContextClassLoader();
  
          LAST_STORAGE_KEY.set(null);
          Thread.currentThread().setContextClassLoader(new RejectingClassLoader(originalClassLoader,
                  CustomFileAccess.class.getName(), RandomAccessInterface.class.getName()));
  
          try (Connection connection = openDatabase()) {
              assertQueryWorks(connection);
              assertThat(LAST_STORAGE_KEY).hasValue(STORAGE_KEY);
              shutdown(connection);
          } finally {
              Thread.currentThread().setContextClassLoader(originalClassLoader);
          }
      }
  
      private static Connection openDatabase() throws SQLException {
          Properties properties = new Properties();
  
          properties.setProperty("user", "SA");
          properties.setProperty("password", "");
          properties.setProperty("fileaccess_class_name", CustomFileAccess.class.getName());
          properties.setProperty("storage_class_name", RandomAccessInterface.class.getName());
          properties.setProperty("storage_key", STORAGE_KEY);
  
          return DRIVER.connect("jdbc:hsqldb:mem:" + uniqueDatabaseName(), properties);
      }
  
      private static String uniqueDatabaseName() {
          return "logger_" + Long.toUnsignedString(System.nanoTime());
      }
  
      private static void assertQueryWorks(Connection connection) throws SQLException {
          try (Statement statement = connection.createStatement();
                  ResultSet resultSet = statement.executeQuery("VALUES 1")) {
              assertThat(resultSet.next()).isTrue();
              assertThat(resultSet.getInt(1)).isEqualTo(1);
          }
      }
  
      private static void shutdown(Connection connection) throws SQLException {
          try (Statement statement = connection.createStatement()) {
              statement.execute("SHUTDOWN");
          }
      }
  
      public static final class CustomFileAccess implements FileAccess {
          public CustomFileAccess(Object storageKey) {
              LAST_STORAGE_KEY.set(String.valueOf(storageKey));
          }
  
          @Override
          public InputStream openInputStreamElement(String streamName) {
              return new ByteArrayInputStream(new byte[0]);
          }
  
          @Override
          public OutputStream openOutputStreamElement(String streamName, boolean append) {
              return new ByteArrayOutputStream();
          }
  
          @Override
          public boolean isStreamElement(String elementName) {
              return false;
          }
  
          @Override
          public void createParentDirs(String filename) {
          }
  
          @Override
          public void removeElement(String filename) {
          }
  
          @Override
          public void renameElement(String oldName, String newName, boolean copyIfFailed) {
          }
  
          @Override
          public FileSync getFileSync(OutputStream os) throws IOException {
              return os::flush;
          }
      }
  
      private static final class RejectingClassLoader extends ClassLoader {
          private final String firstRejectedClassName;
          private final String secondRejectedClassName;
  
          private RejectingClassLoader(ClassLoader parent, String firstRejectedClassName,
                  String secondRejectedClassName) {
              super(parent);
              this.firstRejectedClassName = firstRejectedClassName;
              this.secondRejectedClassName = secondRejectedClassName;
          }
  
          @Override
          protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {
              if (firstRejectedClassName.equals(name) || secondRejectedClassName.equals(name)) {
                  throw new ClassNotFoundException(name);
              }
  
              return super.loadClass(name, resolve);
          }
