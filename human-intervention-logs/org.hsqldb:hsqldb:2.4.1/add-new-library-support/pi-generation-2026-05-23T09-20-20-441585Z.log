[tool-call] delta {"path":"tests/src/org.hsqldb/hsqldb/2.4.1/src/test/java/org_hsqldb/hsqldb/MainInvokerTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_hsqldb.hsqldb;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayOutputStream;\nimport java.io.PrintStream;\nimport java.nio.charset.StandardCharsets;\n\nimport org.hsqldb.cmdline.sqltool.Calculator;\nimport org.hsqldb.util.MainInvoker;\nimport org.junit.jupiter.api.Test;\n\npublic class MainInvokerTest {\n    @Test\n    void invokeRunsLibraryMainMethodWithArguments() throws Exception {\n        PrintStream originalOut = System.out;\n        ByteArrayOutputStream outputBytes = new ByteArrayOutputStream();\n\n        try (PrintStream capturedOut = new PrintStream(outputBytes, true, StandardCharsets.UTF_8.name())) {\n            System.setOut(capturedOut);\n\n            MainInvoker.invoke(Calculator.class.getName(), new String[] { \"(one + two) * three\" });\n        } finally {\n            System.setOut(originalOut);\n        }\n\n        String output = outputBytes.toString(StandardCharsets.UTF_8.name());\n\n        assertThat(output).contains(System.lineSeparator() + \"9\" + System.lineSeparator());\n    }\n}\n"}
