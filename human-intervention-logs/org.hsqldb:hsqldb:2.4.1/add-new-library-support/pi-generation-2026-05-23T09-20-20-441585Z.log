          private Atom(MathOp op) { this.op = op; }
          private Atom(long val) { this.val = val; }
          public MathOp op;
          public long val;
          public String toString() {
              return (op == null) ? Long.toString(val) : op.toString();
          }
      }
  
      public String toString() {
          return atoms.toString();
      }
  
