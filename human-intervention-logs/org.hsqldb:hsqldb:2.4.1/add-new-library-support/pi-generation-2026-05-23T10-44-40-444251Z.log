[tool-call] delta {"path":"tests/src/org.hsqldb/hsqldb/2.4.1/src/test/java/org_hsqldb/hsqldb/ResourceBundleHandlerTest.java","edits":[{"oldText":"import java.util.Locale;\nimport java.util.ResourceBundle;\n\nimport org.hsqldb.resources.ResourceBundleHandler;\nimport org.junit.jupiter.api.Test;\n\npublic class ResourceBundleHandlerTest {\n    private static final String SQL_STATE_MESSAGES = \"org.hsqldb.resources.sql-state-messages\";\n\n    @Test\n    void getBundleLoadsHsqldbResourceWithDefaultClassLoader() {\n        ResourceBundle bundle = ResourceBundleHandler.getBundle(SQL_STATE_MESSAGES, Locale.ROOT, null);\n\n        assertThat(bundle.getString(\"0001\")).contains(\"required\");\n    }\n\n    @Test\n    void getBundleLoadsHsqldbResourceWithExplicitClassLoader() {\n        ClassLoader classLoader = ResourceBundleHandler.class.getClassLoader();\n\n        ResourceBundle bundle = ResourceBundleHandler.getBundle(SQL_STATE_MESSAGES, Locale.ROOT, classLoader);\n\n        assertThat(bundle.getString(\"0001\")).contains(\"required\");\n    }\n}\n","newText":"import java.util.ListResourceBundle;\nimport java.util.Locale;\nimport java.util.ResourceBundle;\n\nimport org.hsqldb.resources.ResourceBundleHandler;\nimport org.junit.jupiter.api.Test;\n\npublic class ResourceBundleHandlerTest {\n    @Test\n    void getBundleLoadsClassBundleWithDefaultClassLoader() {\n        ResourceBundle bundle = ResourceBundleHandler.getBundle(Messages.class.getName(), Locale.ROOT, null);\n\n        assertThat(bundle.getString(\"message\")).isEqualTo(\"loaded\");\n    }\n\n    @Test\n    void getBundleLoadsClassBundleWithExplicitClassLoader() {\n        ClassLoader classLoader = ResourceBundleHandlerTest.class.getClassLoader();\n\n        ResourceBundle bundle = ResourceBundleHandler.getBundle(Messages.class.getName(), Locale.ROOT, classLoader);\n\n        assertThat(bundle.getString(\"message\")).isEqualTo(\"loaded\");\n    }\n\n    public static class Messages extends ListResourceBundle {\n        @Override\n        protected Object[][] getContents() {\n            return new Object[][] {\n                {\"message\", \"loaded\"}\n            };\n        }\n    }\n}\n"}]}
