",\n            \"--password\", \"\",\n            \"--noexit\"\n        });\n\n        assertThat(databaseManagerFrame()).isNotNull();\n        try (Connection connection = DriverManager.getConnection(url + \";ifexists=true\", \"SA\", \"\")) {\n            assertThat(connection.isValid((int) Duration.ofSeconds(2).getSeconds())).isTrue();\n        } finally {\n            closeOpenWindows();\n        }\n    }\n\n    private static Frame databaseManagerFrame() {\n        for (Window window : Window.getWindows()) {\n            if (window instanceof Frame) {\n                Frame frame = (Frame) window;\n\n                if (\"HSQL Database Manager\".equals(frame.getTitle()) && frame.isDisplayable()) {\n                    return frame;\n                }\n            }\n        }\n\n        return null;\n    }\n\n    private static void closeOpenWindows() {\n        for (Window window : Window.getWindows()) {\n            if (window.isDisplayable()) {\n                window.dispatchEvent(new WindowEvent(window, WindowEvent.WINDOW_CLOSING));\n                window.dispose();\n            }\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 555, "output": 1132, "cacheRead": 28672, "cacheWrite": 0, "totalTokens": 30359, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1779533556817, "responseId": "resp_0413721a0db94a26016a1186f55f68819fb1ef01689b831c93"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_zdlUcsLe5t5vp2MHrSiy8wvJ|fc_0413721a0db94a26016a1186ff406c819fac7c471a6c33a461", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2305 bytes to tests/src/org.hsqldb/hsqldb/2.4.1/src/test/java/org_hsqldb/hsqldb/ConnectionDialogTest.java"}], "isError": false, "timestamp": 1779533569269}]}
