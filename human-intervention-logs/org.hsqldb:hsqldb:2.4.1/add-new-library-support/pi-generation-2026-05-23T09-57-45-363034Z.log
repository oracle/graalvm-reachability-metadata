;\n\npublic class HsqlArrayListTest {\n    @Test\n    void addBeyondTypedBackingArrayResizesWithSameComponentType() {\n        HsqlArrayList list = new HsqlArrayList(new String[] { \"alpha\" }, 1);\n\n        list.add(\"beta\");\n\n        assertThat(list.size()).isEqualTo(2);\n        assertThat(list.getArray()).isInstanceOf(String[].class);\n        assertThat((String[]) list.getArray()).containsExactly(\"alpha\", \"beta\");\n    }\n\n    @Test\n    void toArrayCopiesElementsUsingBackingArrayComponentType() {\n        HsqlArrayList list = new HsqlArrayList(new String[] { \"alpha\", \"beta\", \"gamma\" }, 3);\n\n        Object[] copy = list.toArray();\n        Object[] rangeCopy = list.toArray(1, 3);\n        Object typedCopy = list.toArray(new String[1]);\n\n        assertThat(copy).isInstanceOf(String[].class);\n        assertThat((String[]) copy).containsExactly(\"alpha\", \"beta\", \"gamma\");\n        assertThat(rangeCopy).isInstanceOf(String[].class);\n        assertThat((String[]) rangeCopy).containsExactly(\"beta\", \"gamma\");\n        assertThat(typedCopy).isInstanceOf(String[].class);\n        assertThat((String[]) typedCopy).containsExactly(\"alpha\", \"beta\", \"gamma\");\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1147, "output": 991, "cacheRead": 15872, "cacheWrite": 0, "totalTokens": 18010, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1779530247448, "responseId": "resp_0264ccd843566237016a117a07f354819399e61bc0ff5c14ae"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_Yr08s0DsbNMRDpJRjlyzk7Q2|fc_0264ccd843566237016a117a10f9408193a20bc3737500d04b", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1516 bytes to tests/src/org.hsqldb/hsqldb/2.4.1/src/test/java/org_hsqldb/hsqldb/HsqlArrayListTest.java"}], "isError": false, "timestamp": 1779530258588}]}
