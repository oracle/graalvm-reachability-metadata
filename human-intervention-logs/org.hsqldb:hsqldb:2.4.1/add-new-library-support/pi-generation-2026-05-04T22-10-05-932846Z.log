ception;\nimport java.sql.Statement;\nimport java.util.Properties;\nimport java.util.concurrent.atomic.AtomicReference;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class LoggerTest {\n    private static final JDBCDriver DRIVER = new JDBCDriver();\n    private static final AtomicReference<String> LAST_STORAGE_KEY = new AtomicReference<>();\n    private static final String STORAGE_KEY = \"custom-storage-key\";\n\n    @Test\n    void opensDatabaseWithCustomFileAccessLoadedFromContextClassLoader() throws Exception {\n        LAST_STORAGE_KEY.set(null);\n\n        try (Connection connection = openDatabase()) {\n            assertQueryWorks(connection);\n            assertThat(LAST_STORAGE_KEY).hasValue(STORAGE_KEY);\n            shutdown(connection);\n        }\n    }\n\n    @Test\n    void opensDatabaseWithCustomFileAccessAfterContextClassLoaderFallback() throws Exception {\n        ClassLoader originalClassLoader = Thread.currentThread().getContextClassLoader();\n\n        LAST_STORAGE_KEY.set(null);\n        Thread.currentThread().setContextClassLoader(new RejectingClassLoader(originalClassLoader,\n                CustomFileAccess.class.getName(), RandomAccessInterface.class.getName()));\n\n        try (Connection connection = openDatabase()) {\n            assertQueryWorks(connection);\n            assertThat(LAST_STORAGE_KEY).hasValue(STORAGE_KEY);\n            shutdown(connection);\n        } finally {\n            Thread.currentThread().setContextClassLoader(originalClassLoader);\n        }\n    }\n\n    private static Connection openDatabase() throws SQLException {\n        Properties properties = new Properties();\n\n        properties.setProperty(\"user\", \"SA\");\n        properties.setProperty(\"password\", \"\");\n        properties.setProperty(\"fileaccess_class_name\", CustomFileAccess.class.getName());\n        properties.setProperty(\"storage_class_name\", RandomAccessInterface.class.getName());\n        properties.setProperty(\"storage_key\", STORAGE_KEY);\n\n        return DRIVER.connect(\"jdbc:hsqldb:mem:\" + uniqueDatabaseName(), properties);\n    }\n\n    private static String uniqueDatabaseName() {\n        return \"logger_\" + Long.toUnsignedString(System.nanoTime());\n    }\n\n    private static void assertQueryWorks(Connection connection) throws SQLException {\n        try (Statement statement = connection.createStatement();\n                ResultSet resultSet = statement.executeQuery(\"VALUES 1\")) {\n            assertThat(resultSet.next()).isTrue();\n            assertThat(resultSet.getInt(1)).isEqualTo(1);\n        }\n    }\n\n    private static void shutdown(Connection connection) throws SQLException {\n        try (Statement statement = connection.createStatement()) {\n            statement.execute(\"SHUTDOWN\");\n        }\n    }\n\n    public static final class CustomFileAccess implements FileAccess {\n        public CustomFileAccess(Object storageKey) {\n            LAST_STORAGE_KEY.set(String.valueOf(storageKey));\n        }\n\n        @Override\n        public InputStream openInputStreamElement(String streamName) {\n            return new ByteArrayInputStream(new byte[0]);\n        }\n\n        @Override\n        public OutputStream openOutputStreamElement(String streamName, boolean append) {\n            return new ByteArrayOutputStream();\n        }\n\n        @Override\n        public boolean isStreamElement(String elementName) {\n            return false;\n        }\n\n        @Override\n        public void createParentDirs(String filename) {\n        }\n\n        @Override\n        public void removeElement(String filename) {\n        }\n\n        @Override\n        public void renameElement(String oldName, String newName, boolean copyIfFailed) {\n        }\n\n        @Override\n        public FileSync getFileSync(OutputStream os) throws IOException {\n            return os::flush;\n        }\n    }\n\n    private static final class RejectingClassLoader extends 