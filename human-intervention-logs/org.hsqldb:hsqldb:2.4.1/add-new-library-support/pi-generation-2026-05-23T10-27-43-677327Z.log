qldb:file:\" + sourceDatabasePath\n    45\t                + \";hsqldb.lock_file=false\";\n    46\t        String expectedPayload = \"cached table row from resource database\";\n    47\t\n    48\t        createFileDatabaseWithCachedTable(sourceUrl, expectedPayload);\n    49\t\n    50\t        String resourceDatabasePath = \"/org_hsqldb/hsqldb/generated-rafile-in-jar-db-\"\n    51\t                + Long.toUnsignedString(System.nanoTime());\n    52\t        Map<String, byte[]> resources = databaseResources(sourceDatabasePath, resourceDatabasePath);\n    53\t        Thread currentThread = Thread.currentThread();\n    54\t        ClassLoader originalClassLoader = currentThread.getContextClassLoader();\n    55\t        ResourceProvidingClassLoader resourceClassLoader = new ResourceProvidingClassLoader(\n    56\t                originalClassLoader,\n    57\t                resources);\n    58\t\n    59\t        try {\n    60\t            currentThread.setContextClassLoader(resourceClassLoader);\n    61\t\n    62\t            String resourceUrl = \"jdbc:hsqldb:res:\" + resourceDatabasePath.substring(1);\n    63\t\n    64\t            try (Connection connection = openConnection(resourceUrl);\n    65\t                    Statement statement = connection.createStatement()) {\n    66\t                Database database = databaseSession(connection).getDatabase();\n    67\t                DataFileCache dataFileCache = new DataFileCache(database, database.getPath());\n    68\t\n    69\t                try {\n    70\t                    dataFileCache.open(true);\n    71\t                } finally {\n    72\t                    dataFileCache.release();\n    73\t                }\n    74\t\n    75\t                try (ResultSet resultSet = statement.executeQuery(\n    76\t                        \"SELECT payload FROM cached_items WHERE id = 1\")) {\n    77\t                    assertThat(resultSet.next()).isTrue();\n    78\t                    assertThat(resultSet.getString(1)).isEqualTo(expectedPayload);\n    79\t                }\n    80\t\n    81\t                statement.execute(\"SHUTDOWN\");\n    82\t            }\n    83\t        } finally {\n    84\t            currentThread.setContextClassLoader(originalClassLoader);\n    85\t        }\n    86\t\n    87\t        assertThat(resourceClassLoader.requested(resourceDatabasePath + \".data\")).isTrue();\n    88\t        assertThat(resourceClassLoader.streamRequested(resourceDatabasePath + \".data\")).isTrue();\n    89\t    }\n    90\t\n    91\t    private static void createFileDatabaseWithCachedTable(String url, String expectedPayload) throws Exception {\n    92\t        try (Connection connection = openConnection(url); Statement statement = connection.createStatement()) {\n    93\t            statement.execute(\"CREATE CACHED TABLE cached_items (id INTEGER PRIMARY KEY, payload VARCHAR(128))\");\n    94\t\n    95\t            try (PreparedStatement preparedStatement = connection.prepareStatement(\n    96\t                    \"INSERT INTO cached_items VALUES (?, ?)\")) {\n    97\t                preparedStatement.setInt(1, 1);\n    98\t                preparedStatement.setString(2, expectedPayload);\n    99\t                preparedStatement.executeUpdate();\n   100\t            }\n   101\t\n   102\t            statement.execute(\"CHECKPOINT\");\n   103\t            statement.execute(\"SHUTDOWN\");\n   104\t        }\n   105\t    }\n   106\t\n   107\t    private static Map<String, byte[]> databaseResources(\n   108\t            String sourceDatabasePath,\n   109\t            String resourceDatabasePath) throws IOException {\n   110\t        Map<String, byte[]> resources = new HashMap<>();\n   111\t\n   112\t        addDatabaseResource(resources, sourceDatabasePath, resourceDatabasePath, \".properties\");\n   113\t        addDatabaseResource(resources, sourceDatabasePath, resourceDatabasePath, \".script\");\n   114\t        addDatabaseResource(resources, sourceDatabasePath, resourceDatabasePath, \".data\");\n   115\t        addDatabaseResource(resources, sourceDatabasePath, resourceDatabasePath, \".backup\");\n   116\t        addDatabaseResource(resources, sourceDatabasePath, resourceDatabasePath, \".log\");\n   117\t\n   118\t        assertThat(resources).containsKey(resourceDatabasePath + \".data\");\n   119\t\n   120\t        return resources;\n   121\t    }\n   122\t\n   123\t    private static void addDatabaseResource(\n   124\t            Map<String, byte[]> resources,\n   125\t            String sourceDatabasePath,\n   126\t            String resourceDatabasePath,\n   127\t            String extension) throws IOException {\n   128\t        Path sourcePath = Path.of(sourceDatabasePath + extension);\n   129\t\n   130\t        if (Files.exists(sourcePath)) {\n   131\t            byte[] bytes = Files.readAllBytes(sourcePath);\n   132\t\n   133\t            resources.put(resourceDatabasePath + extension, bytes);\n   134\t            resources.put(resourceDatabasePath.substring(1) + extension, bytes);\n   135\t        }\n   136\t    }\n   137\t\n   138\t    private static Connection openConnection(String url) throws Exception {\n   139\t        JDBCDataSource dataSource = new JDBCDataSource();\n   140\t\n   141\t        dataSource.setUrl(url);\n   142\t        dataSource.setUser(\"SA\");\n   143\t        dataSource.setPassword(\"\");\n   144\t\n   145\t        return dataSource.getConnection();\n   146\t    }\n   147\t\n   148\t    private static Session databaseSession(Connection connection) throws Exception {\n   149\t        JDBCConnection hsqldbConnection = connection.unwrap(JDBCConnection.class);\n   150\t\n   151\t        return (Session) hsqldbConnection.getSession();\n   152\t    }\n   153\t\n   154\t    private static final class ResourceProvidingClassLoader extends ClassLoader {\n   155\t        private final Map<String, byte[]> resources;\n   156\t        private final Set<String> requestedNames = ConcurrentHashMap.newKeySet();\n   157\t        private final Set<String> streamRequestedNames = ConcurrentHashMap.newKeySet();\n   158\t\n   159\t        ResourceProvidingClassLoader(ClassLoader parent, Map<String, byte[]> resources) {\n   160\t            super(parent);\n   161\t            this.resources = new HashMap<>(resources);\n   162\t        }\n   163\t\n   164\t        @Override\n   165\t        public URL getResource(String name) {\n   166\t            requestedNames.add(name);\n   167\t\n   168\t            byte[] resourceBytes = resources.get(name);\n   169\t\n   170\t            if (resourceBytes == null) {\n   171\t                return super.getResource(name);\n   172\t            }\n   173\t\n   174\t            try {\n   175\t                return new URL(null, \"memory://rafile-in-jar/\" + name,\n   176\t                        new ResourceStreamHandler(resourceBytes));\n   177\t            } catch (IOException e) {\n   178\t                throw new IllegalStateException(e);\n   179\t            }\n   180\t        }\n   181\t\n   182\t        @Override\n   183\t        public InputStream getResourceAsStream(String name) {\n   184\t            requestedNames.add(name);\n   185\t\n   186\t            byte[] resourceBytes = resources.get(name);\n   187\t\n   188\t            if (resourceBytes == null) {\n   189\t                return super.getResourceAsStream(name);\n   190\t            }\n   191\t\n   192\t            streamRequestedNames.add(name);\n   193\t\n   194\t            return new ByteArrayInputStream(resourceBytes);\n   195\t        }\n   196\t\n   197\t        boolean requested(String name) {\n   198\t            return requestedNames.contains(name);\n   199\t        }\n   200\t\n   201\t        boolean streamRequested(String name) {\n   202\t            return streamRequestedNames.contains(name);\n   203\t        }\n   204\t    }\n   205\t\n   206\t    private static final class ResourceStreamHandler extends URLStreamHandler {\n   207\t        private final byte[] resourceBytes;\n   208\t\n   209\t        ResourceStreamHandler(byte[] resourceBytes) {\n   210\t            this.resourceBytes = resourceBytes.clone();\n   211\t        }\n   212\t\n   213\t        @Override\n   214\t        protected URLConnection openConnection(URL url) {\n   215\t            return new URLConnection(url) {\n   216\t                @Override\n   217\t                public void connect() {\n   218\t                    connected = true;\n   219\t                }\n   220\t\n"}], "isError": false, "timestamp": 1779532176886}]}
