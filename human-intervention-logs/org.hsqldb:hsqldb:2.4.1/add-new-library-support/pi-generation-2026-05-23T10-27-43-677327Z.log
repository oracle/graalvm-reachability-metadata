     187	
     188	            if (resourceBytes == null) {
     189	                return super.getResourceAsStream(name);
     190	            }
     191	
     192	            streamRequestedNames.add(name);
     193	
     194	            return new ByteArrayInputStream(resourceBytes);
     195	        }
     196	
     197	        boolean requested(String name) {
     198	            return requestedNames.contains(name);
     199	        }
     200	
     201	        boolean streamRequested(String name) {
     202	            return streamRequestedNames.contains(name);
     203	        }
     204	    }
