      91	    private static void createFileDatabaseWithCachedTable(String url, String expectedPayload) throws Exception {
      92	        try (Connection connection = openConnection(url); Statement statement = connection.createStatement()) {
      93	            statement.execute("CREATE CACHED TABLE cached_items (id INTEGER PRIMARY KEY, payload VARCHAR(128))");
