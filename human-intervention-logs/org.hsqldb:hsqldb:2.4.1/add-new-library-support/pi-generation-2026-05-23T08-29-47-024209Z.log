tClassLoader).isNotNull();\n\n        try {\n            currentThread.setContextClassLoader(testClassLoader);\n\n            assertThat(fileAccess.isStreamElement(resourceName)).isFalse();\n            assertThatExceptionOfType(FileNotFoundException.class)\n                    .isThrownBy(() -> fileAccess.openInputStreamElement(resourceName))\n                    .withMessage(resourceName);\n        } finally {\n            currentThread.setContextClassLoader(originalClassLoader);\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1779525162964}]}
