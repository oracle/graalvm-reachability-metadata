[tool-call] delta {"path":"tests/src/org.hsqldb/hsqldb/2.4.1/src/test/java/org_hsqldb/hsqldb/FileUtilInnerFileAccessResTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_hsqldb.hsqldb;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.InputStream;\n\nimport org.hsqldb.lib.FileAccess;\nimport org.hsqldb.lib.FileUtil;\nimport org.junit.jupiter.api.Test;\n\npublic class FileUtilInnerFileAccessResTest {\n    @Test\n    void resourceAccessOpensPackageRelativeLibraryResource() throws Exception {\n        FileAccess fileAccess = FileUtil.getFileAccess(true);\n        String resourceName = \"tar/rb.properties\";\n\n        assertThat(fileAccess.isStreamElement(resourceName)).isTrue();\n\n        try (InputStream inputStream = fileAccess.openInputStreamElement(resourceName)) {\n            assertThat(inputStream.read()).isNotEqualTo(-1);\n        }\n    }\n\n    @Test\n    void resourceAccessFallsBackToContextClassLoaderForClasspathResource() throws Exception {\n        FileAccess fileAccess = FileUtil.getFileAccess(true);\n        String resourceName = \"org/hsqldb/resources/webserver-content-types.properties\";\n        Thread currentThread = Thread.currentThread();\n        ClassLoader originalClassLoader = currentThread.getContextClassLoader();\n        ClassLoader testClassLoader = FileUtilInnerFileAccessResTest.class.getClassLoader();\n\n        assertThat(testClassLoader).isNotNull();\n\n        try {\n            currentThread.setContextClassLoader(testClassLoader);\n\n            assertThat(fileAccess.isStreamElement(resourceName)).isTrue();\n\n            try (InputStream inputStream = fileAccess.openInputStreamElement(resourceName)) {\n                assertThat(inputStream.read()).isNotEqualTo(-1);\n            }\n        } finally {\n            currentThread.setContextClassLoader(originalClassLoader);\n        }\n    }\n}\n"}
