[tool-call] delta {"path":"tests/src/org.hsqldb/hsqldb/2.4.1/src/test/java/org_hsqldb/hsqldb/FrameworkLoggerTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_hsqldb.hsqldb;\n\nimport org.hsqldb.lib.FrameworkLogger;\nimport org.junit.jupiter.api.Test;\n\nimport java.util.logging.Level;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class FrameworkLoggerTest {\n    private static final String LOGGER_NAME = \"org_hsqldb.hsqldb.FrameworkLoggerTest\";\n\n    @Test\n    void logsThroughLog4jBackendWhenLog4jIsAvailable() {\n        assertThat(org.apache.log4j.Logger.getLogger(LOGGER_NAME)).isNotNull();\n\n        FrameworkLogger.clearLoggers(LOGGER_NAME);\n        FrameworkLogger logger = FrameworkLogger.getLog(LOGGER_NAME);\n\n        logger.info(\"FrameworkLogger log4j info message\");\n        logger.log(Level.WARNING, \"FrameworkLogger log4j warning message\", new IllegalStateException(\"warning\"));\n        logger.privlog(Level.FINER, \"FrameworkLogger log4j private message\", null, 1, FrameworkLoggerTest.class);\n        logger.enduserlog(Level.SEVERE, \"FrameworkLogger log4j end-user message\");\n\n        assertThat(FrameworkLogger.report()).contains(LOGGER_NAME);\n    }\n}\n"}
