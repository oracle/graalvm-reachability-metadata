      public static Type getParameterSQLType(Class c) {
  
          String name;
          int    typeCode;
  
          if (c == null) {
              throw Error.runtimeError(ErrorCode.U_S0500, "Types");
          }
  
          if (Void.TYPE.equals(c)) {
