          initNewFile();
          initBuffers();
  
          if (database.logger.getDataFileSpaces() > 0) {
              spaceManager = new DataSpaceManagerBlocks(this);
          } else {
              spaceManager = new DataSpaceManagerSimple(this, false);
          }
      }
  
