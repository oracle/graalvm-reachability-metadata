ption {\n        Throwable cause = exception.getCause();\n        if (cause instanceof Exception) {\n            throw (Exception) cause;\n        }\n        if (cause instanceof Error) {\n            throw (Error) cause;\n        }\n        throw new AssertionError(cause);\n    }\n\n    private static Throwable rootCause(Throwable throwable) {\n"}]}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 2443, "output": 1787, "cacheRead": 64000, "cacheWrite": 0, "totalTokens": 68230, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777926921174, "responseId": "resp_0fb63b68099e23620169f9030a3d0c819caebb1bc66dbe3038"}}
