[tool-call] delta {"path":"tests/src/net.java.dev.jna/jna-platform/5.3.1/src/test/java/net_java_dev_jna/jna_platform/ConvertTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage net_java_dev_jna.jna_platform;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport com.sun.jna.platform.win32.COM.util.CallbackProxy;\nimport com.sun.jna.platform.win32.COM.util.IComEnum;\nimport com.sun.jna.platform.win32.COM.util.IComEventCallbackListener;\nimport com.sun.jna.platform.win32.COM.util.ObjectFactory;\nimport com.sun.jna.platform.win32.COM.util.annotation.ComEventCallback;\nimport com.sun.jna.platform.win32.COM.util.annotation.ComInterface;\nimport com.sun.jna.platform.win32.OaIdl.DISPID;\nimport com.sun.jna.platform.win32.OleAuto;\nimport com.sun.jna.platform.win32.OleAuto.DISPPARAMS;\nimport com.sun.jna.platform.win32.Variant;\nimport com.sun.jna.platform.win32.Variant.VARIANT;\nimport com.sun.jna.platform.win32.WinDef.LCID;\nimport com.sun.jna.platform.win32.WinDef.WORD;\nimport com.sun.jna.platform.win32.COM.IDispatchCallback;\nimport com.sun.jna.ptr.IntByReference;\nimport java.lang.reflect.Method;\nimport org.junit.jupiter.api.Test;\n\npublic class ConvertTest {\n    @Test\n    void toVariantUsesVariantConstructorMatchingUnhandledJnaValueType() throws Exception {\n        IntByReference value = new IntByReference(123);\n\n        VARIANT variant = invokeConvertToVariant(value);\n\n        assertThat(variant.getVarType().intValue()).isEqualTo(Variant.VT_INT | Variant.VT_BYREF);\n        assertThat(variant.getValue()).isInstanceOf(IntByReference.class);\n        assertThat(((IntByReference) variant.getValue()).getValue()).isEqualTo(123);\n    }\n\n    @Test\n    void callbackArgumentConversionMapsNumericVariantToComEnumConstant() {\n        EnumCallbackListener listener = new EnumCallbackListener();\n        CallbackProxy callbackProxy = new CallbackProxy(new ObjectFactory(), EnumEvents.class, listener);\n        DISPPARAMS.ByReference parameters = new DISPPARAMS.ByReference();\n        parameters.setArgs(new VARIANT[] {new VARIANT(2L)});\n        parameters.setRgdispidNamedArgs(new DISPID[0]);\n\n        callbackProxy.Invoke(new DISPID(7), null, new LCID(0), new WORD(OleAuto.DISPATCH_METHOD), parameters, null, null, null);\n\n        assertThat(listener.receivedValue).isEqualTo(SampleComEnum.SECOND);\n    }\n\n    private static VARIANT invokeConvertToVariant(Object value) throws Exception {\n        Class<?> convertType = Class.forName(\"com.sun.jna.platform.win32.COM.util.Convert\");\n        Method toVariant = convertType.getDeclaredMethod(\"toVariant\", Object.class);\n        toVariant.setAccessible(true);\n        return (VARIANT) toVariant.invoke(null, value);\n    }\n\n    @ComInterface(iid = \"11111111-2222-3333-4444-555555555555\")\n    public interface EnumEvents {\n        @ComEventCallback(dispid = 7)\n        void onEnumValue(SampleComEnum value);\n    }\n\n    public enum SampleComEnum implements IComEnum {\n        FIRST(1),\n        SECOND(2);\n\n        private final long value;\n\n        SampleComEnum(long value) {\n            this.value = value;\n        }\n\n        @Override\n        public long getValue() {\n            return value;\n        }\n    }\n\n    public static final class EnumCallbackListener implements EnumEvents, IComEventCallbackListener {\n        private SampleComEnum receivedValue;\n\n        @Override\n        public void onEnumValue(SampleComEnum value) {\n            this.receivedValue = value;\n        }\n\n        @Override\n        public void setDispatchCallbackListener(IDispatchCallback dispatchCallback) {\n        }\n\n        @Override\n        public void errorReceivingCallbackEvent(String message, Exception exception) {\n            throw new AssertionError(message, exception);\n        }\n    }\n}\n"}
