[tool-call] delta {"path":"tests/src/net.java.dev.jna/jna-platform/5.3.1/src/test/java/net_java_dev_jna/jna_platform/ConvertTest.java","edits":[{"oldText":"import com.sun.jna.platform.win32.COM.util.CallbackProxy;\nimport com.sun.jna.platform.win32.COM.util.IComEnum;\nimport com.sun.jna.platform.win32.COM.util.IComEventCallbackListener;\nimport com.sun.jna.platform.win32.COM.util.ObjectFactory;\nimport com.sun.jna.platform.win32.COM.util.annotation.ComEventCallback;\nimport com.sun.jna.platform.win32.COM.util.annotation.ComInterface;\nimport com.sun.jna.platform.win32.OaIdl.DISPID;\nimport com.sun.jna.platform.win32.OleAuto;\nimport com.sun.jna.platform.win32.OleAuto.DISPPARAMS;\nimport com.sun.jna.platform.win32.Variant;\nimport com.sun.jna.platform.win32.Variant.VARIANT;\nimport com.sun.jna.platform.win32.WinDef.LCID;\nimport com.sun.jna.platform.win32.WinDef.WORD;\nimport com.sun.jna.platform.win32.COM.IDispatchCallback;\n","newText":"import com.sun.jna.platform.win32.COM.util.IComEnum;\nimport com.sun.jna.platform.win32.Variant;\nimport com.sun.jna.platform.win32.Variant.VARIANT;\n"},{"oldText":"    @Test\n    void callbackArgumentConversionMapsNumericVariantToComEnumConstant() {\n        EnumCallbackListener listener = new EnumCallbackListener();\n        CallbackProxy callbackProxy = new CallbackProxy(new ObjectFactory(), EnumEvents.class, listener);\n        DISPPARAMS.ByReference parameters = new DISPPARAMS.ByReference();\n        parameters.setArgs(new VARIANT[] {new VARIANT(2L)});\n        parameters.setRgdispidNamedArgs(new DISPID[0]);\n\n        callbackProxy.Invoke(new DISPID(7), null, new LCID(0), new WORD(OleAuto.DISPATCH_METHOD), parameters, null, null, null);\n\n        assertThat(listener.receivedValue).isEqualTo(SampleComEnum.SECOND);\n    }\n\n    private static VARIANT invokeConvertToVariant(Object value) throws Exception {\n","newText":"    @Test\n    void toComEnumUsesEnumValuesMethodToFindMatchingConstant() throws Exception {\n        SampleC