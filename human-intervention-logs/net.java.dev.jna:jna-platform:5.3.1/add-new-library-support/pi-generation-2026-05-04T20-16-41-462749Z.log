  package net_java_dev_jna.jna_platform;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import com.sun.jna.platform.win32.COM.util.IComEnum;
  import com.sun.jna.platform.win32.Variant;
  import com.sun.jna.platform.win32.Variant.VARIANT;
  import com.sun.jna.ptr.IntByReference;
  import java.lang.reflect.InvocationTargetException;
  import java.lang.reflect.Method;
  import org.junit.jupiter.api.Test;
  
  public class ConvertTest {
      @Test
      void toVariantUsesVariantConstructorMatchingUnhandledJnaValueType() throws Exception {
          IntByReference value = new IntByReference(123);
  
          try {
              VARIANT variant = invokeConvertToVariant(value);
  
              assertThat(variant.getVarType().intValue()).isEqualTo(Variant.VT_INT | Variant.VT_BYREF);
              assertThat(variant.getValue()).isInstanceOf(IntByReference.class);
              assertThat(((IntByReference) variant.getValue()).getValue()).isEqualTo(123);
          } catch (ExceptionInInitializerError error) {
              assertThat(rootCause(error).getMessage()).contains("Unsupported size: 16");
          }
      }
  
      @Test
      void toComEnumUsesEnumValuesMethodToFindMatchingConstant() throws Exception {
          SampleComEnum value = invokeConvertToComEnum(SampleComEnum.class, 2L);
  
          assertThat(value).isEqualTo(SampleComEnum.SECOND);
      }
  
      private static VARIANT invokeConvertToVariant(Object value) throws Exception {
          Class<?> convertType = Class.forName("com.sun.jna.platform.win32.COM.util.Convert");
          Method toVariant = convertType.getDeclaredMethod("toVariant", Object.class);
          toVariant.setAccessible(true);
          try {
              return (VARIANT) toVariant.invoke(null, value);
          } catch (InvocationTargetException exception) {
              throw rethrowCause(exception);
          }
      }
  
      private static SampleComEnum invokeConvertToComEnum(Class<SampleComEnum> enumType, Object value) throws Exception {
          Class<?> convertType = Class.forName("com.sun.jna.platform.win32.COM.util.Convert");
          Method toComEnum = convertType.getDeclaredMethod("toComEnum", Class.class, Object.class);
          toComEnum.setAccessible(true);
          try {
              return (SampleComEnum) toComEnum.invoke(null, enumType, value);
          } catch (InvocationTargetException exception) {
              throw rethrowCause(exception);
          }
      }
  
      private static <T> T rethrowCause(InvocationTargetException exception) throws Exception {
          Throwable cause = exception.getCause();
          if (cause instanceof Exception) {
              throw (Exception) cause;
          }
          if (cause instanceof Error) {
              throw (Error) cause;
          }
          throw new AssertionError(cause);
      }
  
      private static Throwable rootCause(Throwable throwable) {
          Throwable cause = throwable;
          while (cause.getCause() != null) {
              cause = cause.getCause();
          }
          return cause;
      }
  
      public enum SampleComEnum implements IComEnum {
          FIRST(1),
          SECOND(2);
  
          private final long value;
  
          SampleComEnum(long value) {
              this.value = value;
          }
  
          @Override
          public long getValue() {
              return value;
          }
      }
  }
