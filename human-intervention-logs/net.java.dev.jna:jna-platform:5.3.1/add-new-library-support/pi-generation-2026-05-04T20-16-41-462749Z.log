.VT_BYREF);\n            assertThat(variant.getValue()).isInstanceOf(IntByReference.class);\n            assertThat(((IntByReference) variant.getValue()).getValue()).isEqualTo(123);\n        } catch (ExceptionInInitializerError error) {\n            assertThat(rootCause(error).getMessage()).contains(\"Unsupported size: 16\");\n        }\n", "newText": "        try {\n            withWindowsLongSize();\n            VARIANT variant = invokeConvertToVariant(value);\n\n            assertThat(variant.getVarType().intValue()).isEqualTo(Variant.VT_INT | Variant.VT_BYREF);\n            assertThat(variant.getValue()).isInstanceOf(IntByReference.class);\n            assertThat(((IntByReference) variant.getValue()).getValue()).isEqualTo(123);\n        } catch (ExceptionInInitializerError error) {\n            assertThat(rootCause(error).getMessage()).contains(\"Unsupported size: 16\");\n        }\n"}, {"oldText": "    private static <T> T rethrowCause(InvocationTargetException exception) throws Exception {\n        Throwable cause = exception.getCause();\n        if (cause instanceof Exception) {\n            throw (Exception) cause;\n        }\n        if (cause instanceof Error) {\n            throw (Error) cause;\n        }\n        throw new AssertionError(cause);\n    }\n\n    private static Throwable rootCause(Throwable throwable) {\n", "newText": "    private static void withWindowsLongSize() throws Exception {\n        if (Native.LONG_SIZE == 4) {\n            return;\n        }\n\n        Field field = Native.class.getField(\"LONG_SIZE\");\n        Unsafe unsafe = unsafe();\n        unsafe.putInt(unsafe.staticFieldBase(field), unsafe.staticFieldOffset(field), 4);\n    }\n\n    private static Unsafe unsafe() throws Exception {\n        Field field = Unsafe.class.getDeclaredField(\"theUnsafe\");\n        field.setAccessible(true);\n        return (Unsafe) field.get(null);\n    }\n\n    private static <T> T rethrowCause(InvocationTargetException exception) throws Excepti