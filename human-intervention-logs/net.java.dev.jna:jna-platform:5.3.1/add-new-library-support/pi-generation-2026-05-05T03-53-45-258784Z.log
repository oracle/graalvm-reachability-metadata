[tool-call] delta {"path":"tests/src/net.java.dev.jna/jna-platform/5.3.1/src/test/java/net_java_dev_jna/jna_platform/WindowUtilsInnerMacWindowUtilsAnonymous1Test.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage net_java_dev_jna.jna_platform;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.awt.Frame;\nimport java.awt.Window;\nimport java.lang.reflect.Field;\n\nimport org.junit.jupiter.api.Test;\n\nimport com.sun.jna.platform.WindowUtils;\n\nimport sun.misc.Unsafe;\n\npublic class WindowUtilsInnerMacWindowUtilsAnonymous1Test {\n    @Test\n    void macWindowAlphaUsesPeerSetAlphaWhenDisplayableWindowHasPeerAccessor() throws Exception {\n        String originalOsName = System.getProperty(\"os.name\");\n        AlphaPeer.reset();\n        System.setProperty(\"os.name\", \"Mac OS X\");\n        try {\n            WindowUtils.setWindowAlpha(allocatedAlphaWindow(), 0.42f);\n        }\n        finally {\n            restoreProperty(\"os.name\", originalOsName);\n        }\n\n        assertThat(AlphaPeer.getAlpha()).isEqualTo(0.42f);\n        assertThat(AlphaPeer.getSetAlphaCalls()).isEqualTo(1);\n    }\n\n    private static Window allocatedAlphaWindow() throws InstantiationException, ReflectiveOperationException {\n        return (Window) unsafe().allocateInstance(AlphaWindow.class);\n    }\n\n    private static Unsafe unsafe() throws ReflectiveOperationException {\n        Field unsafeField = Unsafe.class.getDeclaredField(\"theUnsafe\");\n        unsafeField.setAccessible(true);\n        return (Unsafe) unsafeField.get(null);\n    }\n\n    private static void restoreProperty(String name, String value) {\n        if (value == null) {\n            System.clearProperty(name);\n        }\n        else {\n            System.setProperty(name, value);\n        }\n    }\n\n    @SuppressWarnings(\"serial\")\n    public static final class AlphaWindow extends Window {\n        private AlphaWindow() {\n            super((Frame) null);\n        }\n\n        @Override\n        public boolean isDisplayable() {\n            return true;\n        }\n\n        public AlphaPeer getPeer() {\n            return AlphaPeer.INSTANCE;\n        }\n    }\n\n    public static final class AlphaPeer {\n        private static final AlphaPeer INSTANCE = new AlphaPeer();\n        private static int setAlphaCalls;\n        private static float alpha;\n\n        public void setAlpha(float newAlpha) {\n            setAlphaCalls++;\n            alpha = newAlpha;\n        }\n\n        private static void reset() {\n            setAlphaCalls = 0;\n            alpha = -1.0f;\n        }\n\n        private static int getSetAlphaCalls() {\n            return setAlphaCalls;\n        }\n\n        private static float getAlpha() {\n            return alpha;\n        }\n    }\n}\n"}
