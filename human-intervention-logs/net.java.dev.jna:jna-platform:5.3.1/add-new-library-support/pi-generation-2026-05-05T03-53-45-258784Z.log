erty(name);\n        }\n        else {\n            System.setProperty(name, value);\n        }\n    }\n\n    @SuppressWarnings(\"serial\")\n    public static final class AlphaWindow extends Window {\n        private AlphaWindow() {\n            super((Frame) null);\n        }\n\n        @Override\n        public boolean isDisplayable() {\n            return true;\n        }\n\n        public AlphaPeer getPeer() {\n            return AlphaPeer.INSTANCE;\n        }\n    }\n\n    public static final class AlphaPeer {\n        private static final AlphaPeer INSTANCE = new AlphaPeer();\n        private static int setAlphaCalls;\n        private static float alpha;\n\n        public void setAlpha(float newAlpha) {\n            setAlphaCalls++;\n            alpha = newAlpha;\n        }\n\n        private static void reset() {\n            setAlphaCalls = 0;\n            alpha = -1.0f;\n        }\n\n        private static int getSetAlphaCalls() {\n            return setAlphaCalls;\n        }\n\n        private static float getAlpha() {\n            return alpha;\n        }\n    }\n}\n"}
