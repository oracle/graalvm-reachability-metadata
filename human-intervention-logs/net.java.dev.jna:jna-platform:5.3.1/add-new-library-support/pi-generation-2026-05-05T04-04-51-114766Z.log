[tool-call] delta {"path":"tests/src/net.java.dev.jna/jna-platform/5.3.1/src/test/java/net_java_dev_jna/jna_platform/ConvertTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage net_java_dev_jna.jna_platform;\n\nimport java.lang.reflect.Method;\n\nimport com.sun.jna.platform.win32.Variant;\nimport com.sun.jna.platform.win32.WinDef;\nimport com.sun.jna.platform.win32.COM.util.IComEnum;\n\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ConvertTest {\n    @Test\n    void toVariantUsesMatchingPublicVariantConstructorForWinDefValue() throws Exception {\n        Variant.VARIANT variant = invokeToVariant(new WinDef.BYTE(123));\n\n        assertThat(variant.getVarType().intValue()).isEqualTo(Variant.VT_UI1);\n        assertThat(variant.byteValue()).isEqualTo((byte) 123);\n    }\n\n    @Test\n    void toComEnumUsesEnumValuesMethodToResolveMatchingValue() throws Exception {\n        SampleComEnum result = invokeToComEnum(SampleComEnum.class, SampleComEnum.SECOND.getValue());\n\n        assertThat(result).isSameAs(SampleComEnum.SECOND);\n    }\n\n    private static Variant.VARIANT invokeToVariant(Object value) throws Exception {\n        Method method = convertClass().getDeclaredMethod(\"toVariant\", Object.class);\n        method.setAccessible(true);\n        return (Variant.VARIANT) method.invoke(null, value);\n    }\n\n    private static <T extends IComEnum> T invokeToComEnum(Class<T> enumType, Object value) throws Exception {\n        Method method = convertClass().getDeclaredMethod(\"toComEnum\", Class.class, Object.class);\n        method.setAccessible(true);\n        return enumType.cast(method.invoke(null, enumType, value));\n    }\n\n    private static Class<?> convertClass() throws ClassNotFoundException {\n        return Class.forName(\"com.sun.jna.platform.win32.COM.util.Convert\");\n    }\n\n    public enum SampleComEnum implements IComEnum {\n        FIRST(1),\n        SECOND(2);\n\n        private final long value;\n\n        SampleComEnum(long value) {\n            this.value = value;\n        }\n\n        @Override\n        public long getValue() {\n            return value;\n        }\n    }\n}\n"}
