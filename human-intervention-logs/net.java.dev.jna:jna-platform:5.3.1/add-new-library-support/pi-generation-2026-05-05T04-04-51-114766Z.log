[tool-call] delta {"path":"tests/src/net.java.dev.jna/jna-platform/5.3.1/src/test/java/net_java_dev_jna/jna_platform/ConvertTest.java","edits":[{"oldText":"import com.sun.jna.platform.win32.Variant;\nimport com.sun.jna.platform.win32.WinDef;\nimport com.sun.jna.platform.win32.COM.util.IComEnum;\n","newText":"import com.sun.jna.platform.win32.OaIdl.DISPID;\nimport com.sun.jna.platform.win32.Variant;\nimport com.sun.jna.platform.win32.WinDef;\nimport com.sun.jna.platform.win32.WinError;\nimport com.sun.jna.platform.win32.WinNT.HRESULT;\nimport com.sun.jna.platform.win32.COM.IDispatch;\nimport com.sun.jna.platform.win32.COM.util.IComEnum;\nimport com.sun.jna.platform.win32.COM.util.ProxyObject;\n"},{"oldText":"            Variant.VARIANT variant = invokeToVariant(new WinDef.BYTE(123));\n\n            assertThat(variant.getVarType().intValue()).isEqualTo(Variant.VT_UI1);\n            assertThat(variant.byteValue()).isEqualTo((byte) 123);\n","newText":"            CapturingProxyObject proxyObject = allocatedProxyObject();\n            proxyObject.setProperty(new DISPID(7), new WinDef.BYTE(123));\n\n            Variant.VARIANT variant = proxyObject.getCapturedArgument();\n            assertThat(variant.getVarType().intValue()).isEqualTo(Variant.VT_UI1);\n            assertThat(variant.byteValue()).isEqualTo((byte) 123);\n"},{"oldText":"    private static Variant.VARIANT invokeToVariant(Object value) throws Exception {\n        Method method = convertClass().getDeclaredMethod(\"toVariant\", Object.class);\n        method.setAccessible(true);\n        return (Variant.VARIANT) invoke(method, value);\n    }\n\n    private static <T extends IComEnum> T invokeToComEnum(Class<T> enumType, Object value) throws Exception {\n","newText":"    private static CapturingProxyObject allocatedProxyObject() throws InstantiationException, ReflectiveOperationException {\n        return (CapturingProxyObject) unsafe().allocateInstance(CapturingProxyObject.class);\n    }\n\n    private static <T extends IComEnum> T invokeToComEnum(Class<T> enumType, Object value) throws Exception {\n"},{"oldText":"    public enum SampleComEnum implements IComEnum {\n","newText":"    public static final class CapturingProxyObject extends ProxyObject {\n        private Variant.VARIANT[] capturedArguments;\n\n        private CapturingProxyObject() {\n            super(null, null, null);\n        }\n\n        @SuppressWarnings(\"deprecation\")\n        @Override\n        protected HRESULT oleMethod(int nType, Variant.VARIANT.ByReference pvResult, IDispatch dispatch,\n                DISPID dispId, Variant.VARIANT[] arguments) {\n            capturedArguments = arguments;\n            return WinError.S_OK;\n        }\n\n        private Variant.VARIANT getCapturedArgument() {\n            assertThat(capturedArguments).hasSize(1);\n            return capturedArguments[0];\n        }\n    }\n\n    public enum SampleComEnum implements IComEnum {\n"}]}
