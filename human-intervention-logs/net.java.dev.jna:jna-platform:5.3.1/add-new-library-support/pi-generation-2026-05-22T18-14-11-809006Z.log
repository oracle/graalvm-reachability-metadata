                  Window w = (Window)c;
                  OSXMaskingContentPane content = installMaskingPane(w);
                  content.setMask(shape);
                  setBackgroundTransparent(w, shape != MASK_NONE, "setWindowMask");
              }
              else {
                  // not yet implemented
              }
          }
  
