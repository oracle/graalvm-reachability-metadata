[tool-call] delta {"path":"tests/src/net.java.dev.jna/jna-platform/5.3.1/src/test/java/net_java_dev_jna/jna_platform/WindowUtilsInnerMacWindowUtilsAnonymous1Test.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage net_java_dev_jna.jna_platform;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.awt.AWTError;\nimport java.awt.Color;\nimport java.awt.GraphicsConfiguration;\nimport java.awt.GraphicsDevice;\nimport java.awt.Rectangle;\nimport java.awt.Transparency;\nimport java.awt.Window;\nimport java.awt.geom.AffineTransform;\nimport java.awt.image.ColorModel;\n\nimport org.junit.jupiter.api.Test;\n\nimport com.sun.jna.platform.WindowUtils;\n\npublic class WindowUtilsInnerMacWindowUtilsAnonymous1Test {\n    @Test\n    void setWindowAlphaUsesMacPeerAlphaMethod() {\n        String originalOsName = System.getProperty(\"os.name\");\n        String originalHeadless = System.getProperty(\"java.awt.headless\");\n        System.setProperty(\"os.name\", \"Mac OS X\");\n        System.setProperty(\"java.awt.headless\", \"false\");\n\n        try {\n            AlphaTestWindow window = new AlphaTestWindow();\n\n            WindowUtils.setWindowAlpha(window, 0.375f);\n\n            assertThat(window.getPeer().alpha).isEqualTo(0.375f);\n        } finally {\n            restoreProperty(\"os.name\", originalOsName);\n            restoreProperty(\"java.awt.headless\", originalHeadless);\n        }\n    }\n\n    private static void restoreProperty(String key, String value) {\n        if (value == null) {\n            System.clearProperty(key);\n        } else {\n            System.setProperty(key, value);\n        }\n    }\n\n    public static final class AlphaTestWindow extends Window {\n        private final AlphaPeer peer = new AlphaPeer();\n\n        private AlphaTestWindow() throws AWTError {\n            super((Window) null, new TestGraphicsConfiguration());\n        }\n\n        @Override\n        public boolean isDisplayable() {\n            return true;\n        }\n\n        public AlphaPeer getPeer() {\n            return peer;\n        }\n    }\n\n    public static final class AlphaPeer {\n        private float alpha = 1.0f;\n\n        public void setAlpha(float alpha) {\n            this.alpha = alpha;\n        }\n    }\n\n    private static final class TestGraphicsConfiguration extends GraphicsConfiguration {\n        private final GraphicsDevice device = new TestGraphicsDevice(this);\n\n        @Override\n        public GraphicsDevice getDevice() {\n            return device;\n        }\n\n        @Override\n        public ColorModel getColorModel() {\n            return ColorModel.getRGBdefault();\n        }\n\n        @Override\n        public ColorModel getColorModel(int transparency) {\n            return transparency == Transparency.OPAQUE ? ColorModel.getRGBdefault() : ColorModel.getRGBdefault();\n        }\n\n        @Override\n        public AffineTransform getDefaultTransform() {\n            return new AffineTransform();\n        }\n\n        @Override\n        public AffineTransform getNormalizingTransform() {\n            return new AffineTransform();\n        }\n\n        @Override\n        public Rectangle getBounds() {\n            return new Rectangle(0, 0, 640, 480);\n        }\n    }\n\n    private static final class TestGraphicsDevice extends GraphicsDevice {\n        private final GraphicsConfiguration configuration;\n\n        private TestGraphicsDevice(GraphicsConfiguration configuration) {\n            this.configuration = configuration;\n        }\n\n        @Override\n        public int getType() {\n            return TYPE_RASTER_SCREEN;\n        }\n\n        @Override\n        public String getIDstring() {\n            return \"test\";\n        }\n\n        @Override\n        public GraphicsConfiguration[] getConfigurations() {\n            return new GraphicsConfiguration[] { configuration };\n        }\n\n        @Override\n        public GraphicsConfiguration getDefaultConfiguration() {\n            return configuration;\n        }\n    }\n}\n"}
