cessible(true);\n        return (InvocationHandler) constructor.newInstance(new MessageLoopThread(), delegate);\n    }\n\n    private static <T> T newProxy(Class<T> type, InvocationHandler handler) {\n        Object proxy = Proxy.newProxyInstance(\n                DdemlUtilInnerMessageLoopWrapperTest.class.getClassLoader(),\n                new Class<?>[] { type },\n                handler);\n        return type.cast(proxy);\n    }\n\n    public interface DelegateOperations {\n        DdemlUtil.IDdeConnection connection();\n    }\n\n    private static class DelegateOperationsImpl implements DelegateOperations {\n        private final DdemlUtil.IDdeConnection connection;\n\n        DelegateOperationsImpl(DdemlUtil.IDdeConnection connection) {\n            this.connection = connection;\n        }\n\n        @Override\n        public DdemlUtil.IDdeConnection connection() {\n            return connection;\n        }\n    }\n}\n"}
