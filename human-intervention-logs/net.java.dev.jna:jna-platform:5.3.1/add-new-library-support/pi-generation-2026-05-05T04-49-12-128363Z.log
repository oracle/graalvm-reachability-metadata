  package net_java_dev_jna.jna_platform;
  
  import java.lang.reflect.Field;
  import java.lang.reflect.InvocationTargetException;
  import java.lang.reflect.Method;
  
  import com.sun.jna.Native;
  import com.sun.jna.platform.win32.Variant;
  import com.sun.jna.platform.win32.WinDef;
  import com.sun.jna.platform.win32.COM.util.IComEnum;
  
  import org.junit.jupiter.api.Test;
  
  import sun.misc.Unsafe;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ConvertTest {
      @Test
      void toVariantUsesMatchingPublicVariantConstructorForWinDefValue() throws Exception {
          int originalLongSize = Native.LONG_SIZE;
          setNativeLongSize(Integer.BYTES);
          try {
              Variant.VARIANT variant = invokeToVariant(new WinDef.BYTE(123));
              assertThat(variant.getVarType().intValue()).isEqualTo(Variant.VT_UI1);
              assertThat(variant.byteValue()).isEqualTo((byte) 123);
          }
          finally {
              setNativeLongSize(originalLongSize);
          }
      }
  
      @Test
      void toComEnumUsesEnumValuesMethodToResolveMatchingValue() throws Exception {
          SampleComEnum result = invokeToComEnum(SampleComEnum.class, SampleComEnum.SECOND.getValue());
  
          assertThat(result).isSameAs(SampleComEnum.SECOND);
      }
  
      private static Variant.VARIANT invokeToVariant(Object value) throws Exception {
          Method method = convertClass().getDeclaredMethod("toVariant", Object.class);
          method.setAccessible(true);
          return (Variant.VARIANT) invoke(method, value);
      }
  
      private static <T extends IComEnum> T invokeToComEnum(Class<T> enumType, Object value) throws Exception {
          Method method = convertClass().getDeclaredMethod("toComEnum", Class.class, Object.class);
          method.setAccessible(true);
          return enumType.cast(invoke(method, enumType, value));
      }
  
      private static Object invoke(Method method, Object... arguments) throws Exception {
          try {
              return method.invoke(null, arguments);
          }
          catch (InvocationTargetException exception) {
              Throwable cause = exception.getCause();
              if (cause instanceof Error) {
                  throw (Error) cause;
              }
              if (cause instanceof Exception) {
                  throw (Exception) cause;
              }
              throw exception;
          }
      }
  
      private static Class<?> convertClass() throws ClassNotFoundException {
          return Class.forName("com.sun.jna.platform.win32.COM.util.Convert");
      }
  
      private static void setNativeLongSize(int longSize) throws ReflectiveOperationException {
          final Field longSizeField = Native.class.getDeclaredField("LONG_SIZE");
          Unsafe unsafe = unsafe();
          unsafe.putInt(unsafe.staticFieldBase(longSizeField), unsafe.staticFieldOffset(longSizeField), longSize);
      }
  
      private static Unsafe unsafe() throws ReflectiveOperationException {
          final Field unsafeField = Unsafe.class.getDeclaredField("theUnsafe");
          unsafeField.setAccessible(true);
          return (Unsafe) unsafeField.get(null);
      }
  
      public enum SampleComEnum implements IComEnum {
          FIRST(1),
          SECOND(2);
  
          private final long value;
  
          SampleComEnum(long value) {
              this.value = value;
          }
  
          @Override
          public long getValue() {
              return value;
          }
      }
  }
