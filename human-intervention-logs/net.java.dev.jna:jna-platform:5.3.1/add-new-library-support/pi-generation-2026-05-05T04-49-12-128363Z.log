                  throw DdemlException.create(getLastError());
              }
          }
  
          public void postAdvise(Ddeml.HSZ hszTopic, Ddeml.HSZ hszItem) {
              boolean result = Ddeml.INSTANCE.DdePostAdvise(idInst, hszTopic, hszItem);
              if (!result) {
                  throw DdemlException.create(getLastError());
