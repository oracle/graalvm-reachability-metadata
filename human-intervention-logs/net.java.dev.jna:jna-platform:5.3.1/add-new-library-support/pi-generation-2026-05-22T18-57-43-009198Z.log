atform/DdemlUtilInnerDdemlExceptionTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage net_java_dev_jna.jna_platform;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.util.Locale;\n\nimport org.junit.jupiter.api.Test;\n\nimport com.sun.jna.platform.win32.Ddeml;\nimport com.sun.jna.platform.win32.DdemlUtil.DdemlException;\n\npublic class DdemlUtilInnerDdemlExceptionTest {\n    @Test\n    void createMapsKnownDdemlErrorCodeToExceptionMessage() {\n        try {\n            final DdemlException exception = DdemlException.create(Ddeml.DMLERR_BUSY);\n\n            assertThat(exception.getErrorCode()).isEqualTo(Ddeml.DMLERR_BUSY);\n            assertThat(exception).hasMessageContaining(\"DMLERR_BUSY\");\n            assertThat(exception).hasMessageContaining(\"0x4001\");\n        } catch (final ExceptionInInitializerError error) {\n            if (isWindows() || !(error.getCause() instanceof UnsatisfiedLinkError)) {\n                throw error;\n            }\n            assertThat(error).hasCauseInstanceOf(UnsatisfiedLinkError.class);\n        }\n    }\n\n    private static boolean isWindows() {\n        return System.getProperty(\"os.name\", \"\")\n                .toLowerCase(Locale.ROOT)\n                .contains(\"win\");\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 177, "output": 1112, "cacheRead": 28160, "cacheWrite": 0, "totalTokens": 29449, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1779476239996, "responseId": "resp_0cca6e5ebb9c88ce016a10a710762481a090b14e5319060a95"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_FdhfwzP8w69kPSz5vNukhkom|fc_0cca6e5ebb9c88ce016a10a71b64f081a091246d224fdb631a", "toolName":