  package net_java_dev_jna.jna_platform;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.lang.reflect.Field;
  import java.lang.reflect.InvocationTargetException;
  import java.lang.reflect.Method;
  
  import org.junit.jupiter.api.Test;
  
  import com.sun.jna.Native;
  import com.sun.jna.platform.win32.WinDef.BYTE;
  import com.sun.jna.platform.win32.COM.util.IComEnum;
  
  import sun.misc.Unsafe;
  
  public class ConvertTest {
      @Test
      void toVariantSearchesForMatchingVariantConstructor() throws Exception {
          try (NativeLongSizeOverride ignored = NativeLongSizeOverride.toWindowsLongSize()) {
              try {
                  final Object variant = invokeConvertMethod("toVariant", new Class<?>[] { Object.class }, new BYTE(11));
                  assertThat(variant).isNotNull();
              } catch (final ExceptionInInitializerError error) {
                  assertThat(error.getCause()).isInstanceOf(IllegalArgumentException.class);
              }
          }
      }
  
      @Test
      void toComEnumMapsNativeValueToEnumConstant() throws Exception {
          final Object result = invokeConvertMethod(
                  "toComEnum",
                  new Class<?>[] { Class.class, Object.class },
                  Choice.class,
                  Choice.SECOND.getValue());
  
          assertThat(result).isEqualTo(Choice.SECOND);
      }
  
      private static Object invokeConvertMethod(
              final String name,
              final Class<?>[] parameterTypes,
              final Object... arguments) throws Exception {
          final Class<?> convertClass = Class.forName("com.sun.jna.platform.win32.COM.util.Convert");
          final Method method = convertClass.getDeclaredMethod(name, parameterTypes);
          method.setAccessible(true);
          try {
              return method.invoke(null, arguments);
          } catch (final InvocationTargetException exception) {
              final Throwable cause = exception.getCause();
              if (cause instanceof Exception) {
                  throw (Exception) cause;
              }
              if (cause instanceof Error) {
