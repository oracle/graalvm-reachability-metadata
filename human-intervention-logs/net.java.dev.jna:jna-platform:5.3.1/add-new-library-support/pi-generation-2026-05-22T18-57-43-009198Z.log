0a72da99c81a0a001da278eb19735"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_VkPCZsVKK7xOuR34W0GDThto|fc_0cca6e5ebb9c88ce016a10a73403e481a0b074731c7d511c3c", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage net_java_dev_jna.jna_platform;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.lang.reflect.Field;\nimport java.lang.reflect.Method;\nimport java.util.HashMap;\nimport java.util.Map;\n\nimport org.junit.jupiter.api.Test;\n\nimport com.sun.jna.platform.win32.OaIdl.DISPID;\nimport com.sun.jna.platform.win32.OleAuto.DISPPARAMS;\nimport com.sun.jna.platform.win32.Variant.VARIANT;\nimport com.sun.jna.platform.win32.WinDef.LCID;\nimport com.sun.jna.platform.win32.WinDef.WORD;\nimport com.sun.jna.platform.win32.WinError;\nimport com.sun.jna.platform.win32.COM.IDispatchCallback;\nimport com.sun.jna.platform.win32.COM.util.AbstractComEventCallbackListener;\nimport com.sun.jna.platform.win32.COM.util.CallbackProxy;\nimport com.sun.jna.platform.win32.COM.util.annotation.ComInterface;\nimport com.sun.jna.platform.win32.COM.util.annotation.ComMethod;\nimport com.sun.jna.ptr.IntByReference;\n\nimport sun.misc.Unsafe;\n\npublic class CallbackProxyTest {\n    @Test\n    void invokesAnnotatedComEventCallback() throws Exception {\n        final RecordingListener listener = new RecordingListener();\n        final CallbackProxy proxy = createCallbackProxy(listener);\n        final TestDispatchParameters dispatchParameters = createDispatchParameters(new VARIANT[0], new DISPID[0]);\n\n        final int result = proxy.Invoke(\n                new DISPID(7),\n                null,\n                new LCID(0),\n                new WORD(0),\n                dispatchParameters,\n                null,\n                null,\n                new IntByReference()).intValue();\n\n        assertThat(result).isEqualTo(WinError.S_OK.intValue());\n        assertThat(listener.callbackCount).isEqualTo(1);\n        assertThat(listener.errorMessage).isNull();\n    }\n\n    private static CallbackProxy createCallbackProxy(final RecordingListener listener) throws Exception {\n        try {\n            return new CallbackProxy(null, SampleEvents.class, listener);\n        } catch (final IllegalArgumentException exception) {\n            if (!isUnsupportedStdCallCallback(exception)) {\n                throw exception;\n            }\n            return allocateCallbackProxy(listener);\n        }\n    }\n\n    private static boolean isUnsupportedStdCallCallback(final Throwable throwable) {\n        Throwable current = throwable;\n        while (current != null) {\n            if (current instanceof IllegalArgumentException\n                    && current.getMessage() != null\n                    && current.getMessage().contains(\"Invalid calling convention\")) {\n                return true;\n            }\n            current = current.getCause();\n        }\n        return false;\n    }\n\n    private static CallbackProxy allocateCallbackProxy(final RecordingListener listener) throws Exception {\n        final Unsafe unsafe = getUnsafe();\n        final CallbackProxy proxy = (CallbackProxy) unsafe.allocateInstance(CallbackProxy.class);\n        final Method eventMethod = SampleEvents.class.getMethod(\"onValue\");\n        final Map<DISPID, Method> dispIdMap = new HashMap<>();\n        dispIdMap.put(new DISPID(7), eventMethod);\n        setField(unsafe, proxy, \"comEventCallbackListener\", listener);\n        setField(unsafe, proxy, \"dsipIdMap\", dispIdMap);\n        return proxy;\n    }\n\n    private static TestDispatchParameters createDispatchParameters(\n            final VARIANT[] arguments,\n            final DISPID[] namedArguments) throws ReflectiveOperationException {\n        final TestDispatchParameters dispatchParameters = (TestDispatchParameters) getUnsafe()\n                .allocateInstance(TestDispatchParameters.class);\n        dispatchParameters.arguments = arguments;\n        dispatchParameters.namedArguments = namedArguments;\n        return dispatchParameters;\n    }\n\n    private static Unsafe getUnsafe() throws ReflectiveOperationException {\n        final Field unsafe = Unsafe.class.getDeclaredField(\"theUnsafe\");\n        unsafe.setAccessible(true);\n        return (Unsafe) unsafe.get(null);\n    }\n\n    private static void setField(\n            final Unsafe unsafe,\n            final CallbackProxy proxy,\n            final String name,\n            final Object value) throws ReflectiveOperationException {\n        final Field field = CallbackProxy.class.getDeclaredField(name);\n        unsafe.putObject(proxy, unsafe.objectFieldOffset(field), value);\n    }\n\n    public static final class TestDispatchParameters extends DISPPARAMS.ByReference {\n        private VARIANT[] arguments;\n        private DISPID[] namedArguments;\n\n        @Override\n        public VARIANT[] getArgs() {\n            return arguments;\n        }\n\n        @Override\n        public DISPID[] getRgdispidNamedArgs() {\n            return namedArguments;\n        }\n    }\n\n    @ComInterface(iid = \"{12345678-1234-1234-1234-1234567890AB}\")\n    public interface SampleEvents {\n        @ComMethod(dispId = 7)\n        void onValue();\n    }\n\n    public static final class RecordingListener extends AbstractComEventCallbackListener implements SampleEvents {\n        private int callbackCount;\n        private String errorMessage;\n\n        @Override\n        public void setDispatchCallbackListener(final IDispatchCallback dispatchCallback) {\n            super.setDispatchCallbackListener(dispatchCallback);\n        }\n\n        @Override\n        public void errorReceivingCallbackEvent(final String message, final Exception exception) {\n            errorMessage = message;\n        }\n\n        @Override\n        public void onValue() {\n            callbackCount++;\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1779476276733}]}
