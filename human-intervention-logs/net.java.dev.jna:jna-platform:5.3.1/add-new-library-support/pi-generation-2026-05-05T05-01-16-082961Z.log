[tool-call] delta {"path":"tests/src/net.java.dev.jna/jna-platform/5.3.1/src/test/java/net_java_dev_jna/jna_platform/WindowUtilsInnerX11WindowUtilsTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage net_java_dev_jna.jna_platform;\n\nimport java.awt.GraphicsConfiguration;\nimport java.awt.GraphicsDevice;\nimport java.awt.Rectangle;\nimport java.awt.Transparency;\nimport java.awt.geom.AffineTransform;\nimport java.awt.image.BufferedImage;\nimport java.awt.image.ColorModel;\nimport java.lang.reflect.InvocationTargetException;\nimport java.lang.reflect.Method;\n\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class WindowUtilsInnerX11WindowUtilsTest {\n    @Test\n    void getVisualIdUsesPublicGraphicsConfigurationVisualAccessor() throws Exception {\n        long visual = invokeGetVisualId(new VisualGraphicsConfiguration(0x1234abcdL));\n\n        assertThat(visual).isEqualTo(0x1234abcdL);\n    }\n\n    private static long invokeGetVisualId(GraphicsConfiguration graphicsConfiguration) throws Exception {\n        Method method = x11WindowUtilsClass().getDeclaredMethod(\"getVisualID\", GraphicsConfiguration.class);\n        method.setAccessible(true);\n        return ((Number) invoke(method, graphicsConfiguration)).longValue();\n    }\n\n    private static Object invoke(Method method, Object... arguments) throws Exception {\n        try {\n            return method.invoke(null, arguments);\n        }\n        catch (InvocationTargetException exception) {\n            Throwable cause = exception.getCause();\n            if (cause instanceof Error) {\n                throw (Error) cause;\n            }\n            if (cause instanceof Exception) {\n                throw (Exception) cause;\n            }\n            throw exception;\n        }\n    }\n\n    private static Class<?> x11WindowUtilsClass() throws ClassNotFoundException {\n        return Class.forName(\"com.sun.jna.platform.WindowUtils$X11WindowUtils\");\n    }\n\n    public static final class VisualGraphicsConfiguration extends GraphicsConfiguration {\n        private final long visual;\n\n        private VisualGraphicsConfiguration(long visual) {\n            this.visual = visual;\n        }\n\n        public long getVisual() {\n            return visual;\n        }\n\n        @Override\n        public GraphicsDevice getDevice() {\n            return null;\n        }\n\n        @Override\n        public ColorModel getColorModel() {\n            return ColorModel.getRGBdefault();\n        }\n\n        @Override\n        public ColorModel getColorModel(int transparency) {\n            if (transparency == Transparency.OPAQUE) {\n                return ColorModel.getRGBdefault();\n            }\n            return ColorModel.getRGBdefault();\n        }\n\n        @Override\n        public AffineTransform getDefaultTransform() {\n            return new AffineTransform();\n        }\n\n        @Override\n        public AffineTransform getNormalizingTransform() {\n            return new AffineTransform();\n        }\n\n        @Override\n        public Rectangle getBounds() {\n            return new Rectangle(0, 0, 1, 1);\n        }\n\n        @Override\n        public BufferedImage createCompatibleImage(int width, int height) {\n            return new BufferedImage(width, height, BufferedImage.TYPE_INT_ARGB);\n        }\n    }\n}\n"}
