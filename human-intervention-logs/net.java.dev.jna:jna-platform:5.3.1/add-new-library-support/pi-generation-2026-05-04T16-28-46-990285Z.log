[tool-call] delta {"path":"tests/src/net.java.dev.jna/jna-platform/5.3.1/src/test/java/net_java_dev_jna/jna_platform/WindowUtilsInnerMacWindowUtilsAnonymous1Test.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage net_java_dev_jna.jna_platform;\n\nimport static org.junit.jupiter.api.Assertions.assertEquals;\n\nimport java.awt.Frame;\nimport java.awt.Window;\n\nimport org.junit.jupiter.api.Test;\n\nimport com.sun.jna.platform.WindowUtils;\n\npublic class WindowUtilsInnerMacWindowUtilsAnonymous1Test {\n    @Test\n    void setsAlphaThroughMacPeerCompatibilityPath() {\n        String originalHeadless = System.getProperty(\"java.awt.headless\");\n        System.setProperty(\"java.awt.headless\", \"false\");\n\n        PeerBackedWindow window = new PeerBackedWindow();\n        String originalOsName = System.getProperty(\"os.name\");\n        try {\n            System.setProperty(\"os.name\", \"Mac OS X\");\n\n            WindowUtils.setWindowAlpha(window, 0.375f);\n\n            assertEquals(0.375f, window.getPeer().alpha, 0.0f);\n        }\n        finally {\n            restoreProperty(\"os.name\", originalOsName);\n            restoreProperty(\"java.awt.headless\", originalHeadless);\n            window.dispose();\n        }\n    }\n\n    private static void restoreProperty(String name, String value) {\n        if (value == null) {\n            System.clearProperty(name);\n        }\n        else {\n            System.setProperty(name, value);\n        }\n    }\n\n    public static final class PeerBackedWindow extends Window {\n        private static final long serialVersionUID = 1L;\n\n        private final AlphaPeer peer = new AlphaPeer();\n\n        private PeerBackedWindow() {\n            super((Frame) null);\n        }\n\n        @Override\n        public boolean isDisplayable() {\n            return true;\n        }\n\n        public AlphaPeer getPeer() {\n            return peer;\n        }\n    }\n\n    public static final class AlphaPeer {\n        private float alpha = 1.0f;\n\n        public void setAlpha(float alpha) {\n            this.alpha = alpha;\n        }\n    }\n}\n"}
