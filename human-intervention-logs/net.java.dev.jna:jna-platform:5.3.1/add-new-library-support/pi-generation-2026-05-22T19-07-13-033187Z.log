       *
       * @see com.sun.jna.platform.win32.COM.tlb.imp.TlbBase#getClassTemplate()
       */
      @Override
      protected String getClassTemplate() {
          return "com/sun/jna/platform/win32/COM/tlb/imp/TlbCoClass.template";
      }
  }
