  package net_java_dev_jna.jna_platform;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.lang.reflect.Field;
  import java.lang.reflect.InvocationTargetException;
  import java.lang.reflect.Method;
  
  import org.junit.jupiter.api.Test;
  
  import com.sun.jna.Native;
  import com.sun.jna.platform.win32.WinDef.BYTE;
  import com.sun.jna.platform.win32.COM.util.IComEnum;
  
  import sun.misc.Unsafe;
  
  public class ConvertTest {
      @Test
      void toVariantSearchesForMatchingVariantConstructor() throws Exception {
          try (NativeLongSizeOverride ignored = NativeLongSizeOverride.toWindowsLongSize()) {
              try {
                  final Object variant = invokeConvertMethod("toVariant", new Class<?>[] { Object.class }, new BYTE(11));
                  assertThat(variant).isNotNull();
              } catch (final ExceptionInInitializerError error) {
                  assertThat(error.getCause()).isInstanceOf(IllegalArgumentException.class);
              }
          }
      }
  
      @Test
      void toComEnumMapsNativeValueToEnumConstant() throws Exception {
          final Object result = invokeConvertMethod(
                  "toComEnum",
                  new Class<?>[] { Class.class, Object.class },
                  Choice.class,
                  Choice.SECOND.getValue());
  
          assertThat(result).isEqualTo(Choice.SECOND);
      }
  
      private static Object invokeConvertMethod(
              final String name,
              final Class<?>[] parameterTypes,
              final Object... arguments) throws Exception {
          final Class<?> convertClass = Class.forName("com.sun.jna.platform.win32.COM.util.Convert");
          final Method method = convertClass.getDeclaredMethod(name, parameterTypes);
          method.setAccessible(true);
          try {
              return method.invoke(null, arguments);
          } catch (final InvocationTargetException exception) {
              final Throwable cause = exception.getCause();
              if (cause instanceof Exception) {
                  throw (Exception) cause;
              }
              if (cause instanceof Error) {
                  throw (Error) cause;
              }
              throw exception;
          }
      }
  
      private static final class NativeLongSizeOverride implements AutoCloseable {
          private static final int WINDOWS_LONG_SIZE = 4;
  
          private final Unsafe unsafe;
          private final Object staticFieldBase;
          private final long staticFieldOffset;
          private final int originalLongSize;
  
          private NativeLongSizeOverride(
                  final Unsafe unsafe,
                  final Object staticFieldBase,
                  final long staticFieldOffset,
                  final int originalLongSize) {
              this.unsafe = unsafe;
              this.staticFieldBase = staticFieldBase;
              this.staticFieldOffset = staticFieldOffset;
              this.originalLongSize = originalLongSize;
          }
  
          static NativeLongSizeOverride toWindowsLongSize() {
              try {
                  Class.forName(Native.class.getName(), true, Native.class.getClassLoader());
                  final Unsafe unsafe = getUnsafe();
                  final Field longSize = Native.class.getField("LONG_SIZE");
                  final Object staticFieldBase = unsafe.staticFieldBase(longSize);
                  final long staticFieldOffset = unsafe.staticFieldOffset(longSize);
                  final int originalLongSize = unsafe.getInt(staticFieldBase, staticFieldOffset);
                  unsafe.putInt(staticFieldBase, staticFieldOffset, WINDOWS_LONG_SIZE);
                  return new NativeLongSizeOverride(unsafe, staticFieldBase, staticFieldOffset, originalLongSize);
              } catch (final ReflectiveOperationException | RuntimeException | LinkageError unsupported) {
                  return new NativeLongSizeOverride(null, null, 0, 0);
              }
          }
  
          private static Unsafe getUnsafe() throws ReflectiveOperationException {
              final Field unsafe = Unsafe.class.getDeclaredField("theUnsafe");
              unsafe.setAccessible(true);
              return (Unsafe) unsafe.get(null);
          }
  
          @Override
          public void close() {
              if (unsafe != null) {
                  unsafe.putInt(staticFieldBase, staticFieldOffset, originalLongSize);
              }
          }
      }
  
      public enum Choice implements IComEnum {
          FIRST(1),
          SECOND(2);
  
          private final long value;
  
          Choice(final long value) {
              this.value = value;
          }
  
          @Override
          public long getValue() {
              return value;
          }
