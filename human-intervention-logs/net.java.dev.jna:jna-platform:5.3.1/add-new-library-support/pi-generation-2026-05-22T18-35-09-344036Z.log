  package net_java_dev_jna.jna_platform;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.awt.GraphicsConfiguration;
  import java.awt.GraphicsEnvironment;
  
  import org.junit.jupiter.api.Test;
  
  import com.sun.jna.Platform;
  import com.sun.jna.platform.WindowUtils;
  
  public class WindowUtilsInnerX11WindowUtilsTest {
      @Test
      void alphaCompatibleGraphicsConfigurationUsesX11WindowUtils() {
          assertThat(Platform.isX11())
                  .as("WindowUtils should use its X11 implementation on this test platform")
                  .isTrue();
          assertThat(GraphicsEnvironment.isHeadless())
                  .as("X11 visual lookup requires an available display")
                  .isFalse();
  
          final GraphicsConfiguration defaultConfiguration = GraphicsEnvironment.getLocalGraphicsEnvironment()
                  .getDefaultScreenDevice()
                  .getDefaultConfiguration();
          final boolean alphaSupported = WindowUtils.isWindowAlphaSupported();
          final GraphicsConfiguration configuration = WindowUtils.getAlphaCompatibleGraphicsConfiguration();
  
          assertThat(configuration).isNotNull();
          assertThat(configuration.getDevice()).isNotNull();
          if (!alphaSupported) {
              assertThat(configuration).isEqualTo(defaultConfiguration);
          }
      }
  }
