[tool-call] delta {"path":"tests/src/net.java.dev.jna/jna-platform/5.3.1/src/test/java/net_java_dev_jna/jna_platform/WindowUtilsInnerX11WindowUtilsTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage net_java_dev_jna.jna_platform;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.awt.GraphicsConfiguration;\nimport java.awt.GraphicsDevice;\nimport java.awt.Rectangle;\nimport java.awt.Transparency;\nimport java.awt.geom.AffineTransform;\nimport java.awt.image.BufferedImage;\nimport java.awt.image.ColorModel;\nimport java.lang.reflect.Method;\n\nimport org.junit.jupiter.api.Test;\n\nimport com.sun.jna.platform.WindowUtils;\n\npublic class WindowUtilsInnerX11WindowUtilsTest {\n    @Test\n    void visualIdIsReadFromGraphicsConfigurationVisualMethod() throws Exception {\n        final Method getVisualId = Class.forName(\"com.sun.jna.platform.WindowUtils$X11WindowUtils\")\n                .getDeclaredMethod(\"getVisualID\", GraphicsConfiguration.class);\n        getVisualId.setAccessible(true);\n\n        final Object visualId = getVisualId.invoke(null, new VisualGraphicsConfiguration(0x2f7));\n\n        assertThat(visualId).isEqualTo(0x2f7L);\n    }\n\n    @Test\n    void alphaCompatibleGraphicsConfigurationFallsBackWhenCurrentDisplayHasNoAlphaVisual() {\n        final GraphicsConfiguration configuration = WindowUtils.getAlphaCompatibleGraphicsConfiguration();\n\n        assertThat(configuration).isNotNull();\n        assertThat(configuration.getDevice()).isNotNull();\n    }\n\n    public static final class VisualGraphicsConfiguration extends GraphicsConfiguration {\n        private final int visual;\n\n        private VisualGraphicsConfiguration(final int visual) {\n            this.visual = visual;\n        }\n\n        public int getVisual() {\n            return visual;\n        }\n\n        @Override\n        public GraphicsDevice getDevice() {\n            return null;\n        }\n\n        @Override\n        public BufferedImage createCompatibleImage(final int width, final int height) {\n            return new BufferedImage(width, height, BufferedImage.TYPE_INT_ARGB);\n        }\n\n        @Override\n        public BufferedImage createCompatibleImage(\n                final int width,\n                final int height,\n                final int transparency) {\n            return new BufferedImage(width, height, imageType(transparency));\n        }\n\n        @Override\n        public ColorModel getColorModel() {\n            return ColorModel.getRGBdefault();\n        }\n\n        @Override\n        public ColorModel getColorModel(final int transparency) {\n            return ColorModel.getRGBdefault();\n        }\n\n        @Override\n        public AffineTransform getDefaultTransform() {\n            return new AffineTransform();\n        }\n\n        @Override\n        public AffineTransform getNormalizingTransform() {\n            return new AffineTransform();\n        }\n\n        @Override\n        public Rectangle getBounds() {\n            return new Rectangle(0, 0, 1, 1);\n        }\n\n        private static int imageType(final int transparency) {\n            if (transparency == Transparency.OPAQUE) {\n                return BufferedImage.TYPE_INT_RGB;\n            }\n            return BufferedImage.TYPE_INT_ARGB;\n        }\n    }\n}\n"}
