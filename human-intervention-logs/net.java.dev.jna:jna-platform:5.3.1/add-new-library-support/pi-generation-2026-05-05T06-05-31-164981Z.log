  package net_java_dev_jna.jna_platform;
  
  import java.io.IOException;
  import java.nio.file.Files;
  import java.nio.file.Path;
  import java.util.List;
  
  import com.sun.jna.NativeLibrary;
  import com.sun.jna.Platform;
  import com.sun.jna.platform.win32.DdemlUtil;
  
  import org.junit.jupiter.api.Test;
  import org.junit.jupiter.api.io.TempDir;
  
  import static org.junit.jupiter.api.Assertions.assertEquals;
  import static org.junit.jupiter.api.Assertions.assertTrue;
  
  public class DdemlUtilInnerDdemlExceptionTest {
      private static final int DMLERR_BUSY = 0x4001;
  
      @Test
      void createBuildsExceptionForDdemlErrorCode(@TempDir Path tempDirectory)
              throws IOException {
          prepareUser32Alias(tempDirectory);
  
          DdemlUtil.DdemlException exception = DdemlUtil.DdemlException.create(
                  DMLERR_BUSY);
          String message = exception.getMessage();
  
          assertEquals(DMLERR_BUSY, exception.getErrorCode());
          assertTrue(message.contains("Code: 0x4001"));
          assertTrue(message.contains("DMLERR_BUSY"));
      }
  
      private static void prepareUser32Alias(Path tempDirectory) throws IOException {
          if (Platform.isWindows()) {
              return;
          }
  
          Path source = findLoadableSystemLibrary();
          Path alias = tempDirectory.resolve(System.mapLibraryName("user32"));
          try {
              Files.createSymbolicLink(alias, source);
          } catch (UnsupportedOperationException | IOException error) {
              Files.copy(source, alias);
          }
          NativeLibrary.addSearchPath("user32", tempDirectory.toString());
      }
  
      private static Path findLoadableSystemLibrary() {
          List<Path> candidates = List.of(
                  Path.of("/lib/x86_64-linux-gnu/libc.so.6"),
                  Path.of("/usr/lib/x86_64-linux-gnu/libc.so.6"),
                  Path.of("/lib/aarch64-linux-gnu/libc.so.6"),
                  Path.of("/usr/lib/aarch64-linux-gnu/libc.so.6"),
                  Path.of("/lib64/libc.so.6"),
                  Path.of("/usr/lib64/libc.so.6"),
                  Path.of("/lib/libc.musl-x86_64.so.1"),
                  Path.of("/usr/lib/libSystem.B.dylib"));
          for (Path candidate : candidates) {
              if (Files.isRegularFile(candidate)) {
                  return candidate;
              }
          }
          throw new IllegalStateException(
                  "No loadable system library found for user32 alias");
      }
  }
