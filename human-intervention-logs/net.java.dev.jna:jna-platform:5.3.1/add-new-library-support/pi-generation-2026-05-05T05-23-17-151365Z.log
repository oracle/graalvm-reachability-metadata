  package net_java_dev_jna.jna_platform;
  
  import java.awt.Frame;
  import java.awt.Window;
  import java.lang.reflect.Field;
  
  import com.sun.jna.Platform;
  import com.sun.jna.platform.WindowUtils;
  
  import org.junit.jupiter.api.Test;
  
  import sun.misc.Unsafe;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class WindowUtilsInnerMacWindowUtilsAnonymous1Test {
      @Test
      void macWindowAlphaUsesPeerSetAlphaWhenDisplayableWindowHasPeerAccessor() throws Exception {
          final String originalOsName = System.getProperty("os.name");
          final int originalOsType = Platform.getOSType();
          AlphaPeer.reset();
          System.setProperty("os.name", "Mac OS X");
          setPlatformOsType(Platform.MAC);
          try {
              WindowUtils.setWindowAlpha(allocatedAlphaWindow(), 0.42f);
          }
          finally {
              setPlatformOsType(originalOsType);
              restoreProperty("os.name", originalOsName);
          }
  
          assertThat(AlphaPeer.getAlpha()).isEqualTo(0.42f);
          assertThat(AlphaPeer.getSetAlphaCalls()).isEqualTo(1);
      }
  
      private static Window allocatedAlphaWindow() throws ReflectiveOperationException {
          return (Window) unsafe().allocateInstance(AlphaWindow.class);
      }
  
      private static Unsafe unsafe() throws ReflectiveOperationException {
          final Field unsafeField = Unsafe.class.getDeclaredField("theUnsafe");
          unsafeField.setAccessible(true);
          return (Unsafe) unsafeField.get(null);
      }
  
      private static void setPlatformOsType(int osType) throws ReflectiveOperationException {
          final Field osTypeField = Platform.class.getDeclaredField("osType");
          Unsafe unsafe = unsafe();
          unsafe.putInt(unsafe.staticFieldBase(osTypeField), unsafe.staticFieldOffset(osTypeField), osType);
      }
  
      private static void restoreProperty(String name, String value) {
          if (value == null) {
              System.clearProperty(name);
          }
          else {
              System.setProperty(name, value);
          }
      }
  
      @SuppressWarnings("serial")
      public static final class AlphaWindow extends Window {
          private AlphaWindow() {
              super((Frame) null);
          }
  
          @Override
          public boolean isDisplayable() {
              return true;
          }
  
          public AlphaPeer getPeer() {
              return AlphaPeer.INSTANCE;
          }
      }
  
      public static final class AlphaPeer {
          private static final AlphaPeer INSTANCE = new AlphaPeer();
          private static int setAlphaCalls;
          private static float alpha;
  
          public void setAlpha(float newAlpha) {
              setAlphaCalls++;
              alpha = newAlpha;
          }
  
          private static void reset() {
              setAlphaCalls = 0;
              alpha = -1.0f;
          }
  
          private static int getSetAlphaCalls() {
              return setAlphaCalls;
          }
  
          private static float getAlpha() {
              return alpha;
          }
      }
  }
