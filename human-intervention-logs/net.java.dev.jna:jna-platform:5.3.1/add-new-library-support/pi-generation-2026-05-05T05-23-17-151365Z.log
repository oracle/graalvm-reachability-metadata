          <module name="SuperFinalize"/>
          <module name="UnnecessaryParentheses">
              <property name="severity" value="ignore"/>
              <metadata name="net.sf.eclipsecs.core.lastEnabledSeverity" value="inherit"/>
          </module>
          <module name="Indentation">
