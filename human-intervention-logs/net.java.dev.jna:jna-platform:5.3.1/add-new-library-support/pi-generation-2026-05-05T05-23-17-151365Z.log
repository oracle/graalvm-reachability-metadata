  package net_java_dev_jna.jna_platform;
  
  import java.lang.reflect.Constructor;
  import java.lang.reflect.InvocationHandler;
  import java.lang.reflect.Proxy;
  
  import com.sun.jna.platform.win32.Ddeml.CONVCONTEXT;
  import com.sun.jna.platform.win32.Ddeml.HCONV;
  import com.sun.jna.platform.win32.Ddeml.HSZ;
  import com.sun.jna.platform.win32.DdemlUtil;
  import com.sun.jna.platform.win32.User32Util.MessageLoopThread;
  
  import org.junit.jupiter.api.Test;
  
  import static org.junit.jupiter.api.Assertions.assertNotSame;
  import static org.junit.jupiter.api.Assertions.assertTrue;
  
  public class DdemlUtilInnerMessageLoopWrapperTest {
      @Test
      void invocationWrapsReturnedConnectionInMessageLoopProxies() throws Exception {
          DdemlUtil.IDdeConnection connection = new DdemlUtil.DdeConnection(null, new HCONV());
          DdemlUtil.IDdeClient delegate = new DelegateClient(connection);
          InvocationHandler handler = newMessageLoopWrapper(delegate);
          DdemlUtil.IDdeClient proxy = newProxy(DdemlUtil.IDdeClient.class, handler);
  
          DdemlUtil.IDdeConnection wrappedConnection = proxy.connect((HSZ) null, (HSZ) null, null);
  
          assertNotSame(connection, wrappedConnection);
          assertTrue(Proxy.isProxyClass(wrappedConnection.getClass()));
      }
  
      private static InvocationHandler newMessageLoopWrapper(Object delegate) throws Exception {
          Class<?> wrapperClass = Class.forName("com.sun.jna.platform.win32.DdemlUtil$MessageLoopWrapper");
          Constructor<?> constructor = wrapperClass.getDeclaredConstructor(MessageLoopThread.class, Object.class);
          constructor.setAccessible(true);
          return (InvocationHandler) constructor.newInstance(new MessageLoopThread(), delegate);
      }
  
      private static <T> T newProxy(Class<T> type, InvocationHandler handler) {
          Object proxy = Proxy.newProxyInstance(
                  DdemlUtilInnerMessageLoopWrapperTest.class.getClassLoader(),
                  new Class<?>[] { type },
                  handler);
          return type.cast(proxy);
      }
  
      private static final class DelegateClient extends DdemlUtil.DdeClient {
          private final DdemlUtil.IDdeConnection connection;
  
          private DelegateClient(DdemlUtil.IDdeConnection connection) {
              this.connection = connection;
          }
  
          @Override
          public DdemlUtil.IDdeConnection connect(HSZ service, HSZ topic, CONVCONTEXT convcontext) {
              return connection;
          }
  
          @Override
          public DdemlUtil.IDdeConnection connect(String service, String topic, CONVCONTEXT convcontext) {
              return connection;
          }
      }
  }
