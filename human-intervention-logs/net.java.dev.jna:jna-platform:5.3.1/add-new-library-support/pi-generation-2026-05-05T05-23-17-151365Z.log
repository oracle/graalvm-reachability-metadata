  package net_java_dev_jna.jna_platform;
  
  import java.lang.reflect.Field;
  import java.lang.reflect.InvocationTargetException;
  import java.lang.reflect.Method;
  import java.util.ArrayList;
  import java.util.List;
  import java.util.Map;
  
  import com.sun.jna.platform.win32.Guid.REFIID;
  import com.sun.jna.platform.win32.OaIdl.DISPID;
  import com.sun.jna.platform.win32.OleAuto.DISPPARAMS;
  import com.sun.jna.platform.win32.WinDef.LCID;
  import com.sun.jna.platform.win32.WinDef.WORD;
  import com.sun.jna.platform.win32.COM.IDispatchCallback;
  import com.sun.jna.platform.win32.COM.util.CallbackProxy;
  import com.sun.jna.platform.win32.COM.util.IComEventCallbackListener;
  import com.sun.jna.platform.win32.COM.util.annotation.ComInterface;
  import com.sun.jna.platform.win32.COM.util.annotation.ComMethod;
  
  import org.junit.jupiter.api.Test;
  
  import sun.misc.Unsafe;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class CallbackProxyTest {
      private static final int EVENT_DISP_ID = 7;
  
      @Test
      void invokeDispatchesAnnotatedCallbackMethodToListener() throws Exception {
          RecordingListener listener = new RecordingListener();
          CallbackProxy proxy = allocatedCallbackProxy();
          setField(proxy, "comEventCallbackListener", listener);
          setField(proxy, "dsipIdMap", createDispIdMap(proxy, SampleEvents.class));
          DISPPARAMS.ByReference parameters = new DISPPARAMS.ByReference();
  
          invokeOnThread(proxy, new DISPID(EVENT_DISP_ID), parameters);
  
          assertThat(listener.heartbeatCount).isEqualTo(1);
          assertThat(listener.errors).isEmpty();
      }
  
      @SuppressWarnings("unchecked")
      private static Map<DISPID, Method> createDispIdMap(CallbackProxy proxy, Class<?> eventInterface) throws Exception {
          Method method = CallbackProxy.class.getDeclaredMethod("createDispIdMap", Class.class);
          method.setAccessible(true);
          return (Map<DISPID, Method>) invoke(method, proxy, eventInterface);
      }
  
      private static void invokeOnThread(CallbackProxy proxy, DISPID dispId, DISPPARAMS.ByReference parameters)
              throws Exception {
          Method method = CallbackProxy.class.getDeclaredMethod(
                  "invokeOnThread",
                  DISPID.class,
                  REFIID.class,
                  LCID.class,
                  WORD.class,
                  DISPPARAMS.ByReference.class);
          method.setAccessible(true);
          invoke(method, proxy, dispId, null, new LCID(0), new WORD(0), parameters);
      }
  
      private static Object invoke(Method method, Object target, Object... arguments) throws Exception {
          try {
