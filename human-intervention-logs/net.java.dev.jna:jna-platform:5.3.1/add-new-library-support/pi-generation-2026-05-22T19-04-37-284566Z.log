[tool-call] delta {"path":"tests/src/net.java.dev.jna/jna-platform/5.3.1/src/test/java/net_java_dev_jna/jna_platform/DdemlUtilInnerStandaloneDdeClientTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage net_java_dev_jna.jna_platform;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.IOException;\nimport java.util.Locale;\n\nimport org.junit.jupiter.api.Test;\n\nimport com.sun.jna.platform.win32.Ddeml;\nimport com.sun.jna.platform.win32.DdemlUtil.IDdeClient;\nimport com.sun.jna.platform.win32.DdemlUtil.StandaloneDdeClient;\n\npublic class DdemlUtilInnerStandaloneDdeClientTest {\n    @Test\n    void createsMessageLoopBackedDdeClient() throws IOException {\n        final StandaloneDdeClient client = new StandaloneDdeClient();\n\n        assertThat(client).isInstanceOf(IDdeClient.class);\n        assertThat(client.getInstanceIdentitifier()).isNull();\n\n        if (isWindows()) {\n            client.initialize(Ddeml.APPCMD_CLIENTONLY);\n            client.close();\n        }\n    }\n\n    private static boolean isWindows() {\n        return System.getProperty(\"os.name\", \"\")\n                .toLowerCase(Locale.ROOT)\n                .contains(\"win\");\n    }\n}\n"}
