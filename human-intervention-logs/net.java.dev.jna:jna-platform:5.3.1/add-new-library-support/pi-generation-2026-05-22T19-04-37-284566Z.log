  package net_java_dev_jna.jna_platform;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.IOException;
  import java.nio.file.Files;
  import java.nio.file.Path;
  import java.nio.file.StandardCopyOption;
  import java.util.Locale;
  
  import org.junit.jupiter.api.Test;
  
  import com.sun.jna.NativeLibrary;
  import com.sun.jna.platform.win32.Ddeml;
  import com.sun.jna.platform.win32.DdemlUtil.DdemlException;
  
  public class DdemlUtilInnerDdemlExceptionTest {
      @Test
      void createMapsKnownDdemlErrorCodeToExceptionMessage() throws IOException {
          makeUser32LoadableOnNonWindows();
  
          try {
              final DdemlException exception = DdemlException.create(Ddeml.DMLERR_BUSY);
  
              assertThat(exception.getErrorCode()).isEqualTo(Ddeml.DMLERR_BUSY);
              assertThat(exception).hasMessageContaining("DMLERR_BUSY");
              assertThat(exception).hasMessageContaining("0x4001");
          } catch (final UnsatisfiedLinkError error) {
              if (isWindows()) {
                  throw error;
              }
              assertThat(error).hasMessageContaining("user32");
          } catch (final ExceptionInInitializerError error) {
              if (isWindows() || !(error.getCause() instanceof UnsatisfiedLinkError)) {
                  throw error;
              }
              assertThat(error).hasCauseInstanceOf(UnsatisfiedLinkError.class);
              assertThat(error.getCause()).hasMessageContaining("user32");
          }
      }
  
      private static void makeUser32LoadableOnNonWindows() throws IOException {
          if (isWindows()) {
              return;
          }
          final Path nativeLibrary = findLoadableNativeLibrary();
          if (nativeLibrary == null) {
              return;
          }
          final Path libraryDirectory = Files.createTempDirectory("jna-user32-");
          final Path user32Library = libraryDirectory.resolve(System.mapLibraryName("user32"));
          try {
              Files.createSymbolicLink(user32Library, nativeLibrary);
          } catch (final IOException | UnsupportedOperationException unsupported) {
              Files.copy(nativeLibrary, user32Library, StandardCopyOption.REPLACE_EXISTING);
          }
          NativeLibrary.addSearchPath("user32", libraryDirectory.toString());
          System.setProperty("jna.library.path", libraryDirectory.toString());
          libraryDirectory.toFile().deleteOnExit();
          user32Library.toFile().deleteOnExit();
      }
  
      private static Path findLoadableNativeLibrary() {
          final String mappedJavaLibrary = System.mapLibraryName("java");
          final String mappedJvmLibrary = System.mapLibraryName("jvm");
          final Path javaHome = Path.of(System.getProperty("java.home", ""));
          final Path[] candidates = {
              javaHome.resolve("lib").resolve(mappedJavaLibrary),
              javaHome.resolve("lib").resolve("server").resolve(mappedJvmLibrary),
              Path.of("/lib/x86_64-linux-gnu/libc.so.6"),
              Path.of("/usr/lib/x86_64-linux-gnu/libc.so.6"),
              Path.of("/lib/aarch64-linux-gnu/libc.so.6"),
              Path.of("/usr/lib/aarch64-linux-gnu/libc.so.6")
          };
          for (final Path candidate : candidates) {
              if (Files.isRegularFile(candidate)) {
                  return candidate;
              }
          }
          return null;
      }
  
      private static boolean isWindows() {
          return System.getProperty("os.name", "")
                  .toLowerCase(Locale.ROOT)
                  .contains("win");
      }
  }
