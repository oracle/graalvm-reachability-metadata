  package net_java_dev_jna.jna_platform;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.lang.reflect.Field;
  import java.lang.reflect.Method;
  import java.util.HashMap;
  import java.util.Locale;
  import java.util.Map;
  
  import org.junit.jupiter.api.Test;
  
  import com.sun.jna.platform.win32.OaIdl.DISPID;
  import com.sun.jna.platform.win32.OleAuto.DISPPARAMS;
  import com.sun.jna.platform.win32.Variant.VARIANT;
  import com.sun.jna.platform.win32.WinDef.LCID;
  import com.sun.jna.platform.win32.WinDef.WORD;
  import com.sun.jna.platform.win32.WinError;
  import com.sun.jna.platform.win32.COM.IDispatchCallback;
  import com.sun.jna.platform.win32.COM.util.AbstractComEventCallbackListener;
  import com.sun.jna.platform.win32.COM.util.CallbackProxy;
  import com.sun.jna.platform.win32.COM.util.annotation.ComInterface;
  import com.sun.jna.platform.win32.COM.util.annotation.ComMethod;
  import com.sun.jna.ptr.IntByReference;
  
  import sun.misc.Unsafe;
  
  public class CallbackProxyTest {
      @Test
      void invokesAnnotatedComEventCallback() throws Exception {
          final RecordingListener listener = new RecordingListener();
          final CallbackProxy proxy = createCallbackProxy(listener);
          final TestDispatchParameters dispatchParameters = createDispatchParameters(new VARIANT[0], new DISPID[0]);
  
          try {
              final int result = proxy.Invoke(
                      new DISPID(7),
                      null,
                      new LCID(0),
                      new WORD(0),
                      dispatchParameters,
                      null,
                      null,
                      new IntByReference()).intValue();
  
              assertThat(result).isEqualTo(WinError.S_OK.intValue());
              assertThat(listener.callbackCount).isEqualTo(1);
              assertThat(listener.errorMessage).isNull();
          } catch (final UnsatisfiedLinkError error) {
              if (isWindows()) {
                  throw error;
              }
              assertThat(error).hasMessageContaining("Ole32");
          }
      }
  
      private static CallbackProxy createCallbackProxy(final RecordingListener listener) throws Exception {
          try {
              return new CallbackProxy(null, SampleEvents.class, listener);
          } catch (final IllegalArgumentException exception) {
              if (!isUnsupportedStdCallCallback(exception)) {
                  throw exception;
              }
              return allocateCallbackProxy(listener);
          }
      }
  
      private static boolean isWindows() {
          return System.getProperty("os.name", "")
                  .toLowerCase(Locale.ROOT)
                  .contains("win");
      }
  
      private static boolean isUnsupportedStdCallCallback(final Throwable throwable) {
          Throwable current = throwable;
          while (current != null) {
