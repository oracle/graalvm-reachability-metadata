ongSize;\n\n        private NativeLongSizeOverride(\n                final Unsafe unsafe,\n                final Object staticFieldBase,\n                final long staticFieldOffset,\n                final int originalLongSize) {\n            this.unsafe = unsafe;\n            this.staticFieldBase = staticFieldBase;\n            this.staticFieldOffset = staticFieldOffset;\n            this.originalLongSize = originalLongSize;\n        }\n\n        static NativeLongSizeOverride toWindowsLongSize() throws Exception {\n            final Unsafe unsafe = getUnsafe();\n            final Field longSize = Native.class.getField(\"LONG_SIZE\");\n            final Object staticFieldBase = unsafe.staticFieldBase(longSize);\n            final long staticFieldOffset = unsafe.staticFieldOffset(longSize);\n            final int originalLongSize = unsafe.getInt(staticFieldBase, staticFieldOffset);\n            unsafe.putInt(staticFieldBase, staticFieldOffset, WINDOWS_LONG_SIZE);\n            return new NativeLongSizeOverride(unsafe, staticFieldBase, staticFieldOffset, originalLongSize);\n        }\n\n        private static Unsafe getUnsafe() throws Exception {\n            final Field unsafe = Unsafe.class.getDeclaredField(\"theUnsafe\");\n            unsafe.setAccessible(true);\n            return (Unsafe) unsafe.get(null);\n        }\n\n        @Override\n        public void close() {\n            unsafe.putInt(staticFieldBase, staticFieldOffset, originalLongSize);\n        }\n    }\n\n    public enum Choice implements IComEnum {\n"}]}
