backConversionMapsVariantValueToComEnum() {\n        final RecordingEventListener listener = new RecordingEventListener();\n        final CallbackProxy callbackProxy = new CallbackProxy(null, EventSink.class, listener);\n        final DISPPARAMS.ByReference parameters = new DISPPARAMS.ByReference();\n        parameters.setArgs(new VARIANT[] { new VARIANT(new LONG(Choice.SECOND.getValue())) });\n\n        final HRESULT result = callbackProxy.Invoke(\n                new DISPID(17),\n                new REFIID(Guid.IID_NULL),\n                new LCID(0),\n                new WORD(OleAuto.DISPATCH_METHOD),\n                parameters,\n                new VARIANT.ByReference(),\n                new EXCEPINFO.ByReference(),\n                new IntByReference());\n\n        assertThat(result).isEqualTo(WinError.S_OK);\n        assertThat(listener.choice).isEqualTo(Choice.SECOND);\n        assertThat(listener.errorMessage).isNull();\n        assertThat(listener.errorException).isNull();\n    }\n\n    private static VARIANT invokeToVariant(final Object value) throws Exception {\n        final Class<?> convertClass = Class.forName(\"com.sun.jna.platform.win32.COM.util.Convert\");\n        final Method toVariant = convertClass.getDeclaredMethod(\"toVariant\", Object.class);\n        toVariant.setAccessible(true);\n        return (VARIANT) toVariant.invoke(null, value);\n    }\n\n    @ComInterface(iid = \"00000000-0000-0000-C000-000000000046\")\n    public interface EventSink {\n        @ComMethod(dispId = 17)\n        void onChoice(Choice choice);\n    }\n\n    public enum Choice implements IComEnum {\n        FIRST(1),\n        SECOND(2);\n\n        private final long value;\n\n        Choice(final long value) {\n            this.value = value;\n        }\n\n        @Override\n        public long getValue() {\n            return value;\n        }\n    }\n\n    public static final class RecordingEventListener implements EventSink, IComEventCallbackListener {\n        private Choice choice;\n        private String errorMessage;\n        private Exception errorException;\n\n        @Override\n        public void onChoice(final Choice choice) {\n            this.choice = choice;\n        }\n\n        @Override\n        public void setDispatchCallbackListener(final IDispatchCallback dispatchCallback) {\n        }\n\n        @Override\n        public void errorReceivingCallbackEvent(final String message, final Exception exception) {\n            this.errorMessage = message;\n            this.errorException = exception;\n        }\n    }\n}\n"}
