sult = invokeConvertMethod(\n                \"toComEnum\",\n                new Class<?>[] { Class.class, Object.class },\n                Choice.class,\n                Choice.SECOND.getValue());\n\n        assertThat(result).isEqualTo(Choice.SECOND);\n    }\n\n    private static Object invokeConvertMethod(\n            final String name,\n            final Class<?>[] parameterTypes,\n            final Object... arguments) throws Exception {\n        final Class<?> convertClass = Class.forName(\"com.sun.jna.platform.win32.COM.util.Convert\");\n        final Method method = convertClass.getDeclaredMethod(name, parameterTypes);\n        method.setAccessible(true);\n        return method.invoke(null, arguments);\n    }\n\n    public enum Choice implements IComEnum {\n        FIRST(1),\n        SECOND(2);\n\n        private final long value;\n\n        Choice(final long value) {\n            this.value = value;\n        }\n\n        @Override\n        public long getValue() {\n            return value;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 987, "output": 604, "cacheRead": 59392, "cacheWrite": 0, "totalTokens": 60983, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1779474075414, "responseId": "resp_0ecc7ddc06a26aed016a109e9c88d881a38753935a30042846"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_uxkx8zf8G1oa0KdhFh1MqeJY|fc_0ecc7ddc06a26aed016a109ea126d881a3a0f25a9887d54641", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1935 bytes to tests/src/net.java.dev.jna/jna-platform/5.3.1/src/test/java/net_java_dev_jna/jna_platform/ConvertTest.java"}], "isError": false, "timestamp": 1779474085040}]}
