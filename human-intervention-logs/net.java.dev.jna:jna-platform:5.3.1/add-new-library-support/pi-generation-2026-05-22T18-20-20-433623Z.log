  package net_java_dev_jna.jna_platform;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.lang.reflect.Method;
  
  import org.junit.jupiter.api.Test;
  
  import com.sun.jna.platform.win32.Guid;
  import com.sun.jna.platform.win32.Guid.REFIID;
  import com.sun.jna.platform.win32.OaIdl.DISPID;
  import com.sun.jna.platform.win32.OaIdl.EXCEPINFO;
  import com.sun.jna.platform.win32.OleAuto;
  import com.sun.jna.platform.win32.OleAuto.DISPPARAMS;
  import com.sun.jna.platform.win32.Variant;
  import com.sun.jna.platform.win32.Variant.VARIANT;
  import com.sun.jna.platform.win32.WinDef.BYTE;
  import com.sun.jna.platform.win32.WinDef.LCID;
  import com.sun.jna.platform.win32.WinDef.LONG;
  import com.sun.jna.platform.win32.WinDef.WORD;
  import com.sun.jna.platform.win32.WinError;
  import com.sun.jna.platform.win32.WinNT.HRESULT;
  import com.sun.jna.platform.win32.COM.IDispatchCallback;
  import com.sun.jna.platform.win32.COM.util.CallbackProxy;
  import com.sun.jna.platform.win32.COM.util.IComEnum;
  import com.sun.jna.platform.win32.COM.util.IComEventCallbackListener;
  import com.sun.jna.platform.win32.COM.util.annotation.ComInterface;
  import com.sun.jna.platform.win32.COM.util.annotation.ComMethod;
  import com.sun.jna.ptr.IntByReference;
  
  public class ConvertTest {
      @Test
      void toVariantUsesMatchingVariantConstructorForJnaValueTypes() throws Exception {
          final VARIANT variant = invokeToVariant(new BYTE(11));
  
          assertThat(variant.getVarType().intValue()).isEqualTo(Variant.VT_UI1);
          assertThat((BYTE) variant.getValue()).isEqualTo(new BYTE(11));
      }
  
      @Test
      void callbackConversionMapsVariantValueToComEnum() {
          final RecordingEventListener listener = new RecordingEventListener();
          final CallbackProxy callbackProxy = new CallbackProxy(null, EventSink.class, listener);
          final DISPPARAMS.ByReference parameters = new StaticDispatchParameters(
                  new VARIANT[] { new VARIANT(new LONG(Choice.SECOND.getValue())) });
  
          final HRESULT result = callbackProxy.Invoke(
                  new DISPID(17),
                  new REFIID(Guid.IID_NULL),
                  new LCID(0),
                  new WORD(OleAuto.DISPATCH_METHOD),
                  parameters,
                  new VARIANT.ByReference(),
                  new EXCEPINFO.ByReference(),
                  new IntByReference());
  
          assertThat(result).isEqualTo(WinError.S_OK);
          assertThat(listener.choice).isEqualTo(Choice.SECOND);
          assertThat(listener.errorMessage).isNull();
          assertThat(listener.errorException).isNull();
      }
  
      private static VARIANT invokeToVariant(final Object value) throws Exception {
          final Class<?> convertClass = Class.forName("com.sun.jna.platform.win32.COM.util.Convert");
          final Method toVariant = convertClass.getDeclaredMethod("toVariant", Object.class);
          toVariant.setAccessible(true);
          return (VARIANT) toVariant.invoke(null, value);
      }
  
      @ComInterface(iid = "00000000-0000-0000-C000-000000000046")
      public interface EventSink {
          @ComMethod(dispId = 17)
          void onChoice(Choice choice);
      }
  
      public static final class StaticDispatchParameters extends DISPPARAMS.ByReference {
          private final VARIANT[] arguments;
  
          StaticDispatchParameters(final VARIANT[] arguments) {
              this.arguments = arguments;
          }
  
          @Override
          public VARIANT[] getArgs() {
              return arguments;
          }
  
          @Override
          public DISPID[] getRgdispidNamedArgs() {
              return new DISPID[0];
          }
      }
  
      public enum Choice implements IComEnum {
          FIRST(1),
          SECOND(2);
  
          private final long value;
  
          Choice(final long value) {
              this.value = value;
          }
  
          @Override
          public long getValue() {
              return value;
          }
      }
  
      public static final class RecordingEventListener implements EventSink, IComEventCallbackListener {
          private Choice choice;
          private String errorMessage;
          private Exception errorException;
  
          @Override
          public void onChoice(final Choice choice) {
              this.choice = choice;
          }
  
          @Override
          public void setDispatchCallbackListener(final IDispatchCallback dispatchCallback) {
          }
  
          @Override
          public void errorReceivingCallbackEvent(final String message, final Exception exception) {
              this.errorMessage = message;
              this.errorException = exception;
          }
      }
