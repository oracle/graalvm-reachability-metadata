  package net_java_dev_jna.jna_platform;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.lang.reflect.Field;
  import java.lang.reflect.Method;
  import java.util.HashMap;
  import java.util.Map;
  
  import org.junit.jupiter.api.Test;
  
  import com.sun.jna.platform.win32.OaIdl.DISPID;
  import com.sun.jna.platform.win32.OleAuto.DISPPARAMS;
  import com.sun.jna.platform.win32.Variant.VARIANT;
  import com.sun.jna.platform.win32.WinDef.LCID;
  import com.sun.jna.platform.win32.WinDef.WORD;
  import com.sun.jna.platform.win32.WinError;
  import com.sun.jna.platform.win32.COM.IDispatchCallback;
  import com.sun.jna.platform.win32.COM.util.AbstractComEventCallbackListener;
  import com.sun.jna.platform.win32.COM.util.CallbackProxy;
  import com.sun.jna.platform.win32.COM.util.annotation.ComInterface;
  import com.sun.jna.platform.win32.COM.util.annotation.ComMethod;
  import com.sun.jna.ptr.IntByReference;
  
  import sun.misc.Unsafe;
  
  public class CallbackProxyTest {
      @Test
      void invokesAnnotatedComEventCallback() throws Exception {
          final RecordingListener listener = new RecordingListener();
          final CallbackProxy proxy = createCallbackProxy(listener);
          final TestDispatchParameters dispatchParameters = createDispatchParameters(
                  new VARIANT[] { new VARIANT(42) },
                  new DISPID[0]);
  
          final int result = proxy.Invoke(
                  new DISPID(7),
                  null,
                  new LCID(0),
                  new WORD(0),
                  dispatchParameters,
                  null,
                  null,
                  new IntByReference()).intValue();
  
          assertThat(result).isEqualTo(WinError.S_OK.intValue());
          assertThat(listener.lastValue).isEqualTo(42);
          assertThat(listener.lastDefaultFlag).isFalse();
          assertThat(listener.errorMessage).isNull();
      }
  
      private static CallbackProxy createCallbackProxy(final RecordingListener listener) throws Exception {
          try {
              return new CallbackProxy(null, SampleEvents.class, listener);
          } catch (final IllegalArgumentException exception) {
              if (!isUnsupportedStdCallCallback(exception)) {
                  throw exception;
              }
              return allocateCallbackProxy(listener);
          }
      }
  
      private static boolean isUnsupportedStdCallCallback(final Throwable throwable) {
          Throwable current = throwable;
          while (current != null) {
              if (current instanceof IllegalArgumentException
                      && current.getMessage() != null
                      && current.getMessage().contains("Invalid calling convention")) {
                  return true;
              }
              current = current.getCause();
          }
          return false;
      }
  
      private static CallbackProxy allocateCallbackProxy(final RecordingListener listener) throws Exception {
          final Unsafe unsafe = getUnsafe();
          final CallbackProxy proxy = (CallbackProxy) unsafe.allocateInstance(CallbackProxy.class);
          final Method eventMethod = SampleEvents.class.getMethod("onValue", int.class, boolean.class);
          final Map<DISPID, Method> dispIdMap = new HashMap<>();
          dispIdMap.put(new DISPID(7), eventMethod);
          setField(unsafe, proxy, "comEventCallbackListener", listener);
          setField(unsafe, proxy, "dsipIdMap", dispIdMap);
          return proxy;
      }
  
      private static TestDispatchParameters createDispatchParameters(
              final VARIANT[] arguments,
              final DISPID[] namedArguments) throws InstantiationException, ReflectiveOperationException {
          final TestDispatchParameters dispatchParameters = (TestDispatchParameters) getUnsafe()
                  .allocateInstance(TestDispatchParameters.class);
          dispatchParameters.arguments = arguments;
          dispatchParameters.namedArguments = namedArguments;
          return dispatchParameters;
      }
  
      private static Unsafe getUnsafe() throws ReflectiveOperationException {
          final Field unsafe = Unsafe.class.getDeclaredField("theUnsafe");
          unsafe.setAccessible(true);
          return (Unsafe) unsafe.get(null);
      }
  
      private static void setField(
              final Unsafe unsafe,
              final CallbackProxy proxy,
              final String name,
              final Object value) throws ReflectiveOperationException {
          final Field field = CallbackProxy.class.getDeclaredField(name);
          unsafe.putObject(proxy, unsafe.objectFieldOffset(field), value);
      }
  
      public static final class TestDispatchParameters extends DISPPARAMS.ByReference {
          private VARIANT[] arguments;
          private DISPID[] namedArguments;
  
          @Override
          public VARIANT[] getArgs() {
              return arguments;
          }
  
          @Override
          public DISPID[] getRgdispidNamedArgs() {
              return namedArguments;
          }
      }
  
      @ComInterface(iid = "{12345678-1234-1234-1234-1234567890AB}")
      public interface SampleEvents {
          @ComMethod(dispId = 7)
          void onValue(int value, boolean defaultFlag);
      }
  
      public static final class RecordingListener extends AbstractComEventCallbackListener implements SampleEvents {
          private int lastValue = -1;
          private boolean lastDefaultFlag = true;
          private String errorMessage;
  
          @Override
          public void setDispatchCallbackListener(final IDispatchCallback dispatchCallback) {
              super.setDispatchCallbackListener(dispatchCallback);
          }
  
          @Override
          public void errorReceivingCallbackEvent(final String message, final Exception exception) {
              errorMessage = message;
          }
  
          @Override
          public void onValue(final int value, final boolean defaultFlag) {
              lastValue = value;
              lastDefaultFlag = defaultFlag;
          }
      }
  }
