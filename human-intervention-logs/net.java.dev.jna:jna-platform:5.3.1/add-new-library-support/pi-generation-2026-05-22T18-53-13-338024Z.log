      @ComInterface(iid = "{12345678-1234-1234-1234-1234567890AB}")
      public interface SampleEvents {
          @ComMethod(dispId = 7)
          void onValue(int value, boolean defaultFlag);
      }
  
      public static final class RecordingListener extends AbstractComEventCallbackListener implements SampleEvents {
          private int lastValue = -1;
          private boolean lastDefaultFlag = true;
          private String errorMessage;
  
          @Override
          public void setDispatchCallbackListener(final IDispatchCallback dispatchCallback) {
              super.setDispatchCallbackListener(dispatchCallback);
          }
  
          @Override
          public void errorReceivingCallbackEvent(final String message, final Exception exception) {
              errorMessage = message;
          }
  
          @Override
          public void onValue(final int value, final boolean defaultFlag) {
              lastValue = value;
              lastDefaultFlag = defaultFlag;
          }
      }
