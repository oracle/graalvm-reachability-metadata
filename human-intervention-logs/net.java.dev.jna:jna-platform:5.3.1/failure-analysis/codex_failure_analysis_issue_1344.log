 {\\n        Throwable cause = exception.getCause();\\n        if (cause instanceof Exception) {\\n            throw (Exception) cause;\\n        }\\n        if (cause instanceof Error) {\\n            throw (Error) cause;\\n        }\\n        throw new AssertionError(cause);\\n    }\\n\\n    private static Throwable rootCause(Throwable throwable) {\\n\", \"newText\": \"    private static void withWindowsLongSize() throws Exception {\\n        if (Native.LONG_SIZE == 4) {\\n            return;\\n        }\\n\\n        Field field = Native.class.getField(\\\"LONG_SIZE\\\");\\n        Unsafe unsafe = unsafe();\\n        unsafe.putInt(unsafe.staticFieldBase(field), unsafe.staticFieldOffset(field), 4);\\n    }\\n\\n    private static Unsafe unsafe() throws Exception {\\n        Field field = Unsafe.class.getDeclaredField(\\\"theUnsafe\\\");\\n        field.setAccessible(true);\\n        return (Unsafe) field.get(null);\\n    }\\n\\n    private static <T> T rethrowCause(InvocationTargetException exception) throws Exception {\\n        Throwable cause = exception.getCause();\\n        if (cause instanceof Exception) {\\n            throw (Exception) cause;\\n        }\\n        if (cause instanceof Error) {\\n            throw (Error) cause;\\n        }\\n        throw new AssertionError(cause);\\n    }\\n\\n    private static Throwable rootCause(Throwable throwable) {\\n\"}]}}], \"api\": \"openai-responses\", \"provider\": \"OCA\", \"model\": \"gpt-5.5\", \"usage\": {\"input\": 2443, \"output\": 1787, \"cacheRead\": 64000, \"cacheWrite\": 0, \"totalTokens\": 68230, \"cost\": {\"input\": 0, \"output\": 0, \"cacheRead\": 0, \"cacheWrite\": 0, \"total\": 0}}, \"stopReason\": \"toolUse\", \"timestamp\": 1777926921174, \"responseId\": \"resp_0fb63b68099e23620169f9030a3d0c819caebb1bc66dbe3038\"}, \"toolResults\": [{\"role\": \"toolResult\", \"toolCallId\": \"call_ypDFjywcgC5mdIf1W9lOktxH|fc_0fb63b68099e23620169f9031a6ac8819ca4bfcef7b69f63b4\", \"toolName\": \"edit\", \"conten