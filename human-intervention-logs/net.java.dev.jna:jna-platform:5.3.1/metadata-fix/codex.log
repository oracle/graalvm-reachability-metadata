Convert\");\n        Method toVariant = convertType.getDeclaredMethod(\"toVariant\", Object.class);\n        toVariant.setAccessible(true);\n        try {\n            return (VARIANT) toVariant.invoke(null, value);\n        } catch (InvocationTargetException exception) {\n            return rethrowCause(exception);\n        }\n    }\n\n    private static SampleComEnum invokeConvertToComEnum(Class<SampleComEnum> enumType, Object value) throws Exception {\n        Class<?> convertType = Class.forName(\"com.sun.jna.platform.win32.COM.util.Convert\");\n        Method toComEnum = convertType.getDeclaredMethod(\"toComEnum\", Class.class, Object.class);\n        toComEnum.setAccessible(true);\n        try {\n            return (SampleComEnum) toComEnum.invoke(null, enumType, value);\n        } catch (InvocationTargetException exception) {\n            return rethrowCause(exception);\n        }\n    }\n\n    private static <T> T rethrowCause(InvocationTargetException exception) throws Exception {\n        Throwable cause = exception.getCause();\n        if (cause instanceof Exception) {\n            throw (Exception) cause;\n        }\n        if (cause instanceof Error) {\n            throw (Error) cause;\n        }\n        throw new AssertionError(cause);\n    }\n\n    private static Throwable rootCause(Throwable throwable) {\n        Throwable cause = throwable;\n        while (cause.getCause() != null) {\n            cause = cause.getCause();\n        }\n        return cause;\n    }\n\n    public enum SampleComEnum implements IComEnum {\n        FIRST(1),\n        SECOND(2);\n\n        private final long value;\n\n        SampleComEnum(long value) {\n            this.value = value;\n        }\n\n        @Override\n        public long getValue() {\n            return value;\n        }\n    }\n}\n","exit_code":0,"status":"completed"}}
