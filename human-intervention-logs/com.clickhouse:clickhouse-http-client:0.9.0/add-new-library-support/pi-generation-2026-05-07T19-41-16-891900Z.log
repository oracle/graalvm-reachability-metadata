      protected final String getUserAgent() {
          final ClickHouseConfig c = config;
          String name = c.getClientName();
          String userAgent = getDefaultUserAgent();
  
          if (!ClickHouseClientOption.CLIENT_NAME.getDefaultValue().equals(name)) {
