      38	@SuppressWarnings("deprecation")
      39	public class Clickhouse_http_clientTest {
      40	    @Test
      41	    void allConnectionProvidersExecuteQueriesWithHeadersAndParameters() throws Exception {
      42	        for (HttpConnectionProvider provider : HttpConnectionProvider.values()) {
      43	            try (MockClickHouseServer server = MockClickHouseServer.start();
      44	                    ClickHouseClient client = newClient(provider)) {
      45	                ClickHouseNode node = server.node("analytics");
      46	
      47	                assertThat(client.accept(ClickHouseProtocol.HTTP)).isTrue();
      48	
      49	                String queryId = "query-" + provider.name();
      50	                try (ClickHouseResponse response = client.read(node)
      51	                        .option(ClickHouseClientOption.ASYNC, false)
      52	                        .option(ClickHouseClientOption.CONNECTION_TIMEOUT, 2_000)
      53	                        .option(ClickHouseClientOption.SOCKET_TIMEOUT, 5_000)
      54	                        .option(ClickHouseHttpOption.CONNECTION_PROVIDER, provider)
      55	                        .format(ClickHouseFormat.TabSeparated)
      56	                        .session("session 1", true, 4)
      57	                        .set(ClickHouseClientOption.MAX_RESULT_ROWS.getKey(), "7")
      58	                        .query("SELECT 42 FORMAT TabSeparated", queryId)
      59	                        .executeAndWait()) {
      60	                    assertThat(new String(response.getInputStream().readAllBytes(), UTF_8)).isEqualTo("answer\n");
      61	                    assertThat(response.getTimeZone().getID()).isEqualTo("UTC");
      62	                }
      63	
      64	                RequestRecord queryRequest = server.nextRequest();
      65	                assertThat(queryRequest.method()).isEqualTo("POST");
      66	                assertThat(queryRequest.path()).isEqualTo("/");
      67	                assertThat(queryRequest.query())
      68	                        .contains("session_id=session+1")
      69	                        .contains("session_check=1")
      70	                        .contains("session_timeout=4")
      71	                        .contains("query_id=" + queryId)
      72	                        .contains("max_result_rows=7")
      73	                        .contains("extremes=0");
      74	                assertThat(queryRequest.header("X-Test-Header")).isEqualTo("test-value");
      75	                assertThat(queryRequest.header("X-ClickHouse-Database")).isEqualTo("analytics");
      76	                assertThat(queryRequest.header("X-ClickHouse-Format")).isEqualTo("TabSeparated");
      77	                assertThat(queryRequest.header("User-Agent")).contains("ClickHouse");
      78	                assertThat(queryRequest.bodyAsString()).contains("SELECT 42 FORMAT TabSeparated");
      79	            }
      80	        }
      81	    }
