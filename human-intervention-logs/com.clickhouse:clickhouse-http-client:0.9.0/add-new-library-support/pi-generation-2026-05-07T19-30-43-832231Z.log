      83	    @Test
      84	    void pingUsesClickHousePingEndpoint() throws Exception {
      85	        try (MockClickHouseServer server = MockClickHouseServer.start();
      86	                ClickHouseClient client = newClient(HttpConnectionProvider.APACHE_HTTP_CLIENT)) {
      87	            assertThat(client.ping(server.node("default"), 2_000)).isTrue();
      88	
      89	            RequestRecord pingRequest = server.nextRequest();
      90	            assertThat(pingRequest.method()).isEqualTo("GET");
      91	            assertThat(pingRequest.path()).isEqualTo("/ping");
