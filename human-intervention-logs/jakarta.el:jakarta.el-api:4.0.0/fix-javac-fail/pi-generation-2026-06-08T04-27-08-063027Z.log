          @Override
          public ELResolver getELResolver() {
              return null;
          }
  
          @Override
          public FunctionMapper getFunctionMapper() {
              return null;
          }
  
          @Override
          public VariableMapper getVariableMapper() {
              return null;
          }
      }
  }
