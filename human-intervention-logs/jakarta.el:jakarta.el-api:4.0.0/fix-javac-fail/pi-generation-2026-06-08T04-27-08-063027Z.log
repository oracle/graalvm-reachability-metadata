             ELContext context,\n                String expression,\n                Class<?> expectedReturnType,\n                Class<?>[] expectedParamTypes) {\n            throw new UnsupportedOperationException(\"Expression parsing is not needed by these tests\");\n        }\n\n        @Override\n        public Object coerceToType(Object obj, Class<?> targetType) {\n            if (targetType == null) {\n                throw new NullPointerException(\"targetType\");\n            }\n            Class<?> boxedTargetType = box(targetType);\n            if (obj == null) {\n                return targetType.isPrimitive() ? primitiveDefault(targetType) : null;\n            }\n            if (boxedTargetType.isInstance(obj)) {\n                return obj;\n            }\n            if (boxedTargetType == String.class) {\n                return obj.toString();\n            }\n            throw new ELException(\"Cannot coerce \" + obj + \" to \" + targetType.getName());\n        }\n\n        @Override\n        public ELResolver getStreamELResolver() {\n            return null;\n        }\n\n        private static Class<?> box(Class<?> type) {\n            if (!type.isPrimitive()) {\n                return type;\n            }\n            if (type == boolean.class) {\n                return Boolean.class;\n            }\n            if (type == char.class) {\n                return Character.class;\n            }\n            if (type == byte.class) {\n                return Byte.class;\n            }\n            if (type == short.class) {\n                return Short.class;\n            }\n            if (type == int.class) {\n                return Integer.class;\n            }\n            if (type == long.class) {\n                return Long.class;\n            }\n            if (type == float.class) {\n                return Float.class;\n            }\n            return Double.class;\n        }\n\n        private static Object primitiveDefault(Class<?> type) {\n            if (type == boolean.class) {\n                return false;\n            }\n            if (type == char.class) {\n                return '\\0';\n            }\n            if (type == byte.class) {\n                return (byte) 0;\n            }\n            if (type == short.class) {\n                return (short) 0;\n            }\n            if (type == int.class) {\n                return 0;\n\n[12 more lines in file. Use offset=171 to continue.]"}], "isError": false, "timestamp": 1780892858894}}
