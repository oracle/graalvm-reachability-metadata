TARGET,\n                StandardAuthScheme.BASIC,\n                new BasicNameValuePair(\"realm\", \"cached-realm\")), null);\n\n        BasicAuthCache authCache = new BasicAuthCache();\n        authCache.put(host, scheme);\n\n        AuthScheme restored = authCache.get(new HttpHost(\"http\", \"cache.example\", 8080));\n\n        assertThat(restored).isInstanceOf(BasicScheme.class);\n        assertThat(restored).isNotSameAs(scheme);\n        BasicScheme restoredScheme = (BasicScheme) restored;\n        assertThat(restoredScheme.getName()).isEqualTo(StandardAuthScheme.BASIC);\n        assertThat(restoredScheme.getRealm()).isEqualTo(\"cached-realm\");\n        assertThat(restoredScheme.isChallengeComplete()).isTrue();\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 754, "output": 1325, "cacheRead": 19456, "cacheWrite": 0, "totalTokens": 21535, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777382881050, "responseId": "resp_00d3faaeaecb72230169f0b5e18858819dbfdc14a76d87e3a6"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_T4eYA1PNl293HWYPcV8an3Ze|fc_00d3faaeaecb72230169f0b5ea8db8819dac2650f9c83ebbb4", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2185 bytes to tests/src/com.github.docker-java/docker-java-transport-zerodep/3.2.13/src/test/java/com_github_docker_java/docker_java_transport_zerodep/BasicAuthCacheTest.java"}], "isError": false, "timestamp": 1777382893951}]}
