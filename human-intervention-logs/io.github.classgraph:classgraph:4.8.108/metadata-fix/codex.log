           }\n            throw exception;\n        } catch (final Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    private static void invokeLegacyDirectBufferCleanerPath() throws Exception {\n        LegacyCleanerHooks.reset();\n        final String previousJavaVersion = System.getProperty(\"java.version\");\n        System.setProperty(\"java.version\", LEGACY_JAVA_VERSION);\n        try (URLClassLoader isolatedClassLoader = new URLClassLoader(isolatedClassPath(), null)) {\n            final Class<?> fileUtilsClass = Class.forName(FILE_UTILS_CLASS_NAME, true, isolatedClassLoader);\n            installLegacyCleanerHooks(fileUtilsClass);\n\n            final Class<?> logNodeClass = Class.forName(LOG_NODE_CLASS_NAME, false, isolatedClassLoader);\n            final Method closeDirectByteBuffer = fileUtilsClass.getMethod(\"closeDirectByteBuffer\",\n                    ByteBuffer.class, logNodeClass);\n            final Object closed = closeDirectByteBuffer.invoke(null, ByteBuffer.allocateDirect(16), null);\n\n            assertThat(closed).isEqualTo(Boolean.TRUE);\n            assertThat(LegacyCleanerHooks.attachmentInvoked).isTrue();\n            assertThat(LegacyCleanerHooks.cleanerInvoked).isTrue();\n            assertThat(LegacyCleanerHooks.cleanInvoked).isTrue();\n        } finally {\n            restoreJavaVersion(previousJavaVersion);\n        }\n    }\n\n    private static void installLegacyCleanerHooks(final Class<?> fileUtilsClass) throws Exception {\n        setStaticField(fileUtilsClass, \"attachmentMethod\", LegacyCleanerHooks.class.getMethod(\"attachment\"));\n        setStaticField(fileUtilsClass, \"directByteBufferCleanerMethod\", LegacyCleanerHooks.class.getMethod(\"cleaner\"));\n        setStaticField(fileUtilsClass, \"cleanerCleanMethod\", LegacyCleanerHooks.class.getMethod(\"clean\"));\n    }\n\n    private static void setStaticField(final Class<?> targetClass, final String fieldName, final Object value)\n            throws Exception {\n        final Field field = targetClass.getDeclaredField(fieldName);\n        field.setAccessible(true);\n        field.set(null, value);\n    }\n\n    private static URL[] isolatedClassPath() throws Exception {\n        final CodeSource codeSource = FileUtils.class.getProtectionDomain().getCodeSource();\n        if (codeSource != null && codeSource.getLocation() != null) {\n            return new URL[] { codeSource.getLocation() };\n        }\n        return Arrays.stream(System.getProperty(\"java.class.path\", \"\").split(Pattern.quote(File.pathSeparator)))\n                .filter(entry -> !entry.isEmpty())\n                .map(File::new)\n                .map(file -> {\n                    try {\n                        return file.toURI().toURL();\n                    } catch (final Exception exception) {\n                        throw new IllegalArgumentException(\"Could not convert classpath entry to URL: \" + file,\n                                exception);\n                    }\n                })\n                .toArray(URL[]::new);\n    }\n\n    private static void restoreJavaVersion(final String previousJavaVersion) {\n        if (previousJavaVersion == null) {\n            System.clearProperty(\"java.version\");\n        } else {\n            System.setProperty(\"java.version\", previousJavaVersion);\n        }\n    }\n\n    public static final class LegacyCleanerHooks {\n        private static boolean attachmentInvoked;\n        private static boolean cleanerInvoked;\n        private static boolean cleanInvoked;\n\n        private LegacyCleanerHooks() {\n        }\n\n        public static Object attachment() {\n            attachmentInvoked = true;\n            return null;\n        }\n\n        public static Object cleaner() {\n            cleanerInvoked = true;\n            return new Object();\n        }\n\n        public static void clean() {\n   