  package io_github_classgraph.classgraph;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import io.github.classgraph.AnnotationEnumValue;
  import io.github.classgraph.AnnotationInfo;
  import io.github.classgraph.ClassGraph;
  import io.github.classgraph.ClassInfo;
  import io.github.classgraph.ScanResult;
  import org.junit.jupiter.api.Test;
  
  public class AnnotationEnumValueTest {
      @Test
      void loadsEnumConstantFromAnnotationParameterValue() {
          try (ScanResult scanResult = new ClassGraph()
                  .acceptClasses(AnnotatedFixture.class.getName(), EnumConfigured.class.getName(), EnumMode.class.getName())
                  .enableAnnotationInfo()
                  .scan()) {
              final ClassInfo classInfo = scanResult.getClassInfo(AnnotatedFixture.class.getName());
              final AnnotationInfo annotationInfo = classInfo.getAnnotationInfo(EnumConfigured.class.getName());
              final Object parameterValue = annotationInfo.getParameterValues().getValue("mode");
  
              assertThat(parameterValue).isInstanceOf(AnnotationEnumValue.class);
              final AnnotationEnumValue enumValue = (AnnotationEnumValue) parameterValue;
  
              assertThat(enumValue.getClassName()).isEqualTo(EnumMode.class.getName());
              assertThat(enumValue.getValueName()).isEqualTo(EnumMode.ENABLED.name());
              assertThat(enumValue.loadClassAndReturnEnumValue()).isSameAs(EnumMode.ENABLED);
          }
      }
  
      @EnumConfigured(mode = EnumMode.ENABLED)
      public static class AnnotatedFixture {
      }
  
      public @interface EnumConfigured {
          EnumMode mode();
      }
  
      public enum EnumMode {
          DISABLED,
          ENABLED
      }
  }
