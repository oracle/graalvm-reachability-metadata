      private static void toString(final Object val, final boolean useSimpleNames, final StringBuilder buf) {
          if (val == null) {
              buf.append("null");
          } else if (val instanceof ScanResultObject) {
              ((ScanResultObject) val).toString(useSimpleNames, buf);
          } else {
