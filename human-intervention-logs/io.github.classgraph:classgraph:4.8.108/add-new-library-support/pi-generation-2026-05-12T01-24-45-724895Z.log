              value.setScanResult(scanResult);
          }
      }
  
      /**
       * Get {@link ClassInfo} objects for any classes referenced in the annotation parameters.
       *
       * @param classNameToClassInfo
       *            the map from class name to {@link ClassInfo}.
       * @param refdClassInfo
