      public TypeSignature getElementTypeSignature() {
          ArrayTypeSignature curr = this;
          while (curr.nestedType instanceof ArrayTypeSignature) {
              curr = (ArrayTypeSignature) curr.nestedType;
          }
          return curr.getNestedType();
      }
  
