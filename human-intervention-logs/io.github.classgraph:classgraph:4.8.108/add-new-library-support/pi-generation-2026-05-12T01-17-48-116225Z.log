  package io_github_classgraph.classgraph;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.lang.reflect.Constructor;
  import java.lang.reflect.Method;
  
  import io.github.classgraph.ClassGraph;
  import io.github.classgraph.ClassInfo;
  import io.github.classgraph.MethodInfo;
  import io.github.classgraph.MethodInfoList;
  import io.github.classgraph.ScanResult;
  import org.junit.jupiter.api.Test;
  
  public class MethodInfoTest {
      @Test
      void loadsPublicAndDeclaredMethods() {
          try (ScanResult scanResult = scanMethodFixtures()) {
              final ClassInfo classInfo = scanResult.getClassInfo(MethodFixtures.class.getName());
  
              final Method publicMethod = classInfo.getDeclaredMethodInfo()
                      .getSingleMethod("visibleMethod")
                      .loadClassAndGetMethod();
              final Method privateMethod = classInfo.getDeclaredMethodInfo()
                      .getSingleMethod("hiddenMethod")
                      .loadClassAndGetMethod();
  
              assertThat(publicMethod.getDeclaringClass()).isEqualTo(MethodFixtures.class);
              assertThat(publicMethod.getName()).isEqualTo("visibleMethod");
              assertThat(publicMethod.getParameterTypes()).containsExactly(String.class, int.class);
              assertThat(privateMethod.getDeclaringClass()).isEqualTo(MethodFixtures.class);
              assertThat(privateMethod.getName()).isEqualTo("hiddenMethod");
              assertThat(privateMethod.getParameterTypes()).containsExactly(CharSequence.class);
          }
      }
  
      @Test
      void loadsPublicAndDeclaredConstructors() {
          try (ScanResult scanResult = scanMethodFixtures()) {
              final ClassInfo classInfo = scanResult.getClassInfo(MethodFixtures.class.getName());
              final MethodInfoList constructors = classInfo.getDeclaredConstructorInfo();
  
              final MethodInfo publicConstructorInfo = constructorWithDescriptor(
                      constructors, "(Ljava/lang/String;)V");
              final MethodInfo privateConstructorInfo = constructorWithDescriptor(
                      constructors, "(J)V");
              final Constructor<?> publicConstructor = publicConstructorInfo
                      .loadClassAndGetConstructor();
              final Constructor<?> privateConstructor = privateConstructorInfo
                      .loadClassAndGetConstructor();
  
              assertThat(publicConstructor.getDeclaringClass()).isEqualTo(MethodFixtures.class);
              assertThat(publicConstructor.getParameterTypes()).containsExactly(String.class);
              assertThat(privateConstructor.getDeclaringClass()).isEqualTo(MethodFixtures.class);
              assertThat(privateConstructor.getParameterTypes()).containsExactly(long.class);
          }
      }
  
      private static ScanResult scanMethodFixtures() {
          return new ClassGraph()
                  .acceptClasses(MethodFixtures.class.getName())
                  .enableClassInfo()
                  .enableMethodInfo()
                  .ignoreMethodVisibility()
                  .scan();
      }
  
      private static MethodInfo constructorWithDescriptor(final MethodInfoList constructors,
              final String descriptor) {
          for (final MethodInfo constructor : constructors) {
              if (descriptor.equals(constructor.getTypeDescriptorStr())) {
                  return constructor;
              }
          }
          throw new IllegalStateException("Constructor not found with descriptor " + descriptor);
      }
  
      public static class MethodFixtures {
          public MethodFixtures(String value) {
              assertThat(value).isNotNull();
          }
  
          private MethodFixtures(long value) {
              assertThat(value).isGreaterThanOrEqualTo(0L);
          }
  
          public String visibleMethod(String value, int count) {
              return value.repeat(count);
          }
  
          private String hiddenMethod(CharSequence value) {
              return value.toString();
          }
      }
  }
