  package io_github_classgraph.classgraph;
  
  import static org.assertj.core.api.Assertions.assertThat;
  import static org.junit.jupiter.api.Assertions.assertThrows;
  
  import java.lang.reflect.InvocationTargetException;
  import java.lang.reflect.Method;
  import java.lang.reflect.ParameterizedType;
  import java.lang.reflect.Type;
  import java.util.ArrayList;
  import java.util.HashMap;
  import java.util.List;
  import java.util.Map;
  
  import nonapi.io.github.classgraph.json.JSONDeserializer;
  import org.junit.jupiter.api.Test;
  
  public class JSONDeserializerTest {
      @Test
      void deserializesObjectFieldsUsingArrayAndFieldConstructors() {
          final FieldConstructorContainer container = JSONDeserializer.deserializeObject(
                  FieldConstructorContainer.class,
                  """
                  {
                    "child": {"name": "primary"},
                    "numbers": [1, 2, 3],
                    "scores": {"first": 7, "second": 11},
                    "words": [["alpha", "beta"], ["gamma"]]
                  }
                  """);
  
          assertThat(container.child.name).isEqualTo("primary");
          assertThat(container.numbers).containsExactly(1, 2, 3);
          assertThat(container.scores).containsEntry("first", 7).containsEntry("second", 11);
          assertThat(container.words).isDeepEqualTo(new String[][] { { "alpha", "beta" }, { "gamma" } });
      }
  
      @Test
      void deserializesCollectionItemsUsingCommonValueConstructors() {
          final CommonValueContainer container = JSONDeserializer.deserializeObject(
                  CommonValueContainer.class,
                  """
                  {
                    "children": [{"name": "left"}, {"name": "right"}],
                    "maps": [{"one": 1}, {"two": 2, "three": 3}]
                  }
                  """);
  
          assertThat(container.children).extracting(child -> child.name).containsExactly("left", "right");
          assertThat(container.maps).hasSize(2);
          assertThat(container.maps.get(0)).containsEntry("one", 1);
          assertThat(container.maps.get(1)).containsEntry("two", 2).containsEntry("three", 3);
      }
  
      @Test
      void constructsNestedArrayWhenArrayInstanceHasParameterizedResolvedType() throws Exception {
          final Object parsedJson = parseJson("[[\"alpha\"], []]");
          final Object[] array = new Object[2];
          final InvocationTargetException exception = assertThrows(InvocationTargetException.class,
                  () -> populateObjectFromJsonObject(array, parameterizedListOfStringType(), parsedJson));
  
          assertThat(exception.getCause()).isInstanceOf(IllegalArgumentException.class)
                  .hasMessageContaining("Got illegal type");
          assertThat(array[0]).isInstanceOf(Object[].class);
          assertThat((Object[]) array[0]).hasSize(1);
          assertThat(array[1]).isInstanceOf(Object[].class);
          assertThat((Object[]) array[1]).isEmpty();
      }
  
      private static Object parseJson(final String json) throws Exception {
          final Class<?> jsonParserClass = Class.forName("nonapi.io.github.classgraph.json.JSONParser");
          final Method parseJsonMethod = jsonParserClass.getDeclaredMethod("parseJSON", String.class);
          parseJsonMethod.setAccessible(true);
          return parseJsonMethod.invoke(null, json);
      }
  
      private static void populateObjectFromJsonObject(final Object objectInstance, final Type objectResolvedType,
              final Object parsedJson) throws Exception {
          final Class<?> classFieldCacheClass = Class.forName("nonapi.io.github.classgraph.json.ClassFieldCache");
          final Method populateMethod = JSONDeserializer.class.getDeclaredMethod("populateObjectFromJsonObject",
                  Object.class, Type.class, Object.class, classFieldCacheClass, Map.class, List.class);
          populateMethod.setAccessible(true);
          populateMethod.invoke(null, objectInstance, objectResolvedType, parsedJson, null,
                  new HashMap<CharSequence, Object>(), new ArrayList<Runnable>());
      }
  
      private static ParameterizedType parameterizedListOfStringType() {
          return new ParameterizedType() {
              @Override
              public Type[] getActualTypeArguments() {
                  return new Type[] { String.class };
              }
  
              @Override
              public Type getRawType() {
                  return List.class;
              }
  
              @Override
              public Type getOwnerType() {
                  return null;
              }
          };
      }
  
      public static class FieldConstructorContainer {
          public NestedPojo child;
          public int[] numbers;
          public Map<String, Integer> scores;
          public String[][] words;
      }
  
      public static class CommonValueContainer {
          public List<NestedPojo> children;
          public List<Map<String, Integer>> maps;
      }
  
      public static class NestedPojo {
          public String name;
      }
  }
