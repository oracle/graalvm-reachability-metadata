  package io_github_classgraph.classgraph;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import nonapi.io.github.classgraph.json.JSONDeserializer;
  import org.junit.jupiter.api.Test;
  
  public class FieldTypeInfoTest {
      @Test
      void deserializesEveryFieldAssignmentKind() {
          final String json = """
                  {
                    "booleanValue": true,
                    "byteValue": 7,
                    "charValue": "g",
                    "classValue": "java.lang.String",
                    "doubleValue": 12.5,
                    "floatValue": 6.25,
                    "intValue": 42,
                    "longValue": 3000000000,
                    "nonPrimitiveValue": "classgraph",
                    "nullValue": null,
                    "shortValue": 1234
                  }
                  """;
  
          final FieldValues values = JSONDeserializer.deserializeObject(FieldValues.class, json);
  
          assertThat(values.booleanValue).isTrue();
          assertThat(values.byteValue).isEqualTo((byte) 7);
          assertThat(values.charValue).isEqualTo('g');
          assertThat(values.classValue).isEqualTo(String.class);
          assertThat(values.doubleValue).isEqualTo(12.5d);
          assertThat(values.floatValue).isEqualTo(6.25f);
          assertThat(values.intValue).isEqualTo(42);
          assertThat(values.longValue).isEqualTo(3_000_000_000L);
          assertThat(values.nonPrimitiveValue).isEqualTo("classgraph");
          assertThat(values.nullValue).isNull();
          assertThat(values.shortValue).isEqualTo((short) 1234);
      }
  
      public static class FieldValues {
          public boolean booleanValue;
          public byte byteValue;
          public char charValue;
          public Class<?> classValue;
          public double doubleValue;
          public float floatValue;
          public int intValue;
          public long longValue;
          public String nonPrimitiveValue;
          public String nullValue = "initial";
          public short shortValue;
  
          public FieldValues() {
          }
      }
  }
