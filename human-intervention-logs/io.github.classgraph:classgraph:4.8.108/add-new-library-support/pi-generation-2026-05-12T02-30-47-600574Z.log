  package io_github_classgraph.classgraph;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import io.github.classgraph.ArrayTypeSignature;
  import io.github.classgraph.FieldInfo;
  import io.github.classgraph.TypeSignature;
  import nonapi.io.github.classgraph.json.JSONDeserializer;
  import org.junit.jupiter.api.Test;
  
  public class ArrayTypeSignatureTest {
      @Test
      void loadsDetachedReferenceElementAndArrayClasses() {
          final FieldInfo fieldInfo = JSONDeserializer.deserializeObject(FieldInfo.class,
                  """
                  {
                    "declaringClassName": "io_github_classgraph.classgraph.ArrayTypeSignatureTest",
                    "name": "values",
                    "typeDescriptorStr": "[[Ljava/lang/String;"
                  }
                  """);
          final TypeSignature typeDescriptor = fieldInfo.getTypeDescriptor();
  
          assertThat(typeDescriptor).isInstanceOf(ArrayTypeSignature.class);
          final ArrayTypeSignature arrayTypeSignature = (ArrayTypeSignature) typeDescriptor;
  
          assertThat(arrayTypeSignature.getTypeSignatureStr()).isEqualTo("[[Ljava/lang/String;");
          assertThat(arrayTypeSignature.getNumDimensions()).isEqualTo(2);
          assertThat(arrayTypeSignature.loadElementClass()).isEqualTo(String.class);
          assertThat(arrayTypeSignature.loadClass()).isEqualTo(String[][].class);
      }
  }
