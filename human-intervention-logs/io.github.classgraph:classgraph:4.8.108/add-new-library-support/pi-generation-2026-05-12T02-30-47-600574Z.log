phClassLoader = classGraphClassLoader(scanResult);\n        setField(classGraphClassLoader, \"environmentClassLoaderDelegationOrder\", environmentClassLoaders);\n        setField(classGraphClassLoader, \"addedClassLoaderDelegationOrder\", addedClassLoaders);\n        return classGraphClassLoader;\n    }\n\n    private static ClassLoader classGraphClassLoader(ScanResult scanResult) throws Exception {\n        return (ClassLoader) getField(scanResult, \"classGraphClassLoader\");\n    }\n\n    private static Object getField(Object target, String fieldName) throws Exception {\n        final Field field = target.getClass().getDeclaredField(fieldName);\n        field.setAccessible(true);\n        return field.get(target);\n    }\n\n    private static void setField(Object target, String fieldName, Object value) throws Exception {\n        final Field field = target.getClass().getDeclaredField(fieldName);\n        field.setAccessible(true);\n        field.set(target, value);\n    }\n\n    private static ResourceOnlyClassLoader resourceLoader(Path tempDir, String resourcePath, String content)\n            throws Exception {\n        final Path resourceFile = tempDir.resolve(resourcePath);\n        final byte[] bytes = content.getBytes(StandardCharsets.UTF_8);\n        Files.write(resourceFile, bytes);\n        return new ResourceOnlyClassLoader(resourcePath, resourceFile.toUri().toURL(), bytes);\n    }\n\n    private static final class EmptyResourceClassLoader extends ClassLoader {\n        private EmptyResourceClassLoader() {\n            super(null);\n        }\n    }\n\n    private static final class ClassReturningClassLoader extends ClassLoader {\n        private boolean requestedTargetClass;\n\n        private ClassReturningClassLoader() {\n            super(null);\n        }\n\n        @Override\n        protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {\n            if (TEST_CLASS_NAME.equals(name)) {\n                requestedT