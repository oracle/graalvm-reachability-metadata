  package io_github_classgraph.classgraph;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.ByteArrayInputStream;
  import java.io.InputStream;
  import java.lang.reflect.Field;
  import java.net.URL;
  import java.nio.charset.StandardCharsets;
  import java.nio.file.Files;
  import java.nio.file.Path;
  import java.util.Collections;
  import java.util.Enumeration;
  import java.util.List;
  import java.util.Set;
  
  import io.github.classgraph.ClassGraph;
  import io.github.classgraph.ScanResult;
  import org.junit.jupiter.api.Test;
  import org.junit.jupiter.api.io.TempDir;
  
  public class ClassGraphClassLoaderTest {
      private static final String TEST_CLASS_NAME = ClassGraphClassLoaderTest.class.getName();
      private static final String MISSING_CLASS_NAME = "io_github_classgraph.classgraph."
              + "MissingClassGraphFixture";
      private static final String TEST_PACKAGE = ClassGraphClassLoaderTest.class.getPackageName();
  
      @Test
      void loadsClassThroughDelegateClassGraphClassLoader() throws Exception {
          try (ScanResult delegateScanResult = scanTestPackage(); ScanResult nestedScanResult = scanTestPackage()) {
              final ClassLoader delegateClassGraphClassLoader = classGraphClassLoader(delegateScanResult);
              final Object classpathFinder = getField(nestedScanResult, "classpathFinder");
              setField(classpathFinder, "delegateClassGraphClassLoader", delegateClassGraphClassLoader);
  
              assertThat(nestedScanResult.loadClass(TEST_CLASS_NAME, false))
                      .isSameAs(ClassGraphClassLoaderTest.class);
          }
      }
  
      @Test
      void loadsClassThroughOverrideClassLoader() {
          final ClassLoader contextClassLoader = Thread.currentThread().getContextClassLoader();
          try (ScanResult scanResult = new ClassGraph()
                  .overrideClassLoaders(contextClassLoader)
                  .acceptPackages(TEST_PACKAGE)
                  .enableClassInfo()
                  .scan()) {
              assertThat(scanResult.loadClass(TEST_CLASS_NAME, false)).isSameAs(ClassGraphClassLoaderTest.class);
          }
      }
  
      @Test
      void loadsClassThroughClassInfoClassLoaderAfterEnvironmentFails() throws Exception {
          final ClassReturningClassLoader classInfoClassLoader = new ClassReturningClassLoader();
          try (ScanResult scanResult = scanTestPackage()) {
              final ClassLoader classGraphClassLoader = classGraphClassLoader(scanResult);
              setField(classGraphClassLoader, "environmentClassLoaderDelegationOrder",
                      Set.of(new RecordingFailingClassLoader(TEST_CLASS_NAME)));
              setField(classGraphClassLoader, "addedClassLoaderDelegationOrder", Collections.emptySet());
              setField(scanResult.getClassInfo(TEST_CLASS_NAME), "classLoader", classInfoClassLoader);
  
              assertThat(scanResult.loadClass(TEST_CLASS_NAME, false)).isSameAs(ClassGraphClassLoaderTest.class);
              assertThat(classInfoClassLoader.requestedTargetClass).isTrue();
          }
      }
  
      @Test
      void loadsClassThroughEnvironmentClassLoader() {
          try (ScanResult scanResult = scanTestPackage()) {
              assertThat(scanResult.loadClass(TEST_CLASS_NAME, false)).isSameAs(ClassGraphClassLoaderTest.class);
          }
      }
  
      @Test
      void triesClasspathClassLoaderForMissingClass() throws Exception {
          final RecordingFailingClassLoader classpathClassLoader = new RecordingFailingClassLoader(MISSING_CLASS_NAME);
          try (ScanResult scanResult = scanTestPackage()) {
              final ClassLoader classGraphClassLoader = classGraphClassLoader(scanResult);
              setField(classGraphClassLoader, "environmentClassLoaderDelegationOrder", Collections.emptySet());
              setField(classGraphClassLoader, "overrideClassLoaders", null);
              setField(classGraphClassLoader, "classpathClassLoader", classpathClassLoader);
              setField(classGraphClassLoader, "addedClassLoaderDelegationOrder", Collections.emptySet());
  
              assertThat(scanResult.loadClass(MISSING_CLASS_NAME, true)).isNull();
              assertThat(classpathClassLoader.requestedExpectedClass).isTrue();
          }
      }
  
      @Test
      void triesAddedClassLoaderForMissingClass() throws Exception {
          final RecordingFailingClassLoader addedClassLoader = new RecordingFailingClassLoader(MISSING_CLASS_NAME);
          try (ScanResult scanResult = scanTestPackage()) {
              final ClassLoader classGraphClassLoader = classGraphClassLoader(scanResult);
              setField(classGraphClassLoader, "environmentClassLoaderDelegationOrder", Collections.emptySet());
              setField(classGraphClassLoader, "overrideClassLoaders", null);
