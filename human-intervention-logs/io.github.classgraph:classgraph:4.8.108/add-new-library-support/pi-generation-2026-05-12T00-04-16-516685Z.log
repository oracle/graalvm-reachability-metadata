GraphFixture\";\n    private static final String TEST_PACKAGE = ClassGraphClassLoaderTest.class.getPackageName();\n\n    @Test\n    void loadsClassThroughDelegateClassGraphClassLoader() throws Exception {\n        try (ScanResult delegateScanResult = scanTestPackage(); ScanResult nestedScanResult = scanTestPackage()) {\n            final ClassLoader delegateClassGraphClassLoader = classGraphClassLoader(delegateScanResult);\n            final Object classpathFinder = getField(nestedScanResult, \"classpathFinder\");\n            setField(classpathFinder, \"delegateClassGraphClassLoader\", delegateClassGraphClassLoader);\n\n            assertThat(nestedScanResult.loadClass(TEST_CLASS_NAME, false)).isSameAs(ClassGraphClassLoaderTest.class);\n        }\n    }\n\n    @Test\n    void loadsClassThroughOverrideClassLoader() {\n        final ClassLoader contextClassLoader = Thread.currentThread().getContextClassLoader();\n        try (ScanResult scanResult = new ClassGraph()\n                .overrideClassLoaders(contextClassLoader)\n                .acceptPackages(TEST_PACKAGE)\n                .enableClassInfo()\n                .scan()) {\n            assertThat(scanResult.loadClass(TEST_CLASS_NAME, false)).isSameAs(ClassGraphClassLoaderTest.class);\n        }\n    }\n\n    @Test\n    void triesClassInfoClassLoaderAfterOverrideClassLoaderFails() throws Exception {\n        try {\n            final URL testClassesLocation = testClassesLocation();\n            try (URLClassLoader isolatedLoader = new URLClassLoader(new URL[] { testClassesLocation }, null);\n                    ScanResult scanResult = new ClassGraph()\n                            .overrideClassLoaders(isolatedLoader)\n                            .acceptClasses(TEST_CLASS_NAME)\n                            .enableClassInfo()\n                            .scan()) {\n                isolatedLoader.close();\n\n                assertThat(scanResult.loadClass(TEST_CLASS_NAME, true))\n                        .extracting(Class::getName)\n                        .isEqualTo(TEST_CLASS_NAME);\n            }\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    @Test\n    void loadsClassThroughEnvironmentClassLoader() {\n        try (ScanResult scanResult = scanTestPackage()) {\n            assertThat(scanResult.loadClass(TEST_CLASS_NAME, false)).isSameAs(ClassGraphClassLoaderTest.class);\n        }\n    }\n\n    @Test\n    void triesClasspathClassLoaderForMissingClass() {\n        try (ScanResult scanResult = scanTestPackage()) {\n            assertThat(scanResult.loadClass(MISSING_CLASS_NAME, true)).isNull();\n        }\n    }\n\n    @Test\n    void triesAddedClassLoaderForMissingClass() {\n        final ClassLoader addedClassLoader = new ClassLoader(null) {\n        };\n        try (ScanResult scanResult = new ClassGraph()\n                .addClassLoader(addedClassLoader)\n                .acceptPackages(TEST_PACKAGE)\n                .enableClassInfo()\n                .scan()) {\n            assertThat(scanResult.loadClass(MISSING_CLASS_NAME, true)).isNull();\n        }\n    }\n\n    @Test\n    void delegatesResourceLookupsToEnvironmentClassLoader(@TempDir Path tempDir) throws Exception {\n        final String resourcePath = \"classgraph-loader-env-resource.txt\";\n        final ResourceOnlyClassLoader environmentLoader = resourceLoader(tempDir, resourcePath, \"environment\");\n        final ClassLoader classGraphClassLoader = configuredClassGraphClassLoader(\n                Set.of(environmentLoader), Collections.emptySet());\n\n        assertThat(classGraphClassLoader.getResource(resourcePath)).isEqualTo(environmentLoader.resourceUrl);\n        assertThat(Collections.list(classGraphClassLoader.getResources(resourcePath)))\n                .containsExactly(environmentLoader.resourceUrl);\n        try (InputStream inputStream = classGraphClassLoader.getResourceAsStream(resourcePath)) {\n            assertThat(new String(inputStream.readAllBytes(), StandardCharsets.UTF_8)).isEqualTo(\"environment\");\n        }\n    }\n\n    @Test\n    void delegatesResourceLookupsToAddedClassLoader(@TempDir Path tempDir) throws Exception {\n        final String resourcePath = \"classgraph-loader-added-resource.txt\";\n        final ResourceOnlyClassLoader addedLoader = resourceLoader(tempDir, resourcePath, \"added\");\n        final ClassLoader classGraphClassLoader = configuredClassGraphClassLoader(\n                Set.of(new EmptyResourceClassLoader()), Set.of(addedLoader));\n\n        assertThat(classGraphClassLoader.getResource(resourcePath)).isEqualTo(addedLoader.resourceUrl);\n        assertThat(Collections.list(classGraphClassLoader.getResources(resourcePath))).containsExactly(addedLoader.resourceUrl);\n        try (InputStream inputStream = classGraphClassLoader.getResourceAsStream(resourcePath)) {\n            assertThat(new String(inputStream.readAllBytes(), StandardCharsets.UTF_8)).isEqualTo(\"added\");\n        }\n    }\n\n    @Test\n    void fallsBackWhenResourceIsAbsent() throws Exception {\n        final String resourcePath = \"classgraph-loader-missing-resource.txt\";\n        final ClassLoader classGraphClassLoader = configuredClassGraphClassLoader(\n                Set.of(new EmptyResourceClassLoader()), Set.of(new EmptyResourceClassLoader()));\n\n        assertThat(classGraphClassLoader.getResource(resourcePath)).isNull();\n        assertThat(Collections.list(classGraphClassLoader.getResources(resourcePath))).isEmpty();\n        assertThat(classGraphClassLoader.getResourceAsStream(resourcePath)).isNull();\n    }\n\n    private static ScanResult scanTestPackage() {\n        return new ClassGraph()\n                .acceptPackages(TEST_PACKAGE)\n                .enableClassInfo()\n                .scan();\n    }\n\n    private static ClassLoader configuredClassGraphClassLoader(\n            Set<ClassLoader> environmentClassLoaders, Set<ClassLoader> addedClassLoaders) throws Exception {\n        final ScanResult scanResult = scanTestPackage();\n        final ClassLoader classGraphClassLoader = classGraphClassLoader(scanResult);\n        setField(classGraphClassLoader, \"environmentClassLoaderDelegationOrder\", environmentClassLoaders);\n        setField(classGraphClassLoader, \"addedClassLoaderDelegationOrder\", addedClassLoaders);\n        return classGraphClassLoader;\n    }\n\n    private static ClassLoader classGraphClassLoader(ScanResult scanResult) throws Exception {\n        return (ClassLoader) getField(scanResult, \"classGraphClassLoader\");\n    }\n\n    private static Object getField(Object target, String fieldName) throws Exception {\n        final Field field = target.getClass().getDeclaredField(fieldName);\n        field.setAccessible(true);\n        return field.get(target);\n    }\n\n    private static void setField(Object target, String fieldName, Object value) throws Exception {\n        final Field field = target.getClass().getDeclaredField(fieldName);\n        field.setAccessible(true);\n        field.set(target, value);\n    }\n\n    private static URL testClassesLocation() {\n        return ClassGraphClassLoaderTest.class.getProtectionDomain().getCodeSource().getLocation();\n    }\n\n    private static ResourceOnlyClassLoader resourceLoader(Path tempDir, String resourcePath, String content)\n            throws Exception {\n        final Path resourceFile = tempDir.resolve(resourcePath);\n        final byte[] bytes = content.getBytes(StandardCharsets.UTF_8);\n        Files.write(resourceFile, bytes);\n        return new ResourceOnlyClassLoader(resourcePath, resourceFile.toUri().toURL(), bytes);\n    }\n\n    private static final class EmptyResourceClassLoader extends ClassLoader {\n        private EmptyResourceClassLoader() {\n            super(null);\n        }\n    }\n\n    private static final class ResourceOnlyClassLoader extends ClassLoader {\n        private final String resourcePath;\n        private final URL resourceUrl;\n        private final byte[] resourceBytes;\n\n        private ResourceOnlyClassLoader(String resourcePath, URL resourceUrl, byte[] resourceBytes) {\n            super(null);\n            this.resourcePath = resourcePath;\n            this.resourceUrl = resourceUrl;\n            this.resourceBytes = resourceBytes.clone();\n        }\n\n        @Override\n        public URL getResource(String name) {\n            return resourcePath.equals(name) ? resourceUrl : null;\n        }\n\n        @Override\n        public Enumeration<URL> getResources(String name) {\n            if (resourcePath.equals(name)) {\n                return Collections.enumeration(List.of(resourceUrl));\n            }\n            return Collections.emptyEnumeration();\n        }\n\n        @Override\n        public InputStream getResourceAsStream(String name) {\n            if (resourcePath.equals(name)) {\n                return new ByteArrayInputStream(resourceBytes);\n            }\n            return null;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 415, "output": 3031, "cacheRead": 35328, "cacheWrite": 0, "totalTokens": 38774, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778544148932, "responseId": "resp_0bd6a39afaff084d016a026e1602cc819d85e4948d01b3bce6"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_NyWTyDOxEyWak7xmMlPFHwxu|fc_0bd6a39afaff084d016a026e2094d8819d8c8d260eb2f6adb4", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 9966 bytes to tests/src/io.github.classgraph/classgraph/4.8.108/src/test/java/io_github_classgraph/classgraph/ClassGraphClassLoaderTest.java"}], "isError": false, "timestamp": 1778544173856}]}
