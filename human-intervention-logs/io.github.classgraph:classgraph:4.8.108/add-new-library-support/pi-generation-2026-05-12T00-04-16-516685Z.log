t.of(addedLoader));\n\n        assertThat(classGraphClassLoader.getResource(resourcePath)).isEqualTo(addedLoader.resourceUrl);\n        assertThat(Collections.list(classGraphClassLoader.getResources(resourcePath))).containsExactly(addedLoader.resourceUrl);\n        try (InputStream inputStream = classGraphClassLoader.getResourceAsStream(resourcePath)) {\n            assertThat(new String(inputStream.readAllBytes(), StandardCharsets.UTF_8)).isEqualTo(\"added\");\n        }\n    }\n\n    @Test\n    void fallsBackWhenResourceIsAbsent() throws Exception {\n        final String resourcePath = \"classgraph-loader-missing-resource.txt\";\n        final ClassLoader classGraphClassLoader = configuredClassGraphClassLoader(\n                Set.of(new EmptyResourceClassLoader()), Set.of(new EmptyResourceClassLoader()));\n\n        assertThat(classGraphClassLoader.getResource(resourcePath)).isNull();\n        assertThat(Collections.list(classGraphClassLoader.getResources(resourcePath))).isEmpty();\n        assertThat(classGraphClassLoader.getResourceAsStream(resourcePath)).isNull();\n    }\n\n    private static ScanResult scanTestPackage() {\n        return new ClassGraph()\n                .acceptPackages(TEST_PACKAGE)\n                .enableClassInfo()\n                .scan();\n    }\n\n    private static ClassLoader configuredClassGraphClassLoader(\n            Set<ClassLoader> environmentClassLoaders, Set<ClassLoader> addedClassLoaders) throws Exception {\n        final ScanResult scanResult = scanTestPackage();\n        final ClassLoader classGraphClassLoader = classGraphClassLoader(scanResult);\n        setField(classGraphClassLoader, \"environmentClassLoaderDelegationOrder\", environmentClassLoaders);\n        setField(classGraphClassLoader, \"addedClassLoaderDelegationOrder\", addedClassLoaders);\n        return classGraphClassLoader;\n    }\n\n    private static ClassLoader classGraphClassLoader(ScanResult scanResult) throws Exception {\n        return (ClassLoader) 