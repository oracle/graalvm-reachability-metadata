[tool-call] delta {"path":"tests/src/io.github.classgraph/classgraph/4.8.108/src/test/java/io_github_classgraph/classgraph/ReflectionUtilsTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_github_classgraph.classgraph;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport nonapi.io.github.classgraph.utils.ReflectionUtils;\nimport org.junit.jupiter.api.Test;\n\npublic class ReflectionUtilsTest {\n    @Test\n    void readsPrivateFieldDeclaredBySuperclass() {\n        final FieldFixture fixture = new FieldFixture(\"classgraph\");\n\n        final Object value = ReflectionUtils.getFieldVal(fixture, \"inheritedPrivateField\", true);\n\n        assertThat(value).isEqualTo(\"classgraph\");\n    }\n\n    @Test\n    void readsStaticFieldDeclaredBySuperclass() {\n        final Object value = ReflectionUtils.getStaticFieldVal(FieldFixture.class, \"STATIC_INHERITED_FIELD\", true);\n\n        assertThat(value).isEqualTo(108);\n    }\n\n    private static class FieldFixture extends FieldFixtureBase {\n        FieldFixture(final String inheritedPrivateField) {\n            super(inheritedPrivateField);\n        }\n    }\n\n    private static class FieldFixtureBase {\n        private static final int STATIC_INHERITED_FIELD = 108;\n\n        private final String inheritedPrivateField;\n\n        FieldFixtureBase(final String inheritedPrivateField) {\n            this.inheritedPrivateField = inheritedPrivateField;\n        }\n    }\n}\n"}
