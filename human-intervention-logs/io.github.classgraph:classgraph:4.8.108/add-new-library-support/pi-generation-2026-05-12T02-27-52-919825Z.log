  package io_github_classgraph.classgraph;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import nonapi.io.github.classgraph.json.JSONDeserializer;
  import org.junit.jupiter.api.Test;
  
  public class TypeResolutionsTest {
      @Test
      void deserializesResolvedGenericArrayFields() {
          final Wrapper wrapper = JSONDeserializer.deserializeObject(
                  Wrapper.class,
                  """
                  {
                    "holder": {
                      "oneDimension": ["alpha", "beta"],
                      "twoDimensions": [["gamma"], ["delta", "epsilon"]]
                    }
                  }
                  """);
  
          assertThat(wrapper.holder.oneDimension).containsExactly("alpha", "beta");
          assertThat(wrapper.holder.twoDimensions).isDeepEqualTo(new String[][] {
                  { "gamma" },
                  { "delta", "epsilon" }
          });
      }
  
      public static class Wrapper {
          public GenericArrayHolder<String> holder;
      }
  
      public static class GenericArrayHolder<T> {
          public T[] oneDimension;
          public T[][] twoDimensions;
      }
  }
