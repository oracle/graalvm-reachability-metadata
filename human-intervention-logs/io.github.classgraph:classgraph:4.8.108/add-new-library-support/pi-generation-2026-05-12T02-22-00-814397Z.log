  package io_github_classgraph.classgraph;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.lang.reflect.Field;
  
  import io.github.classgraph.ClassGraph;
  import io.github.classgraph.ClassInfo;
  import io.github.classgraph.ScanResult;
  import org.junit.jupiter.api.Test;
  
  public class FieldInfoTest {
      @Test
      void loadsPublicAndDeclaredFields() {
          try (ScanResult scanResult = scanFieldFixtures()) {
              final ClassInfo classInfo = scanResult.getClassInfo(FieldFixtures.class.getName());
  
              final Field publicField = classInfo.getDeclaredFieldInfo("visibleField")
                      .loadClassAndGetField();
              final Field privateField = classInfo.getDeclaredFieldInfo("hiddenField")
                      .loadClassAndGetField();
  
              assertThat(publicField.getDeclaringClass()).isEqualTo(FieldFixtures.class);
              assertThat(publicField.getName()).isEqualTo("visibleField");
              assertThat(publicField.getType()).isEqualTo(String.class);
              assertThat(privateField.getDeclaringClass()).isEqualTo(FieldFixtures.class);
              assertThat(privateField.getName()).isEqualTo("hiddenField");
              assertThat(privateField.getType()).isEqualTo(int.class);
          }
      }
  
      private static ScanResult scanFieldFixtures() {
          return new ClassGraph()
                  .acceptClasses(FieldFixtures.class.getName())
                  .enableClassInfo()
                  .enableFieldInfo()
                  .ignoreFieldVisibility()
                  .scan();
      }
  
      public static class FieldFixtures {
          public String visibleField = "classgraph";
          private int hiddenField = 42;
      }
  }
