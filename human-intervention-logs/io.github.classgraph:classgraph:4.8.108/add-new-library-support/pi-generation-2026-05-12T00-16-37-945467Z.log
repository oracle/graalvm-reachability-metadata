e static final class AccessibleObjectMethods {\n        private static final Method IS_ACCESSIBLE;\n        private static final Method TRY_SET_ACCESSIBLE;\n\n        static {\n            try {\n                IS_ACCESSIBLE = Field.class.getMethod(\"isAccessible\");\n                TRY_SET_ACCESSIBLE = Field.class.getMethod(\"trySetAccessible\");\n            } catch (NoSuchMethodException e) {\n                throw new ExceptionInInitializerError(e);\n            }\n        }\n    }\n}\n"}
