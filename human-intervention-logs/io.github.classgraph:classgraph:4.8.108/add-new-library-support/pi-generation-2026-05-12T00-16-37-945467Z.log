[tool-call] delta {"path":"tests/src/io.github.classgraph/classgraph/4.8.108/src/test/java/io_github_classgraph/classgraph/JSONUtilsTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_github_classgraph.classgraph;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.lang.reflect.Field;\nimport java.lang.reflect.Method;\n\nimport nonapi.io.github.classgraph.json.JSONSerializer;\nimport nonapi.io.github.classgraph.json.JSONUtils;\nimport org.junit.jupiter.api.Test;\n\npublic class JSONUtilsTest {\n    @Test\n    void serializesEveryPrimitiveAndObjectFieldAccessor() {\n        final String json = JSONSerializer.serializeObject(new FieldValues());\n\n        assertThat(json)\n                .contains(\"\\\"booleanValue\\\":true\")\n                .contains(\"\\\"byteValue\\\":7\")\n                .contains(\"\\\"charValue\\\":\\\"g\\\"\")\n                .contains(\"\\\"doubleValue\\\":12.5\")\n                .contains(\"\\\"floatValue\\\":6.25\")\n                .contains(\"\\\"intValue\\\":42\")\n                .contains(\"\\\"longValue\\\":3000000000\")\n                .contains(\"\\\"objectValue\\\":\\\"classgraph\\\"\")\n                .contains(\"\\\"shortValue\\\":1234\");\n    }\n\n    @Test\n    void usesAccessibleObjectMethodFallbacksWhenMethodHandlesAreUnavailable() throws Exception {\n        final Field isAccessibleMethodHandleField = jsonUtilsField(\"isAccessibleMethodHandle\");\n        final Field isAccessibleMethodField = jsonUtilsField(\"isAccessibleMethod\");\n        final Field trySetAccessibleMethodHandleField = jsonUtilsField(\"trySetAccessibleMethodHandle\");\n        final Field trySetAccessibleMethodField = jsonUtilsField(\"trySetAccessibleMethod\");\n\n        final Object originalIsAccessibleMethodHandle = isAccessibleMethodHandleField.get(null);\n        final Object originalIsAccessibleMethod = isAccessibleMethodField.get(null);\n        final Object originalTrySetAccessibleMethodHandle = trySetAccessibleMethodHandleField.get(null);\n        final Object originalTrySetAccessibleMethod = trySetAccessibleMethodField.get(null);\n\n        try {\n            isAccessibleMethodHandleField.set(null, null);\n            isAccessibleMethodField.set(null, AccessibleObjectMethods.IS_ACCESSIBLE);\n            trySetAccessibleMethodHandleField.set(null, null);\n            trySetAccessibleMethodField.set(null, AccessibleObjectMethods.TRY_SET_ACCESSIBLE);\n\n            assertThat(JSONSerializer.serializeObject(new FallbackValues()))\n                    .contains(\"\\\"value\\\":7\");\n        } finally {\n            isAccessibleMethodHandleField.set(null, originalIsAccessibleMethodHandle);\n            isAccessibleMethodField.set(null, originalIsAccessibleMethod);\n            trySetAccessibleMethodHandleField.set(null, originalTrySetAccessibleMethodHandle);\n            trySetAccessibleMethodField.set(null, originalTrySetAccessibleMethod);\n        }\n    }\n\n    private static Field jsonUtilsField(String fieldName) throws Exception {\n        final Field field = JSONUtils.class.getDeclaredField(fieldName);\n        field.setAccessible(true);\n        return field;\n    }\n\n    public static class FieldValues {\n        public boolean booleanValue = true;\n        public byte byteValue = 7;\n        public char charValue = 'g';\n        public double doubleValue = 12.5d;\n        public float floatValue = 6.25f;\n        public int intValue = 42;\n        public long longValue = 3_000_000_000L;\n        public String objectValue = \"classgraph\";\n        public short shortValue = 1_234;\n    }\n\n    public static class FallbackValues {\n        public int value = 7;\n    }\n\n    private static final class AccessibleObjectMethods {\n        private static final Method IS_ACCESSIBLE;\n        private static final Method TRY_SET_ACCESSIBLE;\n\n        static {\n            try {\n                IS_ACCESSIBLE = Field.class.getMethod(\"isAccessible\");\n                TRY_SET_ACCESSIBLE = Field.class.getMethod(\"trySetAccessible\");\n            } catch (NoSuchMethodException e) {\n                throw new ExceptionInInitializerError(e);\n            }\n        }\n    }\n}\n"}
