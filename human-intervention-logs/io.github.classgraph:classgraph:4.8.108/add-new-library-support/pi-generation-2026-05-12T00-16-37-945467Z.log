  package io_github_classgraph.classgraph;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.ByteArrayInputStream;
  import java.io.InputStream;
  import java.lang.reflect.Field;
  import java.net.URL;
  import java.nio.charset.StandardCharsets;
  import java.nio.file.Files;
  import java.nio.file.Path;
  import java.util.Collections;
  import java.util.Enumeration;
  import java.util.List;
  import java.util.Set;
  
  import io.github.classgraph.ClassGraph;
  import io.github.classgraph.ScanResult;
  import org.junit.jupiter.api.Test;
  import org.junit.jupiter.api.io.TempDir;
  
  public class ClassGraphClassLoaderTest {
      private static final String TEST_CLASS_NAME = ClassGraphClassLoaderTest.class.getName();
      private static final String MISSING_CLASS_NAME = "io_github_classgraph.classgraph."
              + "MissingClassGraphFixture";
      private static final String TEST_PACKAGE = ClassGraphClassLoaderTest.class.getPackageName();
  
      @Test
      void loadsClassThroughDelegateClassGraphClassLoader() throws Exception {
          try (ScanResult delegateScanResult = scanTestPackage(); ScanResult nestedScanResult = scanTestPackage()) {
              final ClassLoader delegateClassGraphClassLoader = classGraphClassLoader(delegateScanResult);
              final Object classpathFinder = getField(nestedScanResult, "classpathFinder");
              setField(classpathFinder, "delegateClassGraphClassLoader", delegateClassGraphClassLoader);
  
              assertThat(nestedScanResult.loadClass(TEST_CLASS_NAME, false))
                      .isSameAs(ClassGraphClassLoaderTest.class);
          }
      }
  
      @Test
      void loadsClassThroughOverrideClassLoader() {
          final ClassLoader contextClassLoader = Thread.currentThread().getContextClassLoader();
          try (ScanResult scanResult = new ClassGraph()
                  .overrideClassLoaders(contextClassLoader)
                  .acceptPackages(TEST_PACKAGE)
                  .enableClassInfo()
                  .scan()) {
              assertThat(scanResult.loadClass(TEST_CLASS_NAME, false)).isSameAs(ClassGraphClassLoaderTest.class);
          }
      }
  
      @Test
      void loadsClassThroughClassInfoClassLoaderAfterEnvironmentFails() throws Exception {
          final ClassReturningClassLoader classInfoClassLoader = new ClassReturningClassLoader();
          try (ScanResult scanResult = scanTestPackage()) {
              final ClassLoader classGraphClassLoader = classGraphClassLoader(scanResult);
              setField(classGraphClassLoader, "environmentClassLoaderDelegationOrder",
                      Set.of(new RecordingFailingClassLoader(TEST_CLASS_NAME)));
              setField(classGraphClassLoader, "addedClassLoaderDelegationOrder", Collections.emptySet());
              setField(scanResult.getClassInfo(TEST_CLASS_NAME), "classLoader", classInfoClassLoader);
  
              assertThat(scanResult.loadClass(TEST_CLASS_NAME, false)).isSameAs(ClassGraphClassLoaderTest.class);
              assertThat(classInfoClassLoader.requestedTargetClass).isTrue();
          }
      }
  
      @Test
      void loadsClassThroughEnvironmentClassLoader() {
          try (ScanResult scanResult = scanTestPackage()) {
              assertThat(scanResult.loadClass(TEST_CLASS_NAME, false)).isSameAs(ClassGraphClassLoaderTest.class);
          }
      }
  
      @Test
      void triesClasspathClassLoaderForMissingClass() throws Exception {
          final RecordingFailingClassLoader classpathClassLoader = new RecordingFailingClassLoader(MISSING_CLASS_NAME);
          try (ScanResult scanResult = scanTestPackage()) {
              final ClassLoader classGraphClassLoader = classGraphClassLoader(scanResult);
              setField(classGraphClassLoader, "environmentClassLoaderDelegationOrder", Collections.emptySet());
              setField(classGraphClassLoader, "overrideClassLoaders", null);
              setField(classGraphClassLoader, "classpathClassLoader", classpathClassLoader);
              setField(classGraphClassLoader, "addedClassLoaderDelegationOrder", Collections.emptySet());
  
              assertThat(scanResult.loadClass(MISSING_CLASS_NAME, true)).isNull();
              assertThat(classpathClassLoader.requestedExpectedClass).isTrue();
          }
      }
  
      @Test
      void triesAddedClassLoaderForMissingClass() throws Exception {
          final RecordingFailingClassLoader addedClassLoader = new RecordingFailingClassLoader(MISSING_CLASS_NAME);
          try (ScanResult scanResult = scanTestPackage()) {
              final ClassLoader classGraphClassLoader = classGraphClassLoader(scanResult);
              setField(classGraphClassLoader, "environmentClassLoaderDelegationOrder", Collections.emptySet());
              setField(classGraphClassLoader, "overrideClassLoaders", null);
              setField(classGraphClassLoader, "classpathClassLoader", null);
              setField(classGraphClassLoader, "addedClassLoaderDelegationOrder", Set.of(addedClassLoader));
  
              assertThat(scanResult.loadClass(MISSING_CLASS_NAME, true)).isNull();
              assertThat(addedClassLoader.requestedExpectedClass).isTrue();
          }
      }
  
      @Test
      void delegatesResourceLookupsToEnvironmentClassLoader(@TempDir Path tempDir) throws Exception {
          final String resourcePath = "classgraph-loader-env-resource.txt";
          final ResourceOnlyClassLoader environmentLoader = resourceLoader(tempDir, resourcePath, "environment");
          try (ScanResult scanResult = scanTestPackage()) {
              final ClassLoader classGraphClassLoader = configuredClassGraphClassLoader(
                      scanResult, Set.of(environmentLoader), Collections.emptySet());
  
              assertThat(classGraphClassLoader.getResource(resourcePath)).isEqualTo(environmentLoader.resourceUrl);
              assertThat(Collections.list(classGraphClassLoader.getResources(resourcePath)))
                      .containsExactly(environmentLoader.resourceUrl);
              try (InputStream inputStream = classGraphClassLoader.getResourceAsStream(resourcePath)) {
                  assertThat(new String(inputStream.readAllBytes(), StandardCharsets.UTF_8)).isEqualTo("environment");
              }
          }
      }
  
      @Test
      void delegatesResourceLookupsToAddedClassLoader(@TempDir Path tempDir) throws Exception {
          final String resourcePath = "classgraph-loader-added-resource.txt";
          final ResourceOnlyClassLoader addedLoader = resourceLoader(tempDir, resourcePath, "added");
          try (ScanResult scanResult = scanTestPackage()) {
              final ClassLoader classGraphClassLoader = configuredClassGraphClassLoader(
                      scanResult, Set.of(new EmptyResourceClassLoader()), Set.of(addedLoader));
  
              assertThat(classGraphClassLoader.getResource(resourcePath)).isEqualTo(addedLoader.resourceUrl);
              assertThat(Collections.list(classGraphClassLoader.getResources(resourcePath)))
                      .containsExactly(addedLoader.resourceUrl);
              try (InputStream inputStream = classGraphClassLoader.getResourceAsStream(resourcePath)) {
                  assertThat(new String(inputStream.readAllBytes(), StandardCharsets.UTF_8)).isEqualTo("added");
              }
          }
      }
  
      @Test
      void fallsBackWhenResourceIsAbsent() throws Exception {
          final String resourcePath = "classgraph-loader-missing-resource.txt";
          try (ScanResult scanResult = scanTestPackage()) {
              final ClassLoader classGraphClassLoader = configuredClassGraphClassLoader(
                      scanResult, Set.of(new EmptyResourceClassLoader()), Set.of(new EmptyResourceClassLoader()));
  
              assertThat(classGraphClassLoader.getResource(resourcePath)).isNull();
              assertThat(Collections.list(classGraphClassLoader.getResources(resourcePath))).isEmpty();
              assertThat(classGraphClassLoader.getResourceAsStream(resourcePath)).isNull();
          }
      }
  
      private static ScanResult scanTestPackage() {
          return new ClassGraph()
                  .acceptPackages(TEST_PACKAGE)
                  .enableClassInfo()
                  .scan();
      }
  
      private static ClassLoader configuredClassGraphClassLoader(ScanResult scanResult,
              Set<ClassLoader> environmentClassLoaders, Set<ClassLoader> addedClassLoaders) throws Exception {
          final ClassLoader classGraphClassLoader = classGraphClassLoader(scanResult);
          setField(classGraphClassLoader, "environmentClassLoaderDelegationOrder", environmentClassLoaders);
          setField(classGraphClassLoader, "addedClassLoaderDelegationOrder", addedClassLoaders);
          return classGraphClassLoader;
      }
  
      private static ClassLoader classGraphClassLoader(ScanResult scanResult) throws Exception {
          return (ClassLoader) getField(scanResult, "classGraphClassLoader");
      }
  
      private static Object getField(Object target, String fieldName) throws Exception {
          final Field field = target.getClass().getDeclaredField(fieldName);
          field.setAccessible(true);
          return field.get(target);
      }
  
      private static void setField(Object target, String fieldName, Object value) throws Exception {
          final Field field = target.getClass().getDeclaredField(fieldName);
          field.setAccessible(true);
          field.set(target, value);
      }
  
      private static ResourceOnlyClassLoader resourceLoader(Path tempDir, String resourcePath, String content)
              throws Exception {
          final Path resourceFile = tempDir.resolve(resourcePath);
          final byte[] bytes = content.getBytes(StandardCharsets.UTF_8);
          Files.write(resourceFile, bytes);
          return new ResourceOnlyClassLoader(resourcePath, resourceFile.toUri().toURL(), bytes);
      }
  
      private static final class EmptyResourceClassLoader extends ClassLoader {
          private EmptyResourceClassLoader() {
              super(null);
          }
      }
  
      private static final class ClassReturningClassLoader extends ClassLoader {
          private boolean requestedTargetClass;
  
          private ClassReturningClassLoader() {
              super(null);
          }
  
          @Override
          protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {
              if (TEST_CLASS_NAME.equals(name)) {
                  requestedTargetClass = true;
                  return ClassGraphClassLoaderTest.class;
              }
              throw new ClassNotFoundException(name);
          }
      }
  
      private static final class RecordingFailingClassLoader extends ClassLoader {
          private final String expectedClassName;
          private boolean requestedExpectedClass;
  
          private RecordingFailingClassLoader(String expectedClassName) {
              super(null);
              this.expectedClassName = expectedClassName;
          }
  
          @Override
          protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {
              if (expectedClassName.equals(name)) {
                  requestedExpectedClass = true;
              }
              throw new ClassNotFoundException(name);
          }
      }
  
      private static final class ResourceOnlyClassLoader extends ClassLoader {
          private final String resourcePath;
          private final URL resourceUrl;
          private final byte[] resourceBytes;
  
          private ResourceOnlyClassLoader(String resourcePath, URL resourceUrl, byte[] resourceBytes) {
              super(null);
              this.resourcePath = resourcePath;
              this.resourceUrl = resourceUrl;
              this.resourceBytes = resourceBytes.clone();
          }
  
          @Override
          public URL getResource(String name) {
              return resourcePath.equals(name) ? resourceUrl : null;
          }
  
          @Override
          public Enumeration<URL> getResources(String name) {
              if (resourcePath.equals(name)) {
                  return Collections.enumeration(List.of(resourceUrl));
              }
              return Collections.emptyEnumeration();
          }
  
          @Override
          public InputStream getResourceAsStream(String name) {
              if (resourcePath.equals(name)) {
                  return new ByteArrayInputStream(resourceBytes);
              }
              return null;
          }
      }
  }
