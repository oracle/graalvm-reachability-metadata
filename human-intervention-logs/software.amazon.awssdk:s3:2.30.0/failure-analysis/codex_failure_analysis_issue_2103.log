  .checksumValidationEnabled(false);\", \"newText\": \"            .pathStyleAccessEnabled(true)\\n            .chunkedEncodingEnabled(false);\"}, {\"oldText\": \"            .endpointOverride(endpoint)\\n            .serviceConfiguration(configurationBuilder.build())\\n            .httpClient(httpClient)\", \"newText\": \"            .endpointOverride(endpoint)\\n            .serviceConfiguration(configurationBuilder.build())\\n            .requestChecksumCalculation(RequestChecksumCalculation.WHEN_REQUIRED)\\n            .responseChecksumValidation(ResponseChecksumValidation.WHEN_REQUIRED)\\n            .httpClient(httpClient)\"}, {\"oldText\": \"    private static String md5Base64(byte[] content) {\\n        try {\\n            return Base64.getEncoder().encodeToString(MessageDigest.getInstance(\\\"MD5\\\").digest(content));\\n        } catch (NoSuchAlgorithmException exception) {\\n            throw new IllegalStateException(\\\"MD5 digest is unavailable\\\", exception);\\n        }\\n    }\", \"newText\": \"    private static String crc32Base64(byte[] content) {\\n        CRC32 crc32 = new CRC32();\\n        crc32.update(content);\\n        ByteBuffer checksum = ByteBuffer.allocate(Integer.BYTES);\\n        checksum.putInt((int) crc32.getValue());\\n        return Base64.getEncoder().encodeToString(checksum.array());\\n    }\"}]}}], \"api\": \"openai-responses\", \"provider\": \"OCA\", \"model\": \"gpt-5.5\", \"usage\": {\"input\": 809, \"output\": 2217, \"cacheRead\": 31232, \"cacheWrite\": 0, \"totalTokens\": 34258, \"cost\": {\"input\": 0, \"output\": 0, \"cacheRead\": 0, \"cacheWrite\": 0, \"total\": 0}}, \"stopReason\": \"toolUse\", \"timestamp\": 1777803824416, \"responseId\": \"resp_08260da99dc7bb900169f72230e090819eb81d2948668c99a9\"}}\n1858:[tool-exec] start id=call_F6lpSByGQxd7xqxrb4hpI5yP|fc_08260da99dc7bb900169f72244cf14819e87f77be9e53f92da name=edit args={\"path\": \"tests/src/software.amazon.awssdk/s3/2.30.0/src/test/java/software_amazon_awssdk/s3