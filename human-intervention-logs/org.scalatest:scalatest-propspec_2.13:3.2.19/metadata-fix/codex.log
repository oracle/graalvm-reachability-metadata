ersey.containers/jersey-container-servlet/4.0.2/reachability-metadata.json:2:  \"resources\": [\nmetadata/org.eclipse.jetty/jetty-servlet/9.4.0.RC0/reachability-metadata.json:102:      \"type\" : \"sun.util.resources.cldr.CalendarData\"\nmetadata/com.github.luben/zstd-jni/1.5.2-5/reachability-metadata.json:162:  \"resources\": [\nmetadata/org.glassfish.jersey.containers/jersey-container-servlet/index.json:69:    \"description\" : \"Jersey Container Servlet integrates Eclipse Jersey's Jakarta REST server runtime with Jakarta Servlet containers. It provides servlet registration, request handling, and async-context support so Jersey REST resources can run in WAR-based web applications.\",\nmetadata/org.glassfish.jersey.containers/jersey-container-servlet/index.json:83:    \"description\" : \"Jersey Container Servlet integrates Eclipse Jersey's Jakarta REST server runtime with Jakarta Servlet containers. It provides servlet registration, request handling, and async-context support so Jersey REST resources can run in WAR-based web applications.\",\nmetadata/org.glassfish.jersey.containers/jersey-container-servlet/index.json:97:    \"description\" : \"Jersey Container Servlet integrates Eclipse Jersey's Jakarta REST server runtime with Jakarta Servlet containers. It provides servlet registration, request handling, and async-context support so Jersey REST resources can run in WAR-based web applications.\",\nmetadata/org.glassfish.jersey.containers/jersey-container-servlet/index.json:111:    \"description\" : \"Jersey Container Servlet provides Eclipse Jersey's server-side Jakarta REST integration for Servlet containers, exposing Jersey applications through servlet registration and request handling. It is used to run Jersey REST resources in WAR-based deployments on Jakarta Servlet 6 compatible containers.\",\nmetadata/org.eclipse.jetty/jetty-servlet/9.4.0.RC3/reachability-metadata.json:102:      \"type\" : \"sun.util.resources.cldr.CalendarData\"\nmetadata/org.glassfish.je