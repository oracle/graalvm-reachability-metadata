es\\\": [\\nmetadata/io.netty/netty-handler-proxy/4.1.60.Final/reachability-metadata.json:271:      \\\"glob\\\": \\\"sun/util/logging/resources/logging_en.properties\\\"\\nmetadata/io.netty/netty-handler-proxy/4.1.60.Final/reachability-metadata.json:278:      \\\"glob\\\": \\\"sun/util/logging/resources/logging_en_US.properties\\\"\\nmetadata/io.netty/netty-handler-proxy/4.1.60.Final/reachability-metadata.json:281:      \\\"bundle\\\": \\\"sun.util.logging.resources.logging\\\"\\nmetadata/org.jboss/jandex/3.0.0/reachability-metadata.json:24:  \\\"resources\\\" : [\\nmetadata/io.netty/netty-transport-native-epoll/4.1.42.Final/reachability-metadata.json:154:  \\\"resources\\\": [\\nmetadata/io.netty/netty-transport-classes-epoll/4.1.99.Final/reachability-metadata.json:226:  \\\"resources\\\": [\\nmetadata/org.jboss/jandex/3.0.7/reachability-metadata.json:30:  \\\"resources\\\" : [\\nmetadata/io.netty/netty-transport-native-unix-common/4.1.57.Final/reachability-metadata.json:292:  \\\"resources\\\": [\\nmetadata/io.fabric8/kubernetes-model-apiextensions/index.json:9:    \\\"description\\\" : \\\"Fabric8 Kubernetes Model API Extensions provides Java model classes and builders for Kubernetes API extension resources, including CustomResourceDefinition and conversion review types. It is part of the Fabric8 Kubernetes Client model set and lets JVM applications serialize, deserialize, and construct API extension objects when working with Kubernetes custom resources.\\\",\\nmetadata/io.fabric8/kubernetes-model-admissionregistration/index.json:9:    \\\"description\\\" : \\\"Fabric8 Kubernetes Model Admission Registration provides generated Java model classes for Kubernetes admission, admissionregistration, authentication, and authorization API resources. It is part of the Fabric8 Kubernetes Client model set and lets JVM applications serialize, deserialize, and construct those Kubernetes API objects.\\\",\\nmetadata/io.fabric8/kubernetes-model-core/index.json:9:    \\\"description\\\" : \\\"kubernetes-model-core provides the core Java model classes for Kubernetes API resources used by the Fabric8 Kubernetes client. It includes generated and handwritten types, builders, and serialization metadata for representing Kubernetes core objects in JVM applications.\\\",\\nmetadata/com.h2database/h2/2.1.210/reachability-metadata.json:234:  \\\"resources\\\": [\\nmetadata/io.fabric8/kubernetes-model-rbac/index.json:9:    \\\"description\\\" : \\\"Fabric8 Kubernetes Model RBAC provides Java model classes for Kubernetes role-based access control resources such as Roles, ClusterRoles, RoleBindings, and ClusterRoleBindings. It is part of the Fabric8 Kubernetes Client model set and is used to serialize, deserialize, and manipulate Kubernetes RBAC API objects in JVM applications.\\\",\\nmetadata/xalan/xalan/2.7.0/reachability-metadata.json:975:      \\\"type\\\": \\\"sun.text.resources.CollationData\\\"\\nmetadata/xalan/xalan/2.7.0/reachability-metadata.json:978:  \\\"resources\\\": [\\nmetadata/jakarta.xml.bind/jakarta.xml.bind-api/3.0.0/reachability-metadata.json:2:  \\\"resources\\\" : [\\nmetadata/io.fabric8/kubernetes-model-gatewayapi/index.json:9:    \\\"description\\\" : \\\"Fabric8 Kubernetes Model Gateway API provides generated Java model classes and builders for the Kubernetes SIG Network Gateway API resources, including Gateway, GatewayClass, HTTPRoute, GRPCRoute, TLSRoute, TCPRoute, UDPRoute, ReferenceGrant, and related policy objects. It is part of the Fabric8 Kubernetes Client model set and lets JVM applications serialize, deserialize, and construct Gateway API resource definitions for use with Kubernetes.\\\",\\nmetadata/jakarta.xml.bind/jakarta.xml.bind-api/4.0.0/reachability-metadata.json:41:  \\\"resources\\\" : [\\nmetadata/io.fabric8/kubernetes-model-scheduling/index.json:9:    \\\"description\\\" : \\\"This artifact provides the Fabric8 Java model classes for Kubernetes Scheduling API resources such as PriorityClass across supported API versions. It is part of the Fabric8 Kubernetes Client model set and is used to serialize, deserialize, and build Kubernetes scheduling resource definitions in JVM applications.\\\",\\nmetadata/com.clickhouse/clickhouse-jdbc/0.9.0/reachability-metadata.json:10:  \\\"resources\\\" : [\\nmetadata/io.fabric8/kubernetes-model-apps/index.json:9:    \\\"description\\\" : \\\"Fabric8 Kubernetes Model Apps provides Java model classes and builders for Kubernetes Apps API resources such as Deployments, DaemonSets, ReplicaSets, StatefulSets, and ControllerRevisions. It is part of the Fabric8 Kubernetes Client generated model modules and lets JVM applications serialize, deserialize, and construct Kubernetes Apps API objects.\\\",\\nmetadata/io.fabric8/kubernetes-model-batch/index.json:9:    \\\"description\\\" : \\\"Fabric8 Kubernetes Model Batch provides Java model classes for Kubernetes Batch API resources such as Jobs and CronJobs. It is part of the Fabric8 Kubernetes Client model modules and is used to serialize, deserialize, and build batch API resource objects in JVM applications.\\\",\\nmetadata/io.fabric8/kubernetes-model-coordination/index.json:9:    \\\"description\\\" : \\\"Fabric8 Kubernetes Model Coordination provides Java model classes for Kubernetes coordination API resources, including Lease and LeaseCandidate types. It is part of the Fabric8 Kubernetes Client model generator output and lets JVM applications serialize, deserialize, and build coordination.k8s.io resources.\\\",\\nmetadata/io.fabric8/kubernetes-model-node/index.json:9:    \\\"description\\\" : \\\"Fabric8 Kubernetes Model Node provides Java model classes for the Kubernetes node.k8s.io API group, including RuntimeClass and related list, scheduling, and overhead types. These generated models are used by the Fabric8 Kubernetes client to serialize, deserialize, and build node runtime class resources across supported API versions.\\\",\\nmetadata/io.fabric8/kubernetes-model-extensions/index.json:9:    \\\"description\\\" : \\\"Fabric8 Kubernetes Model Extensions provides generated Java model classes and builders for legacy Kubernetes extensions API resources such as Deployments, Ingresses, NetworkPolicies, ReplicaSets, Scales, and PodSecurityPolicies. It is part of the Fabric8 Kubernetes Java Client model set and lets JVM applications serialize, deserialize, and construct those extension API objects.\\\",\\nmetadata/com.clickhouse/org.apache.commons.compress/1.9.2/reachability-metadata.json:184:  \\\"resources\\\": [\\nmetadata/io.fabric8/kubernetes-model-discovery/index.json:9:    \\\"description\\\" : \\\"Fabric8 Kubernetes Model Discovery provides Java model classes and builders for Kubernetes discovery API resources such as EndpointSlice. It is part of the Fabric8 Kubernetes Client model modules and is used to serialize, deserialize, and work with those discovery resources from JVM applications.\\\",\\nmetadata/io.fabric8/kubernetes-model-networking/index.json:9:    \\\"description\\\" : \\\"This artifact contains Fabric8 Java model classes for the Kubernetes networking API group, generated from Kubernetes OpenAPI schemas. It provides typed representations and builders for networking resources such as NetworkPolicy, Ingress, and IngressClass for use with the Fabric8 Kubernetes Client and JVM applications.\\\",\\nmetadata/io.fabric8/kubernetes-model-networking/index.json:23:    \\\"description\\\" : \\\"This artifact contains Fabric8 Java model classes for the Kubernetes networking API group, generated from Kubernetes OpenAPI schemas. It provides typed representations and builders for networking resources such as NetworkPolicy, Ingress, and IngressClass for use with the Fabric8 Kubernetes Client and JVM applications.\\\",\\nmetadata/io.fabric8/kubernetes-model-events/index.json:9:    \\\"description\\\" : \\\"Fabric8 Kubernetes Model Events provides Java model classes and builders for Kubernetes Events API resources. It is part of Fabric8 Kubernetes Client's generated model set and lets JVM applications serialize, deserialize, and construct Event, EventList, and EventSeries objects.\\\",\\nmetadata/io.fabric8/kubernetes-model-certificates/index.json:9:    \\\"description\\\" : \\\"Fabric8 Kubernetes Model Certificates provides generated Java model classes for Kubernetes certificates API resources such as CertificateSigningRequest, ClusterTrustBundle, and PodCertificateRequest. It is part of the Fabric8 Kubernetes Client model set and is used to serialize, deserialize, and build certificate-related Kubernetes resource objects on the JVM.\\\",\\nmetadata/io.fabric8/kubernetes-model-policy/index.json:9:    \\\"description\\\" : \\\"Fabric8 Kubernetes Model Policy provides Java model classes for Kubernetes Policy API resources such as PodDisruptionBudget, Eviction, and legacy PodSecurityPolicy. It is part of the Fabric8 Kubernetes Client model set and is used to serialize, deserialize, and build policy resources from JVM applications.\\\",\\nmetadata/io.fabric8/kubernetes-model-autoscaling/index.json:9:    \\\"description\\\" : \\\"Fabric8 Kubernetes Model Autoscaling provides generated Java model classes and builders for Kubernetes autoscaling API resources, including HorizontalPodAutoscaler, Scale, metrics, and scaling policy types. It is part of the Fabric8 Kubernetes Client model set and lets JVM applications serialize, deserialize, and construct autoscaling resource definitions for use with Kubernetes.\\\",\\nmetadata/io.netty/netty-common/4.1.80.Final/reachability-metadata.json:6774:  \\\"resources\\\": [\\nmetadata/io.netty/netty-common/4.1.79.Final/reachability-metadata.json:424:  \\\"resources\\\" : [\\nmetadata/com.squareup.retrofit2/retrofit/2.5.0/reachability-metadata.json:78:  \\\"resources\\\" : [\\nmetadata/com.clickhouse/jdbc-v2/0.9.1/reachability-metadata.json:121:      \\\"type\\\": \\\"sun.util.resources.cldr.CalendarData\\\"\\nmetadata/com.clickhouse/jdbc-v2/0.9.1/reachability-metadata.json:124:  \\\"