  import static org.junit.jupiter.api.Assertions.assertNull;
  
  public class SinkAnonymous1Test {
      @Test
      void sinkRecordsDocumentEventsAndUsesDefaultLocator() {
          RecordingSink sink = new RecordingSink();
  
          sink.head();
          sink.title();
          sink.text("Doxia");
          sink.title_();
          sink.head_();
          sink.section(Sink.SECTION_LEVEL_6, null);
          sink.sectionTitle(Sink.SECTION_LEVEL_6, null);
          sink.text("Native Image");
          sink.sectionTitle_(Sink.SECTION_LEVEL_6);
          sink.section_(Sink.SECTION_LEVEL_6);
  
          Locator locator = sink.getDocumentLocator();
          assertEquals(-1, locator.getLineNumber());
          assertEquals(-1, locator.getColumnNumber());
          assertNull(locator.getReference());
          assertEquals(6, Sink.SECTION_LEVEL_6);
          assertEquals(4, Sink.NUMBERING_UPPER_ROMAN);
          assertEquals(
                  List.of(
                          "head",
                          "title",
                          "text:Doxia",
                          "title_",
                          "head_",
                          "section",
                          "sectionTitle",
                          "text:Native Image",
                          "sectionTitle_",
                          "section_"),
                  sink.events());
      }
  
