        .replaceAll("""\$\$?\w+""", "") // drop scala anonymous functions/classes
        .replaceAll("[^a-zA-Z_0-9-]", "_")
        .replaceAll("""MultiJvmNode\d+""", "") // drop MultiJvm suffix
    }
  }
