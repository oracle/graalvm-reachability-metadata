  package com_typesafe_akka.akka_testkit_3
  
  import org.assertj.core.api.Assertions.assertThat
  import org.junit.jupiter.api.Test
  
  class TestKitUtilsTest {
    @Test
    def derivesANameFromTheCurrentJUnitCallStack(): Unit = {
      val derivedName: String = TestKitUtilsAccessor.testNameFromCallStack(
        classOf[TestKitUtilsTest],
        "akka[.]testkit[.].*".r)
  
      assertThat(derivedName).isNotBlank
      assertThat(derivedName).doesNotContain(".")
    }
  }
