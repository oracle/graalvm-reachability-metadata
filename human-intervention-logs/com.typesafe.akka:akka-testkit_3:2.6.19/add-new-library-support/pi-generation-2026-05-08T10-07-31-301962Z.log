  package com_typesafe_akka.akka_testkit_3
  
  import akka.actor.{ActorSystem, ExtendedActorSystem}
  import akka.testkit.TestJavaSerializer
  import org.assertj.core.api.Assertions.assertThat
  import org.junit.jupiter.api.Test
  
  import scala.concurrent.Await
  import scala.concurrent.duration.DurationInt
  
  class TestJavaSerializerTest {
    @Test
    def roundTripsSerializableValueWithJavaObjectStreams(): Unit = {
      val actorSystem: ActorSystem = ActorSystem("TestJavaSerializerTest")
      try {
        val serializer: TestJavaSerializer = new TestJavaSerializer(actorSystem.asInstanceOf[ExtendedActorSystem])
        val message: String = "akka-testkit java-serialization"
  
        val bytes: Array[Byte] = serializer.toBinary(message)
        val roundTripped: AnyRef = serializer.fromBinary(bytes, None)
  
        assertThat(roundTripped).isEqualTo(message)
      } finally {
        Await.result(actorSystem.terminate(), 10.seconds)
      }
    }
