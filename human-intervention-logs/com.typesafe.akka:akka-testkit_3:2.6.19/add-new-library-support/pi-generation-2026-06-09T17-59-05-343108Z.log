  package com_typesafe_akka.akka_testkit_3
  
  import akka.actor.{ActorSystem, ExtendedActorSystem}
  import akka.testkit.TestJavaSerializer
  import org.junit.jupiter.api.Assertions.assertEquals
  import org.junit.jupiter.api.Test
  
  import scala.concurrent.Await
  import scala.concurrent.duration.DurationInt
  
  class TestJavaSerializerTest {
    @Test
    def serializesAndDeserializesWithJavaSerialization(): Unit = {
      val actorSystem: ActorSystem = ActorSystem("test-java-serializer")
  
      try {
        val serializer: TestJavaSerializer =
          new TestJavaSerializer(actorSystem.asInstanceOf[ExtendedActorSystem])
        val original: String = "akka-testkit-java-serializer-message"
  
        val bytes: Array[Byte] = serializer.toBinary(original)
        val deserialized: AnyRef = serializer.fromBinary(bytes, None)
  
        assertEquals(original, deserialized)
      } finally {
        Await.result(actorSystem.terminate(), 10.seconds)
      }
    }
  }
