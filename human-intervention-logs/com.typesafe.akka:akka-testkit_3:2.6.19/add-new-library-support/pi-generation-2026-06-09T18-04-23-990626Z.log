[tool-call] delta {"path":"tests/src/com.typesafe.akka/akka-testkit_3/2.6.19/src/test/scala/com_typesafe_akka/akka_testkit_3/TestKitUtilsTest.scala","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage akka.testkit.bridge {\n\n  import scala.util.matching.Regex\n\n  object AkkaTestKitUtilsBridge {\n    def testNameFromCallStack(classToStartFrom: Class[_], testKitRegex: Regex): String =\n      akka.testkit.TestKitUtils.testNameFromCallStack(classToStartFrom, testKitRegex)\n  }\n}\n\npackage com_typesafe_akka.akka_testkit_3 {\n\n  import akka.testkit.bridge.AkkaTestKitUtilsBridge\n  import org.junit.jupiter.api.Assertions.assertEquals\n  import org.junit.jupiter.api.Test\n\n  abstract class TestKitUtilsStackBase {\n    protected def deriveTestName(): String =\n      AkkaTestKitUtilsBridge.testNameFromCallStack(\n        classOf[TestKitUtilsStackBase],\n        \"^akka\\\\.testkit\\\\..*\".r)\n  }\n\n  class TestKitUtilsTest extends TestKitUtilsStackBase {\n    @Test\n    def derivesConcreteCallerNameFromCallStack(): Unit = {\n      val derivedName: String = deriveTestName()\n\n      assertEquals(\"TestKitUtilsTest\", derivedName)\n    }\n  }\n}\n"}
[tool-call] end id=call_uH9p0qnI8cPBW6PadBVuZrfl|fc_0de03878d8e79384016a28558e63b48194bcaaf3fabbe6f571 name=write args={"path": "tests/src/com.typesafe.akka/akka-testkit_3/2.6.19/src/test/scala/com_typesafe_akka/akka_testkit_3/TestKitUtilsTest.scala", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage akka.testkit.bridge {\n\n  import scala.util.matching.Regex\n\n  object AkkaTestKitUtilsBridge {\n    def testNameFromCallStack(classToStartFrom: Class[_], testKitRegex: Regex): String =\n      akka.testkit.TestKitUtils.testNameFromCallStack(classToStartFrom, testKitRegex)\n  }\n}\n\npackage com_typesafe_akka.akka_testkit_3 {\n\n  import akka.testkit.bridge.AkkaTestKitUtilsBridge\n  import org.junit.jupiter.api.Assertions.assertEquals\n  import org.junit.jupiter.api.Test\n\n  abstract class TestKitUtilsStackBase {\n    protected def deriveTestName(): String =\n      AkkaTestKitUtilsBridge.testNameFromCallStack(\n        classOf[TestKitUtilsStackBase],\n        \"^akka\\\\.testkit\\\\..*\".r)\n  }\n\n  class TestKitUtilsTest extends TestKitUtilsStackBase {\n    @Test\n    def derivesConcreteCallerNameFromCallStack(): Unit = {\n      val derivedName: String = deriveTestName()\n\n      assertEquals(\"TestKitUtilsTest\", derivedName)\n    }\n  }\n}\n"}
