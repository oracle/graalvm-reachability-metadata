    @Deprecated
    @deprecated("Use the overloaded one which accepts java.time.Duration instead.", since = "2.5.12")
    def within[T](min: FiniteDuration, max: FiniteDuration, f: Supplier[T]): T = tp.within(min, max)(f.get)
  
