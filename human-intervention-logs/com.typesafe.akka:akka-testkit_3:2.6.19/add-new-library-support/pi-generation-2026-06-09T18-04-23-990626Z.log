        actorSystem: ActorSystem = system,
        duration: Duration = Duration.Undefined,
        verifySystemShutdown: Boolean = false): Unit = {
      TestKit.shutdownActorSystem(actorSystem, duration, verifySystemShutdown)
    }
  
