        if (hasText(agentCommand)) {
            return agentCommand.trim();
        }
        Object prop = getProject().findProperty("codingAgentCommand");
        if (prop == null) {
            prop = getProject().findProperty("agentCommand");
        }
        return prop == null ? null : prop.toString().trim();
    }

