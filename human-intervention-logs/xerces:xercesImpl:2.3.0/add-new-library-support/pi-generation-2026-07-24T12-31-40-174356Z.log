  package xerces.xercesImpl;
  
  import org.apache.html.dom.HTMLDocumentImpl;
  import org.junit.jupiter.api.Test;
  import org.w3c.dom.Document;
  import org.w3c.dom.Element;
  import org.w3c.dom.html.HTMLAnchorElement;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  /**
   * Exercises creation of specialized HTML elements through the public HTML document API.
   * §FS-repository-functional-spec.5.2
   */
  public class HTMLDocumentImplTest {
      @Test
      void createsSpecializedHtmlElements() {
          Object implementation = new HTMLDocumentImpl();
          Document document = (Document) implementation;
  
          Element element = document.createElement("a");
  
          assertThat(element).isInstanceOf(HTMLAnchorElement.class);
          assertThat(element.getTagName()).isEqualTo("A");
      }
  }
