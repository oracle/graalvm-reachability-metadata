ontext.put(\"request.id\", \"req-789\");\n                ThreadContext.put(\"tenant\", \"contoso\");\n                ThreadContext.put(\"not.captured\", \"ignored\");\n\n                loggerContext\n                        .getLogger(loggerName)\n                        .info(MarkerManager.getMarker(\"CONFIGURED\"), \"configured appender log\");\n\n                LogRecordData record = telemetry.singleRecord();\n                assertThat(record.getBody().asString()).isEqualTo(\"configured appender log\");\n                assertThat(record.getAttributes().get(stringKey(\"log4j.marker\")))\n                        .isEqualTo(\"CONFIGURED\");\n                assertThat(record.getAttributes().get(stringKey(\"request.id\")))\n                        .isEqualTo(\"req-789\");\n                assertThat(record.getAttributes().get(stringKey(\"tenant\"))).isEqualTo(\"contoso\");\n                assertThat(record.getAttributes().get(stringKey(\"not.captured\"))).isNull();\n            } finally {\n                Configurator.shutdown(loggerContext);\n            }\n        }\n    }\n\n    @Test\n    void emittedLogRecordUsesTheCurrentOpenTelemetryContext() {"}]}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 1262, "output": 2914, "cacheRead": 49664, "cacheWrite": 0, "totalTokens": 53840, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1782486508026, "responseId": "resp_0df45c42b02beb6b016a3e95ec96548190b71f737c47cc7ad7"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_AlwCRW8hZTfYTDQxC0hhChS0|fc_0df45c42b02beb6b016a3e960d31cc819098829d8c25ceed83", "toolName": "edit", "content": [{"type": "text", "text": "Successfully replaced 4 block(s) in tests/src/io.opentelemetry.instrumentation/opentelemetry-log4j-appender-2.17/2.28.1-alpha/src/test/java/io_opentelemetry_instrumentation/opentelemetry_log4j_appender_2_17/Opentelemetry_log4j_appender_2_17