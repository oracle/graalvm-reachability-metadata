/forge2/graalvm-reachability-metadata/forge/local_repositories/forge_worktrees/8544-7f677780/forge/.pylintrc\n/home/vjovanov/c/forge/forge2/graalvm-reachability-metadata/forge/local_repositories/forge_worktrees/8544-7f677780/forge/forge_metadata.py\n/home/vjovanov/c/forge/forge2/graalvm-reachability-metadata/forge/local_repositories/forge_worktrees/8544-7f677780/ci.json\n/home/vjovanov/c/forge/forge2/graalvm-reachability-metadata/forge/local_repositories/forge_worktrees/8544-7f677780/.git\n/home/vjovanov/c/forge/forge2/graalvm-reachability-metadata/forge/local_repositories/forge_worktrees/8544-7f677780/tests/src/AGENTS.md\n/home/vjovanov/c/forge/forge2/graalvm-reachability-metadata/forge/local_repositories/forge_worktrees/8544-7f677780/tests/tck-build-logic/settings.gradle\n/home/vjovanov/c/forge/forge2/graalvm-reachability-metadata/forge/local_repositories/forge_worktrees/8544-7f677780/tests/tck-build-logic/build.gradle\n/home/vjovanov/c/forge/forge2/graalvm-reachability-metadata/forge/local_repositories/forge_worktrees/8544-7f677780/tests/tck-test-support/settings.gradle\n/home/vjovanov/c/forge/forge2/graalvm-reachability-metadata/forge/local_repositories/forge_worktrees/8544-7f677780/tests/tck-test-support/build.gradle\n","exit_code":0,"status":"completed"}}
