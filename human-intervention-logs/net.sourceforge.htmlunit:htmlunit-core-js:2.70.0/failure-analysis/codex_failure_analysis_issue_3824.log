iginal);\\n\\n            assertThat(copied.unwrap()).isInstanceOf(SerializableBox.class);\\n            SerializableBox box = (SerializableBox) copied.unwrap();\\n            assertThat(box.name()).isEqualTo(\\\"wrapped\\\");\\n            assertThat(box.count()).isEqualTo(42);\\n        } finally {\\n            Context.exit();\\n        }\\n    }\\n\\n    @Test\\n    void roundTripsWrappedJavaAdapter() throws Exception {\\n        try {\\n            roundTripWrappedJavaAdapter();\\n        } catch (Error error) {\\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\\n                throw error;\\n            }\\n        }\\n    }\\n\\n    private void roundTripWrappedJavaAdapter() throws Exception {\\n        Context context = Context.enter();\\n        try {\\n            ScriptableObject scope = context.initStandardObjects();\\n            Object adapterWrapper = createAdapterWrapper(context, scope);\\n\\n            NativeJavaObject copied = roundTrip(scope, (NativeJavaObject) adapterWrapper);\\n\\n            assertThat(copied.unwrap()).isInstanceOf(AdapterMarker.class);\\n            AdapterMarker marker = (AdapterMarker) copied.unwrap();\\n            assertThat(marker.label()).isEqualTo(\\\"adapter-label\\\");\\n        } finally {\\n            Context.exit();\\n        }\\n    }\\n\\n    private Object createAdapterWrapper(Context context, ScriptableObject scope) {\\n        JavaAdapter.init(context, scope, false);\\n        RecordingFunction labelFunction = new RecordingFunction(\\\"adapter-label\\\");\\n        ScriptRuntime.setFunctionProtoAndParent(labelFunction, context, scope);\\n        NativeObject implementation = new NativeObject();\\n        ScriptRuntime.setObjectProtoAndParent(implementation, scope);\\n        implementation.defineProperty(\\\"label\\\", labelFunction, ScriptableObject.EMPTY);\\n\\n        Object constructor = ScriptableObject.getProperty(scope, \\\"JavaAdapter\\\");\\n        Object adapterWrapper =\\