nstanceOf(int[].class);\\n        assertThat((int[]) converted).containsExactly(1, 2, 3);\\n    }\\n\\n    @Test\\n    void serializesWrappedJavaObjectAndStaticType() throws Exception {\\n        NativeJavaObject wrapper = new NativeJavaObject(\\n                newTopLevelScope(), new SerializableValue(\\\"alpha\\\"), SerializableValue.class);\\n\\n        NativeJavaObject restored = roundTrip(wrapper);\\n\\n        assertThat(restored.unwrap()).isEqualTo(new SerializableValue(\\\"alpha\\\"));\\n    }\\n\\n    @Test\\n    void serializesWrappedJavaObjectWithNullStaticType() throws Exception {\\n        NativeJavaObject wrapper = new NativeJavaObject(\\n                newTopLevelScope(), new SerializableValue(\\\"beta\\\"), null);\\n\\n        NativeJavaObject restored = roundTrip(wrapper);\\n\\n        assertThat(restored.unwrap()).isEqualTo(new SerializableValue(\\\"beta\\\"));\\n    }\\n\\n    @Test\\n    void serializesWrappedJavaAdapter() throws Exception {\\n        Context cx = Context.enter();\\n        try {\\n            Scriptable standardScope = cx.initStandardObjects();\\n            Object adapter = newGreetingAdapter(cx, standardScope);\\n            NativeJavaObject wrapper = new NativeJavaObject(\\n                    newTopLevelScope(), adapter, GreetingService.class, true);\\n\\n            NativeJavaObject restored = roundTrip(wrapper);\\n\\n            assertThat(restored.unwrap()).isInstanceOf(GreetingService.class);\\n        } catch (Error error) {\\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\\n                throw error;\\n            }\\n        } finally {\\n            Context.exit();\\n        }\\n    }\\n\\n    private static NativeObject newTopLevelScope() {\\n        NativeObject scope = new NativeObject();\\n        new ClassCache().associate(scope);\\n        return scope;\\n    }\\n\\n    private static NativeJavaObject roundTrip(NativeJavaObject wrapper) throws Exception {\\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\\n            output.writeObject(wrapper);\\n        }\\n\\n        try (ObjectInputStream input = new ObjectInputStream(\\n                new ByteArrayInputStream(bytes.toByteArray()))) {\\n            return (NativeJavaObject) input.readObject();\\n        }\\n    }\\n\\n    private static Object newGreetingAdapter(Context cx, Scriptable scope) {\\n        Object constructor = ScriptableObject.getProperty(scope, \\\"JavaAdapter\\\");\\n        NativeJavaClass interfaceClass = new NativeJavaClass(scope, GreetingService.class, true);\\n        NativeObject delegee = new NativeObject();\\n        ScriptRuntime.setObjectProtoAndParent(delegee, scope);\\n        GreetingFunction greet = new GreetingFunction();\\n        ScriptRuntime.setFunctionProtoAndParent(greet, cx, scope, false);\\n        ScriptableObject.putProperty(delegee, \\\"greet\\\", greet);\\n\\n        Object self = ((Function) constructor)\\n                .construct(cx, scope, new Object[] {interfaceClass, delegee});\\n        Object adapter = ((Wrapper) self).unwrap();\\n        delegee.setParentScope(null);\\n        delegee.setPrototype(null);\\n        greet.setParentScope(null);\\n        greet.setPrototype(null);\\n        return adapter;\\n    }\\n\\n    public static final class Quantity {\\n        private final String value;\\n\\n        Quantity(String value) {\\n            this.value = value;\\n        }\\n\\n        public Number doubleValue() {\\n            return Double.valueOf(value);\\n        }\\n    }\\n\\n    public static final class SerializableValue implements Serializable {\\n        private static final long serialVersionUID = 1L;\\n\\n        private final String value;\\n\\n        public SerializableValue(String value) {\\n            this.value = value;\\n        }\\n\\n        @Override\\n        public boolean equals(Object other) {\\n            if (t