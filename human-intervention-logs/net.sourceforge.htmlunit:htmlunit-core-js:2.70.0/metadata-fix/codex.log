{"type":"item.completed","item":{"id":"item_58","type":"command_execution","command":"/usr/bin/bash -lc \"sed -n '1,260p' tests/src/net.sourceforge.htmlunit/htmlunit-core-js/2.70.0/src/test/java/net_sourceforge_htmlunit/htmlunit_core_js/MainTest.java\"","aggregated_output":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage net_sourceforge_htmlunit.htmlunit_core_js;\n\nimport java.nio.file.Files;\nimport java.nio.file.Path;\n\nimport net.sourceforge.htmlunit.corejs.javascript.CompilerEnvirons;\nimport net.sourceforge.htmlunit.corejs.javascript.Context;\nimport net.sourceforge.htmlunit.corejs.javascript.ScriptableObject;\nimport net.sourceforge.htmlunit.corejs.javascript.SecurityController;\nimport net.sourceforge.htmlunit.corejs.javascript.optimizer.ClassCompiler;\nimport net.sourceforge.htmlunit.corejs.javascript.tools.shell.Global;\nimport net.sourceforge.htmlunit.corejs.javascript.tools.shell.Main;\n\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.MethodOrderer;\nimport org.junit.jupiter.api.Order;\nimport org.junit.jupiter.api.Test;\nimport org.junit.jupiter.api.TestMethodOrder;\nimport org.junit.jupiter.api.io.TempDir;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\n@TestMethodOrder(MethodOrderer.OrderAnnotation.class)\npublic class MainTest {\n    private static final String COMPILED_SCRIPT_CLASS_NAME = \"HtmlUnitCoreJsShellCompiledScript\";\n    private static final String COMPILED_SCRIPT_RESULT = \"shellCompiledClassResult\";\n\n    @TempDir\n    Path tempDir;\n\n    @Test\n    @Order(1)\n    void processFileExecutesCompiledScriptClass() throws Exception {\n        try {\n            processGeneratedCompiledScriptClass();\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    @Test\n    @Order(2)\n    void mainInitializesJavaPolicySecurityWhenRequested() {\n        String previous = System.getProperty(\"rhino.use_java_policy_security\");\n        System.setProperty(\"rhino.use_java_policy_security\", \"true\");\n        try {\n            if (NativeImageSupport.isNativeImageRuntime()) {\n                Main.main(new String[] {\"-opt\", \"-1\", \"-e\", \"1;\"});\n            } else {\n                Main.main(new String[] {\"-e\", \"1;\"});\n            }\n\n            assertThat(SecurityController.hasGlobal()).isTrue();\n        } finally {\n            if (previous == null) {\n                System.clearProperty(\"rhino.use_java_policy_security\");\n            } else {\n                System.setProperty(\"rhino.use_java_policy_security\", previous);\n            }\n        }\n    }\n\n    private void processGeneratedCompiledScriptClass() throws Exception {\n        Context context = Context.enter();\n        try {\n            Global global = new Global(context);\n            Path compiledClassFile = tempDir.resolve(COMPILED_SCRIPT_CLASS_NAME + \".class\");\n            Files.write(compiledClassFile, compileScriptClass(context));\n\n            Main.processFile(context, global, compiledClassFile.toUri().toURL().toExternalForm());\n\n            assertThat(ScriptableObject.getProperty(global, COMPILED_SCRIPT_RESULT))\n                    .isEqualTo(\"executed\");\n        } finally {\n            Context.exit();\n        }\n    }\n\n    private static byte[] compileScriptClass(Context context) {\n        CompilerEnvirons compilerEnvirons = new CompilerEnvirons();\n        compilerEnvirons.initFromContext(context);\n        ClassCompiler compiler = new ClassCompiler(compilerEnvirons);\n        Object[] compiled = compiler.compileToClassFiles(\n                \"var \" + COMPILED_SCRIPT_RESULT + \" = 'executed';\",\n                COMPILED_SCRIPT_CLASS_NAME + \".js\",\n            