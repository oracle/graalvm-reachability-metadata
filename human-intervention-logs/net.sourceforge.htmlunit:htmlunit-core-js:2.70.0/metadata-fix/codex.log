{"type":"item.completed","item":{"id":"item_57","type":"command_execution","command":"/usr/bin/bash -lc \"sed -n '1,260p' tests/src/net.sourceforge.htmlunit/htmlunit-core-js/2.70.0/src/test/java/net_sourceforge_htmlunit/htmlunit_core_js/CodegenTest.java\"","aggregated_output":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage net_sourceforge_htmlunit.htmlunit_core_js;\n\nimport net.sourceforge.htmlunit.corejs.javascript.Context;\nimport net.sourceforge.htmlunit.corejs.javascript.Function;\nimport net.sourceforge.htmlunit.corejs.javascript.Scriptable;\n\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class CodegenTest {\n    @Test\n    void compileFunctionCreatesExecutableOptimizedFunction() {\n        try {\n            compileAndCallOptimizedFunction();\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    private static void compileAndCallOptimizedFunction() {\n        Context context = Context.enter();\n        try {\n            context.setOptimizationLevel(0);\n            Scriptable scope = context.initStandardObjects();\n            Function function = context.compileFunction(\n                    scope,\n                    \"function square(value) { return value * value; }\",\n                    \"codegen-function.js\",\n                    1,\n                    null);\n\n            Object result = function.call(context, scope, scope, new Object[] {7});\n\n            assertThat(Context.toNumber(result)).isEqualTo(49.0D);\n        } finally {\n            Context.exit();\n        }\n    }\n}\n","exit_code":0,"status":"completed"}}
