              Method[] methods = interfaces[i].getMethods();
              for (int j = 0; j < methods.length; j++) {
                  Method method = methods[j];
                  int mods = method.getModifiers();
                  if (Modifier.isStatic(mods) || Modifier.isFinal(mods) || method.isDefault()) {
