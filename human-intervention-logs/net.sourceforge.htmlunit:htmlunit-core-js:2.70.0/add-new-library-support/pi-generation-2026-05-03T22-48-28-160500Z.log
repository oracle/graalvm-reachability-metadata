et.sourceforge.htmlunit.corejs.javascript.Context;\nimport net.sourceforge.htmlunit.corejs.javascript.JavaAdapter;\nimport net.sourceforge.htmlunit.corejs.javascript.NativeJavaClass;\nimport net.sourceforge.htmlunit.corejs.javascript.NativeObject;\nimport net.sourceforge.htmlunit.corejs.javascript.ObjToIntMap;\nimport net.sourceforge.htmlunit.corejs.javascript.Scriptable;\nimport net.sourceforge.htmlunit.corejs.javascript.ScriptableObject;\nimport net.sourceforge.htmlunit.corejs.javascript.Wrapper;\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class JavaAdapterTest {\n    @Test\n    void createsAdapterCodeForSuperclassAndInterfaces() {\n        ObjToIntMap functionNames = new ObjToIntMap();\n        functionNames.put(\"mustOverride\", 1);\n        functionNames.put(\"implementedBySuperclass\", 1);\n        functionNames.put(\"concreteMethod\", 0);\n        functionNames.put(\"additionalMethod\", 2);\n\n        byte[] bytecode = JavaAdapter.createAdapterCode(\n                functionNames,\n                \"GeneratedAdapterForCoverage\",\n                AdapterSuperclass.class,\n                new Class<?>[] {AdapterInterface.class},\n                null);\n\n        assertThat(bytecode).isNotEmpty();\n    }\n\n    @Test\n    void createsSerializesAndDeserializesScriptBackedAdapter() throws Exception {\n        Context cx = Context.enter();\n        try {\n            Scriptable scope = cx.initStandardObjects();\n            Object adapterSelf = newGreetingAdapter(cx, scope);\n\n            assertThat(adapterSelf).isInstanceOf(Wrapper.class);\n            Object adapterObject = ((Wrapper) adapterSelf).unwrap();\n            assertThat(adapterObject).isInstanceOf(GreetingService.class);\n            assertThat(((GreetingService) adapterObject).greet(\"Ada\")).isEqualTo(\"hello Ada\");\n            assertThat(JavaAdapter.getAdapterSelf(adapterObject.getClass(), adapterObject))\n                    .isSameAs(adapterSelf);\n\n            byte[] serializedAdapter = serializeAdapter(adapterObject);\n            Object restoredAdapter = deserializeAdapter((Scriptable) adapterSelf, serializedAdapter);\n\n            assertThat(restoredAdapter).isInstanceOf(GreetingService.class);\n            assertThat(((GreetingService) restoredAdapter).greet(\"Grace\")).isEqualTo(\"hello Grace\");\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        } finally {\n            Context.exit();\n        }\n    }\n\n    private static Object newGreetingAdapter(Context cx, Scriptable scope) {\n        Object constructor = ScriptableObject.getProperty(scope, \"JavaAdapter\");\n        NativeJavaClass interfaceClass = new NativeJavaClass(scope, GreetingService.class, true);\n        NativeObject delegee = new NativeObject();\n        ScriptableObject.putProperty(delegee, \"greet\", new GreetingFunction());\n\n        return ((net.sourceforge.htmlunit.corejs.javascript.Function) constructor)\n                .construct(cx, scope, new Object[] {interfaceClass, delegee});\n    }\n\n    private static byte[] serializeAdapter(Object adapterObject) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            JavaAdapter.writeAdapterObject(adapterObject, output);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static Object deserializeAdapter(Scriptable self, byte[] serializedAdapter)\n            throws Exception {\n        ByteArrayInputStream bytes = new ByteArrayInputStream(serializedAdapter);\n        try (ObjectInputStream input = new ObjectInputStream(bytes)) {\n            return JavaAdapter.readAdapterObject(self, input);\n        }\n    }\n\n    public interface GreetingService {\n        String greet(String name);\n    }\n\n    public interface SuperclassInterface {\n        String inheritedInterfaceMethod();\n    }\n\n    public interface AdapterInterface {\n        String mustOverride(String value);\n\n        String implementedBySuperclass(String value);\n    }\n\n    public static class AdapterSuperclass implements SuperclassInterface {\n        public AdapterSuperclass() {\n        }\n\n        public AdapterSuperclass(String ignored) {\n        }\n\n        @Override\n        public String inheritedInterfaceMethod() {\n            return \"inherited\";\n        }\n\n        public String implementedBySuperclass(String value) {\n            return \"super \" + value;\n        }\n\n        public String concreteMethod() {\n            return \"concrete\";\n        }\n\n        protected String protectedMethod() {\n            return \"protected\";\n        }\n\n        public final String finalMethod() {\n            return \"final\";\n        }\n    }\n\n    public static final class GreetingFunction extends BaseFunction implements Serializable {\n        private static final long serialVersionUID = 1L;\n\n        @Override\n        public Object call(Context cx, Scriptable scope, Scriptable thisObj, Object[] args) {\n            return \"hello \" + Context.toString(args[0]);\n        }\n\n        @Override\n        public int getLength() {\n            return 1;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 843, "output": 2348, "cacheRead": 35328, "cacheWrite": 0, "totalTokens": 38519, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777848420224, "responseId": "resp_0f1572d84b9faefb0169f7d064affc8194a6545ebd7685eebe"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_FjKdAel1e32iOE1lUK4cK1s4|fc_0f1572d84b9faefb0169f7d071a1a48194b6cd9dd71120c415", "toolName": "write", "content": [{"type": "text", "text": "Suc