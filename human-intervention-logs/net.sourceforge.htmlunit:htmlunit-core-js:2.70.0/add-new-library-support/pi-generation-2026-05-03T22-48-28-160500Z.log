          cfw.addField(
                  "factory",
                  "Lnet/sourceforge/htmlunit/corejs/javascript/ContextFactory;",
                  (short) (ClassFileWriter.ACC_PUBLIC | ClassFileWriter.ACC_FINAL));
          cfw.addField(
                  "delegee",
                  "Lnet/sourceforge/htmlunit/corejs/javascript/Scriptable;",
                  (short) (ClassFileWriter.ACC_PUBLIC | ClassFileWriter.ACC_FINAL));
          cfw.addField(
                  "self",
                  "Lnet/sourceforge/htmlunit/corejs/javascript/Scriptable;",
                  (short) (ClassFileWriter.ACC_PUBLIC | ClassFileWriter.ACC_FINAL));
          int interfacesCount = interfaces == null ? 0 : interfaces.length;
          for (int i = 0; i < interfacesCount; i++) {
              if (interfaces[i] != null) cfw.addInterface(interfaces[i].getName());
          }
  
          String superName = superClass.getName().replace('.', '/');
