          out.writeObject(cl.getSuperclass().getName());
  
          Class<?>[] interfaces = cl.getInterfaces();
          String[] interfaceNames = new String[interfaces.length];
  
          for (int i = 0; i < interfaces.length; i++) interfaceNames[i] = interfaces[i].getName();
  
