          if (keys != null) {
              for (int i = 0; i != N; ++i) {
                  keys[i] = EMPTY;
              }
              if (values != null) {
                  for (int i = 0; i != N; ++i) {
                      values[i] = null;
                  }
              }
          }
          ivaluesShift = 0;
          keyCount = 0;
          occupiedCount = 0;
      }
  
      /** Return array of present keys */
      public int[] getKeys() {
          int[] keys = this.keys;
          int n = keyCount;
          int[] result = new int[n];
          for (int i = 0; n != 0; ++i) {
              int entry = keys[i];
              if (entry != EMPTY && entry != DELETED) {
                  result[--n] = entry;
              }
          }
          return result;
      }
  
      private static int tableLookupStep(int fraction, int mask, int power) {
          int shift = 32 - 2 * power;
          if (shift >= 0) {
              return ((fraction >>> shift) & mask) | 1;
          }
          return (fraction & (mask >>> -shift)) | 1;
      }
  
      private int findIndex(int key) {
          int[] keys = this.keys;
          if (keys != null) {
