     717	        // Make two passes: one to find a method with direct type assignment,
     718	        // and one to find a widening conversion.
     719	        for (int pass = 1; pass <= 2; ++pass) {
     720	            for (MemberBox method : methods) {
     721	                if (!isStatic || method.isStatic()) {
     722	                    Class<?>[] params = method.argTypes;
     723	                    if (params.length == 1) {
