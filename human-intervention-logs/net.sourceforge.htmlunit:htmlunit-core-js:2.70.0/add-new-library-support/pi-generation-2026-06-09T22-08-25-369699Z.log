        try {\n            Scriptable scope = context.initStandardObjects();\n            Constructor<ConstructedScriptable> constructor =\n                    ConstructedScriptable.class.getConstructor(String.class);\n            FunctionObject original =\n                    new FunctionObject(\"ConstructedScriptable\", constructor, scope);\n\n            FunctionObject copied = roundTrip(original);\n            Scriptable constructed = copied.construct(context, scope, new Object[] {\"created\"});\n\n            assertThat(constructed).isInstanceOf(ConstructedScriptable.class);\n            assertThat(((ConstructedScriptable) constructed).value()).isEqualTo(\"created\");\n            assertThat(copied.getMethodOrConstructor()).isEqualTo(constructor);\n        } finally {\n            Context.exit();\n        }\n    }\n\n    @Test\n    void invokesPublicInterfaceMethodDeclaredByNonPublicReceiver() throws Exception {\n        Context context = Context.enter();\n        try {\n            Scriptable scope = context.initStandardObjects();\n            HiddenInterfaceReceiver receiver = new HiddenInterfaceReceiver(\"interface\");\n            Method method =\n                    HiddenInterfaceReceiver.class.getDeclaredMethod(\n                            \"interfaceValue\", String.class);\n            FunctionObject function = new FunctionObject(\"interfaceValue\", method, scope);\n\n            Object result = function.call(context, scope, receiver, new Object[] {\"method\"});\n\n            assertThat(result).isEqualTo(\"interface-method\");\n        } finally {\n            Context.exit();\n        }\n    }\n\n    @Test\n    void invokesPublicSuperclassMethodDeclaredByNonPublicReceiver() throws Exception {\n        Context context = Context.enter();\n        try {\n            Scriptable scope = context.initStandardObjects();\n            HiddenSuperclassReceiver receiver = new HiddenSuperclassReceiver(\"superclass\");\n            Method method =\n                    HiddenSuperclassReceiver.class.getDeclaredMethod(\n                            \"superclassValue\", String.class);\n            FunctionObject function = new FunctionObject(\"superclassValue\", method, scope);\n\n            Object result = function.call(context, scope, receiver, new Object[] {\"method\"});\n\n            assertThat(result).isEqualTo(\"superclass-method\");\n        } finally {\n            Context.exit();\n        }\n    }\n\n    @Test\n    void constructsNonPublicScriptableAfterMakingConstructorAccessible() throws Exception {\n        Context context = Context.enter();\n        try {\n            Scriptable scope = context.initStandardObjects();\n            Constructor<HiddenConstructedScriptable> constructor =\n                    HiddenConstructedScriptable.class.getDeclaredConstructor(String.class);\n            FunctionObject function =\n                    new FunctionObject(\"HiddenConstructedScriptable\", constructor, scope);\n\n            Scriptable constructed = function.construct(context, scope, new Object[] {\"hidden\"});\n\n            assertThat(constructed).isInstanceOf(HiddenConstructedScriptable.class);\n            assertThat(((HiddenConstructedScriptable) constructed).value()).isEqualTo(\"hidden\");\n        } finally {\n            Context.exit();\n        }\n    }\n\n    private FunctionObject roundTrip(FunctionObject functionObject) throws Exception {\n        functionObject.setParentScope(null);\n        functionObject.setPrototype(null);\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(functionObject);\n        }\n        try (ObjectInputStream input =\n                new ObjectInputStream(new ByteArrayInputStream(bytes.toByteArray()))) {\n            return (FunctionObject) input.readObject();\n        }\n    }\n\n    public static final class MethodTarget {\n        private MethodTarget() {}\