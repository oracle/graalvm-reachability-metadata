     709	    private static MemberBox extractSetMethod(
     710	            Class<?> type, MemberBox[] methods, boolean isStatic) {
     711	        //
     712	        // Note: it may be preferable to allow NativeJavaMethod.findFunction()
     713	        //       to find the appropriate setter; unfortunately, it requires an
     714	        //       instance of the target arg to determine that.
