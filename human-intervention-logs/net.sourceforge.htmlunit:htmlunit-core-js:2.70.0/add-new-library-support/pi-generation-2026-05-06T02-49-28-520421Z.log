ion function = (Function) ScriptableObject.getProperty(\n                    scope,\n                    \"publicFallbackFunction\");\n            Object result = function.call(\n                    context,\n                    scope,\n                    scope,\n                    new Object[] {\"value\"});\n\n            assertThat(Context.toString(result)).isEqualTo(\"fallback:value\");\n        } finally {\n            Context.exit();\n        }\n    }\n\n    @Test\n    void constructUsesDefaultConstructorForFunctionObjectsBackedByInstanceMethod()\n            throws Exception {\n        Context context = Context.enter();\n        try {\n            Scriptable scope = context.initStandardObjects();\n            String className = ScriptableObject.defineClass(\n                    scope,\n                    ConstructibleScriptable.class,\n                    false,\n                    false);\n\n            Function constructor = (Function) ScriptableObject.getProperty(\n                    scope,\n                    \"ConstructibleScriptable\");\n            Scriptable created = constructor.construct(\n                    context,\n                    scope,\n                    new Object[] {\"Ada\"});\n\n            assertThat(className).isEqualTo(\"ConstructibleScriptable\");\n            assertThat(created).isInstanceOf(ConstructibleScriptable.class);\n            assertThat(((ConstructibleScriptable) created).getName()).isEqualTo(\"Ada\");\n            assertThat(created.getPrototype()).isNotNull();\n            assertThat(created.getParentScope()).isSameAs(scope);\n        } finally {\n            Context.exit();\n        }\n    }\n\n    private static final String PUBLIC_FALLBACK_FUNCTIONS_CLASS = \"\"\"\n            yv66vgAAADQAHAoAAgADBwAEDAAFAAYBABBqYXZhL2xhbmcvT2JqZWN0AQAGPGluaXQ+AQADKClW\n            BwAIAQAXamF2YS9sYW5nL1N0cmluZ0J1aWxkZXIKAAcAAwgACwEACWZhbGxiYWNrOgoABwANDAAO\n            AA8BAAZhcHBlbmQBAC0oTGphdmEvbGFuZy9TdHJpbmc7KUxqYXZhL2xhb