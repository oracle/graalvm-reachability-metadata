          itsStackTop = (short) newStack;
          if (newStack > itsMaxStack) itsMaxStack = (short) newStack;
          if (DEBUGSTACK) {
              System.out.println("After " + bytecodeStr(theOpCode) + " stack = " + itsStackTop);
          }
      }
  
