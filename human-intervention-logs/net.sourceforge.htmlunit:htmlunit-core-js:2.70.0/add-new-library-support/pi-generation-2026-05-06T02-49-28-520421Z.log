              Y2tGdW5jdGlvbgEAJihMamF2YS9sYW5nL1N0cmluZzspTGphdmEvbGFuZy9TdHJpbmc7AQAKU291
              cmNlRmlsZQEAKkZ1bmN0aW9uT2JqZWN0UHVibGljRmFsbGJhY2tGdW5jdGlvbnMuamF2YQAxABQA
              AgAAAAAAAgACAAUABgABABYAAAAhAAEAAQAAAAUqtwABsQAAAAEAFwAAAAoAAgAAAAQABAAFAAkA
              GAAZAAEAFgAAACwAAgABAAAAFLsAB1m3AAkSCrYADCq2AAy2ABCwAAAAAQAXAAAABgABAAAACAAB
              ABoAAAACABs=
              """;
  
      public static class ConstructibleScriptable extends ScriptableObject {
          private static final long serialVersionUID = 1L;
  
          private String name;
  
          public ConstructibleScriptable() {
          }
  
          @Override
          public String getClassName() {
              return "ConstructibleScriptable";
          }
  
          public void jsConstructor(String newName) {
              name = newName;
          }
  
          public String getName() {
              return name;
          }
      }
  
      @SuppressWarnings("removal")
      private static boolean installSecurityManagerIfSupported(SecurityManager securityManager) {
          try {
              System.setSecurityManager(securityManager);
              return System.getSecurityManager() == securityManager;
          } catch (UnsupportedOperationException | SecurityException exception) {
              return false;
          }
      }
  
      private static final class ByteArrayClassLoader extends ClassLoader {
          ByteArrayClassLoader() {
              super(null);
          }
  
          Class<?> define(String name, byte[] bytes) {
              return defineClass(name, bytes, 0, bytes.length);
          }
      }
  
      @SuppressWarnings("removal")
      private static final class DeclaredMemberDenyingSecurityManager extends SecurityManager {
          private boolean denyNextPermissionCheck;
  
          @Override
          public void checkPermission(Permission permission) {
              if (denyNextPermissionCheck) {
                  denyNextPermissionCheck = false;
                  throw new SecurityException("declared member access denied for fallback test");
              }
          }
  
          void setDenyNextPermissionCheck(boolean denyNextPermissionCheck) {
              this.denyNextPermissionCheck = denyNextPermissionCheck;
          }
      }
