ertThat((Boolean) readerClass.getMethod(\"isBellEnabled\").invoke(null)).isFalse();\n\n                shellConsoleClass.getMethod(\"print\", String.class).invoke(console, \"legacy-prefix\");\n                shellConsoleClass.getMethod(\"println\", String.class).invoke(console, \"line\");\n                shellConsoleClass.getMethod(\"println\").invoke(console);\n                shellConsoleClass.getMethod(\"flush\").invoke(console);\n\n                Object line = shellConsoleClass.getMethod(\"readLine\", String.class)\n                        .invoke(console, \"legacy> \");\n                assertThat(line).isEqualTo(\"legacy-command\");\n\n                InputStream input = (InputStream) shellConsoleClass.getMethod(\"getIn\").invoke(console);\n                byte[] streamBytes = input.readNBytes(32);\n                assertThat(new String(streamBytes, StandardCharsets.UTF_8)).isEqualTo(\"legacy-stream\\n\");\n\n                String output = (String) readerClass.getMethod(\"output\").invoke(null);\n                assertThat(output).contains(\"legacy-prefixline\\n\\nlegacy> \");\n            }\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    private static void resetLegacyReader(Class<?> readerClass) throws Exception {\n        readerClass.getMethod(\"reset\").invoke(null);\n        readerClass.getMethod(\"addLine\", String.class).invoke(null, \"legacy-command\");\n        readerClass.getMethod(\"addLine\", String.class).invoke(null, \"legacy-stream\");\n    }\n\n    private static final class JLineV1ClassLoader extends URLClassLoader {\n        JLineV1ClassLoader(URL coreJsUrl, URL testClassesUrl) {\n            super(new URL[] {coreJsUrl, testClassesUrl}, ClassLoader.getPlatformClassLoader());\n        }\n\n        @Override\n        protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {\n            if (name.startsWith(\"jline.console.\")) {\n                throw new ClassNotFoundException(name);\n            }\n            if (isChildFirstClass(name)) {\n                synchronized (getClassLoadingLock(name)) {\n                    Class<?> loadedClass = findLoadedClass(name);\n                    if (loadedClass == null) {\n                        loadedClass = findChildFirstClass(name);\n                    }\n                    if (resolve) {\n                        resolveClass(loadedClass);\n                    }\n                    return loadedClass;\n                }\n            }\n            return super.loadClass(name, resolve);\n        }\n\n        private Class<?> findChildFirstClass(String name) throws ClassNotFoundException {\n            try {\n                return findClass(name);\n            } catch (ClassNotFoundException exception) {\n                return super.loadClass(name, false);\n            }\n        }\n\n        private static boolean isChildFirstClass(String name) {\n            return name.startsWith(\"net.sourceforge.htmlunit.corejs.javascript.\")\n                    || name.equals(\"jline.ConsoleReader\")\n                    || name.equals(\"jline.Completor\");\n        }\n    }\n}\n"}
