       ObjToIntMap functionNames = new ObjToIntMap();\n        functionNames.put(\"get\", 1);\n        functionNames.put(\"size\", 0);\n        functionNames.put(\"run\", 0);\n        functionNames.put(\"scriptOnlyFunction\", 2);\n\n        byte[] bytecode = JavaAdapter.createAdapterCode(\n                functionNames,\n                \"HtmlUnitCoreJsJavaAdapterCoverage\",\n                AbstractList.class,\n                new Class<?>[] {Runnable.class, List.class},\n                null);\n\n        assertThat(bytecode).isNotEmpty();\n    }\n\n    private static Object createEmptyRunnableAdapter(Context context, Scriptable scope) {\n        NativeObject delegee = new NativeObject();\n        delegee.setParentScope(scope);\n        delegee.setPrototype(ScriptableObject.getObjectPrototype(scope));\n        ScriptableObject.putProperty(scope, \"delegee\", delegee);\n\n        Object result = context.evaluateString(scope, \"\"\"\n                new JavaAdapter(java.lang.Runnable, delegee);\n                \"\"\", \"java-adapter-serialization-test\", 1, null);\n        Object adapter = unwrap(result);\n        assertThat(adapter).isInstanceOf(Runnable.class);\n\n        delegee.setParentScope(null);\n        delegee.setPrototype(null);\n        return adapter;\n    }\n\n    private static byte[] serializeAdapterDescriptor(Object adapter) throws IOException {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            JavaAdapter.writeAdapterObject(adapter, output);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static Object deserializeAdapterDescriptor(Scriptable self, byte[] descriptor)\n            throws IOException, ClassNotFoundException {\n        ByteArrayInputStream bytes = new ByteArrayInputStream(descriptor);\n        try (ObjectInputStream input = new ObjectInputStream(bytes)) {\n            return JavaAdapter.readAdapterObject(self, input);\n        }\n    }\n\n    private static Object unwrap(Object value) {\n        if (value instanceof Wrapper wrapper) {\n            return wrapper.unwrap();\n        }\n        return value;\n    }\n}\n"}], "isError": false, "timestamp": 1778012480873}}
