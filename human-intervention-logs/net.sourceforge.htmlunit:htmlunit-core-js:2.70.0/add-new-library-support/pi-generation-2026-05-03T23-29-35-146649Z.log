          NativeJavaClass interfaceClass = new NativeJavaClass(scope, GreetingService.class, true);
          NativeObject delegee = new NativeObject();
          ScriptRuntime.setObjectProtoAndParent(delegee, scope);
          GreetingFunction greet = new GreetingFunction();
          ScriptRuntime.setFunctionProtoAndParent(greet, cx, scope, false);
          ScriptableObject.putProperty(delegee, "greet", greet);
  
          Object self = ((Function) constructor)
                  .construct(cx, scope, new Object[] {interfaceClass, delegee});
          return new AdapterFixture(self, delegee, greet);
      }
  
      private static byte[] serializeAdapter(Object adapterObject) throws Exception {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {
              JavaAdapter.writeAdapterObject(adapterObject, output);
          }
          return bytes.toByteArray();
      }
  
      private static Object deserializeAdapter(Scriptable self, byte[] serializedAdapter)
              throws Exception {
          ByteArrayInputStream bytes = new ByteArrayInputStream(serializedAdapter);
          try (ObjectInputStream input = new ObjectInputStream(bytes)) {
              return JavaAdapter.readAdapterObject(self, input);
          }
      }
  
      private record AdapterFixture(Object self, NativeObject delegee, GreetingFunction greet) {
