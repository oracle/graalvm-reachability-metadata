      void generatesAdapterBytecodeForSuperclassAndInterfaceMethods() {
          ObjToIntMap functionNames = new ObjToIntMap();
          functionNames.put("get", 1);
          functionNames.put("size", 0);
          functionNames.put("run", 0);
          functionNames.put("scriptOnlyFunction", 2);
  
          byte[] bytecode = JavaAdapter.createAdapterCode(
                  functionNames,
                  "HtmlUnitCoreJsJavaAdapterCoverage",
                  AbstractList.class,
                  new Class<?>[] {Runnable.class, List.class},
                  null);
  
          assertThat(bytecode).isNotEmpty();
