bject constructor = ScriptableObject.getProperty(scope, \"FinishInitScriptable\");\n            assertThat(definedName).isEqualTo(\"FinishInitScriptable\");\n            assertThat(constructor).isInstanceOf(FunctionObject.class);\n            assertThat(FinishInitScriptable.constructorInvocations).isEqualTo(1);\n            assertThat(FinishInitScriptable.finishInitInvocations).isEqualTo(1);\n            assertThat(FinishInitScriptable.observedScope).isSameAs(scope);\n            assertThat(FinishInitScriptable.observedConstructor).isSameAs(constructor);\n            assertThat(FinishInitScriptable.observedPrototype).isInstanceOf(FinishInitScriptable.class);\n            assertThat(ScriptableObject.getProperty((Scriptable) constructor, \"finishInitRegistered\"))\n                    .isEqualTo(Boolean.TRUE);\n        } finally {\n            Context.exit();\n        }\n    }\n\n    public static class InitMethodScriptable extends ScriptableObject {\n        private static final long serialVersionUID = 1L;\n\n        static boolean initialized;\n        static Context observedContext;\n        static Scriptable observedScope;\n        static boolean observedSealed;\n\n        public static void init(Context cx, Scriptable scope, boolean sealed) {\n            initialized = true;\n            observedContext = cx;\n            observedScope = scope;\n            observedSealed = sealed;\n            ScriptableObject.putProperty(scope, \"initRegistered\", Boolean.TRUE);\n        }\n\n        static void reset() {\n            initialized = false;\n            observedContext = null;\n            observedScope = null;\n            observedSealed = false;\n        }\n\n        @Override\n        public String getClassName() {\n            return \"InitMethodScriptable\";\n        }\n    }\n\n    public static class FinishInitScriptable extends ScriptableObject {\n        private static final long serialVersionUID = 1L;\n\n        static int constructorInvocations;\n        static int finishInitInvocations;\n        static Scriptable observedScope;\n        static FunctionObject observedConstructor;\n        static Scriptable observedPrototype;\n\n        public FinishInitScriptable() {\n            constructorInvocations++;\n        }\n\n        public static void finishInit(\n                Scriptable scope, FunctionObject constructor, Scriptable prototype) {\n            finishInitInvocations++;\n            observedScope = scope;\n            observedConstructor = constructor;\n            observedPrototype = prototype;\n            ScriptableObject.putProperty(constructor, \"finishInitRegistered\", Boolean.TRUE);\n        }\n\n        static void reset() {\n            constructorInvocations = 0;\n            finishInitInvocations = 0;\n            observedScope = null;\n            observedConstructor = null;\n            observedPrototype = null;\n        }\n\n        @Override\n        public String getClassName() {\n            return \"FinishInitScriptable\";\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 3822, "output": 1776, "cacheRead": 24576, "cacheWrite": 0, "totalTokens": 30174, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777853671950, "responseId": "resp_040a0a543ddbd5520169f7e4e89dd8819ca8248487f0c01c55"}}
