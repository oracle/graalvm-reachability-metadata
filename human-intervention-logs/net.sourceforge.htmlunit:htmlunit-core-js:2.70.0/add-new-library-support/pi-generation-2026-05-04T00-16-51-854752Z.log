  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  
  import net.sourceforge.htmlunit.corejs.javascript.Context;
  import net.sourceforge.htmlunit.corejs.javascript.FunctionObject;
  import net.sourceforge.htmlunit.corejs.javascript.Scriptable;
  import net.sourceforge.htmlunit.corejs.javascript.ScriptableObject;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class MemberBoxTest {
      @Test
      void invokesAndSerializesMethodBackedFunctionObject() throws Exception {
          Context cx = Context.enter();
          try {
              Scriptable scope = cx.initStandardObjects();
              FunctionObject function = new FunctionObject(
                      "format",
                      MethodBackedFunctions.class.getMethod(
                              "format", String.class, int.class, Object.class),
                      scope);
  
              Object result = function.call(cx, scope, scope, new Object[] {"alpha", 7, "omega"});
              assertThat(result).isEqualTo("alpha:7:omega");
  
              FunctionObject restored = roundTrip(function);
              Object restoredResult = restored.call(
                      cx, scope, scope, new Object[] {"beta", 11, "delta"});
              assertThat(restoredResult).isEqualTo("beta:11:delta");
          } finally {
              Context.exit();
          }
      }
  
      @Test
      void invokesAndSerializesConstructorBackedFunctionObject() throws Exception {
          Context cx = Context.enter();
          try {
              Scriptable scope = cx.initStandardObjects();
              FunctionObject constructor = new FunctionObject(
                      "PublicConstructedScriptable",
                      PublicConstructedScriptable.class.getConstructor(),
                      scope);
  
              Object created = constructor.call(cx, scope, null, new Object[0]);
              assertThat(created).isInstanceOf(PublicConstructedScriptable.class);
  
              FunctionObject restored = roundTrip(constructor);
              Object restoredCreated = restored.call(cx, scope, null, new Object[0]);
              assertThat(restoredCreated).isInstanceOf(PublicConstructedScriptable.class);
          } finally {
              Context.exit();
          }
      }
  
      @Test
      void recoversInaccessibleInterfaceMethodThroughPublicInterface() throws Exception {
          Context cx = Context.enter();
          try {
              Scriptable scope = cx.initStandardObjects();
              HiddenInterfaceOperation target = new HiddenInterfaceOperation();
              FunctionObject function = new FunctionObject(
                      "describe",
                      HiddenInterfaceOperation.class.getDeclaredMethod("describe", String.class),
                      scope);
  
              Object result = function.call(cx, scope, target, new Object[] {"interface"});
  
              assertThat(result).isEqualTo("hidden-interface:interface");
          } finally {
              Context.exit();
          }
      }
  
      @Test
      void recoversInaccessibleSuperclassMethodThroughPublicSuperclass() throws Exception {
          Context cx = Context.enter();
          try {
              Scriptable scope = cx.initStandardObjects();
              HiddenSuperclassOperation target = new HiddenSuperclassOperation();
              FunctionObject function = new FunctionObject(
                      "describe",
                      HiddenSuperclassOperation.class.getDeclaredMethod("describe", String.class),
                      scope);
  
              Object result = function.call(cx, scope, target, new Object[] {"superclass"});
  
              assertThat(result).isEqualTo("hidden-superclass:superclass");
          } finally {
              Context.exit();
          }
      }
  
      @Test
      void retriesInaccessibleConstructorAfterMakingItAccessible() throws Exception {
          Context cx = Context.enter();
          try {
              Scriptable scope = cx.initStandardObjects();
              FunctionObject constructor = new FunctionObject(
                      "HiddenConstructedScriptable",
                      HiddenConstructedScriptable.class.getDeclaredConstructor(),
                      scope);
  
              Object created = constructor.call(cx, scope, null, new Object[0]);
  
              assertThat(created).isInstanceOf(HiddenConstructedScriptable.class);
              assertThat(((HiddenConstructedScriptable) created).createdByPrivateConstructor)
                      .isTrue();
          } finally {
              Context.exit();
          }
      }
  
      private static FunctionObject roundTrip(FunctionObject function) throws Exception {
          function.setParentScope(null);
          function.setPrototype(null);
  
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {
              output.writeObject(function);
          }
  
          try (ObjectInputStream input = new ObjectInputStream(
                  new ByteArrayInputStream(bytes.toByteArray()))) {
              return (FunctionObject) input.readObject();
          }
      }
  
      public static final class MethodBackedFunctions {
          private MethodBackedFunctions() {
          }
  
          public static String format(String value, int number, Object suffix) {
              return value + ':' + number + ':' + suffix;
          }
      }
  
      public static class PublicConstructedScriptable extends ScriptableObject {
          private static final long serialVersionUID = 1L;
  
          public PublicConstructedScriptable() {
          }
  
          @Override
          public String getClassName() {
              return "PublicConstructedScriptable";
          }
      }
  
      public interface PublicInterfaceOperation {
          String describe(String value);
      }
  
      private static final class HiddenInterfaceOperation extends ScriptableObject
              implements PublicInterfaceOperation {
          private static final long serialVersionUID = 1L;
  
          @Override
          public String describe(String value) {
              return "hidden-interface:" + value;
          }
  
          @Override
          public String getClassName() {
              return "HiddenInterfaceOperation";
          }
      }
  
      public static class PublicSuperclassOperation extends ScriptableObject {
          private static final long serialVersionUID = 1L;
  
          public String describe(String value) {
              return "public-superclass:" + value;
          }
  
          @Override
          public String getClassName() {
              return "PublicSuperclassOperation";
          }
      }
  
      private static final class HiddenSuperclassOperation extends PublicSuperclassOperation {
          private static final long serialVersionUID = 1L;
  
          @Override
          public String describe(String value) {
              return "hidden-superclass:" + value;
          }
      }
  
      private static final class HiddenConstructedScriptable extends ScriptableObject {
          private static final long serialVersionUID = 1L;
  
          private final boolean createdByPrivateConstructor;
  
          private HiddenConstructedScriptable() {
              createdByPrivateConstructor = true;
          }
  
          @Override
          public String getClassName() {
              return "HiddenConstructedScriptable";
          }
      }
  }
