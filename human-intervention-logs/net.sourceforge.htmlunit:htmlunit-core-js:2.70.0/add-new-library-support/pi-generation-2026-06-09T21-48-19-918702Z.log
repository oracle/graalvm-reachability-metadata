mport net.sourceforge.htmlunit.corejs.javascript.Scriptable;\nimport net.sourceforge.htmlunit.corejs.javascript.ScriptableObject;\nimport org.junit.jupiter.api.Test;\n\npublic class MemberBoxTest {\n    @Test\n    void roundTripsMethodFunctionAndInvokesDeserializedMember() throws Exception {\n        Context context = Context.enter();\n        try {\n            Scriptable scope = context.initStandardObjects();\n            Method method = MethodTarget.class.getMethod(\"combine\", String.class, int.class);\n            FunctionObject original = new FunctionObject(\"combine\", method, scope);\n\n            FunctionObject copied = roundTrip(original);\n            Object result = copied.call(context, scope, scope, new Object[] {\"item\", 7});\n\n            assertThat(result).isEqualTo(\"item:7\");\n            assertThat(copied.getMethodOrConstructor()).isEqualTo(method);\n        } finally {\n            Context.exit();\n        }\n    }\n\n    @Test\n    void roundTripsConstructorFunctionAndConstructsDeserializedMember() throws Exception {\n        Context context = Context.enter();\n        try {\n            Scriptable scope = context.initStandardObjects();\n            Constructor<ConstructedScriptable> constructor =\n                    ConstructedScriptable.class.getConstructor(String.class);\n            FunctionObject original =\n                    new FunctionObject(\"ConstructedScriptable\", constructor, scope);\n\n            FunctionObject copied = roundTrip(original);\n            Scriptable constructed = copied.construct(context, scope, new Object[] {\"created\"});\n\n            assertThat(constructed).isInstanceOf(ConstructedScriptable.class);\n            assertThat(((ConstructedScriptable) constructed).value()).isEqualTo(\"created\");\n            assertThat(copied.getMethodOrConstructor()).isEqualTo(constructor);\n        } finally {\n            Context.exit();\n        }\n    }\n\n    @Test\n    void invokesPublicInterfaceMethodDeclaredByNonPublicReceiver() throws Exception {\n        Context context = Context.enter();\n        try {\n            Scriptable scope = context.initStandardObjects();\n            HiddenInterfaceReceiver receiver = new HiddenInterfaceReceiver(\"interface\");\n            Method method =\n                    HiddenInterfaceReceiver.class.getDeclaredMethod(\n                            \"interfaceValue\", String.class);\n            FunctionObject function = new FunctionObject(\"interfaceValue\", method, scope);\n\n            Object result = function.call(context, scope, receiver, new Object[] {\"method\"});\n\n            assertThat(result).isEqualTo(\"interface-method\");\n        } finally {\n            Context.exit();\n        }\n    }\n\n    @Test\n    void invokesPublicSuperclassMethodDeclaredByNonPublicReceiver() throws Exception {\n        Context context = Context.enter();\n        try {\n            Scriptable scope = context.initStandardObjects();\n            HiddenSuperclassReceiver receiver = new HiddenSuperclassReceiver(\"superclass\");\n            Method method =\n                    HiddenSuperclassReceiver.class.getDeclaredMethod(\n                            \"superclassValue\", String.class);\n            FunctionObject function = new FunctionObject(\"superclassValue\", method, scope);\n\n            Object result = function.call(context, scope, receiver, new Object[] {\"method\"});\n\n            assertThat(result).isEqualTo(\"superclass-method\");\n        } finally {\n            Context.exit();\n        }\n    }\n\n    @Test\n    void constructsNonPublicScriptableAfterMakingConstructorAccessible() throws Exception {\n        Context context = Context.enter();\n        try {\n            Scriptable scope = context.initStandardObjects();\n            Constructor<HiddenConstructedScriptable> constructor =\n                    HiddenConstructedScriptable.class.getDeclaredConstructor(String.class);\n            FunctionObject function =\n                    new FunctionObject(\"HiddenConstructedScriptable\", constructor, scope);\n\n            Scriptable constructed = function.construct(context, scope, new Object[] {\"hidden\"});\n\n            assertThat(constructed).isInstanceOf(HiddenConstructedScriptable.class);\n            assertThat(((HiddenConstructedScriptable) constructed).value()).isEqualTo(\"hidden\");\n        } finally {\n            Context.exit();\n        }\n    }\n\n    private FunctionObject roundTrip(FunctionObject functionObject) throws Exception {\n        functionObject.setParentScope(null);\n        functionObject.setPrototype(null);\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(functionObject);\n        }\n        try (ObjectInputStream input =\n                new ObjectInputStream(new ByteArrayInputStream(bytes.toByteArray()))) {\n            return (FunctionObject) input.readObject();\n        }\n    }\n\n    public static final class MethodTarget {\n        private MethodTarget() {}\n\n        public static String combine(String prefix, int value) {\n            return prefix + ':' + value;\n        }\n    }\n\n    public static class ConstructedScriptable extends ScriptableObject {\n        private static final long serialVersionUID = 1L;\n\n        private final String value;\n\n        public ConstructedScriptable(String value) {\n            this.value = value;\n        }\n\n        @Override\n        public String getClassName() {\n            return \"ConstructedScriptable\";\n        }\n\n        String value() {\n            return value;\n        }\n    }\n\n    public interface InterfaceReceiver {\n        String interfaceValue(String suffix);\n    }\n\n    private static final class HiddenInterfaceReceiver extends ScriptableObject\n            implements InterfaceReceiver {\n        private static final long serialVersionUID = 1L;\n\n        private final String value;\n\n        private HiddenInterfaceReceiver(String value) {\n            this.value = value;\n        }\n\n        @Override\n        public String getClassName() {\n            return \"HiddenInterfaceReceiver\";\n        }\n\n        @Override\n        public String interfaceValue(String suffix) {\n            return value + '-' + suffix;\n        }\n    }\n\n    public static class SuperclassReceiver extends ScriptableObject {\n        private static final long serialVersionUID = 1L;\n\n        protected final String value;\n\n        public SuperclassReceiver(String value) {\n            this.value = value;\n        }\n\n        @Override\n        public String getClassName() {\n            return \"SuperclassReceiver\";\n        }\n\n        public String superclassValue(String suffix) {\n            return value + '-' + suffix;\n        }\n    }\n\n    private static final class HiddenSuperclassReceiver extends SuperclassReceiver {\n        private static final long serialVersionUID = 1L;\n\n        private HiddenSuperclassReceiver(String value) {\n            super(value);\n        }\n\n        @Override\n        public String superclassValue(String suffix) {\n            return value + '-' + suffix;\n        }\n    }\n\n    private static final class HiddenConstructedScriptable extends ScriptableObject {\n        private static final long serialVersionUID = 1L;\n\n        private final String value;\n\n        public HiddenConstructedScriptable(String value) {\n            this.value = value;\n        }\n\n        @Override\n        public String getClassName() {\n            return \"HiddenConstructedScriptable\";\n        }\n\n        String value() {\n            return value;\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1781041671728}]}
