  import org.junit.jupiter.api.Test;
  
  public class JavaAdapterTest {
      @Test
      void createsAdapterBytecodeForClassAndInterfaceMethods() {
          ObjToIntMap functionNames = new ObjToIntMap();
          functionNames.put("run", 0);
          functionNames.put("customValue", 1);
  
          byte[] adapterCode =
                  JavaAdapter.createAdapterCode(
                          functionNames,
                          "GeneratedAdapterBaseMarkerAdapter",
                          AdapterBase.class,
                          new Class<?>[] {AdapterMarker.class},
                          null);
  
          assertThat(adapterCode).isNotEmpty();
      }
  
      @Test
      void createsAdapterFromJavaScriptAndRoundTripsSerializationDescriptor() throws Exception {
          try {
              createAdapterFromJavaScriptAndRoundTripSerializationDescriptor();
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
      }
  
      private void createAdapterFromJavaScriptAndRoundTripSerializationDescriptor()
              throws Exception {
          Context context = Context.enter();
          try {
              ScriptableObject scope = context.initStandardObjects();
              JavaAdapter.init(context, scope, false);
              RecordingFunction runFunction = new RecordingFunction();
              RecordingFunction customValueFunction = new RecordingFunction();
              ScriptRuntime.setFunctionProtoAndParent(runFunction, context, scope);
              ScriptRuntime.setFunctionProtoAndParent(customValueFunction, context, scope);
              NativeObject implementation = new NativeObject();
              ScriptRuntime.setObjectProtoAndParent(implementation, scope);
              implementation.defineProperty("run", runFunction, ScriptableObject.EMPTY);
              implementation.defineProperty(
                      "customValue", customValueFunction, ScriptableObject.EMPTY);
  
              Object constructor = ScriptableObject.getProperty(scope, "JavaAdapter");
              Object wrapper =
                      Function.class
                              .cast(constructor)
                              .construct(
                                      context,
                                      scope,
                                      new Object[] {
                                          new NativeJavaClass(scope, AdapterBase.class),
                                          new NativeJavaClass(scope, AdapterMarker.class),
                                          implementation
                                      });
  
              assertThat(wrapper).isInstanceOf(Wrapper.class);
              Object adapter = ((Wrapper) wrapper).unwrap();
              assertThat(adapter).isInstanceOf(AdapterMarker.class);
              AdapterMarker marker = AdapterMarker.class.cast(adapter);
              assertThat(marker.baseValue()).isEqualTo("base");
              marker.run();
              assertThat(runFunction.callCount()).isOne();
  
              detachFromScope(implementation);
              detachFromScope(runFunction);
              detachFromScope(customValueFunction);
  
              Object copiedAdapter = roundTripAdapter(scope, adapter);
              assertThat(copiedAdapter).isInstanceOf(AdapterMarker.class);
              assertThat(AdapterMarker.class.cast(copiedAdapter).baseValue()).isEqualTo("base");
          } finally {
              Context.exit();
          }
      }
  
      private void detachFromScope(ScriptableObject scriptableObject) {
          scriptableObject.setParentScope(null);
          scriptableObject.setPrototype(null);
      }
  
      private Object roundTripAdapter(Scriptable scope, Object adapter) throws Exception {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {
              JavaAdapter.writeAdapterObject(adapter, output);
          }
  
          try (ObjectInputStream input =
                  new ObjectInputStream(new ByteArrayInputStream(bytes.toByteArray()))) {
              return JavaAdapter.readAdapterObject(scope, input);
          }
      }
  
      public interface AdapterMarker extends Runnable {
          String baseValue();
      }
  
      public static class AdapterBase implements AdapterMarker, Serializable {
          private static final long serialVersionUID = 1L;
  
          @Override
          public String baseValue() {
              return "base";
          }
  
          @Override
          public void run() {}
  
          public Object customValue(Object value) {
              return value;
          }
      }
  
      private static final class RecordingFunction extends BaseFunction implements Serializable {
          private static final long serialVersionUID = 1L;
  
          private int callCount;
  
          @Override
          public Object call(
                  Context context,
                  Scriptable scope,
                  Scriptable thisObj,
                  Object[] args) {
              callCount++;
              return null;
          }
  
          int callCount() {
              return callCount;
          }
      }
