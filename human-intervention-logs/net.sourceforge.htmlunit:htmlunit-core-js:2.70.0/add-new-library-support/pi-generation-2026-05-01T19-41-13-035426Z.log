ory();\n        SwingUtilities.invokeAndWait(factory);\n        return factory.gui;\n    }\n\n    private static void disposeOnEventDispatchThread(SwingGui gui) throws Exception {\n        SwingUtilities.invokeAndWait(gui::dispose);\n    }\n\n    private static void collectSplitPanes(Component component, List<JSplitPane> splitPanes) {\n        if (component instanceof JSplitPane) {\n            splitPanes.add((JSplitPane) component);\n        }\n        if (component instanceof Container) {\n            for (Component child : ((Container) component).getComponents()) {\n                collectSplitPanes(child, splitPanes);\n            }\n        }\n    }\n\n    private static void assertResizeWeight(JSplitPane splitPane, double expectedWeight) {\n        assertThat(splitPane.getResizeWeight()).isEqualTo(expectedWeight);\n    }\n\n    private static final class GuiFactory implements Runnable {\n        private SwingGui gui;\n\n        @Override\n        public void run() {\n            gui = new SwingGui(new Dim(), \"Debugger Test\");\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1262, "output": 1128, "cacheRead": 22528, "cacheWrite": 0, "totalTokens": 24918, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777664427734, "responseId": "resp_0a2a8cb1233823bd0169f501ac37288195a880365b793a9d73"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_oOn2C3T1tQGA2fcPOIhR9Ljg|fc_0a2a8cb1233823bd0169f501b5f03881959f1292e12a7be7ca", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2427 bytes to tests/src/net.sourceforge.htmlunit/htmlunit-core-js/2.70.0/src/test/java/net_sourceforge_htmlunit/htmlunit_core_js/SwingGuiTest.java"}], "isError": false, "timestamp": 1777664441941}]}
