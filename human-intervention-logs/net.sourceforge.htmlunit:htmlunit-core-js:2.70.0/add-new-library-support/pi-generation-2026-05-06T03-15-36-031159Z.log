rt net.sourceforge.htmlunit.corejs.javascript.Scriptable;\n\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class FieldAndMethodsTest {\n    @Test\n    void defaultValueReadsJavaFieldWhenFieldAndMethodShareName() {\n        Context context = Context.enter();\n        try {\n            Scriptable scope = context.initStandardObjects();\n            FieldMethodNameCollision target = new FieldMethodNameCollision(\"field-value\");\n            NativeJavaObject wrapped = new NativeJavaObject(\n                    scope,\n                    target,\n                    FieldMethodNameCollision.class);\n\n            Object fieldAndMethods = wrapped.get(\"value\", wrapped);\n            assertThat(fieldAndMethods).isInstanceOf(Scriptable.class);\n\n            Object defaultValue = ((Scriptable) fieldAndMethods).getDefaultValue(String.class);\n\n            assertThat(defaultValue).isEqualTo(\"field-value\");\n        } finally {\n            Context.exit();\n        }\n    }\n\n    public static final class FieldMethodNameCollision {\n        public String value;\n\n        public FieldMethodNameCollision(String value) {\n            this.value = value;\n        }\n\n        public String value() {\n            return \"method-value\";\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1435, "output": 1146, "cacheRead": 18944, "cacheWrite": 0, "totalTokens": 21525, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778037315408, "responseId": "resp_0f3e6a007f1d17150169fab243e6748190ba45745687b132fb"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_A3BS6FCB8MuDqE7naNy23FsQ|fc_0f3e6a007f1d17150169fab24de5c88190aa0c8ed6bb676c22", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1669 bytes to tests/src/net.sourceforge.htmlunit/htmlunit-core-js/2.70