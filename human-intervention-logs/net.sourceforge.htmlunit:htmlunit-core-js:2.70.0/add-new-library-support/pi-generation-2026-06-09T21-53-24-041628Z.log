        } finally {\n            Context.exit();\n        }\n    }\n\n    @Test\n    void roundTripsWrappedJavaAdapter() throws Exception {\n        try {\n            roundTripWrappedJavaAdapter();\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    private void roundTripWrappedJavaAdapter() throws Exception {\n        Context context = Context.enter();\n        try {\n            ScriptableObject scope = context.initStandardObjects();\n            Object adapterWrapper = createAdapterWrapper(context, scope);\n\n            NativeJavaObject copied = roundTrip(scope, (NativeJavaObject) adapterWrapper);\n\n            assertThat(copied.unwrap()).isInstanceOf(AdapterMarker.class);\n            AdapterMarker marker = (AdapterMarker) copied.unwrap();\n            assertThat(marker.label()).isEqualTo(\"adapter-label\");\n        } finally {\n            Context.exit();\n        }\n    }\n\n    private Object createAdapterWrapper(Context context, ScriptableObject scope) {\n        net.sourceforge.htmlunit.corejs.javascript.JavaAdapter.init(context, scope, false);\n        RecordingFunction labelFunction = new RecordingFunction(\"adapter-label\");\n        ScriptRuntime.setFunctionProtoAndParent(labelFunction, context, scope);\n        NativeObject implementation = new NativeObject();\n        ScriptRuntime.setObjectProtoAndParent(implementation, scope);\n        implementation.defineProperty(\"label\", labelFunction, ScriptableObject.EMPTY);\n\n        Object constructor = ScriptableObject.getProperty(scope, \"JavaAdapter\");\n        Object adapterWrapper =\n                Function.class\n                        .cast(constructor)\n                        .construct(\n                                context,\n                                scope,\n                                new Object[] {\n                                    new NativeJavaClass(scope, AdapterMarker.class),\n                                    implementation\n                                });\n\n        assertThat(adapterWrapper).isInstanceOf(Wrapper.class);\n        assertThat(((Wrapper) adapterWrapper).unwrap()).isInstanceOf(AdapterMarker.class);\n        return adapterWrapper;\n    }\n\n    private NativeJavaObject roundTrip(Scriptable scope, NativeJavaObject object) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ScriptableOutputStream output = new ScriptableOutputStream(bytes, scope)) {\n            output.writeObject(object);\n        }\n        try (ScriptableInputStream input =\n                new ScriptableInputStream(new ByteArrayInputStream(bytes.toByteArray()), scope)) {\n            return (NativeJavaObject) input.readObject();\n        }\n    }\n\n    public interface AdapterMarker {\n        String label();\n    }\n\n    public static final class DoubleValueProvider {\n        private final double value;\n\n        DoubleValueProvider(double value) {\n            this.value = value;\n        }\n\n        public Number doubleValue() {\n            return value;\n        }\n    }\n\n    public static final class SerializableBox implements Serializable {\n        private static final long serialVersionUID = 1L;\n\n        private final String name;\n        private final int count;\n\n        SerializableBox(String name, int count) {\n            this.name = name;\n            this.count = count;\n        }\n\n        public String name() {\n            return name;\n        }\n\n        public int count() {\n            return count;\n        }\n    }\n\n    private static final class RecordingFunction extends BaseFunction implements Serializable {\n        private static final long serialVersionUID = 1L;\n\n        private final String result;\n\n        private RecordingFunction(String result) {\n            this.result = result;\n        }\n\n        @Override\n     