  import net.sourceforge.htmlunit.corejs.javascript.Scriptable;
  import net.sourceforge.htmlunit.corejs.javascript.ScriptableObject;
  import org.junit.jupiter.api.Test;
  
  public class MemberBoxTest {
      @Test
      void roundTripsMethodFunctionAndInvokesDeserializedMember() throws Exception {
          Context context = Context.enter();
          try {
              Scriptable scope = context.initStandardObjects();
              Method method = MethodTarget.class.getMethod("combine", String.class, int.class);
              FunctionObject original = new FunctionObject("combine", method, scope);
  
              FunctionObject copied = roundTrip(original);
              Object result = copied.call(context, scope, scope, new Object[] {"item", 7});
  
              assertThat(result).isEqualTo("item:7");
              assertThat(copied.getMethodOrConstructor()).isEqualTo(method);
          } finally {
              Context.exit();
          }
      }
  
      @Test
      void roundTripsConstructorFunctionAndConstructsDeserializedMember() throws Exception {
          Context context = Context.enter();
          try {
              Scriptable scope = context.initStandardObjects();
              Constructor<ConstructedScriptable> constructor =
                      ConstructedScriptable.class.getConstructor(String.class);
              FunctionObject original =
                      new FunctionObject("ConstructedScriptable", constructor, scope);
  
              FunctionObject copied = roundTrip(original);
              Scriptable constructed = copied.construct(context, scope, new Object[] {"created"});
  
              assertThat(constructed).isInstanceOf(ConstructedScriptable.class);
              assertThat(((ConstructedScriptable) constructed).value()).isEqualTo("created");
              assertThat(copied.getMethodOrConstructor()).isEqualTo(constructor);
          } finally {
              Context.exit();
          }
      }
  
      @Test
      void invokesPublicInterfaceMethodDeclaredByNonPublicReceiver() throws Exception {
          Context context = Context.enter();
          try {
              Scriptable scope = context.initStandardObjects();
              HiddenInterfaceReceiver receiver = new HiddenInterfaceReceiver("interface");
              Method method =
                      HiddenInterfaceReceiver.class.getDeclaredMethod(
                              "interfaceValue", String.class);
              FunctionObject function = new FunctionObject("interfaceValue", method, scope);
  
              Object result = function.call(context, scope, receiver, new Object[] {"method"});
  
              assertThat(result).isEqualTo("interface-method");
          } finally {
              Context.exit();
          }
      }
  
      @Test
      void invokesPublicSuperclassMethodDeclaredByNonPublicReceiver() throws Exception {
          Context context = Context.enter();
          try {
              Scriptable scope = context.initStandardObjects();
              HiddenSuperclassReceiver receiver = new HiddenSuperclassReceiver("superclass");
              Method method =
                      HiddenSuperclassReceiver.class.getDeclaredMethod(
                              "superclassValue", String.class);
              FunctionObject function = new FunctionObject("superclassValue", method, scope);
  
              Object result = function.call(context, scope, receiver, new Object[] {"method"});
  
              assertThat(result).isEqualTo("superclass-method");
          } finally {
              Context.exit();
          }
      }
  
      @Test
      void constructsNonPublicScriptableAfterMakingConstructorAccessible() throws Exception {
          Context context = Context.enter();
          try {
              Scriptable scope = context.initStandardObjects();
              Constructor<HiddenConstructedScriptable> constructor =
                      HiddenConstructedScriptable.class.getDeclaredConstructor(String.class);
              FunctionObject function =
                      new FunctionObject("HiddenConstructedScriptable", constructor, scope);
  
              Scriptable constructed = function.construct(context, scope, new Object[] {"hidden"});
  
              assertThat(constructed).isInstanceOf(HiddenConstructedScriptable.class);
              assertThat(((HiddenConstructedScriptable) constructed).value()).isEqualTo("hidden");
          } finally {
              Context.exit();
          }
      }
  
      private FunctionObject roundTrip(FunctionObject functionObject) throws Exception {
          functionObject.setParentScope(null);
          functionObject.setPrototype(null);
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {
              output.writeObject(functionObject);
          }
          try (ObjectInputStream input =
                  new ObjectInputStream(new ByteArrayInputStream(bytes.toByteArray()))) {
              return (FunctionObject) input.readObject();
          }
      }
  
      public static final class MethodTarget {
          private MethodTarget() {}
  
          public static String combine(String prefix, int value) {
              return prefix + ':' + value;
          }
      }
  
      public static class ConstructedScriptable extends ScriptableObject {
          private static final long serialVersionUID = 1L;
  
          private final String value;
  
          public ConstructedScriptable(String value) {
              this.value = value;
          }
  
          @Override
          public String getClassName() {
              return "ConstructedScriptable";
          }
  
          String value() {
              return value;
          }
      }
  
      public interface InterfaceReceiver {
          String interfaceValue(String suffix);
      }
  
      private static final class HiddenInterfaceReceiver extends ScriptableObject
              implements InterfaceReceiver {
          private static final long serialVersionUID = 1L;
  
          private final String value;
  
          private HiddenInterfaceReceiver(String value) {
              this.value = value;
          }
  
          @Override
          public String getClassName() {
              return "HiddenInterfaceReceiver";
          }
  
          @Override
          public String interfaceValue(String suffix) {
              return value + '-' + suffix;
          }
      }
  
      public static class SuperclassReceiver extends ScriptableObject {
          private static final long serialVersionUID = 1L;
  
          protected final String value;
  
          public SuperclassReceiver(String value) {
              this.value = value;
          }
  
          @Override
          public String getClassName() {
              return "SuperclassReceiver";
          }
  
          public String superclassValue(String suffix) {
              return value + '-' + suffix;
          }
      }
  
      private static final class HiddenSuperclassReceiver extends SuperclassReceiver {
          private static final long serialVersionUID = 1L;
  
          private HiddenSuperclassReceiver(String value) {
              super(value);
          }
  
          @Override
          public String superclassValue(String suffix) {
              return value + '-' + suffix;
          }
      }
  
      private static final class HiddenConstructedScriptable extends ScriptableObject {
          private static final long serialVersionUID = 1L;
  
          private final String value;
  
          public HiddenConstructedScriptable(String value) {
              this.value = value;
          }
  
          @Override
          public String getClassName() {
              return "HiddenConstructedScriptable";
          }
  
          String value() {
              return value;
          }
      }
  }
