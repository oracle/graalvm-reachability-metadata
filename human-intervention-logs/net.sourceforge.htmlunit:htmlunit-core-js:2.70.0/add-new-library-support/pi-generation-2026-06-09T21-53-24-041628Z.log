rt net.sourceforge.htmlunit.corejs.javascript.Wrapper;\nimport net.sourceforge.htmlunit.corejs.javascript.serialize.ScriptableInputStream;\nimport net.sourceforge.htmlunit.corejs.javascript.serialize.ScriptableOutputStream;\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\n\npublic class NativeJavaObjectTest {\n    @Test\n    void convertsNativeArrayToJavaArray() {\n        Context context = Context.enter();\n        try {\n            ScriptableObject scope = context.initStandardObjects();\n            NativeArray array = new NativeArray(new Object[] {\"alpha\", \"beta\"});\n            ScriptRuntime.setObjectProtoAndParent(array, scope);\n\n            Object converted = Context.jsToJava(array, String[].class);\n\n            assertThat(converted).isInstanceOf(String[].class);\n            assertThat((String[]) converted).containsExactly(\"alpha\", \"beta\");\n        } finally {\n            Context.exit();\n        }\n    }\n\n    @Test\n    void convertsJavaObjectWithDoubleValueMethodToPrimitiveDouble() {\n        Object converted = Context.jsToJava(new DoubleValueProvider(12.5), Double.TYPE);\n\n        assertThat(converted).isEqualTo(12.5);\n    }\n\n    @Test\n    void roundTripsWrappedSerializableJavaObject() throws Exception {\n        Context context = Context.enter();\n        try {\n            ScriptableObject scope = context.initStandardObjects();\n            NativeJavaObject original =\n                    new NativeJavaObject(\n                            scope,\n                            new SerializableBox(\"wrapped\", 42),\n                            SerializableBox.class);\n\n            NativeJavaObject copied = roundTrip(scope, original);\n\n            assertThat(copied.unwrap()).isInstanceOf(SerializableBox.class);\n            SerializableBox box = (SerializableBox) copied.unwrap();\n            assertThat(box.name()).isEqualTo(\"wrapped\");\n            assertThat(box.count()).isEqualTo(42);\n        } finally {\n            Context.exit();\n        }\n    }\n\n    @Test\n    void roundTripsWrappedJavaAdapter() throws Exception {\n        try {\n            roundTripWrappedJavaAdapter();\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    private void roundTripWrappedJavaAdapter() throws Exception {\n        Context context = Context.enter();\n        try {\n            ScriptableObject scope = context.initStandardObjects();\n            Object adapterWrapper = createAdapterWrapper(context, scope);\n\n            NativeJavaObject copied = roundTrip(scope, (NativeJavaObject) adapterWrapper);\n\n            assertThat(copied.unwrap()).isInstanceOf(AdapterMarker.class);\n            AdapterMarker marker = (AdapterMarker) copied.unwrap();\n            assertThat(marker.label()).isEqualTo(\"adapter-label\");\n        } finally {\n            Context.exit();\n        }\n    }\n\n    private Object createAdapterWrapper(Context context, ScriptableObject scope) {\n        net.sourceforge.htmlunit.corejs.javascript.JavaAdapter.init(context, scope, false);\n        RecordingFunction labelFunction = new RecordingFunction(\"adapter-label\");\n        ScriptRuntime.setFunctionProtoAndParent(labelFunction, context, scope);\n        NativeObject implementation = new NativeObject();\n        ScriptRuntime.setObjectProtoAndParent(implementation, scope);\n        implementation.defineProperty(\"label\", labelFunction, ScriptableObject.EMPTY);\n\n        Object constructor = ScriptableObject.getProperty(scope, \"JavaAdapter\");\n        Object adapterWrapper =\n                Function.class\n                        .cast(constructor)\n                        .construct(\n                                context,\n                                scope,\n                                new Object[] {\n                                    new NativeJavaClass(scope, AdapterMarker.class),\n                                    implementation\n                                });\n\n        assertThat(adapterWrapper).isInstanceOf(Wrapper.class);\n        assertThat(((Wrapper) adapterWrapper).unwrap()).isInstanceOf(AdapterMarker.class);\n        return adapterWrapper;\n    }\n\n    private NativeJavaObject roundTrip(Scriptable scope, NativeJavaObject object) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ScriptableOutputStream output = new ScriptableOutputStream(bytes, scope)) {\n            output.writeObject(object);\n        }\n        try (ScriptableInputStream input =\n                new ScriptableInputStream(new ByteArrayInputStream(bytes.toByteArray()), scope)) {\n            return (NativeJavaObject) input.readObject();\n        }\n    }\n\n    public interface AdapterMarker {\n        String label();\n    }\n\n    public static final class DoubleValueProvider {\n        private final double value;\n\n        DoubleValueProvider(double value) {\n            this.value = value;\n        }\n\n        public Number doubleValue() {\n            return value;\n        }\n    }\n\n    public static final class SerializableBox implements Serializable {\n        private static final long serialVersionUID = 1L;\n\n        private final String name;\n        private final int count;\n\n        SerializableBox(String name, int count) {\n            this.name = name;\n            this.count = count;\n        }\n\n        public String name() {\n            return name;\n        }\n\n        public int count() {\n            return count;\n        }\n    }\n\n    private static final class RecordingFunction extends BaseFunction implements Serializable {\n        private static final long serialVersionUID = 1L;\n\n        private final String result;\n\n        private RecordingFunction(String result) {\n            this.result = result;\n        }\n\n        @Override\n        public Object call(\n                Context context,\n                Scriptable scope,\n                Scriptable thisObj,\n                Object[] args) {\n            return result;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 2426, "output": 2080, "cacheRead": 46592, "cacheWrite": 0, "totalTokens": 51098, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1781041871997, "responseId": "resp_06839f67e7eb56ea016a288ad09a488196916929277547a3af"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_3M1f4HWHlArKqLEekGto6pNe|fc_06839f67e7eb56ea016a288ae402ec8196a5ee8327a83d401a", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 7081 bytes to tests/src/net.sourceforge.htmlunit/htmlunit-core-js/2.70.0/src/test/java/net_sourceforge_htmlunit/htmlunit_core_js/NativeJavaObjectTest.java"}], "isError": false, "timestamp": 1781041916791}]}
