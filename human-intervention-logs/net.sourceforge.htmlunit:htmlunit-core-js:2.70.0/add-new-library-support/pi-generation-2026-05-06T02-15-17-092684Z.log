  package net_sourceforge_htmlunit.htmlunit_core_js;
  
  import java.nio.file.Files;
  import java.nio.file.Path;
  
  import net.sourceforge.htmlunit.corejs.javascript.CompilerEnvirons;
  import net.sourceforge.htmlunit.corejs.javascript.Context;
  import net.sourceforge.htmlunit.corejs.javascript.ScriptableObject;
  import net.sourceforge.htmlunit.corejs.javascript.SecurityController;
  import net.sourceforge.htmlunit.corejs.javascript.optimizer.ClassCompiler;
  import net.sourceforge.htmlunit.corejs.javascript.tools.shell.Global;
  import net.sourceforge.htmlunit.corejs.javascript.tools.shell.Main;
  
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.MethodOrderer;
  import org.junit.jupiter.api.Order;
  import org.junit.jupiter.api.Test;
  import org.junit.jupiter.api.TestMethodOrder;
  import org.junit.jupiter.api.io.TempDir;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  @TestMethodOrder(MethodOrderer.OrderAnnotation.class)
  public class MainTest {
      private static final String COMPILED_SCRIPT_CLASS_NAME = "HtmlUnitCoreJsShellCompiledScript";
      private static final String COMPILED_SCRIPT_RESULT = "shellCompiledClassResult";
  
      @TempDir
      Path tempDir;
  
      @Test
      @Order(1)
      void processFileExecutesCompiledScriptClass() throws Exception {
          try {
              processGeneratedCompiledScriptClass();
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
      }
  
      @Test
      @Order(2)
      void mainInitializesJavaPolicySecurityWhenRequested() {
          String previous = System.getProperty("rhino.use_java_policy_security");
          System.setProperty("rhino.use_java_policy_security", "true");
          try {
              Main.main(new String[] {"-e", "1;"});
  
              assertThat(SecurityController.hasGlobal()).isTrue();
          } finally {
              if (previous == null) {
                  System.clearProperty("rhino.use_java_policy_security");
              } else {
                  System.setProperty("rhino.use_java_policy_security", previous);
              }
          }
      }
  
      private void processGeneratedCompiledScriptClass() throws Exception {
          Context context = Context.enter();
          try {
              Global global = new Global(context);
              Path compiledClassFile = tempDir.resolve(COMPILED_SCRIPT_CLASS_NAME + ".class");
              Files.write(compiledClassFile, compileScriptClass(context));
  
              Main.processFile(context, global, compiledClassFile.toUri().toURL().toExternalForm());
  
              assertThat(ScriptableObject.getProperty(global, COMPILED_SCRIPT_RESULT))
                      .isEqualTo("executed");
          } finally {
              Context.exit();
          }
      }
  
      private static byte[] compileScriptClass(Context context) {
          CompilerEnvirons compilerEnvirons = new CompilerEnvirons();
          compilerEnvirons.initFromContext(context);
          ClassCompiler compiler = new ClassCompiler(compilerEnvirons);
          Object[] compiled = compiler.compileToClassFiles(
                  "var " + COMPILED_SCRIPT_RESULT + " = 'executed';",
                  COMPILED_SCRIPT_CLASS_NAME + ".js",
                  1,
                  COMPILED_SCRIPT_CLASS_NAME);
  
          assertThat(compiled[0]).isEqualTo(COMPILED_SCRIPT_CLASS_NAME);
          return (byte[]) compiled[1];
      }
  }
