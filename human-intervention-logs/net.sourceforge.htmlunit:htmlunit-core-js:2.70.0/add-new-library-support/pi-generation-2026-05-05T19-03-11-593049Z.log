ge.htmlunit.corejs.javascript.JavaAdapter;\nimport net.sourceforge.htmlunit.corejs.javascript.NativeObject;\nimport net.sourceforge.htmlunit.corejs.javascript.ObjToIntMap;\nimport net.sourceforge.htmlunit.corejs.javascript.Scriptable;\nimport net.sourceforge.htmlunit.corejs.javascript.ScriptableObject;\nimport net.sourceforge.htmlunit.corejs.javascript.Wrapper;\n\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\nimport static org.assertj.core.api.Assertions.assertThatThrownBy;\n\npublic class JavaAdapterTest {\n    @Test\n    void createsRunnableAdapterFromJavaScriptImplementation() {\n        try {\n            Context context = Context.enter();\n            try {\n                Scriptable scope = context.initStandardObjects();\n                Object result = context.evaluateString(scope, \"\"\"\n                        new JavaAdapter(java.lang.Runnable, {\n                            run: function() {\n                                java.lang.System.setProperty('htmlunit.javaAdapter.run', 'called');\n                            },\n                            toString: function() {\n                                return 'scripted-runnable';\n                            }\n                        });\n                        \"\"\", \"java-adapter-create-test\", 1, null);\n\n                Object adapter = unwrap(result);\n                assertThat(adapter).isInstanceOf(Runnable.class);\n\n                ((Runnable) adapter).run();\n                assertThat(System.getProperty(\"htmlunit.javaAdapter.run\")).isEqualTo(\"called\");\n                Object self = JavaAdapter.getAdapterSelf(adapter.getClass(), adapter);\n                assertThat(self).isInstanceOf(Scriptable.class);\n            } finally {\n                Context.exit();\n                System.clearProperty(\"htmlunit.javaAdapter.run\");\n            }\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        } catch (ReflectiveOperationException exception) {\n            throw new AssertionError(exception);\n        }\n    }\n\n    @Test\n    void serializesAndDeserializesGeneratedAdapterDescriptor() throws Exception {\n        try {\n            Context context = Context.enter();\n            try {\n                Scriptable scope = context.initStandardObjects();\n                Object adapter = createEmptyRunnableAdapter(context, scope);\n\n                assertThatThrownBy(() -> serializeAdapterDescriptor(adapter))\n                        .isInstanceOf(IOException.class);\n\n                byte[] descriptor = createAdapterDescriptor(new NativeObject());\n                Object restored = deserializeAdapterDescriptor(scope, descriptor);\n\n                assertThat(restored).isInstanceOf(Runnable.class);\n                Object self = JavaAdapter.getAdapterSelf(restored.getClass(), restored);\n                assertThat(self).isSameAs(scope);\n            } finally {\n                Context.exit();\n            }\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    @Test\n    void generatesAdapterBytecodeForSuperclassAndInterfaceMethods() {\n        ObjToIntMap functionNames = new ObjToIntMap();\n        functionNames.put(\"get\", 1);\n        functionNames.put(\"size\", 0);\n        functionNames.put(\"run\", 0);\n        functionNames.put(\"scriptOnlyFunction\", 2);\n\n        byte[] bytecode = JavaAdapter.createAdapterCode(\n                functionNames,\n                \"HtmlUnitCoreJsJavaAdapterCoverage\",\n                AbstractList.class,\n                new Class<?>[] {Runnable.class, List.class},\n                null);\n\n        assertThat(bytecode).isNotEmpty();\n    }\n\n    private static Object createEmptyRunnableAdapter(Context context, Scriptable scope) {\n        NativeObject delegee = new NativeObject();\n        delegee.setParentScope(scope);\n        delegee.setPrototype(ScriptableObject.getObjectPrototype(scope));\n        ScriptableObject.putProperty(scope, \"delegee\", delegee);\n\n        Object result = context.evaluateString(scope, \"\"\"\n                new JavaAdapter(java.lang.Runnable, delegee);\n                \"\"\", \"java-adapter-serialization-test\", 1, null);\n        Object adapter = unwrap(result);\n        assertThat(adapter).isInstanceOf(Runnable.class);\n        return adapter;\n    }\n\n    private static byte[] serializeAdapterDescriptor(Object adapter) throws IOException {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            JavaAdapter.writeAdapterObject(adapter, output);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static byte[] createAdapterDescriptor(Scriptable delegee) throws IOException {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(Object.class.getName());\n            output.writeObject(new String[] {Runnable.class.getName()});\n            output.writeObject(delegee);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static Object deserializeAdapterDescriptor(Scriptable self, byte[] descriptor)\n            throws IOException, ClassNotFoundException {\n        ByteArrayInputStream bytes = new ByteArrayInputStream(descriptor);\n        try (ObjectInputStream input = new ObjectInputStream(bytes)) {\n            return JavaAdapter.readAdapterObject(self, input);\n        }\n    }\n\n    private static Object unwrap(Object value) {\n        if (value instanceof Wrapper wrapper) {\n            return wrapper.unwrap();\n        }\n        return value;\