          return getGlobal().getIn();
      }
  
      public static void setIn(InputStream in) {
          getGlobal().setIn(in);
      }
  
      public static PrintStream getOut() {
          return getGlobal().getOut();
      }
  
      public static void setOut(PrintStream out) {
          getGlobal().setOut(out);
      }
  
  
