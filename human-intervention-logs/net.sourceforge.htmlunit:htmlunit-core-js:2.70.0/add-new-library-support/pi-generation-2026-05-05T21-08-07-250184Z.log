[tool-call] delta {"path":"tests/src/net.sourceforge.htmlunit/htmlunit-core-js/2.70.0/src/test/java/net_sourceforge_htmlunit/htmlunit_core_js/JavaMembersTest.java","edits":[{"oldText":"import java.net.URL;\nimport java.net.URLClassLoader;\nimport java.security.Permission;\n","newText":"import java.security.Permission;\nimport java.util.Base64;\n"},{"oldText":"        boolean securityManagerInstalled = installSecurityManagerIfSupported(securityManager);\n        try (URLClassLoader classLoader = newIsolatedTestClassLoader()) {\n            Context context = Context.enter();\n            try {\n                Scriptable scope = context.initStandardObjects();\n                Class<?> loadedHolderClass = Class.forName(\n                        PublicFallbackMethodHolder.class.getName(),\n                        true,\n                        classLoader);\n\n                securityManager.setDenyDeclaredMemberAccess(securityManagerInstalled);\n                NativeJavaObject wrapped = new NativeJavaObject(\n                        scope,\n                        null,\n                        loadedHolderClass,\n                        true);\n                securityManager.setDenyDeclaredMemberAccess(false);\n\n                assertThat(wrapped.has(\"value\", wrapped)).isTrue();\n            } finally {\n                securityManager.setDenyDeclaredMemberAccess(false);\n                Context.exit();\n            }\n        } finally {\n            if (securityManagerInstalled) {\n                System.setSecurityManager(previousSecurityManager);\n            }\n        }\n    }\n\n    private static URLClassLoader newIsolatedTestClassLoader() {\n        URL testClassesLocation = JavaMembersTest.class\n                .getProtectionDomain()\n                .getCodeSource()\n                .getLocation();\n        return new URLClassLoader(new URL[] {testClassesLocation}, null);\n    }\n","newText":"        boolean securityManagerInstalled = installSecurityManagerIfSupported(securityManager);\n        try {\n            Class<?> loadedHolderClass = new ByteArrayClassLoader().define(\n                    PublicFallbackMethodHolder.class.getName(),\n                    Base64.getMimeDecoder().decode(PUBLIC_FALLBACK_METHOD_HOLDER_CLASS));\n\n            Context context = Context.enter();\n            try {\n                Scriptable scope = context.initStandardObjects();\n\n                securityManager.setDenyDeclaredMemberAccess(securityManagerInstalled);\n                NativeJavaObject wrapped = new NativeJavaObject(\n                        scope,\n                        null,\n                        loadedHolderClass,\n                        true);\n                securityManager.setDenyDeclaredMemberAccess(false);\n\n                assertThat(wrapped.has(\"value\", wrapped)).isTrue();\n            } finally {\n                securityManager.setDenyDeclaredMemberAccess(false);\n                Context.exit();\n            }\n        } finally {\n            if (securityManagerInstalled) {\n                System.setSecurityManager(previousSecurityManager);\n            }\n        }\n    }\n"}]}
