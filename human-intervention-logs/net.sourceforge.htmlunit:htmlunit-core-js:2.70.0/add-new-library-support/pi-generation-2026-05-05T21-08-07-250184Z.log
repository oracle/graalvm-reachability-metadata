      19	public class JavaMembersTest {
      20	    private static final ContextFactory.GlobalSetter GLOBAL_SETTER =
      21	            ContextFactory.getGlobalSetter();
      22	
      23	    @Test
      24	    void readsAndWritesPublicJavaFieldsThroughWrappedObject() {
      25	        Context context = Context.enter();
      26	        try {
      27	            Scriptable scope = context.initStandardObjects();
      28	            PublicFieldHolder holder = new PublicFieldHolder("initial", 3);
      29	            NativeJavaObject wrapped = new NativeJavaObject(scope, holder, PublicFieldHolder.class);
      30	
      31	            Object initialLabel = wrapped.get("label", wrapped);
      32	            wrapped.put("count", wrapped, 9);
      33	            Object updatedCount = wrapped.get("count", wrapped);
      34	
      35	            assertThat(unwrap(initialLabel)).isEqualTo("initial");
      36	            assertThat(unwrap(updatedCount)).isEqualTo(9);
      37	            assertThat(holder.count).isEqualTo(9);
      38	        } finally {
      39	            Context.exit();
      40	        }
      41	    }
      42	
      43	    @Test
      44	    void enhancedJavaAccessReflectsDeclaredInterfaceConstructors() {
      45	        ContextFactory originalFactory = GLOBAL_SETTER.getContextFactoryGlobal();
      46	        GLOBAL_SETTER.setContextFactoryGlobal(new EnhancedJavaAccessContextFactory());
      47	        try {
      48	            Context context = Context.enter();
      49	            try {
      50	                Scriptable scope = context.initStandardObjects();
      51	                NativeJavaObject wrapped = new NativeJavaObject(
      52	                        scope,
      53	                        null,
      54	                        DeclaredConstructorTarget.class);
      55	
      56	                assertThat(wrapped.has("hiddenValue", wrapped)).isTrue();
      57	            } finally {
      58	                Context.exit();
      59	            }
      60	        } finally {
      61	            GLOBAL_SETTER.setContextFactoryGlobal(originalFactory);
      62	        }
      63	    }
      64	
