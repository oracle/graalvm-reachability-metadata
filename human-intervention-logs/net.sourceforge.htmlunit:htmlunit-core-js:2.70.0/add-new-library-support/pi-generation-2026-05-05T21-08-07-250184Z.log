      67	            return wrapper.unwrap();
      68	        }
      69	        return value;
      70	    }
      71	
      72	    public static final class PublicFieldHolder {
      73	        public String label;
      74	        public int count;
      75	
      76	        public PublicFieldHolder(String label, int count) {
      77	            this.label = label;
      78	            this.count = count;
      79	        }
      80	
      81	        public String labelSummary() {
      82	            return label + ':' + count;
      83	        }
      84	    }
      85	
      86	    public interface DeclaredConstructorTarget {
      87	        String getHiddenValue();
      88	    }
      89	
