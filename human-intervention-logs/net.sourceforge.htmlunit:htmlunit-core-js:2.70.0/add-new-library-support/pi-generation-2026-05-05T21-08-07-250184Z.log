     320	                                    MethodSignature sig = new MethodSignature(method);
     321	                                    if (!map.containsKey(sig)) {
     322	                                        if (includePrivate && !method.isAccessible())
     323	                                            method.setAccessible(true);
     324	                                        map.put(sig, method);
     325	                                    }
     326	                                }
     327	                            }
     328	                            Class<?>[] interfaces = clazz.getInterfaces();
     329	                            for (Class<?> intface : interfaces) {
