[tool-call] delta {"path":"tests/src/net.sourceforge.htmlunit/htmlunit-core-js/2.70.0/src/test/java/net_sourceforge_htmlunit/htmlunit_core_js/ScriptRuntimeTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage net_sourceforge_htmlunit.htmlunit_core_js;\n\nimport net.sourceforge.htmlunit.corejs.javascript.Context;\nimport net.sourceforge.htmlunit.corejs.javascript.ScriptRuntime;\nimport net.sourceforge.htmlunit.corejs.javascript.ScriptableObject;\nimport net.sourceforge.htmlunit.corejs.javascript.tools.shell.Global;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ScriptRuntimeTest {\n    @Test\n    void createsShellGlobalThroughRuntimeLookup() {\n        Context cx = Context.enter();\n        try {\n            ScriptableObject global = ScriptRuntime.getGlobal(cx);\n\n            assertThat(global).isInstanceOf(Global.class);\n            assertThat(((Global) global).isInitialized()).isTrue();\n            assertThat(ScriptableObject.getProperty(global, \"print\")).isNotSameAs(ScriptableObject.NOT_FOUND);\n        } finally {\n            Context.exit();\n        }\n    }\n}\n"}
