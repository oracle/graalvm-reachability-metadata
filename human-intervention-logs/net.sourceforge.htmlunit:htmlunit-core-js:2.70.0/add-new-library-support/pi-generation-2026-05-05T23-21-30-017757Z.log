t;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ScriptableObjectTest {\n    @Test\n    void invokesSingleArgumentInitWhenDefiningScriptableClass() throws Exception {\n        Context.enter();\n        try {\n            Scriptable scope = Context.getCurrentContext().initStandardObjects();\n\n            ScriptableObject.defineClass(\n                    scope,\n                    SingleArgumentInitScriptable.class);\n\n            assertThat(ScriptableObject.getProperty(scope, \"singleArgumentInit\"))\n                    .isEqualTo(\"called\");\n        } finally {\n            Context.exit();\n        }\n    }\n\n    @Test\n    void definesClassByConstructingPrototypeAndRunningFinishInit() throws Exception {\n        Context context = Context.enter();\n        try {\n            if (NativeImageSupport.isNativeImageRuntime()) {\n                context.setOptimizationLevel(-1);\n            }\n            Scriptable scope = context.initStandardObjects();\n\n            String className = ScriptableObject.defineClass(\n                    scope,\n                    FinishInitScriptable.class,\n                    false,\n                    false);\n            Object result = context.evaluateString(scope, \"\"\"\n                    var sample = new FinishInitScriptable();\n                    FinishInitScriptable.finished + ':' + sample.echo('value') + ':'\n                            + sample.marker + ':' + sample.fromFinish;\n                    \"\"\", \"scriptable-object-define-class-test\", 1, null);\n\n            assertThat(className).isEqualTo(\"FinishInitScriptable\");\n            assertThat(Context.toString(result)).isEqualTo(\"true:echo:value:marker:done\");\n        } finally {\n            Context.exit();\n        }\n    }\n\n    @Test\n    void serializesAndDeserializesScriptableObjectSlots() throws Exception {\n        SerializableScriptable original = new SerializableScriptable();\n        ScriptableObject.putProperty(original, \"name\", \"Ada\");\n        ScriptableObject.putProperty(original, \"count\", 3);\n\n        SerializableScriptable restored = roundTrip(original);\n\n        assertThat(restored.getClassName()).isEqualTo(\"SerializableScriptable\");\n        assertThat(ScriptableObject.getProperty(restored, \"name\")).isEqualTo(\"Ada\");\n        assertThat(ScriptableObject.getProperty(restored, \"count\")).isEqualTo(3);\n    }\n\n    private static SerializableScriptable roundTrip(SerializableScriptable scriptable)\n            throws IOException, ClassNotFoundException {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(scriptable);\n        }\n\n        try (ObjectInputStream input = new ObjectInputStream(\n                new ByteArrayInputStream(bytes.toByteArray()))) {\n            return (SerializableScriptable) input.readObject();\n        }\n    }\n\n    public static class SingleArgumentInitScriptable extends ScriptableObject {\n        private static final long serialVersionUID = 1L;\n\n        public SingleArgumentInitScriptable() {\n        }\n\n        public static void init(Scriptable scope) {\n            ScriptableObject.putProperty(scope, \"singleArgumentInit\", \"called\");\n        }\n\n        @Override\n        public String getClassName() {\n            return \"SingleArgumentInitScriptable\";\n        }\n    }\n\n    public static class FinishInitScriptable extends ScriptableObject {\n        private static final long serialVersionUID = 1L;\n\n        public FinishInitScriptable() {\n        }\n\n        @Override\n        public String getClassName() {\n            return \"FinishInitScriptable\";\n        }\n\n        public String jsFunction_echo(String value) {\n            return \"echo:\" + value;\n        }\n\n        public String jsGet_marker() {\n            return \"marker\";\n        }\n\n        public static void finishInit(Scriptable scope, FunctionObject constructor,\n                Scriptable prototype) {\n            ScriptableObject.putProperty(constructor, \"finished\", Boolean.TRUE);\n            ScriptableObject.putProperty(prototype, \"fromFinish\", \"done\");\n        }\n    }\n\n    public static class SerializableScriptable extends ScriptableObject {\n        private static final long serialVersionUID = 1L;\n\n        public SerializableScriptable() {\n        }\n\n        @Override\n        public String getClassName() {\n            return \"SerializableScriptable\";\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778023204476}]}
