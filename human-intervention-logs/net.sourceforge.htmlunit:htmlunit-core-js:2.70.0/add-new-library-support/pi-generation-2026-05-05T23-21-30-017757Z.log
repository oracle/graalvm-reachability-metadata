  package net_sourceforge_htmlunit.htmlunit_core_js;
  
  import java.security.Permission;
  import java.util.Base64;
  
  import net.sourceforge.htmlunit.corejs.javascript.Context;
  import net.sourceforge.htmlunit.corejs.javascript.ContextFactory;
  import net.sourceforge.htmlunit.corejs.javascript.NativeJavaObject;
  import net.sourceforge.htmlunit.corejs.javascript.Scriptable;
  import net.sourceforge.htmlunit.corejs.javascript.Wrapper;
  
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class JavaMembersTest {
      private static final ContextFactory.GlobalSetter GLOBAL_SETTER =
              ContextFactory.getGlobalSetter();
  
      @Test
      void readsAndWritesPublicJavaFieldsThroughWrappedObject() {
          Context context = Context.enter();
          try {
              Scriptable scope = context.initStandardObjects();
              PublicFieldHolder holder = new PublicFieldHolder("initial", 3);
              NativeJavaObject wrapped = new NativeJavaObject(
                      scope,
                      holder,
                      PublicFieldHolder.class);
  
              Object initialLabel = wrapped.get("label", wrapped);
              wrapped.put("count", wrapped, 9);
              Object updatedCount = wrapped.get("count", wrapped);
  
              assertThat(unwrap(initialLabel)).isEqualTo("initial");
              assertThat(unwrap(updatedCount)).isEqualTo(9);
              assertThat(holder.count).isEqualTo(9);
          } finally {
              Context.exit();
          }
      }
  
      @Test
      void fallsBackToPublicMethodsWhenDeclaredMethodAccessIsDenied() throws Exception {
          try {
              runDeclaredMethodAccessDeniedFallback();
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
      }
  
      @Test
      void enhancedJavaAccessReflectsDeclaredInterfaceConstructors() {
          ContextFactory originalFactory = GLOBAL_SETTER.getContextFactoryGlobal();
          GLOBAL_SETTER.setContextFactoryGlobal(new EnhancedJavaAccessContextFactory());
          try {
              Context context = Context.enter();
              try {
                  Scriptable scope = context.initStandardObjects();
                  NativeJavaObject wrapped = new NativeJavaObject(
                          scope,
                          null,
                          DeclaredConstructorTarget.class);
  
                  assertThat(wrapped.has("hiddenValue", wrapped)).isTrue();
              } finally {
                  Context.exit();
              }
          } finally {
              GLOBAL_SETTER.setContextFactoryGlobal(originalFactory);
          }
      }
  
      @SuppressWarnings("removal")
      private static void runDeclaredMethodAccessDeniedFallback() throws Exception {
          DeclaredMemberDenyingSecurityManager securityManager =
                  new DeclaredMemberDenyingSecurityManager();
          SecurityManager previousSecurityManager = System.getSecurityManager();
          boolean securityManagerInstalled = installSecurityManagerIfSupported(securityManager);
          try {
              Class<?> loadedHolderClass = new ByteArrayClassLoader().define(
                      "net_sourceforge_htmlunit.htmlunit_core_js.JavaMembersFallbackTarget",
                      Base64.getMimeDecoder().decode(PUBLIC_FALLBACK_METHOD_HOLDER_CLASS));
  
              Context context = Context.enter();
              try {
                  Scriptable scope = context.initStandardObjects();
  
                  securityManager.setDenyDeclaredMemberAccess(securityManagerInstalled);
                  NativeJavaObject wrapped = new NativeJavaObject(
                          scope,
                          null,
                          loadedHolderClass,
                          true);
                  securityManager.setDenyDeclaredMemberAccess(false);
  
                  assertThat(wrapped.has("value", wrapped)).isTrue();
              } finally {
                  securityManager.setDenyDeclaredMemberAccess(false);
                  Context.exit();
              }
          } finally {
              if (securityManagerInstalled) {
                  System.setSecurityManager(previousSecurityManager);
              }
          }
      }
  
      private static Object unwrap(Object value) {
          if (value instanceof Wrapper wrapper) {
              return wrapper.unwrap();
          }
          return value;
      }
  
      public static final class PublicFieldHolder {
          public String label;
          public int count;
  
          public PublicFieldHolder(String label, int count) {
              this.label = label;
              this.count = count;
          }
  
          public String labelSummary() {
              return label + ':' + count;
          }
      }
  
      private static final String PUBLIC_FALLBACK_METHOD_HOLDER_CLASS = """
              yv66vgAAADcAFAoAAgADBwAEDAAFAAYBABBqYXZhL2xhbmcvT2JqZWN0AQAGPGluaXQ+AQADKClW
              CQAIAAkHAAoMAAsADAEAQ25ldF9zb3VyY2Vmb3JnZV9odG1sdW5pdC9odG1sdW5pdF9jb3JlX2pz
              L0phdmFNZW1iZXJzRmFsbGJhY2tUYXJnZXQBAAV2YWx1ZQEAEkxqYXZhL2xhbmcvU3RyaW5nOwEA
              FShMamF2YS9sYW5nL1N0cmluZzspVgEABENvZGUBAA9MaW5lTnVtYmVyVGFibGUBAAhnZXRWYWx1
              ZQEAFCgpTGphdmEvbGFuZy9TdHJpbmc7AQAKU291cmNlRmlsZQEAHkphdmFNZW1iZXJzRmFsbGJh
              Y2tUYXJnZXQuamF2YQAxAAgAAgAAAAEAEgALAAwAAAACAAEABQANAAEADgAAACoAAgACAAAACiq3
              AAEqK7UAB7EAAAABAA8AAAAOAAMAAAAGAAQABwAJAAgAAQAQABEAAQAOAAAAHQABAAEAAAAFKrQA
              B7AAAAABAA8AAAAGAAEAAAALAAEAEgAAAAIAEw==
              """;
  
      public interface DeclaredConstructorTarget {
          String getHiddenValue();
      }
  
      @SuppressWarnings("removal")
      private static boolean installSecurityManagerIfSupported(SecurityManager securityManager) {
          try {
              System.setSecurityManager(securityManager);
              return System.getSecurityManager() == securityManager;
          } catch (UnsupportedOperationException | SecurityException exception) {
              return false;
          }
      }
  
      @SuppressWarnings("removal")
      private static final class DeclaredMemberDenyingSecurityManager extends SecurityManager {
          private boolean denyDeclaredMemberAccess;
  
          @Override
          public void checkPermission(Permission permission) {
              if (denyDeclaredMemberAccess
                      && permission instanceof RuntimePermission
                      && "accessDeclaredMembers".equals(permission.getName())) {
                  throw new SecurityException("declared member access denied for fallback test");
              }
          }
  
          void setDenyDeclaredMemberAccess(boolean denyDeclaredMemberAccess) {
              this.denyDeclaredMemberAccess = denyDeclaredMemberAccess;
          }
      }
  
      private static final class ByteArrayClassLoader extends ClassLoader {
          ByteArrayClassLoader() {
              super(null);
          }
  
          Class<?> define(String name, byte[] bytes) {
              return defineClass(name, bytes, 0, bytes.length);
          }
      }
  
      public static final class EnhancedJavaAccessContextFactory extends ContextFactory {
          @Override
          protected boolean hasFeature(Context context, int featureIndex) {
              if (featureIndex == Context.FEATURE_ENHANCED_JAVA_ACCESS) {
                  return true;
              }
              return super.hasFeature(context, featureIndex);
          }
      }
  }
