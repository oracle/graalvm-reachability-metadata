ean securityManagerInstalled = installSecurityManagerIfSupported(securityManager);\n            try {\n                securityManager.setDenyDeclaredMemberAccess(securityManagerInstalled);\n                scope.defineFunctionProperties(\n                        new String[] {\"publicFallbackFunction\"},\n                        PublicFallbackFunctions.class,\n                        ScriptableObject.DONTENUM);\n            } finally {\n                securityManager.setDenyDeclaredMemberAccess(false);\n                if (securityManagerInstalled) {\n                    System.setSecurityManager(previousSecurityManager);\n                }\n            }\n\n            Function function = (Function) ScriptableObject.getProperty(\n                    scope,\n                    \"publicFallbackFunction\");\n            Object result = function.call(\n                    context,\n                    scope,\n                    scope,\n                    new Object[] {\"value\"});\n\n            assertThat(Context.toString(result)).isEqualTo(\"fallback:value\");\n        } finally {\n            Context.exit();\n        }\n    }\n\n    @Test\n    void constructUsesDefaultConstructorForFunctionObjectsBackedByInstanceMethod()\n            throws Exception {\n        Context context = Context.enter();\n        try {\n            Scriptable scope = context.initStandardObjects();\n            String className = ScriptableObject.defineClass(\n                    scope,\n                    ConstructibleScriptable.class,\n                    false,\n                    false);\n\n            Function constructor = (Function) ScriptableObject.getProperty(\n                    scope,\n                    \"ConstructibleScriptable\");\n            Scriptable created = constructor.construct(\n                    context,\n                    scope,\n                    new Object[] {\"Ada\"});\n\n            assertThat(className).isEqualTo(\"ConstructibleScriptable\");\n            assertThat(created).isInstanceOf(ConstructibleScriptable.class);\n            assertThat(((ConstructibleScriptable) created).getName()).isEqualTo(\"Ada\");\n            assertThat(created.getPrototype()).isNotNull();\n            assertThat(created.getParentScope()).isSameAs(scope);\n        } finally {\n            Context.exit();\n        }\n    }\n\n    public static final class PublicFallbackFunctions {\n        private PublicFallbackFunctions() {\n        }\n\n        public static String publicFallbackFunction(String value) {\n            return \"fallback:\" + value;\n        }\n    }\n\n    public static class ConstructibleScriptable extends ScriptableObject {\n        private static final long serialVersionUID = 1L;\n\n        private String name;\n\n        public ConstructibleScriptable() {\n        }\n\n        @Override\n        public String getClassName() {\n            return \"ConstructibleScriptable\";\n        }\n\n        public void jsConstructor(String newName) {\n            name = newName;\n        }\n\n        public String getName() {\n            return name;\n        }\n    }\n\n    @SuppressWarnings(\"removal\")\n    private static boolean installSecurityManagerIfSupported(SecurityManager securityManager) {\n        try {\n            System.setSecurityManager(securityManager);\n            return System.getSecurityManager() == securityManager;\n        } catch (UnsupportedOperationException | SecurityException exception) {\n            return false;\n        }\n    }\n\n    @SuppressWarnings(\"removal\")\n    private static final class DeclaredMemberDenyingSecurityManager extends SecurityManager {\n        private boolean denyDeclaredMemberAccess;\n\n        @Override\n        public void checkPermission(Permission permission) {\n            if (denyDeclaredMemberAccess\n                    && permission instanceof RuntimePermission\n                    && \"accessDeclaredMembers\".equals(permission.getName())) {\n              