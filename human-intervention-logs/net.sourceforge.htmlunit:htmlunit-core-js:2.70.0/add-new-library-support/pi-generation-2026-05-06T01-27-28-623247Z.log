[tool-call] delta {"path":"tests/src/net.sourceforge.htmlunit/htmlunit-core-js/2.70.0/src/test/java/net_sourceforge_htmlunit/htmlunit_core_js/SoftCachingModuleScriptProviderTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage net_sourceforge_htmlunit.htmlunit_core_js;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.IOException;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.io.Serializable;\nimport java.io.StringReader;\nimport java.net.URI;\nimport java.net.URISyntaxException;\n\nimport net.sourceforge.htmlunit.corejs.javascript.Context;\nimport net.sourceforge.htmlunit.corejs.javascript.Scriptable;\nimport net.sourceforge.htmlunit.corejs.javascript.commonjs.module.ModuleScript;\nimport net.sourceforge.htmlunit.corejs.javascript.commonjs.module.provider.ModuleSource;\nimport net.sourceforge.htmlunit.corejs.javascript.commonjs.module.provider.ModuleSourceProvider;\nimport net.sourceforge.htmlunit.corejs.javascript.commonjs.module.provider.SoftCachingModuleScriptProvider;\n\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class SoftCachingModuleScriptProviderTest {\n    private static final String MODULE_ID = \"sample/module\";\n    private static final URI MODULE_URI = URI.create(\"memory:/sample/module.js\");\n    private static final String VALIDATOR = \"module-validator\";\n\n    @Test\n    void serializesAndDeserializesCachedModuleScripts() throws Exception {\n        SoftCachingModuleScriptProvider provider = new SoftCachingModuleScriptProvider(\n                new InMemoryModuleSourceProvider());\n\n        Context context = Context.enter();\n        try {\n            context.setOptimizationLevel(-1);\n            Scriptable scope = context.initStandardObjects();\n            ModuleScript original = provider.getModuleScript(context, MODULE_ID, null, null, null);\n            assertThat(execute(context, scope, original)).isEqualTo(42);\n\n            SoftCachingModuleScriptProvider restored = roundTrip(provider);\n            ModuleScript cached = restored.getModuleScript(context, MODULE_ID, null, null, null);\n\n            assertThat(cached.getUri()).isEqualTo(MODULE_URI);\n            assertThat(execute(context, scope, cached)).isEqualTo(42);\n        } finally {\n            Context.exit();\n        }\n    }\n\n    private static int execute(Context context, Scriptable scope, ModuleScript moduleScript) {\n        Object result = moduleScript.getScript().exec(context, scope);\n        return ((Number) Context.jsToJava(result, Number.class)).intValue();\n    }\n\n    private static SoftCachingModuleScriptProvider roundTrip(\n            SoftCachingModuleScriptProvider provider) throws IOException, ClassNotFoundException {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(provider);\n        }\n\n        try (ObjectInputStream input = new ObjectInputStream(\n                new ByteArrayInputStream(bytes.toByteArray()))) {\n            return (SoftCachingModuleScriptProvider) input.readObject();\n        }\n    }\n\n    private static final class InMemoryModuleSourceProvider\n            implements ModuleSourceProvider, Serializable {\n        private static final long serialVersionUID = 1L;\n\n        @Override\n        public ModuleSource loadSource(String moduleId, Scriptable paths, Object validator)\n                throws IOException, URISyntaxException {\n            if (VALIDATOR.equals(validator)) {\n                return ModuleSourceProvider.NOT_MODIFIED;\n            }\n            if (!MODULE_ID.equals(moduleId)) {\n                return null;\n            }\n            return new ModuleSource(\n                    new StringReader(\"var answer = 40 + 2; answer;\"),\n                    null,\n                    MODULE_URI,\n                    null,\n                    VALIDATOR);\n        }\n\n        @Override\n        public ModuleSource loadSource(URI uri, URI baseUri, Object validator) {\n            throw new AssertionError(\"The test loads modules by module ID\");\n        }\n    }\n}\n"}
