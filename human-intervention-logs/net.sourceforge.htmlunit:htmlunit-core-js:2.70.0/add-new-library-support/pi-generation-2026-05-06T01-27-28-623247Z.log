edModuleScripts() throws Exception {\n        SoftCachingModuleScriptProvider provider = new SoftCachingModuleScriptProvider(\n                new InMemoryModuleSourceProvider());\n\n        Context context = Context.enter();\n        try {\n            context.setOptimizationLevel(-1);\n            Scriptable scope = context.initStandardObjects();\n            ModuleScript original = provider.getModuleScript(context, MODULE_ID, null, null, null);\n            assertThat(execute(context, scope, original)).isEqualTo(42);\n\n            SoftCachingModuleScriptProvider restored = roundTrip(provider);\n            ModuleScript cached = restored.getModuleScript(context, MODULE_ID, null, null, null);\n\n            assertThat(cached.getUri()).isEqualTo(MODULE_URI);\n            assertThat(execute(context, scope, cached)).isEqualTo(42);\n        } finally {\n            Context.exit();\n        }\n    }\n\n    private static int execute(Context context, Scriptable scope, ModuleScript moduleScript) {\n        Object result = moduleScript.getScript().exec(context, scope);\n        return ((Number) Context.jsToJava(result, Number.class)).intValue();\n    }\n\n    private static SoftCachingModuleScriptProvider roundTrip(\n            SoftCachingModuleScriptProvider provider) throws IOException, ClassNotFoundException {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(provider);\n        }\n\n        try (ObjectInputStream input = new ObjectInputStream(\n                new ByteArrayInputStream(bytes.toByteArray()))) {\n            return (SoftCachingModuleScriptProvider) input.readObject();\n        }\n    }\n\n    private static final class InMemoryModuleSourceProvider\n            implements ModuleSourceProvider, Serializable {\n        private static final long serialVersionUID = 1L;\n\n        @Override\n        public ModuleSource loadSource(String