  package net_sourceforge_htmlunit.htmlunit_core_js;
  
  import javax.script.Invocable;
  import javax.script.ScriptEngine;
  
  import net.sourceforge.htmlunit.corejs.javascript.engine.RhinoScriptEngine;
  import net.sourceforge.htmlunit.corejs.javascript.engine.RhinoScriptEngineFactory;
  
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class RhinoScriptEngineTest {
      @Test
      void createsInterfaceProxyForTopLevelScriptFunctions() throws Exception {
          ScriptEngine engine = newScriptEngine();
          engine.eval("""
                  function describe(name) {
                      return 'Hello, ' + name;
                  }
  
                  function add(left, right) {
                      return left + right;
                  }
                  """);
  
          TopLevelFunctions functions = ((Invocable) engine).getInterface(TopLevelFunctions.class);
  
          assertThat(functions).isNotNull();
          assertThat(functions.describe("Rhino")).isEqualTo("Hello, Rhino");
          assertThat(functions.add(2, 5)).isEqualTo(7);
      }
  
      @Test
      void createsInterfaceProxyForScriptObjectMethods() throws Exception {
          ScriptEngine engine = newScriptEngine();
          Object calculator = engine.eval("""
                  ({
                      label: function(name) {
                          return 'object-' + name;
                      },
                      multiply: function(left, right) {
                          return left * right;
                      }
                  });
                  """);
  
          ScriptObjectCalculator proxy = ((Invocable) engine)
                  .getInterface(calculator, ScriptObjectCalculator.class);
  
          assertThat(proxy).isNotNull();
          assertThat(proxy.label("calculator")).isEqualTo("object-calculator");
          assertThat(proxy.multiply(6, 7)).isEqualTo(42);
      }
  
      private static ScriptEngine newScriptEngine() {
          ScriptEngine engine = new RhinoScriptEngineFactory().getScriptEngine();
          engine.put(RhinoScriptEngine.OPTIMIZATION_LEVEL, -1);
          return engine;
      }
  
      public interface TopLevelFunctions {
          String describe(String name);
  
          int add(int left, int right);
      }
  
      public interface ScriptObjectCalculator {
          String label(String name);
  
          int multiply(int left, int right);
      }
  }
