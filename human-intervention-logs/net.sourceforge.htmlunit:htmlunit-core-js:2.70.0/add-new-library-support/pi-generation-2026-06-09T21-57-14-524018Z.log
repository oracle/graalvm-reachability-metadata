  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  
  public class NativeJavaObjectTest {
      @Test
      void convertsNativeArrayToJavaArray() {
          Context context = Context.enter();
          try {
              ScriptableObject scope = context.initStandardObjects();
              NativeArray array = new NativeArray(new Object[] {"alpha", "beta"});
              ScriptRuntime.setObjectProtoAndParent(array, scope);
  
              Object converted = Context.jsToJava(array, String[].class);
  
              assertThat(converted).isInstanceOf(String[].class);
              assertThat((String[]) converted).containsExactly("alpha", "beta");
          } finally {
              Context.exit();
          }
      }
  
      @Test
      void convertsJavaObjectWithDoubleValueMethodToPrimitiveDouble() {
          Object converted = Context.jsToJava(new DoubleValueProvider(12.5), Double.TYPE);
  
          assertThat(converted).isEqualTo(12.5);
      }
  
      @Test
      void roundTripsWrappedSerializableJavaObject() throws Exception {
          Context context = Context.enter();
          try {
              ScriptableObject scope = context.initStandardObjects();
              NativeJavaObject original =
                      new NativeJavaObject(
                              scope,
                              new SerializableBox("wrapped", 42),
                              SerializableBox.class);
  
              NativeJavaObject copied = roundTrip(scope, original);
  
              assertThat(copied.unwrap()).isInstanceOf(SerializableBox.class);
              SerializableBox box = (SerializableBox) copied.unwrap();
              assertThat(box.name()).isEqualTo("wrapped");
              assertThat(box.count()).isEqualTo(42);
          } finally {
              Context.exit();
          }
      }
  
      @Test
      void roundTripsWrappedJavaAdapter() throws Exception {
          try {
              roundTripWrappedJavaAdapter();
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
      }
  
      private void roundTripWrappedJavaAdapter() throws Exception {
          Context context = Context.enter();
          try {
              ScriptableObject scope = context.initStandardObjects();
              Object adapterWrapper = createAdapterWrapper(context, scope);
  
              NativeJavaObject copied = roundTrip(scope, (NativeJavaObject) adapterWrapper);
  
              assertThat(copied.unwrap()).isInstanceOf(AdapterMarker.class);
              AdapterMarker marker = (AdapterMarker) copied.unwrap();
              assertThat(marker.label()).isEqualTo("adapter-label");
          } finally {
              Context.exit();
          }
      }
  
      private Object createAdapterWrapper(Context context, ScriptableObject scope) {
          JavaAdapter.init(context, scope, false);
          RecordingFunction labelFunction = new RecordingFunction("adapter-label");
          ScriptRuntime.setFunctionProtoAndParent(labelFunction, context, scope);
          NativeObject implementation = new NativeObject();
          ScriptRuntime.setObjectProtoAndParent(implementation, scope);
          implementation.defineProperty("label", labelFunction, ScriptableObject.EMPTY);
  
          Object constructor = ScriptableObject.getProperty(scope, "JavaAdapter");
          Object adapterWrapper =
                  Function.class
                          .cast(constructor)
                          .construct(
                                  context,
                                  scope,
                                  new Object[] {
                                      new NativeJavaClass(scope, AdapterMarker.class),
                                      implementation
                                  });
  
          assertThat(adapterWrapper).isInstanceOf(Wrapper.class);
          assertThat(((Wrapper) adapterWrapper).unwrap()).isInstanceOf(AdapterMarker.class);
          return adapterWrapper;
      }
  
      private NativeJavaObject roundTrip(Scriptable scope, NativeJavaObject object) throws Exception {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ScriptableOutputStream output = new ScriptableOutputStream(bytes, scope)) {
              output.writeObject(object);
          }
          try (ScriptableInputStream input =
                  new ScriptableInputStream(new ByteArrayInputStream(bytes.toByteArray()), scope)) {
              return (NativeJavaObject) input.readObject();
          }
      }
  
      public interface AdapterMarker {
          String label();
      }
  
      public static final class DoubleValueProvider {
          private final double value;
  
          public DoubleValueProvider(double value) {
              this.value = value;
          }
  
          public Number doubleValue() {
              return value;
          }
      }
  
      public static final class SerializableBox implements Serializable {
          private static final long serialVersionUID = 1L;
  
          private final String name;
          private final int count;
  
          public SerializableBox(String name, int count) {
              this.name = name;
              this.count = count;
          }
  
          public String name() {
              return name;
          }
  
          public int count() {
              return count;
          }
      }
  
      private static final class RecordingFunction extends BaseFunction implements Serializable {
          private static final long serialVersionUID = 1L;
  
          private final String result;
  
          private RecordingFunction(String result) {
              this.result = result;
          }
  
          @Override
          public Object call(
                  Context context,
                  Scriptable scope,
                  Scriptable thisObj,
                  Object[] args) {
              return result;
          }
      }
  }
