[tool-call] delta {"path":"tests/src/net.sourceforge.htmlunit/htmlunit-core-js/2.70.0/src/test/java/net_sourceforge_htmlunit/htmlunit_core_js/ShellConsoleTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage net_sourceforge_htmlunit.htmlunit_core_js;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayOutputStream;\nimport java.io.PrintStream;\nimport java.nio.charset.StandardCharsets;\nimport net.sourceforge.htmlunit.corejs.javascript.Context;\nimport net.sourceforge.htmlunit.corejs.javascript.ScriptableObject;\nimport net.sourceforge.htmlunit.corejs.javascript.tools.shell.ShellConsole;\nimport org.junit.jupiter.api.Test;\n\npublic class ShellConsoleTest {\n    @Test\n    void createsJLineConsoleAndInvokesConsoleOperations() throws Exception {\n        PrintStream originalOut = System.out;\n        String originalTerminal = System.getProperty(\"jline.terminal\");\n        ByteArrayOutputStream output = new ByteArrayOutputStream();\n        try (PrintStream printStream = new PrintStream(output, true, StandardCharsets.UTF_8)) {\n            System.setOut(printStream);\n            System.setProperty(\"jline.terminal\", \"none\");\n\n            ShellConsole console = createJLineConsole();\n\n            assertThat(console).isNotNull();\n            console.print(\"alpha\");\n            console.println(\"beta\");\n            console.println();\n            console.flush();\n        } finally {\n            System.setOut(originalOut);\n            restoreProperty(\"jline.terminal\", originalTerminal);\n        }\n\n        assertThat(output.toString(StandardCharsets.UTF_8)).contains(\"alpha\").contains(\"beta\");\n    }\n\n    private ShellConsole createJLineConsole() {\n        Context context = Context.enter();\n        try {\n            ScriptableObject scope = context.initStandardObjects();\n            scope.defineProperty(\"alphaCompletion\", 1, ScriptableObject.EMPTY);\n\n            return ShellConsole.getConsole(scope, StandardCharsets.UTF_8);\n        } finally {\n            Context.exit();\n        }\n    }\n\n    private void restoreProperty(String name, String value) {\n        if (value == null) {\n            System.clearProperty(name);\n        } else {\n            System.setProperty(name, value);\n        }\n    }\n}\n"}
