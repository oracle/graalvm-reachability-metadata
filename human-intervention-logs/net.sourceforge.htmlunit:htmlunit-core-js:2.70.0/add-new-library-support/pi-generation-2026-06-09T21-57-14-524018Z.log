    System.setOut(printStream);\n            System.setProperty(\"jline.terminal\", \"none\");\n\n            ShellConsole console = createJLineConsole();\n\n            assertThat(console).isNotNull();\n            console.print(\"alpha\");\n            console.println(\"beta\");\n            console.println();\n            console.flush();\n        } finally {\n            System.setOut(originalOut);\n            restoreProperty(\"jline.terminal\", originalTerminal);\n        }\n\n        assertThat(output.toString(StandardCharsets.UTF_8)).contains(\"alpha\").contains(\"beta\");\n    }\n\n    private ShellConsole createJLineConsole() {\n        Context context = Context.enter();\n        try {\n            ScriptableObject scope = context.initStandardObjects();\n            scope.defineProperty(\"alphaCompletion\", 1, ScriptableObject.EMPTY);\n\n            return ShellConsole.getConsole(scope, StandardCharsets.UTF_8);\n        } finally {\n            Context.exit();\n        }\n    }\n\n    private void restoreProperty(String name, String value) {\n        if (value == null) {\n            System.clearProperty(name);\n        } else {\n            System.setProperty(name, value);\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 263, "output": 768, "cacheRead": 30720, "cacheWrite": 0, "totalTokens": 31751, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1781042150770, "responseId": "resp_096c0371f96f3d38016a288be7512c819692763349d3040926"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_VqF9SNzejnY8hVNbKCZiWBik|fc_096c0371f96f3d38016a288bee4fa8819695fc03ef138c3303", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2241 bytes to tests/src/net.sourceforge.htmlunit/htmlunit-core-js/2.70.0/src/test/java/net_sourceforge_htmlunit/htmlunit_core_js/ShellConsoleTest.java"}], "isError": false, "t