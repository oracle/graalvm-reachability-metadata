it.corejs.javascript.Context\", true, classLoader);\n        Class<?> scriptableClass =\n                Class.forName(\n                        \"net.sourceforge.htmlunit.corejs.javascript.Scriptable\", false, classLoader);\n        Class<?> shellConsoleClass =\n                Class.forName(\n                        \"net.sourceforge.htmlunit.corejs.javascript.tools.shell.ShellConsole\",\n                        false,\n                        classLoader);\n        Object context = contextClass.getMethod(\"enter\").invoke(null);\n        try {\n            Object scope = contextClass.getMethod(\"initStandardObjects\").invoke(context);\n            Method getConsole = shellConsoleClass.getMethod(\"getConsole\", scriptableClass, Charset.class);\n            return getConsole.invoke(null, scope, StandardCharsets.UTF_8);\n        } finally {\n            contextClass.getMethod(\"exit\").invoke(null);\n        }\n    }\n\n    private URL toUrl(File file) {\n        try {\n            return file.toURI().toURL();\n        } catch (Exception exception) {\n            throw new IllegalArgumentException(\"Invalid classpath entry: \" + file, exception);\n        }\n    }\n\n    private void restoreProperty(String name, String value) {\n        if (value == null) {\n            System.clearProperty(name);\n        } else {\n            System.setProperty(name, value);\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1781042457332}]}
