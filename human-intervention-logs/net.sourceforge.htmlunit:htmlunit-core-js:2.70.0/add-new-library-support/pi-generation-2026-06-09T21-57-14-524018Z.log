 java.io.ByteArrayOutputStream;\n+import java.io.File;\n import java.io.PrintStream;\n+import java.lang.reflect.Method;\n+import java.net.URL;\n+import java.net.URLClassLoader;\n+import java.nio.charset.Charset;\n import java.nio.charset.StandardCharsets;\n+import java.util.Arrays;\n import jline.TerminalFactory;\n import net.sourceforge.htmlunit.corejs.javascript.Context;\n import net.sourceforge.htmlunit.corejs.javascript.ScriptableObject;\n import net.sourceforge.htmlunit.corejs.javascript.tools.shell.ShellConsole;\n+import org.graalvm.internal.tck.NativeImageSupport;\n import org.junit.jupiter.api.Test;\n \n public class ShellConsoleTest {\n+    private static final String JLINE_ONE_CLASSPATH_PROPERTY = \"htmlunitCoreJs.jlineOneClasspath\";\n+\n     @Test\n     void createsJLineConsoleAndInvokesConsoleOperations() throws Exception {\n         PrintStream originalOut = System.out;\n@@ -44,6 +53,17 @@ public class ShellConsoleTest {\n         assertThat(output.toString(StandardCharsets.UTF_8)).contains(\"alpha\").contains(\"beta\");\n     }\n \n+    @Test\n+    void createsJLineOneConsoleInIsolatedClassLoader() throws Exception {\n+        try {\n+            createJLineOneConsoleInIsolatedClassLoader();\n+        } catch (Error error) {\n+            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n+                throw error;\n+            }\n+        }\n+    }\n+\n     private ShellConsole createJLineConsole() {\n         Context context = Context.enter();\n         try {\n@@ -56,6 +76,76 @@ public class ShellConsoleTest {\n         }\n     }\n \n+    private void createJLineOneConsoleInIsolatedClassLoader() throws Exception {\n+        String classpath = System.getProperty(JLINE_ONE_CLASSPATH_PROPERTY);\n+        assertThat(classpath).isNotBlank();\n+        URL[] urls =\n+                Arrays.stream(classpath.split(File.pathSeparator))\n+                        .map(File::new)\n+                        .map(this::toUrl)\n+                        .toArray(URL[]::new);\n+\n+        PrintStream originalOut = System.out;\n+        String originalTerminal = System.getProperty(\"jline.terminal\");\n+        ByteArrayOutputStream output = new ByteArrayOutputStream();\n+        try (URLClassLoader classLoader = new URLClassLoader(urls, null);\n+                PrintStream printStream = new PrintStream(output, true, StandardCharsets.UTF_8)) {\n+            System.setOut(printStream);\n+            System.setProperty(\"jline.terminal\", \"jline.UnsupportedTerminal\");\n+\n+            Object console = createJLineOneConsole(classLoader);\n+            assertThat(console).isNotNull();\n+\n+            Class<?> shellConsoleClass =\n+                    Class.forName(\n+                            \"net.sourceforge.htmlunit.corejs.javascript.tools.shell.ShellConsole\",\n+                            false,\n+                            classLoader);\n+            shellConsoleClass.getMethod(\"print\", String.class).invoke(console, \"v1-alpha\");\n+            shellConsoleClass.getMethod(\"println\", String.class).invoke(console, \"v1-beta\");\n+            shellConsoleClass.getMethod(\"println\").invoke(console);\n+            shellConsoleClass.getMethod(\"flush\").invoke(console);\n+        } finally {\n+            System.setOut(originalOut);\n+            restoreProperty(\"jline.terminal\", originalTerminal);\n+        }\n+\n+        assertThat(output.toString(StandardCharsets.UTF_8))\n+                .contains(\"v1-alpha\")\n+                .contains(\"v1-beta\");\n+    }\n+\n+    private Object createJLineOneConsole(ClassLoader classLoader) throws Exception {\n+        Class<?> contextClass =\n+                Class.forName(\n+                        \"net.sourceforge.htmlunit.corejs.javascript.Context\", true, classLoader);\n+        Class<?> scriptableClass =\n+                Class.forName(\n+                        \"net.sourceforge.htmlunit.corejs.javascript.Scriptable\", false, classLoader);\n+        Class<?> shellConsoleClass =\n+                Class.forName(\n+                        \"net.sourceforge.htmlunit.corejs.javascript.tools.shell.ShellConsole\",\n+                        false,\n+                        classLoader);\n+        Object context = contextClass.getMethod(\"enter\").invoke(null);\n+        try {\n+            Object scope = contextClass.getMethod(\"initStandardObjects\").invoke(context);\n+            Method getConsole =\n+                    shellConsoleClass.getMethod(\"getConsole\", scriptableClass, Charset.class);\n+            return getConsole.invoke(null, scope, StandardCharsets.UTF_8);\n+        } finally {\n+            contextClass.getMethod(\"exit\").invoke(null);\n+        }\n+    }\n+\n+    private URL toUrl(File file) {\n+        try {\n+            return file.toURI().toURL();\n+        } catch (Exception exception) {\n+            throw new IllegalArgumentException(\"Invalid classpath entry: \" + file, exception);\n+        }\n+    }\n+\n     private void restoreProperty(String name, String value) {\n         if (value == null) {\n             System.clearProperty(name);\n"}], "isError": false, "timestamp": 1781042520050}]}
