[tool-call] delta {"path":"tests/src/net.sourceforge.htmlunit/htmlunit-core-js/2.70.0/src/test/java/net_sourceforge_htmlunit/htmlunit_core_js/ShellConsoleTest.java","edits":[{"oldText":"import java.io.ByteArrayOutputStream;\nimport java.io.PrintStream;\nimport java.nio.charset.StandardCharsets;\nimport jline.TerminalFactory;\nimport net.sourceforge.htmlunit.corejs.javascript.Context;\n","newText":"import java.io.ByteArrayOutputStream;\nimport java.io.File;\nimport java.io.PrintStream;\nimport java.lang.reflect.Method;\nimport java.net.URL;\nimport java.net.URLClassLoader;\nimport java.nio.charset.StandardCharsets;\nimport java.util.Arrays;\nimport jline.TerminalFactory;\nimport net.sourceforge.htmlunit.corejs.javascript.Context;\n"},{"oldText":"import net.sourceforge.htmlunit.corejs.javascript.ScriptableObject;\nimport net.sourceforge.htmlunit.corejs.javascript.tools.shell.ShellConsole;\nimport org.junit.jupiter.api.Test;\n","newText":"import net.sourceforge.htmlunit.corejs.javascript.ScriptableObject;\nimport net.sourceforge.htmlunit.corejs.javascript.tools.shell.ShellConsole;\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\n"},{"oldText":"public class ShellConsoleTest {\n    @Test\n    void createsJLineConsoleAndInvokesConsoleOperations() throws Exception {\n","newText":"public class ShellConsoleTest {\n    private static final String JLINE_ONE_CLASSPATH_PROPERTY = \"htmlunitCoreJs.jlineOneClasspath\";\n\n    @Test\n    void createsJLineConsoleAndInvokesConsoleOperations() throws Exception {\n"},{"oldText":"        assertThat(output.toString(StandardCharsets.UTF_8)).contains(\"alpha\").contains(\"beta\");\n    }\n\n    private ShellConsole createJLineConsole() {\n","newText":"        assertThat(output.toString(StandardCharsets.UTF_8)).contains(\"alpha\").contains(\"beta\");\n    }\n\n    @Test\n    void createsJLineOneConsoleInIsolatedClassLoader() throws Exception {\n        try {\n            createJLineOneConsoleInIsolat