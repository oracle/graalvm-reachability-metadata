7e297838", "name": "write", "arguments": {"path": "tests/src/net.sourceforge.htmlunit/htmlunit-core-js/2.70.0/src/test/java/net_sourceforge_htmlunit/htmlunit_core_js/RhinoScriptEngineTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage net_sourceforge_htmlunit.htmlunit_core_js;\n\nimport javax.script.Invocable;\nimport javax.script.ScriptEngine;\n\nimport net.sourceforge.htmlunit.corejs.javascript.engine.RhinoScriptEngine;\nimport net.sourceforge.htmlunit.corejs.javascript.engine.RhinoScriptEngineFactory;\n\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class RhinoScriptEngineTest {\n    @Test\n    void createsInterfaceProxyForTopLevelScriptFunctions() throws Exception {\n        ScriptEngine engine = newScriptEngine();\n        engine.eval(\"\"\"\n                function describe(name) {\n                    return 'Hello, ' + name;\n                }\n\n                function add(left, right) {\n                    return left + right;\n                }\n                \"\"\");\n\n        TopLevelFunctions functions = ((Invocable) engine).getInterface(TopLevelFunctions.class);\n\n        assertThat(functions).isNotNull();\n        assertThat(functions.describe(\"Rhino\")).isEqualTo(\"Hello, Rhino\");\n        assertThat(functions.add(2, 5)).isEqualTo(7);\n    }\n\n    @Test\n    void createsInterfaceProxyForScriptObjectMethods() throws Exception {\n        ScriptEngine engine = newScriptEngine();\n        Object calculator = engine.eval(\"\"\"\n                ({\n                    label: function() {\n                        return 'object-calculator';\n                    },\n                    multiply: function(left, right) {\n                        return left * right;\n                    }\n                });\n                \"\"\");\n\n        ScriptObjectCalculator proxy = ((Invocable) engine)\n                .getInterface(calculator, ScriptObjectCalculator.class);\n\n        assertThat(proxy).isNotNull();\n        assertThat(proxy.label()).isEqualTo(\"object-calculator\");\n        assertThat(proxy.multiply(6, 7)).isEqualTo(42);\n    }\n\n    private static ScriptEngine newScriptEngine() {\n        ScriptEngine engine = new RhinoScriptEngineFactory().getScriptEngine();\n        engine.put(RhinoScriptEngine.OPTIMIZATION_LEVEL, -1);\n        return engine;\n    }\n\n    public interface TopLevelFunctions {\n        String describe(String name);\n\n        int add(int left, int right);\n    }\n\n    public interface ScriptObjectCalculator {\n        String label();\n\n        int multiply(int left, int right);\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 11490, "output": 1171, "cacheRead": 6656, "cacheWrite": 0, "totalTokens": 19317, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778020635674, "responseId": "resp_055ef71f0e7514b80169fa711c193c81a3b8431d3c7ee1fb29"}}
