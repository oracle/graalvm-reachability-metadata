    assertThat(restored.getObject(1)).isEqualTo(\"one\");\n        assertThat(restored.getObject(2)).isNull();\n        assertThat(restored.getObject(3)).isEqualTo(\"three\");\n        assertThat(restored.getInt(1, -1)).isZero();\n        assertThat(restored.getInt(2, -1)).isEqualTo(200);\n        assertThat(restored.getExistingInt(3)).isEqualTo(300);\n        assertThat(restored.getKeys()).containsExactlyInAnyOrder(1, 2, 3);\n    }\n\n    private static UintMap roundTrip(UintMap map) throws IOException, ClassNotFoundException {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(map);\n        }\n\n        try (ObjectInputStream input = new ObjectInputStream(\n                new ByteArrayInputStream(bytes.toByteArray()))) {\n            return (UintMap) input.readObject();\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 374, "output": 828, "cacheRead": 15360, "cacheWrite": 0, "totalTokens": 16562, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778030029959, "responseId": "resp_06881c80cbd8f6400169fa95ce4aec819d8c657743f147a39d"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_0q950948xPsEjidjPCLnlltn|fc_06881c80cbd8f6400169fa95d1d028819db89587575c733535", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2127 bytes to tests/src/net.sourceforge.htmlunit/htmlunit-core-js/2.70.0/src/test/java/net_sourceforge_htmlunit/htmlunit_core_js/UintMapTest.java"}], "isError": false, "timestamp": 1778030037318}]}
