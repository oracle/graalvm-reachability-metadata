[tool-call] delta {"path":"tests/src/net.sourceforge.htmlunit/htmlunit-core-js/2.70.0/src/test/java/net_sourceforge_htmlunit/htmlunit_core_js/InterfaceAdapterTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage net_sourceforge_htmlunit.htmlunit_core_js;\n\nimport java.util.ArrayList;\nimport java.util.Comparator;\nimport java.util.List;\n\nimport net.sourceforge.htmlunit.corejs.javascript.Context;\nimport net.sourceforge.htmlunit.corejs.javascript.Scriptable;\nimport net.sourceforge.htmlunit.corejs.javascript.ScriptableObject;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class InterfaceAdapterTest {\n    public static class ComparatorHarness {\n        public String orderWith(Comparator<String> comparator) {\n            List<String> names = new ArrayList<>(List.of(\"pear\", \"fig\", \"banana\"));\n            names.sort(comparator);\n            return String.join(\",\", names);\n        }\n    }\n\n    @Test\n    void adaptsJavaScriptFunctionToFunctionalInterfaceParameter() {\n        Context cx = Context.enter();\n        try {\n            Scriptable scope = cx.initStandardObjects();\n            ComparatorHarness harness = new ComparatorHarness();\n            ScriptableObject.putProperty(scope, \"harness\", Context.javaToJS(harness, scope));\n\n            Object value = cx.evaluateString(scope, \"\"\"\n                    harness.orderWith(function(left, right) {\n                        return left.length - right.length;\n                    });\n                    \"\"\", \"interface-adapter-comparator\", 1, null);\n\n            assertThat(value).isEqualTo(\"fig,pear,banana\");\n        } finally {\n            Context.exit();\n        }\n    }\n}\n"}
