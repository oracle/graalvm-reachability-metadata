  package net_sourceforge_htmlunit.htmlunit_core_js;
  
  import java.security.Permission;
  
  import net.sourceforge.htmlunit.corejs.javascript.Context;
  import net.sourceforge.htmlunit.corejs.javascript.FunctionObject;
  import net.sourceforge.htmlunit.corejs.javascript.Scriptable;
  import net.sourceforge.htmlunit.corejs.javascript.ScriptableObject;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class FunctionObjectTest {
      @Test
      void constructCreatesDeclaringScriptableWithDefaultConstructor() throws Exception {
          ConstructedScriptable.reset();
          Context cx = Context.enter();
          try {
              Scriptable scope = cx.initStandardObjects();
              FunctionObject function = new FunctionObject(
                      "record",
                      ConstructedScriptable.class.getMethod("record", String.class),
                      scope);
  
              Scriptable created = function.construct(cx, scope, new Object[] {"created"});
  
              assertThat(created).isInstanceOf(ConstructedScriptable.class);
              ConstructedScriptable scriptable = (ConstructedScriptable) created;
              assertThat(scriptable.value).isEqualTo("created");
              assertThat(ConstructedScriptable.constructorInvocations).isEqualTo(1);
              assertThat(scriptable.getParentScope()).isSameAs(function.getParentScope());
              assertThat(scriptable.getPrototype())
                      .isSameAs(ScriptableObject.getObjectPrototype(scope));
          } finally {
              Context.exit();
          }
      }
  
      @Test
      @SuppressWarnings("removal")
      void defineClassFallsBackToPublicMethodsWhenDeclaredMethodAccessIsDenied() throws Exception {
          InitOnlyScriptable.reset();
          Context cx = Context.enter();
          SecurityManager previousSecurityManager = System.getSecurityManager();
          boolean securityManagerInstalled = false;
          try {
              Scriptable scope = cx.initStandardObjects();
              securityManagerInstalled = setSecurityManager(
                      new DenyDeclaredMemberAccessSecurityManager());
  
              ScriptableObject.defineClass(scope, InitOnlyScriptable.class, false, false);
  
              assertThat(InitOnlyScriptable.initialized).isTrue();
              assertThat(InitOnlyScriptable.observedScope).isSameAs(scope);
              assertThat(ScriptableObject.getProperty(scope, "functionObjectFallback"))
                      .isEqualTo(Boolean.TRUE);
          } finally {
              if (securityManagerInstalled) {
                  setSecurityManager(previousSecurityManager);
              }
              Context.exit();
          }
      }
  
      @SuppressWarnings("removal")
      private static boolean setSecurityManager(SecurityManager securityManager) {
          try {
              System.setSecurityManager(securityManager);
              return System.getSecurityManager() == securityManager;
          } catch (UnsupportedOperationException unsupported) {
              return false;
          }
      }
  
      public static class ConstructedScriptable extends ScriptableObject {
          private static final long serialVersionUID = 1L;
  
          static int constructorInvocations;
          String value;
  
          public ConstructedScriptable() {
              constructorInvocations++;
          }
  
          public void record(String newValue) {
              value = newValue;
          }
  
          static void reset() {
              constructorInvocations = 0;
          }
  
          @Override
          public String getClassName() {
              return "ConstructedScriptable";
          }
      }
  
      public static class InitOnlyScriptable extends ScriptableObject {
          private static final long serialVersionUID = 1L;
  
          static boolean initialized;
          static Scriptable observedScope;
  
          public static void init(Scriptable scope) {
              initialized = true;
              observedScope = scope;
              ScriptableObject.putProperty(scope, "functionObjectFallback", Boolean.TRUE);
          }
  
          static void reset() {
              initialized = false;
              observedScope = null;
          }
  
          @Override
          public String getClassName() {
              return "InitOnlyScriptable";
          }
      }
  
      @SuppressWarnings("removal")
      private static final class DenyDeclaredMemberAccessSecurityManager extends SecurityManager {
          @Override
          public void checkPermission(Permission permission) {
              if ("accessDeclaredMembers".equals(permission.getName())) {
                  throw new SecurityException(permission.getName());
              }
          }
      }
  }
