[tool-call] delta {"path":"tests/src/net.sourceforge.htmlunit/htmlunit-core-js/2.70.0/src/test/java/net_sourceforge_htmlunit/htmlunit_core_js/ContextTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage net_sourceforge_htmlunit.htmlunit_core_js;\n\nimport net.sourceforge.htmlunit.corejs.javascript.Context;\nimport net.sourceforge.htmlunit.corejs.javascript.ContextFactory;\nimport net.sourceforge.htmlunit.corejs.javascript.tools.debugger.Main;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ContextTest {\n    @Test\n    @SuppressWarnings(\"deprecation\")\n    void attachesDebuggerContextListenerThroughLegacyCompatibilityHook() {\n        Main debugger = new Main();\n\n        Context.addContextListener(debugger);\n\n        assertThat(debugger.getAttachedFactory()).isSameAs(ContextFactory.getGlobal());\n    }\n}\n"}
