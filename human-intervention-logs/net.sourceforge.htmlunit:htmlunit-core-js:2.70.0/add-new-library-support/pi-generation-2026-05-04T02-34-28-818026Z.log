  package net_sourceforge_htmlunit.htmlunit_core_js;
  
  import java.net.URL;
  import java.security.CodeSource;
  import java.security.cert.Certificate;
  import java.util.UUID;
  
  import net.sourceforge.htmlunit.corejs.javascript.Callable;
  import net.sourceforge.htmlunit.corejs.javascript.Context;
  import net.sourceforge.htmlunit.corejs.javascript.Scriptable;
  import net.sourceforge.htmlunit.corejs.javascript.SecureCallerAccess;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class SecureCallerAnonymous2Test {
      @Test
      void callsCallableThroughSecureCallerGeneratedClass() throws Exception {
          ClassLoader originalClassLoader = Thread.currentThread().getContextClassLoader();
          Context cx = Context.enter();
          try {
              Thread.currentThread().setContextClassLoader(getClass().getClassLoader());
              Scriptable scope = cx.initStandardObjects();
              CodeSource codeSource = new CodeSource(
                      new URL("file", "", "/secure-caller-" + UUID.randomUUID() + "/"),
                      (Certificate[]) null);
  
              try {
                  Object result = SecureCallerAccess.callSecurely(
                          codeSource,
                          new ReturningCallable(),
                          cx,
                          scope,
                          scope,
                          new Object[] {"payload"});
  
                  assertThat(result).isEqualTo("called:payload");
              } catch (Error error) {
                  if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                      throw error;
                  }
              }
          } finally {
              Thread.currentThread().setContextClassLoader(originalClassLoader);
              Context.exit();
          }
      }
  
      private static final class ReturningCallable implements Callable {
          @Override
          public Object call(Context cx, Scriptable scope, Scriptable thisObj, Object[] args) {
              assertThat(thisObj).isSameAs(scope);
              return "called:" + Context.toString(args[0]);
          }
      }
  }
