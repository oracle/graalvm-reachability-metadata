  /*
   * Copyright and related rights waived via CC0
   *
   * You should have received a copy of the CC0 legalcode along with this
   * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.
   */
  package net_sourceforge_htmlunit.htmlunit_core_js;
  
  import net.sourceforge.htmlunit.corejs.javascript.Context;
  import net.sourceforge.htmlunit.corejs.javascript.Function;
  import net.sourceforge.htmlunit.corejs.javascript.Scriptable;
  
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class CodegenTest {
      @Test
      void compileFunctionCreatesExecutableOptimizedFunction() {
          try {
              compileAndCallOptimizedFunction();
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
      }
  
      private static void compileAndCallOptimizedFunction() {
          Context context = Context.enter();
          try {
              context.setOptimizationLevel(0);
              Scriptable scope = context.initStandardObjects();
              Function function = context.compileFunction(
                      scope,
                      "function square(value) { return value * value; }",
                      "codegen-function.js",
                      1,
                      null);
  
              Object result = function.call(context, scope, scope, new Object[] {7});
  
              assertThat(Context.toNumber(result)).isEqualTo(49.0D);
          } finally {
              Context.exit();
          }
