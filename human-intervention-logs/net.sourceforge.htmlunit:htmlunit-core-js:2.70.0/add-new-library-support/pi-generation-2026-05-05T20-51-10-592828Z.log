  package net_sourceforge_htmlunit.htmlunit_core_js;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.IOException;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.util.AbstractList;
  import java.util.List;
  
  import net.sourceforge.htmlunit.corejs.javascript.Context;
  import net.sourceforge.htmlunit.corejs.javascript.JavaAdapter;
  import net.sourceforge.htmlunit.corejs.javascript.NativeObject;
  import net.sourceforge.htmlunit.corejs.javascript.ObjToIntMap;
  import net.sourceforge.htmlunit.corejs.javascript.Scriptable;
  import net.sourceforge.htmlunit.corejs.javascript.ScriptableObject;
  import net.sourceforge.htmlunit.corejs.javascript.Wrapper;
  
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class JavaAdapterTest {
      @Test
      void createsRunnableAdapterFromJavaScriptImplementation() {
          try {
              Context context = Context.enter();
              try {
                  Scriptable scope = context.initStandardObjects();
                  Object result = context.evaluateString(scope, """
                          new JavaAdapter(java.lang.Runnable, {
                              run: function() {
                                  java.lang.System.setProperty('htmlunit.javaAdapter.run', 'called');
                              },
                              toString: function() {
                                  return 'scripted-runnable';
                              }
                          });
                          """, "java-adapter-create-test", 1, null);
  
                  Object adapter = unwrap(result);
                  assertThat(adapter).isInstanceOf(Runnable.class);
  
                  ((Runnable) adapter).run();
                  assertThat(System.getProperty("htmlunit.javaAdapter.run")).isEqualTo("called");
                  Object self = JavaAdapter.getAdapterSelf(adapter.getClass(), adapter);
                  assertThat(self).isInstanceOf(Scriptable.class);
              } finally {
                  Context.exit();
                  System.clearProperty("htmlunit.javaAdapter.run");
              }
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          } catch (ReflectiveOperationException exception) {
              throw new AssertionError(exception);
          }
      }
  
      @Test
      void serializesAndDeserializesGeneratedAdapterDescriptor() throws Exception {
          try {
              Context context = Context.enter();
              try {
                  Scriptable scope = context.initStandardObjects();
                  Object adapter = createEmptyRunnableAdapter(context, scope);
  
                  byte[] descriptor = serializeAdapterDescriptor(adapter);
                  Object restored = deserializeAdapterDescriptor(scope, descriptor);
  
                  assertThat(restored).isInstanceOf(Runnable.class);
                  Object self = JavaAdapter.getAdapterSelf(restored.getClass(), restored);
                  assertThat(self).isSameAs(scope);
              } finally {
                  Context.exit();
              }
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
      }
  
      @Test
      void generatesAdapterBytecodeForSuperclassAndInterfaceMethods() {
          ObjToIntMap functionNames = new ObjToIntMap();
          functionNames.put("get", 1);
          functionNames.put("size", 0);
          functionNames.put("run", 0);
          functionNames.put("scriptOnlyFunction", 2);
  
          byte[] bytecode = JavaAdapter.createAdapterCode(
                  functionNames,
                  "HtmlUnitCoreJsJavaAdapterCoverage",
                  AbstractList.class,
                  new Class<?>[] {Runnable.class, List.class},
                  null);
  
          assertThat(bytecode).isNotEmpty();
      }
  
      private static Object createEmptyRunnableAdapter(Context context, Scriptable scope) {
          NativeObject delegee = new NativeObject();
          delegee.setParentScope(scope);
          delegee.setPrototype(ScriptableObject.getObjectPrototype(scope));
          ScriptableObject.putProperty(scope, "delegee", delegee);
  
          Object result = context.evaluateString(scope, """
                  new JavaAdapter(java.lang.Runnable, delegee);
                  """, "java-adapter-serialization-test", 1, null);
          Object adapter = unwrap(result);
          assertThat(adapter).isInstanceOf(Runnable.class);
  
          delegee.setParentScope(null);
          delegee.setPrototype(null);
          return adapter;
      }
  
      private static byte[] serializeAdapterDescriptor(Object adapter) throws IOException {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {
              JavaAdapter.writeAdapterObject(adapter, output);
          }
          return bytes.toByteArray();
      }
  
      private static Object deserializeAdapterDescriptor(Scriptable self, byte[] descriptor)
              throws IOException, ClassNotFoundException {
          ByteArrayInputStream bytes = new ByteArrayInputStream(descriptor);
          try (ObjectInputStream input = new ObjectInputStream(bytes)) {
              return JavaAdapter.readAdapterObject(self, input);
          }
      }
  
      private static Object unwrap(Object value) {
          if (value instanceof Wrapper wrapper) {
              return wrapper.unwrap();
          }
          return value;
      }
  }
