  package net_sourceforge_htmlunit.htmlunit_core_js;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.IOException;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.lang.reflect.Constructor;
  import java.lang.reflect.Method;
  
  import net.sourceforge.htmlunit.corejs.javascript.Context;
  import net.sourceforge.htmlunit.corejs.javascript.FunctionObject;
  import net.sourceforge.htmlunit.corejs.javascript.Scriptable;
  import net.sourceforge.htmlunit.corejs.javascript.ScriptableObject;
  
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class MemberBoxTest {
      @Test
      void invokesPublicMethodFromNonPublicClassThroughAccessibleInterface() throws Exception {
          Context context = Context.enter();
          try {
              Scriptable scope = context.initStandardObjects();
              Method method = HiddenInterfaceTarget.class.getMethod("greet", String.class);
              FunctionObject function = new FunctionObject("greet", method, scope);
  
              Object result = function.call(
                      context,
                      scope,
                      new HiddenInterfaceTarget(),
                      new Object[] {"Ada"});
  
              assertThat(result).isEqualTo("interface:Ada");
          } finally {
              Context.exit();
          }
      }
  
      @Test
      void invokesPublicMethodFromNonPublicClassThroughAccessibleSuperclass() throws Exception {
          Context context = Context.enter();
          try {
              Scriptable scope = context.initStandardObjects();
              Method method = HiddenSuperclassTarget.class.getMethod("describe", String.class);
              FunctionObject function = new FunctionObject("describe", method, scope);
  
              Object result = function.call(
                      context,
                      scope,
                      new HiddenSuperclassTarget(),
                      new Object[] {"oak"});
  
              assertThat(result).isEqualTo("superclass:oak");
          } finally {
              Context.exit();
          }
      }
  
      @Test
      void constructsPublicScriptableObject() throws Exception {
          Context context = Context.enter();
          try {
              Scriptable scope = context.initStandardObjects();
              Constructor<PublicConstructedScriptable> constructor =
                      PublicConstructedScriptable.class.getConstructor(String.class, int.class);
              FunctionObject function =
                      new FunctionObject("PublicConstructedScriptable", constructor, scope);
  
              Object result = function.call(context, scope, null, new Object[] {"item", 3});
  
              assertThat(result).isInstanceOf(PublicConstructedScriptable.class);
              PublicConstructedScriptable scriptable = (PublicConstructedScriptable) result;
              assertThat(scriptable.summary()).isEqualTo("item:3");
          } finally {
              Context.exit();
          }
      }
  
      @Test
      void constructsNonPublicScriptableObjectAfterMakingConstructorAccessible() throws Exception {
          Context context = Context.enter();
          try {
              Scriptable scope = context.initStandardObjects();
              Constructor<HiddenConstructedScriptable> constructor =
                      HiddenConstructedScriptable.class.getDeclaredConstructor(String.class);
              FunctionObject function =
                      new FunctionObject("HiddenConstructedScriptable", constructor, scope);
  
              Object result = function.call(context, scope, null, new Object[] {"secret"});
  
              assertThat(result).isInstanceOf(HiddenConstructedScriptable.class);
              HiddenConstructedScriptable scriptable = (HiddenConstructedScriptable) result;
              assertThat(scriptable.value()).isEqualTo("secret");
          } finally {
              Context.exit();
          }
      }
  
      @Test
      void serializesAndDeserializesMethodFunction() throws Exception {
          Context context = Context.enter();
          try {
              Scriptable scope = context.initStandardObjects();
              Method method = MemberBoxTest.class.getMethod("formatValue", String.class, int.class);
              FunctionObject original = new FunctionObject("formatValue", method, scope);
              original.setParentScope(null);
              original.setPrototype(null);
  
              FunctionObject restored = roundTrip(original);
              Object result = restored.call(context, scope, null, new Object[] {"value", 5});
  
              assertThat(result).isEqualTo("value#5");
          } finally {
              Context.exit();
          }
      }
  
      @Test
      void serializesAndDeserializesConstructorFunction() throws Exception {
          Context context = Context.enter();
          try {
              Scriptable scope = context.initStandardObjects();
              Constructor<PublicConstructedScriptable> constructor =
                      PublicConstructedScriptable.class.getConstructor(String.class, int.class);
              FunctionObject original =
                      new FunctionObject("PublicConstructedScriptable", constructor, scope);
              original.setParentScope(null);
              original.setPrototype(null);
  
              FunctionObject restored = roundTrip(original);
              Object result = restored.call(context, scope, null, new Object[] {"restored", 7});
  
              assertThat(result).isInstanceOf(PublicConstructedScriptable.class);
              PublicConstructedScriptable scriptable = (PublicConstructedScriptable) result;
              assertThat(scriptable.summary()).isEqualTo("restored:7");
          } finally {
              Context.exit();
          }
      }
  
      public static String formatValue(String name, int count) {
          return name + "#" + count;
      }
  
      private static FunctionObject roundTrip(FunctionObject function)
              throws IOException, ClassNotFoundException {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {
              output.writeObject(function);
          }
  
          try (ObjectInputStream input = new ObjectInputStream(
                  new ByteArrayInputStream(bytes.toByteArray()))) {
              return (FunctionObject) input.readObject();
          }
      }
  
      public interface GreetingTarget {
          String greet(String name);
      }
  
      private static final class HiddenInterfaceTarget
              extends ScriptableObject implements GreetingTarget {
          private static final long serialVersionUID = 1L;
  
          @Override
          public String getClassName() {
              return "HiddenInterfaceTarget";
          }
  
          @Override
          public String greet(String name) {
              return "interface:" + name;
          }
      }
  
      public static class PublicGreetingBase extends ScriptableObject {
          private static final long serialVersionUID = 1L;
  
          @Override
          public String getClassName() {
              return "PublicGreetingBase";
          }
  
          public String describe(String value) {
              return "superclass:" + value;
          }
      }
  
      private static final class HiddenSuperclassTarget extends PublicGreetingBase {
          private static final long serialVersionUID = 1L;
  
          @Override
          public String getClassName() {
              return "HiddenSuperclassTarget";
          }
  
          @Override
          public String describe(String value) {
              return "superclass:" + value;
          }
      }
  
      public static class PublicConstructedScriptable extends ScriptableObject {
          private static final long serialVersionUID = 1L;
  
          private final String name;
          private final int count;
  
          public PublicConstructedScriptable(String name, int count) {
              this.name = name;
              this.count = count;
          }
  
          @Override
          public String getClassName() {
              return "PublicConstructedScriptable";
          }
  
          String summary() {
              return name + ':' + count;
          }
      }
  
      private static final class HiddenConstructedScriptable extends ScriptableObject {
          private static final long serialVersionUID = 1L;
  
          private final String value;
  
          public HiddenConstructedScriptable(String value) {
              this.value = value;
          }
  
          @Override
          public String getClassName() {
              return "HiddenConstructedScriptable";
          }
  
          String value() {
              return value;
          }
      }
  }
