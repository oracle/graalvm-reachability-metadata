ject.getObjectPrototype(scope));\n        ScriptableObject.putProperty(scope, \"delegee\", delegee);\n\n        Object result = context.evaluateString(scope, \"\"\"\n                new JavaAdapter(java.lang.Runnable, delegee);\n                \"\"\", \"native-java-object-adapter-test\", 1, null);\n        Object adapter = unwrap(result);\n        assertThat(adapter).isInstanceOf(Runnable.class);\n\n        delegee.setParentScope(null);\n        delegee.setPrototype(null);\n        return adapter;\n    }\n\n    private static NativeJavaObject roundTrip(NativeJavaObject object)\n            throws IOException, ClassNotFoundException {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(object);\n        }\n\n        try (ObjectInputStream input = new ObjectInputStream(\n                new ByteArrayInputStream(bytes.toByteArray()))) {\n            return (NativeJavaObject) input.readObject();\n        }\n    }\n\n    private static Object unwrap(Object value) {\n        if (value instanceof Wrapper wrapper) {\n            return wrapper.unwrap();\n        }\n        return value;\n    }\n\n    public static final class PublicDoubleValue {\n        private final double value;\n\n        PublicDoubleValue(double value) {\n            this.value = value;\n        }\n\n        public Number doubleValue() {\n            return value;\n        }\n    }\n\n    public static final class SerializableTopLevel extends ScriptableObject implements Serializable {\n        private static final long serialVersionUID = 1L;\n\n        public SerializableTopLevel() {\n            associateClassCache();\n        }\n\n        @Override\n        public String getClassName() {\n            return \"SerializableTopLevel\";\n        }\n\n        private void readObject(ObjectInputStream input)\n                throws IOException, ClassNotFoundException {\n            in