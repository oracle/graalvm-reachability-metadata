  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class JavaAdapterTest {
      @Test
      void createsRunnableAdapterFromJavaScriptImplementation() {
          try {
              Context context = Context.enter();
              try {
                  Scriptable scope = context.initStandardObjects();
                  Object result = context.evaluateString(scope, """
                          new JavaAdapter(java.lang.Runnable, {
                              run: function() {
                                  java.lang.System.setProperty('htmlunit.javaAdapter.run', 'called');
                              },
                              toString: function() {
                                  return 'scripted-runnable';
                              }
                          });
                          """, "java-adapter-create-test", 1, null);
  
                  Object adapter = unwrap(result);
                  assertThat(adapter).isInstanceOf(Runnable.class);
  
                  ((Runnable) adapter).run();
                  assertThat(System.getProperty("htmlunit.javaAdapter.run")).isEqualTo("called");
                  Object self = JavaAdapter.getAdapterSelf(adapter.getClass(), adapter);
                  assertThat(self).isInstanceOf(Scriptable.class);
              } finally {
                  Context.exit();
                  System.clearProperty("htmlunit.javaAdapter.run");
              }
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          } catch (ReflectiveOperationException exception) {
              throw new AssertionError(exception);
          }
      }
  
      @Test
      void serializesAndDeserializesGeneratedAdapterDescriptor() throws Exception {
          try {
              Context context = Context.enter();
              try {
                  Scriptable scope = context.initStandardObjects();
                  Object adapter = createEmptyRunnableAdapter(context, scope);
  
                  byte[] descriptor = serializeAdapterDescriptor(adapter);
                  Object restored = deserializeAdapterDescriptor(scope, descriptor);
  
                  assertThat(restored).isInstanceOf(Runnable.class);
                  Object self = JavaAdapter.getAdapterSelf(restored.getClass(), restored);
                  assertThat(self).isSameAs(scope);
