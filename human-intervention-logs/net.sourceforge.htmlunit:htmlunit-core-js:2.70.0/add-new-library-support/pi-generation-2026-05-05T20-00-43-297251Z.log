ect;\nimport net.sourceforge.htmlunit.corejs.javascript.NativeObject;\nimport net.sourceforge.htmlunit.corejs.javascript.Scriptable;\nimport net.sourceforge.htmlunit.corejs.javascript.ScriptableObject;\nimport net.sourceforge.htmlunit.corejs.javascript.Wrapper;\n\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class NativeJavaObjectTest {\n    @Test\n    void coercesNativeArrayToJavaArray() {\n        NativeArray values = new NativeArray(new Object[] {\"alpha\", \"beta\", \"gamma\"});\n\n        Object coerced = NativeJavaObject.coerceType(String[].class, values);\n\n        assertThat(coerced).isInstanceOf(String[].class);\n        assertThat((String[]) coerced).containsExactly(\"alpha\", \"beta\", \"gamma\");\n    }\n\n    @Test\n    void coercesObjectWithDoubleValueMethodToPrimitiveDouble() {\n        Object coerced = NativeJavaObject.coerceType(\n                Double.TYPE,\n                new PublicDoubleValue(12.75));\n\n        assertThat(coerced).isEqualTo(12.75d);\n    }\n\n    @Test\n    void serializesAndDeserializesRegularWrappedObjects() throws Exception {\n        SerializableTopLevel scope = new SerializableTopLevel();\n        NativeJavaObject typed = new NativeJavaObject(\n                scope,\n                \"typed value\",\n                CharSequence.class);\n        NativeJavaObject untyped = new NativeJavaObject(\n                scope,\n                Integer.valueOf(42),\n                null);\n\n        NativeJavaObject restoredTyped = roundTrip(typed);\n        NativeJavaObject restoredUntyped = roundTrip(untyped);\n\n        assertThat(restoredTyped.unwrap()).isEqualTo(\"typed value\");\n        assertThat(restoredUntyped.unwrap()).isEqualTo(42);\n    }\n\n    @Test\n    void serializesAndDeserializesAdapterWrappedObject() throws Exception {\n        try {\n            Context context = Context.enter();\n            try {\n                Scriptable standardScope = context.initStandardObjects();\n                Object adapter = createRunnableAdapter(context, standardScope);\n                NativeJavaObject wrapped = new NativeJavaObject(\n                        new SerializableTopLevel(),\n                        adapter,\n                        Runnable.class,\n                        true);\n\n                NativeJavaObject restored = roundTrip(wrapped);\n\n                assertThat(restored.unwrap()).isInstanceOf(Runnable.class);\n            } finally {\n                Context.exit();\n            }\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    private static Object createRunnableAdapter(Context context, Scriptable scope) {\n        NativeObject delegee = new NativeObject();\n        delegee.setParentScope(scope);\n        delegee.setPrototype(ScriptableObject.getObjectPrototype(scope));\n        ScriptableObject.putProperty(scope, \"delegee\", delegee);\n\n        Object result = context.evaluateString(scope, \"\"\"\n                new JavaAdapter(java.lang.Runnable, delegee);\n                \"\"\", \"native-java-object-adapter-test\", 1, null);\n        Object adapter = unwrap(result);\n        assertThat(adapter).isInstanceOf(Runnable.class);\n\n        delegee.setParentScope(null);\n        delegee.setPrototype(null);\n        return adapter;\n    }\n\n    private static NativeJavaObject roundTrip(NativeJavaObject object)\n            throws IOException, ClassNotFoundException {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(object);\n        }\n\n        try (ObjectInputStream input = new ObjectInputStream(\n                new ByteArrayInputStream(bytes.toByteArray()))) {\n            return (NativeJavaObject) input.readObject();\n        }\n    }\n\n    private static Object unwrap(Object value) {\n        if (value instanceof Wrapper wrapper) {\n            return wrapper.unwrap();\n        }\n        return value;\n    }\n\n    public static final class PublicDoubleValue {\n        private final double value;\n\n        PublicDoubleValue(double value) {\n            this.value = value;\n        }\n\n        public Number doubleValue() {\n            return value;\n        }\n    }\n\n    public static final class SerializableTopLevel\n            extends ScriptableObject implements Serializable {\n        private static final long serialVersionUID = 1L;\n\n        public SerializableTopLevel() {\n            associateClassCache();\n        }\n\n        @Override\n        public String getClassName() {\n            return \"SerializableTopLevel\";\n        }\n\n        private void readObject(ObjectInputStream input)\n                throws IOException, ClassNotFoundException {\n            input.defaultReadObject();\n            associateClassCache();\n        }\n\n        private void associateClassCache() {\n            new ClassCache().associate(this);\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778011227806}]}
