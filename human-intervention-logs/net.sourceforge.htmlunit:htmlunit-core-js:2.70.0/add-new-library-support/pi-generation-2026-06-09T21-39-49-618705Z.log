      public static Scriptable runScript(final Script script) {
          return ContextFactory.getGlobal()
                  .call(
                          cx -> {
                              ScriptableObject global = ScriptRuntime.getGlobal(cx);
                              script.exec(cx, global);
                              return global;
                          });
      }
  
