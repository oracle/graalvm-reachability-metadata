[tool-call] delta {"path":"tests/src/net.sourceforge.htmlunit/htmlunit-core-js/2.70.0/src/test/java/net_sourceforge_htmlunit/htmlunit_core_js/JavaAdapterTest.java","edits":[{"oldText":"import java.util.ArrayList;\nimport java.util.List;\nimport net.sourceforge.htmlunit.corejs.javascript.BaseFunction;\nimport net.sourceforge.htmlunit.corejs.javascript.Context;\nimport net.sourceforge.htmlunit.corejs.javascript.JavaAdapter;\nimport net.sourceforge.htmlunit.corejs.javascript.NativeObject;\nimport net.sourceforge.htmlunit.corejs.javascript.ObjToIntMap;\nimport net.sourceforge.htmlunit.corejs.javascript.ScriptRuntime;\nimport net.sourceforge.htmlunit.corejs.javascript.Scriptable;\nimport net.sourceforge.htmlunit.corejs.javascript.ScriptableObject;\nimport net.sourceforge.htmlunit.corejs.javascript.Wrapper;\n","newText":"import java.util.List;\nimport net.sourceforge.htmlunit.corejs.javascript.BaseFunction;\nimport net.sourceforge.htmlunit.corejs.javascript.Context;\nimport net.sourceforge.htmlunit.corejs.javascript.Function;\nimport net.sourceforge.htmlunit.corejs.javascript.JavaAdapter;\nimport net.sourceforge.htmlunit.corejs.javascript.NativeJavaClass;\nimport net.sourceforge.htmlunit.corejs.javascript.NativeObject;\nimport net.sourceforge.htmlunit.corejs.javascript.ObjToIntMap;\nimport net.sourceforge.htmlunit.corejs.javascript.ScriptRuntime;\nimport net.sourceforge.htmlunit.corejs.javascript.Scriptable;\nimport net.sourceforge.htmlunit.corejs.javascript.ScriptableObject;\nimport net.sourceforge.htmlunit.corejs.javascript.Wrapper;\n"},{"oldText":"                        \"GeneratedListRunnableAdapter\",\n                        ArrayList.class,\n                        new Class<?>[] {List.class, Runnable.class},\n","newText":"                        \"GeneratedAdapterBaseMarkerAdapter\",\n                        AdapterBase.class,\n                        new Class<?>[] {AdapterMarker.class},\n"},{"oldText":"            ScriptableObject scope = context.initStandardObjects();\n            RecordingFunction runFunction = new RecordingFunction();\n            RecordingFunction customValueFunction = new RecordingFunction();\n            ScriptRuntime.setFunctionProtoAndParent(runFunction, context, scope);\n            ScriptRuntime.setFunctionProtoAndParent(customValueFunction, context, scope);\n            NativeObject implementation = new NativeObject();\n            ScriptRuntime.setObjectProtoAndParent(implementation, scope);\n            implementation.defineProperty(\"run\", runFunction, ScriptableObject.EMPTY);\n            implementation.defineProperty(\n                    \"customValue\", customValueFunction, ScriptableObject.EMPTY);\n            ScriptableObject.putProperty(scope, \"implementation\", implementation);\n\n            Object wrapper =\n                    context.evaluateString(\n                            scope,\n                            \"\"\"\n                            new JavaAdapter(\n                                Packages.java.util.ArrayList,\n                                Packages.java.util.List,\n                                Packages.java.lang.Runnable,\n                                implementation);\n                            \"\"\",\n                            \"javaAdapterTest\",\n                            1,\n                            null);\n\n            assertThat(wrapper).isInstanceOf(Wrapper.class);\n            Object adapter = ((Wrapper) wrapper).unwrap();\n            assertThat(adapter).isInstanceOf(Runnable.class).isInstanceOf(List.class);\n            List<Object> adapterList = asObjectList(adapter);\n            assertThat(adapterList).isEmpty();\n            assertThat(adapterList.add(\"seed\")).isTrue();\n            assertThat(adapterList).containsExactly(\"seed\");\n            Runnable.class.cast(adapter).run();\n            assertThat(runFunction.callCount()).isOne();\n\n            Object copiedAdapter = roundTripAdapter(scope, adapter);\n            assertThat(copiedAdapter).isInstanceOf(Runnable.class).isInstanceOf(List.class);\n            assertThat(asObjectList(copiedAdapter)).isEmpty();\n            Runnable.class.cast(copiedAdapter).run();\n","newText":"            ScriptableObject scope = context.initStandardObjects();\n            JavaAdapter.init(context, scope, false);\n            RecordingFunction runFunction = new RecordingFunction();\n            RecordingFunction customValueFunction = new RecordingFunction();\n            ScriptRuntime.setFunctionProtoAndParent(runFunction, context, scope);\n            ScriptRuntime.setFunctionProtoAndParent(customValueFunction, context, scope);\n            NativeObject implementation = new NativeObject();\n            ScriptRuntime.setObjectProtoAndParent(implementation, scope);\n            implementation.defineProperty(\"run\", runFunction, ScriptableObject.EMPTY);\n            implementation.defineProperty(\n                    \"customValue\", customValueFunction, ScriptableObject.EMPTY);\n\n            Object constructor = ScriptableObject.getProperty(scope, \"JavaAdapter\");\n            Object wrapper =\n                    Function.class\n                            .cast(constructor)\n                            .construct(\n                                    context,\n                                    scope,\n                                    new Object[] {\n                                        new NativeJavaClass(scope, AdapterBase.class),\n                                        new NativeJavaClass(scope, AdapterMarker.class),\n                                        implementation\n                                    });\n\n            assertThat(wrapper).isInstanceOf(Wrapper.class);\n            Object adapter = ((Wrapper) wrapper).unwrap();\n            assertThat(adapter).isInstanceOf(AdapterMarker.class);\n            AdapterMarker marker = AdapterMarker.class.cast(adapter);\n            assertThat(marker.baseValue()).isEqualTo(\"base\");\n            marker.run();\n            assertThat(runFunction.callCount()).isOne();\n\n            Object copiedAdapter = roundTripAdapter(scope, adapter);\n            assertThat(copiedAdapter).isInstanceOf(AdapterMarker.class);\n            assertThat(AdapterMarker.class.cast(copiedAdapter).baseValue()).isEqualTo(\"base\");\n            AdapterMarker.class.cast(copiedAdapter).run();\n"},{"oldText":"    @SuppressWarnings(\"unchecked\")\n    private List<Object> asObjectList(Object value) {\n        return (List<Object>) value;\n    }\n\n    private Object roundTripAdapter(Scriptable scope, Object adapter) throws Exception {\n","newText":"    private Object roundTripAdapter(Scriptable scope, Object adapter) throws Exception {\n"},{"oldText":"    private static final class RecordingFunction extends BaseFunction implements Serializable {\n","newText":"    public interface AdapterMarker extends Runnable {\n        String baseValue();\n    }\n\n    public static class AdapterBase implements AdapterMarker, Serializable {\n        private static final long serialVersionUID = 1L;\n\n        @Override\n        public String baseValue() {\n            return \"base\";\n        }\n\n        @Override\n        public void run() {}\n\n        public Object customValue(Object value) {\n            return value;\n        }\n    }\n\n    private static final class RecordingFunction extends BaseFunction implements Serializable {\n"}]}
