js.javascript.Wrapper;\n", "newText": "import java.io.Serializable;\nimport java.util.ArrayList;\nimport java.util.List;\nimport net.sourceforge.htmlunit.corejs.javascript.BaseFunction;\nimport net.sourceforge.htmlunit.corejs.javascript.Context;\nimport net.sourceforge.htmlunit.corejs.javascript.JavaAdapter;\nimport net.sourceforge.htmlunit.corejs.javascript.NativeObject;\nimport net.sourceforge.htmlunit.corejs.javascript.ObjToIntMap;\nimport net.sourceforge.htmlunit.corejs.javascript.Scriptable;\nimport net.sourceforge.htmlunit.corejs.javascript.ScriptableObject;\nimport net.sourceforge.htmlunit.corejs.javascript.Wrapper;\n"}, {"oldText": "            ScriptableObject scope = context.initStandardObjects();\n            Object wrapper =\n                    context.evaluateString(\n                            scope,\n                            \"\"\"\n                            var state = { ran: false };\n                            var adapter = new JavaAdapter(\n                                Packages.java.util.ArrayList,\n                                Packages.java.util.List,\n                                Packages.java.lang.Runnable,\n                                {\n                                    run: function() {\n                                        state.ran = true;\n                                    },\n                                    customValue: function(value) {\n                                        return 'custom:' + value;\n                                    }\n                                });\n                            adapter.add('seed');\n                            adapter.run();\n                            if (!state.ran) {\n                                throw 'run was not called';\n                            }\n                            adapter;\n                            \"\"\",\n                            \"javaAdapterTest\",\n                            1,\n                            null);\n\n            assertThat(wrapper).isInstanceOf(Wrapper.class);\n            Object adapter = ((Wrapper) wrapper).unwrap();\n            assertThat(adapter).isInstanceOf(Runnable.class).isInstanceOf(List.class);\n            assertThat((List<?>) adapter).contains(\"seed\");\n", "newText": "            ScriptableObject scope = context.initStandardObjects();\n            RecordingFunction runFunction = new RecordingFunction();\n            NativeObject implementation = new NativeObject();\n            implementation.defineProperty(\"run\", runFunction, ScriptableObject.EMPTY);\n            implementation.defineProperty(\"customValue\", new RecordingFunction(), ScriptableObject.EMPTY);\n            ScriptableObject.putProperty(scope, \"implementation\", implementation);\n\n            Object wrapper =\n                    context.evaluateString(\n                            scope,\n                            \"\"\"\n                            new JavaAdapter(\n                                Packages.java.util.ArrayList,\n                                Packages.java.util.List,\n                                Packages.java.lang.Runnable,\n                                implementation);\n                            \"\"\",\n                            \"javaAdapterTest\",\n                            1,\n                            null);\n\n            assertThat(wrapper).isInstanceOf(Wrapper.class);\n            Object adapter = ((Wrapper) wrapper).unwrap();\n            assertThat(adapter).isInstanceOf(Runnable.class).isInstanceOf(List.class);\n            assertThat((List<?>) adapter).isEmpty();\n            ((List<?>) adapter).contains(\"seed\");\n            Runnable.class.cast(adapter).run();\n            assertThat(runFunction.callCount()).isOne();\n"}, {"oldText": "    private Object roundTripAdapter(Scriptable scope, Object adapter) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            JavaAdapter.writeAdapterObject(adapter, output);\n        }\n\n        try (ObjectInputStream input =\n                new ObjectInputStream(new ByteArrayInputStream(bytes.toByteArray()))) {\n            return JavaAdapter.readAdapterObject(scope, input);\n        }\n    }\n}\n", "newText": "    private Object roundTripAdapter(Scriptable scope, Object adapter) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            JavaAdapter.writeAdapterObject(adapter, output);\n        }\n\n        try (ObjectInputStream input =\n                new ObjectInputStream(new ByteArrayInputStream(bytes.toByteArray()))) {\n            return JavaAdapter.readAdapterObject(scope, input);\n        }\n    }\n\n    private static final class RecordingFunction extends BaseFunction implements Serializable {\n        private static final long serialVersionUID = 1L;\n\n        private int callCount;\n\n        @Override\n        public Object call(\n                Context context,\n                Scriptable scope,\n                Scriptable thisObj,\n                Object[] args) {\n            callCount++;\n            return null;\n        }\n\n        int callCount() {\n            return callCount;\n        }\n    }\n}\n"}]}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 269, "output": 3134, "cacheRead": 42496, "cacheWrite": 0, "totalTokens": 45899, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1781041026422, "responseId": "resp_0583090586bb498c016a2887835a788196a4485bfd5e7d11ae"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_q28O2E0LKBcPGdmOwQw4i5A2|fc_0583090586bb498c016a2887c3e5988196bb046a8e74a495a4", "toolName": "edit", "content": [{"type": "text", "text": "Successfully replaced 3 block(s) in tes