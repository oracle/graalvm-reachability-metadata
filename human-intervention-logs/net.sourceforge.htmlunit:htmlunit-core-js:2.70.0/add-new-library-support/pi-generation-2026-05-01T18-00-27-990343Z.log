                              // access to Class.getDeclaredMethods. Fall back to
                              // Class.getMethods.
                              Method[] methods = clazz.getMethods();
                              for (Method method : methods) {
                                  MethodSignature sig = new MethodSignature(method);
                                  if (!map.containsKey(sig)) map.put(sig, method);
