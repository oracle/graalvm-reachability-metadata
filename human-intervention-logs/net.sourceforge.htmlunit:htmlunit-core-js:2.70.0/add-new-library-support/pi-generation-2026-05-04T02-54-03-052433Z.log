  package net_sourceforge_htmlunit.htmlunit_core_js;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.io.Serializable;
  
  import net.sourceforge.htmlunit.corejs.javascript.BaseFunction;
  import net.sourceforge.htmlunit.corejs.javascript.ClassCache;
  import net.sourceforge.htmlunit.corejs.javascript.Context;
  import net.sourceforge.htmlunit.corejs.javascript.Function;
  import net.sourceforge.htmlunit.corejs.javascript.NativeArray;
  import net.sourceforge.htmlunit.corejs.javascript.NativeJavaClass;
  import net.sourceforge.htmlunit.corejs.javascript.NativeJavaObject;
  import net.sourceforge.htmlunit.corejs.javascript.NativeObject;
  import net.sourceforge.htmlunit.corejs.javascript.ScriptRuntime;
  import net.sourceforge.htmlunit.corejs.javascript.Scriptable;
  import net.sourceforge.htmlunit.corejs.javascript.ScriptableObject;
  import net.sourceforge.htmlunit.corejs.javascript.Wrapper;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class NativeJavaObjectTest {
      @Test
      void convertsObjectsWithDoubleValueMethodToPrimitiveDouble() {
          Object converted = Context.jsToJava(new Quantity("12.75"), Double.TYPE);
  
          assertThat(converted).isEqualTo(Double.valueOf(12.75d));
      }
  
      @Test
      void convertsNativeArrayToJavaArray() {
          NativeArray array = new NativeArray(new Object[] {1, "2", 3.8d});
  
          Object converted = Context.jsToJava(array, int[].class);
  
          assertThat(converted).isInstanceOf(int[].class);
          assertThat((int[]) converted).containsExactly(1, 2, 3);
      }
  
      @Test
      void serializesWrappedJavaObjectAndStaticType() throws Exception {
          NativeJavaObject wrapper = new NativeJavaObject(
                  newTopLevelScope(), new SerializableValue("alpha"), SerializableValue.class);
  
          NativeJavaObject restored = roundTrip(wrapper);
  
          assertThat(restored.unwrap()).isEqualTo(new SerializableValue("alpha"));
      }
  
      @Test
      void serializesWrappedJavaObjectWithNullStaticType() throws Exception {
          NativeJavaObject wrapper = new NativeJavaObject(
                  newTopLevelScope(), new SerializableValue("beta"), null);
  
          NativeJavaObject restored = roundTrip(wrapper);
  
          assertThat(restored.unwrap()).isEqualTo(new SerializableValue("beta"));
      }
  
      @Test
      void serializesWrappedJavaAdapter() throws Exception {
          Context cx = Context.enter();
          try {
              Scriptable standardScope = cx.initStandardObjects();
              Object adapter = newGreetingAdapter(cx, standardScope);
              NativeJavaObject wrapper = new NativeJavaObject(
                      newTopLevelScope(), adapter, GreetingService.class, true);
  
              NativeJavaObject restored = roundTrip(wrapper);
  
              assertThat(restored.unwrap()).isInstanceOf(GreetingService.class);
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          } finally {
              Context.exit();
          }
      }
  
      private static NativeObject newTopLevelScope() {
          NativeObject scope = new NativeObject();
          new ClassCache().associate(scope);
          return scope;
      }
  
      private static NativeJavaObject roundTrip(NativeJavaObject wrapper) throws Exception {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {
              output.writeObject(wrapper);
          }
  
          try (ObjectInputStream input = new ObjectInputStream(
                  new ByteArrayInputStream(bytes.toByteArray()))) {
              return (NativeJavaObject) input.readObject();
          }
      }
  
      private static Object newGreetingAdapter(Context cx, Scriptable scope) {
          Object constructor = ScriptableObject.getProperty(scope, "JavaAdapter");
          NativeJavaClass interfaceClass = new NativeJavaClass(scope, GreetingService.class, true);
          NativeObject delegee = new NativeObject();
          ScriptRuntime.setObjectProtoAndParent(delegee, scope);
          GreetingFunction greet = new GreetingFunction();
          ScriptRuntime.setFunctionProtoAndParent(greet, cx, scope, false);
          ScriptableObject.putProperty(delegee, "greet", greet);
  
          Object self = ((Function) constructor)
                  .construct(cx, scope, new Object[] {interfaceClass, delegee});
          Object adapter = ((Wrapper) self).unwrap();
          delegee.setParentScope(null);
          delegee.setPrototype(null);
          greet.setParentScope(null);
          greet.setPrototype(null);
          return adapter;
      }
  
      public static final class Quantity {
          private final String value;
  
          Quantity(String value) {
              this.value = value;
          }
  
          public Number doubleValue() {
              return Double.valueOf(value);
          }
      }
  
      public static final class SerializableValue implements Serializable {
          private static final long serialVersionUID = 1L;
  
          private final String value;
  
          public SerializableValue(String value) {
              this.value = value;
          }
  
          @Override
          public boolean equals(Object other) {
              if (this == other) {
                  return true;
              }
              if (!(other instanceof SerializableValue)) {
                  return false;
              }
              SerializableValue that = (SerializableValue) other;
              return value.equals(that.value);
          }
  
          @Override
          public int hashCode() {
              return value.hashCode();
          }
      }
  
      public interface GreetingService {
          String greet(String name);
      }
  
      public static final class GreetingFunction extends BaseFunction implements Serializable {
          private static final long serialVersionUID = 1L;
  
          @Override
          public Object call(Context cx, Scriptable scope, Scriptable thisObj, Object[] args) {
              return "hello " + Context.toString(args[0]);
          }
  
          @Override
          public int getLength() {
              return 1;
          }
      }
  }
