  package net_sourceforge_htmlunit.htmlunit_core_js;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  
  import net.sourceforge.htmlunit.corejs.javascript.UintMap;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class UintMapTest {
      @Test
      void serializesObjectAndIntegerValues() throws Exception {
          UintMap map = new UintMap(2);
          map.put(7, 70);
          map.put(7, "seven");
          map.put(11, "eleven");
          map.put(13, 130);
          map.put(17, "removed");
          map.remove(17);
  
          UintMap restored = roundTrip(map);
  
          assertThat(restored.size()).isEqualTo(3);
          assertThat(restored.getKeys()).containsExactlyInAnyOrder(7, 11, 13);
          assertThat(restored.getInt(7, -1)).isEqualTo(70);
          assertThat(restored.getObject(7)).isEqualTo("seven");
          assertThat(restored.getInt(11, -1)).isZero();
          assertThat(restored.getObject(11)).isEqualTo("eleven");
          assertThat(restored.getInt(13, -1)).isEqualTo(130);
          assertThat(restored.getObject(13)).isNull();
          assertThat(restored.has(17)).isFalse();
      }
  
      private static UintMap roundTrip(UintMap map) throws Exception {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {
              output.writeObject(map);
          }
  
          try (ObjectInputStream input = new ObjectInputStream(
                  new ByteArrayInputStream(bytes.toByteArray()))) {
              return (UintMap) input.readObject();
          }
      }
  }
