mberBoxTest {\n    @Test\n    void invokesAndSerializesMethodBackedFunctionObject() throws Exception {\n        Context cx = Context.enter();\n        try {\n            Scriptable scope = cx.initStandardObjects();\n            FunctionObject function = new FunctionObject(\n                    \"format\",\n                    MethodBackedFunctions.class.getMethod(\n                            \"format\", String.class, int.class, Object.class),\n                    scope);\n\n            Object result = function.call(cx, scope, scope, new Object[] {\"alpha\", 7, \"omega\"});\n            assertThat(result).isEqualTo(\"alpha:7:omega\");\n\n            FunctionObject restored = roundTrip(function);\n            Object restoredResult = restored.call(cx, scope, scope, new Object[] {\"beta\", 11, \"delta\"});\n            assertThat(restoredResult).isEqualTo(\"beta:11:delta\");\n        } finally {\n            Context.exit();\n        }\n    }\n\n    @Test\n    void invokesAndSerializesConstructorBackedFunctionObject() throws Exception {\n        Context cx = Context.enter();\n        try {\n            Scriptable scope = cx.initStandardObjects();\n            FunctionObject constructor = new FunctionObject(\n                    \"PublicConstructedScriptable\",\n                    PublicConstructedScriptable.class.getConstructor(),\n                    scope);\n\n            Object created = constructor.call(cx, scope, null, new Object[0]);\n            assertThat(created).isInstanceOf(PublicConstructedScriptable.class);\n\n            FunctionObject restored = roundTrip(constructor);\n            Object restoredCreated = restored.call(cx, scope, null, new Object[0]);\n            assertThat(restoredCreated).isInstanceOf(PublicConstructedScriptable.class);\n        } finally {\n            Context.exit();\n        }\n    }\n\n    @Test\n    void recoversInaccessibleInterfaceMethodThroughPublicInterface() throws Exception {\n        Context cx = Context.enter();\n        try {\n            Scriptable scope = cx.initStandardObjects();\n            HiddenInterfaceOperation target = new HiddenInterfaceOperation();\n            FunctionObject function = new FunctionObject(\n                    \"describe\",\n                    HiddenInterfaceOperation.class.getDeclaredMethod(\"describe\", String.class),\n                    scope);\n\n            Object result = function.call(cx, scope, target, new Object[] {\"interface\"});\n\n            assertThat(result).isEqualTo(\"hidden-interface:interface\");\n        } finally {\n            Context.exit();\n        }\n    }\n\n    @Test\n    void recoversInaccessibleSuperclassMethodThroughPublicSuperclass() throws Exception {\n        Context cx = Context.enter();\n        try {\n            Scriptable scope = cx.initStandardObjects();\n            HiddenSuperclassOperation target = new HiddenSuperclassOperation();\n            FunctionObject function = new FunctionObject(\n                    \"describe\",\n                    HiddenSuperclassOperation.class.getDeclaredMethod(\"describe\", String.class),\n                    scope);\n\n            Object result = function.call(cx, scope, target, new Object[] {\"superclass\"});\n\n            assertThat(result).isEqualTo(\"hidden-superclass:superclass\");\n        } finally {\n            Context.exit();\n        }\n    }\n\n    @Test\n    void retriesInaccessibleConstructorAfterMakingItAccessible() throws Exception {\n        Context cx = Context.enter();\n        try {\n            Scriptable scope = cx.initStandardObjects();\n            FunctionObject constructor = new FunctionObject(\n                    \"HiddenConstructedScriptable\",\n                    HiddenConstructedScriptable.class.getDeclaredConstructor(),\n                    scope);\n\n            Object created = constructor.call(cx, scope, null, new Object[0]);\n\n            assertThat(created).isInstanceOf(HiddenConstructedScriptable.class);\n            assertThat(((HiddenConstructedScriptable) created).createdByPrivateConstructor)\n                    .isTrue();\n        } finally {\n            Context.exit();\n        }\n    }\n\n    private static FunctionObject roundTrip(FunctionObject function) throws Exception {\n        function.setParentScope(null);\n        function.setPrototype(null);\n\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(function);\n        }\n\n        try (ObjectInputStream input = new ObjectInputStream(\n                new ByteArrayInputStream(bytes.toByteArray()))) {\n            return (FunctionObject) input.readObject();\n        }\n    }\n\n    public static final class MethodBackedFunctions {\n        private MethodBackedFunctions() {\n        }\n\n        public static String format(String value, int number, Object suffix) {\n            return value + ':' + number + ':' + suffix;\n        }\n    }\n\n    public static class PublicConstructedScriptable extends ScriptableObject {\n        private static final long serialVersionUID = 1L;\n\n        public PublicConstructedScriptable() {\n        }\n\n        @Override\n        public String getClassName() {\n            return \"PublicConstructedScriptable\";\n        }\n    }\n\n    public interface PublicInterfaceOperation {\n        String describe(String value);\n    }\n\n    private static final class HiddenInterfaceOperation implements PublicInterfaceOperation {\n        @Override\n        public String describe(String value) {\n            return \"hidden-interface:\" + value;\n        }\n    }\n\n    public static class PublicSuperclassOperation {\n        public String describe(String value) {\n            return \"public-superclass:\" + value;\n        }\n    }\n\n    private static final class HiddenSuperclassOperation extends PublicSuperclassOperation {\n        @Override\n        public String describe(String value) {\n            return \"hidden-superclass:\" + value;\n        }\n    }\n\n    private static final class HiddenConstructedScriptable extends ScriptableObject {\n        private static final long serialVersionUID = 1L;\n\n        private final boolean createdByPrivateConstructor;\n\n        private HiddenConstructedScriptable() {\n            createdByPrivateConstructor = true;\n        }\n\n        @Override\n        public String getClassName() {\n            return \"HiddenConstructedScriptable\";\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777848787016}]}
