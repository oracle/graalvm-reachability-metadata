  +package net_sourceforge_htmlunit.htmlunit_core_js;
  +
  +import java.io.ByteArrayInputStream;
  +import java.io.ByteArrayOutputStream;
  +import java.io.IOException;
  +import java.io.ObjectInputStream;
  +import java.io.ObjectOutputStream;
  +
  +import net.sourceforge.htmlunit.corejs.javascript.ObjToIntMap;
  +
  +import org.junit.jupiter.api.Test;
  +
  +import static org.assertj.core.api.Assertions.assertThat;
  +
  +public class ObjToIntMapTest {
  +    @Test
  +    void serializesAndDeserializesPresentEntries() throws Exception {
  +        ObjToIntMap original = new ObjToIntMap(2);
  +        original.put("alpha", 11);
  +        original.put(null, 22);
  +        original.put(Integer.valueOf(3), 33);
  +        original.put("removed", 44);
  +        original.remove("removed");
  +
  +        ObjToIntMap restored = roundTrip(original);
  +
  +        assertThat(restored.size()).isEqualTo(3);
  +        assertThat(restored.get("alpha", -1)).isEqualTo(11);
  +        assertThat(restored.get(null, -1)).isEqualTo(22);
  +        assertThat(restored.get(Integer.valueOf(3), -1)).isEqualTo(33);
  +        assertThat(restored.has("removed")).isFalse();
  +        assertThat(restored.getKeys()).containsExactlyInAnyOrder("alpha", null, Integer.valueOf(3));
  +    }
  +
  +    private static ObjToIntMap roundTrip(ObjToIntMap map) throws IOException, ClassNotFoundException {
  +        ByteArrayOutputStream bytes = new ByteArrayOutputStream();
  +        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {
  +            output.writeObject(map);
  +        }
  +
  +        try (ObjectInputStream input = new ObjectInputStream(
  +                new ByteArrayInputStream(bytes.toByteArray()))) {
  +            return (ObjToIntMap) input.readObject();
  +        }
  +    }
  +}
