              keyArg = UniqueTag.NULL_VALUE;
          }
          int index = ensureIndex(keyArg);
          values[index] = 0;
          return (nullKey) ? null : keys[index];
      }
  
      public void remove(Object key) {
          if (key == null) {
              key = UniqueTag.NULL_VALUE;
          }
