tStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\n\nimport net.sourceforge.htmlunit.corejs.javascript.Context;\nimport net.sourceforge.htmlunit.corejs.javascript.FunctionObject;\nimport net.sourceforge.htmlunit.corejs.javascript.Scriptable;\nimport net.sourceforge.htmlunit.corejs.javascript.ScriptableObject;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class MemberBoxTest {\n    @Test\n    void invokesAndSerializesMethodBackedFunctionObject() throws Exception {\n        Context cx = Context.enter();\n        try {\n            Scriptable scope = cx.initStandardObjects();\n            FunctionObject function = new FunctionObject(\n                    \"format\",\n                    MethodBackedFunctions.class.getMethod(\n                            \"format\", String.class, int.class, Object.class),\n                    scope);\n\n            Object result = function.call(cx, scope, scope, new Object[] {\"alpha\", 7, \"omega\"});\n            assertThat(result).isEqualTo(\"alpha:7:omega\");\n\n            FunctionObject restored = roundTrip(function);\n            Object restoredResult = restored.call(\n                    cx, scope, scope, new Object[] {\"beta\", 11, \"delta\"});\n            assertThat(restoredResult).isEqualTo(\"beta:11:delta\");\n        } finally {\n            Context.exit();\n        }\n    }\n\n    @Test\n    void invokesAndSerializesConstructorBackedFunctionObject() throws Exception {\n        Context cx = Context.enter();\n        try {\n            Scriptable scope = cx.initStandardObjects();\n            FunctionObject constructor = new FunctionObject(\n                    \"PublicConstructedScriptable\",\n                    PublicConstructedScriptable.class.getConstructor(),\n                    scope);\n\n            Object created = constructor.call(cx, scope, null, new Object[0]);\n            assertThat(created).isInstanceOf(PublicConstructedScriptable.class);\n\n            FunctionObject restored = roundTrip(constructor);\n            Object restoredCreated = restored.call(cx, scope, null, new Object[0]);\n            assertThat(restoredCreated).isInstanceOf(PublicConstructedScriptable.class);\n        } finally {\n            Context.exit();\n        }\n    }\n\n    @Test\n    void recoversInaccessibleInterfaceMethodThroughPublicInterface() throws Exception {\n        Context cx = Context.enter();\n        try {\n            Scriptable scope = cx.initStandardObjects();\n            HiddenInterfaceOperation target = new HiddenInterfaceOperation();\n            FunctionObject function = new FunctionObject(\n                    \"describe\",\n                    HiddenInterfaceOperation.class.getDeclaredMethod(\"describe\", String.class),\n                    scope);\n\n            Object result = function.call(cx, scope, target, new Object[] {\"interface\"});\n\n            assertThat(result).isEqualTo(\"hidden-interface:interface\");\n        } finally {\n            Context.exit();\n        }\n    }\n\n    @Test\n    void recoversInaccessibleSuperclassMethodThroughPublicSuperclass() throws Exception {\n        Context cx = Context.enter();\n        try {\n            Scriptable scope = cx.initStandardObjects();\n            HiddenSuperclassOperation target = new HiddenSuperclassOperation();\n            FunctionObject function = new FunctionObject(\n                    \"describe\",\n                    HiddenSuperclassOperation.class.getDeclaredMethod(\"describe\", String.class),\n                    scope);\n\n            Object result = function.call(cx, scope, target, new Object[] {\"superclass\"});\n\n            assertThat(result).isEqualTo(\"hidden-superclass:superclass\");\n        } finally {\n            Context.exit();\n        }\n    }\n\n    @Test\n    void retriesInaccessibleConstructorAfterMakingItAccessible() throws Exception {\n        Context