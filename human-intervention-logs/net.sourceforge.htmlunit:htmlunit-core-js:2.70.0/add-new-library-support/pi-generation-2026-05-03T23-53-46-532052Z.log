ived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage net_sourceforge_htmlunit.htmlunit_core_js;\n\nimport net.sourceforge.htmlunit.corejs.javascript.Context;\nimport net.sourceforge.htmlunit.corejs.javascript.ContextFactory;\nimport net.sourceforge.htmlunit.corejs.javascript.NativeJavaClass;\nimport net.sourceforge.htmlunit.corejs.javascript.NativeJavaObject;\nimport net.sourceforge.htmlunit.corejs.javascript.Scriptable;\nimport net.sourceforge.htmlunit.corejs.javascript.Wrapper;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class JavaMembersTest {\n    @Test\n    void readsAndWritesReflectedPublicInstanceField() {\n        Context cx = Context.enter();\n        try {\n            Scriptable scope = cx.initStandardObjects();\n            PublicFieldBean bean = new PublicFieldBean(7);\n            NativeJavaObject wrapped = new NativeJavaObject(scope, bean, PublicFieldBean.class);\n\n            Object initialValue = wrapped.get(\"count\", wrapped);\n            wrapped.put(\"count\", wrapped, 42);\n\n            assertThat(initialValue).isEqualTo(7);\n            assertThat(bean.count).isEqualTo(42);\n        } finally {\n            Context.exit();\n        }\n    }\n\n    @Test\n    void reflectsDeclaredConstructorsWhenEnhancedJavaAccessIsEnabled() {\n        Context cx = new EnhancedJavaAccessContextFactory().enterContext();\n        try {\n            Scriptable scope = cx.initStandardObjects();\n            NativeJavaClass javaClass = new NativeJavaClass(scope, PrivateConstructedValue.class);\n\n            Scriptable constructed = javaClass.construct(cx, scope, new Object[] {\"created\"});\n\n            assertThat(((Wrapper) constructed).unwrap())\n                    .isEqualTo(new PrivateConstructedValue(\"created\"));\n        } finally {\n            Context.exit();\n        }\n    }\n\n    public static final class PublicFieldBean {\n        public int count;\n\n        PublicFieldBean(int count) {\n            this.count = count;\n        }\n\n        public String describe() {\n            return \"count=\" + count;\n        }\n    }\n\n    public static final class PrivateConstructedValue {\n        private final String value;\n\n        private PrivateConstructedValue(String value) {\n            this.value = value;\n        }\n\n        @Override\n        public boolean equals(Object other) {\n            if (this == other) {\n                return true;\n            }\n            if (!(other instanceof PrivateConstructedValue)) {\n                return false;\n            }\n            PrivateConstructedValue that = (PrivateConstructedValue) other;\n            return value.equals(that.value);\n        }\n\n        @Override\n        public int hashCode() {\n            return value.hashCode();\n        }\n    }\n\n    private static final class EnhancedJavaAccessContextFactory extends ContextFactory {\n        @Override\n        protected boolean hasFeature(Context cx, int featureIndex) {\n            if (featureIndex == Context.FEATURE_ENHANCED_JAVA_ACCESS) {\n                return true;\n            }\n            return super.hasFeature(cx, featureIndex);\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1228, "output": 2041, "cacheRead": 31744, "cacheWrite": 0, "totalTokens": 35013, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777852353473, "responseId": "resp_0c7ba5d74865d9270169f7dfc1e82c819f9462371941428c58"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_b3eGiswp3pYDckNYaBRUUABX|fc_0c7ba5d74865d9270169f7dfd4e7b4819fbbe43271a3bd7d3b", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 3276 bytes to tests/src/net.sourceforge.htmlunit/htmlu