  package net_sourceforge_htmlunit.htmlunit_core_js;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.io.Serializable;
  
  import net.sourceforge.htmlunit.corejs.javascript.BaseFunction;
  import net.sourceforge.htmlunit.corejs.javascript.Context;
  import net.sourceforge.htmlunit.corejs.javascript.Function;
  import net.sourceforge.htmlunit.corejs.javascript.JavaAdapter;
  import net.sourceforge.htmlunit.corejs.javascript.NativeJavaClass;
  import net.sourceforge.htmlunit.corejs.javascript.NativeObject;
  import net.sourceforge.htmlunit.corejs.javascript.ObjToIntMap;
  import net.sourceforge.htmlunit.corejs.javascript.ScriptRuntime;
  import net.sourceforge.htmlunit.corejs.javascript.Scriptable;
  import net.sourceforge.htmlunit.corejs.javascript.ScriptableObject;
  import net.sourceforge.htmlunit.corejs.javascript.Wrapper;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class JavaAdapterTest {
      @Test
      void createsAdapterCodeForSuperclassAndInterfaces() {
          ObjToIntMap functionNames = new ObjToIntMap();
          functionNames.put("mustOverride", 1);
          functionNames.put("concreteMethod", 0);
          functionNames.put("additionalMethod", 2);
  
          byte[] bytecode = JavaAdapter.createAdapterCode(
                  functionNames,
                  "GeneratedAdapterForCoverage",
                  AdapterSuperclass.class,
                  new Class<?>[] {AdapterInterface.class},
                  null);
  
          assertThat(bytecode).isNotEmpty();
      }
  
      @Test
      void createsSerializesAndDeserializesScriptBackedAdapter() throws Exception {
          Context cx = Context.enter();
          try {
              Scriptable scope = cx.initStandardObjects();
              AdapterFixture adapter = newGreetingAdapter(cx, scope);
  
              assertThat(adapter.self()).isInstanceOf(Wrapper.class);
              Object adapterObject = ((Wrapper) adapter.self()).unwrap();
              assertThat(adapterObject).isInstanceOf(GreetingService.class);
              assertThat(((GreetingService) adapterObject).greet("Ada")).isEqualTo("hello Ada");
              assertThat(JavaAdapter.getAdapterSelf(adapterObject.getClass(), adapterObject))
                      .isSameAs(adapter.self());
  
              adapter.detachDelegateFromTopLevelScope();
              byte[] serializedAdapter = serializeAdapter(adapterObject);
              Object restoredAdapter = deserializeAdapter(scope, serializedAdapter);
  
              assertThat(restoredAdapter).isInstanceOf(GreetingService.class);
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          } finally {
              Context.exit();
          }
      }
  
      private static AdapterFixture newGreetingAdapter(Context cx, Scriptable scope) {
          Object constructor = ScriptableObject.getProperty(scope, "JavaAdapter");
          NativeJavaClass interfaceClass = new NativeJavaClass(scope, GreetingService.class, true);
          NativeObject delegee = new NativeObject();
          ScriptRuntime.setObjectProtoAndParent(delegee, scope);
          GreetingFunction greet = new GreetingFunction();
          ScriptRuntime.setFunctionProtoAndParent(greet, cx, scope, false);
          ScriptableObject.putProperty(delegee, "greet", greet);
  
          Object self = ((Function) constructor)
                  .construct(cx, scope, new Object[] {interfaceClass, delegee});
          return new AdapterFixture(self, delegee, greet);
      }
  
      private static byte[] serializeAdapter(Object adapterObject) throws Exception {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {
              JavaAdapter.writeAdapterObject(adapterObject, output);
          }
          return bytes.toByteArray();
      }
  
      private static Object deserializeAdapter(Scriptable self, byte[] serializedAdapter)
              throws Exception {
          ByteArrayInputStream bytes = new ByteArrayInputStream(serializedAdapter);
          try (ObjectInputStream input = new ObjectInputStream(bytes)) {
              return JavaAdapter.readAdapterObject(self, input);
          }
      }
  
      private record AdapterFixture(Object self, NativeObject delegee, GreetingFunction greet) {
          void detachDelegateFromTopLevelScope() {
              delegee.setParentScope(null);
              delegee.setPrototype(null);
              greet.setParentScope(null);
              greet.setPrototype(null);
          }
      }
  
      public interface GreetingService {
          String greet(String name);
      }
  
      public interface SuperclassInterface {
          String inheritedInterfaceMethod();
      }
  
      public interface AdapterInterface {
          String mustOverride(String value);
  
          String implementedBySuperclass(String value);
      }
  
      public static class AdapterSuperclass implements SuperclassInterface {
          public AdapterSuperclass() {
          }
  
          public AdapterSuperclass(String ignored) {
          }
  
          @Override
          public String inheritedInterfaceMethod() {
              return "inherited";
          }
  
          public String implementedBySuperclass(String value) {
              return "super " + value;
          }
  
          public String concreteMethod() {
              return "concrete";
          }
  
          protected String protectedMethod() {
              return "protected";
          }
  
          public final String finalMethod() {
              return "final";
          }
      }
  
      public static final class GreetingFunction extends BaseFunction implements Serializable {
          private static final long serialVersionUID = 1L;
  
          @Override
          public Object call(Context cx, Scriptable scope, Scriptable thisObj, Object[] args) {
              return "hello " + Context.toString(args[0]);
          }
  
          @Override
          public int getLength() {
              return 1;
          }
      }
  }
