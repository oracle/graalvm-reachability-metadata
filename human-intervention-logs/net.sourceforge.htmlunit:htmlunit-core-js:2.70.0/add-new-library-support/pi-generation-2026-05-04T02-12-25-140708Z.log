  package net_sourceforge_htmlunit.htmlunit_core_js;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  
  import net.sourceforge.htmlunit.corejs.javascript.ObjToIntMap;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ObjToIntMapTest {
      @Test
      void serializesEntriesWithTheirIntegerValues() throws Exception {
          ObjToIntMap map = new ObjToIntMap();
          map.put("first", 10);
          map.put("second", 20);
          map.put("removed", 30);
          map.remove("removed");
  
          ObjToIntMap restored = roundTrip(map);
  
          assertThat(restored.size()).isEqualTo(2);
          assertThat(restored.get("first", -1)).isEqualTo(10);
          assertThat(restored.get("second", -1)).isEqualTo(20);
          assertThat(restored.has("removed")).isFalse();
          assertThat(restored.getKeys()).containsExactlyInAnyOrder("first", "second");
      }
  
      private static ObjToIntMap roundTrip(ObjToIntMap map) throws Exception {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {
              output.writeObject(map);
          }
  
          try (ObjectInputStream input = new ObjectInputStream(
                  new ByteArrayInputStream(bytes.toByteArray()))) {
              return (ObjToIntMap) input.readObject();
          }
