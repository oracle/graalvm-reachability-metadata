      @Test
      void defineFunctionPropertiesFallsBackToPublicMethodsWhenDeclaredAccessIsDenied()
              throws Exception {
          try {
              runDeclaredMemberAccessDeniedFallback();
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
      }
  
      @SuppressWarnings("removal")
      private static void runDeclaredMemberAccessDeniedFallback() throws Exception {
          Class<?> loadedFunctionsClass = new ByteArrayClassLoader().define(
                  "net_sourceforge_htmlunit.htmlunit_core_js.FunctionObjectPublicFallbackFunctions",
                  Base64.getMimeDecoder().decode(PUBLIC_FALLBACK_FUNCTIONS_CLASS));
  
          Context context = Context.enter();
          try {
              ScriptableObject scope = (ScriptableObject) context.initStandardObjects();
              DeclaredMemberDenyingSecurityManager securityManager =
                      new DeclaredMemberDenyingSecurityManager();
              SecurityManager previousSecurityManager = System.getSecurityManager();
              boolean securityManagerInstalled = installSecurityManagerIfSupported(securityManager);
              try {
                  securityManager.setDenyNextPermissionCheck(securityManagerInstalled);
                  scope.defineFunctionProperties(
                          new String[] {"publicFallbackFunction"},
                          loadedFunctionsClass,
                          ScriptableObject.DONTENUM);
              } finally {
                  securityManager.setDenyNextPermissionCheck(false);
                  if (securityManagerInstalled) {
                      System.setSecurityManager(previousSecurityManager);
                  }
              }
  
              Function function = (Function) ScriptableObject.getProperty(
                      scope,
                      "publicFallbackFunction");
              Object result = function.call(
                      context,
                      scope,
                      scope,
                      new Object[] {"value"});
  
              assertThat(Context.toString(result)).isEqualTo("fallback:value");
          } finally {
              Context.exit();
          }
      }
  
      @Test
      void constructUsesDefaultConstructorForFunctionObjectsBackedByInstanceMethod()
              throws Exception {
          Context context = Context.enter();
          try {
              Scriptable scope = context.initStandardObjects();
              String className = ScriptableObject.defineClass(
                      scope,
                      ConstructibleScriptable.class,
                      false,
                      false);
  
              Function constructor = (Function) ScriptableObject.getProperty(
                      scope,
                      "ConstructibleScriptable");
              Scriptable created = constructor.construct(
                      context,
                      scope,
                      new Object[] {"Ada"});
  
              assertThat(className).isEqualTo("ConstructibleScriptable");
              assertThat(created).isInstanceOf(ConstructibleScriptable.class);
              assertThat(((ConstructibleScriptable) created).getName()).isEqualTo("Ada");
              assertThat(created.getPrototype()).isNotNull();
              assertThat(created.getParentScope()).isSameAs(scope);
          } finally {
              Context.exit();
          }
      }
  
