  package net_sourceforge_htmlunit.htmlunit_core_js;
  
  import net.sourceforge.htmlunit.corejs.javascript.Context;
  import net.sourceforge.htmlunit.corejs.javascript.ContextFactory;
  import net.sourceforge.htmlunit.corejs.javascript.tools.debugger.Main;
  
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ContextTest {
      @Test
      @SuppressWarnings("deprecation")
      void addContextListenerAttachesDebuggerListenerReflectively() {
          Main.resetAttachedFactory();
          Main listener = new Main();
  
          Context.addContextListener(listener);
  
          assertThat(Main.getAttachedFactory()).isSameAs(ContextFactory.getGlobal());
      }
  }
