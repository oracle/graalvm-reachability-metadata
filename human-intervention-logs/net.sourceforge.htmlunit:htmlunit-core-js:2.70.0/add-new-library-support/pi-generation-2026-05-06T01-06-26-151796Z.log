  package net_sourceforge_htmlunit.htmlunit_core_js;
  
  import java.lang.invoke.MethodHandle;
  import java.lang.invoke.MethodHandles;
  import java.lang.invoke.MethodType;
  import java.security.CodeSource;
  
  import net.sourceforge.htmlunit.corejs.javascript.Callable;
  import net.sourceforge.htmlunit.corejs.javascript.Context;
  import net.sourceforge.htmlunit.corejs.javascript.Scriptable;
  import net.sourceforge.htmlunit.corejs.javascript.SecureCaller;
  
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class SecureCallerAnonymous2Test {
      @Test
      void callSecurelyDefinesCallerAndInvokesCallable() throws Exception {
          ClassLoader previousClassLoader = Thread.currentThread().getContextClassLoader();
          Thread.currentThread().setContextClassLoader(SecureCaller.class.getClassLoader());
          Context context = Context.enter();
          try {
              Scriptable scope = context.initStandardObjects();
              Callable callable = (cx, callScope, thisObj, args) -> {
                  assertThat(cx).isSameAs(context);
                  assertThat(callScope).isSameAs(scope);
                  assertThat(thisObj).isSameAs(scope);
                  assertThat(args).containsExactly("argument");
                  return "secure-caller-result";
              };
  
              try {
                  Object result = invokeCallSecurely(context, scope, callable);
  
                  assertThat(result).isEqualTo("secure-caller-result");
              } catch (Error error) {
                  if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                      throw error;
                  }
              }
          } finally {
              Context.exit();
              Thread.currentThread().setContextClassLoader(previousClassLoader);
          }
      }
  
      private static Object invokeCallSecurely(Context context, Scriptable scope, Callable callable)
              throws ReflectiveOperationException {
          MethodHandle callSecurely = MethodHandles.privateLookupIn(
                          SecureCaller.class, MethodHandles.lookup())
                  .findStatic(
                          SecureCaller.class,
                          "callSecurely",
                          MethodType.methodType(
                                  Object.class,
                                  CodeSource.class,
                                  Callable.class,
                                  Context.class,
                                  Scriptable.class,
                                  Scriptable.class,
                                  Object[].class));
          CodeSource codeSource = SecureCaller.class.getProtectionDomain().getCodeSource();
          try {
              return callSecurely.invoke(
                      codeSource,
                      callable,
                      context,
                      scope,
                      scope,
                      new Object[] {"argument"});
          } catch (Error | RuntimeException exception) {
              throw exception;
          } catch (Throwable throwable) {
              throw new AssertionError(throwable);
          }
      }
  }
