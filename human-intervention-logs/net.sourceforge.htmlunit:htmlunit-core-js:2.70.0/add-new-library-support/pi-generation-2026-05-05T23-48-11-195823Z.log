  package net_sourceforge_htmlunit.htmlunit_core_js;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.IOException;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  
  import net.sourceforge.htmlunit.corejs.javascript.Context;
  import net.sourceforge.htmlunit.corejs.javascript.FunctionObject;
  import net.sourceforge.htmlunit.corejs.javascript.Scriptable;
  import net.sourceforge.htmlunit.corejs.javascript.ScriptableObject;
  
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ScriptableObjectTest {
      @Test
      void invokesSingleArgumentInitWhenDefiningScriptableClass() throws Exception {
          Context.enter();
          try {
              Scriptable scope = Context.getCurrentContext().initStandardObjects();
  
              ScriptableObject.defineClass(
                      scope,
                      SingleArgumentInitScriptable.class);
  
              assertThat(ScriptableObject.getProperty(scope, "singleArgumentInit"))
                      .isEqualTo("called");
          } finally {
              Context.exit();
          }
      }
  
      @Test
      void definesClassByConstructingPrototypeAndRunningFinishInit() throws Exception {
          Context context = Context.enter();
          try {
              if (NativeImageSupport.isNativeImageRuntime()) {
                  context.setOptimizationLevel(-1);
              }
              Scriptable scope = context.initStandardObjects();
  
              String className = ScriptableObject.defineClass(
                      scope,
                      FinishInitScriptable.class,
                      false,
                      false);
              Object result = context.evaluateString(scope, """
                      var sample = new FinishInitScriptable();
                      FinishInitScriptable.finished + ':' + sample.echo('value') + ':'
                              + sample.marker + ':' + sample.fromFinish;
                      """, "scriptable-object-define-class-test", 1, null);
  
              assertThat(className).isEqualTo("FinishInitScriptable");
              assertThat(Context.toString(result)).isEqualTo("true:echo:value:marker:done");
          } finally {
              Context.exit();
          }
      }
  
      @Test
      void serializesAndDeserializesScriptableObjectSlots() throws Exception {
          SerializableScriptable original = new SerializableScriptable();
          ScriptableObject.putProperty(original, "name", "Ada");
          ScriptableObject.putProperty(original, "count", 3);
  
          SerializableScriptable restored = roundTrip(original);
  
          assertThat(restored.getClassName()).isEqualTo("SerializableScriptable");
          assertThat(ScriptableObject.getProperty(restored, "name")).isEqualTo("Ada");
          assertThat(ScriptableObject.getProperty(restored, "count")).isEqualTo(3);
      }
  
      private static SerializableScriptable roundTrip(SerializableScriptable scriptable)
              throws IOException, ClassNotFoundException {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {
              output.writeObject(scriptable);
          }
  
          try (ObjectInputStream input = new ObjectInputStream(
                  new ByteArrayInputStream(bytes.toByteArray()))) {
              return (SerializableScriptable) input.readObject();
          }
      }
  
      public static class SingleArgumentInitScriptable extends ScriptableObject {
          private static final long serialVersionUID = 1L;
  
          public SingleArgumentInitScriptable() {
          }
  
          public static void init(Scriptable scope) {
              ScriptableObject.putProperty(scope, "singleArgumentInit", "called");
          }
  
          @Override
          public String getClassName() {
              return "SingleArgumentInitScriptable";
          }
      }
  
      public static class FinishInitScriptable extends ScriptableObject {
          private static final long serialVersionUID = 1L;
  
          public FinishInitScriptable() {
          }
  
          @Override
          public String getClassName() {
              return "FinishInitScriptable";
          }
  
          public String jsFunction_echo(String value) {
              return "echo:" + value;
          }
  
          public String jsGet_marker() {
              return "marker";
          }
  
          public static void finishInit(Scriptable scope, FunctionObject constructor,
                  Scriptable prototype) {
              ScriptableObject.putProperty(constructor, "finished", Boolean.TRUE);
              ScriptableObject.putProperty(prototype, "fromFinish", "done");
          }
      }
  
      public static class SerializableScriptable extends ScriptableObject {
          private static final long serialVersionUID = 1L;
  
          public SerializableScriptable() {
          }
  
          @Override
          public String getClassName() {
              return "SerializableScriptable";
          }
      }
  }
