         outputStream.write(buffer, 0, read);\n            }\n            return outputStream.toByteArray();\n        }\n    }\n\n    private static final class ClassFileWriterResourceBlockingClassLoader extends ClassLoader {\n        private final byte[] classBytes;\n        private boolean blockedClassResourceRequest;\n\n        ClassFileWriterResourceBlockingClassLoader(byte[] classBytes) {\n            super(ClassLoader.getSystemClassLoader());\n            this.classBytes = classBytes;\n        }\n","newText":"    private static URL findLibraryJarUrl() throws IOException {\n        ClassLoader testClassLoader = ClassFileWriterTest.class.getClassLoader();\n        URL resourceUrl = testClassLoader.getResource(RESOURCE_NAME);\n        assertThat(resourceUrl).isNotNull();\n        assertThat(resourceUrl.getProtocol()).isEqualTo(\"jar\");\n\n        String externalForm = resourceUrl.toExternalForm();\n        int separator = externalForm.indexOf(\"!/\");\n        assertThat(separator).isPositive();\n        return new URL(externalForm.substring(\"jar:\".length(), separator));\n    }\n\n    private static final class ClassFileWriterResourceBlockingClassLoader\n            extends URLClassLoader {\n        private boolean blockedClassResourceRequest;\n\n        ClassFileWriterResourceBlockingClassLoader(URL libraryJarUrl) {\n            super(new URL[] {libraryJarUrl}, ClassLoader.getSystemClassLoader());\n        }\n"},{"oldText":"                Class<?> loadedClass = findLoadedClass(name);\n                if (loadedClass == null) {\n                    loadedClass = defineClass(name, classBytes, 0, classBytes.length);\n                }\n","newText":"                Class<?> loadedClass = findLoadedClass(name);\n                if (loadedClass == null) {\n                    loadedClass = findClass(name);\n                }\n"}]}
