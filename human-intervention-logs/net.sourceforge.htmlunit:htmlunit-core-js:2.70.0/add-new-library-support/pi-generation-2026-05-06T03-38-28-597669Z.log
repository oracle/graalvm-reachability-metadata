  package net_sourceforge_htmlunit.htmlunit_core_js;
  
  import java.util.Map;
  
  import net.sourceforge.htmlunit.corejs.javascript.JavaToJSONConverters;
  
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class JavaToJSONConvertersTest {
      @Test
      void beanConverterReadsJavaBeanProperties() {
          SampleBean bean = new SampleBean("Ada", 37);
  
          Object converted = JavaToJSONConverters.BEAN.apply(bean);
  
          assertThat(converted).isInstanceOf(Map.class);
          Map<?, ?> root = (Map<?, ?>) converted;
          assertThat(root).containsEntry("beanClass", SampleBean.class.getName());
          assertThat(root.get("properties")).isInstanceOf(Map.class);
  
          Map<?, ?> properties = (Map<?, ?>) root.get("properties");
          assertThat(properties)
                  .containsEntry("age", 37)
                  .containsEntry("name", "Ada");
      }
  
      public static final class SampleBean {
          private final String name;
          private final int age;
  
          public SampleBean(String name, int age) {
              this.name = name;
              this.age = age;
          }
  
          public String getName() {
              return name;
          }
  
          public int getAge() {
              return age;
          }
      }
  }
