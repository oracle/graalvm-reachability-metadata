  package net_sourceforge_htmlunit.htmlunit_core_js;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.IOException;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.io.Serializable;
  
  import net.sourceforge.htmlunit.corejs.javascript.ClassCache;
  import net.sourceforge.htmlunit.corejs.javascript.Context;
  import net.sourceforge.htmlunit.corejs.javascript.NativeArray;
  import net.sourceforge.htmlunit.corejs.javascript.NativeJavaObject;
  import net.sourceforge.htmlunit.corejs.javascript.NativeObject;
  import net.sourceforge.htmlunit.corejs.javascript.Scriptable;
  import net.sourceforge.htmlunit.corejs.javascript.ScriptableObject;
  import net.sourceforge.htmlunit.corejs.javascript.Wrapper;
  
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class NativeJavaObjectTest {
      @Test
      void coercesNativeArrayToJavaArray() {
          NativeArray values = new NativeArray(new Object[] {"alpha", "beta", "gamma"});
  
          Object coerced = NativeJavaObject.coerceType(String[].class, values);
  
          assertThat(coerced).isInstanceOf(String[].class);
          assertThat((String[]) coerced).containsExactly("alpha", "beta", "gamma");
      }
  
      @Test
      void coercesObjectWithDoubleValueMethodToPrimitiveDouble() {
          Object coerced = NativeJavaObject.coerceType(
                  Double.TYPE,
                  new PublicDoubleValue(12.75));
  
          assertThat(coerced).isEqualTo(12.75d);
      }
  
      @Test
      void serializesAndDeserializesRegularWrappedObjects() throws Exception {
          SerializableTopLevel scope = new SerializableTopLevel();
          NativeJavaObject typed = new NativeJavaObject(
                  scope,
                  "typed value",
                  CharSequence.class);
          NativeJavaObject untyped = new NativeJavaObject(
                  scope,
                  Integer.valueOf(42),
                  null);
  
          NativeJavaObject restoredTyped = roundTrip(typed);
          NativeJavaObject restoredUntyped = roundTrip(untyped);
  
          assertThat(restoredTyped.unwrap()).isEqualTo("typed value");
          assertThat(restoredUntyped.unwrap()).isEqualTo(42);
      }
  
      @Test
      void serializesAndDeserializesAdapterWrappedObject() throws Exception {
          try {
              Context context = Context.enter();
              try {
                  Scriptable standardScope = context.initStandardObjects();
                  Object adapter = createRunnableAdapter(context, standardScope);
                  NativeJavaObject wrapped = new NativeJavaObject(
                          new SerializableTopLevel(),
                          adapter,
                          Runnable.class,
                          true);
  
                  NativeJavaObject restored = roundTrip(wrapped);
  
                  assertThat(restored.unwrap()).isInstanceOf(Runnable.class);
              } finally {
                  Context.exit();
              }
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
      }
  
      private static Object createRunnableAdapter(Context context, Scriptable scope) {
          NativeObject delegee = new NativeObject();
          delegee.setParentScope(scope);
          delegee.setPrototype(ScriptableObject.getObjectPrototype(scope));
          ScriptableObject.putProperty(scope, "delegee", delegee);
  
          Object result = context.evaluateString(scope, """
                  new JavaAdapter(java.lang.Runnable, delegee);
                  """, "native-java-object-adapter-test", 1, null);
          Object adapter = unwrap(result);
          assertThat(adapter).isInstanceOf(Runnable.class);
  
          delegee.setParentScope(null);
          delegee.setPrototype(null);
          return adapter;
      }
  
      private static NativeJavaObject roundTrip(NativeJavaObject object)
              throws IOException, ClassNotFoundException {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {
              output.writeObject(object);
          }
  
          try (ObjectInputStream input = new ObjectInputStream(
                  new ByteArrayInputStream(bytes.toByteArray()))) {
              return (NativeJavaObject) input.readObject();
          }
      }
  
      private static Object unwrap(Object value) {
          if (value instanceof Wrapper wrapper) {
              return wrapper.unwrap();
          }
          return value;
      }
  
      public static final class PublicDoubleValue {
          private final double value;
  
          PublicDoubleValue(double value) {
              this.value = value;
          }
  
          public Number doubleValue() {
              return value;
          }
      }
  
      public static final class SerializableTopLevel
              extends ScriptableObject implements Serializable {
          private static final long serialVersionUID = 1L;
  
          public SerializableTopLevel() {
              associateClassCache();
          }
  
          @Override
          public String getClassName() {
              return "SerializableTopLevel";
          }
  
          private void readObject(ObjectInputStream input)
                  throws IOException, ClassNotFoundException {
              input.defaultReadObject();
              associateClassCache();
          }
  
          private void associateClassCache() {
              new ClassCache().associate(this);
          }
      }
  }
