          void detachDelegateFromTopLevelScope() {
              delegee.setParentScope(null);
              delegee.setPrototype(null);
              greet.setParentScope(null);
              greet.setPrototype(null);
          }
      }
  
      public interface GreetingService {
          String greet(String name);
      }
  
      public interface SuperclassInterface {
          String inheritedInterfaceMethod();
      }
  
      public interface AdapterInterface {
          String mustOverride(String value);
  
          String implementedBySuperclass(String value);
      }
  
      public static class AdapterSuperclass implements SuperclassInterface {
          public AdapterSuperclass() {
          }
  
          public AdapterSuperclass(String ignored) {
          }
  
          @Override
          public String inheritedInterfaceMethod() {
              return "inherited";
          }
  
          public String implementedBySuperclass(String value) {
              return "super " + value;
          }
  
          public String concreteMethod() {
              return "concrete";
          }
  
          protected String protectedMethod() {
              return "protected";
          }
  
          public final String finalMethod() {
              return "final";
          }
      }
  
