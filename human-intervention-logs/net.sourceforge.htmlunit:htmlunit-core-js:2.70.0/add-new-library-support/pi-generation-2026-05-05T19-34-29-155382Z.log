[tool-call] delta {"path":"tests/src/net.sourceforge.htmlunit/htmlunit-core-js/2.70.0/src/test/java/net_sourceforge_htmlunit/htmlunit_core_js/MemberBoxTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage net_sourceforge_htmlunit.htmlunit_core_js;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.IOException;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.lang.reflect.Constructor;\nimport java.lang.reflect.Method;\n\nimport net.sourceforge.htmlunit.corejs.javascript.Context;\nimport net.sourceforge.htmlunit.corejs.javascript.FunctionObject;\nimport net.sourceforge.htmlunit.corejs.javascript.Scriptable;\nimport net.sourceforge.htmlunit.corejs.javascript.ScriptableObject;\n\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class MemberBoxTest {\n    @Test\n    void invokesPublicMethodFromNonPublicClassThroughAccessibleInterface() throws Exception {\n        Context context = Context.enter();\n        try {\n            Scriptable scope = context.initStandardObjects();\n            Method method = HiddenInterfaceTarget.class.getMethod(\"greet\", String.class);\n            FunctionObject function = new FunctionObject(\"greet\", method, scope);\n\n            Object result = function.call(\n                    context,\n                    scope,\n                    new HiddenInterfaceTarget(),\n                    new Object[] {\"Ada\"});\n\n            assertThat(result).isEqualTo(\"interface:Ada\");\n        } finally {\n            Context.exit();\n        }\n    }\n\n    @Test\n    void invokesPublicMethodFromNonPublicClassThroughAccessibleSuperclass() throws Exception {\n        Context context = Context.enter();\n        try {\n            Scriptable scope = context.initStandardObjects();\n            Method method = HiddenSuperclassTarget.class.getMethod(\"describe\", String.class);\n            FunctionObject function = new FunctionObject(\"describe\", method, scope);\n\n            Object result = function.call(\n                    context,\n                    scope,\n                    new HiddenSuperclassTarget(),\n                    new Object[] {\"oak\"});\n\n            assertThat(result).isEqualTo(\"superclass:oak\");\n        } finally {\n            Context.exit();\n        }\n    }\n\n    @Test\n    void constructsPublicScriptableObject() throws Exception {\n        Context context = Context.enter();\n        try {\n            Scriptable scope = context.initStandardObjects();\n            Constructor<PublicConstructedScriptable> constructor =\n                    PublicConstructedScriptable.class.getConstructor(String.class, int.class);\n            FunctionObject function = new FunctionObject(\"PublicConstructedScriptable\", constructor, scope);\n\n            Object result = function.call(context, scope, null, new Object[] {\"item\", 3});\n\n            assertThat(result).isInstanceOf(PublicConstructedScriptable.class);\n            PublicConstructedScriptable scriptable = (PublicConstructedScriptable) result;\n            assertThat(scriptable.summary()).isEqualTo(\"item:3\");\n        } finally {\n            Context.exit();\n        }\n    }\n\n    @Test\n    void constructsNonPublicScriptableObjectAfterMakingConstructorAccessible() throws Exception {\n        Context context = Context.enter();\n        try {\n            Scriptable scope = context.initStandardObjects();\n            Constructor<HiddenConstructedScriptable> constructor =\n                    HiddenConstructedScriptable.class.getDeclaredConstructor(String.class);\n            FunctionObject function = new FunctionObject(\"HiddenConstructedScriptable\", constructor, scope);\n\n            Object result = function.call(context, scope, null, new Object[] {\"secret\"});\n\n            assertThat(result).isInstanceOf(HiddenConstructedScriptable.class);\n            HiddenConstructedScriptable scriptable = (HiddenConstructedScriptable) result;\n            assertThat(scriptable.value()).isEqualTo(\"secret\");\n        } finally {\n            Context.exit();\n        }\n    }\n\n    @Test\n    void serializesAndDeserializesMethodFunction() throws Exception {\n        Context context = Context.enter();\n        try {\n            Scriptable scope = context.initStandardObjects();\n            Method method = MemberBoxTest.class.getMethod(\"formatValue\", String.class, int.class);\n            FunctionObject original = new FunctionObject(\"formatValue\", method, scope);\n            original.setParentScope(null);\n            original.setPrototype(null);\n\n            FunctionObject restored = roundTrip(original);\n            Object result = restored.call(context, scope, null, new Object[] {\"value\", 5});\n\n            assertThat(result).isEqualTo(\"value#5\");\n        } finally {\n            Context.exit();\n        }\n    }\n\n    @Test\n    void serializesAndDeserializesConstructorFunction() throws Exception {\n        Context context = Context.enter();\n        try {\n            Scriptable scope = context.initStandardObjects();\n            Constructor<PublicConstructedScriptable> constructor =\n                    PublicConstructedScriptable.class.getConstructor(String.class, int.class);\n            FunctionObject original = new FunctionObject(\"PublicConstructedScriptable\", constructor, scope);\n            original.setParentScope(null);\n            original.setPrototype(null);\n\n            FunctionObject restored = roundTrip(original);\n            Object result = restored.call(context, scope, null, new Object[] {\"restored\", 7});\n\n            assertThat(result).isInstanceOf(PublicConstructedScriptable.class);\n            PublicConstructedScriptable scriptable = (PublicConstructedScriptable) result;\n            assertThat(scriptable.summary()).isEqualTo(\"restored:7\");\n        } finally {\n            Context.exit();\n        }\n    }\n\n    public static String formatValue(String name, int count) {\n        return name + \"#\" + count;\n    }\n\n    private static FunctionObject roundTrip(FunctionObject function)\n            throws IOException, ClassNotFoundException {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(function);\n        }\n\n        try (ObjectInputStream input = new ObjectInputStream(\n                new ByteArrayInputStream(bytes.toByteArray()))) {\n            return (FunctionObject) input.readObject();\n        }\n    }\n\n    public interface GreetingTarget {\n        String greet(String name);\n    }\n\n    private static final class HiddenInterfaceTarget extends ScriptableObject implements GreetingTarget {\n        private static final long serialVersionUID = 1L;\n\n        @Override\n        public String getClassName() {\n            return \"HiddenInterfaceTarget\";\n        }\n\n        @Override\n        public String greet(String name) {\n            return \"interface:\" + name;\n        }\n    }\n\n    public static class PublicGreetingBase extends ScriptableObject {\n        private static final long serialVersionUID = 1L;\n\n        @Override\n        public String getClassName() {\n            return \"PublicGreetingBase\";\n        }\n\n        public String describe(String value) {\n            return \"superclass:\" + value;\n        }\n    }\n\n    private static final class HiddenSuperclassTarget extends PublicGreetingBase {\n        private static final long serialVersionUID = 1L;\n\n        @Override\n        public String getClassName() {\n            return \"HiddenSuperclassTarget\";\n        }\n\n        @Override\n        public String describe(String value) {\n            return \"superclass:\" + value;\n        }\n    }\n\n    public static class PublicConstructedScriptable extends ScriptableObject {\n        private static final long serialVersionUID = 1L;\n\n        private final String name;\n        private final int count;\n\n        public PublicConstructedScriptable(String name, int count) {\n            this.name = name;\n            this.count = count;\n        }\n\n        @Override\n        public String getClassName() {\n            return \"PublicConstructedScriptable\";\n        }\n\n        String summary() {\n            return name + ':' + count;\n        }\n    }\n\n    private static final class HiddenConstructedScriptable extends ScriptableObject {\n        private static final long serialVersionUID = 1L;\n\n        private final String value;\n\n        public HiddenConstructedScriptable(String value) {\n            this.value = value;\n        }\n\n        @Override\n        public String getClassName() {\n            return \"HiddenConstructedScriptable\";\n        }\n\n        String value() {\n            return value;\n        }\n    }\n}\n"}
