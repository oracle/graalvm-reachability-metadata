  package net_sourceforge_htmlunit.htmlunit_core_js;
  
  import java.util.MissingResourceException;
  
  import net.sourceforge.htmlunit.corejs.javascript.tools.ToolErrorReporter;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThatThrownBy;
  
  public class ToolErrorReporterTest {
      @Test
      void getMessageLooksUpToolMessageResourceBundle() {
          assertThatThrownBy(() -> ToolErrorReporter.getMessage("msg.format1"))
                  .isInstanceOf(MissingResourceException.class)
                  .hasMessageContaining("net.sourceforge.htmlunit.corejs.javascript.tools.resources.Messages");
      }
  }
