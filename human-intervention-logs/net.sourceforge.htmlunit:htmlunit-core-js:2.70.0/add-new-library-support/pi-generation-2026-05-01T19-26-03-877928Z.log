apper) result).unwrap();\n\n            assertThat(collector.label()).isEqualTo(\"letters\");\n            assertThat(collector.values()).containsExactly(\"alpha\", \"beta\", \"gamma\");\n        } finally {\n            Context.exit();\n        }\n    }\n\n    public static class VarargsCollector {\n        private final String label;\n        private final String[] values;\n\n        public VarargsCollector(String label, String... values) {\n            this.label = label;\n            this.values = values.clone();\n        }\n\n        public String label() {\n            return label;\n        }\n\n        public String[] values() {\n            return Arrays.copyOf(values, values.length);\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1404, "output": 1003, "cacheRead": 19968, "cacheWrite": 0, "totalTokens": 22375, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777663538581, "responseId": "resp_062e5ed5ce007a940169f4fe330bc8819d80c72ce52fa74172"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_ddjWhexKqTEErLEXjYFiCC4x|fc_062e5ed5ce007a940169f4fe39fc14819d8685ee32dac09b8d", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1842 bytes to tests/src/net.sourceforge.htmlunit/htmlunit-core-js/2.70.0/src/test/java/net_sourceforge_htmlunit/htmlunit_core_js/NativeJavaClassTest.java"}], "isError": false, "timestamp": 1777663548655}]}
