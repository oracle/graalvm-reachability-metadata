  package net_sourceforge_htmlunit.htmlunit_core_js;
  
  import java.io.InputStream;
  import java.lang.reflect.Method;
  import java.net.URL;
  import java.net.URLClassLoader;
  import java.nio.charset.Charset;
  import java.nio.charset.StandardCharsets;
  
  import jline.console.ConsoleReader;
  
  import net.sourceforge.htmlunit.corejs.javascript.Context;
  import net.sourceforge.htmlunit.corejs.javascript.Scriptable;
  import net.sourceforge.htmlunit.corejs.javascript.ScriptableObject;
  import net.sourceforge.htmlunit.corejs.javascript.tools.shell.ShellConsole;
  
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  import static org.junit.jupiter.api.Assumptions.assumeFalse;
  
  public class ShellConsoleTest {
      @Test
      void createsJLineV2ConsoleAndDelegatesThroughReflectedReaderMethods() throws Exception {
          ConsoleReader.reset();
          ConsoleReader.addLine("typed-command");
          ConsoleReader.addLine("stream-command");
  
          Context context = Context.enter();
          try {
              if (NativeImageSupport.isNativeImageRuntime()) {
                  context.setOptimizationLevel(-1);
              }
              Scriptable scope = context.initStandardObjects();
              context.evaluateString(scope, "function hello() {};", "shell-console-test", 1, null);
              ScriptableObject.putProperty(scope, "helium", "value");
  
              ShellConsole console = ShellConsole.getConsole(scope, StandardCharsets.UTF_8);
  
              assertThat(console).isNotNull();
              assertThat(ConsoleReader.isBellEnabled()).isFalse();
              assertThat(ConsoleReader.completions()).contains("hello(", "helium");
  
              console.print("prefix");
              console.println("line");
              console.println();
              console.flush();
              assertThat(console.readLine("prompt> ")).isEqualTo("typed-command");
  
              byte[] streamBytes = console.getIn().readNBytes(32);
              assertThat(new String(streamBytes, StandardCharsets.UTF_8))
                      .isEqualTo("stream-command\n");
              assertThat(ConsoleReader.output()).contains("prefixline\n\nprompt> ");
          } finally {
              Context.exit();
          }
      }
  
      @Test
      void createsJLineV1ConsoleWhenOnlyLegacyJLineClassesAreVisible() throws Exception {
          assumeFalse(
                  NativeImageSupport.isNativeImageRuntime(),
                  "URLClassLoader-based legacy JLine coverage is JVM-only");
          try {
              URL coreJsUrl = ShellConsole.class.getProtectionDomain()
                      .getCodeSource().getLocation().toURI().toURL();
              URL testClassesUrl = ShellConsoleTest.class.getProtectionDomain()
                      .getCodeSource().getLocation().toURI().toURL();
  
              try (JLineV1ClassLoader classLoader =
                      new JLineV1ClassLoader(coreJsUrl, testClassesUrl)) {
                  Class<?> shellConsoleClass = classLoader.loadClass(
                          "net.sourceforge.htmlunit.corejs.javascript.tools.shell.ShellConsole");
                  Class<?> scriptableClass = classLoader.loadClass(
                          "net.sourceforge.htmlunit.corejs.javascript.Scriptable");
                  Class<?> readerClass = classLoader.loadClass("jline.ConsoleReader");
                  resetLegacyReader(readerClass);
  
                  Method getConsole = shellConsoleClass.getMethod(
                          "getConsole", scriptableClass, Charset.class);
                  Object console = getConsole.invoke(null, null, StandardCharsets.UTF_8);
  
                  assertThat(console).isNotNull();
                  assertThat(console.getClass().getSimpleName()).isEqualTo("JLineShellConsoleV1");
                  assertThat((Boolean) readerClass.getMethod("isBellEnabled").invoke(null))
                          .isFalse();
  
                  shellConsoleClass.getMethod("print", String.class).invoke(console, "legacy-prefix");
                  shellConsoleClass.getMethod("println", String.class).invoke(console, "line");
                  shellConsoleClass.getMethod("println").invoke(console);
                  shellConsoleClass.getMethod("flush").invoke(console);
  
                  Object line = shellConsoleClass.getMethod("readLine", String.class)
                          .invoke(console, "legacy> ");
                  assertThat(line).isEqualTo("legacy-command");
  
                  InputStream input = (InputStream) shellConsoleClass.getMethod("getIn")
                          .invoke(console);
                  byte[] streamBytes = input.readNBytes(32);
                  assertThat(new String(streamBytes, StandardCharsets.UTF_8))
                          .isEqualTo("legacy-stream\n");
  
                  String output = (String) readerClass.getMethod("output").invoke(null);
                  assertThat(output).contains("legacy-prefixline\n\nlegacy> ");
              }
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
      }
  
      private static void resetLegacyReader(Class<?> readerClass) throws Exception {
          readerClass.getMethod("reset").invoke(null);
          readerClass.getMethod("addLine", String.class).invoke(null, "legacy-command");
          readerClass.getMethod("addLine", String.class).invoke(null, "legacy-stream");
      }
  
      private static final class JLineV1ClassLoader extends URLClassLoader {
          JLineV1ClassLoader(URL coreJsUrl, URL testClassesUrl) {
              super(new URL[] {coreJsUrl, testClassesUrl}, ClassLoader.getPlatformClassLoader());
          }
  
          @Override
          protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {
              if (name.startsWith("jline.console.")) {
                  throw new ClassNotFoundException(name);
              }
              if (isChildFirstClass(name)) {
                  synchronized (getClassLoadingLock(name)) {
                      Class<?> loadedClass = findLoadedClass(name);
                      if (loadedClass == null) {
                          loadedClass = findChildFirstClass(name);
                      }
                      if (resolve) {
                          resolveClass(loadedClass);
                      }
                      return loadedClass;
                  }
              }
              return super.loadClass(name, resolve);
          }
  
          private Class<?> findChildFirstClass(String name) throws ClassNotFoundException {
              try {
                  return findClass(name);
              } catch (ClassNotFoundException exception) {
                  return super.loadClass(name, false);
              }
          }
  
          private static boolean isChildFirstClass(String name) {
              return name.startsWith("net.sourceforge.htmlunit.corejs.javascript.")
                      || name.equals("jline.ConsoleReader")
                      || name.equals("jline.Completor");
          }
      }
  }
