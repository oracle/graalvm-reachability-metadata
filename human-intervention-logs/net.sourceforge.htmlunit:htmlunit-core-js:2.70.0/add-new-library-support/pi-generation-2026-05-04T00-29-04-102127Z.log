  package net_sourceforge_htmlunit.htmlunit_core_js;
  
  import net.sourceforge.htmlunit.corejs.javascript.Context;
  import net.sourceforge.htmlunit.corejs.javascript.FunctionObject;
  import net.sourceforge.htmlunit.corejs.javascript.Scriptable;
  import net.sourceforge.htmlunit.corejs.javascript.ScriptableObject;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ScriptableObjectTest {
      @Test
      void invokesStaticInitMethodWhenDefiningClass() throws Exception {
          InitMethodScriptable.reset();
          Context cx = Context.enter();
          try {
              Scriptable scope = cx.initStandardObjects();
  
              String definedName = ScriptableObject.defineClass(
                      scope, InitMethodScriptable.class, false, false);
  
              assertThat(definedName).isNull();
              assertThat(InitMethodScriptable.initialized).isTrue();
              assertThat(InitMethodScriptable.observedContext).isSameAs(cx);
              assertThat(InitMethodScriptable.observedScope).isSameAs(scope);
              assertThat(InitMethodScriptable.observedSealed).isFalse();
              assertThat(ScriptableObject.getProperty(scope, "initRegistered"))
                      .isEqualTo(Boolean.TRUE);
          } finally {
              Context.exit();
          }
      }
  
      @Test
      void invokesCompatibilityInitMethodWhenDefiningClass() throws Exception {
          CompatibilityInitMethodScriptable.reset();
          Context cx = Context.enter();
          try {
              Scriptable scope = cx.initStandardObjects();
  
              String definedName = ScriptableObject.defineClass(
                      scope, CompatibilityInitMethodScriptable.class, false, false);
  
              assertThat(definedName).isNull();
              assertThat(CompatibilityInitMethodScriptable.initialized).isTrue();
              assertThat(CompatibilityInitMethodScriptable.observedScope).isSameAs(scope);
              assertThat(ScriptableObject.getProperty(scope, "compatibilityInitRegistered"))
                      .isEqualTo(Boolean.TRUE);
          } finally {
              Context.exit();
          }
      }
  
      @Test
      void constructsPrototypeAndCallsFinishInitWhenDefiningClass() throws Exception {
          FinishInitScriptable.reset();
          Context cx = Context.enter();
          try {
              Scriptable scope = cx.initStandardObjects();
  
              String definedName = ScriptableObject.defineClass(
                      scope, FinishInitScriptable.class, false, false);
  
              Object constructor = ScriptableObject.getProperty(scope, "FinishInitScriptable");
              assertThat(definedName).isEqualTo("FinishInitScriptable");
              assertThat(constructor).isInstanceOf(FunctionObject.class);
              assertThat(FinishInitScriptable.constructorInvocations).isEqualTo(1);
              assertThat(FinishInitScriptable.finishInitInvocations).isEqualTo(1);
              assertThat(FinishInitScriptable.observedScope).isSameAs(scope);
              assertThat(FinishInitScriptable.observedConstructor).isSameAs(constructor);
              assertThat(FinishInitScriptable.observedPrototype)
                      .isInstanceOf(FinishInitScriptable.class);
              assertThat(ScriptableObject.getProperty(
                              (Scriptable) constructor, "finishInitRegistered"))
                      .isEqualTo(Boolean.TRUE);
          } finally {
              Context.exit();
          }
      }
  
      public static class InitMethodScriptable extends ScriptableObject {
          private static final long serialVersionUID = 1L;
  
          static boolean initialized;
          static Context observedContext;
          static Scriptable observedScope;
          static boolean observedSealed;
  
          public static void init(Context cx, Scriptable scope, boolean sealed) {
              initialized = true;
              observedContext = cx;
              observedScope = scope;
              observedSealed = sealed;
              ScriptableObject.putProperty(scope, "initRegistered", Boolean.TRUE);
          }
  
          static void reset() {
              initialized = false;
              observedContext = null;
              observedScope = null;
              observedSealed = false;
          }
  
          @Override
          public String getClassName() {
              return "InitMethodScriptable";
          }
      }
  
      public static class CompatibilityInitMethodScriptable extends ScriptableObject {
          private static final long serialVersionUID = 1L;
  
          static boolean initialized;
          static Scriptable observedScope;
  
          public static void init(Scriptable scope) {
              initialized = true;
              observedScope = scope;
              ScriptableObject.putProperty(scope, "compatibilityInitRegistered", Boolean.TRUE);
          }
  
          static void reset() {
              initialized = false;
              observedScope = null;
          }
  
          @Override
          public String getClassName() {
              return "CompatibilityInitMethodScriptable";
          }
      }
  
      public static class FinishInitScriptable extends ScriptableObject {
          private static final long serialVersionUID = 1L;
  
          static int constructorInvocations;
          static int finishInitInvocations;
          static Scriptable observedScope;
          static FunctionObject observedConstructor;
          static Scriptable observedPrototype;
  
          public FinishInitScriptable() {
              constructorInvocations++;
          }
  
          public static void finishInit(
                  Scriptable scope, FunctionObject constructor, Scriptable prototype) {
              finishInitInvocations++;
              observedScope = scope;
              observedConstructor = constructor;
              observedPrototype = prototype;
              ScriptableObject.putProperty(constructor, "finishInitRegistered", Boolean.TRUE);
          }
  
          static void reset() {
              constructorInvocations = 0;
              finishInitInvocations = 0;
              observedScope = null;
              observedConstructor = null;
              observedPrototype = null;
          }
  
          @Override
          public String getClassName() {
              return "FinishInitScriptable";
          }
      }
  }
