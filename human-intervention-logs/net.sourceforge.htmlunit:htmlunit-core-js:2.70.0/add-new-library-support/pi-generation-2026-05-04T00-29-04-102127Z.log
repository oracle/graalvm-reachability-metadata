  package net_sourceforge_htmlunit.htmlunit_core_js;
  
  import java.lang.reflect.Method;
  import java.net.URL;
  import java.net.URLClassLoader;
  import java.nio.charset.Charset;
  import java.nio.charset.StandardCharsets;
  import java.security.CodeSource;
  import java.util.Set;
  
  import net.sourceforge.htmlunit.corejs.javascript.tools.shell.ShellConsole;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  import org.opentest4j.TestAbortedException;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ShellConsoleTest {
      private static final String SHELL_CONSOLE_CLASS_NAME =
              "net.sourceforge.htmlunit.corejs.javascript.tools.shell.ShellConsole";
      private static final String SCRIPTABLE_CLASS_NAME =
              "net.sourceforge.htmlunit.corejs.javascript.Scriptable";
  
      @Test
      void createsJLine2ConsoleThroughPublicFactory() throws Exception {
          try {
              ShellConsoleResult result = exerciseIsolatedJLineConsole(Set.of());
  
              assertThat(result.consoleClassName()).contains("JLineShellConsoleV2");
              assertThat(result.line()).isEqualTo("jline2-line");
              assertThat(result.promptedLine()).isEqualTo("jline2-prompt> ");
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
      }
  
      @Test
      void createsJLine1ConsoleThroughPublicFactoryWhenJLine2IsUnavailable() throws Exception {
          if (isNativeImageRuntime()) {
              throw new TestAbortedException(
                      "Native image runtime does not preserve the isolated class loader needed to hide JLine 2");
          }
          try {
              ShellConsoleResult result = exerciseIsolatedJLineConsole(Set.of(
                      "jline.console.ConsoleReader",
                      "jline.console.completer.Completer"));
  
              assertThat(result.consoleClassName()).contains("JLineShellConsoleV1");
              assertThat(result.line()).isEqualTo("jline1-line");
              assertThat(result.promptedLine()).isEqualTo("jline1-prompt> ");
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
      }
  
      private static ShellConsoleResult exerciseIsolatedJLineConsole(Set<String> hiddenClasses)
              throws Exception {
          URL[] urls = new URL[] {
              codeLocation(ShellConsole.class),
              codeLocation(ShellConsoleTest.class)
          };
          try (IsolatedShellClassLoader classLoader =
                  new IsolatedShellClassLoader(urls, hiddenClasses)) {
              Class<?> shellConsoleClass = Class.forName(SHELL_CONSOLE_CLASS_NAME, true, classLoader);
              Class<?> scriptableClass = Class.forName(SCRIPTABLE_CLASS_NAME, false, classLoader);
              Method getConsole = shellConsoleClass.getMethod(
                      "getConsole", scriptableClass, Charset.class);
              Object console = getConsole.invoke(null, null, StandardCharsets.UTF_8);
              assertThat(console).isNotNull();
  
              Method print = shellConsoleClass.getMethod("print", String.class);
              Method println = shellConsoleClass.getMethod("println", String.class);
              Method flush = shellConsoleClass.getMethod("flush");
              Method readLine = shellConsoleClass.getMethod("readLine");
              Method readLineWithPrompt = shellConsoleClass.getMethod("readLine", String.class);
  
              print.invoke(console, "hello");
              println.invoke(console, " world");
              flush.invoke(console);
              String line = (String) readLine.invoke(console);
              String promptedLine = (String) readLineWithPrompt.invoke(console, "prompt> ");
              return new ShellConsoleResult(console.getClass().getName(), line, promptedLine);
          }
      }
  
      private static URL codeLocation(Class<?> clazz) {
          CodeSource codeSource = clazz.getProtectionDomain().getCodeSource();
          assertThat(codeSource).as("code source for %s", clazz.getName()).isNotNull();
          URL location = codeSource.getLocation();
          assertThat(location).as("code location for %s", clazz.getName()).isNotNull();
          return location;
      }
  
      private static boolean isNativeImageRuntime() {
          return "runtime".equals(System.getProperty("org.graalvm.nativeimage.imagecode"));
      }
  
      private record ShellConsoleResult(String consoleClassName, String line, String promptedLine) {}
  
      private static final class IsolatedShellClassLoader extends URLClassLoader {
          private static final String HTMLUNIT_PACKAGE = "net.sourceforge.htmlunit.corejs.";
          private static final String JLINE_PACKAGE = "jline.";
  
          private final Set<String> hiddenClasses;
  
          private IsolatedShellClassLoader(URL[] urls, Set<String> hiddenClasses) {
              super(urls, ShellConsoleTest.class.getClassLoader());
              this.hiddenClasses = hiddenClasses;
          }
  
          @Override
          protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {
              if (hiddenClasses.contains(name)) {
                  throw new ClassNotFoundException(name);
              }
              if (name.startsWith(HTMLUNIT_PACKAGE) || name.startsWith(JLINE_PACKAGE)) {
                  Class<?> loadedClass = findLoadedClass(name);
                  if (loadedClass == null) {
                      try {
                          loadedClass = findClass(name);
                      } catch (ClassNotFoundException e) {
                          loadedClass = super.loadClass(name, false);
                      }
                  }
                  if (resolve) {
                      resolveClass(loadedClass);
                  }
                  return loadedClass;
              }
              return super.loadClass(name, resolve);
          }
      }
  }
