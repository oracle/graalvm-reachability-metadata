dLineWithPrompt = shellConsoleClass.getMethod(\"readLine\", String.class);\n\n            print.invoke(console, \"hello\");\n            println.invoke(console, \" world\");\n            flush.invoke(console);\n            String line = (String) readLine.invoke(console);\n            String promptedLine = (String) readLineWithPrompt.invoke(console, \"prompt> \");\n            return new ShellConsoleResult(console.getClass().getName(), line, promptedLine);\n        }\n    }\n\n    private static URL codeLocation(Class<?> clazz) {\n        CodeSource codeSource = clazz.getProtectionDomain().getCodeSource();\n        assertThat(codeSource).as(\"code source for %s\", clazz.getName()).isNotNull();\n        URL location = codeSource.getLocation();\n        assertThat(location).as(\"code location for %s\", clazz.getName()).isNotNull();\n        return location;\n    }\n\n    private static boolean isNativeImageRuntime() {\n        return \"runtime\".equals(System.getProperty(\"org.graalvm.nativeimage.imagecode\"));\n    }\n\n    private record ShellConsoleResult(String consoleClassName, String line, String promptedLine) {}\n\n    private static final class IsolatedShellClassLoader extends URLClassLoader {\n        private static final String HTMLUNIT_PACKAGE = \"net.sourceforge.htmlunit.corejs.\";\n        private static final String JLINE_PACKAGE = \"jline.\";\n\n        private final Set<String> hiddenClasses;\n\n        private IsolatedShellClassLoader(URL[] urls, Set<String> hiddenClasses) {\n            super(urls, ShellConsoleTest.class.getClassLoader());\n            this.hiddenClasses = hiddenClasses;\n        }\n\n        @Override\n        protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {\n            if (hiddenClasses.contains(name)) {\n                throw new ClassNotFoundException(name);\n            }\n            if (name.startsWith(HTMLUNIT_PACKAGE) || name.startsWith(JLINE_PACKAGE)) {\n                Class<?> loadedClass = findLoadedClass(name);\n                if (loadedClass == null) {\n                    try {\n                        loadedClass = findClass(name);\n                    } catch (ClassNotFoundException e) {\n                        loadedClass = super.loadClass(name, false);\n                    }\n                }\n                if (resolve) {\n                    resolveClass(loadedClass);\n                }\n                return loadedClass;\n            }\n            return super.loadClass(name, resolve);\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777854381542}}
