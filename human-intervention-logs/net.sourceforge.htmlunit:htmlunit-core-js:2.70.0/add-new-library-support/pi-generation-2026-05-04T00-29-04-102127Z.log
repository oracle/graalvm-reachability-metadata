  package net_sourceforge_htmlunit.htmlunit_core_js;
  
  import java.nio.file.Files;
  import java.nio.file.Path;
  
  import net.sourceforge.htmlunit.corejs.javascript.Context;
  import net.sourceforge.htmlunit.corejs.javascript.Script;
  import net.sourceforge.htmlunit.corejs.javascript.Scriptable;
  import net.sourceforge.htmlunit.corejs.javascript.ScriptableObject;
  import net.sourceforge.htmlunit.corejs.javascript.tools.shell.Global;
  import org.junit.jupiter.api.Test;
  import org.junit.jupiter.api.io.TempDir;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class GlobalTest {
      @TempDir
      Path tempDir;
  
      @Test
      void loadsScriptClassByNameAndExecutesIt() throws Exception {
          LoadableScript.reset();
          Context cx = Context.enter();
          try {
              Scriptable scope = cx.initStandardObjects();
  
              Global.loadClass(cx, scope, new Object[] {LoadableScript.class.getName()}, null);
  
              assertThat(LoadableScript.executionCount).isEqualTo(1);
              assertThat(ScriptableObject.getProperty(scope, "loadedByGlobalLoadClass"))
                      .isEqualTo(1);
          } finally {
              Context.exit();
          }
      }
  
      @Test
      void serializesAndDeserializesThroughShellGlobal() throws Exception {
          Context cx = Context.enter();
          try {
              Scriptable scope = cx.initStandardObjects();
              Path serializedFile = tempDir.resolve("global-serialized-object.bin");
  
              Global.serialize(
                      cx, scope, new Object[] {"persisted text", serializedFile.toString()}, null);
              Object restored = Global.deserialize(
                      cx, scope, new Object[] {serializedFile.toString()}, null);
  
              assertThat(Files.size(serializedFile)).isGreaterThan(0L);
              assertThat(Context.toString(restored)).isEqualTo("persisted text");
          } finally {
              Context.exit();
          }
      }
  
      public static class LoadableScript implements Script {
          static int executionCount;
  
          static void reset() {
              executionCount = 0;
          }
  
          @Override
          public Object exec(Context cx, Scriptable scope) {
              executionCount++;
              ScriptableObject.putProperty(scope, "loadedByGlobalLoadClass", executionCount);
              return executionCount;
          }
      }
  }
