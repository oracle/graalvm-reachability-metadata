          // class flag. This is specified in the first JVM spec, so it should
          // be old enough that it's okay to always set it.
          itsFlags = ACC_PUBLIC | ACC_SUPER;
      }
  
      public final String getClassName() {
          return generatedClassName;
      }
  
      /**
