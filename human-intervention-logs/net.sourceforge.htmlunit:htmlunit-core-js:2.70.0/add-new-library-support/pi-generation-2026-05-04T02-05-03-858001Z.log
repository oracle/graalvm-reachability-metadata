ort net.sourceforge.htmlunit.corejs.javascript.ObjArray;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\nimport static org.assertj.core.api.Assertions.assertThatThrownBy;\n\npublic class ObjArrayTest {\n    @Test\n    void serializesCustomElementStorage() throws Exception {\n        ObjArray array = new ObjArray();\n        for (int i = 0; i < 7; i++) {\n            array.add(null);\n        }\n        array.seal();\n\n        ObjArray restored = roundTrip(array);\n\n        assertThat(restored.size()).isEqualTo(7);\n        assertThat(restored.toArray()).containsOnlyNulls();\n        assertThat(restored.isSealed()).isTrue();\n        assertThatThrownBy(() -> restored.add(null))\n                .isInstanceOf(IllegalStateException.class)\n                .hasMessage(\"Attempt to modify sealed array\");\n    }\n\n    private static ObjArray roundTrip(ObjArray array) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(array);\n        }\n\n        try (ObjectInputStream input = new ObjectInputStream(\n                new ByteArrayInputStream(bytes.toByteArray()))) {\n            return (ObjArray) input.readObject();\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 3867, "output": 491, "cacheRead": 24576, "cacheWrite": 0, "totalTokens": 28934, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777860228856, "responseId": "resp_0a47d02141e5540e0169f7fe8552d08192b6bfce22273138b2"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_kHqdsjn0cwj0NDvURNCX075y|fc_0a47d02141e5540e0169f7fe86b3ac8192a755e3e2dd73b9e8", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1710 bytes to tests/src/net.sourceforge.htmlunit/htmlunit