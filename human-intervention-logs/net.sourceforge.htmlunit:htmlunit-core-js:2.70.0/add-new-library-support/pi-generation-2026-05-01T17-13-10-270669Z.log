                      || obj instanceof Integer
                      || obj instanceof Short
                      || obj instanceof Long
                      || obj instanceof Float
                      || obj instanceof Double
                      || obj instanceof BigInteger) {
                  return obj;
              } else if (obj instanceof Character) {
                  return String.valueOf(((Character) obj).charValue());
              }
