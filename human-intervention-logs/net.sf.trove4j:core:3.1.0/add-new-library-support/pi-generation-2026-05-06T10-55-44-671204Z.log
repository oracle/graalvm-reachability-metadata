[tool-call] delta {"path":"tests/src/net.sf.trove4j/core/3.1.0/src/test/java/net_sf_trove4j/core/TObjectCharCustomHashMapTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage net_sf_trove4j.core;\n\nimport gnu.trove.map.custom_hash.TObjectCharCustomHashMap;\nimport gnu.trove.strategy.HashingStrategy;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class TObjectCharCustomHashMapTest {\n    @Test\n    void keysAllocatesTypedArrayWhenProvidedArrayIsTooSmall() {\n        TObjectCharCustomHashMap<String> map = new TObjectCharCustomHashMap<>(new CaseInsensitiveHashingStrategy());\n\n        map.put(\"Alpha\", 'a');\n        map.put(\"Beta\", 'b');\n\n        String[] keys = map.keys(new String[0]);\n\n        assertThat(keys).isInstanceOf(String[].class);\n        assertThat(keys).containsExactlyInAnyOrder(\"Alpha\", \"Beta\");\n        assertThat(map.get(\"alpha\")).isEqualTo('a');\n        assertThat(map.get(\"BETA\")).isEqualTo('b');\n    }\n\n    private static final class CaseInsensitiveHashingStrategy implements HashingStrategy<String> {\n        private static final long serialVersionUID = 1L;\n\n        @Override\n        public int computeHashCode(String object) {\n            return object.toLowerCase().hashCode();\n        }\n\n        @Override\n        public boolean equals(String first, String second) {\n            return first.equalsIgnoreCase(second);\n        }\n    }\n}\n"}
