  package net_sf_trove4j.core;
  
  import gnu.trove.list.TLinkable;
  import gnu.trove.list.linked.TLinkedList;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class TLinkedListTest {
      @Test
      void toUnlinkedArrayAllocatesTypedArrayAndClearsLinks() {
          Link first = new Link("first");
          Link second = new Link("second");
          TLinkedList<Link> list = new TLinkedList<>();
  
          list.add(first);
          list.add(second);
  
          Link[] links = list.toUnlinkedArray(new Link[0]);
  
          assertThat(links).containsExactly(first, second);
          assertThat(links).isInstanceOf(Link[].class);
          assertThat(list).isEmpty();
          assertThat(first.getNext()).isNull();
          assertThat(first.getPrevious()).isNull();
          assertThat(second.getNext()).isNull();
          assertThat(second.getPrevious()).isNull();
      }
  
      private static final class Link implements TLinkable<Link> {
          private final String value;
          private Link next;
          private Link previous;
  
          private Link(String value) {
              this.value = value;
          }
  
          @Override
          public Link getNext() {
              return next;
          }
  
          @Override
          public Link getPrevious() {
              return previous;
          }
  
          @Override
          public void setNext(Link next) {
              this.next = next;
          }
  
          @Override
          public void setPrevious(Link previous) {
              this.previous = previous;
          }
  
          @Override
          public String toString() {
              return value;
          }
      }
  }
