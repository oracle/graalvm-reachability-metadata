ic class TObjectLongCustomHashMapInnerMapBackedViewTest {\n    @Test\n    void keySetToArrayAllocatesTypedArrayWhenProvidedArrayIsTooSmall() {\n        TObjectLongCustomHashMap<String> map = new TObjectLongCustomHashMap<>(new CaseInsensitiveHashingStrategy());\n        map.put(\"Alpha\", 1L);\n        map.put(\"Beta\", 2L);\n        Set<String> keyView = map.keySet();\n\n        String[] keys = keyView.toArray(new String[0]);\n\n        assertThat(keys).isInstanceOf(String[].class);\n        assertThat(keys).containsExactlyInAnyOrder(\"Alpha\", \"Beta\");\n        assertThat(keyView.contains(\"alpha\")).isTrue();\n        assertThat(keyView.contains(\"BETA\")).isTrue();\n    }\n\n    private static final class CaseInsensitiveHashingStrategy implements HashingStrategy<String> {\n        private static final long serialVersionUID = 1L;\n\n        @Override\n        public int computeHashCode(String object) {\n            return object.toLowerCase().hashCode();\n        }\n\n        @Override\n        public boolean equals(String first, String second) {\n            return first.equalsIgnoreCase(second);\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 802, "output": 471, "cacheRead": 12800, "cacheWrite": 0, "totalTokens": 14073, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778067844692, "responseId": "resp_04aef514c204159f0169fb29851c98819fa1c597d5363fcb98"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_BX7BVXCMQfCRhvnJM8XfsZ7M|fc_04aef514c204159f0169fb29863bb0819f9a4ef18bbd7f7b38", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1555 bytes to tests/src/net.sf.trove4j/core/3.1.0/src/test/java/net_sf_trove4j/core/TObjectLongCustomHashMapInnerMapBackedViewTest.java"}], "isError": false, "timestamp": 1778067848807}]}
