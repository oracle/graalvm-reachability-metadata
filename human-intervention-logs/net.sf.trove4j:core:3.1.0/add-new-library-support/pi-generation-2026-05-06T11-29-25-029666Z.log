[tool-call] delta {"path":"tests/src/net.sf.trove4j/core/3.1.0/src/test/java/net_sf_trove4j/core/TObjectIntCustomHashMapInnerMapBackedViewTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage net_sf_trove4j.core;\n\nimport gnu.trove.map.custom_hash.TObjectIntCustomHashMap;\nimport gnu.trove.strategy.HashingStrategy;\nimport java.util.Set;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class TObjectIntCustomHashMapInnerMapBackedViewTest {\n    @Test\n    void keySetToArrayAllocatesTypedArrayWhenProvidedArrayIsTooSmall() {\n        TObjectIntCustomHashMap<String> map = new TObjectIntCustomHashMap<>(new CaseInsensitiveHashingStrategy());\n        map.put(\"Alpha\", 1);\n        map.put(\"Beta\", 2);\n        Set<String> keyView = map.keySet();\n\n        String[] keys = keyView.toArray(new String[0]);\n\n        assertThat(keys).isInstanceOf(String[].class);\n        assertThat(keys).containsExactlyInAnyOrder(\"Alpha\", \"Beta\");\n        assertThat(keyView.contains(\"alpha\")).isTrue();\n        assertThat(keyView.contains(\"BETA\")).isTrue();\n    }\n\n    private static final class CaseInsensitiveHashingStrategy implements HashingStrategy<String> {\n        private static final long serialVersionUID = 1L;\n\n        @Override\n        public int computeHashCode(String object) {\n            return object.toLowerCase().hashCode();\n        }\n\n        @Override\n        public boolean equals(String first, String second) {\n            return first.equalsIgnoreCase(second);\n        }\n    }\n}\n"}
