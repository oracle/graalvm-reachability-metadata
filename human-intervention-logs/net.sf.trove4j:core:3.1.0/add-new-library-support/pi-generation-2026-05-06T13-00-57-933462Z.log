  package net_sf_trove4j.core;
  
  import gnu.trove.map.hash.TByteObjectHashMap;
  import java.util.Collection;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class TByteObjectHashMapInnerMapBackedViewTest {
      @Test
      void valueCollectionToArrayAllocatesTypedArrayWhenProvidedArrayIsTooSmall() {
          TByteObjectHashMap<String> map = new TByteObjectHashMap<>();
          map.put((byte) 1, "Alpha");
          map.put((byte) 2, "Beta");
          Collection<String> valuesView = map.valueCollection();
  
          String[] values = valuesView.toArray(new String[0]);
  
          assertThat(values).isInstanceOf(String[].class);
          assertThat(values).containsExactlyInAnyOrder("Alpha", "Beta");
          assertThat(valuesView.contains("Alpha")).isTrue();
          assertThat(valuesView.contains("Beta")).isTrue();
      }
  }
