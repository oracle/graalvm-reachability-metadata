[tool-call] delta {"path":"tests/src/net.sf.trove4j/core/3.1.0/src/test/java/net_sf_trove4j/core/TDoubleObjectHashMapInnerMapBackedViewTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage net_sf_trove4j.core;\n\nimport gnu.trove.map.hash.TDoubleObjectHashMap;\nimport java.util.Collection;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class TDoubleObjectHashMapInnerMapBackedViewTest {\n    @Test\n    void valueCollectionToArrayAllocatesTypedArrayWhenProvidedArrayIsTooSmall() {\n        TDoubleObjectHashMap<String> map = new TDoubleObjectHashMap<>();\n        map.put(1.5d, \"Alpha\");\n        map.put(2.5d, \"Beta\");\n        Collection<String> valuesView = map.valueCollection();\n\n        String[] values = valuesView.toArray(new String[0]);\n\n        assertThat(values).isInstanceOf(String[].class);\n        assertThat(values).containsExactlyInAnyOrder(\"Alpha\", \"Beta\");\n        assertThat(valuesView.contains(\"Alpha\")).isTrue();\n        assertThat(valuesView.contains(\"Beta\")).isTrue();\n    }\n}\n"}
