      public V putIfAbsent( K key, V value ) {
          int index = insertKey( key );
          if ( index < 0 ) {
              return _values[-index - 1];
          }
          return doPut(value, index );
      }
  
  
      private V doPut( V value, int index ) {
          V previous = null;
          boolean isNewMapping = true;
          if ( index < 0 ) {
              index = -index - 1;
              previous = _values[index];
              isNewMapping = false;
          }
  
          _values[index] = value;
  
  
