[tool-call] delta {"path":"tests/src/org.robolectric/android-all/10-robolectric-5803371/src/test/java/org_robolectric/android_all/Android_allTest.java","edits":[{"oldText":"import android.content.ContentValues;\nimport android.graphics.Rect;\nimport android.net.Uri;\nimport android.os.Bundle;\nimport android.util.ArrayMap;\nimport android.util.Base64;\nimport android.util.JsonReader;\nimport android.util.JsonToken;\nimport android.util.JsonWriter;\nimport android.util.LruCache;\nimport android.util.Patterns;\nimport android.util.Range;\nimport android.util.Size;\nimport android.util.SparseArray;\n","newText":"import android.content.ContentValues;\nimport android.graphics.Rect;\nimport android.net.Uri;\nimport android.os.Bundle;\nimport android.text.TextUtils;\nimport android.util.ArrayMap;\nimport android.util.Base64;\nimport android.util.JsonReader;\nimport android.util.JsonToken;\nimport android.util.JsonWriter;\nimport android.util.Pair;\nimport android.util.Patterns;\nimport android.util.Range;\nimport android.util.Size;\n"},{"oldText":"        assertThat(Uri.withAppendedPath(Uri.parse(\"content://authority/root\"), \"child value\").toString())\n                .isEqualTo(\"content://authority/root/child%20value\");\n","newText":"        Uri appended = Uri.withAppendedPath(Uri.parse(\"content://authority/root\"), \"child value\");\n        assertThat(appended.toString()).isEqualTo(\"content://authority/root/child value\");\n        assertThat(appended.getLastPathSegment()).isEqualTo(\"child value\");\n"},{"oldText":"    @Test\n    void sparseArrayMaintainsSortedIntegerKeysAndSupportsCloning() {\n        SparseArray<String> sparseArray = new SparseArray<>();\n        sparseArray.put(20, \"twenty\");\n        sparseArray.put(5, \"five\");\n        sparseArray.append(30, \"thirty\");\n        sparseArray.put(20, \"TWENTY\");\n\n        assertThat(sparseArray.size()).isEqualTo(3);\n        assertThat(sparseArray.keyAt(0)).isEqualTo(5);\n        assertThat(sparseArray.valueAt(1)).isEqualTo(\"TWENTY\");\n        assertThat(sparseArray.get(99, \"missing\")).isEqualTo(\"missing\");\n        assertThat(sparseArray.indexOfKey(30)).isEqualTo(2);\n        assertThat(sparseArray.indexOfValue(\"five\")).isEqualTo(0);\n\n        SparseArray<String> clone = sparseArray.clone();\n        String removed = sparseArray.removeReturnOld(20);\n        sparseArray.setValueAt(0, \"FIVE\");\n        sparseArray.removeAtRange(1, 5);\n\n        assertThat(removed).isEqualTo(\"TWENTY\");\n        assertThat(sparseArray.size()).isEqualTo(1);\n        assertThat(sparseArray.valueAt(0)).isEqualTo(\"FIVE\");\n        assertThat(clone.size()).isEqualTo(3);\n        assertThat(clone.get(20)).isEqualTo(\"TWENTY\");\n    }\n","newText":"    @Test\n    void textUtilsSearchesJoinsSplitsAndTransformsCharSequences() {\n        String value = \"  android-all metadata  \";\n        char[] copied = new char[11];\n\n        TextUtils.getChars(value, 2, 13, copied, 0);\n\n        assertThat(new String(copied)).isEqualTo(\"android-all\");\n        assertThat(TextUtils.indexOf(value, 'a')).isEqualTo(2);\n        assertThat(TextUtils.indexOf(value, \"all\")).isEqualTo(10);\n        assertThat(TextUtils.lastIndexOf(value, 'a')).isEqualTo(16);\n        assertThat(TextUtils.regionMatches(value, 2, \"android\", 0, 7)).isTrue();\n        assertThat(TextUtils.substring(value, 2, 13)).isEqualTo(\"android-all\");\n        assertThat(TextUtils.getTrimmedLength(value)).isEqualTo(20);\n        assertThat(TextUtils.isEmpty(\"\")).isTrue();\n        assertThat(TextUtils.emptyIfNull(null)).isEmpty();\n        assertThat(TextUtils.nullIfEmpty(\"\")).isNull();\n        assertThat(TextUtils.firstNotEmpty(\"\", \"fallback\")).isEqualTo(\"fallback\");\n        assertThat(TextUtils.join(\"/\", Arrays.asList(\"android\", \"all\", \"10\"))).isEqualTo(\"android/all/10\");\n        assertThat(TextUtils.split(\"Uri,Bundle,Rect\", \",\")).containsExactly(\"Uri\", \"Bundle\", \"Rect\");\n        assertThat(TextUtils.replace(\"Hello ^1 from ^2\", new String[] {\"^1\", \"^2\"}, new CharSequence[] {\"Android\", \"Java\"}))\n                .hasToString(\"Hello Android from Java\");\n        assertThat(TextUtils.expandTemplate(\"API ^1 on ^2\", \"29\", \"Robolectric\")).hasToString(\"API 29 on Robolectric\");\n        assertThat(TextUtils.getReverse(\"abcdef\", 1, 5)).hasToString(\"edcb\");\n    }\n"},{"oldText":"    @Test\n    void lruCacheCreatesValuesTracksStatisticsAndEvictsLeastRecentlyUsedEntries() {\n        RecordingCache cache = new RecordingCache(2);\n\n        assertThat(cache.get(\"a\")).isEqualTo(\"created-a\");\n        assertThat(cache.put(\"b\", \"bee\")).isNull();\n        assertThat(cache.get(\"a\")).isEqualTo(\"created-a\");\n        assertThat(cache.put(\"c\", \"see\")).isNull();\n\n        assertThat(cache.snapshot()).containsOnlyKeys(\"a\", \"c\");\n        assertThat(cache.evictedKeys).containsExactly(\"b\");\n        assertThat(cache.hitCount()).isEqualTo(1);\n        assertThat(cache.missCount()).isEqualTo(1);\n        assertThat(cache.createCount()).isEqualTo(1);\n        assertThat(cache.putCount()).isEqualTo(2);\n        assertThat(cache.evictionCount()).isEqualTo(1);\n\n        cache.resize(1);\n        assertThat(cache.snapshot()).containsOnlyKeys(\"c\");\n        assertThat(cache.remove(\"c\")).isEqualTo(\"see\");\n        assertThat(cache.size()).isZero();\n    }\n","newText":"    @Test\n    void pairCreatesValueObjectsWithReadableMembersAndEquality() {\n        Pair<String, Integer> direct = new Pair<>(\"api\", 29);\n        Pair<String, Integer> created = Pair.create(\"api\", 29);\n        Pair<String, Integer> different = Pair.create(\"api\", 30);\n\n        assertThat(direct.first).isEqualTo(\"api\");\n        assertThat(direct.second).isEqualTo(29);\n        assertThat(direct).isEqualTo(created).hasSameHashCodeAs(created);\n        assertThat(direct).isNotEqualTo(different);\n        assertThat(direct.toString()).contains(\"api\", \"29\");\n        assertThat(Pair.create(null, \"value\")).isEqualTo(new Pair<>(null, \"value\"));\n    }\n"},{"oldText":"\n    private static final class RecordingCache extends LruCache<String, String> {\n        private final List<String> evictedKeys = new ArrayList<>();\n\n        private RecordingCache(int maxSize) {\n            super(maxSize);\n        }\n\n        @Override\n        protected String create(String key) {\n            return \"created-\" + key;\n        }\n\n        @Override\n        protected int sizeOf(String key, String value) {\n            return 1;\n        }\n\n        @Override\n        protected void entryRemoved(boolean evicted, String key, String oldValue, String newValue) {\n            if (evicted) {\n                evictedKeys.add(key);\n            }\n        }\n    }\n","newText":""}]}
