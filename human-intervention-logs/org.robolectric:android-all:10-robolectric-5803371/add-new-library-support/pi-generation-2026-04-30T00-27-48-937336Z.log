qualTo(20);\n        assertThat(values.valueAt(0)).isEqualTo(\"TWENTY\");\n        assertThat(copy.size()).isEqualTo(3);\n        assertThat(copy.get(10)).isEqualTo(\"ten\");\n        assertThat(copy.get(20)).isEqualTo(\"TWENTY\");\n        assertThat(copy.get(30)).isEqualTo(\"thirty\");\n\n        copy.clear();\n        assertThat(copy.size()).isZero();\n    }\n\n    @Test\n    void pairCreatesValueObjectsWithReadableMembersAndEquality() {\n"}]}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 4388, "output": 993, "cacheRead": 9728, "cacheWrite": 0, "totalTokens": 15109, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777508782389, "responseId": "resp_0f55234c4a0f76c70169f2a1aeb8c481978fa40f3ecab93e7a"}}
