      /**
       * Does the given context match this camel context
       */
      private boolean matchContext(String context) {
          if (ObjectHelper.isNotEmpty(context)) {
              if (!camelContext.getName().equals(context)) {
                  return false;
              }
          }
          return true;
      }
  
      public String toString() {
