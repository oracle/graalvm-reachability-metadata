egyBeanAdapterTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_apache_camel.camel_core;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport org.apache.camel.Exchange;\nimport org.apache.camel.impl.DefaultCamelContext;\nimport org.apache.camel.impl.DefaultExchange;\nimport org.apache.camel.processor.aggregate.AggregationStrategyBeanAdapter;\nimport org.junit.jupiter.api.Test;\n\npublic class AggregationStrategyBeanAdapterTest {\n    @Test\n    void startsNamedBeanMethodAndAggregatesExchangeBodies() throws Exception {\n        DefaultCamelContext context = new DefaultCamelContext();\n        AggregationStrategyBeanAdapter adapter = new AggregationStrategyBeanAdapter(new NamedAggregationBean(), \"merge\");\n        adapter.setCamelContext(context);\n\n        try {\n            adapter.start();\n            Exchange oldExchange = exchangeWithBody(context, \"old\");\n            Exchange newExchange = exchangeWithBody(context, \"new\");\n\n            Exchange result = adapter.aggregate(oldExchange, newExchange);\n\n            assertThat(result).isSameAs(oldExchange);\n            assertThat(result.getIn().getBody()).isEqualTo(\"old+new\");\n            assertThat(result.getException()).isNull();\n        } finally {\n            adapter.stop();\n            context.stop();\n        }\n    }\n\n    @Test\n    void startsImplicitSingleMethodTypeAndCreatesBeanInstance() throws Exception {\n        DefaultCamelContext context = new DefaultCamelContext();\n        AggregationStrategyBeanAdapter adapter = new AggregationStrategyBeanAdapter(SingleMethodAggregationBean.class);\n        adapter.setCamelContext(context);\n\n        try {\n            adapter.start();\n            Exchange oldExchange = exchangeWithBody(context, \"left\");\n            Exchange newExchange = exchangeWithBody(context, \"right\");\n\n            Exchange result = adapter.aggregate(oldExchange, newExchange);\n\n            assertThat(result).isSameAs(oldExchange);\n            assertThat(result.getIn().getBody()).isEqualTo(\"left|right\");\n            assertThat(result.getException()).isNull();\n        } finally {\n            adapter.stop();\n            context.stop();\n        }\n    }\n\n    private static Exchange exchangeWithBody(DefaultCamelContext context, String body) {\n        Exchange exchange = new DefaultExchange(context);\n        exchange.getIn().setBody(body);\n        return exchange;\n    }\n\n    public static class NamedAggregationBean {\n        public String merge(String oldBody, String newBody) {\n            return oldBody + \"+\" + newBody;\n        }\n    }\n\n    public static class SingleMethodAggregationBean {\n        public String combine(String oldBody, String newBody) {\n            return oldBody + \"|\" + newBody;\n        }\n    }\n}\n"}, "partialJson": "{\"path\":\"tests/src/org.apache.camel/camel-core/2.16.2/src/test/java/org_apache_camel/camel_core/AggregationStrategyBeanAdapterTest.java\",\"content\":\"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage org_apache_camel.camel_core;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\n\\nimport org.apache.camel.Exchange;\\nimport org.apache.camel.impl.DefaultCamelContext;\\nimport org.apache.camel.impl.DefaultExchange;\\nimport org.apache.camel.processor.aggregate.AggregationStrategyBeanAdapter;\\nimport org.junit.jupiter.api.Test;\\n\\npublic class AggregationStrategyBeanAdapterTest {\\n    @Test\\n    void startsNamedBeanMethodAndAggregatesExchangeBodies() throws Exception {\\n        DefaultCamelContext context = new DefaultCamelContext();\\n        AggregationStrategyBeanAdapter adapter = new AggregationStrategyBeanAdapter(new NamedAggregationBean(), \\\"merge\\\");\\n        adapter.setCamelContext(context);\\n\\n        try {\\n            adapter.start();\\n            Exchange oldExchange = exchangeWithBody(context, \\\"old\\\");\\n            Exchange newExchange = exchangeWithBody(context, \\\"new\\\");\\n\\n            Exchange result = adapter.aggregate(oldExchange, newExchange);\\n\\n            assertThat(result).isSameAs(oldExchange);\\n            assertThat(result.getIn().getBody()).isEqualTo(\\\"old+new\\\");\\n            assertThat(result.getException()).isNull();\\n        } finally {\\n            adapter.stop();\\n            context.stop();\\n        }\\n    }\\n\\n    @Test\\n    void startsImplicitSingleMethodTypeAndCreatesBeanInstance() throws Exception {\\n        DefaultCamelContext context = new DefaultCamelContext();\\n        AggregationStrategyBeanAdapter adapter = new AggregationStrategyBeanAdapter(SingleMethodAggregationBean.class);\\n        adapter.setCamelContext(context);\\n\\n        try {\\n            adapter.start();\\n            Exchange oldExchange = exchangeWithBody(context, \\\"left\\\");\\n            Exchange newExchange = exchangeWithBody(context, \\\"right\\\");\\n\\n            Exchange result = adapter.aggregate(oldExchange, newExchange);\\n\\n            assertThat(result).isSameAs(oldExchange);\\n            assertThat(result.getIn().getBody()).isEqualTo(\\\"left|right\\\");\\n            assertThat(result.getException()).isNull();\\n        } finally {\\n            adapter.stop();\\n            context.stop();\\n        }\\n    }\\n\\n    private static Exchange exchangeWithBody(DefaultCamelContext context, String body) {\\n        Exchange exchange = new DefaultExchange(context);\\n        exchange.getIn().setBody(body);\\n        return exchange;\\n    }\\n\\n    public static class NamedAggregationBean {\\n        public String merge(String oldBody, String newBody) {\\n            return oldBody + \\\"+\\\" + newBody;\\n        }\\n    }\\n\\n    public static class SingleMethodAggregationBean {\\n        public String combine(String oldBody, String newBody) {\\n            return oldBody + \\\"|\\\" + newBody;\\n        }\\n    }\\n}\\n\"}"}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 2700, "output": 1227, "cacheRead": 19456, "cacheWrite": 0, "totalTokens": 23383, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1781027130151, "responseId": "resp_0b91d777a1a8e162016a28513ae51c8197885ffc5294a65593"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_qJibYINjGfFlyAtGzoae6qsq|fc_0b91d777a1a8e162016a2851490d648197b8e88805d4136a25", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2871 bytes to tests/src/org.apache.camel/camel-core/2.16.2/src/test/java/org_apache_camel/camel_core/AggregationStrategyBeanAdapterTest.java"}], "isError": false, "timestamp": 1781027150527}]}
