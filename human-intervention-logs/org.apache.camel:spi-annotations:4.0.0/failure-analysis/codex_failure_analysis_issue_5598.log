metadata/org.apache.camel/camel-util-json/index.json:14:      \"org.apache.camel.util.json\"\n./metadata/org.apache.camel/apt/index.json:5:    \"source-code-url\" : \"https://repo.maven.apache.org/maven2/org/apache/camel/apt/$version$/apt-$version$-sources.jar\",\n./metadata/org.apache.camel/apt/index.json:6:    \"repository-url\" : \"https://github.com/apache/camel\",\n./metadata/org.apache.camel/apt/index.json:7:    \"test-code-url\" : \"https://github.com/apache/camel/tree/camel-$version$/tooling/apt/src/test\",\n./metadata/org.apache.camel/apt/index.json:8:    \"documentation-url\" : \"https://repo.maven.apache.org/maven2/org/apache/camel/apt/$version$/apt-$version$-javadoc.jar\",\n./metadata/org.apache.camel/apt/index.json:9:    \"description\" : \"Apache Camel APT is an annotation processor used by Camel tooling to process endpoint and EIP annotations from Camel component source code. It generates structured metadata and documentation inputs, such as endpoint option models and JSON schema information, that Camel uses for component documentation and tooling.\",\n./metadata/org.apache.camel/apt/index.json:25:      \"org.apache.camel.tools.apt\"\n./metadata/org.apache.camel/camel-api/index.json:5:    \"source-code-url\" : \"https://repo.maven.apache.org/maven2/org/apache/camel/camel-api/$version$/camel-api-$version$-sources.jar\",\n./metadata/org.apache.camel/camel-api/index.json:6:    \"repository-url\" : \"https://github.com/apache/camel\",\n./metadata/org.apache.camel/camel-api/index.json:7:    \"test-code-url\" : \"https://repo.maven.apache.org/maven2/org/apache/camel/camel/$version$/camel-$version$-source-release.zip\",\n./metadata/org.apache.camel/camel-api/index.json:8:    \"documentation-url\" : \"https://repo.maven.apache.org/maven2/org/apache/camel/camel-api/$version$/camel-api-$version$-javadoc.jar\",\n./metadata/org.apache.camel/camel-api/index.json:9:    \"description\" : \"Apache Camel API provides the core interfaces, annotations, and contracts used to define routes, exchanges, processors, components, endpoints, registries, and lifecycle services in Camel. It is the public API layer that Camel components and applications compile against while leaving runtime implementations to the rest of Camel.\",\n./metadata/org.apache.camel/camel-api/index.json:14:      \"org.apache.camel\"\n./metadata/org.apache.camel/camel-management-api/index.json:5:    \"source-code-url\" : \"https://repo.maven.apache.org/maven2/org/apache/camel/camel-management-api/$version$/camel-management-api-$version$-sources.jar\",\n./metadata/org.apache.camel/camel-management-api/index.json:6:    \"repository-url\" : \"https://github.com/apache/camel\",\n./metadata/org.apache.camel/camel-management-api/index.json:7:    \"test-code-url\" : \"https://repo.maven.apache.org/maven2/org/apache/camel/camel/$version$/camel-$version$-source-release.zip\",\n./metadata/org.apache.camel/camel-management-api/index.json:8:    \"documentation-url\" : \"https://repo.maven.apache.org/maven2/org/apache/camel/camel-management-api/$version$/camel-management-api-$version$-javadoc.jar\",\n./metadata/org.apache.camel/camel-management-api/index.json:9:    \"description\" : \"Camel Management API provides Apache Camel management annotations, notification contracts, and JMX MBean interfaces for observing and controlling Camel contexts, routes, endpoints, processors, services, and runtime registries. It is the API layer used by Camel management implementations and integrations to expose operational metadata and management operations without bundling the concrete runtime management implementation.\",\n./metadata/org.apache.camel/camel-management-api/index.json:14:      \"org.apache.camel.api.management\"\n./metadata/org.apache.camel/camel-util/index.json:5:    \"source-code-url\" : \"https://repo.maven.apache.org/maven2/org/apache/camel/camel-util/$version$/camel-util-$version$-sources.jar\",\n./metadata/org.apache.camel/camel-util/index.json:6:    \"repository-url\" : \"h