          if (_deserEnable != null) {
              reader = reader.withFeatures(_deserEnable);
          }
          if (_deserDisable != null) {
              reader = reader.withoutFeatures(_deserDisable);
          }
          _reader = reader;
          return (THIS) this;
      }
  
