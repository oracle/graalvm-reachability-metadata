      assertThat(json.hcursor.downN(2).downField("Closed").get[Option[String]]("resolution"))
        .isEqualTo(Right(Some("configuration updated")))
      assertThat(json.as[List[SupportTicketEvent]]).isEqualTo(Right(events))
    }
  
