      GenericUser(
        name = "Ada Lovelace",
        age = 36,
        address = GenericAddress("St James Square", 12345),
        nickname = Some("ada"),
        tags = List("math", "compiler"),
        scores = Map("analysis" -> BigDecimal("98.5"), "logic" -> BigDecimal("100"))
      )
    }
  }
