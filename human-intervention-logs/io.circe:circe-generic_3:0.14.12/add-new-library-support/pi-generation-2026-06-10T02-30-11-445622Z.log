      CustomerProfile(
        id = 101L,
        name = "Ada Lovelace",
        active = true,
        address = PostalAddress("Analytical Engine Road", "Prague", "11000"),
        tags = List("premium", "newsletter"),
        balances = Map("credits" -> BigDecimal("12.50"), "debits" -> BigDecimal("3")),
        nickname = Some("ada")
      )
    }
  }
