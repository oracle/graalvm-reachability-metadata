  trait ConfiguredEnumEncoder[A] extends Encoder[A]
  object ConfiguredEnumEncoder:
    private def of[A](
      labels: List[String]
    )(using conf: Configuration, mirror: Mirror.SumOf[A]): ConfiguredEnumEncoder[A] =
      new ConfiguredEnumEncoder[A]:
