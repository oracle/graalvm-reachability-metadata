        try test()
        finally events = events :+ s"after:${test.name}"
  
      test("first wrapped") {
        events = events :+ "body:first"
      }
  
      test("second wrapped") {
        events = events :+ "body:second"
      }
  
    private final class FutureFunSuite extends AsyncFunSuite:
