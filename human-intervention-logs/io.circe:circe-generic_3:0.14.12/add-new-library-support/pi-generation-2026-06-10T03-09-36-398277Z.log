on: Json = order.asJson\n\n    assertThat(json.hcursor.get[String](\"number\")).isEqualTo(Right(\"order-4\"))\n    assertThat(json.hcursor.downField(\"lines\").downN(0).get[String](\"sku\")).isEqualTo(Right(\"keyboard\"))\n    assertThat(json.hcursor.downField(\"lines\").downN(1).get[Int](\"quantity\")).isEqualTo(Right(2))\n    assertThat(json.as[AutoOrder]).isEqualTo(Right(order))\n  }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 21579, "output": 2517, "cacheRead": 0, "cacheWrite": 0, "totalTokens": 24096, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1781060903470, "responseId": "resp_0ca3540bff41a2df016a28d5283860819591b91077f248fcd4"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_OIPIRnwH9iTWFrqx6V9WdEle|fc_0ca3540bff41a2df016a28d529a9988195ba815d0986447003", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 8377 bytes to tests/src/io.circe/circe-generic_3/0.14.12/src/test/scala/io_circe/circe_generic_3/Circe_generic_3Test.scala"}], "isError": false, "timestamp": 1781060933679}]}
