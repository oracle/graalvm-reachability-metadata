[tool-call] delta {"path":"tests/src/org.apache.camel/camel-support/4.19.0/src/test/java/org_apache_camel/camel_support/scan/DefaultPackageScanClassResolverTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_apache_camel.camel_support.scan;\n\nimport java.util.Set;\n\nimport org.apache.camel.support.scan.DefaultPackageScanClassResolver;\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class DefaultPackageScanClassResolverTest {\n    @Test\n    void findByFilterLoadsClassesDiscoveredFromPackageResources() {\n        try {\n            DefaultPackageScanClassResolver resolver = new DefaultPackageScanClassResolver();\n\n            Set<Class<?>> classes = resolver.findByFilter(\n                    type -> type == DefaultPackageScanClassResolverScanTarget.class,\n                    DefaultPackageScanClassResolverTest.class.getPackageName());\n\n            assertThat(classes).containsExactly(DefaultPackageScanClassResolverScanTarget.class);\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n}\n\nfinal class DefaultPackageScanClassResolverScanTarget {\n}\n"}
