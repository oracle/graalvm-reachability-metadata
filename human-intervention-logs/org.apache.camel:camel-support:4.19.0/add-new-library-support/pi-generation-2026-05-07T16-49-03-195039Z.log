  package org_apache_camel.camel_support;
  
  import java.lang.reflect.Method;
  import java.util.List;
  
  import org.apache.camel.support.component.ApiMethodArg;
  import org.apache.camel.support.component.ApiMethodImpl;
  import org.junit.jupiter.api.Test;
  
  import static org.junit.jupiter.api.Assertions.assertEquals;
  import static org.junit.jupiter.api.Assertions.assertSame;
  
  public class ApiMethodImplTest {
      @Test
      void resolvesProxyMethodFromNonSetterArguments() {
          ApiMethodImpl apiMethod = new ApiMethodImpl(
                  ProxyApi.class,
                  Summary.class,
                  "fetchSummary",
                  ApiMethodArg.arg("accountId", String.class),
                  ApiMethodArg.setter("locale", LocaleOption.class),
                  ApiMethodArg.arg("limit", int.class));
  
          Method method = apiMethod.getMethod();
  
          assertEquals("fetchSummary", apiMethod.getName());
          assertSame(Summary.class, apiMethod.getResultType());
          assertEquals(List.of("accountId", "limit"), apiMethod.getArgNames());
          assertEquals(List.of("locale"), apiMethod.getSetterArgNames());
          assertEquals(List.of(String.class, int.class), apiMethod.getArgTypes());
          assertEquals("fetchSummary", method.getName());
          assertEquals(List.of(String.class, int.class), List.of(method.getParameterTypes()));
          assertSame(Summary.class, method.getReturnType());
      }
  
      public interface ProxyApi {
          Summary fetchSummary(String accountId, int limit);
      }
  
      public static final class Summary {
      }
  
      public static final class LocaleOption {
      }
  }
