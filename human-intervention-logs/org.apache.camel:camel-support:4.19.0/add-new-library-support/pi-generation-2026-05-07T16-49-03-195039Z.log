  package org_apache_camel.camel_support;
  
  import java.lang.annotation.Annotation;
  
  import org.apache.camel.support.language.DefaultAnnotationExpressionFactory;
  import org.junit.jupiter.api.Test;
  
  import static org.junit.jupiter.api.Assertions.assertEquals;
  import static org.junit.jupiter.api.Assertions.assertThrows;
  
  public class DefaultAnnotationExpressionFactoryTest {
      @Test
      void getExpressionFromAnnotationReadsValueMethod() {
          TestAnnotation annotation = new TestAnnotation() {
              @Override
              public String value() {
                  return "body().as(String.class)";
              }
  
              @Override
              public Class<? extends Annotation> annotationType() {
                  return TestAnnotation.class;
              }
          };
          ExposedAnnotationExpressionFactory factory = new ExposedAnnotationExpressionFactory();
  
          String expression = factory.getExpression(annotation);
  
          assertEquals("body().as(String.class)", expression);
      }
  
      @Test
      void getExpressionFromAnnotationRequiresValueMethod() {
          Annotation annotation = new AnnotationWithoutValue() {
              @Override
              public String expression() {
                  return "ignored";
              }
  
              @Override
              public Class<? extends Annotation> annotationType() {
                  return AnnotationWithoutValue.class;
              }
          };
          ExposedAnnotationExpressionFactory factory = new ExposedAnnotationExpressionFactory();
  
          IllegalArgumentException exception = assertThrows(
                  IllegalArgumentException.class,
                  () -> factory.getExpression(annotation));
  
          assertEquals(
                  "Cannot determine the Object value of the annotation: " + annotation
                          + " as it does not have the method: value() method",
                  exception.getMessage());
      }
  
      public @interface TestAnnotation {
          String value();
      }
  
      public @interface AnnotationWithoutValue {
          String expression();
      }
  
      private static final class ExposedAnnotationExpressionFactory extends DefaultAnnotationExpressionFactory {
          String getExpression(Annotation annotation) {
              return getExpressionFromAnnotation(annotation);
          }
      }
  }
