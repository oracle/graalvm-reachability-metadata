mel/camel-support/4.19.0/src/test/java/org_apache_camel/camel_support/DefaultAnnotationExpressionFactoryTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_apache_camel.camel_support;\n\nimport java.lang.annotation.Annotation;\n\nimport org.apache.camel.support.language.DefaultAnnotationExpressionFactory;\nimport org.junit.jupiter.api.Test;\n\nimport static org.junit.jupiter.api.Assertions.assertEquals;\nimport static org.junit.jupiter.api.Assertions.assertThrows;\n\npublic class DefaultAnnotationExpressionFactoryTest {\n    @Test\n    void getExpressionFromAnnotationReadsValueMethod() {\n        TestAnnotation annotation = new TestAnnotation() {\n            @Override\n            public String value() {\n                return \"body().as(String.class)\";\n            }\n\n            @Override\n            public Class<? extends Annotation> annotationType() {\n                return TestAnnotation.class;\n            }\n        };\n        ExposedAnnotationExpressionFactory factory = new ExposedAnnotationExpressionFactory();\n\n        String expression = factory.getExpression(annotation);\n\n        assertEquals(\"body().as(String.class)\", expression);\n    }\n\n    @Test\n    void getExpressionFromAnnotationRequiresValueMethod() {\n        Annotation annotation = new AnnotationWithoutValue() {\n            @Override\n            public String expression() {\n                return \"ignored\";\n            }\n\n            @Override\n            public Class<? extends Annotation> annotationType() {\n                return AnnotationWithoutValue.class;\n            }\n        };\n        ExposedAnnotationExpressionFactory factory = new ExposedAnnotationExpressionFactory();\n\n        IllegalArgumentException exception = assertThrows(\n                IllegalArgumentException.class,\n                () -> factory.getExpression(annotation));\n\n        assertEquals(\n                \"Cannot determine the Object value of the annotation: \" + annotation\n                        + \" as it does not have the method: value() method\",\n                exception.getMessage());\n    }\n\n    private @interface TestAnnotation {\n        String value();\n    }\n\n    private @interface AnnotationWithoutValue {\n        String expression();\n    }\n\n    private static final class ExposedAnnotationExpressionFactory extends DefaultAnnotationExpressionFactory {\n        String getExpression(Annotation annotation) {\n            return getExpressionFromAnnotation(annotation);\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1994, "output": 944, "cacheRead": 11264, "cacheWrite": 0, "totalTokens": 14202, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778172472013, "responseId": "resp_0506221318b8f7e20169fcc238f87481938dbcf578d36548ad"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_h9JRWIuYN2KcHSsS52fsc3Du|fc_0506221318b8f7e20169fcc23f56b48193a6ac696e1af42f2a", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2513 bytes to tests/src/org.apache.camel/camel-support/4.19.0/src/test/java/org_apache_camel/camel_support/DefaultAnnotationExpressionFactoryTest.java"}], "isError": false, "timestamp": 1778172483219}]}
