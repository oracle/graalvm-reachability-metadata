          Enumeration<URL> urls;
          try {
              urls = getResources(loader, packageName);
              if (!urls.hasMoreElements()) {
                  logger().trace("No URLs returned by classloader");
              }
          } catch (IOException ioe) {
              logger().warn("Cannot read package: {}", packageName, ioe);
              return null;
          }
