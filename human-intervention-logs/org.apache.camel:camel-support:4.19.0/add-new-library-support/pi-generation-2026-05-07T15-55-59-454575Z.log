el.support.component.ApiMethodParser.ApiMethodModel;\nimport org.junit.jupiter.api.Test;\n\nimport static org.junit.jupiter.api.Assertions.assertEquals;\nimport static org.junit.jupiter.api.Assertions.assertSame;\n\npublic class ApiMethodParserTest {\n    @Test\n    void parsesMethodWithArrayAndNestedClassArguments() {\n        String signature = \"java.lang.String combine(java.lang.String[] names, \"\n                + \"org_apache_camel.camel_support.ApiMethodParserTest.NestedValue value)\";\n        TestApiMethodParser parser = new TestApiMethodParser(ProxyApi.class);\n        parser.setSignatures(List.of(signature));\n        parser.addSignatureArguments(signature, arguments(\n                \"names\", \"java.lang.String[]\",\n                \"value\", \"org_apache_camel.camel_support.ApiMethodParserTest.NestedValue\"));\n\n        List<ApiMethodModel> models = parser.parse();\n\n        assertEquals(1, models.size());\n        ApiMethodModel model = models.get(0);\n        assertEquals(\"COMBINE\", model.getUniqueName());\n        assertEquals(\"combine\", model.getName());\n        assertSame(String.class, model.getResultType());\n        assertEquals(\"combine\", model.getMethod().getName());\n        assertEquals(List.of(String[].class, NestedValue.class), model.getArguments().stream()\n                .map(ApiMethodArg::getType)\n                .toList());\n    }\n\n    private static Map<String, String> arguments(String firstName, String firstType, String secondName, String secondType) {\n        Map<String, String> arguments = new LinkedHashMap<>();\n        arguments.put(firstName, firstType);\n        arguments.put(secondName, secondType);\n        return arguments;\n    }\n\n    public interface ProxyApi {\n        String combine(String[] names, NestedValue value);\n    }\n\n    public static final class NestedValue {\n    }\n\n    private static final class TestApiMethodParser extends ApiMethodParser<ProxyApi> {\n        private TestApiMethodParser(Class<ProxyApi> proxyType) {\n            super(proxyType);\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1198, "output": 1157, "cacheRead": 16896, "cacheWrite": 0, "totalTokens": 19251, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778169336226, "responseId": "resp_0c81ce9f84f39df40169fcb5f9163481a097e89954c3d94e2a"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_UD987CIEdHEHMH2jpxV2YsMN|fc_0c81ce9f84f39df40169fcb604a10481a0b83369de7eccf762", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2473 bytes to tests/src/org.apache.camel/camel-support/4.19.0/src/test/java/org_apache_camel/camel_support/ApiMethodParserTest.java"}], "isError": false, "timestamp": 1778169350982}]}
