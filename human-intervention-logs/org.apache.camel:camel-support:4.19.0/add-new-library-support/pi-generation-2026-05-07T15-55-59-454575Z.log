  package org_apache_camel.camel_support;
  
  import java.lang.reflect.InvocationHandler;
  import java.lang.reflect.Proxy;
  
  import org.apache.camel.CamelContext;
  import org.apache.camel.Exchange;
  import org.apache.camel.support.PropertyBindingSupport;
  import org.apache.camel.support.SimpleRegistry;
  import org.apache.camel.support.SimpleTypeConverter;
  import org.apache.camel.spi.PropertyConfigurer;
  import org.apache.camel.spi.PropertyConfigurerGetter;
  import org.junit.jupiter.api.Test;
  
  import static org.junit.jupiter.api.Assertions.assertArrayEquals;
  import static org.junit.jupiter.api.Assertions.assertEquals;
  import static org.junit.jupiter.api.Assertions.assertInstanceOf;
  import static org.junit.jupiter.api.Assertions.assertTrue;
  
  public class PropertyBindingSupportTest {
      @Test
      void constructorParametersCreateInstanceAfterQuotedNumericFallback() throws Exception {
          CamelContext camelContext = minimalCamelContext();
  
          Object result = PropertyBindingSupport.newInstanceConstructorParameters(
                  camelContext, ConstructorParameterBean.class, "'7'");
  
          ConstructorParameterBean bean = assertInstanceOf(ConstructorParameterBean.class, result);
          assertEquals(7, bean.number());
      }
  
      @Test
      void factoryParametersInvokeStaticFactoryAfterQuotedNumericFallback() throws Exception {
          CamelContext camelContext = minimalCamelContext();
  
          Object result = PropertyBindingSupport.newInstanceFactoryParameters(
                  camelContext, FactoryParameterBean.class, "create", "'11'");
  
          FactoryParameterBean bean = assertInstanceOf(FactoryParameterBean.class, result);
          assertEquals(11, bean.number());
      }
  
      @Test
      void constructorParametersRetryWithUnquotedParameterTypes() throws Exception {
          CamelContext camelContext = minimalCamelContext();
  
          Object result = PropertyBindingSupport.newInstanceConstructorParameters(
                  camelContext, ConstructorFallbackBean.class, "'alpha'");
  
          ConstructorFallbackBean bean = assertInstanceOf(ConstructorFallbackBean.class, result);
          assertEquals("alpha", bean.value().name());
      }
  
      @Test
      void factoryParametersRetryWithUnquotedParameterTypes() throws Exception {
          CamelContext camelContext = minimalCamelContext();
  
          Object result = PropertyBindingSupport.newInstanceFactoryParameters(
                  camelContext, FactoryFallbackBean.class, "create", "'bravo'");
  
          FactoryFallbackBean bean = assertInstanceOf(FactoryFallbackBean.class, result);
          assertEquals("bravo", bean.value().name());
      }
  
      @Test
      void configurerBindingCreatesArrayForCollectionProperty() {
          CamelContext camelContext = minimalCamelContext();
          ArrayTarget target = new ArrayTarget();
          ArrayTargetConfigurer configurer = new ArrayTargetConfigurer();
  
          boolean bound = PropertyBindingSupport.build()
                  .withCamelContext(camelContext)
                  .withTarget(target)
                  .withConfigurer(configurer)
                  .withReflection(false)
                  .withProperty("names[0]", "camel")
                  .bind();
  
          assertTrue(bound);
          assertArrayEquals(new Object[] {"camel"}, target.names());
      }
  
      private static CamelContext minimalCamelContext() {
          SimpleRegistry registry = new SimpleRegistry();
          SimpleTypeConverter typeConverter = new SimpleTypeConverter(false, PropertyBindingSupportTest::convert);
          InvocationHandler handler = (proxy, method, args) -> switch (method.getName()) {
              case "getRegistry" -> registry;
              case "getTypeConverter" -> typeConverter;
              case "resolvePropertyPlaceholders" -> args[0];
              case "toString" -> "minimal-camel-context";
              default -> defaultValue(method.getReturnType());
          };
          return (CamelContext) Proxy.newProxyInstance(
                  PropertyBindingSupportTest.class.getClassLoader(), new Class<?>[] {CamelContext.class}, handler);
      }
  
      private static Object convert(Class<?> type, Exchange exchange, Object value) {
          String text = String.valueOf(value);
          if (type == String.class) {
              return text;
          }
          if (type == int.class || type == Integer.class) {
              return Integer.valueOf(text);
          }
          if (type == long.class || type == Long.class) {
              return Long.valueOf(text);
          }
          if (type == boolean.class || type == Boolean.class) {
              return Boolean.valueOf(text);
          }
          if (type == NamedValue.class) {
              return new NamedValue(text);
          }
          if (type == Object.class || type.isInstance(value)) {
              return value;
          }
          return null;
      }
  
      private static Object defaultValue(Class<?> returnType) {
          if (returnType == boolean.class) {
              return false;
          }
          if (returnType == byte.class) {
              return (byte) 0;
          }
          if (returnType == short.class) {
              return (short) 0;
          }
          if (returnType == int.class) {
              return 0;
          }
          if (returnType == long.class) {
              return 0L;
          }
          if (returnType == float.class) {
              return 0.0F;
          }
          if (returnType == double.class) {
              return 0.0D;
          }
          if (returnType == char.class) {
              return '\0';
          }
          return null;
      }
  
      public static final class ConstructorParameterBean {
          private final int number;
  
          public ConstructorParameterBean(int number) {
              this.number = number;
          }
  
          int number() {
              return number;
          }
      }
  
      public static final class FactoryParameterBean {
          private final int number;
  
          private FactoryParameterBean(int number) {
              this.number = number;
          }
  
          public static FactoryParameterBean create(int number) {
              return new FactoryParameterBean(number);
          }
  
          int number() {
              return number;
          }
      }
  
      public static final class ConstructorFallbackBean {
          private final NamedValue value;
  
          public ConstructorFallbackBean(NamedValue value) {
              this.value = value;
          }
  
          NamedValue value() {
              return value;
          }
      }
  
      public static final class FactoryFallbackBean {
          private final NamedValue value;
  
          private FactoryFallbackBean(NamedValue value) {
              this.value = value;
          }
  
          public static FactoryFallbackBean create(NamedValue value) {
              return new FactoryFallbackBean(value);
          }
  
          NamedValue value() {
              return value;
          }
      }
  
      public record NamedValue(String name) {
      }
  
      public static final class ArrayTarget {
          private Object[] names;
  
          public Object[] names() {
              return names;
          }
  
          void setNames(Object[] names) {
              this.names = names;
          }
      }
  
      public static final class ArrayTargetConfigurer implements PropertyConfigurer, PropertyConfigurerGetter {
          @Override
          public boolean configure(CamelContext camelContext, Object target, String name, Object value, boolean ignoreCase) {
              if (target instanceof ArrayTarget arrayTarget && "names".equals(name)) {
                  arrayTarget.setNames((Object[]) value);
                  return true;
              }
              return false;
          }
  
          @Override
          public Class<?> getOptionType(String name, boolean ignoreCase) {
              if ("names".equals(name)) {
                  return Object[].class;
              }
              return null;
          }
  
          @Override
          public Object getOptionValue(Object target, String name, boolean ignoreCase) {
              if (target instanceof ArrayTarget arrayTarget && "names".equals(name)) {
                  return arrayTarget.names();
              }
              return null;
          }
      }
  }
