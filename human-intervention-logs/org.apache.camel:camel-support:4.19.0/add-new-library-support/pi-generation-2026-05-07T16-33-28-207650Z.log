[tool-call] delta {"path":"tests/src/org.apache.camel/camel-support/4.19.0/src/test/java/org_apache_camel/camel_support/DefaultThreadPoolFactoryInnerThreadPoolFactoryTypeTest.java","edits":[{"oldText":"    void newThreadPoolUsesVirtualThreadPerTaskExecutor() throws Exception {\n        System.setProperty(\"camel.threads.virtual.enabled\", \"true\");\n        ExecutorService executorService = new DefaultThreadPoolFactory().newThreadPool(\n                1, 2, 1, TimeUnit.SECONDS, 1, true, null, new VirtualThreadFactory());\n\n        try {\n            Future<Boolean> result = executorService.submit((Callable<Boolean>) () -> Thread.currentThread().isVirtual());\n\n            assertTrue(result.get(10, TimeUnit.SECONDS));\n        } finally {\n            executorService.shutdownNow();\n            assertTrue(executorService.awaitTermination(10, TimeUnit.SECONDS));\n        }\n    }\n","newText":"    void newThreadPoolUsesVirtualThreadPerTaskExecutor() throws Exception {\n        String previousThreadType = System.setProperty(\"camel.threads.virtual.enabled\", \"true\");\n        ExecutorService executorService = new DefaultThreadPoolFactory().newThreadPool(\n                1, 2, 1, TimeUnit.SECONDS, 1, true, null, new VirtualThreadFactory());\n\n        try {\n            Future<Boolean> result = executorService.submit((Callable<Boolean>) () -> Thread.currentThread().isVirtual());\n\n            assertTrue(result.get(10, TimeUnit.SECONDS));\n        } finally {\n            executorService.shutdownNow();\n            assertTrue(executorService.awaitTermination(10, TimeUnit.SECONDS));\n            if (previousThreadType == null) {\n                System.clearProperty(\"camel.threads.virtual.enabled\");\n            } else {\n                System.setProperty(\"camel.threads.virtual.enabled\", previousThreadType);\n            }\n        }\n    }\n"}]}
