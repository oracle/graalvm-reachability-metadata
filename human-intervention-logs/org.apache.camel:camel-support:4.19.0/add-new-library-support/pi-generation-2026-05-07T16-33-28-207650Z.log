  package org_apache_camel.camel_support;
  
  import java.lang.reflect.Method;
  
  import org.apache.camel.AsyncCallback;
  import org.apache.camel.support.AsyncCallbackToCompletableFutureAdapter;
  import org.apache.camel.support.ObjectHelper;
  import org.junit.jupiter.api.Test;
  
  import static org.junit.jupiter.api.Assertions.assertFalse;
  import static org.junit.jupiter.api.Assertions.assertInstanceOf;
  import static org.junit.jupiter.api.Assertions.assertNull;
  import static org.junit.jupiter.api.Assertions.assertSame;
  
  public class ObjectHelperTest {
      @Test
      void newInstanceCreatesDefaultConstructedType() {
          AsyncCallbackToCompletableFutureAdapter<?> adapter
                  = ObjectHelper.newInstance(AsyncCallbackToCompletableFutureAdapter.class);
  
          assertInstanceOf(AsyncCallbackToCompletableFutureAdapter.class, adapter);
          assertFalse(adapter.getFuture().isDone());
      }
  
      @Test
      void newInstanceCastsDefaultConstructedTypeToExpectedType() {
          AsyncCallback callback = ObjectHelper.newInstance(
                  AsyncCallbackToCompletableFutureAdapter.class, AsyncCallback.class);
  
          assertInstanceOf(AsyncCallbackToCompletableFutureAdapter.class, callback);
      }
  
      @Test
      void invokeMethodInvokesMethodWithParameters() throws Exception {
          AsyncCallbackToCompletableFutureAdapter<String> adapter = new AsyncCallbackToCompletableFutureAdapter<>();
          Method method = AsyncCallbackToCompletableFutureAdapter.class.getMethod("setResult", Object.class);
  
          Object result = ObjectHelper.invokeMethod(method, adapter, "camel");
          adapter.done(true);
  
          assertNull(result);
          assertSame("camel", adapter.getFuture().getNow(null));
      }
  
      @Test
      void invokeMethodInvokesMethodWithNullParametersArray() throws Exception {
          AsyncCallbackToCompletableFutureAdapter<String> adapter = new AsyncCallbackToCompletableFutureAdapter<>();
          Method method = AsyncCallbackToCompletableFutureAdapter.class.getMethod("getFuture");
  
          Object result = ObjectHelper.invokeMethod(method, adapter, (Object[]) null);
  
          assertSame(adapter.getFuture(), result);
      }
  
      @Test
      void invokeMethodSafeInvokesMethodWithParameters() throws Exception {
          AsyncCallbackToCompletableFutureAdapter<String> adapter = new AsyncCallbackToCompletableFutureAdapter<>();
          Method method = AsyncCallbackToCompletableFutureAdapter.class.getMethod("setResult", Object.class);
  
          Object result = ObjectHelper.invokeMethodSafe(method, adapter, "camel-safe");
          adapter.done(true);
  
          assertNull(result);
          assertSame("camel-safe", adapter.getFuture().getNow(null));
      }
  
      @Test
      void invokeMethodSafeInvokesMethodWithNullParametersArray() throws Exception {
          AsyncCallbackToCompletableFutureAdapter<String> adapter = new AsyncCallbackToCompletableFutureAdapter<>();
          Method method = AsyncCallbackToCompletableFutureAdapter.class.getMethod("getFuture");
  
          Object result = ObjectHelper.invokeMethodSafe(method, adapter, (Object[]) null);
  
          assertSame(adapter.getFuture(), result);
      }
  }
