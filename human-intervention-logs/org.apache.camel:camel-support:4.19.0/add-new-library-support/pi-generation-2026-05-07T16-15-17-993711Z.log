  package org_apache_camel.camel_support;
  
  import java.lang.reflect.Method;
  import java.util.List;
  import java.util.Map;
  import java.util.stream.Collectors;
  
  import org.apache.camel.support.component.ApiMethod;
  import org.apache.camel.support.component.ApiMethodHelper;
  import org.junit.jupiter.api.Test;
  
  import static org.junit.jupiter.api.Assertions.assertEquals;
  
  public class ApiMethodHelperTest {
      @Test
      void convertsCollectionArgumentToArrayBeforeInvokingProxyMethod() {
          Object result = ApiMethodHelper.invokeMethod(
                  new RecordingProxy(),
                  TestApiMethod.COMBINE_WORDS,
                  Map.of("values", List.of("alpha", "beta")));
  
          assertEquals("java.lang.String:alpha|beta", result);
      }
  
      @Test
      void convertsDerivedArrayArgumentToDeclaredSuperArrayBeforeInvokingProxyMethod() {
          Integer[] values = new Integer[] { 1, 2, 3 };
  
          Object result = ApiMethodHelper.invokeMethod(
                  new RecordingProxy(),
                  TestApiMethod.DESCRIBE_NUMBERS,
                  Map.of("numbers", values));
  
          assertEquals("java.lang.Number:1,2,3", result);
      }
  
      public interface ProxyApi {
          String combineWords(String[] values);
  
          String describeNumbers(Number[] numbers);
      }
  
      public static final class RecordingProxy implements ProxyApi {
          @Override
          public String combineWords(String[] values) {
              return values.getClass().getComponentType().getName() + ":" + String.join("|", values);
          }
  
          @Override
          public String describeNumbers(Number[] numbers) {
              String valueText = List.of(numbers).stream()
                      .map(String::valueOf)
                      .collect(Collectors.joining(","));
              return numbers.getClass().getComponentType().getName() + ":" + valueText;
          }
      }
  
      private enum TestApiMethod implements ApiMethod {
          COMBINE_WORDS("combineWords", String.class, List.of("values"), String[].class),
          DESCRIBE_NUMBERS("describeNumbers", String.class, List.of("numbers"), Number[].class);
  
          private final String name;
          private final Class<?> resultType;
          private final List<String> argNames;
          private final List<Class<?>> argTypes;
          private final Method method;
  
          TestApiMethod(String name, Class<?> resultType, List<String> argNames, Class<?>... argTypes) {
              this.name = name;
              this.resultType = resultType;
              this.argNames = argNames;
              this.argTypes = List.of(argTypes);
              this.method = lookupProxyMethod(name, argTypes);
          }
  
          @Override
          public String getName() {
              return name;
          }
  
          @Override
          public Class<?> getResultType() {
              return resultType;
          }
  
          @Override
          public List<String> getArgNames() {
              return argNames;
          }
  
          @Override
          public List<String> getSetterArgNames() {
              return List.of();
          }
  
          @Override
          public List<Class<?>> getArgTypes() {
              return argTypes;
          }
  
          @Override
          public Method getMethod() {
              return method;
          }
  
