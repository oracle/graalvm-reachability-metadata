DeclaredSuperArrayBeforeInvokingProxyMethod() {\n        Integer[] values = new Integer[] { 1, 2, 3 };\n\n        Object result = ApiMethodHelper.invokeMethod(\n                new RecordingProxy(),\n                TestApiMethod.DESCRIBE_NUMBERS,\n                Map.of(\"numbers\", values));\n\n        assertEquals(\"java.lang.Number:1,2,3\", result);\n    }\n\n    public interface ProxyApi {\n        String combineWords(String[] values);\n\n        String describeNumbers(Number[] numbers);\n    }\n\n    public static final class RecordingProxy implements ProxyApi {\n        @Override\n        public String combineWords(String[] values) {\n            return values.getClass().getComponentType().getName() + \":\" + String.join(\"|\", values);\n        }\n\n        @Override\n        public String describeNumbers(Number[] numbers) {\n            String valueText = List.of(numbers).stream()\n                    .map(String::valueOf)\n                    .collect(Collectors.joining(\",\"));\n            return numbers.getClass().getComponentType().getName() + \":\" + valueText;\n        }\n    }\n\n    private enum TestApiMethod implements ApiMethod {\n        COMBINE_WORDS(\"combineWords\", String.class, List.of(\"values\"), String[].class),\n        DESCRIBE_NUMBERS(\"describeNumbers\", String.class, List.of(\"numbers\"), Number[].class);\n\n        private final String name;\n        private final Class<?> resultType;\n        private final List<String> argNames;\n        private final List<Class<?>> argTypes;\n        private final Method method;\n\n        TestApiMethod(String name, Class<?> resultType, List<String> argNames, Class<?>... argTypes) {\n            this.name = name;\n            this.resultType = resultType;\n            this.argNames = argNames;\n            this.argTypes = List.of(argTypes);\n            this.method = lookupProxyMethod(name, argTypes);\n        }\n\n        @Override\n        public String getName() {\n            return name;\n        }\n\n        @Override\n        public Class<?> getResultType() {\n            return resultType;\n        }\n\n        @Override\n        public List<String> getArgNames() {\n            return argNames;\n        }\n\n        @Override\n        public List<String> getSetterArgNames() {\n            return List.of();\n        }\n\n        @Override\n        public List<Class<?>> getArgTypes() {\n            return argTypes;\n        }\n\n        @Override\n        public Method getMethod() {\n            return method;\n        }\n\n        private static Method lookupProxyMethod(String name, Class<?>... parameterTypes) {\n            try {\n                return ProxyApi.class.getMethod(name, parameterTypes);\n            } catch (NoSuchMethodException e) {\n                throw new ExceptionInInitializerError(e);\n            }\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 932, "output": 1987, "cacheRead": 13312, "cacheWrite": 0, "totalTokens": 16231, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778169878899, "responseId": "resp_0274e215bbc247cc0169fcb817cb6881909608e0c477d65377"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_Tii7SZAF13AZyvH4h3Xfbv7w|fc_0274e215bbc247cc0169fcb82a20c081909df5511d9d256866", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 3794 bytes to tests/src/org.apache.camel/camel-support/4.19.0/src/test/java/org_apache_camel/camel_support/ApiMethodHelperTest.java"}], "isError": false, "timestamp": 1778169903834}]}
