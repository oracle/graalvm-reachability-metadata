    private final Class<?> resultType;\n        private final List<String> argNames;\n        private final List<Class<?>> argTypes;\n        private final Method method;\n\n        TestApiMethod(String name, Class<?> resultType, List<String> argNames, Class<?>... argTypes) {\n            this.name = name;\n            this.resultType = resultType;\n            this.argNames = argNames;\n            this.argTypes = List.of(argTypes);\n            this.method = lookupProxyMethod(name, argTypes);\n        }\n\n        @Override\n        public String getName() {\n            return name;\n        }\n\n        @Override\n        public Class<?> getResultType() {\n            return resultType;\n        }\n\n        @Override\n        public List<String> getArgNames() {\n            return argNames;\n        }\n\n        @Override\n        public List<String> getSetterArgNames() {\n            return List.of();\n        }\n\n        @Override\n        public List<Class<?>> getArgTypes() {\n            return argTypes;\n        }\n\n        @Override\n        public Method getMethod() {\n            return method;\n        }\n\n        private static Method lookupProxyMethod(String name, Class<?>... parameterTypes) {\n            try {\n                return ProxyApi.class.getMethod(name, parameterTypes);\n            } catch (NoSuchMethodException e) {\n                throw new ExceptionInInitializerError(e);\n            }\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778169908687}]}
