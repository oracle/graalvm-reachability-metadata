[tool-call] delta {"path":"tests/src/org.apache.camel/camel-support/4.19.0/src/test/java/org_apache_camel/camel_support/ResumablesTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_apache_camel.camel_support;\n\nimport org.apache.camel.support.resume.Resumables;\nimport org.junit.jupiter.api.Test;\n\nimport static org.junit.jupiter.api.Assertions.assertArrayEquals;\nimport static org.junit.jupiter.api.Assertions.assertNotSame;\nimport static org.junit.jupiter.api.Assertions.assertSame;\n\npublic class ResumablesTest {\n    @Test\n    void resumeEachReturnsTypedArrayWithEntriesThatShouldResume() {\n        String[] input = { \"first\", \"second\", \"third\" };\n\n        String[] resumableEntries = Resumables.resumeEach(input, entry -> entry.contains(\"i\"));\n\n        assertNotSame(input, resumableEntries);\n        assertArrayEquals(new String[] { \"first\", \"third\" }, resumableEntries);\n    }\n\n    @Test\n    void resumeEachReturnsOriginalArrayWhenEveryEntryShouldResume() {\n        String[] input = { \"alpha\", \"beta\" };\n\n        String[] resumableEntries = Resumables.resumeEach(input, entry -> true);\n\n        assertSame(input, resumableEntries);\n        assertArrayEquals(input, resumableEntries);\n    }\n}\n"}
