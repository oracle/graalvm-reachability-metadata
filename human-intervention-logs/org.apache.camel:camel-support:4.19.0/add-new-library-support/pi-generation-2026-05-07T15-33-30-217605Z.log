eInstanceAfterQuotedNumericFallback() throws Exception {\n        CamelContext camelContext = minimalCamelContext();\n\n        Object result = PropertyBindingSupport.newInstanceConstructorParameters(\n                camelContext, ConstructorParameterBean.class, \"'7'\");\n\n        ConstructorParameterBean bean = assertInstanceOf(ConstructorParameterBean.class, result);\n        assertEquals(7, bean.number());\n    }\n\n    @Test\n    void factoryParametersInvokeStaticFactoryAfterQuotedNumericFallback() throws Exception {\n        CamelContext camelContext = minimalCamelContext();\n\n        Object result = PropertyBindingSupport.newInstanceFactoryParameters(\n                camelContext, FactoryParameterBean.class, \"create\", \"'11'\");\n\n        FactoryParameterBean bean = assertInstanceOf(FactoryParameterBean.class, result);\n        assertEquals(11, bean.number());\n    }\n\n    @Test\n    void configurerBindingCreatesArrayForCollectionProperty() {\n        CamelContext camelContext = minimalCamelContext();\n        ArrayTarget target = new ArrayTarget();\n        ArrayTargetConfigurer configurer = new ArrayTargetConfigurer();\n\n        boolean bound = PropertyBindingSupport.build()\n                .withCamelContext(camelContext)\n                .withTarget(target)\n                .withConfigurer(configurer)\n                .withReflection(false)\n                .withProperty(\"names[0]\", \"camel\")\n                .bind();\n\n        assertTrue(bound);\n        assertArrayEquals(new Object[] {\"camel\"}, target.names());\n    }\n\n    private static CamelContext minimalCamelContext() {\n        SimpleRegistry registry = new SimpleRegistry();\n        SimpleTypeConverter typeConverter = new SimpleTypeConverter(false, PropertyBindingSupportTest::convert);\n        InvocationHandler handler = (proxy, method, args) -> switch (method.getName()) {\n            case \"getRegistry\" -> registry;\n            case \"getTypeConverter\" -> typeConverter;\n            case \"resolvePropertyPlaceholders\" -> args[0];\n            case \"toString\" -> \"minimal-camel-context\";\n            default -> defaultValue(method.getReturnType());\n        };\n        return (CamelContext) Proxy.newProxyInstance(\n                PropertyBindingSupportTest.class.getClassLoader(), new Class<?>[] {CamelContext.class}, handler);\n    }\n\n    private static Object convert(Class<?> type, Exchange exchange, Object value) {\n        String text = String.valueOf(value);\n        if (type == String.class) {\n            return text;\n        }\n        if (type == int.class || type == Integer.class) {\n            return Integer.valueOf(text);\n        }\n        if (type == long.class || type == Long.class) {\n            return Long.valueOf(text);\n        }\n        if (type == boolean.class || type == Boolean.class) {\n            return Boolean.valueOf(text);\n        }\n        if (type == Object.class || type.isInstance(value)) {\n            return value;\n        }\n        return null;\n    }\n\n    private static Object defaultValue(Class<?> returnType) {\n        if (returnType == boolean.class) {\n            return false;\n        }\n        if (returnType == byte.class) {\n            return (byte) 0;\n        }\n        if (returnType == short.class) {\n            return (short) 0;\n        }\n        if (returnType == int.class) {\n            return 0;\n        }\n        if (returnType == long.class) {\n            return 0L;\n        }\n        if (returnType == float.class) {\n            return 0.0F;\n        }\n        if (returnType == double.class) {\n            return 0.0D;\n        }\n        if (returnType == char.class) {\n            return '\\0';\n        }\n        return null;\n    }\n\n    public static final class ConstructorParameterBean {\n        private final int number;\n\n        public ConstructorParameterBean(int number) {\n            this.number = number;\n        }\n\n        int number() {\n            return number;\n        }\n    }\n\n    public static final class FactoryParameterBean {\n        private final int number;\n\n        private FactoryParameterBean(int number) {\n            this.number = number;\n        }\n\n        public static FactoryParameterBean create(int number) {\n            return new FactoryParameterBean(number);\n        }\n\n        int number() {\n            return number;\n        }\n    }\n\n    public static final class ArrayTarget {\n        private Object[] names;\n\n        public Object[] names() {\n            return names;\n        }\n\n        void setNames(Object[] names) {\n            this.names = names;\n        }\n    }\n\n    public static final class ArrayTargetConfigurer implements PropertyConfigurer, PropertyConfigurerGetter {\n        @Override\n        public boolean configure(CamelContext camelContext, Object target, String name, Object value, boolean ignoreCase) {\n            if (target instanceof ArrayTarget arrayTarget && \"names\".equals(name)) {\n                arrayTarget.setNames((Object[]) value);\n                return true;\n            }\n            return false;\n        }\n\n        @Override\n        public Class<?> getOptionType(String name, boolean ignoreCase) {\n            if (\"names\".equals(name)) {\n                return Object[].class;\n            }\n            return null;\n        }\n\n        @Override\n        public Object getOptionValue(Object target, String name, boolean ignoreCase) {\n            if (target instanceof ArrayTarget arrayTarget && \"names\".equals(name)) {\n                return arrayTarget.names();\n            }\n            return null;\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778168469048}]}
