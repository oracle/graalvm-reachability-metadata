  package org_apache_camel.camel_support;
  
  import java.lang.reflect.InvocationHandler;
  import java.lang.reflect.Proxy;
  
  import org.apache.camel.CamelContext;
  import org.apache.camel.Exchange;
  import org.apache.camel.support.PropertyBindingSupport;
  import org.apache.camel.support.SimpleRegistry;
  import org.apache.camel.support.SimpleTypeConverter;
  import org.apache.camel.spi.PropertyConfigurer;
  import org.apache.camel.spi.PropertyConfigurerGetter;
  import org.junit.jupiter.api.Test;
  
  import static org.junit.jupiter.api.Assertions.assertArrayEquals;
  import static org.junit.jupiter.api.Assertions.assertEquals;
  import static org.junit.jupiter.api.Assertions.assertInstanceOf;
  import static org.junit.jupiter.api.Assertions.assertTrue;
  
  public class PropertyBindingSupportTest {
      @Test
      void constructorParametersCreateInstanceAfterQuotedNumericFallback() throws Exception {
          CamelContext camelContext = minimalCamelContext();
  
          Object result = PropertyBindingSupport.newInstanceConstructorParameters(
                  camelContext, ConstructorParameterBean.class, "'7'");
  
          ConstructorParameterBean bean = assertInstanceOf(ConstructorParameterBean.class, result);
          assertEquals(7, bean.number());
      }
  
      @Test
      void factoryParametersInvokeStaticFactoryAfterQuotedNumericFallback() throws Exception {
          CamelContext camelContext = minimalCamelContext();
  
          Object result = PropertyBindingSupport.newInstanceFactoryParameters(
                  camelContext, FactoryParameterBean.class, "create", "'11'");
  
          FactoryParameterBean bean = assertInstanceOf(FactoryParameterBean.class, result);
          assertEquals(11, bean.number());
      }
  
      @Test
      void constructorParametersRetryWithUnquotedParameterTypes() throws Exception {
          CamelContext camelContext = minimalCamelContext();
  
          Object result = PropertyBindingSupport.newInstanceConstructorParameters(
                  camelContext, ConstructorFallbackBean.class, "'alpha'");
  
          ConstructorFallbackBean bean = assertInstanceOf(ConstructorFallbackBean.class, result);
          assertEquals("alpha", bean.value().name());
      }
  
      @Test
      void factoryParametersRetryWithUnquotedParameterTypes() throws Exception {
          CamelContext camelContext = minimalCamelContext();
  
          Object result = PropertyBindingSupport.newInstanceFactoryParameters(
                  camelContext, FactoryFallbackBean.class, "create", "'bravo'");
  
          FactoryFallbackBean bean = assertInstanceOf(FactoryFallbackBean.class, result);
          assertEquals("bravo", bean.value().name());
      }
  
      @Test
      void configurerBindingCreatesArrayForCollectionProperty() {
          CamelContext camelContext = minimalCamelContext();
          ArrayTarget target = new ArrayTarget();
          ArrayTargetConfigurer configurer = new ArrayTargetConfigurer();
  
          boolean bound = PropertyBindingSupport.build()
                  .withCamelContext(camelContext)
                  .withTarget(target)
                  .withConfigurer(configurer)
                  .withReflection(false)
                  .withProperty("names[0]", "camel")
                  .bind();
  
          assertTrue(bound);
          assertArrayEquals(new Object[] {"camel"}, target.names());
