      assertEquals("example-service.com", hostname.normalized.toString)
      assertEquals(None, Hostname.fromString("-bad.example"))
      assertEquals(None, Hostname.fromString("bad-.example"))
      assertEquals(None, Hostname.fromString("a" * 64))
      assertEquals(None, Hostname.fromString(""))
  
