ets.UTF_8);\n+157 \n+158         compileDocumentation(\n+159                 sourceDirectory,\n+160                 outputDirectory,\n+161                 List.of(handbook),\n+162                 List.of(\"-Adocgen.source=\" + documentDirectory));\n+163 \n+164         Path generatedDocument = outputDirectory.resolve(\"getting-started.adoc\");\n+165         assertThat(generatedDocument).exists();\n+166         assertThat(Files.readString(generatedDocument, StandardCharsets.UTF_8))\n+167                 .contains(\"= Getting started\")\n+168                 .contains(\"`link:../../apidocs/example/manual/Handbook.html[Handbook]`\");\n+169     }\n+170 \n 136     private static void compileDocumentation(\n 137             Path sourceDirectory, Path outputDirectory, List<Path> sourceFiles) throws IOException {\n+173         compileDocumentation(sourceDirectory, outputDirectory, sourceFiles, List.of());\n+174     }\n+175 \n+176     private static void compileDocumentation(\n+177             Path sourceDirectory, Path outputDirectory, List<Path> sourceFiles, List<String> processorOptions)\n+178             throws IOException {\n 138         Path classDirectory = sourceDirectory.resolveSibling(\"classes\");\n 139         Files.createDirectories(outputDirectory);\n 140         Files.createDirectories(classDirectory);\n 141 \n     ...\n 144         DiagnosticCollector<JavaFileObject> diagnostics = new DiagnosticCollector<>();\n 145         try (StandardJavaFileManager fileManager = compiler.getStandardFileManager(\n 146                 diagnostics, Locale.ROOT, StandardCharsets.UTF_8)) {\n 147             fileManager.setLocationFromPaths(StandardLocation.CLASS_OUTPUT, List.of(classDirectory));\n+189             List<String> options = new ArrayList<>(List.of(\"-proc:only\", \"-Adocgen.output=\" + outputDirectory));\n+190             options.addAll(processorOptions);\n 148             JavaCompiler.CompilationTask task = compiler.getTask(\n 149                     null,\n 150                     fileManager,\n 151                     diagnostics,\n-152                     List.of(\"-proc:only\", \"-Adocgen.output=\" + outputDirectory),\n+195                     options,\n 153                     null,\n 154                     fileManager.getJavaFileObjectsFromPaths(sourceFiles));\n 155             task.setProcessors(List.of(new DocGenProcessor(new JavaDocGenerator())));\n 156 \n     ...", "firstChangedLine": 15}, "isError": false, "timestamp": 1783986695591}}
