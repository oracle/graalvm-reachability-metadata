          if (reportedElt != null) {
            processingEnv.getMessager().printMessage(Diagnostic.Kind.ERROR, msg, reportedElt);
            if (reportedElt instanceof PackageElement) {
              failures.put(((PackageElement) reportedElt).getQualifiedName().toString(), msg);
