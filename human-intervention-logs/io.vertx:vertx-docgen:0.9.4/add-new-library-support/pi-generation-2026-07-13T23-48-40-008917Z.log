  ==== Source
  1:package io.vertx.docgen;
  2:
  3:import java.lang.annotation.ElementType;
  4:import java.lang.annotation.Retention;
  5:import java.lang.annotation.RetentionPolicy;
  6:import java.lang.annotation.Target;
  7:
  8:/**
  9: * Define a scope for source code inclusion: any link ref in this scope should include the content instead
  10: * of linking to it.
  11: *
  12: * @author <a href="mailto:julien@julienviet.com">Julien Viet</a>
  13: */
  14:@Target({ElementType.TYPE, ElementType.PACKAGE, ElementType.METHOD})
  15:@Retention(RetentionPolicy.CLASS)
  16:public @interface Source {
  17:
  18:  /**
  19:   * Enables or disables the translation of the annotated example.
  20:   * When set to `false`, it also enable the inclusion of Java file (entire file) in the documentation
  21:   */
  22:  boolean translate() default true;
  23:}
