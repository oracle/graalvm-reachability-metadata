  27:/**
  28: * @author <a href="mailto:julien@julienviet.com">Julien Viet</a>
  29: */
  30:public class JavaDocGenerator implements DocGenerator {
  31:
  32:  protected DocTrees docTrees;
  33:  protected ProcessingEnvironment processingEnv;
  34:
  35:  @Override
  36:  public void init(ProcessingEnvironment env) {
  37:    docTrees = DocTrees.instance(env);
  38:    processingEnv = env;
  39:  }
  40:
  41:  @Override
  42:  public String getName() {
  43:    return "java";
  44:  }
  45:
  46:  @Override
  47:  public String resolveTypeLink(TypeElement elt) {
  48:    return "../../apidocs/" + elt.getQualifiedName().toString().replace('.', '/') + ".html";
  49:  }
  50:
  51:  @Override
  52:  public String resolveConstructorLink(ExecutableElement elt) {
  53:    return toExecutableLink(elt, elt.getEnclosingElement().getSimpleName().toString());
  54:  }
  55:
  56:  @Override
  57:  public String resolveMethodLink(ExecutableElement elt) {
  58:    return toExecutableLink(elt, elt.getSimpleName().toString());
  59:  }
  60:
  61:  @Override
  62:  public String resolveLabel(Element elt, String defaultLabel) {
  63:    return defaultLabel;
  64:  }
  65:
  66:  private String toExecutableLink(ExecutableElement elt, String name) {
  67:    TypeElement typeElt = (TypeElement) elt.getEnclosingElement();
  68:    String link = resolveTypeLink(typeElt);
  69:    StringBuilder anchor = new StringBuilder("#");
  70:    anchor.append(name).append('-');
  71:    TypeMirror type = elt.asType();
  72:    ExecutableType methodType = (ExecutableType) processingEnv.getTypeUtils().erasure(type);
  73:    List<? extends TypeMirror> parameterTypes = methodType.getParameterTypes();
  74:    for (int i = 0; i < parameterTypes.size(); i++) {
  75:      if (i > 0) {
  76:        anchor.append('-');
  77:      }
  78:      // We need to check whether or not the parameter is annotated. In this case, we must use the unannotated type.
  79:      TypeMirror typeOfParameter = parameterTypes.get(i);
  80:      String s = typeOfParameter.toString();
  81:      Matcher matcher = A.matcher(s);
  82:      if (matcher.matches()) {
  83:        String t = matcher.group(1);
  84:        anchor.append(t);
  85:      } else {
  86:        anchor.append(s);
  87:      }
  88:    }
  89:    anchor.append('-');
  90:    return link + anchor;
  91:  }
  92:
  93:  private static final Pattern A = Pattern.compile("^\\(@[^ ]+ :: ([^\\\\]+)\\)$");
  94:
  95:  @Override
  96:  public String resolveFieldLink(VariableElement elt) {
  97:    TypeElement typeElt = (TypeElement) elt.getEnclosingElement();
  98:    String link = resolveTypeLink(typeElt);
  99:    return link + "#" + elt.getSimpleName();
  100:  }
  101:
  102:  /**
  103:   * Render the source fragment for the Java language. Java being the pivot language, we consider this method as the
  104:   * _default_ behavior. This method is final as it must not be overridden by any extension.
  105:   *
  106:   * @param elt    the element
  107:   * @param source the source
  108:   * @return the fragment
  109:   */
  110:  @Override
  111:  public String renderSource(ExecutableElement elt, String source) {
  112:    // Get block
  113:    TreePath path = docTrees.getPath(elt);
  114:    MethodTree methodTree = (MethodTree) path.getLeaf();
  115:    BlockTree blockTree = methodTree.getBody();
  116:    List<? extends StatementTree> statements = blockTree.getStatements();
  117:    if (statements.size() > 0) {
  118:      return renderSource(path, statements, source);
  119:    } else {
  120:      return null;
  121:    }
  122:  }
  123:
  124:  public String renderSource(TypeElement elt, String source) {
  125:    TreePath path = docTrees.getPath(elt);
  126:    ClassTree classTree = (ClassTree) path.getLeaf();
  127:    return renderSource(path, Collections.singletonList(classTree), source);
  128:  }
  129:
  130:  public String renderSource(TreePath path, List<? extends Tree> trees, String source) {
  131:    CompilationUnitTree unit = path.getCompilationUnit();
  132:    int from = (int) docTrees.getSourcePositions().getStartPosition(unit, trees.get(0));
  133:    int to = (int) docTrees.getSourcePositions().getEndPosition(unit, trees.get(trees.size() - 1));
  134:    // Correct boundaries
  135:    while (from > 1 && source.charAt(from - 1) != '\n') {
  136:      from--;
  137:    }
  138:    while (to < source.length() && source.charAt(to) != '\n') {
  139:      to++;
  140:    }
  141:    String block = source.substring(from, to);
  142:    // Determine margin
  143:    int blockMargin = Integer.MAX_VALUE;
  144:    LineMap lineMap = unit.getLineMap();
  145:    for (Tree statement : trees) {
  146:      int statementStart = (int) docTrees.getSourcePositions().getStartPosition(unit, statement);
  147:      int lineStart = statementStart;
  148:      while (lineMap.getLineNumber(statementStart) == lineMap.getLineNumber(lineStart - 1)) {
  149:        lineStart--;
  150:      }
  151:      blockMargin = Math.min(blockMargin, statementStart - lineStart);
  152:    }
  153:    // Crop the fragment
  154:    StringBuilder fragment = new StringBuilder();
  155:    for (Iterator<String> sc = new Scanner(block).useDelimiter("\n"); sc.hasNext(); ) {
  156:      String line = sc.next();
  157:      int margin = Math.min(blockMargin, line.length());
  158:      line = line.substring(margin);
  159:      fragment.append(line);
  160:      if (sc.hasNext()) {
  161:        fragment.append('\n');
  162:      }
  163:    }
  164:    return fragment.toString();
  165:  }
  166:}
  ==== LanguageFilterPostProcessor
  1:package io.vertx.docgen;
  2:
  3:/**
  4: * A post processor filtering out content not matching the current processor language.
  5: */
  6:public class LanguageFilterPostProcessor implements PostProcessor {
  7:  @Override
  8:  public String getName() {
  9:    return "language";
  10:  }
  11:
  12:  @Override
  13:  public String process(String name, String content, String... args) {
  14:    if (args.length == 0) {
  15:      throw new IllegalArgumentException("The post-processor '" + getName() + "' requires at least one argument");
  16:    }
  17:    if (matches(name, args)) {
  18:      return content;
  19:    }
  20:    return EMPTY_CONTENT;
  21:  }
  22:
  23:  private boolean matches(String lang, String[] args) {
  24:    for (String arg : args) {
  25:      if (lang.equalsIgnoreCase(arg)) {
  26:        return true;
  27:      }
  28:    }
  29:    return false;
  30:  }
  31:}
