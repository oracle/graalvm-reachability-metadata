     553	  class LinkProcessing {
     554	
     555	    final DocGenerator generator;
     556	    final String label;
     557	    private DocWriter writer;
     558	
     559	    public LinkProcessing(DocGenerator generator, String label) {
     560	      this.generator = generator;
     561	      this.label = label;
     562	    }
     563	
     564	    void handle(Element elt) {
     565	      writer = new DocWriter();
     566	      if (elt instanceof PackageElement) {
     567	        PackageElement includedElt = (PackageElement) elt;
     568	        if (includedElt.getAnnotation(Document.class) == null) {
     569	          new PackageDoc(includedElt).process(generator, writer);
     570	        } else {
     571	          String link = resolveLinkToPackageDoc((PackageElement) elt);
     572	          writer.append(link);
     573	        }
     574	      } else {
     575	        if (helper.isExample(elt)) {
     576	          String source = helper.readSource(elt);
     577	          switch (elt.getKind()) {
     578	            case CONSTRUCTOR:
     579	            case METHOD:
     580	              // Check whether or not the fragment must be translated
     581	              String fragment;
     582	              if (helper.hasToBeTranslated(elt)) {
     583	                // Invoke the custom renderer, this may should the translation to the expected language.
     584	                fragment = generator.renderSource((ExecutableElement) elt, source);
     585	              } else {
     586	                // Do not call the custom rendering process, just use the default / java one.
     587	                JavaDocGenerator javaGen = new JavaDocGenerator();
     588	                javaGen.init(processingEnv);
     589	                fragment = javaGen.renderSource((ExecutableElement) elt, source);
     590	              }
     591	              if (fragment != null) {
     592	                writer.literalMode();
     593	                writer.append(fragment);
     594	                writer.commentMode();
     595	              }
     596	              return;
     597	            case CLASS:
     598	            case INTERFACE:
     599	            case ENUM:
     600	            case ANNOTATION_TYPE:
     601	              TypeElement typeElt = (TypeElement) elt;
     602	              JavaDocGenerator javaGen = new JavaDocGenerator();
     603	              javaGen.init(processingEnv);
     604	              fragment = javaGen.renderSource(typeElt, source);
     605	              if (fragment != null) {
     606	                writer.literalMode();
     607	                writer.append(fragment);
     608	                writer.commentMode();
     609	              }
     610	              return;
     611	            default:
     612	              throw new UnsupportedOperationException("unsupported element: " + elt.getKind());
     613	          }
     614	        }
     615	        String link;
     616	        switch (elt.getKind()) {
     617	          case CLASS:
     618	          case INTERFACE:
     619	          case ANNOTATION_TYPE:
     620	          case ENUM: {
     621	            TypeElement typeElt = (TypeElement) elt;
     622	            link = generator.resolveTypeLink(typeElt);
     623	            break;
     624	          }
     625	          case METHOD: {
     626	            ExecutableElement methodElt = (ExecutableElement) elt;
     627	            TypeElement typeElt = (TypeElement) methodElt.getEnclosingElement();
     628	            link = generator.resolveMethodLink(methodElt);
     629	            break;
     630	          }
     631	          case CONSTRUCTOR: {
     632	            ExecutableElement constructorElt = (ExecutableElement) elt;
     633	            TypeElement typeElt = (TypeElement) constructorElt.getEnclosingElement();
     634	            link = generator.resolveConstructorLink(constructorElt);
     635	            break;
     636	          }
     637	          case FIELD:
     638	          case ENUM_CONSTANT: {
     639	            VariableElement variableElt = (VariableElement) elt;
     640	            TypeElement typeElt = (TypeElement) variableElt.getEnclosingElement();
     641	            link = generator.resolveFieldLink(variableElt);
     642	            break;
     643	          }
     644	          default:
     645	            throw new UnsupportedOperationException("Not yet implemented " + elt + " with kind " + elt.getKind());
     646	        }
     647	        String s;
     648	        if (label.length() == 0) {
     649	          s = resolveLabel(generator, elt);
     650	        } else {
     651	          s = label;
     652	        }
     653	        if (link != null) {
     654	          syntax.writeLink(link, s, writer);
     655	        } else {
     656	          writer.append("`").append(s).append("`");
     657	        }
     658	      }
     659	    }
     660	  }
