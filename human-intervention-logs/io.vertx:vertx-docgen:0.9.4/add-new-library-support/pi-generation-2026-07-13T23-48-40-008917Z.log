70\t      }\n    71\t    }\n    72\t    return null;\n    73\t  }\n    74\t\n    75\t\n    76\t  @Override\n    77\t  public synchronized void init(ProcessingEnvironment processingEnv) {\n    78\t    super.init(processingEnv);\n    79\t    String sourceOpt = processingEnv.getOptions().get(DOCGEN_SOURCE);\n    80\t    if (sourceOpt != null) {\n    81\t      sources = new ArrayList<>(Arrays.asList(sourceOpt.split(\"\\\\s*,\\\\s*\")));\n    82\t    }\n    83\t    docTrees = DocTrees.instance(processingEnv);\n    84\t    helper = new Helper(processingEnv);\n    85\t    String syntaxOpt = processingEnv.getOptions().get(DOCGEN_SYNTAX);\n    86\t    this.syntax = \"markdown\".equals(syntaxOpt) ? Syntax.MARKDOWN : Syntax.ASCIIDOC;\n    87\t    registerPostProcessor(new LanguageFilterPostProcessor());\n    88\t  }\n    89\t\n    90\t  private String render(List<? extends DocTree> trees) {\n    91\t    StringBuilder buffer = new StringBuilder();\n    92\t    DocTreeVisitor<Void, Void> visitor = new DocTreeScanner<Void, Void>() {\n    93\t      @Override\n    94\t      public Void visitText(TextTree node, Void aVoid) {\n    95\t        buffer.append(node.getBody());\n    96\t        return super.visitText(node, aVoid);\n    97\t      }\n    98\t    };\n    99\t    trees.forEach(tree -> tree.accept(visitor, null));\n   100\t    return buffer.toString();\n   101\t  }\n   102\t\n   103\t  private final Map<Doc, Map<DocGenerator, DocWriter>> state = new HashMap<>();\n   104\t\n   105\t  @Override\n   106\t  public boolean process(Set<? extends TypeElement> annotations, RoundEnvironment roundEnv) {\n   107\t    StackTraceElement[] trace = Thread.currentThread().getStackTrace();\n   108\t    for (StackTraceElement elt : trace) {\n   109\t      if (elt.getClassName().startsWith(\"org.jetbrains\")) {\n   110\t        return true;\n   111\t      }\n   112\t    }\n   113\t    if (failures.isEmpty()) {\n   114\t      try {\n   115\t        if (!roundEnv.processingOver()) {\n   116\t          roundEnv.getElementsAnnotatedWith(Document.class).forEach(elt -> {\n   117\t            try {\n   118\t              PackageDoc doc = new PackageDoc((PackageElement) elt);\n   119\t              state.put(doc, handleGen(doc));\n   120\t            } catch (DocGenException e) {\n   121\t              if (e.element == null) {\n   122\t                e.element = elt;\n   123\t              }\n   124\t              throw e;\n   125\t            }\n   126\t          });\n   127\t\n   128\t          if (sources != null && sources.size() > 0) {\n   129\t            for (String source : sources) {\n   130\t\n   131\t              // Handle wildcards\n   132\t              List<File> files = new ArrayList<>();\n   133\t              File f = new File(source);\n   134\t              if (!f.exists()) {\n   135\t                if (f.getName().contains(\"*\")) {\n   136\t                  StringBuilder sb = new StringBuilder();\n   137\t                  for (char c : f.getName().toCharArray()) {\n   138\t                    if (c == '*') {\n   139\t                      sb.append(\".*\");\n   140\t                    } else {\n   141\t                      sb.append(Matcher.quoteReplacement(Character.toString(c)));\n   142\t                    }\n   143\t                  }\n   144\t                  Pattern p = Pattern.compile(sb.toString());\n   145\t                  File parentFile = f.getParentFile();\n   146\t                  File[] children = parentFile.listFiles();\n   147\t                  if (children != null) {\n   148\t                    for (File child : children) {\n   149\t                      if (p.matcher(child.getName()).matches()) {\n   150\t                        files.add(child);\n   151\t                      }\n   152\t                    }\n   153\t                  }\n   154\t                } else {\n   155\t                  throw new FileNotFoundException(\"Cannot process document \" + source);\n   156\t                }\n   157\t              } else {\n   158\t                files.add(f);\n   159\t              }\n   160\t              for (File file : files) {\n   161\t                if (file.isFile()) {\n   162\t                  FileDoc fileDoc = new FileDoc(file, file.getName());\n   163\t                  Map<DocGenerator, DocWriter> m = handleGen(fileDoc);\n   164\t                  state.put(fileDoc, m);\n   165\t                } else if (file.isDirectory()) {\n   166\t                  Files.walk(file.toPath())\n   167\t                    .map(Path::toFile)\n   168\t                    .filter(File::isFile).forEach(docFile -> {\n   169\t                    String relativePath = file.toPath().relativize(docFile.toPath()).toString();\n   170\t                    FileDoc fileDoc = new FileDoc(docFile, relativePath);\n   171\t                    Map<DocGenerator, DocWriter> m = handleGen(fileDoc);\n   172\t                    state.put(fileDoc, m);\n   173\t                  });\n   174\t                } else {\n   175\t                  throw new IOException(\"Document \" + file.getAbsolutePath() + \" is not a file nor a dir\");\n   176\t                }\n   177\t              }\n   178\t            }\n   179\t            sources.clear();\n   180\t          }\n   181\t\n   182\t          Set<String> processed = new HashSet<>();\n   183\t          while (true) {\n   184\t            Optional<ElementResolution> opt = resolutions\n   185\t              .values()\n   186\t              .stream()\n   187\t              .filter(res -> res.elt == null && !processed.contains(res.signature))\n   188\t              .findFirst();\n   189\t            if (opt.isPresent()) {\n   190\t              ElementResolution res = opt.get();\n   191\t              processed.add(res.signature);\n   192\t              res.tryResolve();\n   193\t            } else {\n   194\t              break;\n   195\t            }\n   196\t          }\n   197\t        } else {\n   198\t          state.forEach((doc, m) -> {\n   199\t            m.forEach((gen, w) -> {\n   200\t              String content = postProcess(gen.getName(), w.render());\n   201\t              write(gen, doc, content);\n   202\t            });\n   203\t          });\n   204\t        }\n   205\t      } catch(Exception e) {\n   206\t        Element reportedElt = (e instanceof DocGenException) ? ((DocGenException) e).element : null;\n   207\t        String msg = e.getMessage();\n   208\t        if (msg == null) {\n   209\t          msg = e.toString();\n   210\t        }\n   211\t        e.printStackTrace();\n   212\t        if (reportedElt != null) {\n   213\t          processingEnv.getMessager().printMessage(Diagnostic.Kind.ERROR, msg, reportedElt);\n   214\t          if (reportedElt instanceof PackageElement) {\n   215\t            failures.put(((PackageElement) reportedElt).getQualifiedName().toString(), msg);\n   216\t          } else {\n   217\t            throw new UnsupportedOperationException(\"not implemented\");\n   218\t          }\n   219\t        } else {\n   220\t          processingEnv.getMessager().printMessage(Diagnostic.Kind.ERROR, msg);\n   221\t        }\n   222\t      }\n   223\t    }\n   224\t    return false;\n   225\t  }\n   226\t\n   227\t  protected abstract Iterable<DocGenerator> generators();\n   228\t\n   229\t  private Map<DocGenerator, DocWriter> handleGen(Doc doc) {\n   230\t    Map<DocGenerator, DocWriter> map = new HashMap<>();\n   530\t    public int hashCode() {\n   531\t      return signature.hashCode();\n   532\t    }\n   533\t\n   534\t    private void doResolve() {\n   535\t      elt = helper.resolveLink(signature);\n   536\t      if (elt != null) {\n   537\t        for (LinkProcessing fut : handlers) {\n   538\t          fut.handle(elt);\n   539\t        }\n   540\t        handlers.clear();\n   541\t      }\n   542\t    }\n   543\t\n   544\t    private void add(LinkProcessing fut) {\n   545\t      if (elt != null) {\n   546\t        fut.handle(elt);\n   547\t      } else {\n   548\t        handlers.add(fut);\n   549\t      }\n   550\t    }\n   551\t  }\n   552\t\n   553\t  class LinkProcessing {\n   554\t\n   555\t    final DocGenerator generator;\n   556\t    final String label;\n   557\t    private DocWriter writer;\n   558\t\n   559\t    public LinkProcessing(DocGenerator generator, String label) {\n   560\t      this.generator = generator;\n   561\t      this.label = label;\n   562\t    }\n   563\t\n   564\t    void handle(Element elt) {\n   565\t      writer = new DocWriter();\n   566\t      if (elt instanceof PackageElement) {\n   567\t        PackageElement includedElt = (PackageElement) elt;\n   568\t        if (includedElt.getAnnotation(Document.class) == null) {\n   569\t          new PackageDoc(includedElt).process(generator, writer);\n   570\t        } else {\n   571\t          String link = resolveLinkToPackageDoc((PackageElement) elt);\n   572\t          writer.append(link);\n   573\t        }\n   574\t      } else {\n   575\t        if (helper.isExample(elt)) {\n   576\t          String source = helper.readSource(elt);\n   577\t          switch (elt.getKind()) {\n   578\t            case CONSTRUCTOR:\n   579\t            case METHOD:\n   580\t              // Check whether or not the fragment must be translated\n   581\t              String fragment;\n   582\t              if (helper.hasToBeTranslated(elt)) {\n   583\t                // Invoke the custom renderer, this may should the translation to the expected language.\n   584\t                fragment = generator.renderSource((ExecutableElement) elt, source);\n   585\t              } else {\n   586\t                // Do not call the custom rendering process, just use the default / java one.\n   587\t                JavaDocGenerator javaGen = new JavaDocGenerator();\n   588\t                javaGen.init(processingEnv);\n   589\t                fragment = javaGen.renderSource((ExecutableElement) elt, source);\n   590\t              }\n   591\t              if (fragment