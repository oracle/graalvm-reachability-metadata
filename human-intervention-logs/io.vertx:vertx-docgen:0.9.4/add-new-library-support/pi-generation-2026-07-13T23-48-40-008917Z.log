d(\"]`\");\n9:    }\n10:  }, MARKDOWN() {\n11:    @Override\n12:    void writeLink(String link, String s, DocWriter writer) {\n13:      writer.append(\"[`\").append(s).append(\"`](\").append(link).append(\")\");\n14:    }\n15:  };\n16:\n17:  abstract void writeLink(String link, String s, DocWriter writer);\n18:\n19:}\n==== JavaDocGenerator\n1:package io.vertx.docgen;\n2:\n3:import com.sun.source.tree.BlockTree;\n4:import com.sun.source.tree.ClassTree;\n5:import com.sun.source.tree.CompilationUnitTree;\n6:import com.sun.source.tree.LineMap;\n7:import com.sun.source.tree.MethodTree;\n8:import com.sun.source.tree.StatementTree;\n9:import com.sun.source.tree.Tree;\n10:import com.sun.source.util.DocTrees;\n11:import com.sun.source.util.TreePath;\n12:\n13:import javax.annotation.processing.ProcessingEnvironment;\n14:import javax.lang.model.element.Element;\n15:import javax.lang.model.element.ExecutableElement;\n16:import javax.lang.model.element.TypeElement;\n17:import javax.lang.model.element.VariableElement;\n18:import javax.lang.model.type.ExecutableType;\n19:import javax.lang.model.type.TypeMirror;\n20:import java.util.Collections;\n21:import java.util.Iterator;\n22:import java.util.List;\n23:import java.util.Scanner;\n24:import java.util.regex.Matcher;\n25:import java.util.regex.Pattern;\n26:\n27:/**\n28: * @author <a href=\"mailto:julien@julienviet.com\">Julien Viet</a>\n29: */\n30:public class JavaDocGenerator implements DocGenerator {\n31:\n32:  protected DocTrees docTrees;\n33:  protected ProcessingEnvironment processingEnv;\n34:\n35:  @Override\n36:  public void init(ProcessingEnvironment env) {\n37:    docTrees = DocTrees.instance(env);\n38:    processingEnv = env;\n39:  }\n40:\n41:  @Override\n42:  public String getName() {\n43:    return \"java\";\n44:  }\n45:\n46:  @Override\n47:  public String resolveTypeLink(TypeElement elt) {\n48:    return \"../../apidocs/\" + elt.getQualifiedName().toString().replace('.', '/') + \".html\";\n49:  }\n50:\n51:  @Override\n52:  public String resolveConstructorLink(ExecutableElement elt) {\n53:    return toExecutableLink(elt, elt.getEnclosingElement().getSimpleName().toString());\n54:  }\n55:\n56:  @Override\n57:  public String resolveMethodLink(ExecutableElement elt) {\n58:    return toExecutableLink(elt, elt.getSimpleName().toString());\n59:  }\n60:\n61:  @Override\n62:  public String resolveLabel(Element elt, String defaultLabel) {\n63:    return defaultLabel;\n64:  }\n65:\n66:  private String toExecutableLink(ExecutableElement elt, String name) {\n67:    TypeElement typeElt = (TypeElement) elt.getEnclosingElement();\n68:    String link = resolveTypeLink(typeElt);\n69:    StringBuilder anchor = new StringBuilder(\"#\");\n70:    anchor.append(name).append('-');\n71:    TypeMirror type = elt.asType();\n72:    ExecutableType methodType = (ExecutableType) processingEnv.getTypeUtils().erasure(type);\n73:    List<? extends TypeMirror> parameterTypes = methodType.getParameterTypes();\n74:    for (int i = 0; i < parameterTypes.size(); i++) {\n75:      if (i > 0) {\n76:        anchor.append('-');\n77:      }\n78:      // We need to check whether or not the parameter is annotated. In this case, we must use the unannotated type.\n79:      TypeMirror typeOfParameter = parameterTypes.get(i);\n80:      String s = typeOfParameter.toString();\n81:      Matcher matcher = A.matcher(s);\n82:      if (matcher.matches()) {\n83:        String t = matcher.group(1);\n84:        anchor.append(t);\n85:      } else {\n86:        anchor.append(s);\n87:      }\n88:    }\n89:    anchor.append('-');\n90:    return link + anchor;\n91:  }\n92:\n93:  private static final Pattern A = Pattern.compile(\"^\\\\(@[^ ]+ :: ([^\\\\\\\\]+)\\\\)$\");\n94:\n95:  @Override\n96:  public String resolveFieldLink(VariableElement elt) {\n97:    TypeElement typeElt = (TypeElement) elt.getEnclosingElement();\n98:    String link = resolveTypeLink(typeElt);\n99:    return link + \"#\" + elt.getSimpleName();\n100:  }\n101:\n102:  /**\n103:   * Render the source fragment for the Java language. Java being the pivot language, we consider this method as the\n104:   * _default_ behavior. This method is final as it must not be overridden by any extension.\n105:   *\n106:   * @param elt    the element\n107:   * @param source the source\n108:   * @return the fragment\n109:   */\n110:  @Override\n111:  public String renderSource(ExecutableElement elt, String source) {\n112:    // Get block\n113:    TreePath path = docTrees.getPath(elt);\n114:    MethodTree methodTree = (MethodTree) path.getLeaf();\n115:    BlockTree blockTree = methodTree.getBody();\n116:    List<? extends StatementTree> statements = blockTree.getStatements();\n117:    if (statements.size() > 0) {\n118:      return renderSource(path, statements, source);\n119:    } else {\n120:      return null;\n121:    }\n122:  }\n123:\n124:  public String renderSource(TypeElement elt, String source) {\n125:    TreePath path = docTrees.getPath(elt);\n126:    ClassTree classTree = (ClassTree) path.getLeaf();\n127:    return renderSource(path, Collections.singletonList(classTree), source);\n128:  }\n129:\n130:  public String renderSource(TreePath path, List<? extends Tree> trees, String source) {\n131:    CompilationUnitTree unit = path.getCompilationUnit();\n132:    int from = (int) docTrees.getSourcePositions().getStartPosition(unit, trees.get(0));\n133:    int to = (int) docTrees.getSourcePositions().getEndPosition(unit, trees.get(trees.size() - 1));\n134:    // Correct boundaries\n135:    while (from > 1 && source.charAt(from - 1) != '\\n') {\n136:      from--;\n137:    }\n138:    while (to < source.length() && source.charAt(to) != '\\n') {\n139:      to++;\n140:    }\n141:    String block = source.substring(from, to);\n142:    // Determine margin\n143:    int blockMargin = Integer.MAX_VALUE;\n144:    LineMap lineMap = unit.getLineMap();\n145:    for (Tree statement : trees) {\n146:      int statementStart = (int) docTrees.getSourcePositions().getStartPosition(unit, statement);\n147:      int lineStart = statementStart;\n148:      while (lineMap.getLineNumber(statementStart) == lineMap.getLineNumber(lineStart - 1)) {\n149:        lineStart--;\n150:      }\n151:      blockMargin = Math.min(blockMargin, statementStart - lineStart);\n152:    }\n153:    // Crop the fragment\n154:    StringBuilder fragment = new StringBuilder();\n155:    for (Iterator<String> sc = new Scanner(block).useDelimiter(\"\\n\"); sc.hasNext(); ) {\n156:      String line = sc.next();\n157:      int margin = Math.min(blockMargin, line.length());\n158:      line = line.substring(margin);\n159:      fragment.append(line);\n160:      if (sc.hasNext()) {\n161:        fragment.append('\\n');\n162:      }\n163:    }\n164:    return fragment.toString();\n165:  }\n166:}\n==== LanguageFilterPostProcessor\n1:package io.vertx.docgen;\n2:\n3:/**\n4: * A post processor filtering out content not matching the current processor language.\n5: */\n6:public class LanguageFilterPostProcessor implements PostProcessor {\n7:  @Override\n8:  public String getName() {\n9:    return \"language\";\n10:  }\n11:\n12:  @Override\n13:  public String process(String name, String content, String... args) {\n14:    if (args.length == 0) {\n15:      throw new IllegalArgumentException(\"The post-processor '\" + getName() + \"' requires at least one argument\");\n16:    }\n17:    if (matches(name, args)) {\n18:      return content;\n19:    }\n20:    return EMPTY_CONTENT;\n21:  }\n22:\n23:  private boolean matches(String lang, String[] args) {\n24:    for (String arg : args) {\n25:      if (lang.equalsIgnoreCase(arg)) {\n26:        return true;\n27:      }\n28:    }\n29:    return false;\n30:  }\n31:}\n==== DocGenerator\n1:package io.vertx.docgen;\n2:\n3:import javax.annotation.processing.ProcessingEnvironment;\n4:import javax.lang.model.element.Element;\n5:import javax.lang.model.element.ExecutableElement;\n6:import javax.lang.model.element.PackageElement;\n7:import javax.lang.model.element.TypeElement;\n8:import javax.lang.model.element.VariableElement;\n9:\n10:/**\n11: * A doc generator plugin.\n12: *\n13: * @author <a href=\"mailto:julien@julienviet.com\">Julien Viet</a>\n14: */\n15:public interface DocGenerator {\n16:\n17:  /**\n18:   * Init the generator.\n19:   *\n20:   * @param env the processor environment\n21:   */\n22:  void init(ProcessingEnvironment env);\n23:\n24:  /**\n25:   * @return the generator name\n26:   */\n27:  String getName();\n28:\n29:  /**\n30:   * Resolve the relative file name of a document, the default implementation returns the {@literal relativeFileName}\n31:   * parameter.\n32:   *\n33:   * @param docElt the doc element\n34:   * @param relativeFileName the relative file name original value\n35:   * @return the relative file name\n36:   */\n37:  default String resolveRelativeFileName(PackageElement docElt, String relativeFileName) {\n38:    return relativeFileName;\n39:  }\n40:\n41:  /**\n42:   * Render the source code of the {@code elt} argument.\n43:   *\n44:   * @param elt the element to render\n45:   * @param source the Java source of the element\n46:   * @return the rendered source\n47:   */\n48:  String renderSource(ExecutableElement elt, String source);\n49:\n50:  /**\n51:   * Resolve a constructor link.\n52:   *\n53:   * @param elt the element linked to\n54:   * @return the resolved http link or null if the link cannot be resolved\n55:   */\n56:  String resolveTypeLink(TypeElement elt);\n57:\n58:  /**\n59:   * Resolve a constructor link.\n60:   *\n61:   * @param elt the element linked to\n62:   * @return the resolved http link or null if the link cannot be resolved\n63:   */\n64:  String resolveConstructorLink(ExecutableElement elt);\n65:\n66:  /**\n67:   * Resolve a method link.\n68:   *\n69:   * @param elt the element linked to\n70:   * @return the resolved http link or null if the link cannot be resolved\n71:   */\n72:  String resolveMethodLink(ExecutableElement elt);\n73:\n74:  /**\n75:   * Resolve a field link.\n76:   *\n77:   * @param elt the element linked to\n78:   * @return the resolved http link or null if the link cannot be resolved\n79:   */\n80:  String resolveFieldLink(VariableElement elt);\n81:\n82:  /**\n83:   * Resolve a label.\n84:   *\n85:   * @param elt the labelled element\n86:   * @param defaultLabel the default label\n87:   * @return the resolved label or null if a label cannot be resolved\n88:   */\n89:  String resolveLabel(Element elt, String defaultLabel);\n90:}\n==== PostProcessor\n1:package io.vertx.docgen;\n2:\n3:import java.util.Arrays;\n4:import java.util.Iterator;\n5:import java.util.regex.Pattern;\n6:\n7:/**\n8: * Post processor interface.\n9: */\n10:public interface PostProcessor {\n11:\n12:  String EMPTY_CONTENT = \"\";\n13:\n14:  Pattern BLOCK_DECLARATION = Pattern.compile(\"\\\\[.+\\\\]\");\n15:\n16:  String getName();\n17:\n18:  String process(String name, String content, String... args);\n19:\n20:  static boolean isBlockDeclaration(String line) {\n21:    return BLOCK_DECLARATION.matcher(line).matches();\n22:  }\n23:\n24:  static String getProcessorName(String line) {\n25:    // The line starts and ends with \"[\" and \"]\".\n26:    int indexOfComma = line.indexOf(\",\");\n27:    return line.substring(1, indexOfComma != -1 ? indexOfComma : line.length() - 1).trim();\n28:  }\n29:\n30:  static String[] getProcessorAttributes(String line) {\n31:    // The line starts and ends with \"[\" and \"]\".\n32:    int indexOfComma = line.indexOf(\",\");\n33:    if (indexOfComma == -1) {\n34:      return new String[0];\n35:    } else {\n36:      return Arrays.stream(line.substring(indexOfComma + 1, line.length() - 1).split(\",\")).map(String::trim)\n37:          .toArray(String[]::new);\n38:    }\n39:  }\n40:\n41:  static String getBlockContent(Iterator<String> iterator) {\n42:    StringBuilder content = new StringBuilder();\n43:    boolean startOfBlock = false;\n44:    boolean endOfBlock = false;\n45:    while (iterator.hasNext() && !endOfBlock) {\n46:      String line = iterator.next().trim();\n47:      if (line.equals(\"----\") && !startOfBlock) {\n48:        startOfBlock = true;\n49:      } else if (line.equals(\"\\\\----\") && startOfBlock) {\n50:        // Escaped nested block. If the content is using a nested block such as [source], it must \"escape\" it with\n51:        // \\---- instead of ----.\n52:        content.append(\"----\").append(\"\\n\");\n53:      } else if (line.equals(\"----\") && startOfBlock) {\n54:        endOfBlock = true;\n55:      } else if (!line.equals(\"----\") && !startOfBlock) {\n56:        // Block without delimiters (1 line only)\n57:        return line;\n58:      } else {\n59:        content.append(line).append(\"\\n\");\n60:      }\n61:    }\n62:    return content.toString();\n63:  }\n64:}\n"}], "isError": false, "timestamp": 1783986487956}}
