     708	      } else {
     709	        String name = PostProcessor.getProcessorName(trimmedLine);
     710	        String[] attributes = PostProcessor.getProcessorAttributes(trimmedLine);
     711	        PostProcessor postProcessor = getPostProcessor(name);
