      90	  private String render(List<? extends DocTree> trees) {
      91	    StringBuilder buffer = new StringBuilder();
      92	    DocTreeVisitor<Void, Void> visitor = new DocTreeScanner<Void, Void>() {
      93	      @Override
      94	      public Void visitText(TextTree node, Void aVoid) {
      95	        buffer.append(node.getBody());
      96	        return super.visitText(node, aVoid);
      97	      }
      98	    };
      99	    trees.forEach(tree -> tree.accept(visitor, null));
     100	    return buffer.toString();
     101	  }
