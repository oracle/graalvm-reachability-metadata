 extra space, except for the first time.\n70:   */\n71:  void commentMode() {\n72:    literal = false;\n73:  }\n74:\n75:  void write(Supplier<DocWriter> future) {\n76:    if (delegate.length() > 0) {\n77:      String s = delegate.toString();\n78:      delegate.setLength(0);\n79:      chunks.add(s);\n80:    }\n81:    chunks.add(future);\n82:  }\n83:\n84:  @Override\n85:  public void write(int c) {\n86:    try {\n87:      super.write(c);\n88:    } catch (IOException e) {\n89:      throw new UndeclaredThrowableException(e);\n90:    }\n91:  }\n92:\n93:  @Override\n94:  public void write(char[] cbuf) {\n95:    try {\n96:      super.write(cbuf);\n97:    } catch (IOException e) {\n98:      throw new UndeclaredThrowableException(e);\n99:    }\n100:  }\n101:\n102:  @Override\n103:  public void write(String str) {\n104:    try {\n105:      super.write(str);\n106:    } catch (IOException e) {\n107:      throw new UndeclaredThrowableException(e);\n108:    }\n109:  }\n110:\n111:  @Override\n112:  public void write(String str, int off, int len) {\n113:    try {\n114:      super.write(str, off, len);\n115:    } catch (IOException e) {\n116:      throw new UndeclaredThrowableException(e);\n117:    }\n118:  }\n119:\n120:  @Override\n121:  public DocWriter append(CharSequence csq) {\n122:    try {\n123:      return (DocWriter) super.append(csq);\n124:    } catch (IOException e) {\n125:      throw new UndeclaredThrowableException(e);\n126:    }\n127:  }\n128:\n129:  @Override\n130:  public DocWriter append(CharSequence csq, int start, int end) {\n131:    try {\n132:      return (DocWriter) super.append(csq, start, end);\n133:    } catch (IOException e) {\n134:      throw new UndeclaredThrowableException(e);\n135:    }\n136:  }\n137:\n138:  @Override\n139:  public DocWriter append(char c) {\n140:    try {\n141:      return (DocWriter) super.append(c);\n142:    } catch (IOException e) {\n143:      throw new UndeclaredThrowableException(e);\n144:    }\n145:  }\n146:\n147:  @Override\n148:  public void write(char[] cbuf, int off, int len) {\n149:    if (literal) {\n150:      while (off < len) {\n151:        delegate.append(cbuf[off++]);\n152:      }\n153:    } else {\n154:      while (off < len) {\n155:        char c = cbuf[off++];\n156:        switch (c) {\n157:          case '\\n':\n158:            status = 1;\n159:            delegate.append(c);\n160:            break;\n161:          case ' ':\n162:            if (status == 1) {\n163:              status = 2;\n164:            } else {\n165:              delegate.append(c);\n166:            }\n167:            break;\n168:          default:\n169:            delegate.append(c);\n170:            if (status == 1) {\n171:              status = 2;\n172:            }\n173:            break;\n174:        }\n175:      }\n176:    }\n177:  }\n178:\n179:  @Override\n180:  public void flush() throws IOException {\n181:  }\n182:\n183:  @Override\n184:  public void close() throws IOException {\n185:  }\n186:}\n1:{}\n"}], "isError": false, "timestamp": 1783986500716}]}
