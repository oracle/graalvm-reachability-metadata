     186	        int len = reader.read(buffer);
     187	        if (len == -1) {
     188	          break;
     189	        }
     190	        source.append(buffer, 0, len);
     191	      }
     192	      return source.toString();
     193	    } catch (IOException e) {
     194	      throw new DocGenException(elt, "Could not read source code of element " + elt);
     195	    }
     196	  }
