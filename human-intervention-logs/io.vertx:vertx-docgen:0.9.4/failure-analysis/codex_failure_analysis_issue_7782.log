n\\\\n                /** A documented greeting type. */\\\\n                public class Greeting {\\\\n                    /** Returns a greeting for the supplied name. */\\\\n                    public String message(String name) {\\\\n                        return \\\\\\\"Hello \\\\\\\" + name;\\\\n                    }\\\\n                }\\\\n                \\\\\\\"\\\\\\\"\\\\\\\", StandardCharsets.UTF_8);\\\\n\\\\n        JavaCompiler compiler = ToolProvider.getSystemJavaCompiler();\\\\n        assertThat(compiler).as(\\\\\\\"system Java compiler\\\\\\\").isNotNull();\\\\n        DiagnosticCollector<JavaFileObject> diagnostics = new DiagnosticCollector<>();\\\\n        try (StandardJavaFileManager fileManager = compiler.getStandardFileManager(\\\\n                diagnostics, Locale.ROOT, StandardCharsets.UTF_8)) {\\\\n            fileManager.setLocationFromPaths(StandardLocation.CLASS_OUTPUT, List.of(classDirectory));\\\\n            List<String> options = List.of(\\\\n                    \\\\\\\"-proc:only\\\\\\\",\\\\n                    \\\\\\\"-Adocgen.output=\\\\\\\" + outputDirectory);\\\\n            JavaCompiler.CompilationTask task = compiler.getTask(\\\\n                    null,\\\\n                    fileManager,\\\\n                    diagnostics,\\\\n                    options,\\\\n                    null,\\\\n                    fileManager.getJavaFileObjectsFromPaths(List.of(packageInfo, greeting)));\\\\n            task.setProcessors(List.of(new DocGenProcessor(new JavaDocGenerator())));\\\\n\\\\n            assertThat(task.call()).as(diagnosticText(diagnostics)).isTrue();\\\\n        }\\\\n\\\\n        Path generatedGuide = outputDirectory.resolve(\\\\\\\"greeting-guide.adoc\\\\\\\");\\\\n        assertThat(generatedGuide).exists();\\\\n        assertThat(Files.readString(generatedGuide, StandardCharsets.UTF_8))\\\\n                .contains(\\\\\\\"Greeting guide\\\\\\\")\\\\n                .contains(\\\\\\\"Greeting\\\\\\\")\\\\n                .contains(\\\\\\\"greeting\\\\\\\");\\\\n    }\\\\n\\\\n    private static String diagnosticText(List<Diagnostic<? extends JavaFileObject>> diagnostics) {\\\\n        StringBuilder text = new StringBuilder();\\\\n        for (Diagnostic<? extends JavaFileObject> diagnostic : diagnostics) {\\\\n            text.append(diagnostic.getKind())\\\\n                    .append(\\\\\\\": \\\\\\\")\\\\n                    .append(diagnostic.getMessage(Locale.ROOT))\\\\n                    .append(System.lineSeparator());\\\\n        }\\\\n        return text.toString();\\\\n    }\\\\n}\\\\n\\\"}\\n[recv] {\\\"type\\\": \\\"message_end\\\", \\\"message\\\": {\\\"role\\\": \\\"assistant\\\", \\\"content\\\": [{\\\"type\\\": \\\"thinking\\\", \\\"thinking\\\": \\\"**Planning Java source compilation with processors**\\\\n\\\\n**Configuring compile task with classpath and assertions**\\\\n\\\\n**Adding JUnit TempDir for output cleanup**\\\", \\\"thinkingSignature\\\": \\\"{\\\\\\\"id\\\\\\\":\\\\\\\"rs_0ccfb8ac4a0870e6016a54e8ab98b8819796eaf7a7f3061d19\\\\\\\",\\\\\\\"type\\\\\\\":\\\\\\\"reasoning\\\\\\\",\\\\\\\"content\\\\\\\":[],\\\\\\\"encrypted_content\\\\\\\":\\\\\\\"gAAAAABqVOi1sMAkTSBbGQUX-p5AS10a1yxjr6-i4EiuimkaFkcGvCu_pTuzxzgFed6vwMcgJPLUununObJC_xKuSnOis0NY5IF7ErU2n15J9ZEgBY7XVZN0oCiOpJ_fiZYMeF0PjE7W0r0B0I7O8vS3k4wuOw0p-qvc76XJ3SZS3V_ggcEbfTXGrRq_F-hE0JRE82oaTiOLt-hi6iTp0XCvg6ZOEIdA0mjVD847x276TR3hkBEAcFkgI8-_WCBxzdLegTeaL3ChAOhygn_kOscd_2Zva5JqXtunjiz_Ds4kkT4wHMOU_Ortkf_Yh-emHE7hN4QT1Bu9dBuEspXwYA8faOmdwVWJLvHyNGjRRXVrUo6CUhS0ohrYKS8vuyWMe140wHoFm3JXSRaI9-gF6UK0_pOV516Qov45VWLALe0nRwATcc2gmFntYCjCw6bH7PaKPlKmWaqOP7xeKFHk1u34whMIl_8PNZggVzlWpNo35OYHQItX5SDTXLLU4-9XylodnWorPOu2rXBm8d4dGdlsyEuhR0bs_N1JDGRyKjC118PbsVhSW-WGykzJhyQ0_LEs3EBfvPw7HEgRGEwZxZKYcIcSqYClY7sSICVPt8d3NeGcKsvDms9Q-8ia_-cVgs1NOu7HWQyNljIxcZAUvXsLY8Aoih82ESQmYj1BkDE40_4rs4pxAMbQxyoXq4Cu5vCLHbYSfYUxY-fCXWu0zwSg47_-tJQCo1hXGzkj0C1RbcctVCx3f_aYCK8bAHfX5diwM_JPas0fgqxtvK7I9OLQXlWrPPphUt9Wt