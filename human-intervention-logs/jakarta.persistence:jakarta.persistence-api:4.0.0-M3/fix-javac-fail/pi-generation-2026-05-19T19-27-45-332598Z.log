y<T> setLockMode(LockModeType lockMode) {\n            super.setLockMode(lockMode);\n            recordOption(lockMode);\n            return this;\n        }"},{"oldText":"        public TypedQuery<T> setLockScope(PessimisticLockScope lockScope) {\n            this.lockScope = lockScope;\n            return this;\n        }","newText":"        public TypedQuery<T> setLockScope(PessimisticLockScope lockScope) {\n            this.lockScope = lockScope;\n            recordOption(lockScope);\n            return this;\n        }"},{"oldText":"        public TypedQuery<T> setCacheRetrieveMode(CacheRetrieveMode cacheRetrieveMode) {\n            super.setCacheRetrieveMode(cacheRetrieveMode);\n            return this;\n        }\n\n        @Override\n        public TypedQuery<T> setCacheStoreMode(CacheStoreMode cacheStoreMode) {\n            super.setCacheStoreMode(cacheStoreMode);\n            return this;\n        }\n\n        @Override\n        public TypedQuery<T> setTimeout(Integer timeout) {\n            super.setTimeout(timeout);\n            return this;\n        }\n\n        @Override\n        public TypedQuery<T> setTimeout(Timeout timeout) {\n            super.setTimeout(timeout);\n            return this;\n        }","newText":"        public TypedQuery<T> setCacheRetrieveMode(CacheRetrieveMode cacheRetrieveMode) {\n            super.setCacheRetrieveMode(cacheRetrieveMode);\n            recordOption(cacheRetrieveMode);\n            return this;\n        }\n\n        @Override\n        public TypedQuery<T> setCacheStoreMode(CacheStoreMode cacheStoreMode) {\n            super.setCacheStoreMode(cacheStoreMode);\n            recordOption(cacheStoreMode);\n            return this;\n        }\n\n        @Override\n        public TypedQuery<T> setTimeout(Integer timeout) {\n            super.setTimeout(timeout);\n            if (timeout != null) {\n                recordOption(Timeout.ms(timeout));\n            }\n            return this;\n        }\n\n        @Override