      @Test
      void tcpChannelsCanSendFileRegionsWhenAvailable(@TempDir Path tempDir) throws Exception {
          if (!IoUring.isAvailable()) {
              assertThatThrownBy(IoUringIoHandler::newFactory).isInstanceOf(LinkageError.class);
              return;
