rect.hashCode());\n        assertThat(copy.toString()).contains(\"id: abc\", \"event: created\", \"payload\", \"retry: 250\");\n\n        SseEvent empty = new SseEvent();\n        assertThat(empty.id()).isNull();\n        assertThat(empty.event()).isNull();\n        assertThat(empty.data()).isNull();\n        assertThat(empty.retry()).isZero();\n    }\n", "newText": "\n"}, {"oldText": "            TemplateHolder<String> holder = new TemplateHolder<>(\"compiled-template\", \"views\");\n", "newText": "            CachedTemplate<String> holder = new CachedTemplate<>(\"compiled-template\", \"views\");\n"}, {"oldText": "            TemplateHolder<String> holder = new TemplateHolder<>(\"compiled-template\");\n", "newText": "            CachedTemplate<String> holder = new CachedTemplate<>(\"compiled-template\");\n"}, {"oldText": "        CompletableFuture<BodyStream<T>> future = new CompletableFuture<>();\n        codec.create((Handler<AsyncResult<BodyStream<T>>>) result -> complete(future, result));\n        return future.get(TIMEOUT_SECONDS, TimeUnit.SECONDS);\n", "newText": "        return codec.stream();\n"}, {"oldText": "    private static <T> void complete(CompletableFuture<T> future, AsyncResult<T> result) {\n        if (result.succeeded()) {\n            future.complete(result.result());\n        } else {\n            future.completeExceptionally(result.cause());\n        }\n    }\n\n", "newText": ""}, {"oldText": "        @Override\n        public void write(Buffer data, Handler<AsyncResult<Void>> handler) {\n            content.appendBuffer(data);\n            handler.handle(Future.succeededFuture());\n        }\n\n        @Override\n        public void end(Handler<AsyncResult<Void>> handler) {\n            closed = true;\n            handler.handle(Future.succeededFuture());\n        }\n\n", "newText": "        @Override\n        public Future<Void> end() {\n            closed = true;\n            return Future.succeededFuture();\n        }\n\n"}, {"oldText": " 