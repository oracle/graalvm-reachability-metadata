      public static synchronized MimeTypes getDefaultMimeTypes(ClassLoader classLoader) {
          MimeTypes types = DEFAULT_TYPES;
          if (classLoader != null) {
              types = CLASSLOADER_SPECIFIC_DEFAULT_TYPES.get(classLoader);
          }
  
          if (types == null) {
              try {
                  types = MimeTypesFactory
