port static org.assertj.core.api.Assertions.assertThat;\\n\\nimport java.util.LinkedHashMap;\\nimport java.util.Map;\\nimport java.util.concurrent.atomic.AtomicInteger;\\nimport java.util.concurrent.atomic.AtomicReference;\\n\\nimport javax.persistence.EntityManager;\\nimport javax.persistence.EntityManagerFactory;\\nimport javax.persistence.Persistence;\\nimport javax.persistence.spi.PersistenceProvider;\\nimport javax.persistence.spi.PersistenceUnitInfo;\\n\\nimport org.junit.jupiter.api.BeforeEach;\\nimport org.junit.jupiter.api.Test;\\n\\npublic class PersistenceTest {\\n\\n    private static final String PERSISTENCE_UNIT_NAME = \\\"dynamic-access-unit\\\";\\n\\n    @BeforeEach\\n    void resetProviderState() {\\n        ServicePersistenceProvider.reset();\\n    }\\n\\n    @Test\\n    void createEntityManagerFactoryDiscoversProviderFromServiceResource() {\\n        Map<String, Object> properties = new LinkedHashMap<>();\\n        properties.put(\\\"tenant\\\", \\\"sample\\\");\\n        properties.put(\\\"ddl\\\", Boolean.FALSE);\\n\\n        EntityManagerFactory entityManagerFactory = Persistence.createEntityManagerFactory(PERSISTENCE_UNIT_NAME, properties);\\n\\n        assertThat(entityManagerFactory).isInstanceOf(SimpleEntityManagerFactory.class);\\n        assertThat(entityManagerFactory.isOpen()).isTrue();\\n        assertThat(ServicePersistenceProvider.constructorCalls).hasValue(1);\\n        assertThat(ServicePersistenceProvider.createEntityManagerFactoryCalls).hasValue(1);\\n        assertThat(ServicePersistenceProvider.lastPersistenceUnitName).hasValue(PERSISTENCE_UNIT_NAME);\\n        assertThat(ServicePersistenceProvider.lastProperties.get()).isSameAs(properties);\\n\\n        entityManagerFactory.close();\\n        assertThat(entityManagerFactory.isOpen()).isFalse();\\n    }\\n\\n    public static final class ServicePersistenceProvider implements PersistenceProvider {\\n        private static final AtomicInteger constructorCalls = new AtomicInteger(