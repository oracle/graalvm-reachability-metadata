[tool-call] delta {"path":"tests/src/javax.persistence/persistence-api/1.0/src/test/java/javax_persistence/persistence_api/PersistenceTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage javax_persistence.persistence_api;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.util.LinkedHashMap;\nimport java.util.Map;\nimport java.util.concurrent.atomic.AtomicInteger;\nimport java.util.concurrent.atomic.AtomicReference;\n\nimport javax.persistence.EntityManager;\nimport javax.persistence.EntityManagerFactory;\nimport javax.persistence.Persistence;\nimport javax.persistence.spi.PersistenceProvider;\nimport javax.persistence.spi.PersistenceUnitInfo;\n\nimport org.junit.jupiter.api.BeforeEach;\nimport org.junit.jupiter.api.Test;\n\npublic class PersistenceTest {\n\n    private static final String PERSISTENCE_UNIT_NAME = \"dynamic-access-unit\";\n\n    @BeforeEach\n    void resetProviderState() {\n        ServicePersistenceProvider.reset();\n    }\n\n    @Test\n    void createEntityManagerFactoryDiscoversProviderFromServiceResource() {\n        Map<String, Object> properties = new LinkedHashMap<>();\n        properties.put(\"tenant\", \"sample\");\n        properties.put(\"ddl\", Boolean.FALSE);\n\n        EntityManagerFactory entityManagerFactory = Persistence.createEntityManagerFactory(PERSISTENCE_UNIT_NAME, properties);\n\n        assertThat(entityManagerFactory).isInstanceOf(SimpleEntityManagerFactory.class);\n        assertThat(entityManagerFactory.isOpen()).isTrue();\n        assertThat(ServicePersistenceProvider.constructorCalls).hasValue(1);\n        assertThat(ServicePersistenceProvider.createEntityManagerFactoryCalls).hasValue(1);\n        assertThat(ServicePersistenceProvider.lastPersistenceUnitName).hasValue(PERSISTENCE_UNIT_NAME);\n        assertThat(ServicePersistenceProvider.lastProperties.get()).isSameAs(properties);\n\n        entityManagerFactory.close();\n        assertThat(entityManagerFactory.isOpen()).isFalse();\n    }\n\n    public static final class ServicePersistenceProvider implements PersistenceProvider {\n        private static final AtomicInteger constructorCalls = new AtomicInteger();\n        private static final AtomicInteger createEntityManagerFactoryCalls = new AtomicInteger();\n        private static final AtomicReference<String> lastPersistenceUnitName = new AtomicReference<>();\n        private static final AtomicReference<Map<?, ?>> lastProperties = new AtomicReference<>();\n\n        public ServicePersistenceProvider() {\n            constructorCalls.incrementAndGet();\n        }\n\n        private static void reset() {\n            constructorCalls.set(0);\n            createEntityManagerFactoryCalls.set(0);\n            lastPersistenceUnitName.set(null);\n            lastProperties.set(null);\n        }\n\n        @Override\n        public EntityManagerFactory createEntityManagerFactory(String emName, Map map) {\n            createEntityManagerFactoryCalls.incrementAndGet();\n            lastPersistenceUnitName.set(emName);\n            lastProperties.set(map);\n            if (PERSISTENCE_UNIT_NAME.equals(emName)) {\n                return new SimpleEntityManagerFactory();\n            }\n            return null;\n        }\n\n        @Override\n        public EntityManagerFactory createContainerEntityManagerFactory(PersistenceUnitInfo info, Map map) {\n            return new SimpleEntityManagerFactory();\n        }\n    }\n\n    private static final class SimpleEntityManagerFactory implements EntityManagerFactory {\n        private boolean open = true;\n\n        @Override\n        public EntityManager createEntityManager() {\n            return null;\n        }\n\n        @Override\n        public EntityManager createEntityManager(Map map) {\n            return null;\n        }\n\n        @Override\n        public void close() {\n            open = false;\n        }\n\n        @Override\n        public boolean isOpen() {\n            return open;\n        }\n    }\n}\n"}
