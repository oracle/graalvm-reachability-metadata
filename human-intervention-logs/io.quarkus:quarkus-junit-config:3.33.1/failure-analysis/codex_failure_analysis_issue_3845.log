tomizer().configBuilder(builder);\\n\\n        SmallRyeConfig config = builder.build();\\n        assertThat(config.getValue(\\\"quarkus.log.file.path\\\", String.class)).isEqualTo(expectedLogFilePath());\\n    }\\n\\n    @Test\\n    void serviceLoaderFindsQuarkusConfigBuilderCustomizer() {\\n        List<String> customizerClassNames = ServiceLoader.load(SmallRyeConfigBuilderCustomizer.class).stream()\\n                .map(ServiceLoader.Provider::type)\\n                .map(Class::getName)\\n                .toList();\\n\\n        assertThat(customizerClassNames).contains(TestConfigCustomizer.class.getName());\\n    }\\n\\n    @Test\\n    void serviceLoaderFindsLoggingSetupExtension() {\\n        List<String> extensionClassNames = ServiceLoader.load(Extension.class).stream()\\n                .map(ServiceLoader.Provider::type)\\n                .map(Class::getName)\\n                .toList();\\n\\n        assertThat(extensionClassNames).contains(LoggingSetupExtension.class.getName());\\n        assertThat(new LoggingSetupExtension()).isInstanceOf(Extension.class);\\n    }\\n\\n    @Test\\n    void junitPlatformPropertiesEnableTheQuarkusJunitIntegration() throws IOException {\\n        Properties properties = new Properties();\\n        try (InputStream stream = contextClassLoader().getResourceAsStream(\\\"junit-platform.properties\\\")) {\\n            assertThat(stream).isNotNull();\\n            properties.load(stream);\\n        }\\n\\n        assertThat(properties)\\n                .containsEntry(\\\"junit.jupiter.extensions.autodetection.enabled\\\", \\\"true\\\")\\n                .containsEntry(\\\"junit.jupiter.testclass.order.default\\\", QuarkusClassOrderer.class.getName());\\n    }\\n\\n    @Test\\n    void configProviderExposesTheQuarkusTestConfiguration() {\\n        Config config = ConfigProvider.getConfig();\\n        SmallRyeConfig smallRyeConfig = config.unwrap(SmallRyeConfig.class);\\n\\n        assertThat(smallRyeConfig.getValue(\\\"quarkus.log.file.path\\\", String.class)).isEqualTo(expectedLogFilePath());\\n    }\\n\\n    @Test\\n    void quarkusClassOrdererAcceptsAStandardJunitClassOrdererContext() {\\n        List<SimpleClassDescriptor> descriptors = new ArrayList<>();\\n        descriptors.add(new SimpleClassDescriptor(Quarkus_junit_configTest.class));\\n        SimpleClassOrdererContext context = new SimpleClassOrdererContext(descriptors);\\n\\n        new QuarkusClassOrderer().orderClasses(context);\\n\\n        assertThat(context.getClassDescriptors())\\n                .hasSize(1)\\n                .first()\\n                .extracting(ClassDescriptor::getTestClass)\\n                .isEqualTo(Quarkus_junit_configTest.class);\\n    }\\n\\n    public static class ReverseDisplayNameOrderer implements ClassOrderer {\\n        @Override\\n        public void orderClasses(ClassOrdererContext context) {\\n            List<ClassDescriptor> descriptors = mutableDescriptors(context);\\n            descriptors.sort(Comparator.comparing(ClassDescriptor::getDisplayName).reversed());\\n        }\\n\\n        @SuppressWarnings({ \\\"rawtypes\\\", \\\"unchecked\\\" })\\n        private static List<ClassDescriptor> mutableDescriptors(ClassOrdererContext context) {\\n            return (List) context.getClassDescriptors();\\n        }\\n    }\\n\\n    private static String expectedLogFilePath() {\\n        String directory = Files.isDirectory(Path.of(\\\"build\\\")) ? \\\"build\\\" : \\\"target\\\";\\n        return String.join(File.separator, directory, \\\"quarkus.log\\\");\\n    }\\n\\n    private static ClassLoader contextClassLoader() {\\n        return Thread.currentThread().getContextClassLoader();\\n    }\\n\\n    private static final class SimpleClassOrdererContext implements ClassOrdererContext {\\n        private final List<SimpleClassDescriptor> descriptors;\\n\\n        private SimpleClassOrdererContext(List<SimpleClassDescriptor> descriptors) {\\n            this.descriptors = descriptors;\\n        }\\n\\n        @Override\\n        public List<SimpleClassDescriptor> getClassDescriptors() {\\n            return descriptors;\\n        }\\n\\n        @Override\\n        public Optional<String> getConfigurationParameter(String key) {\\n            return Optional.empty();\\n        }\\n    }\\n\\n    private static final class SimpleClassDescriptor implements ClassDescriptor {\\n        private final Class<?> testClass;\\n\\n        private SimpleClassDescriptor(Class<?> testClass) {\\n            this.testClass = testClass;\\n        }\\n\\n        @Override\\n        public Class<?> getTestClass() {\\n            return testClass;\\n        }\\n\\n        @Override\\n        public String getDisplayName() {\\n            return testClass.getSimpleName();\\n        }\\n\\n        @Override\\n        public boolean isAnnotated(Class annotationType) {\\n            return findAnnotation(annotationType).isPresent();\\n        }\\n\\n        @Override\\n        public Optional findAnnotation(Class annotationType) {\\n            return Optional.ofNullable(testClass.getAnnotation(annotationType));\\n        }\\n\\n        @Override\\n        public List findRepeatableAnnotations(Class annotationType) {\\n            return List.of(testClass.getAnnotationsByType(annotationType));\\n        }\\n    }\\n}\\n\"}\nhuman-intervention-logs/io.quarkus:quarkus-junit-config:3.33.1/add-new-library-support/pi-generation-2026-06-09T13-23-59-375603Z.log:10704:[tool-exec] end id=call_4vSQVRiioW6rLST2EIjgj26J|fc_0aa0a07eae13856c016a281392204c8193a23fb4e45d3ceed5 name=write status=success\nhuman-intervention-logs/io.quarkus:quarkus-junit-config:3.33.1/add-new-library-support/pi-generation-2026-06-09T13-23-59-375603Z.log:10706:[recv] {\"type\": \"message_start\", \"message\": {\"role\": \"toolResult\", \"toolCallId\": \"call_4vSQVRiioW6rLST2EIjgj26J|fc_0aa0a07eae13856c016a281392204c8193a23fb4e45d3ceed5\", \"toolName\": \"write\", \"content\": [{\"type\": \"text\", \"text\": \"Succ