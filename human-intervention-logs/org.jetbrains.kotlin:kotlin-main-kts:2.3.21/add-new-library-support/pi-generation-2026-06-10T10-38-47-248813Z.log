  package org_jetbrains_kotlin.kotlin_main_kts
  
  import kotlin.script.experimental.api.KotlinType
  import kotlin.script.experimental.api.ScriptCompilationConfiguration
  import kotlin.script.experimental.api.fileExtension
  import kotlin.script.experimental.jvm.impl.KJvmCompiledScript
  import kotlin.script.experimental.jvm.impl.toBytes
  import org.assertj.core.api.Assertions.assertThat
  import org.junit.jupiter.api.Test
  import java.io.ByteArrayInputStream
  import java.io.ObjectInputStream
  
  public class KJvmCompiledScriptDataTest {
      @Test
      public fun serializesAndDeserializesCompiledScriptData(): Unit {
          val script: KJvmCompiledScript = KJvmCompiledScript(
              sourceLocationId = "test:///serialized-main.kts",
              compilationConfiguration = ScriptCompilationConfiguration(),
              scriptClassFQName = "example.SerializedMainScript",
              resultField = "result" to KotlinType("kotlin.Int"),
              otherScripts = emptyList(),
              compiledModule = null,
          )
  
          val copy: KJvmCompiledScript = ObjectInputStream(ByteArrayInputStream(script.toBytes())).use { stream: ObjectInputStream ->
              stream.readObject() as KJvmCompiledScript
          }
  
          assertThat(copy.sourceLocationId).isEqualTo("test:///serialized-main.kts")
          assertThat(copy.scriptClassFQName).isEqualTo("example.SerializedMainScript")
          assertThat(copy.compilationConfiguration[ScriptCompilationConfiguration.fileExtension]).isEqualTo("kts")
          assertThat(copy.otherScripts).isEmpty()
