  package org_jetbrains_kotlin.kotlin_main_kts
  
  import org.assertj.core.api.Assertions.assertThat
  import org.jetbrains.kotlin.com.google.common.collect.ArrayListMultimap
  import org.jetbrains.kotlin.com.google.common.collect.HashMultiset
  import org.jetbrains.kotlin.com.google.common.collect.ImmutableListMultimap
  import org.junit.jupiter.api.Test
  import java.io.ByteArrayInputStream
  import java.io.ByteArrayOutputStream
  import java.io.ObjectInputStream
  import java.io.ObjectOutputStream
  import java.io.Serializable
  
  public class SerializationTest {
      @Test
      fun serializesAndDeserializesMultisetEntries() {
          val multiset: HashMultiset<String> = HashMultiset.create()
          multiset.add("kotlin", 2)
          multiset.add("script", 3)
  
          val copy: HashMultiset<String> = roundTrip(multiset)
  
          assertThat(copy.count("kotlin")).isEqualTo(2)
          assertThat(copy.count("script")).isEqualTo(3)
          assertThat(copy.entrySet()).hasSameSizeAs(multiset.entrySet())
      }
  
      @Test
      fun serializesAndDeserializesMultimapKeysAndValues() {
          val multimap: ArrayListMultimap<String, String> = ArrayListMultimap.create()
          multimap.put("script", "main.kts")
          multimap.put("script", "init.kts")
          multimap.put("compiler", "embeddable")
  
          val copy: ArrayListMultimap<String, String> = roundTrip(multimap)
  
          assertThat(copy.get("script")).containsExactly("main.kts", "init.kts")
          assertThat(copy.get("compiler")).containsExactly("embeddable")
          assertThat(copy.size()).isEqualTo(multimap.size())
      }
  
      @Test
      fun deserializesImmutableMultimapThroughFieldSetters() {
          val multimap: ImmutableListMultimap<String, String> = ImmutableListMultimap.builder<String, String>()
              .put("script", "main.kts")
              .put("script", "init.kts")
              .put("compiler", "embeddable")
              .build()
  
          val copy: ImmutableListMultimap<String, String> = roundTrip(multimap)
  
          assertThat(copy).isEqualTo(multimap)
          assertThat(copy.get("script")).containsExactly("main.kts", "init.kts")
      }
  
      private fun <T> roundTrip(value: T): T where T : Serializable {
          val output: ByteArrayOutputStream = ByteArrayOutputStream()
          ObjectOutputStream(output).use { stream: ObjectOutputStream ->
              stream.writeObject(value)
          }
  
          ObjectInputStream(ByteArrayInputStream(output.toByteArray())).use { stream: ObjectInputStream ->
              @Suppress("UNCHECKED_CAST")
              return stream.readObject() as T
          }
      }
  }
