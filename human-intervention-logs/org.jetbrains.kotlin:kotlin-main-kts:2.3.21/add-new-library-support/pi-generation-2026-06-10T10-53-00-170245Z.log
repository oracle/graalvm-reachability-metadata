[tool-call] delta {"path":"tests/src/org.jetbrains.kotlin/kotlin-main-kts/2.3.21/src/test/kotlin/org_jetbrains_kotlin/kotlin_main_kts/JvmClasspathUtilKtTest.kt","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_jetbrains_kotlin.kotlin_main_kts\n\nimport kotlin.script.experimental.jvm.util.classpathFromClassloader\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\nimport org.junit.jupiter.api.io.TempDir\nimport java.io.File\nimport java.net.URL\nimport java.util.Collections\nimport java.util.Enumeration\nimport java.util.jar.JarEntry\nimport java.util.jar.JarOutputStream\n\npublic class JvmClasspathUtilKtTest {\n    @TempDir\n    lateinit var tempDir: File\n\n    @Test\n    fun discoversClasspathFromGetUrlsMethodOnCustomClassLoader(): Unit {\n        val classesDirectory: File = tempDir.resolve(\"get-urls-classes\").apply { mkdirs() }\n        val classLoader: GetUrlsClassLoader = GetUrlsClassLoader(listOf(classesDirectory.toURI().toURL()))\n\n        val classpath: List<File>? = classpathFromClassloader(classLoader)\n\n        assertThat(classpath).contains(classesDirectory)\n    }\n\n    @Test\n    fun discoversParentClasspathFromNewIdeaStyleRootClassLoader(): Unit {\n        val parentDirectory: File = tempDir.resolve(\"new-parent-classes\").apply { mkdirs() }\n        val childDirectory: File = tempDir.resolve(\"new-child-classes\").apply { mkdirs() }\n        val parent: GetUrlsClassLoader = GetUrlsClassLoader(listOf(parentDirectory.toURI().toURL()))\n        val child: NewParentsClassLoader = NewParentsClassLoader(\n            parents = arrayOf(parent),\n            urls = listOf(childDirectory.toURI().toURL()),\n        )\n\n        val classpath: List<File>? = classpathFromClassloader(child)\n\n        assertThat(classpath).contains(parentDirectory, childDirectory)\n    }\n\n    @Test\n    fun discoversParentClasspathFromOldIdeaStyleRootClassLoader(): Unit {\n        val parentDirectory: File = tempDir.resolve(\"old-parent-classes\").apply { mkdirs() }\n        val childDirectory: File = tempDir.resolve(\"old-child-classes\").apply { mkdirs() }\n        val parent: GetUrlsClassLoader = GetUrlsClassLoader(listOf(parentDirectory.toURI().toURL()))\n        val child: OldParentsClassLoader = OldParentsClassLoader(\n            parents = arrayOf(parent),\n            urls = listOf(childDirectory.toURI().toURL()),\n        )\n\n        val classpath: List<File>? = classpathFromClassloader(child)\n\n        assertThat(classpath).contains(parentDirectory, childDirectory)\n    }\n\n    @Test\n    fun unpacksJarCollectionResourcesFromCustomClassLoader(): Unit {\n        val executableJar: File = tempDir.resolve(\"application.jar\")\n        createJarCollection(executableJar)\n        val classLoader: JarCollectionClassLoader = JarCollectionClassLoader(executableJar)\n\n        val classpath: List<File>? = classpathFromClassloader(classLoader, unpackJarCollections = true)\n\n        assertThat(classpath).isNotNull\n        assertThat(classpath!!).anySatisfy { file: File ->\n            assertThat(file.path.replace(File.separatorChar, '/')).endsWith(\"BOOT-INF/classes\")\n        }\n        assertThat(classpath).anySatisfy { file: File ->\n            assertThat(file.name).isEqualTo(\"nested.jar\")\n        }\n    }\n\n    private fun createJarCollection(target: File): Unit {\n        JarOutputStream(target.outputStream()).use { jarOutputStream: JarOutputStream ->\n            jarOutputStream.putNextEntry(JarEntry(\"BOOT-INF/classes/example.txt\"))\n            jarOutputStream.write(\"resource\".toByteArray())\n            jarOutputStream.closeEntry()\n            jarOutputStream.putNextEntry(JarEntry(\"BOOT-INF/lib/nested.jar\"))\n            jarOutputStream.write(byteArrayOf(0))\n            jarOutputStream.closeEntry()\n        }\n    }\n\n    private open class GetUrlsClassLoader(private val urls: List<URL>) : ClassLoader(null) {\n        fun getUrls(): List<URL> = urls\n    }\n\n    private class NewParentsClassLoader(\n        private val parents: Array<ClassLoader>,\n        urls: List<URL>,\n    ) : GetUrlsClassLoader(urls) {\n        fun getAllParents(): Array<ClassLoader> = parents\n    }\n\n    private class OldParentsClassLoader(\n        private val myParents: Array<ClassLoader>,\n        urls: List<URL>,\n    ) : GetUrlsClassLoader(urls)\n\n    private class JarCollectionClassLoader(private val jarFile: File) : ClassLoader(null) {\n        override fun getResource(name: String): URL? =\n            if (name == \"BOOT-INF/classes\") jarEntryUrl(name) else null\n\n        override fun getResources(name: String): Enumeration<URL> =\n            if (name == \"BOOT-INF/classes\") {\n                Collections.enumeration(listOf(jarEntryUrl(name)))\n            } else {\n                Collections.emptyEnumeration()\n            }\n\n        private fun jarEntryUrl(name: String): URL = URL(\"jar:${jarFile.toURI().toURL()}!/$name\")\n    }\n}\n"}
