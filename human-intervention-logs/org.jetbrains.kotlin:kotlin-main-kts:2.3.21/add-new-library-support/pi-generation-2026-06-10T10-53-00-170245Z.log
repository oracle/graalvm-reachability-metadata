  package org_jetbrains_kotlin.kotlin_main_kts
  
  import org.assertj.core.api.Assertions.assertThat
  import org.jetbrains.kotlin.org.codehaus.plexus.classworlds.ClassWorld
  import org.jetbrains.kotlin.org.codehaus.plexus.classworlds.realm.ClassRealm
  import org.junit.jupiter.api.Test
  import java.net.URL
  import java.util.Enumeration
  
  public class ClassRealmTest {
      @Test
      fun loadsClassesThroughConfiguredImportAndParentClassLoaders(): Unit {
          val applicationClassLoader: ClassLoader = applicationClassLoader()
          val importedRealm: ClassRealm = ImportBackedClassRealm(
              ClassWorld(),
              "import-class-loading-realm",
              applicationClassLoader,
          )
          val world: ClassWorld = ClassWorld()
          val parentRealm: ClassRealm = world.newRealm("parent-class-loading-realm", applicationClassLoader)
          val childRealm: ClassRealm = world.newRealm("child-class-loading-realm", null)
  
          try {
              childRealm.setParentRealm(parentRealm)
  
              assertThat(importedRealm.loadClassFromImport("java.lang.String")).isSameAs(String::class.java)
              assertThat(childRealm.loadClassFromParent("java.lang.Integer")).isSameAs(Int::class.javaObjectType)
          } finally {
              importedRealm.close()
              parentRealm.close()
              childRealm.close()
          }
      }
  
      @Test
      fun checksRealmItselfBeforeReportingMissingClass(): Unit {
          val realm: ClassRealm = ClassWorld().newRealm("self-loading-realm", null)
  
          try {
              assertThat(realm.loadClassFromSelf("example.DoesNotExistInThisRealm")).isNull()
          } finally {
              realm.close()
          }
      }
  
      @Test
      fun searchesResourcesThroughRealmImportParentAndBaseLoaders(): Unit {
          val applicationClassLoader: ClassLoader = applicationClassLoader()
          val resourceName: String = "org/jetbrains/kotlin/mainKts/no-such-resource.txt"
          val importedRealm: ClassRealm = ImportBackedClassRealm(
              ClassWorld(),
              "import-resource-loading-realm",
              applicationClassLoader,
          )
          val world: ClassWorld = ClassWorld()
          val parentRealm: ClassRealm = world.newRealm("parent-resource-loading-realm", applicationClassLoader)
          val childRealm: ClassRealm = world.newRealm("child-resource-loading-realm", applicationClassLoader)
  
          try {
              childRealm.setParentRealm(parentRealm)
  
              assertThat(childRealm.getResource(resourceName)).isNull()
              assertThat(importedRealm.loadResourceFromImport(resourceName)).isNull()
              assertThat(childRealm.loadResourceFromParent(resourceName)).isNull()
              assertThat(childRealm.getResources(resourceName).toList()).isEmpty()
              assertThat(importedRealm.loadResourcesFromImport(resourceName).toList()).isEmpty()
              assertThat(childRealm.loadResourcesFromParent(resourceName).toList()).isEmpty()
          } finally {
              importedRealm.close()
              parentRealm.close()
              childRealm.close()
          }
      }
  
      private fun applicationClassLoader(): ClassLoader =
          Thread.currentThread().contextClassLoader ?: ClassRealmTest::class.java.classLoader
  
      private class ImportBackedClassRealm(
          world: ClassWorld,
          id: String,
          private val importClassLoader: ClassLoader,
      ) : ClassRealm(world, id, null) {
          override fun getImportClassLoader(name: String): ClassLoader = importClassLoader
      }
  
      private fun Enumeration<URL>.toList(): List<URL> {
          val resources: MutableList<URL> = mutableListOf()
          while (hasMoreElements()) {
              resources.add(nextElement())
          }
          return resources
      }
  }
