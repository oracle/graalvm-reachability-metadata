{\n        val definition = createJvmScriptDefinitionFromTemplate<MainKtsScript>()\n\n        assertThat(definition.compilationConfiguration[ScriptCompilationConfiguration.fileExtension])\n            .isEqualTo(\"main.kts\")\n        assertThat(definition.compilationConfiguration[ScriptCompilationConfiguration.hostConfiguration])\n            .isNotNull()\n    }\n\n    @Test\n    fun initializesMainKtsJsr223FactoryDefinition(): Unit {\n        val factory = KotlinJsr223MainKtsScriptEngineFactory()\n\n        assertThat(factory.extensions).containsExactly(\"main.kts\")\n    }\n\n    @Test\n    fun rejectsCompilationConfigurationClassWithoutNoArgConstructor(): Unit {\n        assertThatThrownBy {\n            createCompilationConfigurationFromTemplate(\n                KotlinType(InvalidCompilationConfigurationScriptTemplate::class),\n                scriptLoadingHostConfiguration(),\n            )\n        }.isInstanceOf(IllegalArgumentException::class.java)\n            .hasMessageContaining(\"compilationConfiguration\")\n    }\n\n    @Test\n    fun rejectsEvaluationConfigurationClassWithoutNoArgConstructor(): Unit {\n        assertThatThrownBy {\n            createEvaluationConfigurationFromTemplate(\n                KotlinType(InvalidEvaluationConfigurationScriptTemplate::class),\n                scriptLoadingHostConfiguration(),\n            )\n        }.isInstanceOf(IllegalArgumentException::class.java)\n            .hasMessageContaining(\"evaluationConfiguration\")\n    }\n\n    @Test\n    fun createsDefinitionFromTemplateUsingConstructorBackedConfigurations(): Unit {\n"},{"oldText":"@KotlinScript(\n    displayName = \"constructor backed script\",\n    fileExtension = \"constructor.kts\",\n    compilationConfiguration = ConstructorBackedCompilationConfiguration::class,\n    evaluationConfiguration = ConstructorBackedEvaluationConfiguration::class,\n    hostConfiguration = BaseAwareHostConfiguration::class,\n)\npublic abstract class ConstructorBackedScriptTempl