n        multiset.add(\"kotlin\", 2)\n        multiset.add(\"script\", 3)\n\n        val copy: HashMultiset<String> = roundTrip(multiset)\n\n        assertThat(copy.count(\"kotlin\")).isEqualTo(2)\n        assertThat(copy.count(\"script\")).isEqualTo(3)\n        assertThat(copy.entrySet()).hasSameSizeAs(multiset.entrySet())\n    }\n\n    @Test\n    fun serializesAndDeserializesMultimapKeysAndValues() {\n        val multimap: ArrayListMultimap<String, String> = ArrayListMultimap.create()\n        multimap.put(\"script\", \"main.kts\")\n        multimap.put(\"script\", \"init.kts\")\n        multimap.put(\"compiler\", \"embeddable\")\n\n        val copy: ArrayListMultimap<String, String> = roundTrip(multimap)\n\n        assertThat(copy.get(\"script\")).containsExactly(\"main.kts\", \"init.kts\")\n        assertThat(copy.get(\"compiler\")).containsExactly(\"embeddable\")\n        assertThat(copy.size()).isEqualTo(multimap.size())\n    }\n\n    @Test\n    fun deserializesImmutableMultimapThroughFieldSetters() {\n        val multimap: ImmutableListMultimap<String, String> = ImmutableListMultimap.builder<String, String>()\n            .put(\"script\", \"main.kts\")\n            .put(\"script\", \"init.kts\")\n            .put(\"compiler\", \"embeddable\")\n            .build()\n\n        val copy: ImmutableListMultimap<String, String> = roundTrip(multimap)\n\n        assertThat(copy).isEqualTo(multimap)\n        assertThat(copy.get(\"script\")).containsExactly(\"main.kts\", \"init.kts\")\n    }\n\n    private fun <T> roundTrip(value: T): T where T : Serializable {\n        val output: ByteArrayOutputStream = ByteArrayOutputStream()\n        ObjectOutputStream(output).use { stream: ObjectOutputStream ->\n            stream.writeObject(value)\n        }\n\n        ObjectInputStream(ByteArrayInputStream(output.toByteArray())).use { stream: ObjectInputStream ->\n            @Suppress(\"UNCHECKED_CAST\")\n            return stream.readObject() as T\n        }\n    }\n}\n"}], "