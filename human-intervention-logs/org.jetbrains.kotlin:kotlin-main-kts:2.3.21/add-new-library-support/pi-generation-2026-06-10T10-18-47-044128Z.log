ucted host\")\n    }\n\n    @Test\n    fun createsEvaluationConfigurationUsingConstructorBackedEvaluationConfiguration(): Unit {\n","newText":"    @Test\n    fun createsCompilationConfigurationUsingNoArgCompilationConfiguration(): Unit {\n        val configuration = createCompilationConfigurationFromTemplate(\n            KotlinType(CompilationConfigurationOnlyScriptTemplate::class),\n            scriptLoadingHostConfiguration(),\n        )\n\n        assertThat(configuration[ScriptCompilationConfiguration.fileExtension]).isEqualTo(\"compilation-only.kts\")\n        assertThat(configuration[ScriptCompilationConfiguration.defaultImports]).containsExactly(\"java.net.URI\")\n    }\n\n    @Test\n    fun createsCompilationConfigurationUsingDefaultConstructedHostConfiguration(): Unit {\n        val configuration = createCompilationConfigurationFromTemplate(\n            KotlinType(DefaultConstructedHostScriptTemplate::class),\n            scriptLoadingHostConfiguration(),\n        )\n\n        assertThat(configuration[ScriptCompilationConfiguration.fileExtension]).isEqualTo(\"default-host.kts\")\n        assertThat(configuration[ScriptCompilationConfiguration.hostConfiguration]?.evaluationCommandLineArgs())\n            .containsExactly(\"from default constructed host\")\n    }\n\n    @Test\n    fun createsCompilationConfigurationUsingDefaultConstructedHostConfigurationAndDefaultScriptConfiguration(): Unit {\n        val configuration = createCompilationConfigurationFromTemplate(\n            KotlinType(DefaultConstructedHostOnlyScriptTemplate::class),\n            scriptLoadingHostConfiguration(),\n        )\n\n        assertThat(configuration[ScriptCompilationConfiguration.fileExtension]).isEqualTo(\"default-host-only.kts\")\n        assertThat(configuration[ScriptCompilationConfiguration.hostConfiguration]?.evaluationCommandLineArgs())\n            .containsExactly(\"from default constructed host\")\n    }\n\n    @Test\n    fun createsEvaluationConfigurationUsingConstr