ntent": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_jetbrains_kotlin.kotlin_main_kts\n\nimport org.assertj.core.api.Assertions.assertThat\nimport org.jetbrains.kotlin.com.google.common.collect.ArrayListMultimap\nimport org.jetbrains.kotlin.com.google.common.collect.HashMultiset\nimport org.jetbrains.kotlin.com.google.common.collect.ImmutableListMultimap\nimport org.junit.jupiter.api.Test\nimport java.io.ByteArrayInputStream\nimport java.io.ByteArrayOutputStream\nimport java.io.ObjectInputStream\nimport java.io.ObjectOutputStream\nimport java.io.Serializable\n\npublic class SerializationTest {\n    @Test\n    fun serializesAndDeserializesMultisetEntries() {\n        val multiset: HashMultiset<String> = HashMultiset.create()\n        multiset.add(\"kotlin\", 2)\n        multiset.add(\"script\", 3)\n\n        val copy: HashMultiset<String> = roundTrip(multiset)\n\n        assertThat(copy.count(\"kotlin\")).isEqualTo(2)\n        assertThat(copy.count(\"script\")).isEqualTo(3)\n        assertThat(copy.entrySet()).hasSameSizeAs(multiset.entrySet())\n    }\n\n    @Test\n    fun serializesAndDeserializesMultimapKeysAndValues() {\n        val multimap: ArrayListMultimap<String, String> = ArrayListMultimap.create()\n        multimap.put(\"script\", \"main.kts\")\n        multimap.put(\"script\", \"init.kts\")\n        multimap.put(\"compiler\", \"embeddable\")\n\n        val copy: ArrayListMultimap<String, String> = roundTrip(multimap)\n\n        assertThat(copy.get(\"script\")).containsExactly(\"main.kts\", \"init.kts\")\n        assertThat(copy.get(\"compiler\")).containsExactly(\"embeddable\")\n        assertThat(copy.size()).isEqualTo(multimap.size())\n    }\n\n    @Test\n    fun deserializesImmutableMultimapThroughFieldSetters() {\n        val multimap: ImmutableListMultimap<String, String> = ImmutableListMultimap.builder<String, String>()\n            .put(\"script\", \"main.kts\")\n            .put(\"script\", \"init.kts\")\n            .put(\"compiler\", \"embeddable\")\n            .build()\n\n        val copy: ImmutableListMultimap<String, String> = roundTrip(multimap)\n\n        assertThat(copy).isEqualTo(multimap)\n        assertThat(copy.get(\"script\")).containsExactly(\"main.kts\", \"init.kts\")\n    }\n\n    private fun <T> roundTrip(value: T): T where T : Serializable {\n        val output: ByteArrayOutputStream = ByteArrayOutputStream()\n        ObjectOutputStream(output).use { stream: ObjectOutputStream ->\n            stream.writeObject(value)\n        }\n\n        ObjectInputStream(ByteArrayInputStream(output.toByteArray())).use { stream: ObjectInputStream ->\n            @Suppress(\"UNCHECKED_CAST\")\n            return stream.readObject() as T\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 300, "output": 1295, "cacheRead": 54272, "cacheWrite": 0, "totalTokens": 55867, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1781086010306, "responseId": "resp_0a8826ad0dcca618016a29373af2608197b315b7a6f2d6fc5f"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_RD2Cn0IrzPkB9XvyaVFxmEwC|fc_0a8826ad0dcca618016a293751309c81979f6c19bed3e5cda7", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2773 bytes to tests/src/org.jetbrains.kotlin/kotlin-main-kts/2.3.21/src/test/kotlin/org_jetbrains_kotlin/kotlin_main_kts/SerializationTest.kt"}], "isError": false, "timestamp": 1781086039492}]}
