[tool-call] delta {"path":"tests/src/org.jetbrains.kotlin/kotlin-main-kts/2.3.21/src/test/kotlin/org_jetbrains_kotlin/kotlin_main_kts/ConfigurationFromTemplateKtTest.kt","edits":[{"oldText":"import kotlin.script.experimental.api.baseClass\n","newText":""},{"oldText":"import kotlin.script.experimental.api.scriptsInstancesSharing\n","newText":""},{"oldText":"import kotlin.script.experimental.jvmhost.createJvmScriptDefinitionFromTemplate\nimport org.assertj.core.api.Assertions.assertThat\nimport org.jetbrains.kotlin.mainKts.MainKtsScript\n","newText":"import org.assertj.core.api.Assertions.assertThat\n"},{"oldText":"    @Test\n    fun createsDefinitionFromBundledMainKtsTemplate(): Unit {\n        val definition = createScriptDefinitionFromTemplate(\n            KotlinType(MainKtsScript::class),\n            scriptLoadingHostConfiguration(),\n        )\n\n        assertThat(definition.compilationConfiguration[ScriptCompilationConfiguration.fileExtension])\n            .isEqualTo(\"main.kts\")\n        assertThat(definition.compilationConfiguration[ScriptCompilationConfiguration.baseClass]?.fromClass)\n            .isEqualTo(MainKtsScript::class)\n        assertThat(definition.evaluationConfiguration[ScriptEvaluationConfiguration.scriptsInstancesSharing])\n            .isTrue()\n    }\n\n    @Test\n    fun createsJvmDefinitionFromConstructorBackedTemplate(): Unit {\n        val definition = createJvmScriptDefinitionFromTemplate<ConstructorBackedScriptTemplate>()\n\n        assertThat(definition.compilationConfiguration[ScriptCompilationConfiguration.defaultImports])\n            .containsExactly(\"java.time.Instant\")\n        assertThat(definition.evaluationConfiguration[ScriptEvaluationConfiguration.constructorArgs])\n            .containsExactly(\"evaluation constructor argument\")\n    }\n\n","newText":""}]}
