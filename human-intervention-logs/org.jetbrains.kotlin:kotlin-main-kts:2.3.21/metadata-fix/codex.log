ewRealm(\"self-loading-realm\", null)\n\n        try {\n            assertThat(realm.loadClassFromSelf(\"example.DoesNotExistInThisRealm\")).isNull()\n        } finally {\n            realm.close()\n        }\n    }\n\n    @Test\n    fun searchesResourcesThroughRealmImportParentAndBaseLoaders(): Unit {\n        val applicationClassLoader: ClassLoader = applicationClassLoader()\n        val resourceName: String = \"org/jetbrains/kotlin/mainKts/no-such-resource.txt\"\n        val importedRealm: ClassRealm = ImportBackedClassRealm(\n            ClassWorld(),\n            \"import-resource-loading-realm\",\n            applicationClassLoader,\n        )\n        val world: ClassWorld = ClassWorld()\n        val parentRealm: ClassRealm = world.newRealm(\"parent-resource-loading-realm\", applicationClassLoader)\n        val childRealm: ClassRealm = world.newRealm(\"child-resource-loading-realm\", applicationClassLoader)\n\n        try {\n            childRealm.setParentRealm(parentRealm)\n\n            assertThat(childRealm.getResource(resourceName)).isNull()\n            assertThat(importedRealm.loadResourceFromImport(resourceName)).isNull()\n            assertThat(childRealm.loadResourceFromParent(resourceName)).isNull()\n            assertThat(childRealm.getResources(resourceName).toList()).isEmpty()\n            assertThat(importedRealm.loadResourcesFromImport(resourceName).toList()).isEmpty()\n            assertThat(childRealm.loadResourcesFromParent(resourceName).toList()).isEmpty()\n        } finally {\n            importedRealm.close()\n            parentRealm.close()\n            childRealm.close()\n        }\n    }\n\n    private fun applicationClassLoader(): ClassLoader =\n        Thread.currentThread().contextClassLoader ?: ClassRealmTest::class.java.classLoader\n\n    private class ImportBackedClassRealm(\n        world: ClassWorld,\n        id: String,\n        private val importClassLoader: ClassLoader,\n    ) : ClassRealm(world, id, null) {\n        override fun getImportClassLoader(name: String): ClassLoader = importClassLoader\n    }\n\n    private fun Enumeration<URL>.toList(): List<URL> {\n        val resources: MutableList<URL> = mutableListOf()\n        while (hasMoreElements()) {\n            resources.add(nextElement())\n        }\n        return resources\n    }\n}\n","exit_code":0,"status":"completed"}}
