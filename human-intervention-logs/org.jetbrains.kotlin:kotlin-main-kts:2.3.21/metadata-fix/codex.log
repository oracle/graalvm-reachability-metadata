ionUsingLibraryBackedNoArgConfigurations(): Unit {\n        val definition = createScriptDefinitionFromTemplate(\n            KotlinType(MainKtsScript::class),\n            scriptLoadingHostConfiguration(),\n        )\n\n        assertThat(definition.compilationConfiguration[ScriptCompilationConfiguration.fileExtension])\n            .isEqualTo(\"main.kts\")\n        assertThat(definition.compilationConfiguration[ScriptCompilationConfiguration.hostConfiguration])\n            .isNotNull()\n    }\n\n    @Test\n    fun createsJvmMainKtsDefinitionUsingDefaultJvmHostConfiguration(): Unit {\n        val definition = createJvmScriptDefinitionFromTemplate<MainKtsScript>()\n\n        assertThat(definition.compilationConfiguration[ScriptCompilationConfiguration.fileExtension])\n            .isEqualTo(\"main.kts\")\n        assertThat(definition.compilationConfiguration[ScriptCompilationConfiguration.hostConfiguration])\n            .isNotNull()\n    }\n\n    @Test\n    fun rejectsCompilationConfigurationClassWithoutNoArgConstructor(): Unit {\n        assertThatThrownBy {\n            createCompilationConfigurationFromTemplate(\n                KotlinType(InvalidCompilationConfigurationScriptTemplate::class),\n                scriptLoadingHostConfiguration(),\n            )\n        }.isInstanceOf(IllegalArgumentException::class.java)\n            .hasMessageContaining(\"compilationConfiguration\")\n    }\n\n    @Test\n    fun rejectsEvaluationConfigurationClassWithoutNoArgConstructor(): Unit {\n        assertThatThrownBy {\n            createEvaluationConfigurationFromTemplate(\n                KotlinType(InvalidEvaluationConfigurationScriptTemplate::class),\n                scriptLoadingHostConfiguration(),\n            )\n        }.isInstanceOf(IllegalArgumentException::class.java)\n            .hasMessageContaining(\"evaluationConfiguration\")\n    }\n\n    @Test\n    fun createsDefinitionFromTemplateUsingConstructorBackedConfigurations(): Unit {\n        val definition =