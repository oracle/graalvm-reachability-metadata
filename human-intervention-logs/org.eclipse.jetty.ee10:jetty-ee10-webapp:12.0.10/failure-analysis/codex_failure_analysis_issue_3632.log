assertThat(configurations.get(FirstConfiguration.class)).isSameAs(first);\\n        assertThat(configurations.getConfigurations(RecordingConfiguration.class)).containsExactly(first, second);\\n\\n        configurations.preConfigure(context);\\n        assertThat(configurations.configure(context)).isTrue();\\n        configurations.postConfigure(context);\\n\\n        assertThat(events).containsExactly(\\n                \\\"pre:first\\\",\\n                \\\"pre:second\\\",\\n                \\\"configure:first\\\",\\n                \\\"configure:second\\\",\\n                \\\"post:first\\\",\\n                \\\"post:second\\\");\\n        assertThat(first.getProtectedClasses().match(\\\"com.example.protected.Component\\\")).isTrue();\\n        assertThat(first.getHiddenClasses().match(\\\"com.example.hidden.Component\\\")).isTrue();\\n\\n        configurations.remove(FirstConfiguration.class);\\n        assertThat(configurations.toStringArray()).containsExactly(SecondConfiguration.class.getName());\\n    }\\n\\n    @Test\\n    void webAppContextClassMatchersResourceAliasesAndDescriptorSettingsAreMutable(@TempDir Path webRoot)\\n            throws Exception {\\n        Path staticDirectory = Files.createDirectories(webRoot.resolve(\\\"static\\\"));\\n        Files.writeString(staticDirectory.resolve(\\\"asset.txt\\\"), \\\"asset\\\", StandardCharsets.UTF_8);\\n\\n        WebAppContext context = new WebAppContext();\\n        context.setContextPath(\\\"/custom\\\");\\n        context.setBaseResourceAsPath(webRoot);\\n        context.setDefaultsDescriptor(\\\"classpath:/org/eclipse/jetty/ee10/webapp/webdefault-ee10.xml\\\");\\n        context.setOverrideDescriptor(\\\"/WEB-INF/override.xml\\\");\\n        context.addOverrideDescriptor(\\\"/WEB-INF/second-override.xml\\\");\\n        context.setDistributable(true);\\n        context.setExtractWAR(false);\\n        context.setCopyWebDir(true);\\n        context.setCopyWebInf(true);\\n        context.setParentLoaderPriority(true);\\n        context.setLogUrlOnStart(true);\\n        context.setAllowDuplicateFragmentNames(true);\\n        context.setResourceAlias(\\\"/asset-alias.txt\\\", \\\"/static/asset.txt\\\");\\n        context.setSystemClassMatcher(new ClassMatcher(\\\"com.acme.api.\\\", \\\"-com.acme.api.internal.\\\"));\\n        context.setServerClassMatcher(new ClassMatcher(\\\"com.acme.server.\\\"));\\n        context.addSystemClassMatcher(new ClassMatcher(\\\"com.acme.shared.\\\"));\\n        context.addServerClassMatcher(new ClassMatcher(\\\"com.acme.hidden.\\\"));\\n\\n        assertThat(context.getContextPath()).isEqualTo(\\\"/custom\\\");\\n        assertThat(context.getDefaultsDescriptor()).isEqualTo(\\\"classpath:/org/eclipse/jetty/ee10/webapp/webdefault-ee10.xml\\\");\\n        assertThat(context.getOverrideDescriptor()).isEqualTo(\\\"/WEB-INF/override.xml\\\");\\n        assertThat(context.getOverrideDescriptors()).contains(\\\"/WEB-INF/override.xml\\\", \\\"/WEB-INF/second-override.xml\\\");\\n        assertThat(context.isDistributable()).isTrue();\\n        assertThat(context.isExtractWAR()).isFalse();\\n        assertThat(context.isCopyWebDir()).isTrue();\\n        assertThat(context.isCopyWebInf()).isTrue();\\n        assertThat(context.isParentLoaderPriority()).isTrue();\\n        assertThat(context.isLogUrlOnStart()).isTrue();\\n        assertThat(context.isAllowDuplicateFragmentNames()).isTrue();\\n        assertThat(context.getResourceAliases()).containsEntry(\\\"/asset-alias.txt\\\", \\\"/static/asset.txt\\\");\\n        assertThat(readResource(context.getResource(\\\"/asset-alias.txt\\\"))).isEqualTo(\\\"asset\\\");\\n        assertThat(context.removeResourceAlias(\\\"/asset-alias.txt\\\")).isEqualTo(\\\"/static/asset.txt\\\");\\n        assertThat(context.getResourceAlias(\\\"/asset-alias.txt\\\")).isNull();\\n        assertThat(context.getSystemClassMatcher().match(\\\"com.acme.api.PublicType\\\")).isTrue();\\n        assertThat(context.getSystemClassMatcher().match(\\\"com.acme.api.internal.SecretType\\\")).isFalse();\\n        assertThat(context.getSystemClassMatcher().match(\\\"com.acme.shared.Model\\\")).isTrue();\\n        assertThat(context.getServerClassMatcher().match(\\\"com.acme.server.ContainerType\\\")).isTrue();\\n        assertThat(context.getServerClassMatcher().match(\\\"com.acme.hidden.ContainerType\\\")).isTrue();\\n        assertThat(context.isSystemClass(String.class)).isFalse();\\n    }\\n\\n    private static WebDescriptor parseWebDescriptor(Path path, String xml) throws Exception {\\n        WebDescriptor descriptor = new WebDescriptor(writeResource(path, xml));\\n        descriptor.parse(WebDescriptor.getParser(false));\\n        return descriptor;\\n    }\\n\\n    private static FragmentDescriptor parseFragmentDescriptor(\\n            Path path,\\n            String name,\\n            String afterName,\\n            boolean beforeOthers) throws Exception {\\n        FragmentDescriptor descriptor = new FragmentDescriptor(writeResource(path, webFragmentXml(name, afterName, beforeOthers)));\\n        descriptor.parse(WebDescriptor.getParser(false));\\n        return descriptor;\\n    }\\n\\n    private static Resource createEmptyResource(Path path) throws IOException {\\n        Files.writeString(path, \\\"\\\", StandardCharsets.UTF_8);\\n        return ResourceFactory.root().newResource(path);\\n    }\\n\\n    private static Resource writeResource(Path path, String content) throws IOException {\\n        Files.writeString(path, content, StandardCharsets.UTF_8);\\n        return ResourceFactory.root().newResource(path);\\n    }\\n\\n    private static String readResource(Resource resource) throws IOException {\\n        try (InputStream inputStream = resource.newInputStream()) {\\n            return new String(inputStream.readAllBytes(), StandardCharsets.UTF_8);\\n        }\\n    }\\n\\n    private static String minimalWebXml(String displayName) {\\n        return \\\"\\\"\\\"\\n                <?xml version=\\\"1.0\\\" encoding=\\\"UTF-8\\\"?>\\n                <web-app xmlns=\\\"https://jakarta.ee/xml/ns/jakartaee\\\" version=\\\"6.0\\\">\\n                  <display-name>%s</display-name>\\n                </web-app>\\n                \\\"\\\"\\\".formatted(displayName);\\n    }\\n\\n    private static String webFragmentXml(String name, String afterName, boolean beforeOthers) {\\n        String after = afterName == null ? \\\"\\\" : \\\"\\\"\\\"\\n                  <after>\\n                    <name>%s</name>\\n                  </after>\\n                \\\"\\\"\\\".formatted(afterName);\\n        String before = beforeOthers ? \\\"\\\"\\\"\\n                  <before>\\n                    <others/>\\n                  </before>\\n                \\\"\\\"\\\" : \\\"\\\";\\n        return \\\"\\\"\\\"\\n                <?xml version=\\\"1.0\\\" encoding=\\\"UTF-8\\\"?>\\n                <web-fragment xmlns=\\\"https://jakarta.ee/xml/ns/jakartaee\\\" version=\\\"6.0\\\">\\n                  <name>%s</name>\\n                  <ordering>\\n                %s%s  </ordering>\\n                </web-fragment>\\n                \\\"\\\"\\\".formatted(name, after, before);\\n    }\\n\\n    private static final class GreetingServlet extends HttpServlet {\\n        @Override\\n        protected void doGet(HttpServletRequest request, HttpServletResponse response) throws IOException {\\n            response.setStatus(HttpServletResponse.SC_OK);\\n            response.setContentType(\\\"text/plain;charset=UTF-8\\\");\\n            response.getWriter().printf(\\n                    \\\"context=%s, resource=%s\\\",\\n                    request.getContextPath(),\\n                    getServletContext().getResource(\\\"/static/message.txt\\\") != null);\\n        }\\n    }\\n\\n    private abstract static class RecordingConfiguration extends AbstractConfiguration {\\n        private final List<String> events;\\n        private final String name;\\n\\n        private RecordingConfiguration(AbstractConfiguration.Builder builder, List<String> events, String name) {\\n            super(builder);\\n            this.events = events;\\n            this.name = name;\\n        }\\n\\n        @Override\\n        public void preConfigure(WebAppContext context) {\\n            events.add(\\\"pre:\\\" + name);\\n        }\\n\\n        @Override\\n        public void configure(WebAppContext context) {\\n            events.add(\\\"configure:\\\" + name);\\n        }\\n\\n        @Override\\n        public void postConfigure(WebAppContext context) {\\n            events.add(\\\"post:\\\" + name);\\n        }\\n    }\\n\\n    private static final class FirstConfiguration extends RecordingConfiguration {\\n        private FirstConfiguration(List<String> events) {\\n            super(new AbstractConfiguration.Builder()\\n                    .enabledByDefault(true)\\n                    .protect(\\\"com.example.protected.\\\")\\n                    .hide(\\\"com.example.hidden.\\\"), events, \\\"first\\\");\\n        }\\n    }\\n\\n    private static final class SecondConfiguration extends RecordingConfiguration {\\n        private SecondConfiguration(List<String> events) {\\n            super(new AbstractConfiguration.Builder()\\n                    .addDependencies(FirstConfiguration.class), events, \\\"second\\\");\\n        }\\n    }\\n}\\n\"}\n4220:[tool-call] end id=call_R3rDjQWztLW2lgjAl6xVTZ7G|fc_0df91dfc7677ce0d0169fe317d3b1c8193bbeae9b0489de226 name=write args={\"path\": \"tests/src/org.eclipse.jetty.ee10/jetty-ee10-webapp/12.0.10/src/test/java/org_eclipse_jetty_ee10/jetty_ee10_webapp/Jetty_ee10_webappTest.java\", \"content\": \"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage org_eclipse_jetty_ee10.jetty_ee10_webapp;\\n\\nimport java.io.IOException;\\nimport java.io.InputStream;\\nimport java.nio.charset.StandardCharsets;\\nimport java.nio.file.Files;\\nimport java.nio.file.Path;\\nimport java.util.ArrayList;\\nimport java.util.List;\\nimport java.util.concurrent.TimeUnit;\\n\\nimport jakarta.servlet.http.HttpServlet;\\nimport jakarta.servlet.http.HttpServletRequest;\\nimport jakarta.servlet.http.HttpServletResponse;\\n\\nimport org.eclipse.jetty.ee10.webapp.AbstractConfiguration;\\nimport org.eclipse.jetty.ee10.webapp.AbsoluteOrdering;\\nimport org.eclipse.jetty.ee10.webapp.ClassMatcher;\\nimport org.eclipse.jetty.ee10.webapp.Configuration;\\nimport org.eclipse.jetty.ee10.webapp.Configurations;\\nimport org.eclipse.jetty.ee10.webapp.FragmentDescriptor;\\nimport org.eclipse.jetty.ee10.webapp.MetaData;\\nimport org.eclipse.jetty.ee10.webapp.Origin;\\nimport org.eclipse.jetty.ee10.webapp.OverrideDescriptor;\\nimport org.eclipse.jetty.ee10.webapp.WebAppContext;\\nimport org.eclipse.jetty.ee10.webapp.WebDescriptor;\\nimport org.eclipse.jetty.ee10.webapp.WebInfConfiguration;\\nimport org.eclipse.jetty.ee10.webapp.WebXmlConfiguration;\\nimport org.eclipse.jetty.server.LocalConnector;\\nimport org.eclipse.jetty.server.Server;\\nimport org.eclipse.jetty.util.resource.Resource;\\nimport org.eclipse.jetty.util.resource.ResourceFactory;\\nimport org.graalvm.internal.tck.NativeImageSupport;\\nimport org.junit.jupiter.api.Test;\\nimport org.junit.jupiter.api.io.TempDir;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\n\\npublic class Jetty_ee10_webappTest {\\n    private static final String WEB_XML = \\\"\\\"\\\"\\n            <?xml version=\\\"1.0\\\" encoding=\\\"UTF-8\\\"?>\\n            <web-app xmlns=\\\"https://jakarta.ee/xml/ns/jakartaee\\\"\\n                     xmlns:xsi=\\\"http://www.w3.org/2001/XMLSchema-instance\\\"\\n                     xsi:schemaLocation=\\\"https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd\\\"\\n                     version=\\\"6.0\\\"\\n                     metadata-complete=\\\"true\\\">\\n              <display-name>Jetty Test Application</display-name>\\n              <distributable/>\\n              <absolute-ordering>\\n                <name>alpha-fragment</name>\\n                <others/>\\n              </absolute-ordering>\\n            </web-app>\\n            \\\"\\\"\\\";\\n\\n    @Test\\n    void webAppContextStartsWithParsedDescriptorAndProgrammaticServlet(@TempDir Path webRoot) throws Exception {\\n        Path webInf = Files.createDirectories(webRoot.resolve(\\\"WEB-INF\\\"));\\n        Path staticDirectory = Files.createDirectories(webRoot.resolve(\\\"static\\\"));\\n        Files.writeString(webInf.resolve(\\\"web.xml\\\"), WEB_XML, StandardCharsets.UTF_8);\\n        Files.writeString(staticDirectory.resolve(\\\"message.txt\\\"), \\\"resource from web root\\\", StandardCharsets.UTF_8);\\n\\n        WebAppContext context = new WebAppContext();\\n        context.setContextPath(\\\"/app\\\");\\n        context.setBaseResourceAsPath(webRoot);\\n        context.setConfigurationDiscovered(false);\\n        context.setThrowUnavailableOnStartupException(true);\\n        context.setConfigurations(new WebInfConfiguration(), new WebXmlConfiguration());\\n        context.setResourceAlias(\\\"/aliased.txt\\\", \\\"/static/message.txt\\\");\\n        context.addServlet(GreetingServlet.class, \\\"/hello\\\");\\n\\n        assertThat(readResource(context.getResource(\\\"/aliased.txt\\\"))).isEqualTo(\\\"resource from web root\\\");\\n        assertThat(context.getResourceAlias(\\\"/aliased.txt\\\")).isEqualTo(\\\"/static/message.txt\\\");\\n\\n        Server server = new Server();\\n        server.setStopTimeout(5_000);\\n        LocalConnector connector = new LocalConnector(server);\\n        server.addConnector(connector);\\n        server.setHandler(context);\\n\\n        try {\\n            try {\\n                server.start();\\n            } catch (Error error) {\\n                if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\\n                    throw error;\\n                }\\n                return;\\n            }\\n\\n            String response = connector.getResponse(\\\"\\\"\\\"\\n                    GET /app/hello HTTP/1.1\\\\r\\n\\\\\\n                    Host: localhost\\\\r\\n\\\\\\n                    Connection: close\\\\r\\n\\\\\\n                    \\\\r\\n\\\\\\n                    \\\"\\\"\\\", 5, TimeUnit.SECONDS);\\n\\n            assertThat(response).contains(\\\"HTTP/1.1 200 OK\\\");\\n            assertThat(response).contains(\\\"context=/app, resource=true\\\");\\n            assertThat(context.getDisplayName()).isEqualTo(\\\"Jetty Test Application\\\");\\n            assertThat(context.getMetaData().getWebDescriptor()).isNotNull();\\n            assertThat(context.isDistributable()).isTrue();\\n        } finally {\\n            if (server.isStarted()) {\\n                server.stop();\\n            }\\n            server.destroy();\\n        }\\n    }\\n\\n    @Test\\n    void webAndFragmentDescriptorsExposeVersionOrderingAndDistributableMetadata(@TempDir Path tempDirectory)\\n            throws Exception {\\n        WebDescriptor webDescriptor = parseWebDescriptor(tempDirectory.resolve(\\\"web.xml\\\"), WEB_XML);\\n\\n        assertThat(webDescriptor.getMajorVersion()).isEqualTo(6);\\n        assertThat(webDescriptor.getMinorVersion()).isEqualTo(0);\\n        assertThat(webDescriptor.getMetaDataComplete()).isEqualTo(MetaData.Complete.True);\\n        assertThat(webDescriptor.isDistributable()).isTrue();\\n        assertThat(webDescriptor.isOrdered()).isTrue();\\n        assertThat(webDescriptor.getOrdering()).containsExactly(\\\"alpha-fragment\\\", AbsoluteOrdering.OTHER);\\n        assertThat(webDescriptor.getRoot().getTag()).isEqualTo(\\\"web-app\\\");\\n\\n        FragmentDescriptor fragmentDescriptor = parseFragmentDescriptor(\\n                tempDirectory.resolve(\\\"fragment.xml\\\"),\\n                \\\"beta-fragment\\\",\\n                \\\"alpha-fragment\\\",\\n                true);\\n\\n        assertThat(fragmentDescriptor.getName()).isEqualTo(\\\"beta-fragment\\\");\\n        assertThat(fragmentDescriptor.getMajorVersion()).isEqualTo(6);\\n        assertThat(fragmentDescriptor.getMinorVersion()).isEqualTo(0);\\n        assertThat(fragmentDescriptor.getAfters()).containsExactly(\\\"alpha-fragment\\\");\\n        assertThat(fragmentDescriptor.getBefores()).isEmpty();\\n        assertThat(fragmentDescriptor.getOtherType()).isEqualTo(FragmentDescriptor.OtherType.Before);\\n        assertThat(fragmentDescriptor.getOrdering()).contains(\\\"alpha-fragment\\\", AbsoluteOrdering.OTHER);\\n    }\\n\\n    @Test\\n    void metadataTracksDescriptorOriginsOverridesResourcesAndAbsoluteFragmentOrdering(@TempDir Path tempDirectory)\\n            throws Exception {\\n        Resource alphaJar = createEmptyResource(tempDirectory.resolve(\\\"alpha.jar\\\"));\\n        Resource betaJar = createEmptyResource(tempDirectory.resolve(\\\"beta.jar\\\"));\\n        Resource otherJar = createEmptyResource(tempDirectory.resolve(\\\"other.jar\\\"));\\n        FragmentDescriptor alphaDescriptor = parseFragmentDescriptor(\\n                tempDirectory.resolve(\\\"alpha-fragment.xml\\\"),\\n                \\\"alpha-fragment\\\",\\n                null,\\n                false);\\n        FragmentDescriptor betaDescriptor = parseFragmentDescriptor(\\n                tempDirectory.resolve(\\\"beta-fragment.xml\\\"),\\n                \\\"beta-fragment\\\",\\n                \\\"alpha-fragment\\\",\\n                false);\\n        WebDescriptor webDescriptor = parseWebDescriptor(tempDirectory.resolve(\\\"web.xml\\\"), WEB_XML);\\n        OverrideDescriptor overrideDescriptor = new OverrideDescriptor(writeResource(\\n                tempDirectory.resolve(\\\"override.xml\\\"),\\n                minimalWebXml(\\\"Override Descriptor\\\")));\\n        overrideDescriptor.parse(WebDescriptor.getParser(false));\\n\\n        MetaData metaData = new MetaData();\\n        metaData.setWebDescriptor(webDescriptor);\\n        metaData.addOverrideDescriptor(overrideDescriptor);\\n        metaData.addFragmentDescriptor(alphaJar, alphaDescriptor);\\n        metaData.addFragmentDescriptor(betaJar, betaDescriptor);\\n        metaData.addWebInfResource(alphaJar);\\n        metaData.addContainerResource(otherJar);\\n        metaData.setOrigin(\\\"tracked-from-web-xml\\\", webDescriptor);\\n        metaData.setOriginAPI(\\\"tracked-from-api\\\");\\n\\n        AbsoluteOrdering ordering = new AbsoluteOrdering(metaData);\\n        ordering.add(\\\"beta-fragment\\\");\\n        ordering.addOthers();\\n        metaData.setOrdering(ordering);\\n\\n        assertThat(metaData.getWebDescriptor()).isSameAs(webDescriptor);\\n        assertThat(metaData.getOverrideDescriptors()).containsExactly(overrideDescriptor);\\n        assertThat(metaData.getFragmentDescriptor(\\\"alpha-fragment\\\")).isSameAs(alphaDescriptor);\\n        assertThat(metaData.getFragmentDescriptorForJar(betaJar)).isSameAs(betaDescriptor);\\n        assertThat(metaData.getJarForFragmentName(\\\"beta-fragment\\\")).isSameAs(betaJar);\\n        assertThat(metaData.getWebInfResources(false)).containsExactly(alphaJar);\\n        assertThat(metaData.getContainerResources()).containsExactly(otherJar);\\n        assertThat(metaData.getOrigin(\\\"tracked-from-web-xml\\\")).isEqualTo(Origin.WebXml);\\n        assertThat(metaData.getOriginDescriptor(\\\"tracked-from-web-xml\\\")).isSameAs(webDescriptor);\\n        assertThat(metaData.getOrigin(\\\"tracked-from-api\\\")).isEqualTo(Origin.API);\\n        assertThat(metaData.getOrigins()).containsKeys(\\\"tracked-from-web-xml\\\", \\\"tracked-from-api\\\");\\n        assertThat(metaData.getOrdering().order(List.of(alphaJar, betaJar, otherJar)))\\n                .containsExactly(betaJar, alphaJar, otherJar);\\n    }\\n\\n    @Test\\n    void configurationCollectionSortsAndInvokesLifecycleCallbacksInDependencyOrder() throws Exception {\\n        List<String> events = new ArrayList<>();\\n        WebAppContext context = new WebAppContext();\\n        Configurations configurations = new Configurations();\\n        FirstConfiguration first = new FirstConfiguration(events);\\n        SecondConfiguration second = new SecondConfiguration(events);\\n\\n        configurations.add(second, first);\\n        configurations.sort();\\n\\n        assertThat(configurations.toStringArray())\\n                .containsExactly(FirstConfiguration.class.getName(), SecondConfiguration.class.getName());\\n        assertThat(configurations.get(FirstConfiguration.class)).isSameAs(first);\\n        assertThat(configurations.getConfigurations(RecordingConfiguration.class)).containsExactly(first, second);\\n\\n        configurations.preConfigure(context);\\n        assertThat(configurations.configure(context)).isTrue();\\n        configurations.postConfigure(context);\\n\\n        assertThat(events).containsExactly(\\n                \\\"pre:first\\\",\\n                \\\"pre:second\\\",\\n                \\\"configure:first\\\",\\n                \\\"configure:second\\\",\\n                \\\"post:first\\\",\\n                \\\"post:second\\\");\\n        assertThat(first.getProtectedClasses().match(\\\"com.example.protected.Component\\\")).isTrue();\\n        assertThat(first.getHiddenClasses().match(\\\"com.example.hidden.Component\\\")).isTrue();\\n\\n        configurations.remove(FirstConfiguration.class);\\n        assertThat(configurations.toStringArray()).containsExactly(SecondConfiguration.class.getName());\\n    }\\n\\n    @Test\\n    void webAppContextClassMatchersResourceAliasesAndDescriptorSettingsAreMutable(@TempDir Path webRoot)\\n            throws Exception {\\n        Path staticDirectory = Files.createDirectories(webRoot.resolve(\\\"static\\\"));\\n        Files.writeString(staticDirectory.resolve(\\\"asset.txt\\\"), \\\"asset\\\", StandardCharsets.UTF_8);\\n\\n        WebAppContext context = new WebAppContext();\\n        context.setContextPath(\\\"/custom\\\");\\n        context.setBaseResourceAsPath(webRoot);\\n        context.setDefaultsDescriptor(\\\"classpath:/org/eclipse/jetty/ee10/webapp/webdefault-ee10.xml\\\");\\n        context.setOverrideDescriptor(\\\"/WEB-INF/override.xml\\\");\\n        context.addOverrideDescriptor(\\\"/WEB-INF/second-override.xml\\\");\\n        context.setDistributable(true);\\n        context.setExtractWAR(false);\\n        context.setCopyWebDir(true);\\n        context.setCopyWebInf(true);\\n        context.setParentLoaderPriority(true);\\n        context.setLogUrlOnStart(true);\\n        context.setAllowDuplicateFragmentNames(true);\\n        context.setResourceAlias(\\\"/asset-alias.txt\\\", \\\"/static/asset.txt\\\");\\n        context.setSystemClassMatcher(new ClassMatcher(\\\"com.acme.api.\\\", \\\"-com.acme.api.internal.\\\"));\\n        context.setServerClassMatcher(new ClassMatcher(\\\"com.acme.server.\\\"));\\n        context.addSystemClassMatcher(new ClassMatcher(\\\"com.acme.shared.\\\"));\\n        context.addServerClassMatcher(new ClassMatcher(\\\"com.acme.hidden.\\\"));\\n\\n        assertThat(context.getContextPath()).isEqualTo(\\\"/custom\\\");\\n        assertThat(context.getDefaultsDescriptor()).isEqualTo(\\\"classpath:/org/eclipse/jetty/ee10/webapp/webdefault-ee10.xml\\\");\\n        assertThat(context.getOverrideDescriptor()).isEqualTo(\\\"/WEB-INF/override.xml\\\");\\n        assertThat(context.getOverrideDescriptors()).contains(\\\"/WEB-INF/override.xml\\\", \\\"/WEB-INF/second-override.xml\\\");\\n        assertThat(context.isDistributable()).isTrue();\\n        assertThat(context.isExtractWAR()).isFalse();\\n        assertThat(context.isCopyWebDir()).isTrue();\\n        assertThat(context.isCopyWebInf()).isTrue();\\n        assertThat(context.isParentLoaderPriority()).isTrue();\\n        assertThat(context.isLogUrlOnStart()).isTrue();\\n        assertThat(context.isAllowDuplicateFragmentNames()).isTrue();\\n        assertThat(context.getResourceAliases()).containsEntry(\\\"/asset-alias.txt\\\", \\\"/static/asset.txt\\\");\\n        assertThat(readResource(context.getResource(\\\"/asset-alias.txt\\\"))).isEqualTo(\\\"asset\\\");\\n        assertThat(context.removeResourceAlias(\\\"/asset-alias.txt\\\")).isEqualTo(\\\"/static/asset.txt\\\");\\n        assertThat(context.getResourceAlias(\\\"/asset-alias.txt\\\")).isNull();\\n        assertThat(context.getSystemClassMatcher().match(\\\"com.acme.api.PublicType\\\")).isTrue();\\n        assertThat(context.getSystemClassMatcher().match(\\\"com.acme.api.internal.SecretType\\\")).isFalse();\\n        assertThat(context.getSystemClassMatcher().match(\\\"com.acme.shared.Model\\\")).isTrue();\\n        assertThat(context.getServerClassMatcher().match(\\\"com.acme.server.ContainerType\\\")).isTrue();\\n        assertThat(context.getServerClassMatcher().match(\\\"com.acme.hidden.ContainerType\\\")).isTrue();\\n        assertThat(context.isSystemClass(String.class)).isFalse();\\n    }\\n\\n    private static WebDescriptor parseWebDescriptor(Path path, String xml) throws Exception {\\n        WebDescriptor descriptor = new WebDescriptor(writeResource(path, xml));\\n        descriptor.parse(WebDescriptor.getParser(false));\\n        return descriptor;\\n    }\\n\\n    private static FragmentDescriptor parseFragmentDescriptor(\\n            Path path,\\n            String name,\\n            String afterName,\\n            boolean beforeOthers) throws Exception {\\n        FragmentDescriptor descriptor = new FragmentDescriptor(writeResource(path, webFragmentXml(name, afterName, beforeOthers)));\\n        descriptor.parse(WebDescriptor.getParser(false));\\n        return descriptor;\\n    }\\n\\n    private static Resource createEmptyResource(Path path) throws IOException {\\n        Files.writeString(path, \\\"\\\", StandardCharsets.UTF_8);\\n        