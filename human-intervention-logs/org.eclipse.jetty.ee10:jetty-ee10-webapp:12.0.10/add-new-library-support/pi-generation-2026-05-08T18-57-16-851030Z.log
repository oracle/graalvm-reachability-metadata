"com.example.protected.Component\")).isTrue();\n        assertThat(first.getHiddenClasses().match(\"com.example.hidden.Component\")).isTrue();\n\n        configurations.remove(first);\n        assertThat(configurations.toStringArray()).containsExactly(SecondConfiguration.class.getName());\n    }\n\n    @Test\n    void webAppContextClassMatchersResourceAliasesAndDescriptorSettingsAreMutable() throws Exception {\n        Path webRoot = createTestDirectory(\"webapp-settings\");\n        try {\n            Path staticDirectory = Files.createDirectories(webRoot.resolve(\"static\"));\n            Files.writeString(staticDirectory.resolve(\"asset.txt\"), \"asset\", StandardCharsets.UTF_8);\n\n            WebAppContext context = new WebAppContext();\n            context.setContextPath(\"/custom\");\n            context.setBaseResourceAsPath(webRoot);\n            context.setDefaultsDescriptor(\"classpath:/org/eclipse/jetty/ee10/webapp/webdefault-ee10.xml\");\n            context.setOverrideDescriptor(\"/WEB-INF/override.xml\");\n            context.addOverrideDescriptor(\"/WEB-INF/second-override.xml\");\n            context.setDistributable(true);\n            context.setExtractWAR(false);\n            context.setCopyWebDir(true);\n            context.setCopyWebInf(true);\n            context.setParentLoaderPriority(true);\n            context.setLogUrlOnStart(true);\n            context.setAllowDuplicateFragmentNames(true);\n            context.setResourceAlias(\"/asset-alias.txt\", \"/static/asset.txt\");\n            context.setProtectedClassMatcher(new ClassMatcher(\"com.acme.api.\", \"-com.acme.api.internal.\"));\n            context.setHiddenClassMatcher(new ClassMatcher(\"com.acme.server.\"));\n            context.addProtectedClassMatcher(new ClassMatcher(\"com.acme.shared.\"));\n            context.addHiddenClassMatcher(new ClassMatcher(\"com.acme.hidden.\"));\n\n            assertThat(context.getContextPath()).isEqualTo(\"/custom\");\n            assertThat(context.getDefaultsDescriptor())\n                    .isEqualTo(\"classpath:/org/eclipse/jetty/ee10/webapp/webdefault-ee10.xml\");\n            assertThat(context.getOverrideDescriptor()).isEqualTo(\"/WEB-INF/override.xml\");\n            assertThat(context.getOverrideDescriptors()).contains(\"/WEB-INF/override.xml\", \"/WEB-INF/second-override.xml\");\n            assertThat(context.isDistributable()).isTrue();\n            assertThat(context.isExtractWAR()).isFalse();\n            assertThat(context.isCopyWebDir()).isTrue();\n            assertThat(context.isCopyWebInf()).isTrue();\n            assertThat(context.isParentLoaderPriority()).isTrue();\n            assertThat(context.isLogUrlOnStart()).isTrue();\n            assertThat(context.isAllowDuplicateFragmentNames()).isTrue();\n            assertThat(context.getResourceAliases()).containsEntry(\"/asset-alias.txt\", \"/static/asset.txt\");\n            assertThat(readResource(context.getResource(\"/asset-alias.txt\"))).isEqualTo(\"asset\");\n            assertThat(context.removeResourceAlias(\"/asset-alias.txt\")).isEqualTo(\"/static/asset.txt\");\n            assertThat(context.getResourceAlias(\"/asset-alias.txt\")).isNull();\n            assertThat(context.getProtectedClassMatcher().match(\"com.acme.api.PublicType\")).isTrue();\n            assertThat(context.getProtectedClassMatcher().match(\"com.acme.api.internal.SecretType\")).isFalse();\n            assertThat(context.getProtectedClassMatcher().match(\"com.acme.shared.Model\")).isTrue();\n            assertThat(context.getHiddenClassMatcher().match(\"com.acme.server.ContainerType\")).isTrue();\n            assertThat(context.getHiddenClassMatcher().match(\"com.acme.hidden.ContainerType\")).isTrue();\n        } finally {\n            deleteRecursively(webRoot);\n        }\n    }\n\n    private static WebDescriptor parseWebDescriptor(Path path, String xml) throws Exception {\n        WebDescriptor descriptor = new WebDescriptor(writeResource(path, xml));\n        descriptor.parse(WebDescriptor.getParser(false));\n        return descriptor;\n    }\n\n    private static FragmentDescriptor parseFragmentDescriptor(\n            Path path,\n            String name,\n            String afterName,\n            boolean beforeOthers) throws Exception {\n        FragmentDescriptor descriptor = new FragmentDescriptor(\n                writeResource(path, webFragmentXml(name, afterName, beforeOthers)));\n        descriptor.parse(WebDescriptor.getParser(false));\n        return descriptor;\n    }\n\n    private static Resource createEmptyResource(Path path) throws IOException {\n        Files.writeString(path, \"\", StandardCharsets.UTF_8);\n        return ResourceFactory.root().newResource(path);\n    }\n\n    private static Resource writeResource(Path path, String content) throws IOException {\n        Files.writeString(path, content, StandardCharsets.UTF_8);\n        return ResourceFactory.root().newResource(path);\n    }\n\n    private static String readResource(Resource resource) throws IOException {\n        try (InputStream inputStream = resource.newInputStream()) {\n            return new String(inputStream.readAllBytes(), StandardCharsets.UTF_8);\n        }\n    }\n\n    private static Path createTestDirectory(String name) throws IOException {\n        Path directory = Path.of(\"build\", \"tmp\", \"jetty-ee10-webapp-tests\", name + \"-\" + System.nanoTime());\n        return Files.createDirectories(directory);\n    }\n\n    private static void deleteRecursively(Path directory) throws IOException {\n        if (!Files.exists(directory)) {\n            return;\n        }\n        try (Stream<Path> paths = Files.walk(directory)) {\n            for (Path path : paths.sorted(Comparator.reverseOrder()).toList()) {\n                Files.deleteIfExists(path);\n            }\n        }\n    }\n\n    private static String minimalWebXml(String displayName) {\n        return \"\"\"\n                <?xml version=\"1.0\" encoding=\"UTF-8\"?>\n                <web-app xmlns=\"https://jakarta.ee/xml/ns/jakartaee\" version=\"6.0\">\n                  <display-name>%s</display-name>\n                </web-app>\n                \"\"\".formatted(displayName);\n    }\n\n    private static String webFragmentXml(String name, String afterName, boolean beforeOthers) {\n        String after = afterName == null ? \"\" : \"\"\"\n                    <after>\n                      <name>%s</name>\n                    </after>\n                \"\"\".formatted(afterName);\n        String before = beforeOthers ? \"\"\"\n                    <before>\n                      <others/>\n                    </before>\n                \"\"\" : \"\";\n        String ordering = after.isEmpty() && before.isEmpty() ? \"\" : \"\"\"\n                  <ordering>\n                %s%s  </ordering>\n                \"\"\".formatted(after, before);\n        return \"\"\"\n                <?xml version=\"1.0\" encoding=\"UTF-8\"?>\n                <web-fragment xmlns=\"https://jakarta.ee/xml/ns/jakartaee\" version=\"6.0\">\n                  <name>%s</name>\n                %s</web-fragment>\n                \"\"\".formatted(name, ordering);\n    }\n\n    public static final class GreetingServlet extends HttpServlet {\n        @Override\n        protected void doGet(HttpServletRequest request, HttpServletResponse response) throws IOException {\n            response.setStatus(HttpServletResponse.SC_OK);\n            response.setContentType(\"text/plain;charset=UTF-8\");\n            response.getWriter().printf(\n                    \"context=%s, resource=%s\",\n                    request.getContextPath(),\n                    getServletContext().getResource(\"/static/message.txt\") != null);\n        }\n    }\n\n    private abstract static class RecordingConfiguration extends AbstractConfiguration {\n        private final List<String> events;\n        private final String name;\n\n        private RecordingConfiguration(AbstractConfiguration.Builder builder, List<String> events, String name) {\n            super(builder);\n            this.events = events;\n            this.name = name;\n        }\n\n        @Override\n        public void preConfigure(WebAppContext context) {\n            events.add(\"pre:\" + name);\n        }\n\n        @Override\n        public void configure(WebAppContext context) {\n            events.add(\"configure:\" + name);\n        }\n\n        @Override\n        public void postConfigure(WebAppContext context) {\n            events.add(\"post:\" + name);\n        }\n    }\n\n    private static final class FirstConfiguration extends RecordingConfiguration {\n        private FirstConfiguration(List<String> events) {\n            super(new AbstractConfiguration.Builder()\n                    .enabledByDefault(true)\n                    .protect(\"com.example.protected.\")\n                    .hide(\"com.example.hidden.\"), events, \"first\");\n        }\n    }\n\n    private static final class SecondConfiguration extends RecordingConfiguration {\n        private SecondConfiguration(List<String> events) {\n            super(new AbstractConfiguration.Builder()\n                    .addDependencies(FirstConfiguration.class), events, \"second\");\n        }\n    }\n}\n"}
