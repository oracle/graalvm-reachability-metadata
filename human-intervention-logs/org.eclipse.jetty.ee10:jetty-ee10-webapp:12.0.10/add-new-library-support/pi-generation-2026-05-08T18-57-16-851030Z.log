sAndDescriptorSettingsAreMutable() throws Exception {\n        Path webRoot = createTestDirectory(\"webapp-settings\");\n        try {\n            Path staticDirectory = Files.createDirectories(webRoot.resolve(\"static\"));\n            Files.writeString(staticDirectory.resolve(\"asset.txt\"), \"asset\", StandardCharsets.UTF_8);\n\n            WebAppContext context = new WebAppContext();\n"}, {"oldText": "        context.setResourceAlias(\"/asset-alias.txt\", \"/static/asset.txt\");\n        context.setSystemClassMatcher(new ClassMatcher(\"com.acme.api.\", \"-com.acme.api.internal.\"));\n        context.setServerClassMatcher(new ClassMatcher(\"com.acme.server.\"));\n        context.addSystemClassMatcher(new ClassMatcher(\"com.acme.shared.\"));\n        context.addServerClassMatcher(new ClassMatcher(\"com.acme.hidden.\"));\n", "newText": "        context.setResourceAlias(\"/asset-alias.txt\", \"/static/asset.txt\");\n        context.setProtectedClassMatcher(new ClassMatcher(\"com.acme.api.\", \"-com.acme.api.internal.\"));\n        context.setHiddenClassMatcher(new ClassMatcher(\"com.acme.server.\"));\n        context.addProtectedClassMatcher(new ClassMatcher(\"com.acme.shared.\"));\n        context.addHiddenClassMatcher(new ClassMatcher(\"com.acme.hidden.\"));\n"}, {"oldText": "        assertThat(context.getResourceAlias(\"/asset-alias.txt\")).isNull();\n        assertThat(context.getSystemClassMatcher().match(\"com.acme.api.PublicType\")).isTrue();\n        assertThat(context.getSystemClassMatcher().match(\"com.acme.api.internal.SecretType\")).isFalse();\n        assertThat(context.getSystemClassMatcher().match(\"com.acme.shared.Model\")).isTrue();\n        assertThat(context.getServerClassMatcher().match(\"com.acme.server.ContainerType\")).isTrue();\n        assertThat(context.getServerClassMatcher().match(\"com.acme.hidden.ContainerType\")).isTrue();\n    }\n", "newText": "            assertThat(context.getResourceAlias(\"/asset-alias.txt\")).isNull();\n            assertThat(context.getProtectedClassMatcher().match(\"com.acme.api.PublicType\")).isTrue();\n            assertThat(context.getProtectedClassMatcher().match(\"com.acme.api.internal.SecretType\")).isFalse();\n            assertThat(context.getProtectedClassMatcher().match(\"com.acme.shared.Model\")).isTrue();\n            assertThat(context.getHiddenClassMatcher().match(\"com.acme.server.ContainerType\")).isTrue();\n            assertThat(context.getHiddenClassMatcher().match(\"com.acme.hidden.ContainerType\")).isTrue();\n        } finally {\n            deleteRecursively(webRoot);\n        }\n    }\n"}]}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 4199, "output": 2661, "cacheRead": 55808, "cacheWrite": 0, "totalTokens": 62668, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778266652620, "responseId": "resp_0df91dfc7677ce0d0169fe321eb9788193a33250e1f7c7db2a"}}
