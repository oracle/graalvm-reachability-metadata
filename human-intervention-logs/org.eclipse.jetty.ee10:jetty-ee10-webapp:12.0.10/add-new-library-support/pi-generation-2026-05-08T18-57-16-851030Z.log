          assertThat(fragmentDescriptor.getBefores()).isEmpty();
          assertThat(fragmentDescriptor.getOtherType()).isEqualTo(FragmentDescriptor.OtherType.Before);
          assertThat(fragmentDescriptor.getOrdering()).contains("alpha-fragment", AbsoluteOrdering.OTHER);
      }
  
