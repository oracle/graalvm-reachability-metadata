.util.stream.Stream;\n\nimport jakarta.servlet.http.HttpServlet;\nimport jakarta.servlet.http.HttpServletRequest;\nimport jakarta.servlet.http.HttpServletResponse;\n\nimport org.eclipse.jetty.ee10.webapp.AbstractConfiguration;\nimport org.eclipse.jetty.ee10.webapp.AbsoluteOrdering;\nimport org.eclipse.jetty.ee10.webapp.Configurations;\n", "newText": "import java.util.stream.Stream;\n\nimport jakarta.servlet.http.HttpServlet;\nimport jakarta.servlet.http.HttpServletRequest;\nimport jakarta.servlet.http.HttpServletResponse;\n\nimport org.eclipse.jetty.ee10.webapp.AbstractConfiguration;\nimport org.eclipse.jetty.ee10.webapp.AbsoluteOrdering;\nimport org.eclipse.jetty.ee10.webapp.Configuration;\nimport org.eclipse.jetty.ee10.webapp.Configurations;\n"}, {"oldText": "import org.eclipse.jetty.server.LocalConnector;\nimport org.eclipse.jetty.server.Server;\nimport org.eclipse.jetty.util.ClassMatcher;\n", "newText": "import org.eclipse.jetty.util.ClassMatcher;\n"}, {"oldText": "            context.setConfigurationDiscovered(false);\n            context.setThrowUnavailableOnStartupException(true);\n            context.setConfigurations(new Configurations(new WebInfConfiguration(), new WebXmlConfiguration()));\n            context.setResourceAlias(\"/aliased.txt\", \"/static/message.txt\");\n            context.addServlet(GreetingServlet.class, \"/hello\");\n\n            assertThat(readResource(context.getResource(\"/aliased.txt\"))).isEqualTo(\"resource from web root\");\n            assertThat(context.getResourceAlias(\"/aliased.txt\")).isEqualTo(\"/static/message.txt\");\n\n            Server server = new Server();\n            server.setTempDirectory(Files.createDirectories(webRoot.resolve(\"server-tmp\")).toFile());\n            server.setStopTimeout(5_000);\n            LocalConnector connector = new LocalConnector(server);\n            server.addConnector(connector);\n            server.setHandler(context);\n\n            try {\n                server.start();\n       