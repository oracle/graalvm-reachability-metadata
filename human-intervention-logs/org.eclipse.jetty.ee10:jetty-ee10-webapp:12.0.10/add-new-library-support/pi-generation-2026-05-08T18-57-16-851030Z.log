  +                     xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd"
  +                     version="6.0"
  +                     metadata-complete="true">
  +              <display-name>Jetty Test Application</display-name>
  +              <distributable/>
  +              <absolute-ordering>
  +                <name>alpha-fragment</name>
  +                <others/>
  +              </absolute-ordering>
  +            </web-app>
  +            """;
  +
  +    @Test
  +    void webAppContextStartsWithParsedDescriptorAndProgrammaticServlet(@TempDir Path webRoot) throws Exception {
  +        Path webInf = Files.createDirectories(webRoot.resolve("WEB-INF"));
  +        Path staticDirectory = Files.createDirectories(webRoot.resolve("static"));
  +        Files.writeString(webInf.resolve("web.xml"), WEB_XML, StandardCharsets.UTF_8);
  +        Files.writeString(staticDirectory.resolve("message.txt"), "resource from web root", StandardCharsets.UTF_8);
  +
  +        WebAppContext context = new WebAppContext();
  +        context.setContextPath("/app");
  +        context.setBaseResourceAsPath(webRoot);
  +        context.setConfigurationDiscovered(false);
  +        context.setThrowUnavailableOnStartupException(true);
  +        context.setConfigurations(new Configurations(new WebInfConfiguration(), new WebXmlConfiguration()));
  +        context.setResourceAlias("/aliased.txt", "/static/message.txt");
  +        context.addServlet(GreetingServlet.class, "/hello");
  +
  +        assertThat(readResource(context.getResource("/aliased.txt"))).isEqualTo("resource from web root");
  +        assertThat(context.getResourceAlias("/aliased.txt")).isEqualTo("/static/message.txt");
  +
  +        Server server = new Server();
  +        server.setStopTimeout(5_000);
  +        LocalConnector connector = new LocalConnector(server);
  +        server.addConnector(connector);
  +        server.setHandler(context);
  +
  +        try {
  +            try {
  +                server.start();
  +                String response = connector.getResponse(
  +                        "GET /app/hello HTTP/1.1\r\n"
  +                                + "Host: localhost\r\n"
  +                                + "Connection: close\r\n"
  +                                + "\r\n",
  +                        5,
  +                        TimeUnit.SECONDS);
  +
  +                assertThat(response).contains("HTTP/1.1 200 OK");
  +                assertThat(response).contains("context=/app, resource=true");
  +                assertThat(context.getDisplayName()).isEqualTo("Jetty Test Application");
  +                assertThat(context.getMetaData().getWebDescriptor()).isNotNull();
  +                assertThat(context.isDistributable()).isTrue();
  +            } catch (Error error) {
  +                if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
  +                    throw error;
  +                }
  +            }
  +        } finally {
  +            if (server.isStarted()) {
  +                server.stop();
  +            }
  +            server.destroy();
  +        }
  +    }
