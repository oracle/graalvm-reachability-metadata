"callSites\\\" : [ {\\n      \\\"covered\\\" : false,\\n      \\\"frame\\\" : \\\"com.google.common.io.Resources.getResource(Resources.java:162)\\\",\\n      \\\"line\\\" : 162,\\n      \\\"metadataType\\\" : \\\"resources\\\",\\n      \\\"trackedApi\\\" : \\\"java.lang.Class#getResource(java.lang.String)\\\"\\n    }, {\\n      \\\"covered\\\" : false,\\n      \\\"frame\\\" : \\\"com.google.common.io.Resources.getResource(Resources.java:150)\\\",\\n      \\\"line\\\" : 150,\\n      \\\"metadataType\\\" : \\\"resources\\\",\\n      \\\"trackedApi\\\" : \\\"java.lang.ClassLoader#getResource(java.lang.String)\\\"\\n    } ],\\n    \\\"className\\\" : \\\"com.google.common.io.Resources\\\",\\n    \\\"coveredCalls\\\" : 0,\\n    \\\"sourceFile\\\" : \\\"Resources.java\\\",\\n    \\\"totalCalls\\\" : 2\\n  }, {\\n    \\\"callSites\\\" : [ {\\n      \\\"covered\\\" : false,\\n      \\\"frame\\\" : \\\"com.google.common.util.concurrent.SimpleTimeLimiter.findInterruptibleMethods(SimpleTimeLimiter.java:146)\\\",\\n      \\\"line\\\" : 146,\\n      \\\"metadataType\\\" : \\\"reflection\\\",\\n      \\\"trackedApi\\\" : \\\"java.lang.Class#getMethods()\\\"\\n    }, {\\n      \\\"covered\\\" : false,\\n      \\\"frame\\\" : \\\"com.google.common.util.concurrent.SimpleTimeLimiter.newProxy(SimpleTimeLimiter.java:167)\\\",\\n      \\\"line\\\" : 167,\\n      \\\"metadataType\\\" : \\\"reflection\\\",\\n      \\\"trackedApi\\\" : \\\"java.lang.reflect.Proxy#newProxyInstance(java.lang.ClassLoader, java.lang.Class[], java.lang.reflect.InvocationHandler)\\\"\\n    } ],\\n    \\\"className\\\" : \\\"com.google.common.util.concurrent.SimpleTimeLimiter\\\",\\n    \\\"coveredCalls\\\" : 0,\\n    \\\"sourceFile\\\" : \\\"SimpleTimeLimiter.java\\\",\\n    \\\"totalCalls\\\" : 2\\n  }, {\\n    \\\"callSites\\\" : [ {\\n      \\\"covered\\\" : false,\\n      \\\"frame\\\" : \\\"com.google.common.util.concurrent.SimpleTimeLimiter$1$1.call(SimpleTimeLimiter.java:103)\\\",\\n      \\\"line\\\" : 1