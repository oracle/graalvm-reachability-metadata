          original.put("team", "ada");
          original.put("team", "grace");
          original.put("language", "java");
  
          assertThat(original.getClass().getName())
                  .isEqualTo("autovalue.shaded.com.google$.common.collect.$Multimaps$CustomListMultimap");
  
