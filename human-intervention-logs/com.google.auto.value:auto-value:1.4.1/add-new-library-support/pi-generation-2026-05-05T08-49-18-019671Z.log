  package com_google_auto_value.auto_value;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import com.google.auto.value.processor.escapevelocity.Template;
  import java.io.StringReader;
  import java.util.Collections;
  import java.util.HashMap;
  import java.util.List;
  import java.util.Map;
  import org.junit.jupiter.api.Test;
  
  public class ReferenceNodeTest {
      @Test
      void evaluatesMethodOnNonPublicCollectionImplementation() throws Exception {
          Template template = Template.parseFrom(new StringReader("$items.size()"));
          List<String> items = Collections.singletonList("value");
          Map<String, Object> vars = new HashMap<String, Object>();
          vars.put("items", items);
  
          String result = template.evaluate(vars);
  
          assertThat(result).isEqualTo("1");
      }
  }
