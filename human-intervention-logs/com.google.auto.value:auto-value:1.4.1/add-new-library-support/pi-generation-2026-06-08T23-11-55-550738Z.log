 a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_google_auto_value.auto_value;\n\nimport static org.junit.jupiter.api.Assertions.assertEquals;\nimport static org.junit.jupiter.api.Assertions.assertTrue;\n\nimport autovalue.shaded.com.google$.common.collect.$HashMultimap;\nimport autovalue.shaded.com.google$.common.collect.$HashMultiset;\nimport autovalue.shaded.com.google$.common.collect.$ImmutableSetMultimap;\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.IOException;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport org.junit.jupiter.api.Test;\n\npublic class AutovalueShadedComGoogleCommonCollectInnerSerializationTest {\n    @Test\n    public void hashMultisetRoundTripPreservesDistinctElementCounts() throws Exception {\n        $HashMultiset<String> multiset = $HashMultiset.create();\n        multiset.add(\"alpha\", 2);\n        multiset.add(\"beta\", 3);\n\n        @SuppressWarnings(\"unchecked\")\n        $HashMultiset<String> copy = ($HashMultiset<String>) roundTrip(multiset);\n\n        assertEquals(2, copy.count(\"alpha\"));\n        assertEquals(3, copy.count(\"beta\"));\n        assertEquals(multiset.size(), copy.size());\n    }\n\n    @Test\n    public void hashMultimapRoundTripPreservesKeysAndValues() throws Exception {\n        $HashMultimap<String, String> multimap = $HashMultimap.create();\n        multimap.put(\"letters\", \"a\");\n        multimap.put(\"letters\", \"b\");\n        multimap.put(\"digits\", \"1\");\n\n        @SuppressWarnings(\"unchecked\")\n        $HashMultimap<String, String> copy = ($HashMultimap<String, String>) roundTrip(multimap);\n\n        assertEquals(multimap, copy);\n        assertTrue(copy.get(\"letters\").contains(\"a\"));\n        assertTrue(copy.get(\"letters\").contains(\"b\"));\n        assertTrue(copy.get(\"digits\").contains(\"1\"));\n    }\n\n    @Test\n    public void immutableSetMultimapRoundTripRestoresFinalSerializedFields() throws Exception {\n        $ImmutableSetMultimap<String, String> multimap = $ImmutableSetMultimap.of(\n                \"letters\", \"a\",\n                \"letters\", \"b\",\n                \"digits\", \"1\");\n\n        @SuppressWarnings(\"unchecked\")\n        $ImmutableSetMultimap<String, String> copy =\n                ($ImmutableSetMultimap<String, String>) roundTrip(multimap);\n\n        assertEquals(multimap, copy);\n        assertEquals(3, copy.size());\n        assertTrue(copy.get(\"missing\").isEmpty());\n    }\n\n    private static Object roundTrip(Object value) throws IOException, ClassNotFoundException {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(value);\n        }\n        ByteArrayInputStream inputBytes = new ByteArrayInputStream(bytes.toByteArray());\n        try (ObjectInputStream input = new ObjectInputStream(inputBytes)) {\n            return input.readObject();\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1780960246948}, {"role": "toolResult", "toolCallId": "call_46YI55XcwS7fNm1sHfvEE4L9|fc_0d9ee2b928312e45016a274bf71f0081939c683b80e52b115a", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_google_auto_value.auto_value;\n\nimport static org.junit.jupiter.api.Assertions.assertEquals;\nimport static org.junit.jupiter.api.Assertions.assertIterableEquals;\nimport static org.junit.jupiter.api.Assertions.assertTrue;\n\nimport autovalue.shaded.com.google$.common.collect.$LinkedHashMultimap;\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.IOException;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.util.Arrays;\nimport org.junit.jupiter.api.Test;\n\npublic class AutovalueShadedComGoogleCommonCollectInnerLinkedHashMultimapTest {\n    @Test\n    public void linkedHashMultimapRoundTripPreservesKeysValuesAndIterationOrder()\n            throws Exception {\n        $LinkedHashMultimap<String, String> multimap = $LinkedHashMultimap.create();\n        multimap.put(\"letters\", \"a\");\n        multimap.put(\"digits\", \"1\");\n        multimap.put(\"letters\", \"b\");\n        multimap.put(\"symbols\", \"#\");\n\n        @SuppressWarnings(\"unchecked\")\n        $LinkedHashMultimap<String, String> copy =\n                ($LinkedHashMultimap<String, String>) roundTrip(multimap);\n\n        assertEquals(multimap, copy);\n        assertEquals(multimap.size(), copy.size());\n        assertIterableEquals(Arrays.asList(\"letters\", \"digits\", \"symbols\"), copy.keySet());\n        assertIterableEquals(Arrays.asList(\"a\", \"b\"), copy.get(\"letters\"));\n        assertTrue(copy.get(\"missing\").isEmpty());\n        assertIterableEquals(multimap.entries(), copy.entries());\n    }\n\n    private static Object roundTrip(Object value) throws IOException, ClassNotFoundException {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(value);\n        }\n        ByteArrayInputStream inputBytes = new ByteArrayInputStream(bytes.toByteArray());\n        try (ObjectInputStream input = new ObjectInputStream(inputBytes)) {\n            return input.readObject();\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1780960246948}, {"role": "toolResult", "toolCallId": "call_vneh0DSvOHVpclqwY4A5UXju|fc_0d9ee2b928312e45016a274bf71f0881938412b1b096457dda", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have recei