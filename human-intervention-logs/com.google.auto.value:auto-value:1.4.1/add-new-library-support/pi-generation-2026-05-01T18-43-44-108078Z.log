ndException {\n        byte[] serialized = serialize(value);\n        try (ObjectInputStream objectInputStream = new ObjectInputStream(new ByteArrayInputStream(serialized))) {\n            Object restored = objectInputStream.readObject();\n            assertThat(restored).isInstanceOf(expectedType);\n            return expectedType.cast(restored);\n        }\n    }\n\n    private static byte[] serialize(Serializable value) throws IOException {\n        ByteArrayOutputStream outputStream = new ByteArrayOutputStream();\n        try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(outputStream)) {\n            objectOutputStream.writeObject(value);\n        }\n        return outputStream.toByteArray();\n    }\n}\n"}], "isError": false, "timestamp": 1777660985045}, {"role": "toolResult", "toolCallId": "call_t4WqMW6Ao9xHdJRHGd5hjfH3|fc_0b637ce521dd40180169f4f438d24081a1a7606826ec513376", "toolName": "read", "content": [{"type": "text", "text": "{\n  \"classes\" : [ {\n    \"callSites\" : [ {\n      \"covered\" : false,\n      \"frame\" : \"autovalue.shaded.com.google$.common.collect.$ObjectArrays.newArray($ObjectArrays.java:50)\",\n      \"line\" : 50,\n      \"metadataType\" : \"reflection\",\n      \"trackedApi\" : \"java.lang.reflect.Array#newInstance(java.lang.Class, int)\"\n    } ],\n    \"className\" : \"autovalue.shaded.com.google$.common.collect.$ObjectArrays\",\n    \"coveredCalls\" : 0,\n    \"sourceFile\" : \"$ObjectArrays.java\",\n    \"totalCalls\" : 1\n  }, {\n    \"callSites\" : [ {\n      \"covered\" : false,\n      \"frame\" : \"autovalue.shaded.com.google$.common.io.$Closer$SuppressingSuppressor.suppress($Closer.java:286)\",\n      \"line\" : 286,\n      \"metadataType\" : \"reflection\",\n      \"trackedApi\" : \"java.lang.reflect.Method#invoke(java.lang.Object, java.lang.Object[])\"\n    } ],\n    \"className\" : \"autovalue.shaded.com.google$.common.io.$Closer$SuppressingSuppressor\",\n    \"coveredCalls\" : 0,\n    \"sourceFile\" : \"