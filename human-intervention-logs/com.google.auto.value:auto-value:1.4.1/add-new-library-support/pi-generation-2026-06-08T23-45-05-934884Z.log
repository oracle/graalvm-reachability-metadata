  import com.google.auto.value.processor.escapevelocity.Template;
  import java.io.StringReader;
  import java.util.Collections;
  import java.util.Map;
  import org.junit.jupiter.api.Test;
  
  public class ReferenceNodeTest {
      @Test
      public void evaluatesMethodReferencesOnPublicAndNonPublicLibraryTypes() throws Exception {
          Template nestedTemplate = Template.parseFrom(new StringReader("nested"));
          $ImmutableList<String> items = $ImmutableList.of("alpha");
          Map<String, Object> variables = $ImmutableMap.<String, Object>builder()
                  .put("template", nestedTemplate)
                  .put("vars", Collections.emptyMap())
                  .put("items", items)
                  .build();
  
          Template template = Template.parseFrom(new StringReader(
                  "$template.evaluate($vars) $items.size()"));
  
          assertEquals("nested 1", template.evaluate(variables));
      }
  }
