       return new AutoValue_Person(name, id);\n                  }\n\n                  abstract String name();\n                  abstract int id();\n                }\n                \"\"\"));\n\n        try (StandardJavaFileManager fileManager = compiler.getStandardFileManager(\n                diagnostics, Locale.ROOT, StandardCharsets.UTF_8);\n                BrokenTemplateClassLoader processorClassLoader = new BrokenTemplateClassLoader(\n                        new URL[] {\n                                codeSourceUrl(AutoValueProcessor.class),\n                                resourceRootUrl(AutoValueProcessor.class, \"autovalue.vm\")\n                        },\n                        TemplateVarsTest.class.getClassLoader())) {\n            Processor processor = ServiceLoader.load(Processor.class, processorClassLoader).stream()\n                    .map(ServiceLoader.Provider::get)\n                    .filter(provider -> provider.getClass().getName().equals(AUTO_VALUE_PROCESSOR_NAME))\n                    .findFirst()\n                    .orElseThrow(() -> new AssertionError(\"Expected AutoValueProcessor service provider\"));\n            JavaCompiler.CompilationTask task = compiler.getTask(\n                    null, fileManager, diagnostics, options, null, sourceFiles);\n            task.setProcessors(List.of(processor));\n            return new Compilation(Boolean.TRUE.equals(task.call()), diagnosticText(diagnostics));\n        }\n    }\n\n    private static URL codeSourceUrl(Class<?> type) {\n        CodeSource codeSource = type.getProtectionDomain().getCodeSource();\n\n        assertThat(codeSource).isNotNull();\n        return codeSource.getLocation();\n    }\n\n    private static URL resourceRootUrl(Class<?> type, String resourceName) throws IOException {\n        URL resource = type.getResource(resourceName);\n\n        assertThat(resource).isNotNull();\n        String externalForm = resource.toExternalForm();\n        if (externalForm.startsWith(\"jar:\")) {\n            String jarFileUrl = externalForm.substring(\"jar:\".length(), externalForm.indexOf('!'));\n            return URI.create(jarFileUrl).toURL();\n        }\n        return new URL(externalForm.substring(0, externalForm.length() - AUTOVALUE_TEMPLATE_RESOURCE.length()));\n    }\n\n    private static String diagnosticText(DiagnosticCollector<JavaFileObject> diagnostics) {\n        StringBuilder builder = new StringBuilder();\n        for (Diagnostic<? extends JavaFileObject> diagnostic : diagnostics.getDiagnostics()) {\n            builder.append(diagnostic).append(System.lineSeparator());\n        }\n        return builder.toString();\n    }\n\n    @AutoValue\n    abstract static class Person {\n        static Person create(String name, int id) {\n            return new AutoValue_TemplateVarsTest_Person(name, id);\n        }\n\n        abstract String name();\n\n        abstract int id();\n    }\n\n    private record Compilation(boolean successful, String diagnosticText) {\n    }\n\n    private static final class SourceFile extends SimpleJavaFileObject {\n        private final String source;\n\n        private SourceFile(String className, String source) {\n            super(\n                    URI.create(\"string:///\" + className.replace('.', '/') + JavaFileObject.Kind.SOURCE.extension),\n                    JavaFileObject.Kind.SOURCE);\n            this.source = source;\n        }\n\n        @Override\n        public CharSequence getCharContent(boolean ignoreEncodingErrors) {\n            return source;\n        }\n    }\n\n    private static final class BrokenTemplateClassLoader extends URLClassLoader {\n        private static final List<String> CHILD_FIRST_PACKAGE_PREFIXES = List.of(\n                \"autovalue.shaded.\",\n                \"com.google.auto.value.\");\n\n        private BrokenTemplateClassLoader(URL[] urls, ClassLoader parent) {\n            super(urls, parent);\n        }\n\n        @Override\n        public InputStream getResourceAsStream(String name) {\n            if (AUTOVALUE_TEMPLATE_RESOURCE.equals(name)) {\n                return new IOExceptionInputStream();\n            }\n            return super.getResourceAsStream(name);\n        }\n\n        @Override\n        public URL getResource(String name) {\n            if (AUTOVALUE_TEMPLATE_RESOURCE.equals(name)) {\n                URL resource = findResource(name);\n                if (resource != null) {\n                    return resource;\n                }\n            }\n            return super.getResource(name);\n        }\n\n        @Override\n        protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {\n            synchronized (getClassLoadingLock(name)) {\n                Class<?> alreadyLoaded = findLoadedClass(name);\n                if (alreadyLoaded != null) {\n                    return alreadyLoaded;\n                }\n                if (isChildFirstClass(name)) {\n                    try {\n                        Class<?> type = findClass(name);\n                        if (resolve) {\n                            resolveClass(type);\n                        }\n                        return type;\n                    } catch (ClassNotFoundException notFound) {\n                        // Delegate to the parent class loader below.\n                    }\n                }\n                return super.loadClass(name, resolve);\n            }\n        }\n\n        private static boolean isChildFirstClass(String name) {\n            for (String prefix : CHILD_FIRST_PACKAGE_PREFIXES) {\n                if (name.startsWith(prefix)) {\n                    return true;\n                }\n            }\n            return false;\n        }\n    }\n\n    private static final class IOExceptionInputStream extends InputStream {\n        @Override\n        public int read() throws IOException {\n            throw new IOException(\"Simulated closed template stream\");\n        }\n\n        @Override\n        public int read(byte[] buffer, int offset, int length) throws IOException {\n            throw new IOException(\"Simulated closed template stream\");\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1780962216495}]}
