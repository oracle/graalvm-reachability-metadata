? extends JavaFileObject> diagnostic : diagnostics.getDiagnostics()) {\n            result.append(System.lineSeparator())\n                    .append(diagnostic.getKind())\n                    .append(\": \")\n                    .append(diagnostic.getMessage(null));\n        }\n        return result.toString();\n    }\n\n    private static final class IntersectionEquivalenceProcessor extends AbstractProcessor {\n\n        private boolean comparedIntersectionTypes;\n        private boolean intersectionsEquivalent;\n        private String firstKind;\n        private String secondKind;\n\n        @Override\n        public Set<String> getSupportedAnnotationTypes() {\n            return Set.of(\"*\");\n        }\n\n        @Override\n        public SourceVersion getSupportedSourceVersion() {\n            return SourceVersion.latestSupported();\n        }\n\n        @Override\n        public boolean process(Set<? extends TypeElement> annotations, RoundEnvironment roundEnvironment) {\n            if (roundEnvironment.processingOver() || this.comparedIntersectionTypes) {\n                return false;\n            }\n\n            TypeMirror firstUpperBound = upperBoundOfFirstTypeParameter(\"sample.First\");\n            TypeMirror secondUpperBound = upperBoundOfFirstTypeParameter(\"sample.Second\");\n            this.firstKind = firstUpperBound.getKind().name();\n            this.secondKind = secondUpperBound.getKind().name();\n            $Equivalence<TypeMirror> equivalence = $MoreTypes.equivalence();\n            this.intersectionsEquivalent = equivalence.equivalent(firstUpperBound, secondUpperBound);\n            this.comparedIntersectionTypes = true;\n            return false;\n        }\n\n        private TypeMirror upperBoundOfFirstTypeParameter(String className) {\n            TypeElement typeElement = this.processingEnv.getElementUtils().getTypeElement(className);\n            assertThat(typeElement).as(className).isNotNull();\n            TypeParameterElement typeParameter = typeElement.getTypeParameters().get(0);\n            return ((TypeVariable) typeParameter.asType()).getUpperBound();\n        }\n\n        private boolean hasComparedIntersectionTypes() {\n            return this.comparedIntersectionTypes;\n        }\n\n        private boolean intersectionsAreEquivalent() {\n            return this.intersectionsEquivalent;\n        }\n\n        private String firstKind() {\n            return this.firstKind;\n        }\n\n        private String secondKind() {\n            return this.secondKind;\n        }\n    }\n\n    private static final class SourceFile extends SimpleJavaFileObject {\n\n        private final String content;\n\n        private SourceFile(String className, String content) {\n            super(URI.create(\"string:///\" + className.replace('.', '/') + Kind.SOURCE.extension), Kind.SOURCE);\n            this.content = content;\n        }\n\n        @Override\n        public CharSequence getCharContent(boolean ignoreEncodingErrors) {\n            return this.content;\n        }\n    }\n}\n"}
