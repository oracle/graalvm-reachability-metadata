[tool-call] delta {"path":"tests/src/com.google.auto.value/auto-value/1.4.1/src/test/java/com_google_auto_value/auto_value/AutovalueShadedComGoogleCommonCollectMapMakerInternalMapInnerAbstractSerializationProxyTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_google_auto_value.auto_value;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.IOException;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.util.concurrent.ConcurrentMap;\n\nimport autovalue.shaded.com.google$.common.collect.$MapMaker;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class AutovalueShadedComGoogleCommonCollectMapMakerInternalMapInnerAbstractSerializationProxyTest {\n    @Test\n    void weakKeyMapRoundTripsThroughSerializationProxyEntries() throws Exception {\n        ConcurrentMap<CompilerFeature, String> original = newWeakKeyMap();\n        original.put(CompilerFeature.PROCESSING, \"annotation processor\");\n        original.put(CompilerFeature.GENERATED_SOURCES, \"generated sources\");\n\n        ConcurrentMap<CompilerFeature, String> restored = roundTrip(original);\n\n        assertThat(restored).isNotSameAs(original);\n        assertThat(restored)\n                .containsEntry(CompilerFeature.PROCESSING, \"annotation processor\")\n                .containsEntry(CompilerFeature.GENERATED_SOURCES, \"generated sources\")\n                .hasSize(2);\n    }\n\n    private static <K, V> ConcurrentMap<K, V> newWeakKeyMap() {\n        $MapMaker mapMaker = new $MapMaker();\n        mapMaker.initialCapacity(4);\n        mapMaker.concurrencyLevel(1);\n        mapMaker.weakKeys();\n        return mapMaker.makeMap();\n    }\n\n    private static <K, V> ConcurrentMap<K, V> roundTrip(ConcurrentMap<K, V> value)\n            throws IOException, ClassNotFoundException {\n        Object restored = deserialize(serialize(value));\n        assertThat(restored).isInstanceOf(ConcurrentMap.class);\n        return (ConcurrentMap<K, V>) restored;\n    }\n\n    private static byte[] serialize(Object value) throws IOException {\n        ByteArrayOutputStream outputStream = new ByteArrayOutputStream();\n        try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(outputStream)) {\n            objectOutputStream.writeObject(value);\n        }\n        return outputStream.toByteArray();\n    }\n\n    private static Object deserialize(byte[] serialized) throws IOException, ClassNotFoundException {\n        try (ObjectInputStream objectInputStream = new ObjectInputStream(new ByteArrayInputStream(serialized))) {\n            return objectInputStream.readObject();\n        }\n    }\n\n    private enum CompilerFeature {\n        PROCESSING,\n        GENERATED_SOURCES\n    }\n}\n"}
