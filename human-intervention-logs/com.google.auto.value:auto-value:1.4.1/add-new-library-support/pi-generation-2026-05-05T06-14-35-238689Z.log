eakKeyMap() {\n        $MapMaker mapMaker = new $MapMaker();\n        mapMaker.initialCapacity(4);\n        mapMaker.concurrencyLevel(1);\n        mapMaker.weakKeys();\n        return mapMaker.makeMap();\n    }\n\n    private static <K, V> ConcurrentMap<K, V> roundTrip(ConcurrentMap<K, V> value)\n            throws IOException, ClassNotFoundException {\n        Object restored = deserialize(serialize(value));\n        assertThat(restored).isInstanceOf(ConcurrentMap.class);\n        return (ConcurrentMap<K, V>) restored;\n    }\n\n    private static byte[] serialize(Object value) throws IOException {\n        ByteArrayOutputStream outputStream = new ByteArrayOutputStream();\n        try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(outputStream)) {\n            objectOutputStream.writeObject(value);\n        }\n        return outputStream.toByteArray();\n    }\n\n    private static Object deserialize(byte[] serialized) throws IOException, ClassNotFoundException {\n        try (ObjectInputStream objectInputStream = new ObjectInputStream(new ByteArrayInputStream(serialized))) {\n            return objectInputStream.readObject();\n        }\n    }\n\n    private enum CompilerFeature {\n        PROCESSING,\n        GENERATED_SOURCES\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1577, "output": 1746, "cacheRead": 20992, "cacheWrite": 0, "totalTokens": 24315, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777961588137, "responseId": "resp_085ae166e34addb90169f98a749aac819689e08d3dc69523dc"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_n7i7bkA0jJcRBnT9cKmEzKY5|fc_085ae166e34addb90169f98a8255088196af12bd0696955d21", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2707 bytes to tests/src/com.google.auto.value/auto-value/1.4.1/src/test/java/com_google_auto_value/auto_value/AutovalueShaded