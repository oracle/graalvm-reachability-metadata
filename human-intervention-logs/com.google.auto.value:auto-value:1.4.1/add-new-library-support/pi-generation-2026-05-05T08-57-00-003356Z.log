  import java.lang.reflect.Method;
  import java.util.LinkedHashMap;
  import java.util.Map;
  import org.junit.jupiter.api.Test;
  
  public class AutovalueShadedComGoogleCommonCollectSerializationTest {
      @Test
      void serializesAndPopulatesMapEntries() throws Exception {
          Map<String, Serializable> original = new LinkedHashMap<>();
          original.put("first", "one");
          original.put("second", 2);
  
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {
              invokeSerializationMethod("writeMap", new Class<?>[] {Map.class, ObjectOutputStream.class}, original, output);
          }
  
          Map<String, Serializable> restored = new LinkedHashMap<>();
          try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(bytes.toByteArray()))) {
              invokeSerializationMethod("populateMap", new Class<?>[] {Map.class, ObjectInputStream.class}, restored, input);
          }
  
          assertThat(restored).containsExactlyEntriesOf(original);
      }
  
      @Test
      void serializesAndPopulatesMultisetEntries() throws Exception {
          $HashMultiset<String> multiset = $HashMultiset.create();
          multiset.add("apple", 2);
          multiset.add("pear", 3);
  
          $HashMultiset<String> restored = roundTrip(multiset);
  
          assertThat(restored.count("apple")).isEqualTo(2);
          assertThat(restored.count("pear")).isEqualTo(3);
          assertThat(restored.size()).isEqualTo(5);
      }
  
      @Test
      void serializesAndPopulatesMultimapEntries() throws Exception {
          $HashMultimap<String, String> multimap = $HashMultimap.create();
          multimap.put("letters", "a");
          multimap.put("letters", "b");
          multimap.put("digits", "1");
  
          $HashMultimap<String, String> restored = roundTrip(multimap);
  
          assertThat(restored.get("letters")).containsExactlyInAnyOrder("a", "b");
          assertThat(restored.get("digits")).containsExactly("1");
          assertThat(restored.size()).isEqualTo(3);
      }
  
      @Test
      void deserializesImmutableListMultimapWithFieldSetters() throws Exception {
          $ImmutableListMultimap<String, String> multimap = $ImmutableListMultimap.of(
                  "letters", "a",
                  "letters", "b",
                  "digits", "1");
  
          $ImmutableListMultimap<String, String> restored = roundTrip(multimap);
  
          assertThat(restored.get("letters")).containsExactly("a", "b");
          assertThat(restored.get("digits")).containsExactly("1");
          assertThat(restored.size()).isEqualTo(3);
      }
  
      private static Object invokeSerializationMethod(String methodName, Class<?>[] parameterTypes, Object... args)
              throws Exception {
          Class<?> serializationClass = Class.forName("autovalue.shaded.com.google$.common.collect.$Serialization");
