at(result.isSuccessful()).as(result.getDiagnostics()).isTrue();\n        Path generatedSource = result.getSourceOutput().resolve(\"sample/AutoValue_Person.java\");\n        assertThat(generatedSource).exists();\n        assertThat(Files.readString(generatedSource))\n                .contains(\"final class AutoValue_Person extends Person\")\n                .contains(\"private final String name\")\n                .contains(\"private final int age\");\n    }\n\n    @Test\n    void autoValueProcessingFallsBackToTemplateResourceUrlWhenResourceStreamFails() throws Exception {\n        try {\n            URL autoValueJar = autoValueJarUrl();\n            try (FailingTemplateResourceClassLoader loader = new FailingTemplateResourceClassLoader(autoValueJar)) {\n                Processor processor = loadAutoValueProcessor(loader);\n                CompilationResult result = compilePersonWithProcessor(processor);\n\n                assertThat(result.isSuccessful()).as(result.getDiagnostics()).isTrue();\n                assertThat(result.getDiagnostics()).contains(\"warning: Supported source version\");\n                assertThat(Files.readString(result.getSourceOutput().resolve(\"sample/AutoValue_Person.java\")))\n                        .contains(\"final class AutoValue_Person extends Person\");\n            }\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    private CompilationResult compilePersonWithProcessor(Processor processor) throws IOException {\n        JavaCompiler compiler = ToolProvider.getSystemJavaCompiler();\n        assertThat(compiler).as(\"A JDK compiler is required to run AutoValue annotation processing\").isNotNull();\n\n        Path classesDirectory = Files.createDirectories(this.temporaryDirectory.resolve(\"classes-\" + System.nanoTime()));\n        Path sourceOutput = Files.createDirectories(this.temporaryDirectory.resolve(\"generated-\" + System.nanoTime()));\n        DiagnosticCollector<JavaFileObject> diagnostics = new DiagnosticCollector<>();\n        StringWriter compilerOutput = new StringWriter();\n        try (StandardJavaFileManager fileManager = compiler.getStandardFileManager(diagnostics, null, null)) {\n            fileManager.setLocationFromPaths(StandardLocation.CLASS_OUTPUT, List.of(classesDirectory));\n            fileManager.setLocationFromPaths(StandardLocation.SOURCE_OUTPUT, List.of(sourceOutput));\n            JavaCompiler.CompilationTask task = compiler.getTask(compilerOutput, fileManager, diagnostics,\n                    List.of(\"-proc:only\", \"-source\", \"8\", \"-target\", \"8\", \"-classpath\", javaClassPath()), null,\n                    List.of(new SourceFile(\"sample.Person\", personSource())));\n            task.setProcessors(List.of(processor));\n            boolean successful = Boolean.TRUE.equals(task.call());\n            return new CompilationResult(successful, sourceOutput, formatDiagnostics(diagnostics, compilerOutput));\n        }\n    }\n\n    private static String javaClassPath() {\n        return System.getProperty(\"java.class.path\", \"\");\n    }\n\n    private static String personSource() {\n        return \"\"\"\n                package sample;\n\n                import com.google.auto.value.AutoValue;\n\n                @AutoValue\n                abstract class Person {\n                    abstract String name();\n\n                    abstract int age();\n                }\n                \"\"\";\n    }\n\n    private static String formatDiagnostics(DiagnosticCollector<JavaFileObject> diagnostics, StringWriter output) {\n        StringBuilder result = new StringBuilder(output.toString());\n        for (Diagnostic<? extends JavaFileObject> diagnostic : diagnostics.getDiagnostics()) {\n            result.append(System.lineSeparator())\n                    .append(diagnostic.getKind())\n                    .append(\": \")\n                 