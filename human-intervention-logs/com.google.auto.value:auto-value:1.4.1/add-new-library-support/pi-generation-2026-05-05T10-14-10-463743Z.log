port java.net.URLClassLoader;\nimport java.nio.file.Files;\nimport java.nio.file.Path;\nimport java.security.CodeSource;\nimport java.util.ArrayList;\nimport java.util.List;\nimport java.util.ServiceLoader;\nimport javax.annotation.processing.Processor;\nimport javax.tools.Diagnostic;\nimport javax.tools.DiagnosticCollector;\nimport javax.tools.JavaCompiler;\nimport javax.tools.JavaFileObject;\nimport javax.tools.SimpleJavaFileObject;\nimport javax.tools.StandardJavaFileManager;\nimport javax.tools.StandardLocation;\nimport javax.tools.ToolProvider;\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\nimport org.junit.jupiter.api.io.TempDir;\n\npublic class TemplateVarsTest {\n\n    private static final String AUTO_VALUE_PROCESSOR_NAME = \"com.google.auto.value.processor.AutoValueProcessor\";\n    private static final String TEMPLATE_RESOURCE = \"com/google/auto/value/processor/autovalue.vm\";\n\n    @TempDir\n    Path temporaryDirectory;\n\n    @Test\n    void autoValueProcessingExpandsTemplateVariables() throws Exception {\n        CompilationResult result = compilePersonWithProcessor(new AutoValueProcessor());\n\n        assertThat(result.isSuccessful()).as(result.getDiagnostics()).isTrue();\n        Path generatedSource = result.getSourceOutput().resolve(\"sample/AutoValue_Person.java\");\n        assertThat(generatedSource).exists();\n        assertThat(Files.readString(generatedSource))\n                .contains(\"final class AutoValue_Person extends Person\")\n                .contains(\"private final String name\")\n                .contains(\"private final int age\");\n    }\n\n    @Test\n    void autoValueProcessingFallsBackToTemplateResourceUrlWhenResourceStreamFails() throws Exception {\n        try {\n            URL autoValueJar = autoValueJarUrl();\n            try (FailingTemplateResourceClassLoader loader = new FailingTemplateResourceClassLoader(autoValueJar)) {\n                Processor processor = loadAutoValueProcessor(loader);\n                CompilationResult result = compilePersonWithProcessor(processor);\n\n                assertThat(result.isSuccessful()).as(result.getDiagnostics()).isTrue();\n                assertThat(Files.readString(result.getSourceOutput().resolve(\"sample/AutoValue_Person.java\")))\n                        .contains(\"final class AutoValue_Person extends Person\");\n            }\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    private CompilationResult compilePersonWithProcessor(Processor processor) throws IOException {\n        JavaCompiler compiler = ToolProvider.getSystemJavaCompiler();\n        assertThat(compiler).as(\"A JDK compiler is required to run AutoValue annotation processing\").isNotNull();\n\n        Path classesPath = this.temporaryDirectory.resolve(\"classes-\" + System.nanoTime());\n        Path generatedPath = this.temporaryDirectory.resolve(\"generated-\" + System.nanoTime());\n        Path classesDirectory = Files.createDirectories(classesPath);\n        Path sourceOutput = Files.createDirectories(generatedPath);\n        DiagnosticCollector<JavaFileObject> diagnostics = new DiagnosticCollector<>();\n        StringWriter compilerOutput = new StringWriter();\n        try (StandardJavaFileManager fileManager = compiler.getStandardFileManager(diagnostics, null, null)) {\n            fileManager.setLocationFromPaths(StandardLocation.CLASS_OUTPUT, List.of(classesDirectory));\n            fileManager.setLocationFromPaths(StandardLocation.SOURCE_OUTPUT, List.of(sourceOutput));\n            JavaCompiler.CompilationTask task = compiler.getTask(compilerOutput, fileManager, diagnostics,\n                    List.of(\"-proc:only\", \"-source\", \"8\", \"-target\", \"8\", \"-classpath\", javaClassPath()), null,\n                    List.of(new SourceFile(\"sample.Person\", personSource())));\n            task.setProcessors(List.of(processor));\n            boolean successful = Boolean.TRUE.equals(task.call());\n            return new CompilationResult(successful, sourceOutput, formatDiagnostics(diagnostics, compilerOutput));\n        }\n    }\n\n    private static String javaClassPath() {\n        return System.getProperty(\"java.class.path\", \"\");\n    }\n\n    private static String personSource() {\n        return \"\"\"\n                package sample;\n\n                import com.google.auto.value.AutoValue;\n\n                @AutoValue\n                abstract class Person {\n                    abstract String name();\n\n                    abstract int age();\n                }\n                \"\"\";\n    }\n\n    private static String formatDiagnostics(DiagnosticCollector<JavaFileObject> diagnostics, StringWriter output) {\n        StringBuilder result = new StringBuilder(output.toString());\n        for (Diagnostic<? extends JavaFileObject> diagnostic : diagnostics.getDiagnostics()) {\n            result.append(System.lineSeparator())\n                    .append(diagnostic.getKind())\n                    .append(\": \")\n                    .append(diagnostic.getMessage(null));\n        }\n        return result.toString();\n    }\n\n    private static URL autoValueJarUrl() throws IOException {\n        CodeSource codeSource = AutoValue.class.getProtectionDomain().getCodeSource();\n        if (codeSource != null && codeSource.getLocation() != null) {\n            URL location = codeSource.getLocation();\n            if (isJarFile(location)) {\n                return location;\n            }\n        }\n        for (String entry : javaClassPath().split(File.pathSeparator)) {\n            Path path = Path.of(entry);\n            Path fileName = path.getFileName();\n            if (fileName != null && fileName.toString().startsWith(\"auto-value-\")\n                    && fileName.toString().endsWith(\".jar\")) {\n                return path.toUri().toURL();\n            }\n        }\n        throw new AssertionError(\"Could not locate the AutoValue jar on the test class path\");\n    }\n\n    private static boolean isJarFile(URL location) {\n        if (!\"file\".equals(location.getProtocol())) {\n            return false;\n        }\n        try {\n            Path path = Path.of(location.toURI());\n            return Files.isRegularFile(path) && path.getFileName().toString().endsWith(\".jar\");\n        } catch (IllegalArgumentException | URISyntaxException exception) {\n            return false;\n        }\n    }\n\n    private static Processor loadAutoValueProcessor(ClassLoader loader) {\n        ServiceLoader<Processor> processors = ServiceLoader.load(Processor.class, loader);\n        for (Processor processor : processors) {\n            if (processor.getClass().getName().equals(AUTO_VALUE_PROCESSOR_NAME)) {\n                return processor;\n            }\n        }\n        throw new AssertionError(\"Could not load \" + AUTO_VALUE_PROCESSOR_NAME);\n    }\n\n    private static final class SourceFile extends SimpleJavaFileObject {\n\n        private final String content;\n\n        private SourceFile(String className, String content) {\n            super(URI.create(\"string:///\" + className.replace('.', '/') + Kind.SOURCE.extension), Kind.SOURCE);\n            this.content = content;\n        }\n\n        @Override\n        public CharSequence getCharContent(boolean ignoreEncodingErrors) {\n            return this.content;\n        }\n    }\n\n    private static final class FailingTemplateResourceClassLoader extends URLClassLoader {\n\n        private FailingTemplateResourceClassLoader(URL autoValueJar) {\n            super(new URL[] {autoValueJar}, TemplateVarsTest.class.getClassLoader());\n        }\n\n        @Override\n        public InputStream getResourceAsStream(String name) {\n            if (TEMPLATE_RESOURCE.equals(name)) {\n                return new InputStream() {\n                    @Override\n                    public int read() throws IOException {\n                        throw new IOException(\"Deliberately failing template resource stream\");\n                    }\n\n                    @Override\n                    public int read(byte[] bytes, int offset, int length) throws IOException {\n                        throw new IOException(\"Deliberately failing template resource stream\");\n                    }\n                };\n            }\n            return super.getResourceAsStream(name);\n        }\n\n        @Override\n        protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {\n            synchronized (getClassLoadingLock(name)) {\n                Class<?> loaded = findLoadedClass(name);\n                if (loaded == null) {\n                    loaded = loadClassLocallyFirst(name);\n                }\n                if (resolve) {\n                    resolveClass(loaded);\n                }\n                return loaded;\n            }\n        }\n\n        private Class<?> loadClassLocallyFirst(String name) throws ClassNotFoundException {\n            if (isAutoValueClass(name)) {\n                try {\n                    return findClass(name);\n                } catch (ClassNotFoundException ignored) {\n                    // Fall back to the parent class loader for JDK, compiler, and test harness types.\n                }\n            }\n            return super.loadClass(name, false);\n        }\n\n        private static boolean isAutoValueClass(String name) {\n            return name.startsWith(\"com.google.auto.value.\") || name.startsWith(\"autovalue.shaded.\");\n        }\n    }\n\n    private static final class CompilationResult {\n\n        private final boolean successful;\n        private final Path sourceOutput;\n        private final String diagnostics;\n\n        private CompilationResult(boolean successful, Path sourceOutput, String diagnostics) {\n            this.successful = successful;\n            this.sourceOutput = sourceOutput;\n            this.diagnostics = diagnostics;\n        }\n\n        private boolean isSuccessful() {\n            return this.successful;\n        }\n\n        private Path getSourceOutput() {\n            return this.sourceOutput;\n        }\n\n[7 more lines in file. Use offset=261 to continue.]"}], "isError": false, "timestamp": 1777976018383}]}
