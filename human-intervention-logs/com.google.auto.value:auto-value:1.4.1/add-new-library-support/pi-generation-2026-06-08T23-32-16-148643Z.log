   @SuppressWarnings(\"unchecked\")\n        $SortedSetMultimap<String, String> copy =\n                ($SortedSetMultimap<String, String>) roundTrip(multimap);\n\n        assertEquals(multimap, copy);\n        assertEquals(multimap.size(), copy.size());\n        assertIterableEquals(multimap.entries(), copy.entries());\n        assertIterableEquals(List.of(\"a\", \"b\"), copy.get(\"letters\"));\n        assertTrue(copy.get(\"missing\").isEmpty());\n        assertNull(copy.valueComparator());\n\n        copy.put(\"symbols\", \"#\");\n        assertIterableEquals(List.of(\"#\"), copy.get(\"symbols\"));\n    }\n\n    private static Object roundTrip(Object value) throws IOException, ClassNotFoundException {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(value);\n        }\n        ByteArrayInputStream inputBytes = new ByteArrayInputStream(bytes.toByteArray());\n        try (ObjectInputStream input = new ObjectInputStream(inputBytes)) {\n            return input.readObject();\n        }\n    }\n\n    private static final class TreeSetSupplier\n            implements $Supplier<SortedSet<String>>, Serializable {\n        private static final long serialVersionUID = 1L;\n\n        @Override\n        public SortedSet<String> get() {\n            return new TreeSet<>();\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 1556, "output": 1072, "cacheRead": 23552, "cacheWrite": 0, "totalTokens": 26180, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780961504826, "responseId": "resp_0c2ee32189ddf2b8016a2750e212ec81958a6232809ca3e0eb"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_I9oZQWkDKjO0xPs6Aok4g9Oi|fc_0c2ee32189ddf2b8016a2750ebda0881958bc41b946b487293", "toolName": "write", "content": [{"type": "