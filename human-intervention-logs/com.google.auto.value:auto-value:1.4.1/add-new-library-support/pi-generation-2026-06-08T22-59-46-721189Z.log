[tool-call] delta {"path":"tests/src/com.google.auto.value/auto-value/1.4.1/src/test/java/com_google_auto_value/auto_value/AutovalueShadedComGoogleCommonCollectInnerMapMakerInternalMapInnerAbstractSerializationProxyTest.java","edits":[{"oldText":"        ConcurrentMap<String, String> map = new $MapMaker()\n                .initialCapacity(4)\n                .concurrencyLevel(1)\n                .weakValues()\n                .makeMap();\n        String alpha = \"alpha\";\n        String one = \"one\";\n        map.put(\"letters\", alpha);\n        map.put(\"digits\", one);\n\n        @SuppressWarnings(\"unchecked\")\n        ConcurrentMap<String, String> copy = (ConcurrentMap<String, String>) roundTrip(map);\n\n        assertEquals(map, copy);\n        assertEquals(\"alpha\", copy.get(\"letters\"));\n        assertEquals(\"one\", copy.get(\"digits\"));\n        assertTrue(copy.containsKey(\"letters\"));\n    }\n\n    private static Object roundTrip(Object value) throws IOException, ClassNotFoundException {","newText":"        ConcurrentMap<Key, String> map = new $MapMaker()\n                .initialCapacity(4)\n                .concurrencyLevel(1)\n                .weakKeys()\n                .makeMap();\n        map.put(Key.LETTERS, \"alpha\");\n        map.put(Key.DIGITS, \"one\");\n\n        @SuppressWarnings(\"unchecked\")\n        ConcurrentMap<Key, String> copy = (ConcurrentMap<Key, String>) roundTrip(map);\n\n        assertEquals(map, copy);\n        assertEquals(\"alpha\", copy.get(Key.LETTERS));\n        assertEquals(\"one\", copy.get(Key.DIGITS));\n        assertTrue(copy.containsKey(Key.LETTERS));\n    }\n\n    private enum Key {\n        LETTERS,\n        DIGITS\n    }\n\n    private static Object roundTrip(Object value) throws IOException, ClassNotFoundException {"}]}
[tool-call] end id=call_VJhwkcnihoJHBiDodkSuY3il|fc_0a5a5c7216054686016a27494e7334819798c2c1818752aeac name=edit args={"path": "tests/src/com.google.auto.value/auto-value/1.4.1/src/test/java/com_google_auto_value/auto_value/AutovalueShadedComGoogleCommonCollectInnerMapMakerInternalMapInnerAbstractSerializationProxyTest.java", "edits": [{"oldText": "        ConcurrentMap<String, String> map = new $MapMaker()\n                .initialCapacity(4)\n                .concurrencyLevel(1)\n                .weakValues()\n                .makeMap();\n        String alpha = \"alpha\";\n        String one = \"one\";\n        map.put(\"letters\", alpha);\n        map.put(\"digits\", one);\n\n        @SuppressWarnings(\"unchecked\")\n        ConcurrentMap<String, String> copy = (ConcurrentMap<String, String>) roundTrip(map);\n\n        assertEquals(map, copy);\n        assertEquals(\"alpha\", copy.get(\"letters\"));\n        assertEquals(\"one\", copy.get(\"digits\"));\n        assertTrue(copy.containsKey(\"letters\"));\n    }\n\n    private static Object roundTrip(Object value) throws IOException, ClassNotFoundException {", "newText": "        ConcurrentMap<Key, String> map = new $MapMaker()\n                .initialCapacity(4)\n                .concurrencyLevel(1)\n                .weakKeys()\n                .makeMap();\n        map.put(Key.LETTERS, \"alpha\");\n        map.put(Key.DIGITS, \"one\");\n\n        @SuppressWarnings(\"unchecked\")\n        ConcurrentMap<Key, String> copy = (ConcurrentMap<Key, String>) roundTrip(map);\n\n        assertEquals(map, copy);\n        assertEquals(\"alpha\", copy.get(Key.LETTERS));\n        assertEquals(\"one\", copy.get(Key.DIGITS));\n        assertTrue(copy.containsKey(Key.LETTERS));\n    }\n\n    private enum Key {\n        LETTERS,\n        DIGITS\n    }\n\n    private static Object roundTrip(Object value) throws IOException, ClassNotFoundException {"}]}
