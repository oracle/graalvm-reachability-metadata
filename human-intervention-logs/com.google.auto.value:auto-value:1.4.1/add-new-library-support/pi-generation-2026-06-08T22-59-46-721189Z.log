  import org.junit.jupiter.api.Test;
  
  public class AutovalueShadedComGoogleCommonCollectInnerLinkedHashMultimapTest {
      @Test
      public void linkedHashMultimapRoundTripPreservesKeysValuesAndIterationOrder()
              throws Exception {
          $LinkedHashMultimap<String, String> multimap = $LinkedHashMultimap.create();
          multimap.put("letters", "a");
          multimap.put("digits", "1");
          multimap.put("letters", "b");
          multimap.put("symbols", "#");
  
          @SuppressWarnings("unchecked")
          $LinkedHashMultimap<String, String> copy =
                  ($LinkedHashMultimap<String, String>) roundTrip(multimap);
  
