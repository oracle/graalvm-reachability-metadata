[tool-call] delta {"path":"tests/src/com.google.auto.value/auto-value/1.4.1/src/test/java/com_google_auto_value/auto_value/AutovalueShadedComGoogleCommonCollectInnerMultimapsInnerCustomSetMultimapTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_google_auto_value.auto_value;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport autovalue.shaded.com.google$.common.base.$Supplier;\nimport autovalue.shaded.com.google$.common.collect.$Multimaps;\nimport autovalue.shaded.com.google$.common.collect.$SetMultimap;\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.IOException;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.io.Serializable;\nimport java.util.ArrayList;\nimport java.util.Collection;\nimport java.util.LinkedHashMap;\nimport java.util.LinkedHashSet;\nimport java.util.List;\nimport java.util.Map;\nimport java.util.Set;\nimport org.junit.jupiter.api.Test;\n\npublic class AutovalueShadedComGoogleCommonCollectInnerMultimapsInnerCustomSetMultimapTest {\n    @Test\n    void customSetMultimapSerializesFactoryAndBackingMap() throws Exception {\n        $SetMultimap<String, String> original = $Multimaps.newSetMultimap(\n                new LinkedHashMap<String, Collection<String>>(), new StringLinkedHashSetSupplier());\n        original.put(\"letters\", \"alpha\");\n        original.put(\"letters\", \"beta\");\n        original.put(\"digits\", \"one\");\n\n        $SetMultimap<String, String> restored = roundTrip(original);\n        restored.put(\"letters\", \"gamma\");\n        restored.put(\"symbols\", \"hash\");\n        boolean duplicateAdded = restored.put(\"letters\", \"alpha\");\n\n        assertThat(duplicateAdded).isFalse();\n        assertThat(restored.keySet()).containsExactly(\"letters\", \"digits\", \"symbols\");\n        assertThat(restored.get(\"letters\")).containsExactly(\"alpha\", \"beta\", \"gamma\");\n        assertThat(restored.get(\"digits\")).containsExactly(\"one\");\n        assertThat(restored.get(\"symbols\")).containsExactly(\"hash\");\n        assertThat(serializedEntries(restored)).containsExactly(\n                \"letters=alpha\",\n                \"letters=beta\",\n                \"letters=gamma\",\n                \"digits=one\",\n                \"symbols=hash\");\n    }\n\n    private static String serializedEntry(Map.Entry<String, String> entry) {\n        return entry.getKey() + \"=\" + entry.getValue();\n    }\n\n    private static List<String> serializedEntries($SetMultimap<String, String> multimap) {\n        List<String> entries = new ArrayList<>();\n        for (Map.Entry<String, String> entry : multimap.entries()) {\n            entries.add(serializedEntry(entry));\n        }\n        return entries;\n    }\n\n    @SuppressWarnings(\"unchecked\")\n    private static <T> T roundTrip(T value) throws IOException, ClassNotFoundException {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(value);\n        }\n\n        try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(bytes.toByteArray()))) {\n            return (T) input.readObject();\n        }\n    }\n\n    private static final class StringLinkedHashSetSupplier implements $Supplier<Set<String>>, Serializable {\n        private static final long serialVersionUID = 1L;\n\n        @Override\n        public Set<String> get() {\n            return new LinkedHashSet<>();\n        }\n    }\n}\n"}
