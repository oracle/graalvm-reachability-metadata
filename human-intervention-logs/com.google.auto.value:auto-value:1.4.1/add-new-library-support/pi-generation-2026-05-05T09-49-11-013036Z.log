  package com_google_auto_value.auto_value;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import autovalue.shaded.com.google$.common.base.$Supplier;
  import autovalue.shaded.com.google$.common.collect.$ListMultimap;
  import autovalue.shaded.com.google$.common.collect.$Multimaps;
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.IOException;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.io.Serializable;
  import java.util.ArrayList;
  import java.util.Collection;
  import java.util.LinkedHashMap;
  import java.util.List;
  import java.util.Map;
  import org.junit.jupiter.api.Test;
  
  public class AutovalueShadedComGoogleCommonCollectInnerMultimapsInnerCustomListMultimapTest {
      @Test
      void customListMultimapSerializesFactoryAndBackingMap() throws Exception {
          $ListMultimap<String, String> original = $Multimaps.newListMultimap(
                  new LinkedHashMap<String, Collection<String>>(), new StringArrayListSupplier());
          original.put("letters", "alpha");
          original.put("letters", "beta");
          original.put("digits", "one");
  
          $ListMultimap<String, String> restored = roundTrip(original);
          restored.put("letters", "gamma");
          restored.put("symbols", "hash");
  
          assertThat(restored.keySet()).containsExactly("letters", "digits", "symbols");
          assertThat(restored.get("letters")).containsExactly("alpha", "beta", "gamma");
          assertThat(restored.get("digits")).containsExactly("one");
          assertThat(restored.get("symbols")).containsExactly("hash");
          assertThat(serializedEntries(restored)).containsExactly(
                  "letters=alpha",
                  "letters=beta",
                  "letters=gamma",
                  "digits=one",
                  "symbols=hash");
      }
  
      private static String serializedEntry(Map.Entry<String, String> entry) {
          return entry.getKey() + "=" + entry.getValue();
      }
  
      private static List<String> serializedEntries($ListMultimap<String, String> multimap) {
          List<String> entries = new ArrayList<>();
          for (Map.Entry<String, String> entry : multimap.entries()) {
              entries.add(serializedEntry(entry));
          }
          return entries;
      }
  
      @SuppressWarnings("unchecked")
      private static <T> T roundTrip(T value) throws IOException, ClassNotFoundException {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {
              output.writeObject(value);
          }
  
          try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(bytes.toByteArray()))) {
              return (T) input.readObject();
          }
      }
  
      private static final class StringArrayListSupplier implements $Supplier<List<String>>, Serializable {
          private static final long serialVersionUID = 1L;
  
          @Override
          public List<String> get() {
              return new ArrayList<>();
          }
      }
