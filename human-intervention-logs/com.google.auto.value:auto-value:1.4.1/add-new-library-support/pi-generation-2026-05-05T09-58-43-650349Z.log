ies(restored)).containsExactly(\n                \"letters=alpha\",\n                \"letters=beta\",\n                \"letters=gamma\",\n                \"digits=one\",\n                \"symbols=hash\");\n    }\n\n    private static String serializedEntry(Map.Entry<String, String> entry) {\n        return entry.getKey() + \"=\" + entry.getValue();\n    }\n\n    private static List<String> serializedEntries($SetMultimap<String, String> multimap) {\n        List<String> entries = new ArrayList<>();\n        for (Map.Entry<String, String> entry : multimap.entries()) {\n            entries.add(serializedEntry(entry));\n        }\n        return entries;\n    }\n\n    @SuppressWarnings(\"unchecked\")\n    private static <T> T roundTrip(T value) throws IOException, ClassNotFoundException {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(value);\n        }\n\n        try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(bytes.toByteArray()))) {\n            return (T) input.readObject();\n        }\n    }\n\n    private static final class StringLinkedHashSetSupplier implements $Supplier<Set<String>>, Serializable {\n        private static final long serialVersionUID = 1L;\n\n        @Override\n        public Set<String> get() {\n            return new LinkedHashSet<>();\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777975039229}, {"role": "toolResult", "toolCallId": "call_ttR9q743kIAJohSGCDUAROFP|fc_0a8f9b03dbc491930169f9befef504819d8424af2cfd595405", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_google_auto_value.auto_value;\n\nimport static org.assertj.core.api.Assertions.asser