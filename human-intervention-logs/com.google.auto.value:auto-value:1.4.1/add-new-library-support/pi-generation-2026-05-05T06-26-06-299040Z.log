    static class MethodReferenceNode extends ReferenceNode {
      final ReferenceNode lhs;
      final String id;
      final List<ExpressionNode> args;
  
      MethodReferenceNode(ReferenceNode lhs, String id, List<ExpressionNode> args) {
        super(lhs.lineNumber);
        this.lhs = lhs;
        this.id = id;
        this.args = args;
