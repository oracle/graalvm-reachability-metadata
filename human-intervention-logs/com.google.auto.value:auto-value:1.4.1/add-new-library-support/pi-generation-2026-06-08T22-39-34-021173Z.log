();\n        multiset.add(\"alpha\", 2);\n        multiset.add(\"beta\", 3);\n\n        @SuppressWarnings(\"unchecked\")\n        $HashMultiset<String> copy = ($HashMultiset<String>) roundTrip(multiset);\n\n        assertEquals(2, copy.count(\"alpha\"));\n        assertEquals(3, copy.count(\"beta\"));\n        assertEquals(multiset.size(), copy.size());\n    }\n\n    @Test\n    public void hashMultimapRoundTripPreservesKeysAndValues() throws Exception {\n        $HashMultimap<String, String> multimap = $HashMultimap.create();\n        multimap.put(\"letters\", \"a\");\n        multimap.put(\"letters\", \"b\");\n        multimap.put(\"digits\", \"1\");\n\n        @SuppressWarnings(\"unchecked\")\n        $HashMultimap<String, String> copy = ($HashMultimap<String, String>) roundTrip(multimap);\n\n        assertEquals(multimap, copy);\n        assertTrue(copy.get(\"letters\").contains(\"a\"));\n        assertTrue(copy.get(\"letters\").contains(\"b\"));\n        assertTrue(copy.get(\"digits\").contains(\"1\"));\n    }\n\n    @Test\n    public void immutableSetMultimapRoundTripRestoresFinalSerializedFields() throws Exception {\n        $ImmutableSetMultimap<String, String> multimap = $ImmutableSetMultimap.of(\n                \"letters\", \"a\",\n                \"letters\", \"b\",\n                \"digits\", \"1\");\n\n        @SuppressWarnings(\"unchecked\")\n        $ImmutableSetMultimap<String, String> copy =\n                ($ImmutableSetMultimap<String, String>) roundTrip(multimap);\n\n        assertEquals(multimap, copy);\n        assertEquals(3, copy.size());\n        assertTrue(copy.get(\"missing\").isEmpty());\n    }\n\n    private static Object roundTrip(Object value) throws IOException, ClassNotFoundException {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(value);\n        }\n        try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(bytes.toByteArray()))) {\n            return input.readObject();\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 1433, "output": 1349, "cacheRead": 40448, "cacheWrite": 0, "totalTokens": 43230, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780958255350, "responseId": "resp_09b056d148e1919e016a2744306c80819783318357a3d9662a"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_Bki8bcmXDFD6xEZl9qiaO84g|fc_09b056d148e1919e016a27444172a881978d705e7ff6ea9f37", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 3028 bytes to tests/src/com.google.auto.value/auto-value/1.4.1/src/test/java/com_google_auto_value/auto_value/AutovalueShadedComGoogleCommonCollectInnerSerializationTest.java"}], "isError": false, "timestamp": 1780958279683}]}
