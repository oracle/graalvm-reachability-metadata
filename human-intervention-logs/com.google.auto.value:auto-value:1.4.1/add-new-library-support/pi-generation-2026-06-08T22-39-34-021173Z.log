ltiset, ObjectOutputStream)}, or the number of distinct\n    43\t   * keys in a multimap serialized by {@link\n    44\t   * #writeMultimap(Multimap, ObjectOutputStream)}.\n    45\t   */\n    46\t  static int readCount(ObjectInputStream stream) throws IOException {\n    47\t    return stream.readInt();\n    48\t  }\n    49\t\n    50\t  /**\n    51\t   * Stores the contents of a map in an output stream, as part of serialization.\n    52\t   * It does not support concurrent maps whose content may change while the\n    53\t   * method is running.\n    54\t   *\n    55\t   * <p>The serialized output consists of the number of entries, first key,\n    56\t   * first value, second key, second value, and so on.\n    57\t   */\n    58\t  static <K, V> void writeMap(Map<K, V> map, ObjectOutputStream stream) throws IOException {\n    59\t    stream.writeInt(map.size());\n    60\t    for (Map.Entry<K, V> entry : map.entrySet()) {\n    61\t      stream.writeObject(entry.getKey());\n    62\t      stream.writeObject(entry.getValue());\n    63\t    }\n    64\t  }\n    65\t\n    66\t  /**\n    67\t   * Populates a map by reading an input stream, as part of deserialization.\n    68\t   * See {@link #writeMap} for the data format.\n    69\t   */\n    70\t  static <K, V> void populateMap(Map<K, V> map, ObjectInputStream stream)\n    71\t      throws IOException, ClassNotFoundException {\n    72\t    int size = stream.readInt();\n    73\t    populateMap(map, stream, size);\n    74\t  }\n    75\t\n    76\t  /**\n    77\t   * Populates a map by reading an input stream, as part of deserialization.\n    78\t   * See {@link #writeMap} for the data format. The size is determined by a\n    79\t   * prior call to {@link #readCount}.\n    80\t   */\n    81\t  static <K, V> void populateMap(Map<K, V> map, ObjectInputStream stream, int size)\n    82\t      throws IOException, ClassNotFoundException {\n    83\t    for (int i = 0; i < size; i++) {\n    84\t      @SuppressWarnings(\"unchecked\") // reading data stored by writeMap\n    85\t      K key = (K) stream.readObject();\n    86\t      @SuppressWarnings(\"unchecked\") // reading data stored by writeMap\n    87\t      V value = (V) stream.readObject();\n    88\t      map.put(key, value);\n    89\t    }\n    90\t  }\n    91\t\n    92\t  /**\n    93\t   * Stores the contents of a multiset in an output stream, as part of\n    94\t   * serialization. It does not support concurrent multisets whose content may\n    95\t   * change while the method is running.\n    96\t   *\n    97\t   * <p>The serialized output consists of the number of distinct elements, the\n    98\t   * first element, its count, the second element, its count, and so on.\n    99\t   */\n   100\t  static <E> void writeMultiset(Multiset<E> multiset, ObjectOutputStream stream)\n   101\t      throws IOException {\n   102\t    int entryCount = multiset.entrySet().size();\n   103\t    stream.writeInt(entryCount);\n   104\t    for (Multiset.Entry<E> entry : multiset.entrySet()) {\n   105\t      stream.writeObject(entry.getElement());\n   106\t      stream.writeInt(entry.getCount());\n   107\t    }\n   108\t  }\n   109\t\n   110\t  /**\n   111\t   * Populates a multiset by reading an input stream, as part of\n   112\t   * deserialization. See {@link #writeMultiset} for the data format.\n   113\t   */\n   114\t  static <E> void populateMultiset(Multiset<E> multiset, ObjectInputStream stream)\n   115\t      throws IOException, ClassNotFoundException {\n   116\t    int distinctElements = stream.readInt();\n   117\t    populateMultiset(multiset, stream, distinctElements);\n   118\t  }\n   119\t\n   120\t  /**\n   121\t   * Populates a multiset by reading an input stream, as part of\n   122\t   * deserialization. See {@link #writeMultiset} for the data format. The number\n   123\t   * of distinct elements is determined by a prior call to {@link #readCount}.\n   124\t   */\n   125\t  static <E> void populateMultiset(\n   126\t      Multiset<E> multiset, ObjectInputStream stream, int distinctElements)\n   127\t      throws IOException, ClassNotFoundException {\n   128\t    for (int i = 0; i < distinctElements; i++) {\n   129\t      @SuppressWarnings(\"unchecked\") // reading data stored by writeMultiset\n   130\t      E element = (E) stream.readObject();\n   131\t      int count = stream.readInt();\n   132\t      multiset.add(element, count);\n   133\t    }\n   134\t  }\n   135\t\n   136\t  /**\n   137\t   * Stores the contents of a multimap in an output stream, as part of\n   138\t   * serialization. It does not support concurrent multimaps whose content may\n   139\t   * change while the method is running. The {@link Multimap#asMap} view\n   140\t   * determines the ordering in which data is written to the stream.\n   141\t   *\n   142\t   * <p>The serialized output consists of the number of distinct keys, and then\n   143\t   * for each distinct key: the key, the number of values for that key, and the\n   144\t   * key's values.\n   145\t   */\n   146\t  static <K, V> void writeMultimap(Multimap<K, V> multimap, ObjectOutputStream stream)\n   147\t      throws IOException {\n   148\t    stream.writeInt(multimap.asMap().size());\n   149\t    for (Map.Entry<K, Collection<V>> entry : multimap.asMap().entrySet()) {\n   150\t      stream.writeObject(entry.getKey());\n   151\t      stream.writeInt(entry.getValue().size());\n   152\t      for (V value : entry.getValue()) {\n   153\t        stream.writeObject(value);\n   154\t      }\n   155\t    }\n   156\t  }\n   157\t\n   158\t  /**\n   159\t   * Populates a multimap by reading an input stream, as part of\n   160\t   * deserialization. See {@link #writeMultimap} for the data format.\n   161\t   */\n   162\t  static <K, V> void populateMultimap(Multimap<K, V> multimap, ObjectInputStream stream)\n   163\t      throws IOException, ClassNotFoundException {\n   164\t    int distinctKeys = stream.readInt();\n   165\t    populateMultimap(multimap, stream, distinctKeys);\n   166\t  }\n   167\t\n   168\t  /**\n   169\t   * Populates a multimap by reading an input stream, as part of\n   170\t   * deserialization. See {@link #writeMultimap} for the data format. The number\n   171\t   * of distinct keys is determined by a prior call to {@link #readCount}.\n   172\t   */\n   173\t  static <K, V> void populateMultimap(\n   174\t      Multimap<K, V> multimap, ObjectInputStream stream, int distinctKeys)\n   175\t      throws IOException, ClassNotFoundException {\n   176\t    for (int i = 0; i < distinctKeys; i++) {\n   177\t      @SuppressWarnings(\"unchecked\") // reading data stored by writeMultimap\n   178\t      K key = (K) stream.readObject();\n   179\t      Collection<V> values = multimap.get(key);\n   180\t      int valueCount = stream.readInt();\n   181\t      for (int j = 0; j < valueCount; j++) {\n   182\t        @SuppressWarnings(\"unchecked\") // reading data stored by writeMultimap\n   183\t        V value = (V) stream.readObject();\n   184\t        values.add(value);\n   185\t      }\n   186\t    }\n   187\t  }\n   188\t\n   189\t  // Secret sauce for setting final fields; don't make it public.\n   190\t  static <T> FieldSetter<T> getFieldSetter(final Class<T> clazz, String fieldName) {\n   191\t    try {\n   192\t      Field field = clazz.getDeclaredField(fieldName);\n   193\t      return new FieldSetter<T>(field);\n   194\t    } catch (NoSuchFieldException e) {\n   195\t      throw new AssertionError(e); // programmer error\n   196\t    }\n   197\t  }\n   198\t\n   199\t  // Secret sauce for setting final fields; don't make it public.\n   200\t  static final class FieldSetter<T> {\n   201\t    private final Field field;\n   202\t\n   203\t    private FieldSetter(Field field) {\n   204\t      this.field = field;\n   205\t      field.setAccessible(true);\n   206\t    }\n   207\t\n   208\t    void set(T instance, Object value) {\n   209\t      try {\n   210\t        field.set(instance, value);\n   211\t      } catch (IllegalAccessExcept