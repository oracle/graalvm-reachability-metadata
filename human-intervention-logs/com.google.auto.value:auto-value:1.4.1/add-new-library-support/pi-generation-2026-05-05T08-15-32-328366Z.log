  package com_google_auto_value.auto_value;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import autovalue.shaded.com.google$.common.collect.$LinkedHashMultimap;
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.IOException;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.util.ArrayList;
  import java.util.List;
  import java.util.Map;
  import org.junit.jupiter.api.Test;
  
  public class AutovalueShadedComGoogleCommonCollectLinkedHashMultimapTest {
      @Test
      void linkedHashMultimapPreservesKeyValueAndEntryOrderAcrossSerialization() throws Exception {
          $LinkedHashMultimap<String, String> original = $LinkedHashMultimap.create();
          original.put("letters", "alpha");
          original.put("digits", "one");
          original.put("letters", "beta");
          original.put("symbols", "hash");
  
          $LinkedHashMultimap<String, String> restored = roundTrip(original);
  
          assertThat(restored).isEqualTo(original);
          assertThat(restored.keySet()).containsExactly("letters", "digits", "symbols");
          assertThat(restored.get("letters")).containsExactly("alpha", "beta");
          assertThat(restored.get("digits")).containsExactly("one");
          assertThat(restored.get("symbols")).containsExactly("hash");
          assertThat(restored.values()).containsExactly("alpha", "one", "beta", "hash");
          assertThat(serializedEntries(restored)).containsExactly(
                  "letters=alpha",
                  "digits=one",
                  "letters=beta",
                  "symbols=hash");
      }
  
      private static String serializedEntry(Map.Entry<String, String> entry) {
          return entry.getKey() + "=" + entry.getValue();
      }
  
      private static List<String> serializedEntries($LinkedHashMultimap<String, String> multimap) {
          List<String> entries = new ArrayList<>();
          for (Map.Entry<String, String> entry : multimap.entries()) {
              entries.add(serializedEntry(entry));
          }
          return entries;
