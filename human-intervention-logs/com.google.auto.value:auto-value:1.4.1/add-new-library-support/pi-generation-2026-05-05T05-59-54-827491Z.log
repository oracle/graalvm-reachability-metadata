ctInputStream.readObject();\n            assertThat(restored).isInstanceOf($LinkedHashMultimap.class);\n            return $LinkedHashMultimap.class.cast(restored);\n        }\n    }\n\n    private static byte[] serialize($LinkedHashMultimap<String, String> value) throws IOException {\n        ByteArrayOutputStream outputStream = new ByteArrayOutputStream();\n        try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(outputStream)) {\n            objectOutputStream.writeObject(value);\n        }\n        return outputStream.toByteArray();\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1804, "output": 1022, "cacheRead": 35840, "cacheWrite": 0, "totalTokens": 38666, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777960764706, "responseId": "resp_09e486aab6407b650169f9873d31508193b110728e0614a436"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_0di7GAhNMLoFYBy2wPHqYAwM|fc_09e486aab6407b650169f98743a9c8819383aa78937198236f", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2340 bytes to tests/src/com.google.auto.value/auto-value/1.4.1/src/test/java/com_google_auto_value/auto_value/AutovalueShadedComGoogleCommonCollectLinkedHashMultimapTest.java"}], "isError": false, "timestamp": 1777960774877}]}
