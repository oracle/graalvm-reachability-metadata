  public class AutovalueShadedComGoogleCommonCollectMapMakerInternalMapInnerAbstractSerializationProxyTest {
      @Test
      void serializesEntriesThroughMapMakerInternalMapSerializationProxy() throws Exception {
          ConcurrentMap<String, String> original = new $MapMaker()
                  .initialCapacity(4)
                  .concurrencyLevel(1)
                  .weakValues()
                  .makeMap();
          original.put("first", "one");
          original.put("second", "two");
  
          ConcurrentMap<String, String> restored = roundTrip(original);
  
          assertThat(snapshot(restored)).containsExactlyInAnyOrderEntriesOf(expectedEntries());
  
          restored.put("third", "three");
          assertThat(restored.get("third")).isEqualTo("three");
      }
  
      private static Map<String, String> expectedEntries() {
          Map<String, String> entries = new LinkedHashMap<>();
          entries.put("first", "one");
          entries.put("second", "two");
          return entries;
      }
  
      private static Map<String, String> snapshot(ConcurrentMap<String, String> map) {
          Map<String, String> entries = new LinkedHashMap<>();
          for (Map.Entry<String, String> entry : map.entrySet()) {
              entries.put(entry.getKey(), entry.getValue());
          }
          return entries;
      }
  
      @SuppressWarnings("unchecked")
      private static <T> T roundTrip(T value) throws IOException, ClassNotFoundException {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {
              output.writeObject(value);
          }
  
          try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(bytes.toByteArray()))) {
              return (T) input.readObject();
          }
      }
  }
