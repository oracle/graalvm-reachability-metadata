{"type":"item.completed","item":{"id":"item_55","type":"command_execution","command":"/usr/bin/bash -lc \"sed -n '1,180p' tests/src/com.google.auto.value/auto-value/1.4.1/src/test/java/com_google_auto_value/auto_value/AutovalueShadedComGoogleAutoCommonInnerMoreTypesTest.java\"","aggregated_output":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_google_auto_value.auto_value;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport autovalue.shaded.com.google$.auto.common.$MoreTypes;\nimport autovalue.shaded.com.google$.common.base.$Equivalence;\nimport java.io.IOException;\nimport java.io.StringWriter;\nimport java.net.URI;\nimport java.nio.file.Files;\nimport java.nio.file.Path;\nimport java.util.List;\nimport java.util.Set;\nimport javax.annotation.processing.AbstractProcessor;\nimport javax.annotation.processing.RoundEnvironment;\nimport javax.lang.model.SourceVersion;\nimport javax.lang.model.element.TypeElement;\nimport javax.lang.model.element.TypeParameterElement;\nimport javax.lang.model.type.TypeMirror;\nimport javax.lang.model.type.TypeVariable;\nimport javax.tools.Diagnostic;\nimport javax.tools.DiagnosticCollector;\nimport javax.tools.JavaCompiler;\nimport javax.tools.JavaFileObject;\nimport javax.tools.SimpleJavaFileObject;\nimport javax.tools.StandardJavaFileManager;\nimport javax.tools.StandardLocation;\nimport javax.tools.ToolProvider;\nimport org.junit.jupiter.api.Test;\nimport org.junit.jupiter.api.io.TempDir;\n\npublic class AutovalueShadedComGoogleAutoCommonInnerMoreTypesTest {\n\n    @TempDir\n    Path temporaryDirectory;\n\n    @Test\n    void equivalenceComparesIntersectionTypeBounds() throws IOException {\n        JavaCompiler compiler = ToolProvider.getSystemJavaCompiler();\n        assertThat(compiler).as(\"A JDK compiler is required to inspect intersection TypeMirrors\").isNotNull();\n\n        IntersectionEquivalenceProcessor processor = new IntersectionEquivalenceProcessor();\n        DiagnosticCollector<JavaFileObject> diagnostics = new DiagnosticCollector<>();\n        StringWriter compilerOutput = new StringWriter();\n        Path classesDirectory = Files.createDirectories(this.temporaryDirectory.resolve(\"classes\"));\n        try (StandardJavaFileManager fileManager = compiler.getStandardFileManager(diagnostics, null, null)) {\n            fileManager.setLocationFromPaths(StandardLocation.CLASS_OUTPUT, List.of(classesDirectory));\n            JavaCompiler.CompilationTask task = compiler.getTask(compilerOutput, fileManager, diagnostics,\n                    List.of(\"-proc:only\", \"-classpath\", javaClassPath()), null,\n                    List.of(new SourceFile(\"sample.Intersections\", intersectionsSource())));\n            task.setProcessors(List.of(processor));\n\n            assertThat(task.call()).as(formatDiagnostics(diagnostics, compilerOutput)).isTrue();\n        }\n\n        assertThat(processor.hasComparedIntersectionTypes()).as(\"processor compared intersection TypeMirrors\").isTrue();\n        assertThat(processor.firstKind()).isEqualTo(\"INTERSECTION\");\n        assertThat(processor.secondKind()).isEqualTo(\"INTERSECTION\");\n        assertThat(processor.intersectionsAreEquivalent()).isTrue();\n    }\n\n    private static String intersectionsSource() {\n        return \"\"\"\n                package sample;\n\n                interface Base {}\n\n                interface Named {}\n\n                class First<T extends Base & Named> {}\n\n                class Second<T extends Base & Named> {}\n                \"\"\";\n    }\n\n    private static String javaClassPath() {\n        return System.getProperty(\"java.class.path\", \"\");\n    }\n\n    private static String formatDiagnostics(DiagnosticCollector<JavaFileObject> diagnostics, StringWriter output) {\n        StringBuilder result = new StringBuilder(output.toString());\n        for (Diagnostic<? extends JavaFileObject> diagnostic : diagnostics.getDiagnostics()) {\n            result.append(System.lineSeparator())\n                    .append(diagnostic.getKind())\n                    .append(\": \")\n                    .append(diagnostic.getMessage(null));\n        }\n        return result.toString();\n    }\n\n    private static final class IntersectionEquivalenceProcessor extends AbstractProcessor {\n\n        private boolean comparedIntersectionTypes;\n        private boolean intersectionsEquivalent;\n        private String firstKind;\n        private String secondKind;\n\n        @Override\n        public Set<String> getSupportedAnnotationTypes() {\n            return Set.of(\"*\");\n        }\n\n        @Override\n        public SourceVersion getSupportedSourceVersion() {\n            return SourceVersion.latestSupported();\n        }\n\n        @Override\n        public boolean process(Set<? extends TypeElement> annotations, RoundEnvironment roundEnvironment) {\n            if (roundEnvironment.processingOver() || this.comparedIntersectionTypes) {\n                return false;\n            }\n\n            TypeMirror firstUpperBound = upperBoundOfFirstTypeParameter(\"sample.First\");\n            TypeMirror secondUpperBound = upperBoundOfFirstTypeParameter(\"sample.Second\");\n            this.firstKind = firstUpperBound.getKind().name();\n            this.secondKind = secondUpperBound.getKind().name();\n            $Equivalence<TypeMirror> equivalence = $MoreTypes.equivalence();\n            this.intersectionsEquivalent = equivalence.equivalent(firstUpperBound, secondUpperBound);\n            this.comparedIntersectionTypes = true;\n            return false;\n        }\n\n        private TypeMirror upperBoundOfFirstTypeParameter(String className) {\n            TypeElement typeElement = this.processingEnv.getElementUtils().getTypeElement(className);\n            assertThat(typeElement).as(className).isNotNull();\n            TypeParameterElement typeParameter = typeElement.getTypeParameters().get(0);\n            return ((TypeVariable) typeParameter.asType()).getUpperBound();\n        }\n\n        private boolean hasComparedIntersectionTypes() {\n            return this.comparedIntersectionTypes;\n        }\n\n        private boolean intersectionsAreEquivalent() {\n            return this.intersectionsEquivalent;\n        }\n\n        private String firstKind() {\n            return this.firstKind;\n        }\n\n        private String secondKind() {\n            return this.secondKind;\n        }\n    }\n\n    private static final class SourceFile extends SimpleJavaFileObject {\n\n        private final String content;\n\n        private SourceFile(String className, String content) {\n            super(URI.create(\"string:///\" + className.replace('.', '/') + Kind.SOURCE.extension), Kind.SOURCE);\n            this.content = content;\n        }\n\n        @Override\n        public CharSequence getCharContent(boolean ignoreEncodingErrors) {\n            return this.content;\n        }\n    }\n}\n","exit_code":0,"status":"completed"}}
