      private static final long __DEFAULT_MAX_REQUEST_MS_INIT_PARAM = 30000L;
      private static final long __DEFAULT_MAX_IDLE_TRACKER_MS_INIT_PARAM = 30000L;
  
      static final String MANAGED_ATTR_INIT_PARAM = "managedAttr";
