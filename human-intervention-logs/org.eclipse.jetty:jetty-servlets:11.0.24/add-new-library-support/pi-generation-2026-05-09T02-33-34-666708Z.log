am responseBytes = new ByteArrayOutputStream();\n            socket.getInputStream().transferTo(responseBytes);\n            String response = responseBytes.toString(StandardCharsets.ISO_8859_1);\n\n            assertThat(response).doesNotStartWith(\"HTTP/1.1 200\");\n            assertThat(response).doesNotContain(\"slow response\");\n        }\n    }\n\n    @Test\n    void qosFilterReadsInitializationParameters() {"}, {"oldText": "    public static final class GreetingEventSourceServlet extends EventSourceServlet {\n", "newText": "    private static final class SlowServlet extends HttpServlet {\n        @Override\n        protected void doGet(HttpServletRequest request, HttpServletResponse response) throws IOException {\n            try {\n                Thread.sleep(1_000);\n                response.setContentType(\"text/plain;charset=UTF-8\");\n                response.getWriter().write(\"slow response\");\n            } catch (InterruptedException e) {\n                Thread.currentThread().interrupt();\n            }\n        }\n    }\n\n    public static final class GreetingEventSourceServlet extends EventSourceServlet {\n"}]}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 302, "output": 1575, "cacheRead": 30720, "cacheWrite": 0, "totalTokens": 32597, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778293952329, "responseId": "resp_0a1b6bd19e5bbdbc0169fe9cc0f0fc8193abbe91fd07402798"}}
