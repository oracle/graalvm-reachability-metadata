NS\",\n    74\t                Map.of(\n    75\t                    \"Origin\", \"https://api.example.test\",\n    76\t                    CrossOriginFilter.ACCESS_CONTROL_REQUEST_METHOD_HEADER, \"PUT\",\n    77\t                    CrossOriginFilter.ACCESS_CONTROL_REQUEST_HEADERS_HEADER, \"X-Test\"),\n    78\t                null);\n    79\t\n    80\t            assertThat(preflight.status()).isEqualTo(HttpServletResponse.SC_OK);\n    81\t            assertThat(preflight.header(CrossOriginFilter.ACCESS_CONTROL_ALLOW_ORIGIN_HEADER))\n    82\t                .isEqualTo(\"https://api.example.test\");\n    83\t            assertThat(preflight.header(CrossOriginFilter.ACCESS_CONTROL_ALLOW_CREDENTIALS_HEADER))\n    84\t                .isEqualTo(\"true\");\n    85\t            assertThat(preflight.header(CrossOriginFilter.ACCESS_CONTROL_ALLOW_METHODS_HEADER))\n    86\t                .contains(\"GET\", \"PUT\");\n    87\t            assertThat(preflight.header(CrossOriginFilter.ACCESS_CONTROL_ALLOW_HEADERS_HEADER))\n    88\t                .contains(\"X-Test\");\n    89\t            assertThat(preflight.header(\"Vary\")).contains(\"Origin\");\n    90\t\n    91\t            Response simple = rawRequest(\n    92\t                server.uri(\"/resource\"),\n    93\t                \"GET\",\n    94\t                Map.of(\"Origin\", \"https://timing.example.test\"),\n    95\t                null);\n    96\t\n    97\t            assertThat(simple.status()).isEqualTo(HttpServletResponse.SC_OK);\n    98\t            assertThat(simple.body()).isEqualTo(\"application response\");\n    99\t            assertThat(simple.header(CrossOriginFilter.ACCESS_CONTROL_ALLOW_ORIGIN_HEADER))\n   100\t                .isEqualTo(\"https://timing.example.test\");\n   101\t            assertThat(simple.header(CrossOriginFilter.TIMING_ALLOW_ORIGIN_HEADER))\n   102\t                .isEqualTo(\"https://timing.example.test\");\n   103\t            assertThat(simple.header(CrossOriginFilter.ACCESS_CONTROL_EXPOSE_HEADERS_HEADER))\n   104\t                .isEqualTo(\"X-Result\");\n   105\t        }\n   106\t    }\n   107\t\n   108\t    @Test\n   109\t    void headerFilterAppliesConfiguredHeadersOnlyToIncludedRequests() throws Exception {\n   110\t        FilterHolder headerFilter = new FilterHolder(new HeaderFilter());\n   111\t        headerFilter.setInitParameter(\"headerConfig\", \"set X-Filtered: yes, add X-Multi: one, add X-Multi: two\");\n   112\t        headerFilter.setInitParameter(\"includedPaths\", \"/api/*\");\n   113\t        headerFilter.setInitParameter(\"excludedHttpMethods\", \"POST\");\n   114\t\n   115\t        try (JettyServer server = JettyServer.start(new TextServlet(\"ok\", new AtomicInteger()), headerFilter)) {\n   116\t            Response included = request(server.uri(\"/api/data.txt\"), \"GET\", Map.of(), null);\n   117\t            assertThat(included.status()).isEqualTo(HttpServletResponse.SC_OK);\n   118\t            assertThat(included.header(\"X-Filtered\")).isEqualTo(\"yes\");\n   119\t            assertThat(included.header(\"X-Multi\")).contains(\"one\", \"two\");\n   120\t\n   121\t            Response excludedByMethod = request(server.uri(\"/api/data.txt\"), \"POST\", Map.of(), \"payload\");\n   122\t            assertThat(excludedByMethod.status()).isEqualTo(HttpServletResponse.SC_OK);\n   123\t            assertThat(excludedByMethod.header(\"X-Filtered\")).isNull();\n   124\t\n   125\t            Response excludedByPath = request(server.uri(\"/plain/data.txt\"), \"GET\", Map.of(), null);\n   126\t            assertThat(excludedByPath.status()).isEqualTo(HttpServletResponse.SC_OK);\n   127\t            assertThat(excludedByPath.header(\"X-Filtered\")).isNull();\n   128\t        }\n   129\t    }\n   130\t\n   131\t    @Test\n   132\t    void eventSourceServletStreamsNamedEventsDataAndComments() throws Exception {\n   133\t        ServletHolder holder = new ServletHolder(new GreetingEventSourceServlet());\n   134\t        holder.setInitParameter(\"heartBeatPeriod\", \"30\");\n   135\t\n   136\t        try (JettyServer server = JettyServer.start(holder)) {\n   137\t            Response response = request(\n   138\t                server.uri(\"/events\"),\n   139\t                \"GET\",\n   140\t                Map.of(\"Accept\", \"text/event-stream\"),\n   141\t                null);\n   142\t\n   143\t            assertThat(response.status()).isEqualTo(HttpServletResponse.SC_OK);\n   144\t            assertThat(response.header(\"Content-Type\")).startsWith(\"text/event-stream\");\n   145\t            assertThat(response.body()).contains(\n   146\t                \"event: greeting\\r\\n\",\n   147\t                \"data: hello\\r\\n\",\n   148\t                \"data: world\\r\\n\",\n   149\t                \": completed\\r\\n\");\n   150\t        }\n   151\t    }\n   152\t\n   153\t    @Test\n   154\t    void includeExcludeBasedFilterMatchesGuessedMimeTypes() throws Exception {\n   155\t        FilterHolder mimeFilter = new FilterHolder(new MimeTypeFlaggingFilter());\n   156\t        mimeFilter.setInitParameter(\"includedMimeTypes\", \"application/json,text/plain\");\n   157\t        mimeFilter.setInitParameter(\"excludedMimeTypes\", \"text/html\");\n   158\t\n   159\t        try (JettyServer server = JettyServer.start(new TextServlet(\"ok\", new AtomicInteger()), mimeFilter)) {\n   160\t            Response json = rawRequest(server.uri(\"/documents/report.json\"), \"GET\", Map.of(), null);\n   161\t            assertThat(json.status()).isEqualTo(HttpServletResponse.SC_OK);\n   162\t            assertThat(json.header(\"X-Mime-Eligible\")).isEqualTo(\"true\");\n   163\t\n   164\t            Response html = rawRequest(server.uri(\"/documents/page.html\"), \"GET\", Map.of(), null);\n   165\t            assertThat(html.status()).isEqualTo(HttpServletResponse.SC_OK);\n   166\t            assertThat(html.header(\"X-Mime-Eligible\")).isEqualTo(\"false\");\n   167\t        }\n   168\t    }\n   169\t\n   170\t    @Test\n   171\t    void doSFilterExposesConfigurationWhitelistAndListenerActions() throws Exception {\n   172\t        DoSFilter filter = new DoSFilter();\n   173\t        Map<String, String> parameters = Map.ofEntries(\n   174\t            Map.entry(\"maxRequestsPerSec\", \"3\"),\n   175\t            Map.entry(\"delayMs\", \"0\"),\n   176\t            Map.entry(\"throttledRequests\", \"2\"),\n   177\t            Map.entry(\"maxWaitMs\", \"125\"),\n   178\t            Map.entry(\"throttleMs\", \"250\"),\n   179\t            Map.entry(\"maxRequestMs\", \"500\"),\n   180\t            Map.entry(\"maxIdleTrackerMs\", \"750\"),\n   181\t            Map.entry(\"insertHeaders\", \"false\"),\n   182\t            Map.entry(\"remotePort\", \"true\"),\n   183\t            Map.entry(\"enabled\", \"true\"),\n   184\t            Map.entry(\"tooManyCode\", \"503\"),\n   185\t            Map.entry(\"ipWhitelist\", \"127.0.0.1,10.0.0.0/24\"));\n   186\t\n   187\t        try {\n   188\t            filter.init(new SimpleFilterConfig(\"configuredDoS\", parameters));\n   189\t\n   190\t            assertThat(filter.getName()).isEqualTo(\"configuredDoS\");\n   191\t            assertThat(filter.getMaxRequestsPerSec()).isEqualTo(3);\n   192\t            assertThat(filter.getDelayMs()).isZero();\n   193\t            assertThat(filter.getThrottledRequests()).isEqualTo(2);\n   194\t            assertThat(filter.getMaxWaitMs()).isEqualTo(125);\n   195\t            assertThat(filter.getThrottleMs()).isEqualTo(250);\n   196\t            assertThat(filter.getMaxRequestMs()).isEqualTo(500);\n   197\t            assertThat(filter.getMaxIdleTrackerMs()).isEqualTo(750);\n   198\t            assertThat(filter.isInsertHeaders()).isFalse();\n   199\t            assertThat(filter.isRemotePort()).isTrue();\n   200\t            assertThat(filter.isEnabled()).isTrue();\n   201\t            assertThat(filter.getTooManyCode()).isEqualTo(503);\n   202\t            assertThat(filter.getWhitelist()).contains(\"127.0.0.1\", \"10.0.0.0/24\");\n   203\t            assertThat(filter.addWhitelistAddress(\"192.168.1.10\")).isTrue();\n   204\t            assertThat(filter.removeWhitelistAddress(\"127.0.0.1\")).isTrue();\n   205\t            assertThat(filter.getWhitelist()).contains(\"192.168.1.10\").doesNotContain(\"127.0.0.1\");\n   206\t            assertThat(DoSFilter.Action.fromDelay(-1)).isEqualTo(DoSFilter.Action.REJECT);\n   207\t            assertThat(DoSFilter.Action.fromDelay(0)).isEqualTo(DoSFilter.Action.THROTTLE);\n   208\t            assertThat(DoSFilter.Action.fromDelay(1)).isEqualTo(DoSFilter.Action.DELAY);\n   209\t        } finally {\n   210\t            filter.destroy();\n   211\t        }\n   212\t    }\n   213\t\n   214\t    @Test\n   215\t    void closeableDoSFilterClosesTimedOutRequests() throws Exception {\n   216\t        FilterHolder filter = new FilterHolder(new CloseableDoSFilter());\n   217\t        filter.setInitParameter(\"maxRequestMs\", \"100\");\n   218\t        filter.setInitParameter(\"maxRequestsPerSec\", \"100\");\n   219\t        filter.setInitParameter(\"insertHeaders\", \"false\");\n   220\t        filter.setAsyncSupported(true);\n","exit_code":0,"status":"completed"}}
