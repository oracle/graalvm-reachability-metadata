y.getMarker(\"coverage-marker\")).isSameAs(marker);\n            assertThat(mdcAdapter.get(\"coverage-key\")).isEqualTo(\"coverage-value\");\n        } finally {\n            mdcAdapter.remove(\"coverage-key\");\n        }\n    }\n}\n"}
