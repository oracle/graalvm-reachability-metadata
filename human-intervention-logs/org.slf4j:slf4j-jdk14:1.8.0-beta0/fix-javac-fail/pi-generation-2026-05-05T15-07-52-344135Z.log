overage-mdc-value\");\n        } finally {\n            adapter.remove(key);\n        }\n    }\n\n    private static JULServiceProvider initializedProvider() {\n        JULServiceProvider provider = new JULServiceProvider();\n        provider.initialize();\n        return provider;\n    }\n}\n"}
