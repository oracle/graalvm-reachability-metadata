ou should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage org_jetbrains_compose_foundation.foundation\\n\\nimport androidx.compose.foundation.BasicTooltipState\\nimport androidx.compose.foundation.BorderStroke\\nimport androidx.compose.foundation.ExperimentalFoundationApi\\nimport androidx.compose.foundation.MarqueeSpacing\\nimport androidx.compose.foundation.MutatePriority\\nimport androidx.compose.foundation.MutatorMutex\\nimport androidx.compose.foundation.content.MediaType\\nimport androidx.compose.foundation.gestures.Draggable2DState\\nimport androidx.compose.foundation.gestures.DraggableState\\nimport androidx.compose.foundation.gestures.ScrollableState\\nimport androidx.compose.foundation.gestures.TransformableState\\nimport androidx.compose.foundation.gestures.panBy\\nimport androidx.compose.foundation.gestures.rotateBy\\nimport androidx.compose.foundation.gestures.snapping.SnapPosition\\nimport androidx.compose.foundation.gestures.transformBy\\nimport androidx.compose.foundation.gestures.zoomBy\\nimport androidx.compose.foundation.lazy.LazyListState\\nimport androidx.compose.foundation.lazy.grid.GridCells\\nimport androidx.compose.foundation.lazy.grid.GridItemSpan\\nimport androidx.compose.foundation.lazy.grid.LazyGridState\\nimport androidx.compose.foundation.pager.PageSize\\nimport androidx.compose.foundation.pager.PagerSnapDistance\\nimport androidx.compose.ui.geometry.Offset\\nimport androidx.compose.ui.graphics.Color\\nimport androidx.compose.ui.unit.Density\\nimport androidx.compose.ui.unit.dp\\nimport kotlinx.coroutines.runBlocking\\nimport org.assertj.core.api.Assertions.assertThat\\nimport org.junit.jupiter.api.Test\\n\\n@OptIn(ExperimentalFoundationApi::class)\\npublic class FoundationTest {\\n    @Test\\n    fun borderStrokeAndMediaTypeExposeStableValueSemantics() {\\n        val border = BorderStroke(2.dp, Color.Magenta)\\n        val sameBorder = BorderStroke(2.dp, Color.Magenta)\\n        val customType = MediaType(\\\"application/vnd.compose.test+json\\\")\\n\\n        assertThat(border).isEqualTo(sameBorder)\\n        assertThat(border.width).isEqualTo(2.dp)\\n        assertThat(border.toString()).contains(\\\"width=2.0.dp\\\")\\n        assertThat(MediaType.PlainText.representation).isEqualTo(\\\"text/plain\\\")\\n        assertThat(MediaType.HtmlText.toString()).isEqualTo(\\\"text/html\\\")\\n        assertThat(customType.representation).isEqualTo(\\\"application/vnd.compose.test+json\\\")\\n    }\\n\\n    @Test\\n    fun mutatorMutexSupportsExplicitLockingTryMutationAndReceiverMutation() = runBlocking {\\n        val mutex = MutatorMutex()\\n        val events = mutableListOf<String>()\\n\\n        assertThat(mutex.tryLock()).isTrue()\\n        assertThat(mutex.tryLock()).isFalse()\\n        mutex.unlock()\\n\\n        val tryMutateSucceeded = mutex.tryMutate {\\n            events += \\\"tryMutate\\\"\\n        }\\n        val mutatedLength = mutex.mutateWith(StringBuilder(\\\"compose\\\"), MutatePriority.UserInput) {\\n            append(\\\" foundation\\\")\\n            length\\n        }\\n        val mutateResult = mutex.mutate(MutatePriority.Default) {\\n            events += \\\"mutate\\\"\\n            \\\"completed\\\"\\n        }\\n\\n        assertThat(tryMutateSucceeded).isTrue()\\n        assertThat(mutatedLength).isEqualTo(\\\"compose foundation\\\".length)\\n        assertThat(mutateResult).isEqualTo(\\\"completed\\\")\\n        assertThat(events).containsExactly(\\\"tryMutate\\\", \\\"mutate\\\")\\n    }\\n\\n    @Test\\n    fun scrollableStateReportsConsumptionAndInProgressState() = runBlocking {\\n        val consumedDeltas = mutableListOf<Float>()\\n        val state = ScrollableState { delta ->\\n            consumedDeltas += delta\\n            delta / 2f\\n        }\\n\\n        assertThat(state.dispatchRawDelta(18f)).isEqualTo(9f)\\n        assertThat(state.isScrollInProgress).isFalse()\\n\\n        state.scroll {\\n            assertThat(state.isScrollInProgress).isTrue()\\n            assertThat(scrollBy(10f)).isEqualTo(5f)\\n            assertThat(scrollBy(-4f)).isEqualTo(-2f)\\n        }\\n\\n        assertThat(state.isScrollInProgress).isFalse()\\n        assertThat(consumedDeltas).containsExactly(18f, 10f, -4f)\\n    }\\n\\n    @Test\\n    fun draggableStatesDeliverRawAndScopedDragDeltas() = runBlocking {\\n        var oneDimensionalTotal = 0f\\n        var twoDimensionalTotal = Offset.Zero\\n        val draggable = DraggableState { delta ->\\n            oneDimensionalTotal += delta\\n        }\\n        val draggable2D = Draggable2DState { delta ->\\n            twoDimensionalTotal += delta\\n        }\\n\\n        draggable.dispatchRawDelta(3f)\\n        draggable.drag {\\n            dragBy(7f)\\n            dragBy(-2f)\\n        }\\n        draggable2D.dispatchRawDelta(Offset(1f, 2f))\\n        draggable2D.drag {\\n            dragBy(Offset(3f, -1f))\\n            dragBy(Offset(-2f, 4f))\\n        }\\n\\n        assertThat(oneDimensionalTotal).isEqualTo(8f)\\n        assertThat(twoDimensionalTotal).isEqualTo(Offset(2f, 5f))\\n    }\\n\\n    @Test\\n    fun transformableStateCombinesZoomPanAndRotationChanges() = runBlocking {\\n        var zoom = 1f\\n        var pan = Offset.Zero\\n        var rotation = 0f\\n        val state = TransformableState { zoomChange, panChange, rotationChange ->\\n            zoom *= zoomChange\\n            pan += panChange\\n            rotation += rotationChange\\n        }\\n\\n        state.transform {\\n            assertThat(state.isTransformInProgress).isTrue()\\n            transformBy(zoomChange = 2f, panChange = Offset(3f, 4f), rotationChange = 15f)\\n            transformBy(zoomChange = 0.5f, panChange = Offset(-1f, 1f), rotationChange = -5f)\\n        }\\n        state.zoomBy(3f)\\n        state.panBy(Offset(2f, -2f))\\n        state.rotateBy(45f)\\n\\n        assertThat(state.isTransformInProgress).isFalse()\\n        assertThat(zoom).isEqualTo(3f)\\n        assertThat(pan).isEqualTo(Offset(4f, 3f))\\n        assertThat(rotation).isEqualTo(55f)\\n    }\\n\\n    @Test\\n    fun tooltipStateTracksVisibilityPersistenceAndDismissal() {\\n        val transientTooltip = BasicTooltipState(\\n            initialIsVisible = true,\\n            isPersistent = false,\\n            mutatorMutex = MutatorMutex()\\n        )\\n        val persistentTooltip = BasicTooltipState(\\n            initialIsVisible = false,\\n            isPersistent = true,\\n            mutatorMutex = MutatorMutex()\\n        )\\n\\n        assertThat(transientTooltip.isVisible).isTrue()\\n        assertThat(transientTooltip.isPersistent).isFalse()\\n        transientTooltip.dismiss()\\n        assertThat(transientTooltip.isVisible).isFalse()\\n\\n        assertThat(persistentTooltip.isVisible).isFalse()\\n        assertThat(persistentTooltip.isPersistent).isTrue()\\n        persistentTooltip.onDispose()\\n        assertThat(persistentTooltip.isVisible).isFalse()\\n    }\\n\\n    @Test\\n    fun marqueePagerGridAndSnapHelpersCalculateDeterministicGeometry() {\\n        val density = Density(density = 2f)\\n        val spacing = MarqueeSpacing.fractionOfContainer(0.25f)\\n        val fixedPageSize = PageSize.Fixed(24.dp)\\n        val fixedCells = GridCells.Fixed(3)\\n        val span = GridItemSpan(3)\\n        val snapDistance = PagerSnapDistance.atMost(2)\\n\\n        assertThat(spacing.calculateSpacing(density, contentWidth = 80, containerWidth = 200)).isEqualTo(50)\\n        assertThat(PageSize.Fill.calculateMainAxisPageSize(density, availableSpace = 320, pageSpacing = 10)).isEqualTo(320)\\n        assertThat(fixedPageSize.calculateMainAxisPageSize(density, availableSpace = 320, pageSpacing = 10)).isEqualTo(48)\\n        assertThat(fixedCells.calculateCrossAxisCellSizes(density, availableSize = 100, spacing = 5)).containsExactly(30, 30, 30)\\n        assertThat(span.currentLineSpan).isEqualTo(3)\\n        assertThat(SnapPosition.Start.position(layoutSize = 100, itemSize = 20, beforeContentPadding = 10, afterContentPadding = 5, itemIndex = 0, itemCount = 10)).isEqualTo(10)\\n        assertThat(SnapPosition.Center.position(layoutSize = 100, itemSize = 20, beforeContentPadding = 10, afterContentPadding = 5, itemIndex = 0, itemCount = 10)).isEqualTo(42)\\n        assertThat(SnapPosition.End.position(layoutSize = 100, itemSize = 20, beforeContentPadding = 10, afterContentPadding = 5, itemIndex = 0, itemCount = 10)).isEqualTo(75)\\n        assertThat(snapDistance.calculateTargetPage(startPage = 5, suggestedTargetPage = 10, velocity = 1_000f, pageSize = 100, pageSpacing = 0)).isEqualTo(7)\\n        assertThat(snapDistance.calculateTargetPage(startPage = 5, suggestedTargetPage = 1, velocity = -1_000f, pageSize = 100, pageSpacing = 0)).isEqualTo(3)\\n    }\\n\\n    @Test\\n    fun lazyListAndGridStatesExposeInitialScrollAndEmptyLayoutInfo() {\\n        val lazyListState = LazyListState(firstVisibleItemIndex = 4, firstVisibleItemScrollOffset = 12)\\n        val lazyGridState = LazyGridState(firstVisibleItemIndex = 5, firstVisibleItemScrollOffset = 16)\\n\\n        assertThat(lazyListState.firstVisibleItemIndex).isEqualTo(4)\\n        assertThat(lazyListState.firstVisibleItemScrollOffset).isEqualTo(12)\\n        assertThat(lazyListState.layoutInfo.totalItemsCount).isZero()\\n        assertThat(lazyListState.layoutInfo.visibleItemsInfo).isEmpty()\\n\\n        assertThat(lazyGridState.firstVisibleItemIndex).isEqualTo(5)\\n        assertThat(lazyGridState.firstVisibleItemScrollOffset).isEqualTo(16)\\n        assertThat(lazyGridState.layoutInfo.totalItemsCount).isZero()\\n        assertThat(lazyGridState.layoutInfo.visibleItemsInfo).isEmpty()\\n    }\\n}\\n\"}\n42352:[recv] {\"type\": \"message_end\", \"message\": {\"role\": \"assistant\", \"content\": [{\"type\": \"thinking\", \"thinking\": \"\", \"thinkingSignature\": \"{\\\"id\\\":\\\"rs_00e76e8ad392