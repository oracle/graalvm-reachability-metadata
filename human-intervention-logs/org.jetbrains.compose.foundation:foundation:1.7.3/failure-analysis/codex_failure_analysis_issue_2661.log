)\\n+\\n+        assertThat(border).isEqualTo(sameBorder)\\n+        assertThat(border.width).isEqualTo(2.dp)\\n+        assertThat(border.toString()).contains(\\\"width=2.0.dp\\\")\\n+        assertThat(MediaType.PlainText.representation).isEqualTo(\\\"text/plain\\\")\\n+        assertThat(MediaType.HtmlText.toString()).isEqualTo(\\\"text/html\\\")\\n+        assertThat(customType.representation).isEqualTo(\\\"application/vnd.compose.test+json\\\")\\n+    }\\n+\\n+    @Test\\n+    fun mutatorMutexSupportsExplicitLockingTryMutationAndReceiverMutation() = runBlocking {\\n+        val mutex = MutatorMutex()\\n+        val events = mutableListOf<String>()\\n+\\n+        assertThat(mutex.tryLock()).isTrue()\\n+        assertThat(mutex.tryLock()).isFalse()\\n+        mutex.unlock()\\n+\\n+        val tryMutateSucceeded = mutex.tryMutate {\\n+            events += \\\"tryMutate\\\"\\n+        }\\n+        val mutatedLength = mutex.mutateWith(StringBuilder(\\\"compose\\\"), MutatePriority.UserInput) {\\n+            append(\\\" foundation\\\")\\n+            length\\n+        }\\n+        val mutateResult = mutex.mutate(MutatePriority.Default) {\\n+            events += \\\"mutate\\\"\\n+            \\\"completed\\\"\\n+        }\\n+\\n+        assertThat(tryMutateSucceeded).isTrue()\\n+        assertThat(mutatedLength).isEqualTo(\\\"compose foundation\\\".length)\\n+        assertThat(mutateResult).isEqualTo(\\\"completed\\\")\\n+        assertThat(events).containsExactly(\\\"tryMutate\\\", \\\"mutate\\\")\\n+    }\\n+\\n+    @Test\\n+    fun scrollableStateReportsConsumptionAndInProgressState() = runBlocking {\\n+        val consumedDeltas = mutableListOf<Float>()\\n+        val state = ScrollableState { delta ->\\n+            consumedDeltas += delta\\n+            delta / 2f\\n+        }\\n+\\n+        assertThat(state.dispatchRawDelta(18f)).isEqualTo(9f)\\n+        assertThat(state.isScrollInProgress).isFalse()\\n+\\n+        state.scroll {\\n+            assertThat(state.isScrollInProgress).isTrue()\\n+            assertThat(scrollBy(10f)).isEqualTo(5f)\\n+            assertThat(scrollBy(-4f)).isEqualTo(-2f)\\n+        }\\n+\\n+        assertThat(state.isScrollInProgress).isFalse()\\n+        assertThat(consumedDeltas).containsExactly(18f, 10f, -4f)\\n+    }\\n+\\n+    @Test\\n+    fun draggableStatesDeliverRawAndScopedDragDeltas() = runBlocking {\\n+        var oneDimensionalTotal = 0f\\n+        var twoDimensionalTotal = Offset.Zero\\n+        val draggable = DraggableState { delta ->\\n+            oneDimensionalTotal += delta\\n+        }\\n+        val draggable2D = Draggable2DState { delta ->\\n+            twoDimensionalTotal += delta\\n+        }\\n+\\n+        draggable.dispatchRawDelta(3f)\\n+        draggable.drag {\\n+            dragBy(7f)\\n+            dragBy(-2f)\\n+        }\\n+        draggable2D.dispatchRawDelta(Offset(1f, 2f))\\n+        draggable2D.drag {\\n+            dragBy(Offset(3f, -1f))\\n+            dragBy(Offset(-2f, 4f))\\n+        }\\n+\\n+        assertThat(oneDimensionalTotal).isEqualTo(8f)\\n+        assertThat(twoDimensionalTotal).isEqualTo(Offset(2f, 5f))\\n+    }\\n+\\n+    @Test\\n+    fun transformableStateCombinesZoomPanAndRotationChanges() = runBlocking {\\n+        var zoom = 1f\\n+        var pan = Offset.Zero\\n+        var rotation = 0f\\n+        val state = TransformableState { zoomChange, panChange, rotationChange ->\\n+            zoom *= zoomChange\\n+            pan += panChange\\n+            rotation += rotationChange\\n+        }\\n+\\n+        state.transform {\\n+            assertThat(state.isTransformInProgress).isTrue()\\n+            transformBy(zoomChange = 2f, panChange = Offset(3f, 4f), rotationChange = 15f)\\n+            transformBy(zoomChange = 0.5f, panChange = Offset(-1f, 1f), rotationChange = -5f)\\n+        }\\n+        state.zoomBy(3f)\\n+        state.panBy(Offset(2f, -2f))\\n+        state.rotateBy(45f)\\n+\\n+        assertThat(state.isTransformInProgress).isFalse()\\n+        assertThat(zoom).isEqualTo(3f)\\n+        assertThat(pan).isEqualTo(Offset(4f, 3f))\\n+        assertThat(rotation).isEqualTo(55f)\\n+    }\\n+\\n+    @Test\\n+    fun tooltipStateTracksVisibilityPersistenceAndDismissal() {\\n+        val transientTooltip = BasicTooltipState(\\n+            initialIsVisible = true,\\n+            isPersistent = false,\\n+            mutatorMutex = MutatorMutex()\\n+        )\\n+        val persistentTooltip = BasicTooltipState(\\n+            initialIsVisible = false,\\n+            isPersistent = true,\\n+            mutatorMutex = MutatorMutex()\\n+        )\\n+\\n+        assertThat(transientTooltip.isVisible).isTrue()\\n+        assertThat(transientTooltip.isPersistent).isFalse()\\n+        transientTooltip.dismiss()\\n+        assertThat(transientTooltip.isVisible).isFalse()\\n+\\n+        assertThat(persistentTooltip.isVisible).isFalse()\\n+        assertThat(persistentTooltip.isPersistent).isTrue()\\n+        persistentTooltip.onDispose()\\n+        assertThat(persistentTooltip.isVisible).isFalse()\\n+    }\\n+\\n+    @Test\\n+    fun marqueePagerGridAndSnapHelpersCalculateDeterministicGeometry() {\\n+        val density = Density(density = 2f)\\n+        val spacing = MarqueeSpacing.fractionOfContainer(0.25f)\\n+        val fixedPageSize = PageSize.Fixed(24.dp)\\n+        val fixedCells = GridCells.Fixed(3)\\n+        val span = GridItemSpan(3)\\n+        val snapDistance = PagerSnapDistance.atMost(2)\\n+\\n+        assertThat(spacing.calculateSpacing(density, 80, 200)).isEqualTo(50)\\n+        assertThat(PageSize.Fill.calculateMainAxisPageSize(density, 320, 10)).isEqualTo(320)\\n+        assertThat(fixedPageSize.calculateMainAxisPageSize(density, 320, 10)).isEqualTo(48)\\n+        assertThat(fixedCells.calculateCrossAxisCellSizes(density, 100, 5)).containsExactly(30, 30, 30)\\n+        assertThat(span.currentLineSpan).isEqualTo(3)\\n+        assertThat(SnapPosition.Start.position(100, 20, 10, 5, 0, 