        } else if (Character.isDigit(next)) {
          sb.append(next);
          capNext = true;
        } else if (capNext) {
          sb.append(Character.toUpperCase(next));
          capNext = false;
        } else if (ctr == 0) {
          sb.append(Character.toLowerCase(next));
