ance()\n\n    assertEquals(7, message.getCount)\n    assertTrue(message.getSerializedSize > 0)\n  }\n\n  @Test\n  def reportsMissingRawMessageInfoFieldsWithDeclaredFieldDetails(): Unit = {\n    val thrown: RuntimeException = assertThrows(classOf[RuntimeException], new Executable {\n      override def execute(): Unit = MessageSchemaMissingFieldLiteMessage.getDefaultInstance().getSerializedSize\n    })\n\n    assertTrue(thrown.getMessage.contains(\"missing_\"))\n    assertTrue(thrown.getMessage.contains(\"Known fields\"))\n  }\n}\n\nfinal class MessageSchemaFieldBackedLiteMessage private (private var count_ : Int)\n    extends GeneratedMessageLite[MessageSchemaFieldBackedLiteMessage, MessageSchemaFieldBackedLiteMessage.Builder] {\n  def getCount: Int = count_\n\n  override protected def dynamicMethod(method: MethodToInvoke, arg0: AnyRef, arg1: AnyRef): AnyRef = {\n    method match {\n      case MethodToInvoke.NEW_MUTABLE_INSTANCE => new MessageSchemaFieldBackedLiteMessage(0)\n      case MethodToInvoke.NEW_BUILDER => new MessageSchemaFieldBackedLiteMessage.Builder()\n      case MethodToInvoke.BUILD_MESSAGE_INFO =>\n        newMessageInfo(\n          MessageSchemaFieldBackedLiteMessage.DefaultInstance,\n          \"\\u0000\\u0001\\u0000\\u0000\\u0001\\u0001\\u0001\\u0000\\u0000\\u0000\\u0001\\u0004\",\n          Array[AnyRef](\"count_\"))\n      case MethodToInvoke.GET_DEFAULT_INSTANCE => MessageSchemaFieldBackedLiteMessage.DefaultInstance\n      case MethodToInvoke.GET_PARSER => null\n      case MethodToInvoke.GET_MEMOIZED_IS_INITIALIZED => Byte.box(1.toByte)\n      case MethodToInvoke.SET_MEMOIZED_IS_INITIALIZED => null\n    }\n  }\n}\n\nobject MessageSchemaFieldBackedLiteMessage {\n  private val DefaultInstance: MessageSchemaFieldBackedLiteMessage = new MessageSchemaFieldBackedLiteMessage(7)\n\n  def getDefaultInstance(): MessageSchemaFieldBackedLiteMessage = DefaultInstance\n\n  final class Builder private[pekko_protobuf_v3_3] ()\n      extends GeneratedMessageLite.Builder[MessageSchemaFieldBackedLiteMessage, Builder](DefaultInstance)\n}\n\nfinal class MessageSchemaMissingFieldLiteMessage private ()\n    extends GeneratedMessageLite[MessageSchemaMissingFieldLiteMessage, MessageSchemaMissingFieldLiteMessage.Builder] {\n  private var present_ : Int = 11\n\n  def getPresent: Int = present_\n\n  override protected def dynamicMethod(method: MethodToInvoke, arg0: AnyRef, arg1: AnyRef): AnyRef = {\n    method match {\n      case MethodToInvoke.NEW_MUTABLE_INSTANCE => new MessageSchemaMissingFieldLiteMessage()\n      case MethodToInvoke.NEW_BUILDER => new MessageSchemaMissingFieldLiteMessage.Builder()\n      case MethodToInvoke.BUILD_MESSAGE_INFO =>\n        newMessageInfo(\n          MessageSchemaMissingFieldLiteMessage.DefaultInstance,\n          \"\\u0000\\u0001\\u0000\\u0000\\u0001\\u0001\\u0001\\u0000\\u0000\\u0000\\u0001\\u0004\",\n          Array[AnyRef](\"missing_\"))\n      case MethodToInvoke.GET_DEFAULT_INSTANCE => MessageSchemaMissingFieldLiteMessage.DefaultInstance\n      case MethodToInvoke.GET_PARSER => null\n      case MethodToInvoke.GET_MEMOIZED_IS_INITIALIZED => Byte.box(1.toByte)\n      case MethodToInvoke.SET_MEMOIZED_IS_INITIALIZED => null\n    }\n  }\n}\n\nobject MessageSchemaMissingFieldLiteMessage {\n  private val DefaultInstance: MessageSchemaMissingFieldLiteMessage = new MessageSchemaMissingFieldLiteMessage()\n\n  def getDefaultInstance(): MessageSchemaMissingFieldLiteMessage = DefaultInstance\n\n  final class Builder private[pekko_protobuf_v3_3] ()\n      extends GeneratedMessageLite.Builder[MessageSchemaMissingFieldLiteMessage, Builder](DefaultInstance)\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 2388, "output": 1745, "cacheRead": 30720, "cacheWrite": 0, "totalTokens": 34853, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777572001385, "responseId": "resp_09d6fbc918faccb20169f398a2a6b8