      MethodHandles.lookup()
    )
  
    private val GetMethodOrDie: MethodHandle = Lookup.findStatic(
      GeneratedMessageLiteClass,
      "getMethodOrDie",
      MethodType.methodType(classOf[Method], classOf[Class[_]], classOf[String], classOf[Array[Class[_]]])
