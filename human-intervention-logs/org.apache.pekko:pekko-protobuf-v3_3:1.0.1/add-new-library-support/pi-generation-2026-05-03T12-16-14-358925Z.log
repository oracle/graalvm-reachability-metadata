[tool-call] delta {"path":"tests/src/org.apache.pekko/pekko-protobuf-v3_3/1.0.1/src/test/scala/org_apache_pekko/pekko_protobuf_v3_3/UnsafeUtilTest.scala","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage libcore.io\n\nclass Memory {\n  def peekLong(address: Long, swap: Boolean): Long = 0L\n\n  def peekLong(address: Int, swap: Boolean): Long = 0L\n\n  def pokeLong(address: Long, value: Long, swap: Boolean): Unit = ()\n\n  def pokeLong(address: Int, value: Long, swap: Boolean): Unit = ()\n\n  def pokeInt(address: Long, value: Int, swap: Boolean): Unit = ()\n\n  def pokeInt(address: Int, value: Int, swap: Boolean): Unit = ()\n\n  def peekInt(address: Long, swap: Boolean): Int = 0\n\n  def peekInt(address: Int, swap: Boolean): Int = 0\n\n  def pokeByte(address: Long, value: Byte): Unit = ()\n\n  def pokeByte(address: Int, value: Byte): Unit = ()\n\n  def peekByte(address: Long): Byte = 0.toByte\n\n  def peekByte(address: Int): Byte = 0.toByte\n\n  def pokeByteArray(address: Long, bytes: Array[Byte], offset: Int, length: Int): Unit = ()\n\n  def pokeByteArray(address: Int, bytes: Array[Byte], offset: Int, length: Int): Unit = ()\n\n  def peekByteArray(address: Long, bytes: Array[Byte], offset: Int, length: Int): Unit = ()\n\n  def peekByteArray(address: Int, bytes: Array[Byte], offset: Int, length: Int): Unit = ()\n}\n\npackage org_apache_pekko.pekko_protobuf_v3_3\n\nimport org.apache.pekko.protobufv3.internal.CodedOutputStream\nimport org.apache.pekko.protobufv3.internal.GeneratedMessageLite\nimport org.apache.pekko.protobufv3.internal.GeneratedMessageLite.MethodToInvoke\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\n\nclass UnsafeUtilTest {\n  @Test\n  def codedOutputStreamInitializesUnsafeAccessors(): Unit = {\n    val buffer: Array[Byte] = new Array[Byte](32)\n    val output: CodedOutputStream = CodedOutputStream.newInstance(buffer)\n\n    output.writeUInt32NoTag(150)\n    output.writeStringNoTag(\"pekko\")\n    output.flush()\n\n    assertThat(output.spaceLeft()).isLessThan(buffer.length)\n  }\n\n  @Test\n  def generatedMessageLiteFallbackAllocatesDefaultInstance(): Unit = {\n    val method = classOf[GeneratedMessageLite[?, ?]].getDeclaredMethod(\"getDefaultInstance\", classOf[Class[?]])\n    method.setAccessible(true)\n\n    val defaultInstance = method.invoke(null, classOf[MinimalLiteMessage]).asInstanceOf[MinimalLiteMessage]\n\n    assertThat(defaultInstance).isSameAs(MinimalLiteMessage.DefaultInstance)\n  }\n}\n\nfinal class MinimalLiteMessage extends GeneratedMessageLite[MinimalLiteMessage, MinimalLiteMessage.Builder] {\n  override protected def dynamicMethod(method: MethodToInvoke, arg0: Object, arg1: Object): Object = {\n    method match {\n      case MethodToInvoke.GET_DEFAULT_INSTANCE => MinimalLiteMessage.DefaultInstance\n      case MethodToInvoke.NEW_MUTABLE_INSTANCE => new MinimalLiteMessage()\n      case MethodToInvoke.NEW_BUILDER => new MinimalLiteMessage.Builder()\n      case MethodToInvoke.GET_MEMOIZED_IS_INITIALIZED => java.lang.Byte.valueOf(1.toByte)\n      case MethodToInvoke.SET_MEMOIZED_IS_INITIALIZED => null\n      case MethodToInvoke.GET_PARSER =>\n        new GeneratedMessageLite.DefaultInstanceBasedParser[MinimalLiteMessage](MinimalLiteMessage.DefaultInstance)\n      case MethodToInvoke.BUILD_MESSAGE_INFO => throw new UnsupportedOperationException(method.name())\n    }\n  }\n}\n\nobject MinimalLiteMessage {\n  val DefaultInstance: MinimalLiteMessage = new MinimalLiteMessage()\n\n  final class Builder extends GeneratedMessageLite.Builder[MinimalLiteMessage, Builder](DefaultInstance)\n}\n"}
