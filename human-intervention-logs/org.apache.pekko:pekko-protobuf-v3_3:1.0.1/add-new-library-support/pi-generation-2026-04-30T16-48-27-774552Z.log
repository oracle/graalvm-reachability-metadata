ngthDelimitedPayloadThroughCodedOutputStream(): Unit = {\n      val buffer: Array[Byte] = Array.fill[Byte](5)(0.toByte)\n      val payload: Array[Byte] = Array[Byte](1.toByte, 2.toByte, 3.toByte, 4.toByte)\n      val output: CodedOutputStream = CodedOutputStream.newInstance(buffer)\n\n      output.writeByteArrayNoTag(payload)\n      output.flush()\n\n      assertEquals(0, output.spaceLeft())\n      assertArrayEquals(Array[Byte](4.toByte, 1.toByte, 2.toByte, 3.toByte, 4.toByte), buffer)\n    }\n  }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 532, "output": 1219, "cacheRead": 36864, "cacheWrite": 0, "totalTokens": 38615, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777567652873, "responseId": "resp_061844c4710a40310169f387a59cc08190940e6db8b147070b"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_KDTIhiVbasteFQHoxsDT4dip|fc_061844c4710a40310169f387b0ae608190a33ec642491debf2", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2157 bytes to tests/src/org.apache.pekko/pekko-protobuf-v3_3/1.0.1/src/test/scala/org_apache_pekko/pekko_protobuf_v3_3/UnsafeUtilTest.scala"}], "isError": false, "timestamp": 1777567668933}]}
