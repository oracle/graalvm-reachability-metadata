          Configuration.UpperCaseTags = false;
          Configuration.MakeClean     = false;
          Configuration.writeback     = false;
          Configuration.OnlyErrors    = false;
          */
  
          configuration.errfile = null;
          stderr = new PrintWriter(System.err, true);
          errout = stderr;
          initialized = true;
      }
  
      /**
