dByReportInitializer() {\n        StringWriter output = new StringWriter();\n\n        Report.generalInfo(new PrintWriter(output, true));\n\n        assertThat(output.toString())\n                .contains(\"HTML & CSS specifications\")\n                .contains(\"http://www.w3.org/\");\n    }\n}\n"}]}
