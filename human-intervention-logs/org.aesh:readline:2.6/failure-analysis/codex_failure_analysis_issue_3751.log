\n    private boolean nativeSignals = true;\\n\\n    private TerminalBuilder() {\\n    }\\n\\n    private TerminalBuilder apply(Consumer<TerminalBuilder> consumer)  {\\n        consumer.accept(this);\\n        return this;\\n    }\\n\\n    public TerminalBuilder name(String name) {\\n        return apply(c -> c.name = name);\\n    }\\n\\n    public TerminalBuilder input(InputStream in) {\\n        return apply(c -> c.in = in);\\n    }\\n\\n    public TerminalBuilder output(OutputStream out) {\\n        return apply(c -> c.out = out);\\n    }\\n\\n    public TerminalBuilder system(boolean system) {\\n        return apply(c -> c.system = system);\\n    }\\n\\n    public TerminalBuilder nativeSignals(boolean nativeSignals) {\\n        return apply(c -> c.nativeSignals = nativeSignals);\\n    }\\n\\n    public TerminalBuilder type(String type) {\\n        return apply(c -> c.type = type);\\n    }\\n\\n    public Terminal build() throws IOException {\\n        String name = this.name;\\n        if (name == null) {\\n            name = \\\"Aesh console\\\";\\n        }\\n        if ((system != null && system)\\n                || (system == null\\n                    && (in == null || in == System.in)\\n                    && (out == null || out == System.out))) {\\n\\n            // Cygwin support\\n            if (OSUtils.IS_CYGWIN) {\\n                String type = this.type;\\n                if (type == null) {\\n                    type = System.getenv(\\\"TERM\\\");\\n                }\\n                try {\\n                    Pty pty = CygwinPty.current();\\n                    return new PosixSysTerminal(name, type, pty, nativeSignals);\\n                }\\n                catch(IOException ioe) {\\n                    //we might have a windows terminal created from cygwin..\\n                    return createWindowsTerminal(name);\\n                }\\n            }\\n            else if (OSUtils.IS_WINDOWS) {\\n                return createWindowsTerminal(name);\\n            }\\n            else {\\n                String type = this.type;\\n                if (type == null) {\\n                    type = System.getenv(\\\"TERM\\\");\\n                }\\n                Pty pty = null;\\n                try {\\n                    pty = ExecPty.current();\\n                }\\n                catch (IOException e) {\\n                    LOGGER.log(Level.FINE, \\\"Failed to get a local tty\\\", e);\\n                }\\n                if (pty != null) {\\n                    return new PosixSysTerminal(name, type, pty, nativeSignals);\\n                } else {\\n                    return new ExternalTerminal(name, type, (in == null) ? System.in : in, (out == null) ? System.out : out);\\n                }\\n            }\\n        }\\n        else {\\n            return new ExternalTerminal(name, type, (in == null) ? System.in : in,\\n                    (out == null) ? System.out : out);\\n        }\\n    }\\n\\n    private Terminal createWindowsTerminal(String name) throws IOException {\\n        try {\\n            Console console = System.console();\\n            if (console != null && isTerminal(console)) // a native terminal, not redirects etc\\n                return new WinSysTerminal(name, nativeSignals);\\n            else {\\n                return new WinExternalTerminal(name, type, (in == null) ? System.in : in,\\n                        (out == null) ? System.out : out);\\n            }\\n        }\\n        catch(IOException e) {\\n            return new WinExternalTerminal(name, type, (in == null) ? System.in : in,\\n                    (out == null) ? System.out : out);\\n        }\\n    }\\n\\n    // Console.isTerminal() was introduced in Java 22\\n    private static boolean isTerminal(Console console) {\\n        if (console == null) {\\n            return false;\\n        }\\n        try {\\n            Method isTerminal = Console.class.getMethod(\\\"isTerminal\\\");\\n            try {\\n                return (boolean) isTerminal.invoke(console);\\n            } catch (Exception e) {\\n                LOGGER.log(Level.SEVERE, \\\"Failed to invoke System.console().isTerminal() via Reflection API\\\", e);\\n                return false;\\n            }\\n        } catch (NoSuchMethodException e) {\\n            return true; // for Java <= 21\\n        }\\n    }\\n}\\n\"}], \"isError\": false, \"timestamp\": 1777663200735}]}\n/home/vjovanov/c/forge/forge9/graalvm-reachability-metadata/forge/logs/org.aesh:readline:2.6/add-new-library-support/pi-generation-2026-05-01T19-22-36-105024Z.log:1521:[recv] {\"type\": \"message_end\", \"message\": {\"role\": \"assistant\", \"content\": [{\"type\": \"thinking\", \"thinking\": \"**Inspecting API options**\\n\\nI'm wondering if the public API is insufficient for my needs. Could there be a way to manipulate the environment instead? It might be useful to check out OSUtils to see what functionalities are available there. I'll need to think carefully about how to utilize any potential resources effectively. There’s definitely potential for expanded capabilities, but I'll need to clarify what options OSUtils offers!\", \"thinkingSignature\": \"{\\\"id\\\":\\\"rs_094e590b8efbae2c0169f4fce2baf081939e9a5e4720a03df5\\\",\\\"type\\\":\\\"reasoning\\\",\\\"encrypted_content\\\":\\\"gAAAAABp9PzoXLB5G3VUpPmIJdz3DqVs4AVKXk3mR39rFBVGzKsrcHbyb6jBAAPHoLHoKj6hKxtfSTmo5Ut8aQNMMKbwgth70oBrHGTRcUN5f4BzCk8V-NPcT1pQHmbMFnrS5lytk1iOulENZ4IXtSG8ol0auID4KLnFf3DQwcCMEok7E7uC4dkOFxnAzdDOLmOdcIvVjLUE4WSXRLeu6e9u3EJls3Gsng6lZxHnnHanF9s7ksQJ566PNmLJn92ZNlSIiybWu5HsqZ83Q_jqAFNxJUbe2p77UEOedYtgnBcaNMkcsCGXjn8-ROWhskJF7CqPFSKwUhZXknz_BXt9-fGophHUBeWYq9aJZZzW4QbjYd0z8L_xel7onFjliXdYAwa06Ea-beVjYl1Nb6KvwNTu-30xM24iwJxdrLkynDIcKqpex12wUdUGdfKOX8HUR7WIcE3wBcKhYv4Llc4yVbGhPs3G1HVV6XBk3iUSsTkZk3F37kSN1yPQPhRs63yTNTGoffWUO8qHBzolv4IOSKc7YSf1AgglEjQ_zJOQzwA6fbY8oixdgFGp0G49SD4-PgZ3vzcwK4FCVP2QUFF6hDDxkiHLqQfEXxgdJSmjrAQ7_ro8BkS-98oEmocsqyU2iIIpCBG1TmYs8_J8_qa