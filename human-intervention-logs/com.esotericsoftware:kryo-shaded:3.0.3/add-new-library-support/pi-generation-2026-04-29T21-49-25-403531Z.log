d;\n\nimport com.esotericsoftware.kryo.Kryo;\nimport com.esotericsoftware.kryo.io.Input;\nimport com.esotericsoftware.kryo.io.Output;\nimport com.esotericsoftware.kryo.serializers.FieldSerializer;\nimport com.esotericsoftware.kryo.util.IntArray;\nimport org.junit.jupiter.api.Test;\n\nimport java.util.Arrays;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class FieldSerializerTest {\n    @Test\n    void serializesAndCopiesFieldsFromRegisteredLibraryType() {\n        Kryo kryo = new Kryo();\n        FieldSerializer<IntArray> serializer = new FieldSerializer<>(kryo, IntArray.class);\n        kryo.register(IntArray.class, serializer);\n\n        IntArray original = new IntArray(false, new int[] {7, 11, 42});\n        Output output = new Output(128, -1);\n        serializer.write(kryo, output, original);\n\n        IntArray restored = serializer.read(kryo, new Input(output.toBytes()), IntArray.class);\n        IntArray copied = serializer.copy(kryo, original);\n\n        assertThat(serializer.getFields()).hasSizeGreaterThanOrEqualTo(3);\n        assertThat(restored.ordered).isFalse();\n        assertThat(restored.size).isEqualTo(original.size);\n        assertThat(values(restored)).containsExactly(7, 11, 42);\n        assertThat(copied).isNotSameAs(original);\n        assertThat(copied.ordered).isFalse();\n        assertThat(values(copied)).containsExactly(7, 11, 42);\n    }\n\n    @Test\n    void rebuildsCachedFieldsWhenSerializerConfigurationChanges() {\n        Kryo kryo = new Kryo();\n        FieldSerializer<IntArray> serializer = new FieldSerializer<>(kryo, IntArray.class);\n        kryo.register(IntArray.class, serializer);\n\n        serializer.setFieldsCanBeNull(false);\n        serializer.setFixedFieldTypes(true);\n        serializer.setIgnoreSyntheticFields(false);\n\n        IntArray original = new IntArray(true, new int[] {3, 1, 4, 1, 5});\n        Output output = new Output(128, -1);\n        serializer.write(kryo, output, original);\n\n        IntArray restored = serializer.read(kryo, new Input(output.toBytes()), IntArray.class);\n\n        assertThat(restored.ordered).isTrue();\n        assertThat(restored.size).isEqualTo(original.size);\n        assertThat(values(restored)).containsExactly(3, 1, 4, 1, 5);\n    }\n\n    private static int[] values(IntArray array) {\n        return Arrays.copyOf(array.items, array.size);\n    }\n}\n"}, "partialJson": "{\"path\":\"tests/src/com.esotericsoftware/kryo-shaded/3.0.3/src/test/java/com_esotericsoftware/kryo_shaded/FieldSerializerTest.java\",\"content\":\"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage com_esotericsoftware.kryo_shaded;\\n\\nimport com.esotericsoftware.kryo.Kryo;\\nimport com.esotericsoftware.kryo.io.Input;\\nimport com.esotericsoftware.kryo.io.Output;\\nimport com.esotericsoftware.kryo.serializers.FieldSerializer;\\nimport com.esotericsoftware.kryo.util.IntArray;\\nimport org.junit.jupiter.api.Test;\\n\\nimport java.util.Arrays;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\n\\npublic class FieldSerializerTest {\\n    @Test\\n    void serializesAndCopiesFieldsFromRegisteredLibraryType() {\\n        Kryo kryo = new Kryo();\\n        FieldSerializer<IntArray> serializer = new FieldSerializer<>(kryo, IntArray.class);\\n        kryo.register(IntArray.class, serializer);\\n\\n        IntArray original = new IntArray(false, new int[] {7, 11, 42});\\n        Output output = new Output(128, -1);\\n        serializer.write(kryo, output, original);\\n\\n        IntArray restored = serializer.read(kryo, new Input(output.toBytes()), IntArray.class);\\n        IntArray copied = serializer.copy(kryo, original);\\n\\n        assertThat(serializer.getFields()).hasSizeGreaterThanOrEqualTo(3);\\n        assertThat(restored.ordered).isFalse();\\n        assertThat(