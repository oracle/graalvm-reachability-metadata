95e", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_esotericsoftware.kryo_shaded;\n\nimport com.esotericsoftware.kryo.Kryo;\nimport com.esotericsoftware.kryo.io.Input;\nimport com.esotericsoftware.kryo.io.Output;\nimport com.esotericsoftware.kryo.serializers.DefaultSerializers.BigDecimalSerializer;\nimport org.junit.jupiter.api.Test;\n\nimport java.math.BigDecimal;\nimport java.math.BigInteger;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class DefaultSerializersInnerBigDecimalSerializerTest {\n    @Test\n    void readsBigDecimalSubclassUsingPublicBigIntegerScaleConstructor() {\n        Kryo kryo = new Kryo();\n        BigDecimalSerializer serializer = new BigDecimalSerializer();\n        ConstructorTrackingBigDecimal original = new ConstructorTrackingBigDecimal(\n                new BigInteger(\"123456789012345678901234567890\"),\n                12);\n\n        Output output = new Output(128, -1);\n        kryo.writeObject(output, original, serializer);\n\n        ConstructorTrackingBigDecimal restored = kryo.readObject(\n                new Input(output.toBytes()),\n                ConstructorTrackingBigDecimal.class,\n                serializer);\n\n        assertThat(restored).isInstanceOf(ConstructorTrackingBigDecimal.class);\n        assertThat(restored).isEqualTo(original);\n        assertThat(restored.scale()).isEqualTo(original.scale());\n        assertThat(restored.wasCreatedByBigIntegerScaleConstructor()).isTrue();\n    }\n\n    public static final class ConstructorTrackingBigDecimal extends BigDecimal {\n        private static final long serialVersionUID = 1L;\n\n        private final boolean createdByBigIntegerScaleConstructor;\n\n        public ConstructorTrackingBigDecimal(BigInteger unscaledValue, int scale) {\n            super(unscaledValue, scale);\n            this.createdByBigIntegerScaleConstructor = true;\n        }\n\n        boolean wasCreatedByBigIntegerScaleConstructor() {\n            return createdByBigIntegerScaleConstructor;\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777506125698}, {"role": "toolResult", "toolCallId": "call_tyo4rHJgwEHMxTKKfw14sCL3|fc_07ddbd239412428b0169f2974d4b30819484234bbef44aba01", "toolName": "read", "content": [{"type": "text", "text": "ENOENT: no such file or directory, access '/home/jovan/Work/graalvm-reachability-metadata/forge/local_repositories/forge_worktrees/3033-b38ecf97/local_repositories/source_context/com.esotericsoftware/kryo-shaded/3.0.3/main/extracted/com/esotericsoftware/kryo/serializers/DefaultSerializers.java'"}], "details": {}, "isError": true, "timestamp": 1777506125699}, {"role": "toolResult", "toolCallId": "call_kmynGv7CpoyJ0CMK8U5Z6pHN|fc_07ddbd239412428b0169f2974d4b38819480566807a81548b3", "toolName": "bash", "content": [{"type": "text", "text": "tests/src/com.esotericsoftware/kryo-shaded/3.0.3/src/test/java/com_esotericsoftware/kryo_shaded/DefaultArraySerializersInnerObjectArraySerializerTest.java\ntests/src/com.esotericsoftware/kryo-shaded/3.0.3/src/test/java/com_esotericsoftware/kryo_shaded/FieldSerializerGenericsUtilTest.java\ntests/src/com.esotericsoftware/kryo-shaded/3.0.3/src/test/java/com_esotericsoftware/kryo_shaded/FieldSerializerTest.java\ntests/src/com.esotericsoftware/kryo-shaded/3.0.3/src/test/java/com_esotericsoftware/kryo_shaded/ObjectFieldInnerObjectShortFieldTest.java\ntests/src/com.esotericsoftware/kryo-shaded/3.0.3/src/test/java/com_esotericsoftware/kryo_shaded/ObjectFieldInnerObjectByteFieldTest.java\ntests/src/com.esotericsoftware/kryo-shaded/3.0.3/src/test/java/com_esotericsoftware/kryo_shaded/MethodAccessTest.java\ntests/src/com.esotericsoftware/kryo-shaded/3.0.3/src/test/java/com_esotericsoftware/kryo_shaded/ObjectFieldInnerObjectFloatFieldTest.java\ntest