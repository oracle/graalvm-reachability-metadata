      public static LibraryStatsModels.VersionStats buildVersionStatsWithoutDynamicAccess(
              String coordinate,
              Path jacocoReport
      ) {
          ParsedJacocoReport parsedJacocoReport = parseJacocoReport(jacocoReport);
