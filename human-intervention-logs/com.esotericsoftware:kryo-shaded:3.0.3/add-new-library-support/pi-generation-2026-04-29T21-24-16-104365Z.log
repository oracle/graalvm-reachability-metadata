yo_shaded;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.util.Arrays;\nimport java.util.List;\nimport java.util.stream.Collectors;\n\nimport org.junit.jupiter.api.Test;\n\nimport com.esotericsoftware.kryo.Kryo;\nimport com.esotericsoftware.kryo.io.Input;\nimport com.esotericsoftware.kryo.io.Output;\nimport com.esotericsoftware.kryo.serializers.FieldSerializer;\nimport com.esotericsoftware.kryo.util.IntArray;\n\npublic class FieldSerializerTest {\n    @Test\n    void discoversAndRebuildsCachedFieldsForLibraryTypes() {\n        Kryo kryo = newKryo();\n        FieldSerializer<IntArray> serializer = new FieldSerializer<>(kryo, IntArray.class);\n\n        assertThat(serializer.getType()).isEqualTo(IntArray.class);\n        assertThat(fieldNames(serializer)).containsExactly(\"items\", \"ordered\", \"size\");\n\n        serializer.setFieldsCanBeNull(false);\n\n        assertThat(fieldNames(serializer)).containsExactly(\"items\", \"ordered\", \"size\");\n    }\n\n    @Test\n    void serializesCopiesAndReadsObjectsThroughCachedFields() {\n        Kryo kryo = newKryo();\n        FieldSerializer<IntArray> serializer = new FieldSerializer<>(kryo, IntArray.class);\n        IntArray original = new IntArray(false, new int[] {3, 1, 4});\n\n        IntArray copied = serializer.copy(kryo, original);\n        IntArray restored = readFromBytes(kryo, serializer, writeToBytes(kryo, serializer, original));\n\n        assertThat(copied).isNotSameAs(original);\n        assertThat(copied.ordered).isFalse();\n        assertThat(copied.toArray()).containsExactly(3, 1, 4);\n        assertThat(restored.ordered).isFalse();\n        assertThat(restored.toArray()).containsExactly(3, 1, 4);\n    }\n\n    private static Kryo newKryo() {\n        Kryo kryo = new Kryo();\n        kryo.setRegistrationRequired(false);\n        kryo.setAsmEnabled(false);\n        return kryo;\n    }\n\n    private static List<String> fieldNames(FieldSerializer<?> serializer) {\n        return Arrays.stream(serializer.getFields())\n                .map(Object::toString)\n                .collect(Collectors.toList());\n    }\n\n    private static byte[] writeToBytes(Kryo kryo, FieldSerializer<IntArray> serializer, IntArray value) {\n        Output output = new Output(256, -1);\n        serializer.write(kryo, output, value);\n        output.close();\n        return output.toBytes();\n    }\n\n    private static IntArray readFromBytes(Kryo kryo, FieldSerializer<IntArray> serializer, byte[] bytes) {\n        Input input = new Input(bytes);\n        IntArray value = serializer.read(kryo, input, IntArray.class);\n        input.close();\n        return value;\n    }\n}\n"}, "partialJson": "{\"path\":\"tests/src/com.esotericsoftware/kryo-shaded/3.0.3/src/test/java/com_esotericsoftware/kryo_shaded/FieldSerializerTest.java\",\"content\":\"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage com_esotericsoftware.kryo_shaded;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\n\\nimport java.util.Arrays;\\nimport java.util.List;\\nimport java.util.stream.Collectors;\\n\\nimport org.junit.jupiter.api.Test;\\n\\nimport com.esotericsoftware.kryo.Kryo;\\nimport com.esotericsoftware.kryo.io.Input;\\nimport com.esotericsoftware.kryo.io.Output;\\nimport com.esotericsoftware.kryo.serializers.FieldSerializer;\\nimport com.esotericsoftware.kryo.util.IntArray;\\n\\npublic class FieldSerializerTest {\\n    @Test\\n    void discoversAndRebuildsCachedFieldsForLibraryTypes() {\\n        Kryo kryo = newKryo();\\n        FieldSerializer<IntArray> serializer = new FieldSerializer<>(kryo, IntArray.class);\\n\\n        assertThat(serializer.getType()).isEqualTo(IntArray.class);\\n        assertThat(fieldNames(serializer)).containsExactly(\\\"items\\\", \\\"ordered\\\", \\\"size\\\");\\n\\n        serializer.setFieldsCanBeNull(false);\\n\\n        assertThat(fieldNames(serializer)).containsExactly(\\\"items\\\", \\\"ordered\\\", \\\"size\\\");\\n    }\\n\\n    @Test\\n    void serializesCopiesAndReadsObjectsThroughCachedFields() {\\n        Kryo kryo = newKryo();\\n        FieldSerializer<IntArray> serializer = new FieldSerializer<>(kryo, IntArray.class);\\n        IntArray original = new IntArray(false, new int[] {3, 1, 4});\\n\\n        IntArray copied = serializer.copy(kryo, original);\\n        IntArray restored = readFromBytes(kryo, serializer, writeToBytes(kryo, serializer, original));\\n\\n        assertThat(copied).isNotSameAs(original);\\n        assertThat(copied.ordered).isFalse();\\n        assertThat(copied.toArray()).containsExactly(3, 1, 4);\\n        assertThat(restored.ordered).isFalse();\\n        assertThat(restored.toArray()).containsExactly(3, 1, 4);\\n    }\\n\\n    private static Kryo newKryo() {\\n        Kryo kryo = new Kryo();\\n        kryo.setRegistrationRequired(false);\\n        kryo.setAsmEnabled(false);\\n        return kryo;\\n    }\\n\\n    private static List<String> fieldNames(FieldSerializer<?> serializer) {\\n        return Arrays.stream(serializer.getFields())\\n                .map(Object::toString)\\n                .collect(Collectors.toList());\\n    }\\n\\n    private static byte[] writeToBytes(Kryo kryo, FieldSerializer<IntArray> serializer, IntArray value) {\\n        Output output = new Output(256, -1);\\n        serializer.write(kryo, output, value);\\n        output.close();\\n        return output.toBytes();\\n    }\\n\\n    private static IntArray readFromBytes(Kryo kryo, FieldSerializer<IntArray> serializer, byte[] bytes) {\\n        Input input = new Input(bytes);\\n        IntArray value = serializer.read(kryo, input, IntArray.class);\\n        input.close();\\n        return value;\\n    }\\n}\\n\"}"}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 799, "output": 1715, "cache