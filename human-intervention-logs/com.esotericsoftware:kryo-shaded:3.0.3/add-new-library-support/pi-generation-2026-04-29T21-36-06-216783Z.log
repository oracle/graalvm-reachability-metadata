  diff --git a/tests/src/com.esotericsoftware/kryo-shaded/3.0.3/src/test/java/com_esotericsoftware/kryo_shaded/ClosureSerializerTest.java b/tests/src/com.esotericsoftware/kryo-shaded/3.0.3/src/test/java/com_esotericsoftware/kryo_shaded/ClosureSerializerTest.java
  new file mode 100644
  index 000000000..95929ceec
  --- /dev/null
  +++ b/tests/src/com.esotericsoftware/kryo-shaded/3.0.3/src/test/java/com_esotericsoftware/kryo_shaded/ClosureSerializerTest.java
  @@ -0,0 +1,72 @@
  +/*
  + * Copyright and related rights waived via CC0
  + *
  + * You should have received a copy of the CC0 legalcode along with this
  + * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.
  + */
  +package com_esotericsoftware.kryo_shaded;
  +
  +import static org.assertj.core.api.Assertions.assertThat;
  +
  +import java.io.Serializable;
  +
  +import org.junit.jupiter.api.Test;
  +
  +import com.esotericsoftware.kryo.Kryo;
  +import com.esotericsoftware.kryo.io.Input;
  +import com.esotericsoftware.kryo.io.Output;
  +import com.esotericsoftware.kryo.serializers.ClosureSerializer;
  +
  +public class ClosureSerializerTest {
  +    @Test
  +    void writesReadsAndCopiesSerializableClosures() {
  +        CapturingKryo kryo = new CapturingKryo();
  +        ClosureSerializer serializer = new ClosureSerializer();
  +        String capturedValue = "dynamic-access";
  +        SerializableStringSupplier original = () -> "closure-" + capturedValue;
  +
  +        byte[] bytes = writeToBytes(kryo, serializer, original);
  +        SerializableStringSupplier restored = readFromBytes(kryo, serializer, bytes, original.getClass());
  +        SerializableStringSupplier copied = (SerializableStringSupplier) serializer.copy(kryo, original);
  +
  +        assertThat(restored.get()).isEqualTo("closure-dynamic-access");
  +        assertThat(copied.get()).isEqualTo("closure-dynamic-access");
  +    }
  +
  +    private static byte[] writeToBytes(Kryo kryo, ClosureSerializer serializer, SerializableStringSupplier value) {
  +        Output output = new Output(512, -1);
  +        serializer.write(kryo, output, value);
  +        output.close();
  +        return output.toBytes();
  +    }
  +
  +    private static SerializableStringSupplier readFromBytes(
  +            Kryo kryo, ClosureSerializer serializer, byte[] bytes, Class<?> type) {
  +        Input input = new Input(bytes);
  +        SerializableStringSupplier value = (SerializableStringSupplier) serializer.read(kryo, input, type);
  +        input.close();
  +        return value;
  +    }
  +
  +    private static final class CapturingKryo extends Kryo {
  +        private Object replacement;
  +
  +        @Override
  +        public void writeObject(Output output, Object object) {
  +            replacement = object;
  +        }
  +
  +        @Override
  +        public <T> T readObject(Input input, Class<T> type) {
  +            if (replacement == null) {
  +                throw new IllegalStateException("No closure replacement was captured.");
  +            }
  +            return type.cast(replacement);
  +        }
  +    }
  +
  +    @FunctionalInterface
  +    private interface SerializableStringSupplier extends Serializable {
  +        String get();
  +    }
  +}
