  	public void copy (Object original, Object copy) {
  		try {
  			if (accessIndex != -1) {
  				FieldAccess access = (FieldAccess)fieldSerializer.access;
  				access.set(copy, accessIndex, kryo.copy(access.get(original, accessIndex)));
