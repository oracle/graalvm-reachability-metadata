        FieldSerializer<ConfigurableState> serializer = new FieldSerializer<>(kryo, ConfigurableState.class);\n        assertThat(fieldNames(serializer)).containsExactly(\"always\", \"nullableValue\");\n\n        kryo.getContext().put(\"include.optional\", Boolean.TRUE);\n        serializer.setFieldsCanBeNull(false);\n        serializer.setFixedFieldTypes(true);\n        serializer.setIgnoreSyntheticFields(false);\n\n        assertThat(fieldNames(serializer)).containsExactly(\"always\", \"includedWhenRequested\", \"nullableValue\");\n    }\n\n    private static List<String> fieldNames(FieldSerializer<?> serializer) {\n        return Arrays.stream(serializer.getFields())\n                .map(Object::toString)\n                .collect(Collectors.toList());\n    }\n\n    public static final class SampleState {\n        public int id;\n        public String name;\n        public NestedState nested;\n        private long secret;\n\n        public SampleState() {\n        }\n\n        SampleState(int id, String name, long secret, NestedState nested) {\n            this.id = id;\n            this.name = name;\n            this.secret = secret;\n            this.nested = nested;\n        }\n\n        @Override\n        public boolean equals(Object object) {\n            if (this == object) {\n                return true;\n            }\n            if (!(object instanceof SampleState)) {\n                return false;\n            }\n            SampleState that = (SampleState) object;\n            return id == that.id && secret == that.secret && Objects.equals(name, that.name) && Objects.equals(nested, that.nested);\n        }\n\n        @Override\n        public int hashCode() {\n            return Objects.hash(id, name, nested, secret);\n        }\n    }\n\n    public static final class NestedState {\n        public String value;\n\n        public NestedState() {\n        }\n\n        NestedState(String value) {\n            this.value = value;\n        }\n\n        @Override\n        public boolean equals(Object object) {\n            if (this == object) {\n                return true;\n            }\n            if (!(object instanceof NestedState)) {\n                return false;\n            }\n            NestedState that = (NestedState) object;\n            return Objects.equals(value, that.value);\n        }\n\n        @Override\n        public int hashCode() {\n            return Objects.hash(value);\n        }\n    }\n\n    public static final class ConfigurableState {\n        public String always;\n        public String nullableValue;\n\n        @FieldSerializer.Optional(\"include.optional\")\n        public String includedWhenRequested;\n    }\n}\n"}
