[tool-call] delta {"path":"tests/src/com.esotericsoftware/kryo-shaded/3.0.3/src/test/java/com_esotericsoftware/kryo_shaded/FieldSerializerTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_esotericsoftware.kryo_shaded;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.util.Arrays;\nimport java.util.List;\nimport java.util.Objects;\nimport java.util.stream.Collectors;\n\nimport org.junit.jupiter.api.Test;\n\nimport com.esotericsoftware.kryo.Kryo;\nimport com.esotericsoftware.kryo.io.Input;\nimport com.esotericsoftware.kryo.io.Output;\nimport com.esotericsoftware.kryo.serializers.FieldSerializer;\n\npublic class FieldSerializerTest {\n    @Test\n    void serializesPrivateAndPublicFieldsWithTheDefaultUnsafeBackedFieldSerializer() {\n        Kryo kryo = new Kryo();\n        kryo.setAsmEnabled(false);\n        kryo.setRegistrationRequired(false);\n\n        FieldSerializer<SampleState> serializer = new FieldSerializer<>(kryo, SampleState.class);\n        kryo.register(SampleState.class, serializer);\n\n        SampleState original = new SampleState(7, \"kryo\", 99L, new NestedState(\"nested\"));\n        Output output = new Output(256, -1);\n        kryo.writeObject(output, original);\n        output.close();\n\n        Input input = new Input(output.toBytes());\n        SampleState copy = kryo.readObject(input, SampleState.class);\n        input.close();\n\n        assertThat(copy).isEqualTo(original);\n        assertThat(fieldNames(serializer)).containsExactly(\"id\", \"name\", \"nested\", \"secret\");\n    }\n\n    @Test\n    void rebuildsCachedFieldsWhenConfigurationChanges() {\n        Kryo kryo = new Kryo();\n        kryo.setAsmEnabled(false);\n\n        FieldSerializer<ConfigurableState> serializer = new FieldSerializer<>(kryo, ConfigurableState.class);\n        assertThat(fieldNames(serializer)).containsExactly(\"always\", \"nullableValue\");\n\n        kryo.getContext().put(\"include.optional\", Boolean.TRUE);\n        serializer.setFieldsCanBeNull(false);\n        serializer.setFixedFieldTypes(true);\n        serializer.setIgnoreSyntheticFields(false);\n\n        assertThat(fieldNames(serializer)).containsExactly(\"always\", \"includedWhenRequested\", \"nullableValue\");\n    }\n\n    private static List<String> fieldNames(FieldSerializer<?> serializer) {\n        return Arrays.stream(serializer.getFields())\n                .map(Object::toString)\n                .collect(Collectors.toList());\n    }\n\n    public static final class SampleState {\n        public int id;\n        public String name;\n        public NestedState nested;\n        private long secret;\n\n        public SampleState() {\n        }\n\n        SampleState(int id, String name, long secret, NestedState nested) {\n            this.id = id;\n            this.name = name;\n            this.secret = secret;\n            this.nested = nested;\n        }\n\n        @Override\n        public boolean equals(Object object) {\n            if (this == object) {\n                return true;\n            }\n            if (!(object instanceof SampleState)) {\n                return false;\n            }\n            SampleState that = (SampleState) object;\n            return id == that.id && secret == that.secret && Objects.equals(name, that.name) && Objects.equals(nested, that.nested);\n        }\n\n        @Override\n        public int hashCode() {\n            return Objects.hash(id, name, nested, secret);\n        }\n    }\n\n    public static final class NestedState {\n        public String value;\n\n        public NestedState() {\n        }\n\n        NestedState(String value) {\n            this.value = value;\n        }\n\n        @Override\n        public boolean equals(Object object) {\n            if (this == object) {\n                return true;\n            }\n            if (!(object instanceof NestedState)) {\n                return false;\n            }\n            NestedState that = (NestedState) object;\n            return Objects.equals(value, that.value);\n        }\n\n        @Override\n        public int hashCode() {\n            return Objects.hash(value);\n        }\n    }\n\n    public static final class ConfigurableState {\n        public String always;\n        public String nullableValue;\n\n        @FieldSerializer.Optional(\"include.optional\")\n        public String includedWhenRequested;\n    }\n}\n"}
