in\",\nmetadata/io.arrow-kt/arrow-exception-utils-jvm/index.json:8:    \"documentation-url\" : \"https://repo.maven.apache.org/maven2/io/arrow-kt/arrow-exception-utils-jvm/$version$/arrow-exception-utils-jvm-$version$-javadoc.jar\",\nmetadata/io.arrow-kt/arrow-exception-utils-jvm/index.json:9:    \"description\" : \"Arrow Exception Utilities provides Kotlin helpers for classifying fatal and non-fatal Throwable values and rethrowing fatal exceptions. It also includes small Throwable utilities for throwing nullable errors and merging suppressed exceptions.\",\nmetadata/io.arrow-kt/arrow-annotations-jvm/index.json:9:    \"description\" : \"Arrow Annotations provides Kotlin annotations used by Arrow components, including the @optics annotation for generating optics such as lenses, prisms, optionals, isos, and DSL helpers. The artifact also includes the @synthetic marker annotation used by Arrow tooling to mark generated or synthetic API elements.\",\nmetadata/io.opentelemetry.semconv/opentelemetry-semconv/index.json:8:    \"description\" : \"OpenTelemetry Semantic Conventions provides generated Java constants for the semantic attributes defined by the OpenTelemetry specification. Applications and instrumentation libraries use it to refer to telemetry attributes consistently when producing traces, metrics, logs, and resource metadata.\",\nmetadata/io.opentelemetry.semconv/opentelemetry-semconv/index.json:23:    \"description\" : \"OpenTelemetry Semantic Conventions provides generated Java constants for the stable semantic attributes defined by the OpenTelemetry specification. Applications and instrumentation libraries use it to refer to telemetry attributes consistently when producing traces, metrics, logs, and resource metadata.\",\nmetadata/org.jetbrains.kotlinx/kotlinx-cli-jvm/index.json:9:    \"description\" : \"kotlinx-cli-jvm is the JVM artifact of kotlinx-cli, a pure Kotlin library for declaratively building command-line parsers. It parses options, arguments, subcommands, and typed values for Kotlin console applications and can generate errors, help text, and usage messages.\",\nmetadata/io.opentelemetry/opentelemetry-semconv/index.json:9:    \"description\" : \"OpenTelemetry Semantic Conventions provides generated Java constants for the attributes defined by the OpenTelemetry specification. Applications and instrumentation libraries use it to refer to trace and resource semantic attributes consistently when producing telemetry.\",\nmetadata/io.opentelemetry/opentelemetry-semconv/index.json:28:    \"description\" : \"OpenTelemetry Semantic Conventions provides generated Java constants for the attributes defined by the OpenTelemetry specification. Applications and instrumentation libraries use it to refer to trace and resource semantic attributes consistently when producing telemetry.\",\nmetadata/io.opentelemetry/opentelemetry-semconv/index.json:44:    \"description\" : \"OpenTelemetry Semantic Conventions provides generated Java constants for the attributes defined by the OpenTelemetry specification. Applications and instrumentation libraries use it to refer to trace and resource semantic attributes consistently when producing telemetry.\",\nmetadata/io.opentelemetry/opentelemetry-semconv/index.json:61:    \"description\" : \"OpenTelemetry Semantic Conventions provides generated Java constants for the attributes defined by the OpenTelemetry specification. Applications and instrumentation libraries use it to refer to trace and resource semantic attributes consistently when producing telemetry.\",\nmetadata/io.opentelemetry/opentelemetry-semconv/index.json:77:    \"description\" : \"OpenTelemetry Semantic Conventions provides generated Java constants for the attributes defined by the OpenTelemetry specification. Applications and instrumentation libraries use it to refer to trace and resource semantic attributes consistently when producing telemetry.\",\nmetadata/org.jboss.logging/jboss-logging-annotations/index.json:9:    \"description\" : \"JBoss Logging Annotations provides Java annotations used by JBoss Logging Tools to define typed loggers, message bundles, message IDs, and formatting metadata. Annotation processors consume these declarations to generate logging and internationalization helper code for Java applications.\",\nmetadata/com.esotericsoftware/kryo-shaded/index.json:5:    \"source-code-url\" : \"https://repo1.maven.org/maven2/com/esotericsoftware/kryo-shaded/$version$/kryo-shaded-$version$-sources.jar\",\nmetadata/com.esotericsoftware/kryo-shaded/index.json:8:    \"documentation-url\" : \"https://repo1.maven.org/maven2/com/esotericsoftware/kryo-shaded/$version$/kryo-shaded-$version$-javadoc.jar\",\nmetadata/com.esotericsoftware/kryo-shaded/index.json:9:    \"description\" : \"Kryo is a fast, efficient object graph serialization framework for Java. The kryo-shaded artifact packages Kryo with a shaded ReflectASM dependency to reduce conflicts with other ASM versions.\",\nmetadata/jakarta.servlet/jakarta.servlet-api/index.json:8:    \"description\" : \"Jakarta Servlet defines the standard server-side API for Java web applications to process HTTP requests and generate responses. It provides interfaces and classes for servlets, filters, listeners, sessions, and deployment descriptors for Servlet 4.0 applications.\",\nmetadata/jakarta.servlet/jakarta.servlet-api/index.json:23:    \"description\" : \"Jakarta Servlet defines the standard server-side API for Java web applications to process HTTP requests and generate responses. It provides interfaces and classes for servlets, filters, listeners, sessions, and deployment descriptors in Jakarta EE 9.\",\nmetadata/org.codehaus.plexus/plexus-interpolation/index.json:9:    \"description\" : \"Plexus Interpolation is a Java utility library for resolving and substituting expression placeholders in strings from pluggable value sources such as maps, properties, objects, and environment variables. It provides interpolator implementations, recursion handling, prefix-aware lookups, and reflection-based value extraction for tools that need Maven or Plexus-style configuration interpolation.\",\nmetadata/io.jsonwebtoken/jjwt-impl/0.11.5/reachability-metadata.json:130:          \"name\": \"generateKeyPair\",\nmetadata/io.jsonwebtoken/jjwt-impl/0.11.5/reachability-metadata.json:144:          \"name\": \"generateKey\",\nmetadata/io.jsonwebtoken/jjwt-impl/0.11.5/reachability-metadata.json:158:          \"name\": \"generateKeyPair\",\nmetadata/org.sangria-graphql/sangria-derivation_3/index.json:9:    \"description\" : \"Sangria Derivation provides Scala macros for deriving Sangria GraphQL object, input object, and enum types from Scala types. It lets Sangria users customize the generated schema with field selection, renaming, documentation, deprecation, tags, complexity, and related derivation settings.\",\nmetadata/org.sangria-graphql/macro-visit_3/index.json:9:    \"description\" : \"macro-visit is a Scala macro library that generates type-safe visitor code for sealed case-class hierarchies. It supports non-recursive traversal, immutable transformations, skipping or breaking traversal, and visiting supported collection and option fields, making it useful for AST processing.\",\nmetadata/org.glassfish.jaxb/txw2/index.json:9:    \"description\" : \"TXW2 is a typed XML writer library that lets Java code generate XML documents through annotated writer interfaces. It provides runtime support for building structured XML output with SAX, StAX, DOM, and stream-based serializers.\",\nmetadata/org.apache.maven.surefire/surefire-logger-api/2.22.2/reachability-metadata.json:44:          \"name\": \"error\",\nmetadata/org.apache.maven.surefire/surefire-logger-api/2.22.2/reachability-metadata.json:50:          \"name\": \"error\",\nmetadata/org.apache.maven.surefire/surefire-logger-api/2.22.2/reachability-metadata.json:57:          \"name\": \"error\",\nmetadata/io.jsonwebtoken/jjwt-jackson/0.11.5/reachability-metadata.jso