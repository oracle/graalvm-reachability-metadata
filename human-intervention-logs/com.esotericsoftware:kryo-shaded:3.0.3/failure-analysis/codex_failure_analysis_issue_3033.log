yo.Kryo;\\n+import com.esotericsoftware.kryo.io.Input;\\n+import com.esotericsoftware.kryo.io.Output;\\n+import com.esotericsoftware.kryo.serializers.FieldSerializer;\\n+\\n+public class FieldSerializerTest {\\n+    @Test\\n+    void serializesPrivateAndPublicFieldsWithTheDefaultUnsafeBackedFieldSerializer() {\\n+        Kryo kryo = new Kryo();\\n+        kryo.setAsmEnabled(false);\\n+        kryo.setRegistrationRequired(false);\\n+\\n+        FieldSerializer<SampleState> serializer = new FieldSerializer<>(kryo, SampleState.class);\\n+        kryo.register(SampleState.class, serializer);\\n+\\n+        SampleState original = new SampleState(7, \\\"kryo\\\", 99L, new NestedState(\\\"nested\\\"));\\n+        Output output = new Output(256, -1);\\n+        kryo.writeObject(output, original);\\n+        byte[] serialized = output.toBytes();\\n+        output.close();\\n+\\n+        Input input = new Input(serialized);\\n+        SampleState copy = kryo.readObject(input, SampleState.class);\\n+        input.close();\\n+\\n+        assertThat(copy).isEqualTo(original);\\n+        assertThat(fieldNames(serializer)).containsExactly(\\\"id\\\", \\\"name\\\", \\\"nested\\\", \\\"secret\\\");\\n+    }\\n+\\n+    @Test\\n+    void rebuildsCachedFieldsWhenConfigurationChanges() {\\n+        Kryo kryo = new Kryo();\\n+        kryo.setAsmEnabled(false);\\n+\\n+        FieldSerializer<ConfigurableState> serializer = new FieldSerializer<>(kryo, ConfigurableState.class);\\n+        assertThat(fieldNames(serializer)).containsExactly(\\\"always\\\", \\\"nullableValue\\\");\\n+\\n+        kryo.getContext().put(\\\"include.optional\\\", Boolean.TRUE);\\n+        serializer.setFieldsCanBeNull(false);\\n+        serializer.setFixedFieldTypes(true);\\n+        serializer.setIgnoreSyntheticFields(false);\\n+\\n+        assertThat(fieldNames(serializer)).containsExactly(\\\"always\\\", \\\"includedWhenRequested\\\", \\\"nullableValue\\\");\\n+    }\\n+\\n+    private static List<String> field