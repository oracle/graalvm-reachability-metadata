tpdf/svg/index.json:9:    \"description\" : \"This iText module integrates SVG images into PDF creation and manipulation workflows. It parses and renders SVG content so it can be used within documents generated with iText.\",\nbuild/discovered-artifact-metadata/com.esotericsoftware-kryo-shaded-3.0.3.json:2:  \"coordinates\" : \"com.esotericsoftware:kryo-shaded:3.0.3\",\nbuild/discovered-artifact-metadata/com.esotericsoftware-kryo-shaded-3.0.3.json:4:  \"source-code-url\" : \"https://repo1.maven.org/maven2/com/esotericsoftware/kryo-shaded/$version$/kryo-shaded-$version$-sources.jar\",\nbuild/discovered-artifact-metadata/com.esotericsoftware-kryo-shaded-3.0.3.json:6:  \"documentation-url\" : \"https://repo1.maven.org/maven2/com/esotericsoftware/kryo-shaded/$version$/kryo-shaded-$version$-javadoc.jar\",\nbuild/discovered-artifact-metadata/com.esotericsoftware-kryo-shaded-3.0.3.json:7:  \"description\" : \"Kryo is a fast, efficient object graph serialization framework for Java. The kryo-shaded artifact packages Kryo with a shaded ReflectASM dependency to reduce conflicts with other ASM versions.\"\nmetadata/org.apache.directory.api/api-i18n/1.0.0/reachability-metadata.json:13:      \"glob\": \"org/apache/directory/api/i18n/errors.properties\"\nmetadata/org.apache.directory.api/api-i18n/1.0.0/reachability-metadata.json:19:      \"glob\": \"org/apache/directory/api/i18n/errors_en.properties\"\nmetadata/org.apache.directory.api/api-i18n/1.0.0/reachability-metadata.json:25:      \"glob\": \"org/apache/directory/api/i18n/errors_en_US.properties\"\nmetadata/org.apache.directory.api/api-i18n/1.0.0/reachability-metadata.json:46:      \"bundle\": \"org/apache/directory/api/i18n/errors\"\nmetadata/org.apache.activemq/artemis-jms-client/2.29.0/reachability-metadata.json:136:          \"name\": \"exceptionCaught\",\nmetadata/org.apache.activemq/artemis-jms-client/2.29.0/reachability-metadata.json:236:          \"name\": \"exceptionCaught\",\nmetadata/org.apache.activemq/artemis-jms-client/2.29.0/reachability-metadata.json:739:          \"name\": \"exceptionCaught\",\nmetadata/org.apache.directory.api/api-i18n/index.json:9:    \"description\" : \"Apache Directory LDAP API I18n provides the internationalized message and error-code resources used by the Apache Directory LDAP API modules. It exposes the I18n enum and resource bundles that format localized diagnostics for LDAP, ASN1, DSML, and related Directory API components.\",\nmetadata/org.apache.directory.api/api-i18n/index.json:37:    \"description\" : \"Apache Directory LDAP API I18n provides the internationalized message and error-code resources used by the Apache Directory LDAP API modules. It exposes the I18n enum and resource bundles that format localized diagnostics for LDAP, ASN1, DSML, and related Directory API components.\",\nmetadata/org.apache.activemq/artemis-jms-client/2.28.0/reachability-metadata.json:136:          \"name\": \"exceptionCaught\",\nmetadata/org.apache.activemq/artemis-jms-client/2.28.0/reachability-metadata.json:236:          \"name\": \"exceptionCaught\",\nmetadata/org.apache.activemq/artemis-jms-client/2.28.0/reachability-metadata.json:534:          \"name\": \"exceptionCaught\",\nmetadata/org.apache.directory.api/api-i18n/2.0.0/reachability-metadata.json:13:      \"glob\": \"org/apache/directory/api/i18n/errors.properties\"\nmetadata/org.apache.directory.api/api-i18n/2.0.0/reachability-metadata.json:22:      \"bundle\": \"org/apache/directory/api/i18n/errors\"\ntests/tck-test-support/src/main/java/org/graalvm/internal/tck/NativeImageSupport.java:18:    /// Returns true when the error is an UnsupportedFeatureError thrown by\ntests/tck-test-support/src/main/java/org/graalvm/internal/tck/NativeImageSupport.java:20:    public static boolean isUnsupportedFeatureError(Error error) {\ntests/tck-test-support/src/main/java/org/graalvm/internal/tck/NativeImageSupport.java:21:        return error != null\ntests/tck-test-support/src/main/java/org/graalvm/internal/tck/NativeImageSupport.java:22:                && UNSUPPORTED_FEATURE_ERROR.equals(error.getClass().getName());\nmetadata/org.apache.activemq/artemis-jms-client/2.32.0/reachability-metadata.json:172:          \"name\": \"exceptionCaught\",\nmetadata/org.apache.activemq/artemis-jms-client/2.32.0/reachability-metadata.json:272:          \"name\": \"exceptionCaught\",\nmetadata/org.apache.activemq/artemis-jms-client/2.32.0/reachability-metadata.json:794:          \"name\": \"exceptionCaught\",\nmetadata/org.apache.activemq/artemis-log-annotation-processor/index.json:9:    \"description\" : \"ActiveMQ Artemis Log Annotation Processor is a Java annotation processor for Artemis logging annotations such as LogBundle, Message, LogMessage, and GetLogger. It generates SLF4J-backed implementation classes at compile time and validates message identifiers and placeholders for annotated logging interfaces.\",\nmetadata/org.apache.activemq/artemis-log-annotation-processor/index.json:31:    \"description\" : \"ActiveMQ Artemis Log Annotation Processor is a Java annotation processor for Artemis logging annotations such as LogBundle, Message, LogMessage, and GetLogger. It generates SLF4J-backed implementation classes at compile time and validates message identifiers and placeholders for annotated logging interfaces.\",\nmetadata/org.apache.activemq/artemis-log-annotation-processor/index.json:45:    \"description\" : \"ActiveMQ Artemis Log Annotation Processor is a Java annotation processor for Artemis logging annotations such as LogBundle, Message, LogMessage, and GetLogger. It generates SLF4J-backed implementation classes at compile time and validates message identifiers and placeholders for annotated logging interfaces.\",\nmetadata/com.google.guava/listenablefuture/index.json:10:    \"description\": \"This artifact is an empty compatibility placeholder that Guava depends on so build tools prefer it over the standalone ListenableFuture artifact. It avoids duplicate ListenableFuture classes when applications depend on Guava and the older standalone coordinate at the same time.\",\nmetadata/com.google.guava/failureaccess/index.json:17:    \"description\" : \"failureaccess provides Guava's internal classes for optionally exposing the cause of a failed Future through a fast path. It includes InternalFutureFailureAccess and InternalFutures for lightweight failure-cause access used by Guava concurrency utilities.\"\nmetadata/com.google.api.grpc/proto-google-cloud-firestore-v1/index.json:9:    \"description\" : \"This artifact provides generated Java Protocol Buffer message classes, descriptors, and resource-name helpers for the Google Cloud Firestore v1 API. It supplies the data model used by Java Firestore clients and related gRPC libraries for documents, queries, writes, transactions, and listener messages.\",\nmetadata/com.google.api.grpc/grpc-google-common-protos/index.json:9:    \"description\": \"grpc-google-common-protos provides Java gRPC stubs for common Google API services, including the Operations and Locations services generated from Google common protobuf definitions. It lets JVM clients call those shared service endpoints through gRPC alongside the corresponding protobuf message types.\",\nmetadata/com.google.api.grpc/proto-google-cloud-bigquerystorage-v1/index.json:9:    \"description\" : \"This artifact provides the generated Java Protocol Buffer classes and .proto descriptors for the Google Cloud BigQuery Storage v1 API. It defines messages, enums, resource names, and service-related types used by Java clients and gRPC stubs to read from and write to BigQuery Storage.\",\nmetadata/com.softwaremill.sttp.shared/core_3/index.json:9:    \"description\" : \"sttp-shared core provides common Scala abstractions used across the sttp ecosystem, including typed capability markers, attribute maps, monad error typeclasses, and streaming and web socket capability definitions. This artifact is the Scala 3 JVM build of that shared foundation, enabling sttp client, tapir, model, and related modules to express effects, streams, and request and response metadata consistently.\",\nmetadata/com.softwaremill.sttp.shared/ws_3/index.json:9:    \"description\" : \"sttp-shared ws provides Scala abstractions for effectful WebSocket interactions, including sending and receiving raw, text, binary, ping, pong, and close frames. It also includes WebSocket error types and testing support used by sttp modules to model WebSocket behavior consistently across backends.\",\nmetadata/com.google.api.grpc/grpc-google-cloud-spanner-v1/index.json:9:    \"description\" : \"This artifact provides generated Java gRPC stubs for the Google Cloud Spanner v1 API. It lets JVM applications call Spanner service RPCs directly using gRPC and the generated protobuf service bindings.\",\ntests/tck-build-logic/build/resources/main/scaffold/Test.scala.template:14:    println(\"This is just a placeholder, implement your test\")\nmetadata/org.antlr/antlr4-runtime/index.json:9:    \"description\" : \"ANTLR 4 Runtime is the Java runtime library that supplies the core classes needed to execute parsers and lexers generated by ANTLR 4. It provides token streams, parse tree support, error handling, and other infrastructure used by generated language recognizers.\",\nmetadata/com.google.api.grpc/proto-google-cloud-spanner-executor-v1/index.json:9:    \"description\": \"This artifact provides the generated Java Protocol Buffer classes for the Cloud Spanner executor v1 API, including request, response, and admin action messages used by Spanner executor workflows. It is a JVM library that lets Java clients and gRPC stubs serialize and consume those executor protocol messages.\",\ntests/tck-build-logic/build/resources/main/scaffold/Test.groovy.template:14:        println \"This is just a placeholder, implement your test\"\ntests/tck-build-logic/build/resources/main/scaffold/Test.kt.template:14:        println(\"This is just a placeholder, implement your test\")\nmetadata/org.antlr/antlr-runtime/index.json:9:    \"description\" : \"ANTLR 3 Runtime provides the Java runtime support needed by lexers, parsers, and tree parsers generated by ANTLR 3. It includes token streams, recognizer base classes, error handling, and tree APIs used to execute grammars generated from language descriptions.\",\ntests/tck-build-logic/build/resources/main/scaffold/Test.java.template:14:        System.out.println(\"This is just a placeholder, implement your test\");\nmetadata/com.google.api.grpc/grpc-google-cloud-spanner-admin-database-v1/index.json:9:    \"description\" : \"This artifact provides generated Java gRPC stubs for the Cloud Spanner Database Admin v1 API. It lets JVM applications call database administration RPCs for databases, schemas, backups, and restores using gRPC and the generated protobuf service bindings.\",\nmetadata/com.google.api.grpc/proto-google-cloud-spanner-v1/index.json:9:    \"description\" : \"This artifact contains generated Java Protocol Buffer model classes for the Google Cloud Spanner v1 API. It provides message types, resource-name helpers, and protobuf descriptors used by Spanner gRPC stubs and client libraries to serialize requests, responses, transactions, mutations, and result sets.\",\nmetadata/com.google.api.grpc/proto-google-cloud-monitoring-v3/index.json:9:    \"description\" : \"proto-google-cloud-monitoring-v3 provides the generated Java Protocol Buffer message and service descriptor classes for Google Cloud Monitoring v3 APIs. It is used by Google Cloud Monitoring client libraries and direct gRPC/protobuf integrations to build requests, responses, and resource names for metrics, alerting, uptime checks, notification channels, service-level objectives, and related monitoring services.\",\nmetadata/com.google.api.grpc/proto-google-common-protos/index.json:9:    \"description\" : \"This artifact provides generated Java Protocol Buffer classes for Google's common API protobuf definitions, including shared annotations, resource descriptors, HTTP rules, and other cross-API message types. It lets JVM applications and Google API client libraries serialize, deserialize, and reference these common protobuf models when interacting with Google services.\",\nmetadata/com.google.api.grpc/proto-google-cloud-bigquerystorage-v1beta1/index.json:9:    \"description\" : \"This artifact provides generated Java Protocol Buffer classes and descriptors for the Google Cloud BigQuery Storage v1beta1 API. It defines messages, enums, resource names, and service-related types used by JVM clients and gRPC stubs to read from and write to BigQuery Storage.\",\nmetadata/com.google.api.grpc/grpc-google-cloud-spanner-admin-instance-v1/index.json:9:    \"description\": \"This artifact provides generated Java gRPC stubs for the Cloud Spanner Instance Admin v1 API. It lets JVM applications call instance administration RPCs directly to manage Cloud Spanner instances, instance configurations, and instance partitions through gRPC service bindings.\",\nmetadata/com.google.api.grpc/proto-google-cloud-spanner-admin-database-v1/index.json:9:    \"description\" : \"This artifact contains the generated Java Protocol Buffer model classes for the Cloud Spanner Database Admin v1 API. It provides message types, resource-name helpers, and protobuf descriptors used by higher-level Spanner admin gRPC and client libraries to manage databases, backups, backup schedules, database roles, and related long-running operations.\",\nmetadata/com.google.api.grpc/grpc-google-cloud-spanner-executor-v1/index.json:9:    \"description\": \"This artifact provides generated gRPC Java stubs for the Cloud Spanner Executor v1 API. It exposes the SpannerExecutorProxy service bindings used by Java clients and tests to execute Spanner actions asynchronously over gRPC.\",\nmetadata/com.google.api.grpc/proto-google-iam-v1/index.json:9:    \"description\" : \"This artifact contains the generated Java Protocol Buffer classes for Google Cloud IAM v1 policy, binding, audit configuration, and IAM policy request and response messages. It lets JVM clients serialize, deserialize, and reference Google IAM v1 protobuf messages used by Google API and gRPC client libraries.\",\nmetadata/com.google.api.grpc/proto-google-cloud-bigquerystorage-v1alpha/index.json:9:    \"description\" : \"This artifact provides generated Java Protocol Buffer classes and descriptors for the Google Cloud BigQuery Storage v1alpha API. It defines messages, resource names, and service-related types used by JVM clients and gRPC stubs to serialize BigQuery Storage requests and responses.\",\nmetadata/com.google.api.grpc/proto-google-cloud-spanner-admin-instance-v1/index.json:9:    \"description\" : \"This artifact contains the generated Java Protocol Buffer model classes for the Cloud Spanner Instance Admin v1 API. It provides message types, resource-name helpers, and protobuf descriptors used by higher-level Spanner admin gRPC and client libraries to create, list, update, and delete instances, instance configs, and instance partitions.\",\nmetadata/com.google.api.grpc/proto-google-cloud-bigquerystorage-v1beta/index.json:9:    \"description\" : \"This artifact provides generated Java Protocol Buffer classes and descriptors for the Google Cloud BigQuery Storage v1beta API. It defines messages, resource names, and service-related types used by JVM clients and gRPC stubs to read from and write to BigQuery Storage.\",\nmetadata/org.eclipse.jetty/jetty-http/index.json:9:    \"description\" : \"Jetty HTTP provides core HTTP utilities for Eclipse Jetty, including request and response metadata, headers, cookies, MIME types, and URI handling. It is used by Jetty server and client components to parse, represent, and generate HTTP protocol data.\",\nmetadata/org.eclipse.jetty/jetty-http/index.json:94:    \"description\" : \"Jetty HTTP provides core HTTP utilities for Eclipse Jetty, including request and response metadata, headers, cookies, MIME types, and URI handling. It is used by Jetty server and client components to parse, represent, and generate HTTP protocol data.\",\nmetadata/org.eclipse.jetty/jetty-http/index.json:115:    \"description\" : \"Jetty HTTP provides core HTTP utilities for Eclipse Jetty, including request and response metadata, headers, cookies, MIME types, and URI handling. It is used by Jetty server and client components to parse, represent, and generate HTTP protocol data.\",\nmetadata/org.eclipse.jetty/jetty-client/12.1.5/reachability-metadata.json:261:          \"name\": \"errorActionIgnore\",\nmetadata/org.eclipse.jetty/jetty-client/12.1.5/reachability-metadata.json:265:          \"name\": \"errorActionReplace\",\nmetadata/org.eclipse.jetty/jetty-client/12.1.5/reachability-metadata.json:269:          \"name\": \"errorActionReport\",\nmetadata/dev.zio/zio-config_3/index.json:9:    \"description\" : \"ZIO Config is a Scala library that extends ZIO's Config model with composable tools for reading, documenting, deriving, and validating application configuration. It supports flat and nested configuration sources, automatic documentation generation, automatic derivation for data types, refined validations, accumulated errors, and integrations with common configuration backends.\",\nmetadata/org.jetbrains.kotlin/kotlin-parcelize-runtime/index.json:9:    \"description\" : \"Kotlin Parcelize Runtime provides the annotations and helper types used by Kotlin's Parcelize compiler plugin to generate Android Parcelable implementations. It supplies APIs such as @Parcelize, Parceler, TypeParceler, RawValue, and parcelableCreator that generated Kotlin Android code references at compile time and runtime.\",\nmetadata/dev.zio/zio-internal-macros_3/index.json:8:    \"description\" : \"zio-internal-macros provides internal Scala 3 support classes used by ZIO macros to render layer wiring diagnostics and ANSI-formatted compile-time messages. It is a small ZIO implementation artifact rather than a public end-user API, and it supports macro-generated errors for ZIO layer provisioning and test/spec wiring.\",\nmetadata/dev.zio/zio-internal-macros_3/index.json:27:    \"description\" : \"zio-internal-macros provides internal Scala 3 support classes used by ZIO macros to render layer wiring diagnostics and ANSI-formatted compile-time messages. It is a small ZIO implementation artifact rather than a public end-user API, and it supports macro-generated errors for ZIO layer provisioning and test/spec wiring.\",\nmetadata/org.jetbrains.kotlin/kotlin-android-extensions-runtime/index.json:9:    \"description\" : \"Kotlin Android Extensions Runtime provides the runtime annotations and interfaces used by the Kotlin Android Extensions compiler plugin for synthetic Android view access and Parcelable generation. It defines cache configuration, layout container support, and parcelization marker types that generated Kotlin Android code depends on at runtime.\",\nmetadata/org.apache.commons/commons-lang3/3.11/reachability-metadata.json:127:        \"typeReached\" : \"org.apache.commons.lang3.exception.ExceptionUtils\"\nmetadata/org.apache.commons/commons-math3/3.1.1/reachability-metadata.json:5:        \"typeReached\" : \"org.apache.commons.math3.exception.util.ExceptionContext\"\nmetadata/org.apache.commons/commons-math3/3.1.1/reachability-metadata.json:12:        \"typeReached\" : \"org.apache.commons.math3.exception.util.ExceptionContext\"\nmetadata/org.apache.commons/commons-math3/3.1.1/reachability-metadata.json:19:        \"typeReached\" : \"org.apache.commons.math3.exception.util.ExceptionContext\"\nmetadata/org.apache.commons/commons-math3/3.1.1/reachability-metadata.json:26:        \"typeReached\" : \"org.apache.commons.math3.exception.util.ExceptionContext\"\nmetadata/org.apache.commons/commons-math3/3.1.1/reachability-metadata.json:33:        \"typeReached\" : \"org.apache.commons.math3.exception.util.ExceptionContext\"\nmetadata/org.apache.commons/commons-math3/3.1.1/reachability-meta