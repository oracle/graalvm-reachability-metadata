[tool-call] delta {"path":"tests/src/org.eclipse.collections/eclipse-collections/11.1.0/src/test/java/org_eclipse_collections/eclipse_collections/ReflectionHelperTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_eclipse_collections.eclipse_collections;\n\nimport java.lang.reflect.Constructor;\n\nimport org.eclipse.collections.impl.utility.internal.ReflectionHelper;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ReflectionHelperTest {\n    @Test\n    void getsExactConstructorAndInstantiatesIt() {\n        Constructor<StringValue> constructor = ReflectionHelper.getConstructor(StringValue.class, String.class);\n\n        StringValue value = ReflectionHelper.newInstance(constructor, \"eclipse-collections\");\n\n        assertThat(value.value).isEqualTo(\"eclipse-collections\");\n    }\n\n    @Test\n    void searchesConstructorsUsingAssignableParameterTypes() {\n        Constructor<NumberValue> constructor = ReflectionHelper.getConstructor(NumberValue.class, Integer.class);\n\n        NumberValue value = ReflectionHelper.newInstance(constructor, 11);\n\n        assertThat(value.value).isEqualTo(11);\n    }\n\n    @Test\n    void createsInstanceWithDefaultConstructor() {\n        DefaultConstructedValue value = ReflectionHelper.newInstance(DefaultConstructedValue.class);\n\n        assertThat(value.value).isEqualTo(\"default\");\n    }\n\n    @Test\n    void detectsOnlyPublicDefaultConstructors() {\n        assertThat(ReflectionHelper.hasDefaultConstructor(DefaultConstructedValue.class)).isTrue();\n        assertThat(ReflectionHelper.hasDefaultConstructor(PrivateDefaultConstructedValue.class)).isFalse();\n        assertThat(ReflectionHelper.hasDefaultConstructor(StringValue.class)).isFalse();\n    }\n\n    public static final class StringValue {\n        private final String value;\n\n        public StringValue(String value) {\n            this.value = value;\n        }\n    }\n\n    public static final class NumberValue {\n        private final Number value;\n\n        public NumberValue(Number value) {\n            this.value = value;\n        }\n    }\n\n    public static final class DefaultConstructedValue {\n        private final String value;\n\n        public DefaultConstructedValue() {\n            this.value = \"default\";\n        }\n    }\n\n    public static final class PrivateDefaultConstructedValue {\n        private PrivateDefaultConstructedValue() {\n        }\n    }\n}\n"}
