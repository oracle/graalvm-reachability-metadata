3/index.json:9:    \"description\" : \"akka-protobuf-v3 is Akka's shaded copy of the Google Protocol Buffers v3 Java runtime, relocated under akka.protobufv3.internal for Akka internals. It lets Akka modules parse, build, and serialize protobuf messages without exposing or conflicting with an application's own protobuf-java dependency.\",\nmetadata/org.yaml/snakeyaml/index.json:9:    \"description\" : \"SnakeYAML is a Java library for parsing and emitting YAML 1.1 documents. It lets applications load YAML into Java objects and serialize Java data structures back to YAML.\",\nmetadata/org.yaml/snakeyaml/index.json:23:    \"description\" : \"SnakeYAML is a Java library for parsing and emitting YAML 1.1 documents. It lets applications load YAML into Java objects and serialize Java data structures back to YAML.\",\ntests/src/org.jboss.shrinkwrap/shrinkwrap-impl-base/1.2.2/src/test/java/org_jboss_shrinkwrap/shrinkwrap_impl_base/ZipSerializableViewImplTest.java:15:import java.io.ObjectInputStream;\ntests/src/org.jboss.shrinkwrap/shrinkwrap-impl-base/1.2.2/src/test/java/org_jboss_shrinkwrap/shrinkwrap_impl_base/ZipSerializableViewImplTest.java:16:import java.io.ObjectOutputStream;\ntests/src/org.jboss.shrinkwrap/shrinkwrap-impl-base/1.2.2/src/test/java/org_jboss_shrinkwrap/shrinkwrap_impl_base/ZipSerializableViewImplTest.java:29:    private static final String RESOURCE_CONTENT = \"serialized archive payload\";\ntests/src/org.jboss.shrinkwrap/shrinkwrap-impl-base/1.2.2/src/test/java/org_jboss_shrinkwrap/shrinkwrap_impl_base/ZipSerializableViewImplTest.java:32:    void objectSerializationRoundTripPreservesArchiveContentsAndId() throws Exception {\ntests/src/org.jboss.shrinkwrap/shrinkwrap-impl-base/1.2.2/src/test/java/org_jboss_shrinkwrap/shrinkwrap_impl_base/ZipSerializableViewImplTest.java:38:        ZipSerializableView deserializedView = roundTrip(serializableView);\ntests/src/org.jboss.shrinkwrap/shrinkwrap-impl-base/1.2.2/src/test/java/org_jboss_shrinkwrap/shrinkwrap_im