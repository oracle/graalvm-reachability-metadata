  package org_eclipse_collections.eclipse_collections;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.IOException;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  
  import org.eclipse.collections.impl.list.fixed.ArrayAdapter;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ArrayAdapterTest {
      @Test
      void serializationRoundTripPreservesArrayElementsInOrder() throws Exception {
          ArrayAdapter<String> original = ArrayAdapter.newArrayWith("first", "second", "third");
  
          byte[] serialized = serialize(original);
          ArrayAdapter<?> restored = deserialize(serialized);
  
          assertThat(restored).containsExactly("first", "second", "third");
          assertThat(restored.get(1)).isEqualTo("second");
      }
  
      private static byte[] serialize(ArrayAdapter<?> adapter) throws IOException {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {
              output.writeObject(adapter);
          }
          return bytes.toByteArray();
      }
  
      private static ArrayAdapter<?> deserialize(byte[] serialized) throws IOException, ClassNotFoundException {
          try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(serialized))) {
              return (ArrayAdapter<?>) input.readObject();
          }
      }
  }
