      {
          return ArrayAdapter.newArrayWithItem(this, value);
      }
  
      @Override
      public ArrayAdapter<T> without(T element)
      {
          if (this.contains(element))
          {
              return ArrayAdapter.newArray(this.toList().without(element));
          }
          return this;
