  package org_eclipse_collections.eclipse_collections;
  
  import java.lang.reflect.Constructor;
  
  import org.eclipse.collections.impl.Counter;
  import org.eclipse.collections.impl.utility.internal.ReflectionHelper;
  import org.junit.jupiter.api.Test;
  
  import static org.junit.jupiter.api.Assertions.assertEquals;
  import static org.junit.jupiter.api.Assertions.assertNotNull;
  import static org.junit.jupiter.api.Assertions.assertTrue;
  
  public class ReflectionHelperTest {
      @Test
      void getsExactConstructorAndCreatesInstance() {
          Constructor<Counter> constructor = ReflectionHelper.getConstructor(Counter.class, int.class);
  
          assertNotNull(constructor);
          Counter counter = ReflectionHelper.newInstance(constructor, 17);
  
          assertEquals(17, counter.getCount());
      }
  
      @Test
      void searchesForConstructorUsingBoxedPrimitiveParameterType() {
          Constructor<Counter> constructor = ReflectionHelper.getConstructor(Counter.class, Integer.class);
  
          assertNotNull(constructor);
          Counter counter = ReflectionHelper.newInstance(constructor, 23);
  
          assertEquals(23, counter.getCount());
      }
  
      @Test
      void createsInstanceFromDefaultConstructor() {
          Counter counter = ReflectionHelper.newInstance(Counter.class);
  
          assertEquals(0, counter.getCount());
      }
  
      @Test
      void findsPublicDefaultConstructor() {
          assertTrue(ReflectionHelper.hasDefaultConstructor(Counter.class));
      }
  }
