[tool-call] delta {"path":"tests/src/org.eclipse.collections/eclipse-collections/11.1.0/src/test/java/org_eclipse_collections/eclipse_collections/ArrayListIterateTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_eclipse_collections.eclipse_collections;\n\nimport java.util.ArrayList;\n\nimport org.eclipse.collections.impl.utility.ArrayListIterate;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ArrayListIterateTest {\n    @Test\n    void removeIfCompactsPlainArrayListUsingInternalArray() {\n        ArrayList<Integer> values = newIntegerArrayList(150);\n        ArrayList<Integer> expected = newIntegerArrayListWithoutMultiplesOfThree(150);\n\n        boolean changed = ArrayListIterate.removeIf(values, each -> each % 3 == 0);\n\n        assertThat(changed).isTrue();\n        assertThat(values).containsExactlyElementsOf(expected);\n    }\n\n    @Test\n    void takeReadsFromInternalArrayForLargePlainArrayList() {\n        ArrayList<Integer> values = newIntegerArrayList(150);\n\n        ArrayList<Integer> result = ArrayListIterate.take(values, 5);\n\n        assertThat(result).containsExactly(0, 1, 2, 3, 4);\n        assertThat(values).hasSize(150);\n    }\n\n    private static ArrayList<Integer> newIntegerArrayList(int size) {\n        ArrayList<Integer> values = new ArrayList<>(size);\n        for (int each = 0; each < size; each++) {\n            values.add(each);\n        }\n        return values;\n    }\n\n    private static ArrayList<Integer> newIntegerArrayListWithoutMultiplesOfThree(int size) {\n        ArrayList<Integer> values = new ArrayList<>(size);\n        for (int each = 0; each < size; each++) {\n            if (each % 3 != 0) {\n                values.add(each);\n            }\n        }\n        return values;\n    }\n}\n"}
