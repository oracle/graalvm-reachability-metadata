  package org_eclipse_collections.eclipse_collections;
  
  import java.lang.reflect.Constructor;
  
  import org.eclipse.collections.impl.utility.internal.ReflectionHelper;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ReflectionHelperTest {
      @Test
      void getsExactConstructorAndInstantiatesIt() {
          Constructor<StringValue> constructor = ReflectionHelper.getConstructor(StringValue.class, String.class);
  
          StringValue value = ReflectionHelper.newInstance(constructor, "eclipse-collections");
  
          assertThat(value.value).isEqualTo("eclipse-collections");
      }
  
      @Test
      void searchesConstructorsUsingAssignableParameterTypes() {
          Constructor<NumberValue> constructor = ReflectionHelper.getConstructor(NumberValue.class, Integer.class);
  
          NumberValue value = ReflectionHelper.newInstance(constructor, 11);
  
          assertThat(value.value).isEqualTo(11);
      }
  
      @Test
      void createsInstanceWithDefaultConstructor() {
          DefaultConstructedValue value = ReflectionHelper.newInstance(DefaultConstructedValue.class);
  
          assertThat(value.value).isEqualTo("default");
      }
  
      @Test
      void detectsOnlyPublicDefaultConstructors() {
          assertThat(ReflectionHelper.hasDefaultConstructor(DefaultConstructedValue.class)).isTrue();
          assertThat(ReflectionHelper.hasDefaultConstructor(PrivateDefaultConstructedValue.class)).isFalse();
          assertThat(ReflectionHelper.hasDefaultConstructor(StringValue.class)).isFalse();
      }
  
      public static final class StringValue {
          private final String value;
  
          public StringValue(String value) {
              this.value = value;
          }
      }
  
      public static final class NumberValue {
          private final Number value;
  
          public NumberValue(Number value) {
              this.value = value;
          }
      }
  
      public static final class DefaultConstructedValue {
          private final String value;
  
          public DefaultConstructedValue() {
              this.value = "default";
          }
      }
  
      public static final class PrivateDefaultConstructedValue {
          private PrivateDefaultConstructedValue() {
          }
      }
  }
