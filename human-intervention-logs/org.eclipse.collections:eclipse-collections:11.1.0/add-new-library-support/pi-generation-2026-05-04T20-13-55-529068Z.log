[tool-call] delta {"path":"tests/src/org.eclipse.collections/eclipse-collections/11.1.0/src/test/java/org_eclipse_collections/eclipse_collections/UnifiedMapInnerEntrySetTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_eclipse_collections.eclipse_collections;\n\nimport java.util.AbstractMap;\nimport java.util.Map;\n\nimport org.eclipse.collections.impl.map.mutable.UnifiedMap;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class UnifiedMapInnerEntrySetTest {\n    @Test\n    void entrySetToArrayAllocatesTypedArrayWhenProvidedArrayIsTooSmall() {\n        UnifiedMap<String, Integer> map = UnifiedMap.newWithKeysValues(\"one\", 1, \"two\", 2, \"three\", 3);\n        Map.Entry<String, Integer>[] provided = new Map.Entry[0];\n\n        Map.Entry<String, Integer>[] result = map.entrySet().toArray(provided);\n\n        assertThat(result)\n                .isNotSameAs(provided)\n                .isInstanceOf(Map.Entry[].class)\n                .containsExactlyInAnyOrder(\n                        new AbstractMap.SimpleImmutableEntry<>(\"one\", 1),\n                        new AbstractMap.SimpleImmutableEntry<>(\"two\", 2),\n                        new AbstractMap.SimpleImmutableEntry<>(\"three\", 3));\n    }\n}\n"}
