  package org_eclipse_collections.eclipse_collections;
  
  import org.eclipse.collections.api.factory.Stacks;
  import org.eclipse.collections.api.stack.ImmutableStack;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class AbstractRichIterableTest {
      @Test
      void toArrayAllocatesTypedArrayForImmutableStackWhenProvidedArrayIsTooSmall() {
          ImmutableStack<String> stack = Stacks.immutable.with("alpha", "beta", "gamma");
  
          String[] result = stack.toArray(new String[0]);
  
          assertThat(result)
                  .isInstanceOf(String[].class)
                  .containsExactly("gamma", "beta", "alpha");
