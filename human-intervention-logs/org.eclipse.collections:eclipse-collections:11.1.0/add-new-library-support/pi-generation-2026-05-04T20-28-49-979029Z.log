  package org_eclipse_collections.eclipse_collections;
  
  import java.util.AbstractMap;
  import java.util.Map;
  
  import org.eclipse.collections.impl.map.mutable.UnifiedMap;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class UnifiedMapInnerEntrySetTest {
      @Test
      void entrySetToArrayAllocatesTypedArrayWhenProvidedArrayIsTooSmall() {
          UnifiedMap<String, Integer> map = UnifiedMap.newWithKeysValues("one", 1, "two", 2, "three", 3);
          Map.Entry<String, Integer>[] provided = new Map.Entry[0];
  
          Map.Entry<String, Integer>[] result = map.entrySet().toArray(provided);
  
          assertThat(result)
                  .isNotSameAs(provided)
                  .isInstanceOf(Map.Entry[].class)
