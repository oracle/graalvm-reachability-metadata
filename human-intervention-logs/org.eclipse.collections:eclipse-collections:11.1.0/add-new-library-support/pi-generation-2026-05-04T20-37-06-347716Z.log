  package org_eclipse_collections.eclipse_collections;
  
  import org.eclipse.collections.impl.map.mutable.UnifiedMap;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class UnifiedMapInnerKeySetTest {
      @Test
      void keySetToArrayAllocatesTypedArrayWhenProvidedArrayIsTooSmall() {
          UnifiedMap<String, Integer> map = UnifiedMap.newWithKeysValues("one", 1, "two", 2, "three", 3);
          String[] provided = new String[0];
  
          String[] result = map.keySet().toArray(provided);
  
          assertThat(result)
                  .isNotSameAs(provided)
                  .isInstanceOf(String[].class)
                  .containsExactlyInAnyOrder("one", "two", "three");
      }
  }
