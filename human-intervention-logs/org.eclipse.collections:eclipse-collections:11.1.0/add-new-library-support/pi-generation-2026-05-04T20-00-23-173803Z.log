g with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_eclipse_collections.eclipse_collections;\n\nimport org.eclipse.collections.impl.map.mutable.ConcurrentHashMapUnsafe;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ConcurrentHashMapUnsafeAnonymous1Test {\n    @Test\n    void newMapInitializesUnsafeBackedStorage() {\n        ConcurrentHashMapUnsafe<String, Integer> map = ConcurrentHashMapUnsafe.newMap();\n\n        Integer previous = map.put(\"one\", 1);\n\n        assertThat(previous).isNull();\n        assertThat(map.get(\"one\")).isEqualTo(1);\n        assertThat(map.containsKey(\"one\")).isTrue();\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 875, "output": 863, "cacheRead": 26112, "cacheWrite": 0, "totalTokens": 27850, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777924770288, "responseId": "resp_033c69b24efa67dd0169f8faa2d7c4819ca1a9898a525b373a"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_LoSVEdsIKC8WwLbJ4QNxL5Qq|fc_033c69b24efa67dd0169f8faadaeb0819cb6b4ebfc77181a5a", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 824 bytes to tests/src/org.eclipse.collections/eclipse-collections/11.1.0/src/test/java/org_eclipse_collections/eclipse_collections/ConcurrentHashMapUnsafeAnonymous1Test.java"}], "isError": false, "timestamp": 1777924782788}]}
