  package org_eclipse_collections.eclipse_collections;
  
  import org.eclipse.collections.impl.list.mutable.FastList;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class FastListTest {
      @Test
      void toArrayAllocatesTypedArrayWhenProvidedArrayIsTooSmall() {
          FastList<String> list = FastList.newListWith("alpha", "beta", "gamma");
  
          String[] result = list.toArray(new String[0]);
  
          assertThat(result)
                  .isInstanceOf(String[].class)
                  .containsExactly("alpha", "beta", "gamma");
      }
  
      @Test
      void toTypedArrayAllocatesArrayForRequestedComponentType() {
          FastList<String> list = FastList.newListWith("alpha", "beta", "gamma");
  
          String[] result = list.toTypedArray(String.class);
  
          assertThat(result)
                  .isInstanceOf(String[].class)
                  .containsExactly("alpha", "beta", "gamma");
      }
  }
