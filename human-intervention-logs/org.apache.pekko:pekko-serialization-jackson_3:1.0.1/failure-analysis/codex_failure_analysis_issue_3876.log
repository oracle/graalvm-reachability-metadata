 class VersionedProfile(id: String, displayName: String, active: Boolean)\\n\\nclass NoopActor extends Actor {\\n  override def receive: Receive = { case _ => () }\\n}\\n\"}, {\"oldText\": \"  @Test\\n  def jsonSerializerMigratesOlderPayloadsBeforeDeserialization(): Unit = withActorSystem(\\n\", \"newText\": \"  @Test\\n  def jsonSerializerRoundTripsClassicActorReferences(): Unit = withActorSystem(\\n    \\\"actor-ref\\\",\\n    BaseConfig + \\\"\\\"\\\"\\n      pekko.actor.serialization-bindings {\\n        \\\"org_apache_pekko.pekko_serialization_jackson_3.ActorRoute\\\" = jackson-json\\n      }\\n      \\\"\\\"\\\"\\n  ) { system =>\\n    val recipient: ActorRef = system.actorOf(Props(new NoopActor), \\\"recipient\\\")\\n    val route: ActorRoute = ActorRoute(\\\"route-1\\\", recipient, system.deadLetters)\\n    val serializer: SerializerWithStringManifest = jacksonSerializerFor(system, route)\\n    val restored: ActorRoute = serializer.fromBinary(serializer.toBinary(route), serializer.manifest(route)).asInstanceOf[ActorRoute]\\n\\n    assertThat(restored.id).isEqualTo(route.id)\\n    assertThat(restored.recipient).isEqualTo(recipient)\\n    assertThat(restored.replyTo).isEqualTo(system.deadLetters)\\n  }\\n\\n  @Test\\n  def jsonSerializerMigratesOlderPayloadsBeforeDeserialization(): Unit = withActorSystem(\\n\"}]}}], \"api\": \"openai-responses\", \"provider\": \"OCA\", \"model\": \"gpt-5.5\", \"usage\": {\"input\": 2658, \"output\": 1742, \"cacheRead\": 19456, \"cacheWrite\": 0, \"totalTokens\": 23856, \"cost\": {\"input\": 0, \"output\": 0, \"cacheRead\": 0, \"cacheWrite\": 0, \"total\": 0}}, \"stopReason\": \"toolUse\", \"timestamp\": 1778215166181, \"responseId\": \"resp_0d4d08b486d569410169fd68fef1a481a1b75fec1874a7529f\"}, \"toolResults\": [{\"role\": \"toolResult\", \"toolCallId\": \"call_RGlawmiXBHwf5Rvz7RxaD6KP|fc_0d4d08b486d569410169fd690e249c81a1bd5fb7b2a5576e14\", \"toolName\": \"edit\", \"content\": [{\"type\": \"text\", \"text\": \"Successfully re