{"type":"item.completed","item":{"id":"item_212","type":"command_execution","command":"/usr/bin/zsh -lc \"sed -n '1,220p' tests/src/org.springframework.boot/spring-boot-flyway/4.0.6/src/test/java/org_springframework_boot/spring_boot_flyway/FlywayMigrationInitializerTest.java\"","aggregated_output":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_springframework_boot.spring_boot_flyway;\n\nimport java.sql.Connection;\nimport java.sql.ResultSet;\nimport java.sql.SQLException;\nimport java.sql.Statement;\nimport java.util.UUID;\n\nimport javax.sql.DataSource;\n\nimport org.flywaydb.core.Flyway;\nimport org.flywaydb.core.api.configuration.Configuration;\nimport org.flywaydb.core.api.configuration.FluentConfiguration;\nimport org.flywaydb.core.api.output.MigrateResult;\nimport org.h2.jdbcx.JdbcDataSource;\nimport org.junit.jupiter.api.Test;\n\nimport org.springframework.boot.flyway.autoconfigure.FlywayMigrationInitializer;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class FlywayMigrationInitializerTest {\n\n    @Test\n    void runsMigrationWhenInitializerUsesReflectiveFallback() throws Exception {\n        DataSource dataSource = createDataSource();\n        Configuration configuration = new FluentConfiguration().dataSource(dataSource);\n        Flyway flyway = new FirstCallUnavailableFlyway(configuration);\n        FlywayMigrationInitializer initializer = new FlywayMigrationInitializer(flyway);\n\n        try {\n            initializer.afterPropertiesSet();\n\n            assertThat(count(dataSource, \"SELECT COUNT(*) FROM BOOKS\")).isEqualTo(1);\n            assertThat(count(dataSource, \"\"\"\n                    SELECT COUNT(*)\n                    FROM \"flyway_schema_history\"\n                    WHERE \"script\" = 'V1__create_books.sql' AND \"success\" = TRUE\n                    \"\"\")).isEqualTo(1);\n        }\n        finally {\n            execute(dataSource, \"SHUTDOWN\");\n        }\n    }\n\n    private DataSource createDataSource() {\n        JdbcDataSource dataSource = new JdbcDataSource();\n        String databaseName = UUID.randomUUID().toString().replace(\"-\", \"\");\n        dataSource.setURL(\"jdbc:h2:mem:\" + databaseName + \";DB_CLOSE_DELAY=-1\");\n        dataSource.setUser(\"sa\");\n        dataSource.setPassword(\"\");\n        return dataSource;\n    }\n\n    private int count(DataSource dataSource, String sql) throws SQLException {\n        try (Connection connection = dataSource.getConnection();\n                Statement statement = connection.createStatement();\n                ResultSet resultSet = statement.executeQuery(sql)) {\n            assertThat(resultSet.next()).isTrue();\n            return resultSet.getInt(1);\n        }\n    }\n\n    private void execute(DataSource dataSource, String sql) throws SQLException {\n        try (Connection connection = dataSource.getConnection();\n                Statement statement = connection.createStatement()) {\n            statement.execute(sql);\n        }\n    }\n\n    public static final class FirstCallUnavailableFlyway extends Flyway {\n\n        private boolean directCallUnavailable = true;\n\n        public FirstCallUnavailableFlyway(Configuration configuration) {\n            super(configuration);\n        }\n\n        @Override\n        public MigrateResult migrate() {\n            if (this.directCallUnavailable) {\n                this.directCallUnavailable = false;\n                throw new NoSuchMethodError(\"migrate\");\n            }\n            return super.migrate();\n        }\n\n    }\n\n}\n","exit_code":0,"status":"completed"}}
