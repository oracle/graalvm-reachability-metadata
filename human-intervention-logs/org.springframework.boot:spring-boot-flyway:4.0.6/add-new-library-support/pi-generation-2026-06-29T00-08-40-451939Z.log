  package org_springframework_boot.spring_boot_flyway;
  
  import java.sql.Connection;
  import java.sql.ResultSet;
  import java.sql.SQLException;
  import java.sql.Statement;
  import java.util.UUID;
  
  import javax.sql.DataSource;
  
  import org.flywaydb.core.Flyway;
  import org.flywaydb.core.api.configuration.Configuration;
  import org.flywaydb.core.api.configuration.FluentConfiguration;
  import org.flywaydb.core.api.output.MigrateResult;
  import org.h2.jdbcx.JdbcDataSource;
  import org.junit.jupiter.api.Test;
  
  import org.springframework.boot.flyway.autoconfigure.FlywayMigrationInitializer;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class FlywayMigrationInitializerTest {
  
      @Test
      void runsMigrationWhenInitializerUsesReflectiveFallback() throws Exception {
          DataSource dataSource = createDataSource();
          Configuration configuration = new FluentConfiguration().dataSource(dataSource);
          Flyway flyway = new FirstCallUnavailableFlyway(configuration);
          FlywayMigrationInitializer initializer = new FlywayMigrationInitializer(flyway);
  
          try {
              initializer.afterPropertiesSet();
  
              assertThat(count(dataSource, "SELECT COUNT(*) FROM BOOKS")).isEqualTo(1);
              assertThat(count(dataSource, """
                      SELECT COUNT(*)
                      FROM "flyway_schema_history"
                      WHERE "script" = 'V1__create_books.sql' AND "success" = TRUE
                      """)).isEqualTo(1);
          }
          finally {
              execute(dataSource, "SHUTDOWN");
          }
      }
  
      private DataSource createDataSource() {
          JdbcDataSource dataSource = new JdbcDataSource();
          String databaseName = UUID.randomUUID().toString().replace("-", "");
          dataSource.setURL("jdbc:h2:mem:" + databaseName + ";DB_CLOSE_DELAY=-1");
          dataSource.setUser("sa");
          dataSource.setPassword("");
          return dataSource;
      }
  
      private int count(DataSource dataSource, String sql) throws SQLException {
          try (Connection connection = dataSource.getConnection();
                  Statement statement = connection.createStatement();
                  ResultSet resultSet = statement.executeQuery(sql)) {
              assertThat(resultSet.next()).isTrue();
              return resultSet.getInt(1);
          }
      }
  
      private void execute(DataSource dataSource, String sql) throws SQLException {
          try (Connection connection = dataSource.getConnection();
                  Statement statement = connection.createStatement()) {
              statement.execute(sql);
          }
      }
  
      public static final class FirstCallUnavailableFlyway extends Flyway {
  
          private boolean directCallUnavailable = true;
  
          public FirstCallUnavailableFlyway(Configuration configuration) {
              super(configuration);
          }
  
          @Override
          public MigrateResult migrate() {
              if (this.directCallUnavailable) {
                  this.directCallUnavailable = false;
                  throw new NoSuchMethodError("migrate");
              }
              return super.migrate();
          }
  
      }
  
  }
[tool-exec] end id=call_LLXn42PDTaKLnyE1hpQb2Qhy|fc_09a1be87b3b073c2016a41b6357094819084b2762ca866571e name=read status=success
  CREATE TABLE books (
      id INT PRIMARY KEY,
      title VARCHAR(255) NOT NULL
  );
  
  INSERT INTO books (id, title) VALUES (1, 'Spring Boot Flyway');
