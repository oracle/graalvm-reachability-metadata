[tool-call] delta {"path":"tests/src/org.jboss.weld/weld-osgi-bundle/1.1.0.Final/src/test/java/org_jboss_weld/weld_osgi_bundle/ObjectImporterTest.java","edits":[{"oldText":"import java.net.Socket;\nimport java.nio.charset.StandardCharsets;\n","newText":"import java.net.Socket;\nimport java.nio.charset.StandardCharsets;\nimport java.lang.invoke.MethodHandle;\nimport java.lang.invoke.MethodHandles;\nimport java.lang.invoke.MethodType;\n"},{"oldText":"public class ObjectImporterTest {\n    private static final int SOCKET_TIMEOUT_MILLIS = 5_000;\n\n    @Test\n    void lookupObjectCreatesProxyFromRemoteClassName() throws Exception {","newText":"public class ObjectImporterTest {\n    private static final int SOCKET_TIMEOUT_MILLIS = 5_000;\n\n    @Test\n    void compilerGeneratedClassResolverUsesClassForName() throws Throwable {\n        MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(ObjectImporter.class, MethodHandles.lookup());\n        MethodHandle resolver = lookup.findStatic(\n                ObjectImporter.class,\n                \"class$\",\n                MethodType.methodType(Class.class, String.class));\n\n        Class<?> resolvedClass = (Class<?>) resolver.invoke(ObjectImporter.class.getName());\n\n        assertThat(resolvedClass).isSameAs(ObjectImporter.class);\n    }\n\n    @Test\n    void lookupObjectCreatesProxyFromRemoteClassName() throws Exception {"}]}
