[].class, bytes);\\n\\n\\t\\tassertThat(version.toString()).isEqualTo(\\\"1.2.3\\\");\\n\\t\\tassertThat(range.toString()).isEqualTo(\\\"[1.0.0,2.0.0)\\\");\\n\\t\\tassertThat(convertedBytes).containsExactly(1, 2, 3);\\n\\t}\\n\\n\\t@Test\\n\\tvoid convertsMapsToPublicFieldObjectsAndInterfaces() throws Exception {\\n\\t\\tConverter converter = new Converter();\\n\\n\\t\\tFileLine line = converter.convert(FileLine.class, Map.of(\\n\\t\\t\\t\\\"line\\\", \\\"12\\\",\\n\\t\\t\\t\\\"length\\\", 4,\\n\\t\\t\\t\\\"start\\\", 2,\\n\\t\\t\\t\\\"end\\\", \\\"6\\\"));\\n\\t\\tIntSupplier supplier = converter.convert(IntSupplier.class, Map.of(\\\"getAsInt\\\", \\\"7\\\"));\\n\\t\\tExtraCapturingBean bean = converter.convert(ExtraCapturingBean.class, Map.of(\\n\\t\\t\\t\\\"name\\\", \\\"alpha\\\",\\n\\t\\t\\t\\\"unknown\\\", \\\"beta\\\"));\\n\\n\\t\\tassertThat(line.line).isEqualTo(12);\\n\\t\\tassertThat(line.length).isEqualTo(4);\\n\\t\\tassertThat(line.start).isEqualTo(2);\\n\\t\\tassertThat(line.end).isEqualTo(6);\\n\\t\\tassertThat(supplier.getAsInt()).isEqualTo(7);\\n\\t\\tassertThat(bean.name).isEqualTo(\\\"alpha\\\");\\n\\t\\tassertThat(bean.__extra).containsEntry(\\\"unknown\\\", \\\"beta\\\");\\n\\t}\\n\\n\\t@Test\\n\\tvoid convertsToConcreteCollectionsArraysAndEnums() throws Exception {\\n\\t\\tConverter converter = new Converter();\\n\\n\\t\\tExtList<?> extList = converter.convert(ExtList.class, List.of(\\\"first\\\", \\\"second\\\"));\\n\\t\\tint[] ints = converter.convert(int[].class, List.of(\\\"1\\\", 2));\\n\\t\\tStrategy strategy = converter.convert(Strategy.class, 1);\\n\\t\\tList<Integer>[] genericArray = converter.convert(new TypeReference<List<Integer>[]>() {}, List.of(List.of(\\\"3\\\", 4)));\\n\\t\\tNumber[] typeVariableArray = convertToTypeVariableArray(converter, List.of(5));\\n\\t\\tObject wildcardConverted = converter.convert(new TypeReference<? extends Number>() {}.getType(), List.of(6));\\n\\t\\tNumber[] wildcardArray = (Number[]) wildcardConverted;\\n\\n\\t\\tassertThat(extList).containsExactly(\\\"first\\\", \\\"second\\\");\\n\\t\\tassertThat(ints).containsExactly(1, 2);\\n\\t\\tassertThat(strategy).isEqualTo(Strategy.EXACT);\\n\\t\\tassertThat(genericArray).hasSize(1);\\n\\t\\tassertThat(genericArray[0]).containsExactly(3, 4);\\n\\t\\tassertThat(typeVariableArray).containsExactly(5);\\n\\t\\tassertThat(wildcardArray).containsExactly(6);\\n\\t}\\n\\n\\t@Test\\n\\tvoid extractsPublicInstanceFieldsToMap() throws Exception {\\n\\t\\tConverter converter = new Converter();\\n\\t\\tFileLine line = new FileLine();\\n\\t\\tline.line = 8;\\n\\t\\tline.length = 13;\\n\\t\\tline.start = 21;\\n\\t\\tline.end = 34;\\n\\n\\t\\tMap<?, ?> map = converter.toMap(line);\\n\\n\\t\\tassertThat(map).containsEntry(\\\"line\\\", 8)\\n\\t\\t\\t.containsEntry(\\\"length\\\", 13)\\n\\t\\t\\t.containsEntry(\\\"start\\\", 21)\\n\\t\\t\\t.containsEntry(\\\"end\\\", 34);\\n\\t}\\n\\n\\tprivate <T extends Number> Number[] convertToTypeVariableArray(Converter converter, Object source) throws Exception {\\n\\t\\tObject converted = converter.convert(new TypeReference<T>() {}.getType(), source);\\n\\t\\treturn (Number[]) converted;\\n\\t}\\n\\n\\tpublic static class ExtraCapturingBean {\\n\\t\\tpublic String name;\\n\\t\\tpublic Map<String, Object> __extra;\\n\\n\\t\\tpublic ExtraCapturingBean() {}\\n\\t}\\n}\\n\"}], \"isError\": false, \"timestamp\": 1778168765907}]}\n[recv] {\"type\": \"turn_start\"}\n[recv] {\"type\": \"message_start\", \"message\": {\"role\": \"assistant\", \"content\": [], \"api\": \"openai-responses\", \"provider\": \"OCA\", \"model\": \"gpt-5.5\", \"usage\": {\"input\": 0, \"output\": 0, \"cacheRead\": 0, \"cacheWrite\": 0, \"totalTokens\": 0, \"cost\": {\"input\": 0, \"output\": 0, \"cacheRead\": 0, \"cacheWrite\": 0, \"total\": 0}}, \"stopReason\": \"stop\", \"timestamp\": 1778168765911}}\n[assistant-event] thinking_start\n[assistant-event] thinking_end\n[tool-call] start id=unknown\n[tool-call] delta {\"path\":\"t