{"type":"item.completed","item":{"id":"item_14","type":"command_execution","command":"/usr/bin/bash -lc \"sed -n '1,220p' tests/src/biz.aQute.bnd/biz.aQute.bndlib/6.4.1/src/test/java/biz_aQute_bnd/biz_aQute_bndlib/ConfigurableInnerConfigurableHandlerTest.java\"","aggregated_output":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage biz_aQute_bnd.biz_aQute_bndlib;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport aQute.bnd.annotation.metatype.Configurable;\nimport aQute.bnd.osgi.Annotation;\nimport aQute.bnd.osgi.Annotation.ElementType;\nimport aQute.bnd.osgi.Descriptors;\n\nimport java.lang.annotation.RetentionPolicy;\nimport java.util.LinkedHashMap;\nimport java.util.Map;\nimport java.util.TreeMap;\n\nimport org.junit.jupiter.api.Test;\n\npublic class ConfigurableInnerConfigurableHandlerTest {\n    @Test\n    void convertsClassesArraysMapsAndBndAnnotationValues() {\n        Map<String, Object> properties = new LinkedHashMap<>();\n        properties.put(\"plainClass\", \"java.lang.String\");\n        properties.put(\"genericClass\", \"java.lang.Integer\");\n        properties.put(\"numbers\", \"1|2|3\");\n        properties.put(\"integerMap\", Map.of(\"one\", \"1\", \"two\", \"2\"));\n        properties.put(\"marker\", markerAnnotation(\"configured\"));\n\n        ConversionConfiguration configuration = Configurable.createConfigurable(ConversionConfiguration.class,\n            properties);\n\n        assertThat(configuration.plainClass()).isSameAs(String.class);\n        assertThat(configuration.genericClass()).isSameAs(Integer.class);\n        assertThat(configuration.numbers()).containsExactly(1, 2, 3);\n        assertThat(configuration.integerMap()).containsEntry(\"one\", 1)\n            .containsEntry(\"two\", 2);\n        assertThat(configuration.marker()\n            .value()).isEqualTo(\"configured\");\n    }\n\n    private static Annotation markerAnnotation(String value) {\n        Descriptors descriptors = new Descriptors();\n        return new Annotation(descriptors.getTypeRefFromFQN(Marker.class.getName()), Map.of(\"value\", value),\n            ElementType.TYPE, RetentionPolicy.RUNTIME);\n    }\n\n    public interface ConversionConfiguration {\n        @SuppressWarnings(\"rawtypes\")\n        Class plainClass();\n\n        Class<?> genericClass();\n\n        Integer[] numbers();\n\n        TreeMap<String, Integer> integerMap();\n\n        Marker marker();\n    }\n\n    public @interface Marker {\n        String value();\n    }\n}\n","exit_code":0,"status":"completed"}}
