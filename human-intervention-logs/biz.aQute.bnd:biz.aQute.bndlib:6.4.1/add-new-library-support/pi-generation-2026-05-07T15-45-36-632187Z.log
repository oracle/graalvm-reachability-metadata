  		}
  
  		if (o instanceof Map) {
  			String key = null;
  			try {
  				Map<Object, Object> map = (Map) o;
  				MethodHandle mh = publicLookup().findConstructor(resultType, methodType(void.class));
  				Object instance = mh.invoke();
