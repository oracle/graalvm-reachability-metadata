 {\n\t\tConverter converter = new Converter();\n\t\tFileLine line = new FileLine();\n\t\tline.line = 8;\n\t\tline.length = 13;\n\t\tline.start = 21;\n\t\tline.end = 34;\n\n\t\tMap<?, ?> map = converter.toMap(line);\n\n\t\tassertThat(map).containsEntry(\"line\", 8)\n\t\t\t.containsEntry(\"length\", 13)\n\t\t\t.containsEntry(\"start\", 21)\n\t\t\t.containsEntry(\"end\", 34);\n\t}\n\n\tprivate <T extends Number> Number[] convertToTypeVariableArray(Converter converter, Object source) throws Exception {\n\t\tObject converted = converter.convert(new TypeReference<T>() {}, source);\n\t\treturn (Number[]) converted;\n\t}\n\n\tpublic static class ExtraCapturingBean {\n\t\tpublic String name;\n\t\tpublic Map<String, Object> __extra;\n\n\t\tpublic ExtraCapturingBean() {}\n\t}\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 298, "output": 1763, "cacheRead": 69120, "cacheWrite": 0, "totalTokens": 71181, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778168629382, "responseId": "resp_0b27dad7ed3535840169fcb33784408192b04c591f69764023"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_W7zXVgJ1OcfDgxdFKFK4PQus|fc_0b27dad7ed3535840169fcb33ff714819294b6c2d2986d4645", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 3894 bytes to tests/src/biz.aQute.bnd/biz.aQute.bndlib/6.4.1/src/test/java/biz_aQute_bnd/biz_aQute_bndlib/ConverterTest.java"}], "isError": false, "timestamp": 1778168648888}]}
