     Descriptors descriptors = new Descriptors();\n        return new Annotation(descriptors.getTypeRefFromFQN(Marker.class.getName()), Map.of(\"value\", value),\n            ElementType.TYPE, RetentionPolicy.RUNTIME);\n    }\n\n    public interface ConversionConfiguration {\n        @SuppressWarnings(\"rawtypes\")\n        Class plainClass();\n\n        Class<?> genericClass();\n\n        Integer[] numbers();\n\n        TreeMap<String, Integer> integerMap();\n\n        Marker marker();\n    }\n\n    public @interface Marker {\n        String value();\n    }\n}\n"}
