  diff --git 1/tests/src/biz.aQute.bnd/biz.aQute.bndlib/6.4.1/src/test/java/biz_aQute_bnd/biz_aQute_bndlib/ReflectActionTest.java 2/tests/src/biz.aQute.bnd/biz.aQute.bndlib/6.4.1/src/test/java/biz_aQute_bnd/biz_aQute_bndlib/ReflectActionTest.java
  new file mode 100644
  index 0000000000..7eb98da77b
  --- /dev/null
  +++ 2/tests/src/biz.aQute.bnd/biz.aQute.bndlib/6.4.1/src/test/java/biz_aQute_bnd/biz_aQute_bndlib/ReflectActionTest.java
  @@ -0,0 +1,98 @@
  +/*
  + * Copyright and related rights waived via CC0
  + *
  + * You should have received a copy of the CC0 legalcode along with this
  + * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.
  + */
  +package biz_aQute_bnd.biz_aQute_bndlib;
  +
  +import static org.assertj.core.api.Assertions.assertThat;
  +
  +import java.io.File;
  +import java.nio.file.Files;
  +import java.nio.file.Path;
  +
  +import org.junit.jupiter.api.Test;
  +import org.junit.jupiter.api.io.TempDir;
  +
  +import aQute.bnd.build.Project;
  +import aQute.bnd.build.ReflectAction;
  +import aQute.bnd.build.Workspace;
  +
  +public class ReflectActionTest {
  +	@TempDir
  +	Path temporaryDirectory;
  +
  +	@Test
  +	void executeWithActionNameInvokesPublicNoArgumentMethodByName() throws Exception {
  +		try (ActionWorkspace workspace = newWorkspace(); ActionProject project = newProject(workspace, "direct")) {
  +			ReflectAction action = new ReflectAction("directOnly");
  +
  +			action.execute(project, "ignored-action-name");
  +
  +			assertThat(project.directOnlyInvocations).isEqualTo(1);
  +		}
  +	}
  +
  +	@Test
  +	void executeWithNoVarargsScansPublicMethodsAndInvokesMatchingNoArgumentMethod() throws Exception {
  +		try (ActionWorkspace workspace = newWorkspace(); ActionProject project = newProject(workspace, "noargs")) {
  +			ReflectAction action = new ReflectAction("noArgAction");
  +
  +			action.execute(project);
  +
  +			assertThat(project.noArgInvocations).isEqualTo(1);
  +		}
  +	}
  +
  +	@Test
  +	void executeWithVarargsConvertsArgumentsBeforeInvokingMatchingMethod() throws Exception {
  +		try (ActionWorkspace workspace = newWorkspace(); ActionProject project = newProject(workspace, "converted")) {
  +			ReflectAction action = new ReflectAction("stringAction");
  +
  +			action.execute(project, new StringBuilder("converted-value"));
  +
  +			assertThat(project.convertedValue).isEqualTo("converted-value");
  +		}
  +	}
  +
  +	private ActionWorkspace newWorkspace() throws Exception {
  +		Path workspaceDirectory = temporaryDirectory.resolve("workspace-" + System.nanoTime());
  +		Files.createDirectories(workspaceDirectory.resolve(Workspace.CNFDIR));
  +		return new ActionWorkspace(workspaceDirectory.toFile());
  +	}
  +
  +	private ActionProject newProject(Workspace workspace, String name) throws Exception {
  +		Path projectDirectory = temporaryDirectory.resolve("project-" + name + "-" + System.nanoTime());
  +		Files.createDirectories(projectDirectory);
  +		return new ActionProject(workspace, projectDirectory.toFile());
  +	}
  +
  +	public static class ActionProject extends Project {
  +		int directOnlyInvocations;
  +		int noArgInvocations;
  +		String convertedValue;
  +
  +		public ActionProject(Workspace workspace, File buildDirectory) {
  +			super(workspace, buildDirectory);
  +		}
  +
  +		public void directOnly() {
  +			directOnlyInvocations++;
  +		}
  +
  +		public void noArgAction() {
  +			noArgInvocations++;
  +		}
  +
  +		public void stringAction(String value) {
  +			convertedValue = value;
  +		}
  +	}
  +
  +	private static class ActionWorkspace extends Workspace {
  +		ActionWorkspace(File workspaceDirectory) throws Exception {
  +			super(workspaceDirectory);
  +		}
  +	}
  +}
