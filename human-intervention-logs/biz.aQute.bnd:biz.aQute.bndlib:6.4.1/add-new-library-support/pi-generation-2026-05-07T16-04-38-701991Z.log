  package biz_aQute_bnd.biz_aQute_bndlib;
  
  import static org.assertj.core.api.Assertions.assertThat;
  import static org.assertj.core.api.Assertions.assertThatThrownBy;
  
  import java.io.File;
  import java.util.Map;
  import java.util.Properties;
  
  import org.junit.jupiter.api.Test;
  
  import aQute.bnd.osgi.Macro;
  import aQute.bnd.osgi.Processor;
  
  public class MacroTest {
  	@Test
  	void invokesBuiltInMacroCommandThroughMethodHandles() throws Exception {
  		try (Processor processor = new Processor()) {
  			Macro macro = processor.getReplacer();
  
  			String expanded = macro.process("${path;alpha;beta;gamma}");
  
  			assertThat(expanded).isEqualTo(String.join(File.pathSeparator, "alpha", "beta", "gamma"));
  		}
  	}
  
  	@Test
  	void discoversCommandHelpFieldsThroughPublicApi() throws Exception {
  		try (Processor processor = new Processor()) {
  			Macro macro = processor.getReplacer();
  
  			Map<String, String> commands = macro.getCommands();
  
  			assertThat(commands).containsKeys("path", "osfile", "size");
  			assertThat(commands.get("size")).contains("${size;");
  		}
  	}
  
  	@Test
  	void exposesDefaultsParentWhenHiddenJdkFieldIsAccessible() {
  		Properties defaults = new Properties();
  		defaults.setProperty("inherited", "value");
  		Properties child = new Properties(defaults);
  
  		Properties parent = Macro.getParent(child);
  
  		assertThat(child.getProperty("inherited")).isEqualTo("value");
  		if (parent != null) {
  			assertThat(parent).isSameAs(defaults);
  		}
  	}
  
  	@Test
  	void testDebugCommandConstructsExceptionsReflectively() throws Exception {
  		try (Processor processor = new Processor()) {
  			Macro macro = new Macro(processor);
  			macro.inTest = true;
  
  			assertThatThrownBy(() -> macro.__testdebug(new String[] {
  				"_testdebug", "exception", "java.lang.IllegalArgumentException", "boom"
  			})).isInstanceOf(IllegalArgumentException.class)
  				.hasMessage("boom");
  			assertThatThrownBy(() -> macro.__testdebug(new String[] {
  				"_testdebug", "exception", "java.lang.RuntimeException"
  			})).isInstanceOf(RuntimeException.class);
  		}
  	}
  }
