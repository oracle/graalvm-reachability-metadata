  	public List<Capability> addProvideCapabilities(Parameters capabilities) {
  		List<Capability> added = capabilities.stream()
  			.mapKey(Processor::removeDuplicateMarker)
  			.mapToObj(this::addProvideCapability)
  			.collect(toList());
  		return added;
