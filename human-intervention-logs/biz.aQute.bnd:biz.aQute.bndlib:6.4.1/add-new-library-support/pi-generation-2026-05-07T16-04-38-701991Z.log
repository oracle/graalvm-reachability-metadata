s attrs = new Attrs();\n\t\t\tattrs.put(\"name\", \"sample\");\n\n\t\t\tResult<List<PluginApi>> result = workspace.getExternalPlugins()\n\t\t\t\t.getImplementations(PluginApi.class, attrs);\n\t\t\tList<PluginApi> plugins = result.unwrap();\n\n\t\t\tassertThat(plugins).hasSize(1);\n\t\t\tassertThat(plugins.get(0)\n\t\t\t\t.message()).isEqualTo(\"loaded\");\n\t\t\t((AutoCloseable) plugins.get(0)).close();\n\t\t} catch (Error error) {\n\t\t\trethrowIfNotNativeImageDynamicClassLoadingError(error);\n\t\t}\n\t}\n\n\tprivate ExternalPluginWorkspace newWorkspace() throws Exception {\n\t\tPath workspaceDirectory = temporaryDirectory.resolve(\"workspace-\" + System.nanoTime());\n\t\tFiles.createDirectories(workspaceDirectory.resolve(\"cnf\"));\n\t\tFile pluginJar = createEmptyJar(temporaryDirectory.resolve(\"external-plugin-\" + System.nanoTime() + \".jar\"));\n\t\treturn new ExternalPluginWorkspace(workspaceDirectory.toFile(), pluginJar, PluginImplementation.class.getName());\n\t}\n\n\tprivate static File createEmptyJar(Path path) throws IOException {\n\t\ttry (JarOutputStream ignored = new JarOutputStream(Files.newOutputStream(path))) {\n\t\t\treturn path.toFile();\n\t\t}\n\t}\n\n\tprivate static void rethrowIfNotNativeImageDynamicClassLoadingError(Error error) {\n\t\tif (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n\t\t\tthrow error;\n\t\t}\n\t}\n\n\tpublic interface PluginApi {\n\t\tString message();\n\t}\n\n\tpublic static class PluginImplementation implements PluginApi {\n\t\t@Override\n\t\tpublic String message() {\n\t\t\treturn \"loaded\";\n\t\t}\n\t}\n\n\tprivate static class ExternalPluginWorkspace extends Workspace {\n\t\tprivate final File pluginJar;\n\t\tprivate final Capability capability;\n\n\t\tExternalPluginWorkspace(File workspaceDirectory, File pluginJar, String implementationClassName) throws Exception {\n\t\t\tsuper(workspaceDirectory);\n\t\t\tthis.pluginJar = pluginJar;\n\t\t\tthis.capability = new ExternalPluginCapability(new ExternalPluginResource(), implementationClassName);\n\t\t}\n\n\t\t@Override\n\t\tpublic Stream<Capability> findProviders(String namespace, String filter) {\n\t\t\tif (ExternalPluginNamespace.EXTERNAL_PLUGIN_NAMESPACE.equals(namespace)) {\n\t\t\t\treturn Stream.of(capability);\n\t\t\t}\n\t\t\treturn Stream.empty();\n\t\t}\n\n\t\t@Override\n\t\tpublic Result<File> getBundle(Resource resource) {\n\t\t\treturn Result.ok(pluginJar);\n\t\t}\n\t}\n\n\tprivate static class ExternalPluginCapability implements Capability {\n\t\tprivate final Resource resource;\n\t\tprivate final Map<String, Object> attributes;\n\n\t\tExternalPluginCapability(Resource resource, String implementationClassName) {\n\t\t\tthis.resource = resource;\n\t\t\tthis.attributes = Map.of(ExternalPluginNamespace.CAPABILITY_NAME_ATTRIBUTE, \"sample\",\n\t\t\t\tExternalPluginNamespace.CAPABILITY_OBJECTCLASS_ATTRIBUTE, PluginApi.class.getName(),\n\t\t\t\tExternalPluginNamespace.CAPABILITY_IMPLEMENTATION_ATTRIBUTE, implementationClassName,\n\t\t\t\tExternalPluginNamespace.VERSION_ATTRIBUTE, \"1.0.0\");\n\t\t}\n\n\t\t@Override\n\t\tpublic String getNamespace() {\n\t\t\treturn ExternalPluginNamespace.EXTERNAL_PLUGIN_NAMESPACE;\n\t\t}\n\n\t\t@Override\n\t\tpublic Map<String, String> getDirectives() {\n\t\t\treturn Collections.emptyMap();\n\t\t}\n\n\t\t@Override\n\t\tpublic Map<String, Object> getAttributes() {\n\t\t\treturn attributes;\n\t\t}\n\n\t\t@Override\n\t\tpublic Resource getResource() {\n\t\t\treturn resource;\n\t\t}\n\t}\n\n\tprivate static class ExternalPluginResource implements Resource {\n\t\t@Override\n\t\tpublic List<Capability> getCapabilities(String namespace) {\n\t\t\treturn Collections.emptyList();\n\t\t}\n\n\t\t@Override\n\t\tpublic List<Requirement> getRequirements(String namespace) {\n\t\t\treturn Collections.emptyList();\n\t\t}\n\t}\n}\n"}
