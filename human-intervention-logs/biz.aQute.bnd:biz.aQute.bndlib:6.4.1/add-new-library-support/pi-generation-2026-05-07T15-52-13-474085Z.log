ws Exception {\n\t\ttry (Processor processor = new Processor()) {\n\t\t\tMacro macro = processor.getReplacer();\n\n\t\t\tMap<String, String> commands = macro.getCommands();\n\n\t\t\tassertThat(commands).containsKeys(\"path\", \"osfile\", \"size\");\n\t\t\tassertThat(commands.get(\"size\")).contains(\"${size;\");\n\t\t}\n\t}\n\n\t@Test\n\tvoid exposesDefaultsParentWhenHiddenJdkFieldIsAccessible() {\n\t\tProperties defaults = new Properties();\n\t\tdefaults.setProperty(\"inherited\", \"value\");\n\t\tProperties child = new Properties(defaults);\n\n\t\tProperties parent = Macro.getParent(child);\n\n\t\tassertThat(child.getProperty(\"inherited\")).isEqualTo(\"value\");\n\t\tif (parent != null) {\n\t\t\tassertThat(parent).isSameAs(defaults);\n\t\t}\n\t}\n\n\t@Test\n\tvoid testDebugCommandConstructsExceptionsReflectively() {\n\t\tMacro macro = new Macro(new Processor());\n\t\tmacro.inTest = true;\n\n\t\tassertThatThrownBy(() -> macro.__testdebug(new String[] {\n\t\t\t\"_testdebug\", \"exception\", \"java.lang.IllegalArgumentException\", \"boom\"\n\t\t})).isInstanceOf(IllegalArgumentException.class)\n\t\t\t.hasMessage(\"boom\");\n\t\tassertThatThrownBy(() -> macro.__testdebug(new String[] {\n\t\t\t\"_testdebug\", \"exception\", \"java.lang.RuntimeException\"\n\t\t})).isInstanceOf(RuntimeException.class);\n\t}\n}\n"}], "isError": false, "timestamp": 1778169092633}]}
