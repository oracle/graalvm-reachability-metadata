.assertj.core.api.Assertions.assertThat\nimport org.graalvm.internal.tck.NativeImageSupport\nimport org.junit.jupiter.api.Test\n\nimport scala.quoted.Expr\nimport scala.quoted.Quotes\nimport scala.quoted.Type\n\nobject LoadNamingMacroBridge {\n  inline def namingDefault[T <: NamingStrategy]: String = ${ namingDefaultImpl[T] }\n\n  def namingDefaultImpl[T <: NamingStrategy: Type](using Quotes): Expr[String] = {\n    val namingStrategy: NamingStrategy = LoadNaming.static[T].get\n    Expr(namingStrategy.default(\"PersonName\"))\n  }\n}\n\nclass LoadNamingTest {\n  @Test\n  def loadsNamingStrategySingletonDuringMacroExpansion(): Unit = {\n    assertSupportedOpenEndedCompilation { () =>\n      val result: String = evaluateScala(\n        \"\"\"\n          |import io.getquill.Literal\n          |import io_getquill.quill_sql_3.LoadNamingMacroBridge\n          |\n          |LoadNamingMacroBridge.namingDefault[Literal.type]\n          |\"\"\".stripMargin\n      )\n\n      assertThat(result).isEqualTo(\"PersonName\")\n    }\n  }\n\n  private def evaluateScala(source: String): String = {\n    val engine = new dotty.tools.repl.ScriptEngine()\n    engine.eval(source).asInstanceOf[String]\n  }\n\n  private def assertSupportedOpenEndedCompilation(action: () => Unit): Unit = {\n    try action()\n    catch {\n      case error: Error =>\n        if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n          throw error\n        }\n    }\n  }\n}\n"}, "partialJson": "{\"path\":\"tests/src/io.getquill/quill-sql_3/4.8.6/src/test/scala/io_getquill/quill_sql_3/LoadNamingTest.scala\",\"content\":\"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage io_getquill.quill_sql_3\\n\\nimport io.getquill.NamingStrategy\\nimport io.getquill.idiom.LoadNaming\\nimport org.assertj.core.api.Assertions.assertThat\\nimport org.graalvm.internal.tck.NativeImageSupport\\nimport org.junit.jupiter.api.Test\\n\\nimport scala.quoted.Expr\\nimport scala.quoted.Quotes\\nimport scala.quoted.Type\\n\\nobject LoadNamingMacroBridge {\\n  inline def namingDefault[T <: NamingStrategy]: String = ${ namingDefaultImpl[T] }\\n\\n  def namingDefaultImpl[T <: NamingStrategy: Type](using Quotes): Expr[String] = {\\n    val namingStrategy: NamingStrategy = LoadNaming.static[T].get\\n    Expr(namingStrategy.default(\\\"PersonName\\\"))\\n  }\\n}\\n\\nclass LoadNamingTest {\\n  @Test\\n  def loadsNamingStrategySingletonDuringMacroExpansion(): Unit = {\\n    assertSupportedOpenEndedCompilation { () =>\\n      val result: String = evaluateScala(\\n        \\\"\\\"\\\"\\n          |import io.getquill.Literal\\n          |import io_getquill.quill_sql_3.LoadNamingMacroBridge\\n          |\\n          |LoadNamingMacroBridge.namingDefault[Literal.type]\\n          |\\\"\\\"\\\".stripMargin\\n      )\\n\\n      assertThat(result).isEqualTo(\\\"PersonName\\\")\\n    }\\n  }\\n\\n  private def evaluateScala(source: String): String = {\\n    val engine = new dotty.tools.repl.ScriptEngine()\\n    engine.eval(source).asInstanceOf[String]\\n  }\\n\\n  private def assertSupportedOpenEndedCompilation(action: () => Unit): Unit = {\\n    try action()\\n    catch {\\n      case error: Error =>\\n        if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\\n          throw error\\n        }\\n    }\\n  }\\n}\\n\"}"}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1873, "output": 1029, "cacheRead": 22016, "cacheWrite": 0, "totalTokens": 24918, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778124285132, "responseId": "resp_09f7bc24336765200169fc05fdd66881978c432dd7f41ea653"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_D0Ns98LgkK43NfdIt8msB3gg|fc_09f7bc24336765200169fc060a2d588197871063d21b9c2c46", "tool