  package io_getquill.quill_sql_3
  
  import io.getquill.util.Load
  import org.assertj.core.api.Assertions.assertThat
  import org.graalvm.internal.tck.NativeImageSupport
  import org.junit.jupiter.api.Test
  
  import scala.quoted.Expr
  import scala.quoted.Quotes
  import scala.quoted.Type
  import scala.reflect.ClassTag
  import scala.util.Try
  
  object LoadModuleProbe
  
  final class LoadClassProbe
  
  object LoadMacroBridge {
    inline def moduleClassName[T]: String = ${ moduleClassNameImpl[T] }
  
    def moduleClassNameImpl[T: Type](using Quotes): Expr[String] = {
      val module: T = Load.Module[T].get
      Expr(module.getClass.getName)
    }
  
    inline def className[T]: String = ${ classNameImpl[T] }
  
    def classNameImpl[T: Type](using quotes: Quotes): Expr[String] = {
      import quotes.reflect.TypeRepr
  
      val loadedClass: Class[?] = Load.Class.fromTypeRepr(TypeRepr.of[T]).get
      Expr(loadedClass.getName)
    }
  }
  
  class LoadTest {
    @Test
    def loadsScalaModuleFromClassTag(): Unit = {
      val moduleTag: ClassTag[LoadModuleProbe.type] =
        ClassTag(LoadModuleProbe.getClass).asInstanceOf[ClassTag[LoadModuleProbe.type]]
      val loadedModule: Try[LoadModuleProbe.type] = Load.Module.fromClassTag[LoadModuleProbe.type](moduleTag)
  
      assertThat(loadedModule.isSuccess).isTrue()
      assertThat(loadedModule.get).isSameAs(LoadModuleProbe)
    }
  
    @Test
    def loadsModuleAndClassFromTypeReprDuringMacroExpansion(): Unit = {
      assertSupportedOpenEndedCompilation { () =>
        val result: String = evaluateScala(
          """
            |import io_getquill.quill_sql_3.LoadClassProbe
            |import io_getquill.quill_sql_3.LoadMacroBridge
            |import io_getquill.quill_sql_3.LoadModuleProbe
            |
            |val loadedModuleName: String = LoadMacroBridge.moduleClassName[LoadModuleProbe.type]
            |val loadedClassName: String = LoadMacroBridge.className[LoadClassProbe]
            |loadedModuleName + "\n" + loadedClassName
            |""".stripMargin
        )
  
        assertThat(result).isEqualTo(LoadModuleProbe.getClass.getName + "\n" + classOf[LoadClassProbe].getName)
      }
    }
  
    private def evaluateScala(source: String): String = {
      val engine = new dotty.tools.repl.ScriptEngine()
      engine.eval(source).asInstanceOf[String]
    }
  
    private def assertSupportedOpenEndedCompilation(action: () => Unit): Unit = {
      try action()
      catch {
        case error: Error =>
          if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
            throw error
          }
      }
    }
  }
