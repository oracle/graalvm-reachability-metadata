tj.core.api.Assertions.assertThat\nimport org.graalvm.internal.tck.NativeImageSupport\nimport org.junit.jupiter.api.Test\n\nimport scala.quoted.Expr\nimport scala.quoted.Quotes\nimport scala.quoted.Type\nimport scala.reflect.ClassTag\nimport scala.util.Try\n\nobject LoadModuleProbe\n\nfinal class LoadClassProbe\n\nobject LoadMacroBridge {\n  inline def moduleClassName[T]: String = ${ moduleClassNameImpl[T] }\n\n  def moduleClassNameImpl[T: Type](using Quotes): Expr[String] = {\n    val module: T = Load.Module[T].get\n    Expr(module.getClass.getName)\n  }\n\n  inline def className[T]: String = ${ classNameImpl[T] }\n\n  def classNameImpl[T: Type](using quotes: Quotes): Expr[String] = {\n    import quotes.reflect.TypeRepr\n\n    val loadedClass: Class[?] = Load.Class.fromTypeRepr(TypeRepr.of[T]).get\n    Expr(loadedClass.getName)\n  }\n}\n\nclass LoadTest {\n  @Test\n  def loadsScalaModuleFromClassTag(): Unit = {\n    val moduleTag: ClassTag[LoadModuleProbe.type] =\n      ClassTag(LoadModuleProbe.getClass).asInstanceOf[ClassTag[LoadModuleProbe.type]]\n    val loadedModule: Try[LoadModuleProbe.type] = Load.Module.fromClassTag[LoadModuleProbe.type](moduleTag)\n\n    assertThat(loadedModule.isSuccess).isTrue()\n    assertThat(loadedModule.get).isSameAs(LoadModuleProbe)\n  }\n\n  @Test\n  def loadsModuleAndClassFromTypeReprDuringMacroExpansion(): Unit = {\n    assertSupportedOpenEndedCompilation { () =>\n      val result: String = evaluateScala(\n        \"\"\"\n          |import io_getquill.quill_sql_3.LoadClassProbe\n          |import io_getquill.quill_sql_3.LoadMacroBridge\n          |import io_getquill.quill_sql_3.LoadModuleProbe\n          |\n          |val loadedModuleName: String = LoadMacroBridge.moduleClassName[LoadModuleProbe.type]\n          |val loadedClassName: String = LoadMacroBridge.className[LoadClassProbe]\n          |loadedModuleName + \"\\n\" + loadedClassName\n          |\"\"\".stripMargin\n      )\n\n      assertThat(result).isEqualTo(LoadModuleProbe.getClass.getName + \"\\n\" + classOf[LoadClassProbe].getName)\n    }\n  }\n\n  private def evaluateScala(source: String): String = {\n    val engine = new dotty.tools.repl.ScriptEngine()\n    engine.eval(source).asInstanceOf[String]\n  }\n\n  private def assertSupportedOpenEndedCompilation(action: () => Unit): Unit = {\n    try action()\n    catch {\n      case error: Error =>\n        if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n          throw error\n        }\n    }\n  }\n}\n"}], "isError": false, "timestamp": 1778124179918}, {"role": "toolResult", "toolCallId": "call_ikmXX3ClKB5slUNqdBlqTTus|fc_09f7bc24336765200169fc05938b6481978fd42700d900dc74", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_getquill.quill_sql_3\n\nimport org.junit.jupiter.api.Test\n\nclass Quill_sql_3Test {\n  @Test\n  def test(): Unit = {\n    println(\"This is just a placeholder, implement your test\")\n  }\n}\n"}], "isError": false, "timestamp": 1778124179918}, {"role": "toolResult", "toolCallId": "call_SbS8Fnd0eUN3ahQrR7bXsh3J|fc_09f7bc24336765200169fc05938b6c8197bb8e8bbccd1a0db4", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_getquill.quill_sql_3\n\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\n\nimport java.lang.reflect.Method\n\nobject ReflectivePathChainLookupFixtures {\n  object Nested {\n    def computed: Int = 23\n  }\n}\n\nfinal class ReflectivePathChainLookupTest {\n  // The source object is package-private, but these bytecode entry points are the reflective lookup surface under test.\n  @Test\n  def resolvesNestedModuleMethodPath(): Unit = {\n    val lookupClass: Class[?] = Class.forName(\"io.getquill.context.ReflectivePathChainLookup$\")\n    val lookupModule: Object = lookupClass.getField(\"MODULE$\").get(null)\n    val applyMethod: Method = lookupClass.getMethod(\n      \"apply\",\n      classOf[Object],\n      classOf[scala.collection.immutable.List[?]]\n    )\n\n    val result: Either[String, Object] = applyMethod\n      .invoke(lookupModule, ReflectivePathChainLookupFixtures, List(\"Nested\", \"computed\"))\n      .asInstanceOf[Either[String, Object]]\n\n    assertThat(result.isRight).isTrue()\n    assertThat(result.toString).contains(\"Right(Value(23))\")\n  }\n\n  @Test\n  def resolvesPublicFieldLookup(): Unit = {\n    val lookupClass: Class[?] = Class.forName(\"io.getquill.context.ReflectivePathChainLookup$Lookup$\")\n    val lookupModule: Object = lookupClass.getField(\"MODULE$\").get(null)\n    val lookupFirstFieldMethod: Method = lookupClass.getMethod(\n      \"lookupFirstField\",\n      classOf[String],\n      classOf[Class[?]],\n      classOf[Object],\n      classOf[String]\n    )\n    val nestedModule: Object = ReflectivePathChainLookupFixtures.Nested\n\n    val result: Option[Object] = lookupFirstFieldMethod\n      .invoke(lookupModule, \"MODULE$\", nestedModule.getClass, nestedModule, \"field\")\n      .asInstanceOf[Option[Object]]\n\n    assertThat(result).isEqualTo(Some(nestedModule))\n  }\n}\n"}], "isError": false, "timestamp": 1778124179919}, {"role": "toolResult", "toolCallId": "call_qNXkEQkD1Majd5xTp0U4MZYB|fc_09f7bc24336765200169fc05938b748197a6921a3f13cf604a", "toolName": "read", "content": [{"type": "text", "text": "package io.getquill.idiom\n\nimport scala.util.Try\n\nimport scala.quoted.{Type => TType, _}\n\nimport io.getquill.NamingStrategy\nimport io.getquill.util.CollectTry\nimport io.getquill.util.Load\nimport io.getquill.CompositeNamingStrategy\nimport scala.util.Success\nimport scala.util.Failure\nimport io.getquill.util.Format\nimport io.getquill.util.CommonExtensions.Option._\n\nobject LoadNaming {\n\n  def static[T: TType](using Quotes): Try[NamingStrategy] = {\n    import quotes.reflect.{Try => _, _}\n\n    def `endWith$`(str: String) =\n      if (str.endsWith(\"$\")) str else str + \"$\"\n\n    def loadFromTastyType[T](tpe: TypeRepr): Try[T] = {\n      val loadClassType = tpe\n      for {\n        optClassSymbol <- Try(loadClassType.classSymbol)\n        className <- Try {\n          optClassSymbol match {\n            case Some(value) => Success(value.fullName)\n            case None =>\n              if (!loadClassType.termSymbol.moduleClass.isNoSymbol)\n                Success(loadClassType.termSymbol.moduleClass.fullName)\n              else\n                Failure(new IllegalArgumentException(s\"The class ${loadClassType.show} cannot be loaded because it is not a scala class or module\"))\n          }\n        }.flatten\n        field <- Try {\n          val clsFull = `endWith$`(className)\n          val cls = Class.forName(clsFull)\n          val field = cls.getField(\"MODULE$\")\n          field.get(cls).asInstanceOf[T]\n        }\n      } yield (field)\n    }\n\n    CollectTry {\n      strategies[T].map(loadFromTastyType[NamingStrategy](_))\n    }.map(NamingStrategy(_))\n  } // end static\n\n  private def strategies[T: TType](using Quotes) = {\n    import quotes.reflect._\n    val treeTpe = TypeRepr.of[T]\n    treeTpe <:< TypeRepr.of[CompositeNamingStrategy] match {\n      case true =>\n        treeTpe match {\n          case AppliedType(_, types) =>\n            types\n              .filter(_.isInstanceOf[TypeRepr]).map(_.asInstanceOf[TypeRepr])\n              .filterNot(_ =:= TypeRepr.of[NamingStrategy])\n              .filterNot(_ =:= TypeRepr.of[Nothing])\n        }\n      case false =>\n        List(treeTpe)\n    }\n  }\n\n  inline def mac[T](t: T): String = ${ macImpl[T]('t) }\n  def macImpl[T: TType](t: Expr[T])(using Quotes): Expr[String] = {\n    import quotes.reflect._\n    val loadedStrategies = strategies[T]\n    // println( loadedStrategies )\n    Expr(loadedStrategies.toString) // maybe list of string?\n  }\n}\n\ninline def macLoadNamingStrategy[T](t: T): String = ${ macLoadNamingStrategyImpl[T]('t) }\ndef macLoadNamingStrategyImpl[T: TType](t: Expr[T])(using Quotes): Expr[String] = {\n  import quotes.reflect._\n  val loadedStrategies = LoadNaming.static[T]\n  // println( loadedStrategies )\n  Expr(loadedStrategies.toString) // maybe list of string?\n}\n"}], "isError": false, "timestamp": 1778124179919}]}
