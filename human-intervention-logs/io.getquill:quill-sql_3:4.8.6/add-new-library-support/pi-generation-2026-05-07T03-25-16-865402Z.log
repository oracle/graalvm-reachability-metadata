  package io_getquill.quill_sql_3
  
  import org.assertj.core.api.Assertions.assertThat
  import org.junit.jupiter.api.Test
  
  import java.lang.reflect.Method
  
  object ReflectivePathChainLookupFixtures {
    object Nested {
      def computed: Int = 23
    }
  }
  
  final class ReflectivePathChainLookupTest {
    // The source object is package-private, but these bytecode entry points are the reflective lookup surface under test.
    @Test
    def resolvesNestedModuleMethodPath(): Unit = {
      val lookupClass: Class[?] = Class.forName("io.getquill.context.ReflectivePathChainLookup$")
      val lookupModule: Object = lookupClass.getField("MODULE$").get(null)
      val applyMethod: Method = lookupClass.getMethod(
        "apply",
        classOf[Object],
        classOf[scala.collection.immutable.List[?]]
      )
  
      val result: Either[String, Object] = applyMethod
        .invoke(lookupModule, ReflectivePathChainLookupFixtures, List("Nested", "computed"))
        .asInstanceOf[Either[String, Object]]
  
      assertThat(result.isRight).isTrue()
      assertThat(result.toString).contains("Right(Value(23))")
    }
  
    @Test
    def resolvesPublicFieldLookup(): Unit = {
      val lookupClass: Class[?] = Class.forName("io.getquill.context.ReflectivePathChainLookup$Lookup$")
      val lookupModule: Object = lookupClass.getField("MODULE$").get(null)
      val lookupFirstFieldMethod: Method = lookupClass.getMethod(
        "lookupFirstField",
        classOf[String],
        classOf[Class[?]],
        classOf[Object],
        classOf[String]
      )
      val nestedModule: Object = ReflectivePathChainLookupFixtures.Nested
  
      val result: Option[Object] = lookupFirstFieldMethod
        .invoke(lookupModule, "MODULE$", nestedModule.getClass, nestedModule, "field")
        .asInstanceOf[Option[Object]]
  
      assertThat(result).isEqualTo(Some(nestedModule))
    }
  }
