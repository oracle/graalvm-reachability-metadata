Class: Class[?] = Load.Class.fromTypeRepr(TypeRepr.of[T]).get\n    Expr(loadedClass.getName)\n  }\n}\n\nclass LoadTest {\n  @Test\n  def loadsScalaModuleFromClassTag(): Unit = {\n    val moduleTag: ClassTag[LoadModuleProbe.type] =\n      ClassTag(LoadModuleProbe.getClass).asInstanceOf[ClassTag[LoadModuleProbe.type]]\n    val loadedModule: Try[LoadModuleProbe.type] = Load.Module.fromClassTag[LoadModuleProbe.type](moduleTag)\n\n    assertThat(loadedModule.isSuccess).isTrue()\n    assertThat(loadedModule.get).isSameAs(LoadModuleProbe)\n  }\n\n  @Test\n  def loadsModuleAndClassFromTypeReprDuringMacroExpansion(): Unit = {\n    assertSupportedOpenEndedCompilation { () =>\n      val result: String = evaluateScala(\n        \"\"\"\n          |import io_getquill.quill_sql_3.LoadClassProbe\n          |import io_getquill.quill_sql_3.LoadMacroBridge\n          |import io_getquill.quill_sql_3.LoadModuleProbe\n          |\n          |val loadedModuleName: String = LoadMacroBridge.moduleClassName[LoadModuleProbe.type]\n          |val loadedClassName: String = LoadMacroBridge.className[LoadClassProbe]\n          |loadedModuleName + \"\\n\" + loadedClassName\n          |\"\"\".stripMargin\n      )\n\n      assertThat(result).isEqualTo(LoadModuleProbe.getClass.getName + \"\\n\" + classOf[LoadClassProbe].getName)\n    }\n  }\n\n  private def evaluateScala(source: String): String = {\n    val engine = new dotty.tools.repl.ScriptEngine()\n    engine.eval(source).asInstanceOf[String]\n  }\n\n  private def assertSupportedOpenEndedCompilation(action: () => Unit): Unit = {\n    try action()\n    catch {\n      case error: Error =>\n        if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n          throw error\n        }\n    }\n  }\n}\n"}], "isError": false, "timestamp": 1778123174596}]}
