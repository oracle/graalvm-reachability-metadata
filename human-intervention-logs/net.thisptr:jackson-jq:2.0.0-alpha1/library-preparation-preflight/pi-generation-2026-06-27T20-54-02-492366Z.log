  						<id>make-index</id>
  						<goals>
  							<goal>jandex</goal>
  						</goals>
  						<configuration>
  							<verbose>true</verbose>
  							<processDefaultFileSet>false</processDefaultFileSet>
  							<fileSets>
  								<fileSet>
  									<directory>${project.build.outputDirectory}</directory>
  									<includes>
