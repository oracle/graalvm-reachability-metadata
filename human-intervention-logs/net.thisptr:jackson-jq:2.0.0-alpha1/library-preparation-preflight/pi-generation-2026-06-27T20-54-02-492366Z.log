  										<exclude>net/thisptr/jackson/jq/internal/functions/EnvFunction.class</exclude>
  									</excludes>
  								</fileSet>
  							</fileSets>
  						</configuration>
  					</execution>
  				</executions>
  			</plugin>
  		</plugins>
  	</build>
  </project>
