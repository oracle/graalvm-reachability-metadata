  										<pattern>classpath_modules(/.*\.(jq|json))?</pattern>
  										<pattern>tests(/.*\.ya?ml)?</pattern>
  										<pattern>failing_tests(/.*\.ya?ml)?</pattern>
  										<pattern>jq-test-extra-ok.json</pattern>
