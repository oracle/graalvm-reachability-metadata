ticSetterLikeMethods() {\n        Method setter = ReflectionUtils.getSetter(\"staticLabel\", ChildBean.class);\n\n        assertThat(setter).isNull();\n    }\n\n    public static class ParentBean {\n        private String parentValue;\n        private String label;\n\n        public void setLabel(String label) {\n            this.label = label;\n        }\n    }\n\n    public static class ChildBean extends ParentBean {\n        private String childValue;\n\n        public static void setStaticLabel(String ignored) {\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1938, "output": 1169, "cacheRead": 14848, "cacheWrite": 0, "totalTokens": 17955, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777661996480, "responseId": "resp_08852fa9d215e0b20169f4f82cd52081969997c2fe53b5858d"}}
