  package org_apache_groovy.groovy_jmx
  
  import groovy.jmx.builder.JmxBuilderTools
  import org.junit.jupiter.api.Test
  
  import javax.management.ObjectName
  
  import static org.assertj.core.api.Assertions.assertThat
  
  public class JmxBuilderToolsTest {
      @Test
      void normalizesFullyQualifiedTypeNamesOutsideBuiltInTypeMap() {
          String normalizedType = JmxBuilderTools.getNormalizedType('javax.management.ObjectName')
  
          assertThat(normalizedType).isEqualTo(ObjectName.name)
      }
  }
