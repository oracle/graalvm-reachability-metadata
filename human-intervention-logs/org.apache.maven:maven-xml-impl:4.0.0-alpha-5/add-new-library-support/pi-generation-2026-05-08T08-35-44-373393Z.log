[tool-call] delta {"path":"tests/src/org.apache.maven/maven-xml-impl/4.0.0-alpha-5/src/test/java/org_apache_maven/maven_xml_impl/Maven_xml_implTest.java","edits":[{"oldText":"import org.codehaus.plexus.util.xml.pull.MXParser;\nimport org.codehaus.plexus.util.xml.pull.XmlPullParser;\n","newText":"import org.codehaus.plexus.util.xml.pull.MXParser;\nimport org.codehaus.plexus.util.xml.pull.MXSerializer;\nimport org.codehaus.plexus.util.xml.pull.XmlPullParser;\n"},{"oldText":"    @Test\n    void convertsXmlNodeTreesToPlexusConfiguration() throws Exception {\n","newText":"    @Test\n    void serializesXpp3DomTreeThroughXmlSerializer() throws Exception {\n        Xpp3Dom root = new Xpp3Dom(\"configuration\");\n        root.setAttribute(\"enabled\", \"true\");\n        Xpp3Dom threshold = new Xpp3Dom(\"threshold\");\n        threshold.setValue(\"5\");\n        Xpp3Dom nested = new Xpp3Dom(\"nested\");\n        Xpp3Dom name = new Xpp3Dom(\"name\");\n        name.setValue(\"compiler\");\n        nested.addChild(name);\n        root.addChild(threshold);\n        root.addChild(nested);\n\n        StringWriter output = new StringWriter();\n        MXSerializer serializer = new MXSerializer();\n        serializer.setOutput(output);\n\n        root.writeToSerializer(null, serializer);\n        serializer.flush();\n\n        assertThat(output.toString())\n                .isEqualTo(\"<configuration enabled=\\\"true\\\"><threshold>5</threshold>\"\n                        + \"<nested><name>compiler</name></nested></configuration>\");\n    }\n\n    @Test\n    void convertsXmlNodeTreesToPlexusConfiguration() throws Exception {\n"}]}
