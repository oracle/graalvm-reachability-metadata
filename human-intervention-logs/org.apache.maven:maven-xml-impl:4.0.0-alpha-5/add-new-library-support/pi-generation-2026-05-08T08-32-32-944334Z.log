          XmlNodeImpl rightDom = XmlNodeBuilder.build(new StringReader(rhs), new FixedInputLocationBuilder("right"));
  
          XmlNode mergeResult = XmlNodeImpl.merge(leftDom, rightDom, true);
          assertEquals(" ", mergeResult.getValue());
      }
  
