l_3/index.json:    \"documentation-url\" : \"https://repo1.maven.org/maven2/com/typesafe/play/play-functional_3/$version$/play-functional_3-$version$-javadoc.jar\",\nmetadata/io.circe/circe-jawn_3/index.json:    \"source-code-url\" : \"https://repo.maven.apache.org/maven2/io/circe/circe-jawn_3/$version$/circe-jawn_3-$version$-sources.jar\",\nmetadata/io.circe/circe-jawn_3/index.json:    \"repository-url\" : \"https://github.com/circe/circe\",\nmetadata/io.circe/circe-jawn_3/index.json:    \"test-code-url\" : \"https://github.com/circe/circe/tree/v$version$/modules/jawn/shared/src/test/scala/io/circe/jawn\",\nmetadata/io.circe/circe-jawn_3/index.json:    \"documentation-url\" : \"https://repo.maven.apache.org/maven2/io/circe/circe-jawn_3/$version$/circe-jawn_3-$version$-javadoc.jar\",\nmetadata/io.circe/circe-jawn_3/index.json:      \"io.circe.jawn\"\nmetadata/io.circe/circe-generic_3/index.json:    \"source-code-url\" : \"https://repo.maven.apache.org/maven2/io/circe/circe-generic_3/$version$/circe-generic_3-$version$-sources.jar\",\nmetadata/io.circe/circe-generic_3/index.json:    \"repository-url\" : \"https://github.com/circe/circe\",\nmetadata/io.circe/circe-generic_3/index.json:    \"test-code-url\" : \"https://github.com/circe/circe/tree/v$version$/modules/generic/shared/src/test/scala-0/io/circe/generic\",\nmetadata/io.circe/circe-generic_3/index.json:    \"documentation-url\" : \"https://repo.maven.apache.org/maven2/io/circe/circe-generic_3/$version$/circe-generic_3-$version$-javadoc.jar\",\nmetadata/io.circe/circe-generic_3/index.json:    \"description\" : \"circe-generic provides automatic and semi-automatic derivation of Circe Encoder and Decoder instances for Scala case classes and sealed traits. It lets Scala 3 applications convert domain types to and from JSON through Circe's type class APIs with minimal boilerplate.\",\nmetadata/io.circe/circe-generic_3/index.json:      \"io.circe.generic\"\nmetadata/org.tpolecat/doobie-free_3/index.json:    \"source-