gration used by Redis4Cats modules and applications.\",\ntests/tck-build-logic/src/test/java/org/graalvm/internal/tck/ScaffoldTaskTests.java:        Coordinates coordinates = Coordinates.parse(\"org.typelevel:cats-core_3:2.12.0\");\ntests/tck-build-logic/src/test/java/org/graalvm/internal/tck/ScaffoldTaskTests.java:        assertThat(tempDir.resolve(\"tests/src/org.typelevel/cats-core_3/2.12.0/src/test/scala/org_typelevel/cats_core_3/Cats_core_3Test.scala\"))\ntests/tck-build-logic/src/test/java/org/graalvm/internal/tck/ScaffoldTaskTests.java:                \"tests/src/org.typelevel/cats-core_3/2.12.0/build.gradle\",\ntests/tck-build-logic/src/test/java/org/graalvm/internal/tck/ScaffoldTaskTests.java:                \"/scaffold/build.gradle.scala3.template\"\ntests/tck-build-logic/src/test/java/org/graalvm/internal/tck/ScaffoldTaskTests.java:        assertThat(Files.readString(tempDir.resolve(\"tests/src/org.typelevel/cats-core_3/2.12.0/build.gradle\"), StandardCharsets.UTF_8))\ntests/tck-build-logic/src/test/java/org/graalvm/internal/tck/ScaffoldTaskTests.java:                .contains(\"String scala3Version = tck.scala3Version.get()\")\ntests/tck-build-logic/src/test/java/org/graalvm/internal/tck/ScaffoldTaskTests.java:                .contains(\"org.scala-lang:scala3-library_3:$scala3Version\")\ntests/tck-build-logic/src/test/java/org/graalvm/internal/tck/ScaffoldTaskTests.java:                .contains(\"org.scala-lang:scala3-compiler_3:$scala3Version\")\ntests/tck-build-logic/src/test/java/org/graalvm/internal/tck/ScaffoldTaskTests.java:                .doesNotContain(\"org.scala-lang:scala3-library_3:3.3.6\")\ntests/tck-build-logic/src/test/java/org/graalvm/internal/tck/ScaffoldTaskTests.java:                .doesNotContain(\"org.scala-lang:scala3-compiler_3:3.3.6\")\ntests/tck-build-logic/src/test/java/org/graalvm/internal/tck/ScaffoldTaskTests.java:                .doesNotContain(\"org.scala-lang:scala3-library_3:3.7.4\")\ntests/tck-build-logic/src/test/java/org/graalvm/internal/tck/ScaffoldTaskTests.java:                .doesNotContain(\"org.scala-lang:scala3-compiler_3:3.7.4\");\nmetadata/dev.optics/monocle-core_3/index.json:    \"source-code-url\" : \"https://repo.maven.apache.org/maven2/dev/optics/monocle-core_3/$version$/monocle-core_3-$version$-sources.jar\",\nmetadata/dev.optics/monocle-core_3/index.json:    \"documentation-url\" : \"https://repo.maven.apache.org/maven2/dev/optics/monocle-core_3/$version$/monocle-core_3-$version$-javadoc.jar\",\nmetadata/com.github.ghostdogpr/caliban_3/index.json:    \"source-code-url\" : \"https://repo.maven.apache.org/maven2/com/github/ghostdogpr/caliban_3/$version$/caliban_3-$version$-sources.jar\",\nmetadata/com.github.ghostdogpr/caliban_3/index.json:    \"documentation-url\" : \"https://repo.maven.apache.org/maven2/com/github/ghostdogpr/caliban_3/$version$/caliban_3-$version$-javadoc.jar\",\nmetadata/com.github.ghostdogpr/caliban_3/index.json:    \"description\" : \"Caliban is a purely functional Scala library for building GraphQL servers and clients on top of ZIO. The core caliban_3 artifact contains the Scala 3 JVM APIs for schema derivation, request parsing, execution, validation, rendering, subscriptions, wrappers, and JSON interoperability.\",\nmetadata/com.comcast/ip4s-core_3/index.json:    \"source-code-url\" : \"https://repo.maven.apache.org/maven2/com/comcast/ip4s-core_3/$version$/ip4s-core_3-$version$-sources.jar\",\nmetadata/com.comcast/ip4s-core_3/index.json:    \"documentation-url\" : \"https://repo.maven.apache.org/maven2/com/comcast/ip4s-core_3/$version$/ip4s-core_3-$version$-javadoc.jar\",\nmetadata/com.comcast/ip4s-core_3/index.json:    \"description\" : \"ip4s-core_3 provides immutable Scala 3 data types for IP addresses, hosts, ports, socket addresses, CIDR blocks, multicast addresses, and related network values. It emphasizes referentially transparent parsing and validation so applications can model network endpoints without implicit DNS lookups or mutable Java networking objects.\",\nmetadata/com.github.ghostdogpr/caliban-macros_3/index.json:    \"reason\": \"The published caliban-macros_3 2.10.0 JAR and sources JAR contain only META-INF/MANIFEST.MF and no JVM class files or sources.\",\nmetadata/com.github.ghostdogpr/caliban-macros_3/index.json:    \"replacement\": \"com.github.ghostdogpr:caliban_3:2.10.0\"\nmetadata/org.scalatest/scalatest-mustmatchers_3/index.json:    \"source-code-url\" : \"https://repo.maven.apache.org/maven2/org/scalatest/scalatest-mustmatchers_3/$version$/scalatest-mustmatchers_3-$version$-sources.jar\",\nmetadata/org.scalatest/scalatest-mustmatchers_3/index.json:    \"documentation-url\" : \"https://repo.maven.apache.org/maven2/org/scalatest/scalatest-mustmatchers_3/$version$/scalatest-mustmatchers_3-$version$-javadoc.jar\",\nmetadata/com.github.pureconfig/pureconfig-generic-scala3_3/index.json:    \"source-code-url\" : \"https://repo1.maven.org/maven2/com/github/pureconfig/pureconfig-generic-scala3_3/$version$/pureconfig-generic-scala3_3-$version$-sources.jar\",\nmetadata/com.github.pureconfig/pureconfig-generic-scala3_3/index.json:    \"test-code-url\" : \"https://github.com/pureconfig/pureconfig/tree/v$version$/modules/generic-scala3/src/test\",\nmetadata/com.github.pureconfig/pureconfig-generic-scala3_3/index.json:    \"documentation-url\" : \"https://repo1.maven.org/maven2/com/github/pureconfig/pureconfig-generic-scala3_3/$version$/pureconfig-generic-scala3_3-$version$-javadoc.jar\",\nmetadata/com.github.pureconfig/pureconfig-generic-scala3_3/index.json:    \"description\" : \"pureconfig-generic-scala3 provides Scala 3 generic derivation support for PureConfig, deriving ConfigReader and ConfigWriter instances for case classes, enums, sealed families, and value classes. It lets Scala 3 applications load Typesafe Config/HOCON, JSON, or Java properties into strongly typed Scala models with less boilerplate while honoring PureConfig product and coproduct hints.\",\nmetadata/org.scalatest/scalatest-diagrams_3/index.json:    \"source-code-url\" : \"https://repo.maven.apache.org/maven2/org/scalatest/scalatest-diagrams_3/$version$/scalatest-diagrams_3-$version$-sources.jar\",\nmetadata/org.scalatest/scalatest-diagrams_3/index.json:    \"documentation-url\" : \"https://repo.maven.apache.org/maven2/org/scalatest/scalatest-diagrams_3/$version$/scalatest-diagrams_3-$version$-javadoc.jar\",\nmetadata/org.scalatest/scalatest-diagrams_3/index.json:    \"source-code-url\" : \"https://repo.maven.apache.org/maven2/org/scalatest/scalatest-diagrams_3/$version$/scalatest-diagrams_3-$version$-sources.jar\",\nmetadata/org.scalatest/scalatest-diagrams_3/index.json:    \"documentation-url\" : \"https://repo.maven.apache.org/maven2/org/scalatest/scalatest-diagrams_3/$version$/scalatest-diagrams_3-$version$-javadoc.jar\",\nmetadata/com.typesafe.play/play-configuration_3/index.json:    \"source-code-url\" : \"https://repo.maven.apache.org/maven2/com/typesafe/play/play-configuration_3/$version$/play-configuration_3-$version$-sources.jar\",\nmetadata/com.typesafe.play/play-configuration_3/index.json:    \"documentation-url\" : \"https://repo.maven.apache.org/maven2/com/typesafe/play/play-configuration_3/$version$/play-configuration_3-$version$-javadoc.jar\",\nmetadata/com.softwaremill.sttp.shared/core_3/index.json:    \"source-code-url\" : \"https://repo1.maven.org/maven2/com/softwaremill/sttp/shared/core_3/$version$/core_3-$version$-sources.jar\",\nmetadata/com.softwaremill.sttp.shared/core_3/index.json:    \"documentation-url\" : \"https://repo1.maven.org/maven2/com/softwaremill/sttp/shared/core_3/$version$/core_3-$version$-javadoc.jar\",\nmetadata/com.softwaremill.sttp.shared/fs2_3/index.json:    \"source-code-url\" : \"https://repo.maven.apache.org/maven2/com/softwaremill/sttp/shared/fs2_3/$version$/fs2_3-$version$-sources.jar\",\nmetadata/com.softwaremill.sttp.shared/fs2_3/index.json:    \"documentation-url\" : \"https://repo.maven.apache.org/maven2/com/softwaremill/st