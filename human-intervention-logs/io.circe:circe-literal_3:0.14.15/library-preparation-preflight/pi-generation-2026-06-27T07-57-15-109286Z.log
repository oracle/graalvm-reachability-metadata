free_3-$version$-sources.jar\",\nmetadata/org.tpolecat/doobie-free_3/index.json:    \"description\" : \"doobie-free_3 provides doobie's low-level free-algebra layer for representing JDBC operations as pure Scala 3 programs. It exposes direct mappings for JDBC objects such as connections, statements, result sets, and metadata so higher-level doobie modules and advanced users can interpret or compose database actions functionally.\",\nmetadata/io.circe/circe-parser_3/index.json:    \"source-code-url\" : \"https://repo.maven.apache.org/maven2/io/circe/circe-parser_3/$version$/circe-parser_3-$version$-sources.jar\",\nmetadata/io.circe/circe-parser_3/index.json:    \"repository-url\" : \"https://github.com/circe/circe\",\nmetadata/io.circe/circe-parser_3/index.json:    \"test-code-url\" : \"https://github.com/circe/circe/tree/v$version$/modules/tests/shared/src/test/scala/io/circe/parser\",\nmetadata/io.circe/circe-parser_3/index.json:    \"documentation-url\" : \"https://repo.maven.apache.org/maven2/io/circe/circe-parser_3/$version$/circe-parser_3-$version$-javadoc.jar\",\nmetadata/io.circe/circe-parser_3/index.json:      \"io.circe.parser\"\nmetadata/io.suzaku/boopickle_3/index.json:    \"source-code-url\" : \"https://repo.maven.apache.org/maven2/io/suzaku/boopickle_3/$version$/boopickle_3-$version$-sources.jar\",\nmetadata/io.suzaku/boopickle_3/index.json:    \"documentation-url\" : \"https://repo.maven.apache.org/maven2/io/suzaku/boopickle_3/$version$/boopickle_3-$version$-javadoc.jar\",\nmetadata/io.circe/circe-numbers_3/index.json:    \"source-code-url\" : \"https://repo.maven.apache.org/maven2/io/circe/circe-numbers_3/$version$/circe-numbers_3-$version$-sources.jar\",\nmetadata/io.circe/circe-numbers_3/index.json:    \"repository-url\" : \"https://github.com/circe/circe\",\nmetadata/io.circe/circe-numbers_3/index.json:    \"test-code-url\" : \"https://github.com/circe/circe/tree/v$version$/modules/numbers/shared/src/test/scala/io/circe/numbers\",\nmetadata/io.circ