de-url\" : \"https://repo.maven.apache.org/maven2/org/tpolecat/doobie-free_3/$version$/doobie-free_3-$version$-sources.jar\",\nmetadata/org.tpolecat/doobie-free_3/index.json:    \"description\" : \"doobie-free_3 is doobie's low-level free-algebra module for representing JDBC operations as pure Scala 3 programs. It exposes functional algebras and interpreters for JDBC objects such as connections, statements, result sets, and metadata so database actions can be composed and interpreted safely.\",\nmetadata/org.tpolecat/doobie-free_3/index.json:    \"source-code-url\" : \"https://repo.maven.apache.org/maven2/org/tpolecat/doobie-free_3/$version$/doobie-free_3-$version$-sources.jar\",\nmetadata/org.tpolecat/doobie-free_3/index.json:    \"description\" : \"doobie-free_3 provides doobie's low-level free-algebra layer for modeling JDBC operations as pure Scala 3 programs. It defines functional representations and interpreters for JDBC objects such as connections, statements, result sets, and metadata so database actions can be composed and interpreted safely.\",\nmetadata/org.tpolecat/doobie-free_3/index.json:    \"source-code-url\" : \"https://repo.maven.apache.org/maven2/org/tpolecat/doobie-free_3/$version$/doobie-free_3-$version$-sources.jar\",\nmetadata/org.tpolecat/doobie-free_3/index.json:    \"description\" : \"doobie-free_3 provides doobie's low-level free-algebra layer for representing JDBC operations as pure Scala 3 programs. It exposes direct mappings for JDBC objects such as connections, statements, result sets, and metadata so higher-level doobie modules and advanced users can interpret or compose database actions functionally.\",\nmetadata/io.circe/circe-parser_3/index.json:    \"source-code-url\" : \"https://repo.maven.apache.org/maven2/io/circe/circe-parser_3/$version$/circe-parser_3-$version$-sources.jar\",\nmetadata/io.circe/circe-parser_3/index.json:    \"repository-url\" : \"https://github.com/circe/circe\",\nmetadata/io.circe/circe-parser_3/index.json: 