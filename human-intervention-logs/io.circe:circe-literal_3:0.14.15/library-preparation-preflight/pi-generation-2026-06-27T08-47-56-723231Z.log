obie-free_3/index.json:5:    \"source-code-url\" : \"https://repo.maven.apache.org/maven2/org/tpolecat/doobie-free_3/$version$/doobie-free_3-$version$-sources.jar\",\nmetadata/org.tpolecat/doobie-free_3/index.json:9:    \"description\" : \"doobie-free_3 is doobie's low-level free-algebra module for representing JDBC operations as pure Scala 3 programs. It exposes functional algebras and interpreters for JDBC objects such as connections, statements, result sets, and metadata so database actions can be composed and interpreted safely.\",\nmetadata/org.tpolecat/doobie-free_3/index.json:33:    \"source-code-url\" : \"https://repo.maven.apache.org/maven2/org/tpolecat/doobie-free_3/$version$/doobie-free_3-$version$-sources.jar\",\nmetadata/org.tpolecat/doobie-free_3/index.json:37:    \"description\" : \"doobie-free_3 provides doobie's low-level free-algebra layer for modeling JDBC operations as pure Scala 3 programs. It defines functional representations and interpreters for JDBC objects such as connections, statements, result sets, and metadata so database actions can be composed and interpreted safely.\",\nmetadata/org.tpolecat/doobie-free_3/index.json:56:    \"source-code-url\" : \"https://repo.maven.apache.org/maven2/org/tpolecat/doobie-free_3/$version$/doobie-free_3-$version$-sources.jar\",\nmetadata/org.tpolecat/doobie-free_3/index.json:60:    \"description\" : \"doobie-free_3 provides doobie's low-level free-algebra layer for representing JDBC operations as pure Scala 3 programs. It exposes direct mappings for JDBC objects such as connections, statements, result sets, and metadata so higher-level doobie modules and advanced users can interpret or compose database actions functionally.\",\nmetadata/io.circe/circe-jawn_3/index.json:5:    \"source-code-url\" : \"https://repo.maven.apache.org/maven2/io/circe/circe-jawn_3/$version$/circe-jawn_3-$version$-sources.jar\",\nmetadata/io.circe/circe-jawn_3/index.json:6:    \"repository-url\" : \"https://github.com/circe/circe\",\nmetadata/io.circe/circe-jawn_3/index.json:7:    \"test-code-url\" : \"https://github.com/circe/circe/tree/v$version$/modules/jawn/shared/src/test/scala/io/circe/jawn\",\nmetadata/io.circe/circe-jawn_3/index.json:8:    \"documentation-url\" : \"https://repo.maven.apache.org/maven2/io/circe/circe-jawn_3/$version$/circe-jawn_3-$version$-javadoc.jar\",\nmetadata/io.circe/circe-jawn_3/index.json:9:    \"description\" : \"Circe Jawn integrates the Circe JSON data model with the Jawn JSON parser for Scala. It provides parser and facade implementations that read JSON text into Circe Json values and support Circe's higher-level parsing modules.\",\nmetadata/io.circe/circe-jawn_3/index.json:22:      \"io.circe.jawn\"\nmetadata/org.tpolecat/doobie-hikari_3/index.json:5:    \"source-code-url\" : \"https://repo.maven.apache.org/maven2/org/tpolecat/doobie-hikari_3/$version$/doobie-hikari_3-$version$-sources.jar\",\nmetadata/org.tpolecat/doobie-hikari_3/index.json:9:    \"description\" : \"doobie-hikari_3 adds HikariCP-backed transactors to doobie, enabling Scala 3 applications to run JDBC programs through a managed connection pool. It provides Resource-based constructors for creating or wrapping HikariDataSource instances so database connections are acquired, used, and closed within cats-effect workflows.\",\nmetadata/io.circe/circe-generic_3/index.json:5:    \"source-code-url\" : \"https://repo.maven.apache.org/maven2/io/circe/circe-generic_3/$version$/circe-generic_3-$version$-sources.jar\",\nmetadata/io.circe/circe-generic_3/index.json:6:    \"repository-url\" : \"https://github.com/circe/circe\",\nmetadata/io.circe/circe-generic_3/index.json:7:    \"test-code-url\" : \"https://github.com/circe/circe/tree/v$version$/modules/generic/shared/src/test/scala-0/io/circe/generic\",\nmetadata/io.circe/circe-generic_3/index.json:8:    \"documentation-url\" : \"https://repo.maven.apache.org/maven2/io/circe/circe-generic_3/$version$/circe-generic_3-$version$-javadoc.jar\",\nmetadata/io.circe/circe-generic_3/index.json:9:    \"description\" : \"circe-generic provides automatic and semi-automatic derivation of Circe Encoder and Decoder instances for Scala case classes and sealed traits. It lets Scala 3 applications convert domain types to and from JSON through Circe's type class APIs with minimal boilerplate.\",\nmetadata/io.circe/circe-generic_3/index.json:22:      \"io.circe.generic\"\nmetadata/com.github.plokhotnyuk.jsoniter-scala/jsoniter-scala-core_3/index.json:5:    \"source-code-url\" : \"https://repo.maven.apache.org/maven2/com/github/plokhotnyuk/jsoniter-scala/jsoniter-scala-core_3/$version$/jsoniter-scala-core_3-$version$-sources.jar\",\nmetadata/com.github.plokhotnyuk.jsoniter-scala/jsoniter-scala-core_3/index.json:8:    \"documentation-url\" : \"https://repo.maven.apache.org/maven2/com/github/plokhotnyuk/jsoniter-scala/jsoniter-scala-core_3/$version$/jsoniter-scala-core_3-$version$-javadoc.jar\",\nmetadata/org.tpolecat/doobie-postgres_3/index.json:5:    \"source-code-url\" : \"https://repo.maven.apache.org/maven2/org/tpolecat/doobie-postgres_3/$version$/doobie-postgres_3-$version$-sources.jar\",\n"}], "isError": false, "timestamp": 1782550029974}}
