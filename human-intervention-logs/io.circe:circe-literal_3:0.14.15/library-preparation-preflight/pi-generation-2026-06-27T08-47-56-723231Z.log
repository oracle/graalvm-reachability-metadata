07\u0002пњљпњљ4пњљЌђпњљ:\u0017\u0017пњљпњљ*fпњљpпњљпњљпњљ\"-пњљпњљпњљwuпњљ\u001f^пњљпњљпњљпњљпњљ\u000f2пњљ∆Апњљ\\h\fxпњљ\u0006пњљ!пњљпњљпњљпњљjпњљVпњљ4пњљпњљпњљf\u0015пњљ^iaпњљпњљпњљпњљпњљпњљ]1MпњљпњљX\u0018пњљпњљ(пњљ\rпњљJпњљ\u0018y\u001dпњљпњљ1\tпњљпњљ\u0010zпњљ\u0016пњљпњљ\u000e{пњљ6\u0019пњљ‘їпњљ}пњљпњљ\u001e>uпњљпњљпњљпњљпњљпњљ\u0010\u0006wp5пњљпњљпњљпњљ\u0006}|пњљпњљnпњљ3пњљпњљпњљяµпњљпњљbпњљ?gпњљ\"@пњљпњљпњљпњљc'ЁРпњљ\u0006пњљпњљ*(пњљпњљ'b\"\u0012\fMNs6пњљ0UKпњљ%F\u0004\u0019пњљsa(пњљ\u0006\tпњљпњљL*пњљпњљ2пњљ^пњљпњљпњљ\u001c]\u0004\u0001пњљпњљпњљ\f\t\u0015пњљ\u001aпњљSaпњљfi\u0010 !пњљ-пњљпњљпњљ,^пњљ\nпњљпњљпњљЋЈ\u0015|\u0003пњљ2Qhпњљ\r\u0018%пњљпњљ~>\u001fпњљпњљmпњљпњљ4пњљvпњљпњљ/y\u001a?пњљпњљпњљ}7WJZпњљlпњљpпњљ\u00126∆™пњљпњљiSпњљVпњљќ≠H\tпњљDпњљkD\rпњљ$!Ќґ/пњљxпњљпњљ\u001dпњљRпњљпњљ9пњљ6\bпњљпњљ'пњљ—Ї-пњљпњљdпњљV\u00066\u0001пњљпњљOпњљ\tWz(~hпњљ\u000e\\cB\u001eпњљпњљl9пњљпњљ\u001eпњљпњљпњљ‘ФK|пњљ–Хпњљпњљпњљ(пњљ\r…Њпњљпњљя§пњљпњљ<пњљ\u001c=¬•3\u000fпњљ).bпњљ')пњљ@\u0005пњљпњљпњљпњљ`пњљ\u0017пњљпњљ\u001aпњљпњљ\u0004пњљпњљ&3пњљ\u000f aпњљпњљпњљ6пњљ \u0013пњљeпњљ?пњљ`\u000bпњљпњљпњљ{пњљпњљXпњљ\u0007пњљ;BOnпњљ6пњљпњљпњљ\u0014пњљ\"9пњљпњљ#”і\u0014пњљ\u0007\u0005a\"пњљпњљпњљ\u0001 ЧпњљeaMџ∞\u0016A\u001bпњљDQЁҐrпњљпњљ\u001cпњљ\u0001пњљпњљJwпњљЎ±\f[=пњљпњљƒШlпњљ\u00059пњљqJ\u0005пњљYlEпњљпњљпњљr!\u0007\tпњљs\u001eпњљ+пњљпњљ\u001eпњљcпњљ%v/f*пњљкМҐxпњљпњљпњљпњљ\t:oEпњљпњљCпњљ$m\bIпњљ646пњљe \u0006пњљ9znпњљпњљjUoMпњљ\fwпњљпњљпњљ-пњљgпњљпњљпњљXпњљпњљпњљsпњљm М-пњљ\u00122\u0015\u0012пњљX,пњљпњљ]пњљ+пњљпњљbпњљn\u0002пњљ,пњљbпњљ,wEk\u0015AпњљпњљuпњљпњљYh\u00125пњљ\u0017KпњљпњљЎРf\"дЄ©\r\\пњљпњљпњљ>!Y\bMlпњљпњљ\u0019!пњљ\u0019пњљ\u0013\u001d%Q _пњљ(\u001bпњљољҐtпњљF\rпњљoaSпњљ\nпњљDcпњљпњљпњљPпњљпњљпњљxпњљпњљпњљS9пњљxкТ≠\u000bпњљ\u0010пњљibќіfл≤Іпњљ\tпњљ@OZпњљ^NпњљF\u001e.AпњљUпњљ\u0014пњљUпњљпњљ\u001cпњљnпњљ\u0000JпњљпњљLпњљkпњљrпњљпњљпњљiпњљпњљпњљ\"пњљ4\nпњљпњљпњљPпњљпњљпњљ\u0003oпњљJ9пњљ7пњљ0aпњљпњљM\f\u001bпњљIпњљпњљ\u0019пњљ8пњљrпњљG1FпњљA\n[ЌЯ]пњљпњљ4lпњљmпњљes\u0003пњљE,пњљ[пњљ\tпњљ\u000eпњљпњљпњљmпњљЁЊ`пњљпњљпњљ«Іarпњљm Чпњљ=3X\u001cпњљпњљпњљпњљJ*Sпњљпњљ\u000b=\u0013пњљпњљx\u0000\u001aN\u00131h2rпњљЁ©пњљпњљпњљAпњљ7пњљknпњљyпњљпњљпњљпњљпњљпњљjпњљohпњљпњљпњљпњљ6пњљ$пњљпњљdпњљпњљпњљпњљпњљQoпњљ!пњљпњљ8пњљ\t\u0015пњљ\u0013+пњљпњљпњљпњљпњљпњљhпњљ\u001af\u0007\fq~пњљSn\u0007пњљпњљ\u0014пњљ3пњљVпњљ.{xпњљ\rl7пњљeaпњљ\u0015EMпњљL5\nпњљQ\u001fWпњљ\u001bпњљпњљZпњљпњљпњљпњљ{пњљпњљпњљEпњљпњљ8пњљLпњљ?пњљ\u0015пњљпњљ5пњљDпњљtпњљhпњљпњљпњљпњљпњљ\u001cE{mпњљпњљWпњљ.пњљ*qпњљBпњљ∆М пњљпњљяД\u0010\u0013\bпњљ]пњљ\u0017!пњљпњљпњљпњљ*\u0010\u0015:sпњљ\u0004пњљ\u0016пњљпњљпњљwпњљxпњљSпњљ”Ш8tZ}ЁЭ$;пњљkпњљпњљ\u0006\u0013xuпњљпњљпњљgпњљGпњљOпњљпњљпњљ\u0015\u000fпњљ\u001eпњљпњљпњљXпњљпњљпњљslпњљпњљ\u0010пњљQпњљGпњљ\u001e пњљ]\u0013\u0012+?пњљvпњљ1!пњљ\u0012пњљпњљ\u001fпњљ#.[{пњљO(пњљпњљ\u0010пњљпњљпњљпњљ\n?пњљпњљN9пњљпњљпњљпњљ\u001c8pCi?пњљпњљпњљ7qF_7пњљXпњљK\u0016пњљnпњљ—°kпњљпњљпњљпњљ`пњљ\u0005\u0007/пњљпњљC\u001dпњљ,пњљпњљ\u0010пњљпњљvпњљ=x#пњљ{пњљ\u0010пњљmпњљ\rпњљ\u0003PK\u0007\bX\fIпњљпњљ\u0005\u0000\u0000n\u0010\u0000\u0000PK\u0003\u0004\u0014\u0000\b\b\b\u0000\u0000\u0000!<\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\"\u0000\u0000\u0000io/circe/literal/Replacement.scalaпњљUaoпњљ6\u0010пњљпњљ_q0\u0002T\n<пњљ\bпњљпњљC\nhIпњљi-пњљ6r\u001a\u0014A0пњљпњљпњљf'пњљ2IE1пњљпњљпњљ\u001d))пњљпњљ\fпњљ0\fпњљ\u0007пњљ$пњљёљпњљw:NOGp\n\u0017пњљпњљ\u0019пњљпњљ88{{пњљ#\bi\u0004“Њ?пњљ \u0005*пњљ94*G\u0003nпњљпњљпњљ\\пњљO2пњљпњљhпњљпњљ\nпњљпњљ[пњљ<`пњљ\u001fпњљпњљ<пњљN7Pпњљ\u001d(пњљпњљпњљH\u001cпњљB!K\u0004|\u0014X;пњљ\nпњљпњљпњљRr%\u0010Zпњљ6!Nпњљпњљ<«ЧпњљCпњљ\u001c'8пњљ\u0007jZ\u0015пњљ@пњљ\u0017пњљ?\u001bпњљпњљпњљtЏґ-пњљA0пњљf=-;пњљпњљ~H/пњљпњљпњљпњљ\u000f$пњљпњљFпњљh-\u0018пњљ6пњљP¬Ђ\u001dпњљD\tпњљ\"пњљ%oA\u001bпњљkпњљtпњљ\u0017пњљ\u001aпњљZOпњљпњљ¬µпњљпњљпњљA.пњљ3r’Єпњљпњљ\r\u0012)пњљC\u0000Uпњљ+\u0018'\u0019пњљпњљ\u0018~Nпњљ4пњљxпњљпњљtпњљпњљпњљf\tпњљпњљпњљu2_пњљW\u0019,пњљпњљb1пњљLпњљпњљbNпњљ_ пњљпњљпњљпњљпњљr\u0002H\u0015пњљ8пњљX\u001bпњљ\u0001…ФпњљпњљпњљпњљпњљeпњљG\u0012\nпњљIпњљ5\nYHAпњљпњљuпњљпњљ\bkпњљпњљFQFPпњљпњљпњљпњљпњљZ\u0012пњљ{пњљRVпњљq\u0017пњљпњљпњљпњљ\u0007пњљпњљFTпњљ?<пњљпњљ,пњљ\u0010+пњљCпњљпњљ—И\u0004iпњљпњљ+пњљqпњљd77пњљпњљk\u0005/9пњљ6пњљJ¬Юпњљпњљпњљпњљ'пњљпњљ\u0013Xпњљjпњљпњљ\u0001пњљпњљL0%4…ШпњљoVпњљ\tпњљпњљ]пњљCпњљпњљпњљпњљ(9пњљпњљ\u001aпњљ\u000bпњљPпњљиБЧ\u0010V\u001b]\u0012r\u0006\u0019Yпњљ\u001dпњљfпњљxпњљ,DпњљKпњљпњљ>пњљпњљ\u0011@пњљ\u0005pпњљCDпњљпњљпњљпњљпњљziqпњљпњљgпњљp\u001eпњљ\u0000пњљпњљ-3Xпњљ(\u001c;\rпњљ\u0003?5пњљ\u0013пњљ\u001e\u000b\u0010dпњљ\u0019VпњљзД∞3p\u0007{пњљpпњљ\u000eпњљ :gпњљ.пњљ\"пњљjdпњљпњљQпњљ\r_пњљcпњљ}пњљ;G\u0012пњљ\u001dпњљпњљпњљmпњљJпњљпњљпњљrпњљпњљпњљпњљ&пњљ\u0015Fпњљac/пњљпњљ\u0013пњљпњљkпњљ_пњљ]t“©Kпњљuпњљm^\u0014пњљ\u0019пњљ#пњљпњљЌµпњљпњљ\u0016пњљ\u0019пњљпњљchпњљ6пњљ У\u0015пњљ\";\u0016пњљ)пњљ0=\nпњљтЃЈЕtC\u0003пњљпњљ>yпњљпњљ3пњљпњљ-\u0005|\u001e\u0007Gг£®{\r√њпњљпњљSпњљ\fVS\u001fпњљпњљпњљ]пњљпњљKпњљ\u0007пњљпњљпњљпњљпњљпњљ\u0017пњљпњљпњљпњљпњљпњљпњљпњљпњљпњљпњљпњљпњљпњљпњљпњљ^}%;\u000eпњљпњљпњљxmпњљ\u0003wxпњљ/пњљ{\u001fпњљпњљпњљ7}пњљпњљпњљпњљ√Ппњљпњљ\u0010пњљпњљl пњљпњљпњљbпњљж†Ѓпњљпњљ(fNwпњљ/m\u0013пњљdпњљпњљGnпњљпњљпњљq;4пњљпњљпњљevпњљпњљпњљTHпњљ\u0011\u0005пњљ}пњљƒЕпњљbB+пњљs\u001a^RпњљWuпњљпњљ_0RQ;пњљF„Ј\u001bпњљh#пњљ\r9пњљпњљпњљ@6пњљ=пњљ—Нj#\u001b”£\u001bпњљy'Ca{49\u000f$пњљ”Йпњљпњљпњљ\tPK\u0007\bпњљ|zTпњљ\u0003\u0000\u0000F\b\u0000\u0000PK\u0003\u0004\u0014\u0000\b\b\b\u0000\u0000\u0000!<\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u001e\u0000\u0000\u0000io/circe/literal/package.scalaeпњљOoпњљ@\u0010пњљпњљпњљ\u0014OпњљRBDMпњљzпњљпњљпњљ%пњљкЦВпњљIпњљ\u001cпњљel&5пњљпњљпњљ\u000eпњљпњљпњљ;\u000bNпњљ(пњљпњљ;пњљпњљпњљyпњљ\u0017\t.0пњљпњљпњљqпњљ\u000bпњљ\\N>@пњљпњљ$сШЪ≥&пњљiпњљпњљlпњљ!пњљ\bYпњљпњљпњљпњљпњљ\b?пњљyпњљ\u0006пњљпњљ\u0012пњљ`–І\u0006√ПQпњљ`[пњљпњљ\u0001пњљ\u0006пњљпњљDпњљ=Jпњљ\tпњљпњљпњљ\t`\u0003mпњљMпњљпњљhBпњљawпњљ”ЂпњљQпњљ„∞пњљпњљпњљ\\IC#пњљпњљe!Tпњљпњљ\u000bпњљпњљпњљпњљ]„•пњљ\bпњљZWпњљпњљSпњљ\u001fпњљпњљпњљпњљпњљпњљ~/пњљ}”Нпњљпњљ{8пњљЁ≤пњљпњљ7\u0007пњљFпњљпњљпњљ\bjпњљ:X\u0007U9пњљ\\пњљ\u0011пњљs\u001cпњљT#x[пњљNпњљпњљ\u0019пњљпњљпњљM\u001b^yпњљпњљ(пњљпњљ,\u0010„Фпњљ +пњљ\u0017\u0003|ќКпњљ\u0018Eпњљпњљ|пњљuyпњљпњљmпњљZeпњљu~]`пњљпњљlпњљпњљпњљпњљпњљr!пњљ/пњљ\u0016wпњљпњљ/пњљF qLпњљпњљCпњљпњљ\u0006пњљпњљпњљMпњљ\u001eпњљ+пњљ^!пњљпњљпњљпњљ\u001bпњљ\\пњљпњљпњљL’™пњљPпњљ?пњљlпњљпњљ№Ю}пњљпњљ^\u0000пњљQпњљпњљ=\u0007\u0015пњљпњљ7{пњљAпњљ$\u0011пњљE!пњљпњљпњљ\u000e%\u0002b]пњљ\u0017Hk\u000eпњљTпњљ~пњљпњљпњљOпњљ?пњљvпњљпњљoпњљпњљ{пњљ\u0001}%\u001e\u0013пњљfAпњљпњљ;vќ¶f#пњљzпњљBl4пњљћЪ пњљпњљ\u0010пњљпњљ%\u001bпњљпњљRпњљ{пњљпњљ№•\\пњљпњљпњљпњљb8EDпњљ'пњљ{пњљ\u001bпњљ46пњљпњљпњљпњљпњљпњљ#пњљ≈Њ!пњљdпњљSпњљпњљ\u0005PK\u0007\bпњљпњљ\u0016aпњљ\u0001\u0000\u00004\u0003\u0000\u0000PK\u0001\u0002\u0014\u0000\u0014\u0000\b\b\b\u0000\u0000\u0000!<\u001fпњљпњљ(U\u0000\u0000\u0000z\u0000\u0000\u0000\u0014\u0000\u0004\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000META-INF/MANIFEST.MFпњљпњљ\u0000\u0000PK\u0001\u0002\n\u0000\n\u0000\u0000\b\u0000\u0000\u0000\u0000!<\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0003\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000пњљ\u0000\u0000\u0000io/PK\u0001\u0002\n\u0000\n\u0000\u0000\b\u0000\u0000\u0000\u0000!<\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\t\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000пњљ\u0000\u0000\u0000io/circe/PK\u0001\u0002\n\u0000\n\u0000\u0000\b\u0000\u0000\u0000\u0000!<\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0011\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000пњљ\u0000\u0000\u0000io/circe/literal/PK\u0001\u0002\u0014\u0000\u0014\u0000\b\b\b\u0000\u0000\u0000!<X\fIпњљпњљ\u0005\u0000\u0000n\u0010\u0000\u0000(\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0012\u0001\u0000\u0000io/circe/literal/JsonLiteralMacros.scalaPK\u0001\u0002\u0014\u0000\u0014\u0000\b\b\b\u0000\u0000\u0000!<пњљ|zTпњљ\u0003\u0000\u0000F\b\u0000\u0000\"\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\n\u0007\u0000\u0000io/circe/literal/Replacement.scalaPK\u0001\u0002\u0014\u0000\u0014\u0000\b\b\b\u0000\u0000\u0000!<пњљпњљ\u0016aпњљ\u0001\u0000\u00004\u0003\u0000\u0000\u001e\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000пњљ\n\u0000\u0000io/circe/literal/package.scalaPK\u0005\u0006\u0000\u0000\u0000\u0000\u0007\u0000\u0007\u0000пњљ\u0001\u0000\u0000\u0013\r\u0000\u0000\u0000\u0000./io/circe/literal/Replacement.scala\n==== ./io/circe/literal/Replacement.scala\n/*\n * Copyright 2024 circe\n *\n * Licensed under the Apache License, Version 2.0 (the \"License\");\n * you may not use this file except in compliance with the License.\n * You may obtain a copy of the License at\n *\n *     http://www.apache.org/licenses/LICENSE-2.0\n *\n * Unless required by applicable law or agreed to in writing, software\n * distributed under the License is distributed on an \"AS IS\" BASIS,\n * WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n * See the License for the specific language governing permissions and\n * limitations under the License.\n */\n\npackage io.circe.literal\n\nimport java.util.UUID\nimport scala.quoted.{ Expr, Quotes, Type }\nimport io.circe.{ Encoder, Json, KeyEncoder }\n\ncase class Replacement(val placeholder: String, argument: Expr[Any]) {\n  def asJson(using q: Quotes): Expr[Json] = {\n    import q.reflect.*\n    argument match {\n      case '{\n            $arg: t\n          } => {\n        arg.asTerm.tpe.widen.asType match {\n          case '[t] =>\n            Expr.summon[Encoder[t]] match {\n              case Some(encoder) => '{ $encoder.apply($arg.asInstanceOf[t]) }\n              case None          => report.errorAndAbort(s\"could not find implicit Encoder for ${Type.show[t]}\", arg)\n            }\n        }\n      }\n    }\n  }\n\n  def asKey(using q: Quotes): Expr[String] = {\n    import q.reflect.*\n    argument match {\n      case '{ $arg: t } =>\n        arg.asTerm.tpe.widen.asType match {\n          case '[t] =>\n            Expr.summon[KeyEncoder[t]] match {\n              case Some(encoder) => '{ $encoder.apply($arg.asInstanceOf[t]) }\n              case None => report.errorAndAbort(s\"could not find implicit for ${Type.show[KeyEncoder[t]]}\", arg)\n            }\n        }\n    }\n  }\n}\n\nobject Replacement {\n  private[this] final def generatePlaceholder(): String = UUID.randomUUID().toString\n\n  def apply(stringParts: Seq[String], argument: Expr[Any]): Replacement = {\n\n    val placeholder =\n      Stream.continually(generatePlaceholder()).distinct.dropWhile(s => stringParts.exists(_.contains(s))).head\n\n    new Replacement(placeholder, argument)\n  }\n}\n./io/circe/literal/package.scala\n==== ./io/circe/literal/package.scala\n/*\n * Copyright 2024 circe\n *\n * Licensed under the Apache License, Version 2.0 (the \"License\");\n * you may not use this file except in compliance with the License.\n * You may obtain a copy of the License at\n *\n *     http://www.apache.org/licenses/LICENSE-2.0\n *\n * Unless required by applicable law or agreed to in writing, software\n * distributed under the License is distributed on an \"AS IS\" BASIS,\n * WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n * See the License for the specific language governing permissions and\n * limitations under the License.\n */\n\npackage io.circe\n\nimport io.circe.literal.JsonLiteralMacros\n\npackage object literal {\n  extension (inline sc: StringContext) {\n    inline final def json(inline args: Any*): Json = ${ JsonLiteralMacros.jsonImpl('sc, 'args) }\n  }\n}\n./io/circe/literal/JsonLiteralMacros.scala\n==== ./io/circe/literal/JsonLiteralMacros.scala\n/*\n * Copyright 2024 circe\n *\n * Licensed under the Apache License, Version 2.0 (the \"License\");\n * you may not use this file except in compliance with the License.\n * You may obtain a copy of the License at\n *\n *     http://www.apache.org/licenses/LICENSE-2.0\n *\n * Unless required by applicable law or agreed to in writing, software\n * distributed under the License is distributed on an \"AS IS\" BASIS,\n * WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n * See the License for the specific language governing permissions and\n * limitations under the License.\n */\n\npackage io.circe.literal\n\nimport scala.quoted.*\nimport io.circe.{ Encoder, Json, JsonNumber }\nimport org.typelevel.jawn.{ FContext, Facade, Parser }\nimport scala.util.{ Failure, Success }\nimport io.circe.literal.Replacement\n\nobject JsonLiteralMacros {\n  def jsonImpl(sc: Expr[StringContext], args: Expr[Seq[Any]])(using q: Quotes): Expr[Json] = {\n    import q.reflect.*\n    val stringParts = sc match {\n      case '{ StringContext($parts*) } => parts.valueOrAbort\n    }\n\n    val replacements = args match {\n      case Varargs(argExprs) =>\n        argExprs.map(Replacement(stringParts, _))\n      case other => report.errorAndAbort(\"Invalid arguments for json literal.\")\n    }\n\n    val jsonString = stringParts.zip(replacements.map(_.placeholder)).foldLeft(\"\") {\n      case (acc, (part, placeholder)) =>\n        val qm = \"\\\"\"\n        s\"$acc$part$qm$placeholder$qm\"\n    } + stringParts.last\n\n    inline given Facade[Expr[Json]] with {\n\n      private def toJsonKey(s: String): Expr[String] =\n        replacements.find(_.placeholder == s).fold(Expr(s.toString))(_.asKey)\n      private def toJsonString(s: String): Expr[Json] = replacements\n        .find(_.placeholder == s)\n        .fold { val strExpr = Expr(s.toString); '{ Json.fromString($strExpr) } }(_.asJson)\n      def arrayContext(index: Int): FContext[Expr[Json]] = new FContext.NoIndexFContext[Expr[Json]] {\n        private var values: Expr[List[Json]] = Expr(Nil)\n\n        def isObj: Boolean = false\n\n        def add(s: CharSequence): Unit = {\n          val strExpr = toJsonString(s.toString)\n          values = '{ $strExpr :: $values }\n        }\n        def add(v: Expr[Json]): Unit = values = '{ $v :: ${ values } }\n        def finish(): Expr[Json] = '{ Json.arr($values.reverse*) }\n      }\n      def jfalse(index: Int): Expr[Json] = '{ Json.False }\n      def jnull(index: Int): Expr[Json] = '{ Json.Null }\n      inline def jnum(s: CharSequence, decIndex: Int, expIndex: Int, index: Int): Expr[Json] =\n        val str = Expr(s.toString)\n        '{ JsonNumber.fromString($str).map(Json.fromJsonNumber(_)).getOrElse(throw Exception(\"Invalid json number.\")) }\n      def jstring(s: CharSequence, index: Int): Expr[Json] = toJsonString(s.toString)\n      def jtrue(index: Int): Expr[Json] = '{ Json.True }\n\n      def objectContext(index: Int): FContext[Expr[Json]] = new FContext.NoIndexFContext[Expr[Json]] {\n        private[this] var fields: Expr[List[(String, Json)]] = Expr(Nil)\n        private[this] var key: String = null\n\n        def isObj: Boolean = true\n        def add(s: CharSequence): Unit = {\n          if (key.eq(null)) {\n            key = s.toString\n          } else {\n            val keyExpr = toJsonKey(key)\n            val value = toJsonString(s.toString)\n            fields = '{ ($keyExpr, $value) :: $fields }\n            key = null\n          }\n        }\n        def add(v: Expr[Json]): Unit = {\n          val keyExpr = toJsonKey(key)\n          fields = '{ ($keyExpr, $v) :: $fields }\n          key = null\n        }\n        def finish(): Expr[Json] = '{ Json.obj($fields.reverse*) }\n      }\n      def singleContext(index: Int): FContext[Expr[Json]] = new FContext.NoIndexFContext[Expr[Json]] {\n        private[this] var value: Expr[Json] = null\n\n        def isObj: Boolean = false\n        def add(s: CharSequence): Unit = value = toJsonString(s.toString)\n        def add(v: Expr[Json]): Unit = value = v\n        def finish(): Expr[Json] = value\n      }\n    }\n\n    Parser.parseFromString[Expr[Json]](jsonString) match {\n      case Success(jsonExpr) => jsonExpr\n      case Failure(e)        =>\n        report.errorAndAbort(e.toString)\n    }\n  }\n}\n./META-INF/MANIFEST.MF\n==== ./META-INF/MANIFEST.MF\nManifest-Version: 1.0\r\nSpecification-Vendor: circe\r\nSpecification-Title: Circe literal\r\nSpecification-Version: 0.14.15\r\n\r\n"}], "isError": false, "timestamp": 1782550045998}}
[recv] {"type": "message_end", "message": {"role": "toolResult", "toolCallId": "call_ZZC5frx8muaTko6jVY1fvaDf|fc_0af76b3de73ef8a9016a3f8e1c761081959364cdcf3fce0ffc", "toolName": "bash", "content": [{"type": "text", "text": "META-INF/MANIFEST.MF\nio/\nio/circe/\nio/circe/literal/\nio/circe/literal/JsonLiteralMacros.scala\nio/circe/literal/Replacement.scala\nio/circe/literal/package.scala\n./circe-literal_3-0.14.15-sources.jar\n==== ./circe-literal_3-0.14.15-sources.jar\nPK\u0003\u0004\u0014\u0000\b\b\b\u0000\u0000\u0000!<\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0014\u0000\u0004\u0000META-INF/MANIFEST.MFпњљпњљ\u0000\u0000пњљMпњљпњљLK-.пњљ\rK-*пњљпњљѕ≥R0пњљ3пњљпњљ\n.HMпњљLпњљLN,\u0001пњљ\u0001пњљпњљRпњљ\u0014пњљ3пњљпњљSпњљ%C2KrRпњљ\u0014пњљAr\n9пњљ%пњљEпњљ9пњљ\u0006@\r7пњљ34пњљ34пњљпњљпњљпњљ\u0002\u0000PK\u0007\b\u001fпњљпњљ(U\u0000\u0000\u0000z\u0000\u0000\u0000PK\u0003\u0004\n\u0000\u0000\b\u0000\u0000\u0000\u0000!<\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0003\u0000\u0000\u0000io/PK\u0003\u0004\n\u0000\u0000\b\u0000\u0000\u0000\u0000!<\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\t\u0000\u0000\u0000io/circe/PK\u0003\u0004\n\u0000\u0000\b\u0000\u0000\u0000\u0000!<\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0011\u0000\u0000\u0000io/circe/literal/PK\u0003\u0004\u0014\u0000\b\b\b\u0000\u0000\u0000!<\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000(\u0000\u0000\u0000io/circe/literal/JsonLiteralMacros.scalaпњљWпњљoпњљ6\u0010~пњљ_q0\u0002Lпњљ<пњљ(пњљпњљ\"\u0003пњљ4пњљпњљfпњљ\u0016пњљ-пњљ,(hпњљпњљпњљ §LRv<пњљпњљпњљпњљ(Jпњљ\u001c\u001buпњљпњљ<ЎСпњљпњљпњљпњљ~пњљпњљ8\u000fпњљ\u001cпњљTпњљпњљb:пњљпњљпњљпњљпњљ_!\u0011:пњљпњљпњљпњљnE¬•пњљcпњљпњљkпњљ3\u000eЁМ%пњљпњљWпњљпњљk#пњљпњљпњљпњљ+\b\tпњљпњљKпњљпњљ\rпњљXпњљ\u001cпњљl\rRYпњљ\rG\u001bпњљпњљDпњљ\u001cпњљsпњљ3\u000bBBпњљпњљY*пњљL8пњљпњљпњљ9?пњљJL6>{\u001bjd\u0019пњљ\u0019nпњљпњљiR\u0007\u0002пњљпњљ4пњљЌђпњљ:\u0017\u0017пњљпњљ*fпњљpпњљпњљпњљ\"-пњљпњљпњљwuпњљ\u001f^пњљпњљпњљпњљпњљ\u000f2пњљ∆Апњљ\\h\fxпњљ\u0006пњљ!пњљпњљпњљпњљjпњљVпњљ4пњљпњљпњљf\u0015пњљ^iaпњљпњљпњљпњљпњљпњљ]1MпњљпњљX\u0018пњљпњљ(пњљ\rпњљJпњљ\u0018y\u001dпњљпњљ1\tпњљпњљ\u0010zпњљ\u0016пњљпњљ\u000e{пњљ6\u0019пњљ‘їпњљ}пњљпњљ\u001e>uпњљпњљпњљпњљпњљпњљ\u0010\u0006wp5пњљпњљпњљпњљ\u0006}|пњљпњљnпњљ3пњљпњљпњљяµпњљпњљbпњљ?gпњљ\"@пњљпњљпњљпњљc'ЁРпњљ\u0006пњљпњљ*(пњљпњљ'b\"\u0012\fMNs6пњљ0UKпњљ%F\u0004\u0019пњљsa(пњљ\u0006\tпњљпњљL*пњљпњљ2пњљ^пњљпњљпњљ\u001c]\u0004\u0001пњљпњљпњљ\f\t\u0015пњљ\u001aпњљSaпњљfi\u0010 !пњљ-пњљпњљпњљ,^пњљ\nпњљпњљпњљЋЈ\u0015|\u0003пњљ2Qhпњљ\r\u0018%пњљпњљ~>\u001fпњљпњљmпњљпњљ4пњљvпњљпњљ/y\u001a?пњљпњљпњљ}7WJZпњљlпњљpпњљ\u00126∆™пњљпњљiSпњљVпњљќ≠H\tпњљDпњљkD\rпњљ$!Ќґ/пњљxпњљпњљ\u001dпњљRпњљпњљ9пњљ6\bпњљпњљ'пњљ—Ї-пњљпњљdпњљV\u00066\u0001пњљпњљOпњљ\tWz(~hпњљ\u000e\\cB\u001eпњљпњљl9пњљпњљ\u001eпњљпњљпњљ‘ФK|пњљ–Хпњљпњљпњљ(пњљ\r…Њпњљпњљя§пњљпњљ<пњљ\u001c=¬•3\u000fпњљ).bпњљ')пњљ@\u0005пњљпњљпњљпњљ`пњљ\u0017пњљпњљ\u001aпњљпњљ\u0004пњљпњљ&3пњљ\u000f aпњљпњљпњљ6пњљ \u0013пњљeпњљ?пњљ`\u000bпњљпњљпњљ{пњљпњљXпњљ\u0007пњљ;BOnпњљ6пњљпњљпњљ\u0014пњљ\"9пњљпњљ#”і\u0014пњљ\u0007\u0005a\"пњљпњљпњљ\u0001 ЧпњљeaMџ∞\u0016A\u001bпњљDQЁҐrпњљпњљ\u001cпњљ\u0001пњљпњљJwпњљЎ±\f[=пњљпњљƒШlпњљ\u00059пњљqJ\u0005пњљYlEпњљпњљпњљr!\u0007\tпњљs\u001eпњљ+пњљпњљ\u001eпњљcпњљ%v/f*пњљкМҐxпњљпњљпњљпњљ\t:oEпњљпњљCпњљ$m\bIпњљ646пњљe \u0006пњљ9znпњљпњљjUoMпњљ\fwпњљпњљпњљ-пњљgпњљпњљпњљXпњљпњљпњљsпњљm М-пњљ\u00122\u0015\u0012пњљX,пњљпњљ]пњљ+пњљпњљbпњљn\u0002пњљ,пњљbпњљ,wEk\u0015AпњљпњљuпњљпњљYh\u00125пњљ\u0017KпњљпњљЎРf\"дЄ©\r\\пњљпњљпњљ>!Y\bMlпњљпњљ\u0019!пњљ\u0019пњљ\u0013\u001d%Q _пњљ(\u001bпњљољҐtпњљF\rпњљoaSпњљ\nпњљDcпњљпњљпњљPпњљпњљпњљxпњљпњљпњљS9пњљxкТ≠\u000bпњљ\u0010пњљibќіfл≤Іпњљ\tпњљ@OZпњљ^NпњљF\u001e.AпњљUпњљ\u0014пњљUпњљпњљ\u001cпњљnпњљ\u0000JпњљпњљLпњљkпњљrпњљпњљпњљiпњљпњљпњљ\"пњљ4\nпњљпњљпњљPпњљпњљпњљ\u0003oпњљJ9пњљ7пњљ0aпњљпњљM\f\u001bпњљIпњљпњљ\u0019пњљ8пњљrпњљG1FпњљA\n[ЌЯ]пњљпњљ4lпњљmпњљes\u0003пњљE,пњљ[пњљ\tпњљ\u000eпњљпњљпњљmпњљЁЊ`пњљпњљпњљ«Іarпњљm Чпњљ=3X\u001cпњљпњљпњљпњљJ*Sпњљпњљ\u000b=\u0013пњљпњљx\u0000\u001aN\u00131h2rпњљЁ©пњљпњљпњљAпњљ7пњљknпњљyпњљпњљпњљпњљпњљпњљjпњљohпњљпњљпњљпњљ6пњљ$пњљпњљdпњљпњљпњљпњљпњљQoпњљ!пњљпњљ8пњљ\t\u0015пњљ\u0013+пњљпњљпњљпњљпњљпњљhпњљ\u001af\u0007\fq~пњљSn\u0007пњљпњљ\u0014пњљ3пњљVпњљ.{xпњљ\rl7пњљeaпњљ\u0015EMпњљL5\nпњљQ\u001fWпњљ\u001bпњљпњљZпњљпњљпњљпњљ{пњљпњљпњљEпњљпњљ8пњљLпњљ?пњљ\u0015пњљпњљ5пњљDпњљtпњљhпњљпњљпњљпњљпњљ\u001cE{mпњљпњљWпњљ.пњљ*qпњљBпњљ∆М пњљпњљяД\u0010\u0013\bпњљ]пњљ\u0017!пњљпњљпњљпњљ*\u0010\u0015:sпњљ\u0004пњљ\u0016пњљпњљпњљwпњљxпњљSпњљ”Ш8tZ}ЁЭ$;пњљkпњљпњљ\u0006\u0013xuпњљпњљпњљgпњљGпњљOпњљпњљпњљ\u0015\u000fпњљ\u001eпњљпњљпњљXпњљпњљпњљslпњљпњљ\u0010пњљQпњљGпњљ\u001e пњљ]\u0013\u0012+?пњљvпњљ1!пњљ\u0012пњљпњљ\u001fпњљ#.[{пњљO(пњљпњљ\u0010пњљпњљпњљпњљ\n?пњљпњљN9пњљпњљпњљпњљ\u001c8pCi?пњљпњљпњљ7qF_7пњљXпњљK\u0016пњљnпњљ—°kпњљпњљпњљпњљ`пњљ\u0005\u0007/пњљпњљC\u001dпњљ,пњљпњљ\u0010пњљпњљvпњљ=x#пњљ{пњљ\u0010пњљmпњљ\rпњљ\u0003PK\u0007\bX\fIпњљпњљ\u0005\u0000\u0000n\u0010\u0000\u0000PK\u0003\u0004\u0014\u0000\b\b\b\u0000\u0000\u0000!<\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\"\u0000\u0000\u0000io/circe/literal/Replacement.scalaпњљUaoпњљ6\u0010пњљпњљ_q0\u0002T\n<пњљ\bпњљпњљC\nhIпњљi-пњљ6r\u001a\u0014A0пњљпњљпњљf'пњљ2IE1пњљпњљпњљ\u001d))пњљпњљ\fпњљ0\fпњљ\u0007пњљ$пњљёљпњљw:NOGp\n\u0017пњљпњљ\u0019пњљпњљ88{{пњљ#\bi\u0004“Њ?пњљ \u0005*пњљ94*G\u0003nпњљпњљпњљ\\пњљO2пњљпњљhпњљпњљ\nпњљпњљ[пњљ<`пњљ\u001fпњљпњљ<пњљN7Pпњљ\u001d(пњљпњљпњљH\u001cпњљB!K\u0004|\u0014X;пњљ\nпњљпњљпњљRr%\u0010Zпњљ6!Nпњљпњљ<«ЧпњљCпњљ\u001c'8пњљ\u0007jZ\u0015пњљ@пњљ\u0017пњљ?\u001bпњљпњљпњљtЏґ-пњљA0пњљf=-;пњљпњљ~H/пњљпњљпњљпњљ\u000f$пњљпњљFпњљh-\u0018пњљ6пњљP¬Ђ\u001dпњљD\tпњљ\"пњљ%oA\u001bпњљkпњљtпњљ\u0017пњљ\u001aпњљZOпњљпњљ¬µпњљпњљпњљA.пњљ3r’Єпњљпњљ\r\u0012)пњљC\u0000Uпњљ+\u0018'\u0019пњљпњљ\u0018~Nпњљ4пњљxпњљпњљtпњљпњљпњљf\tпњљпњљпњљu2_пњљW\u0019,пњљпњљb1пњљLпњљпњљbNпњљ_ пњљпњљпњљпњљпњљr\u0002H\u0015пњљ8пњљX\u001bпњљ\u0001…ФпњљпњљпњљпњљпњљeпњљG\u0012\nпњљIпњљ5\nYHAпњљпњљuпњљпњљ\bkпњљпњљFQFPпњљпњљпњљпњљпњљZ\u0012пњљ{пњљRVпњљq\u0017пњљпњљпњљпњљ\u0007пњљпњљFTпњљ?<пњљпњљ,пњљ\u0010+пњљCпњљпњљ—И\u0004iпњљпњљ+пњљqпњљd77пњљпњљk\u0005/9пњљ6пњљJ¬Юпњљпњљпњљпњљ'пњљпњљ\u0013Xпњљjпњљпњљ\u0001пњљпњљL0%4…ШпњљoVпњљ\tпњљпњљ]пњљCпњљпњљпњљпњљ(9пњљпњљ\u001aпњљ\u000bпњљPпњљиБЧ\u0010V\u001b]\u0012r\u0006\u0019Yпњљ\u001dпњљfпњљxпњљ,DпњљKпњљпњљ>пњљпњљ\u0011@пњљ\u0005pпњљCDпњљпњљпњљпњљпњљziqпњљпњљgпњљp\u001eпњљ\u0000пњљпњљ-3Xпњљ(\u001c;\rпњљ\u0003?5пњљ\u0013пњљ\u001e\u000b\u0010dпњљ\u0019VпњљзД∞3p\u0007{пњљpпњљ\u000eпњљ :gпњљ.пњљ\"пњљjdпњљпњљQпњљ\r_пњљcпњљ}пњљ;G\u0012пњљ\u001dпњљпњљпњљmпњљJпњљпњљпњљrпњљпњљпњљпњљ&пњљ\u0015Fпњљac/пњљпњљ\u0013пњљпњљkпњљ_пњљ]t“©Kпњљuпњљm^\u0014пњљ\u0019пњљ#пњљпњљЌµпњљпњљ\u0016пњљ\u0019пњљпњљchпњљ6пњљ У\u0015пњљ\";\u0016пњљ)пњљ0=\nпњљтЃЈЕtC\u0003пњљпњљ>yпњљпњљ3пњљпњљ-\u0005|\u001e\u0007Gг£®{\r√њпњљпњљSпњљ\fVS\u001fпњљпњљпњљ]пњљпњљKпњљ\u0007пњљпњљпњљпњљпњљпњљ\u0017пњљпњљпњљпњљпњљпњљпњљпњљпњљпњљпњљпњљпњљпњљпњљпњљ^}%;\u000eпњљпњљпњљxmпњљ\u0003wxпњљ/пњљ{\u001fпњљпњљпњљ7}пњљпњљпњљпњљ√Ппњљпњљ\u0010пњљпњљl пњљпњљпњљbпњљж†Ѓпњљпњљ(fNwпњљ/m\u0013пњљdпњљпњљGnпњљпњљпњљq;4пњљпњљпњљevпњљпњљпњљTHпњљ\u0011\u0005пњљ}пњљƒЕпњљbB+пњљs\u001a^RпњљWuпњљпњљ_0RQ;пњљF„Ј\u001bпњљh#пњљ\r9пњљпњљпњљ@6пњљ=пњљ—Нj#\u001b”£\u001bпњљy'Ca{49\u000f$пњљ”Йпњљпњљпњљ\tPK\u0007\bпњљ|zTпњљ\u0003\u0000\u0000F\b\u0000\u0000PK\u0003\u0004\u0014\u0000\b\b\b\u0000\u0000\u0000!<\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u001e\u0000\u0000\u0000io/circe/literal/package.scalaeпњљOoпњљ@\u0010пњљпњљпњљ\u0014OпњљRBDMпњљzпњљпњљпњљ%пњљкЦВпњљIпњљ\u001cпњљel&5пњљпњљпњљ\u000eпњљпњљпњљ;\u000bNпњљ(пњљпњљ;пњљпњљпњљyпњљ\u0017\t.0пњљпњљпњљqпњљ\u000bпњљ\\N>@пњљпњљ$сШЪ≥&пњљiпњљпњљlпњљ!пњљ\bYпњљпњљпњљпњљпњљ\b?пњљyпњљ\u0006пњљпњљ\u0012пњљ`–І\u0006√ПQпњљ`[пњљпњљ\u0001пњљ\u0006пњљпњљDпњљ=Jпњљ\tпњљпњљпњљ\t`\u0003mпњљMпњљпњљhBпњљawпњљ”ЂпњљQпњљ„∞пњљпњљпњљ\\IC#пњљпњљe!Tпњљпњљ\u000bпњљпњљпњљпњљ]„•пњљ\bпњљZWпњљпњљSпњљ\u001fпњљпњљпњљпњљпњљпњљ~/пњљ}”Нпњљпњљ{8пњљЁ≤пњљпњљ7\u0007пњљFпњљпњљпњљ\bjпњљ:X\u0007U9пњљ\\пњљ\u0011пњљs\u001cпњљT#x[пњљNпњљпњљ\u0019пњљпњљпњљM\u001b^yпњљпњљ(пњљпњљ,\u0010„Фпњљ +пњљ\u0017\u0003|ќКпњљ\u0018Eпњљпњљ|пњљuyпњљпњљmпњљZeпњљu~]`пњљпњљlпњљпњљпњљпњљпњљr!пњљ/пњљ\u0016wпњљпњљ/пњљF qLпњљпњљCпњљпњљ\u0006пњљпњљпњљMпњљ\u001eпњљ+пњљ^!пњљпњљпњљпњљ\u001bпњљ\\пњљпњљпњљL’™пњљPпњљ?пњљlпњљпњљ№Ю}пњљпњљ^\u0000пњљQпњљпњљ=\u0007\u0015пњљпњљ7{пњљAпњљ$\u0011пњљE!пњљпњљпњљ\u000e%\u0002b]пњљ\u0017Hk\u000eпњљTпњљ~пњљпњљпњљOпњљ?пњљvпњљпњљoпњљпњљ{пњљ\u0001}%\u001e\u0013пњљfAпњљпњљ;vќ¶f#пњљzпњљBl4пњљћЪ пњљпњљ\u0010пњљпњљ%\u001bпњљпњљRпњљ{пњљпњљ№•\\пњљпњљпњљпњљb8EDпњљ'пњљ{пњљ\u001bпњљ46пњљпњљпњљпњљпњљпњљ#пњљ≈Њ!пњљdпњљSпњљпњљ\u0005PK\u0007\bпњљпњљ\u0016aпњљ\u0001\u0000\u00004\u0003\u0000\u0000PK\u0001\u0002\u0014\u0000\u0014\u0000\b\b\b\u0000\u0000\u0000!<\u001fпњљпњљ(U\u0000\u0000\u0000z\u0000\u0000\u0000\u0014\u0000\u0004\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000META-INF/MANIFEST.MFпњљпњљ\u0000\u0000PK\u0001\u0002\n\u0000\n\u0000\u0000\b\u0000\u0000\u0000\u0000!<\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0003\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000пњљ\u0000\u0000\u0000io/PK\u0001\u0002\n\u0000\n\u0000\u0000\b\u0000\u0000\u0000\u0000!<\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\t\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000пњљ\u0000\u0000\u0000io/circe/PK\u0001\u0002\n\u0000\n\u0000\u0000\b\u0000\u0000\u0000\u0000!<\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0011\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000пњљ\u0000\u0000\u0000io/circe/literal/PK\u0001\u0002\u0014\u0000\u0014\u0000\b\b\b\u0000\u0000\u0000!<X\fIпњљпњљ\u0005\u0000\u0000n\u0010\u0000\u0000(\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0012\u0001\u0000\u0000io/circe/literal/JsonLiteralMacros.scalaPK\u0001\u0002\u0014\u0000\u0014\u0000\b\b\b\u0000\u0000\u0000!<пњљ|zTпњљ\u0003\u0000\u0000F\b\u0000\u0000\"\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\n\u0007\u0000\u0000io/circe/literal/Replacement.scalaPK\u0001\u0002\u0014\u0000\u0014\u0000\b\b\b\u0000\u0000\u0000!<пњљпњљ\u0016aпњљ\u0001\u0000\u00004\u0003\u0000\u0000\u001e\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000пњљ\n\u0000\u0000io/circe/literal/package.scalaPK\u0005\u0006\u0000\u0000\u0000\u0000\u0007\u0000\u0007\u0000пњљ\u0001\u0000\u0000\u0013\r\u0000\u0000\u0000\u0000./io/circe/literal/Replacement.scala\n==== ./io/circe/literal/Replacement.scala\n/*\n * Copyright 2024 circe\n *\n * Licensed under the Apache License, Version 2.0 (the \"License\");\n * you may not use this file except in compliance with the License.\n * You may obtain a copy of the License at\n *\n *     http://www.apache.org/licenses/LICENSE-2.0\n *\n * Unless required by applicable law or agreed to in writing, software\n * distributed under the License is distributed on an \"AS IS\" BASIS,\n * WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n * See the License for the specific language governing permissions and\n * limitations under the License.\n */\n\npackage io.circe.literal\n\nimport java.util.UUID\nimport scala.quoted.{ Expr, Quotes, Type }\nimport io.circe.{ Encoder, Json, KeyEncoder }\n\ncase class Replacement(val placeholder: String, argument: Expr[Any]) {\n  def asJson(using q: Quotes): Expr[Json] = {\n    import q.reflect.*\n    argument match {\n      case '{\n            $arg: t\n          } => {\n        arg.asTerm.tpe.widen.asType match {\n          case '[t] =>\n            Expr.summon[Encoder[t]] match {\n              case Some(encoder) => '{ $encoder.apply($arg.asInstanceOf[t]) }\n              case None          => report.errorAndAbort(s\"could not find implicit Encoder for ${Type.show[t]}\", arg)\n            }\n        }\n      }\n    }\n  }\n\n  def asKey(using q: Quotes): Expr[String] = {\n    import q.reflect.*\n    argument match {\n      case '{ $arg: t } =>\n        arg.asTerm.tpe.widen.asType match {\n          case '[t] =>\n            Expr.summon[KeyEncoder[t]] match {\n              case Some(encoder) => '{ $encoder.apply($arg.asInstanceOf[t]) }\n              case None => report.errorAndAbort(s\"could not find implicit for ${Type.show[KeyEncoder[t]]}\", arg)\n            }\n        }\n    }\n  }\n}\n\nobject Replacement {\n  private[this] final def generatePlaceholder(): String = UUID.randomUUID().toString\n\n  def apply(stringParts: Seq[String], argument: Expr[Any]): Replacement = {\n\n    val placeholder =\n      Stream.continually(generatePlaceholder()).distinct.dropWhile(s => stringParts.exists(_.contains(s))).head\n\n    new Replacement(placeholder, argument)\n  }\n}\n./io/circe/literal/package.scala\n==== ./io/circe/literal/package.scala\n/*\n * Copyright 2024 circe\n *\n * Licensed under the Apache License, Version 2.0 (the \"License\");\n * you may not use this file except in compliance with the License.\n * You may obtain a copy of the License at\n *\n *     http://www.apache.org/licenses/LICENSE-2.0\n *\n * Unless required by applicable law or agreed to in writing, software\n * distributed under the License is distributed on an \"AS IS\" BASIS,\n * WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n * See the License for the specific language governing permissions and\n * limitations under the License.\n */\n\npackage io.circe\n\nimport io.circe.literal.JsonLiteralMacros\n\npackage object literal {\n  extension (inline sc: StringContext) {\n    inline final def json(inline args: Any*): Json = ${ JsonLiteralMacros.jsonImpl('sc, 'args) }\n  }\n}\n./io/circe/literal/JsonLiteralMacros.scala\n==== ./io/circe/literal/JsonLiteralMacros.scala\n/*\n * Copyright 2024 circe\n *\n * Licensed under the Apache License, Version 2.0 (the \"License\");\n * you may not use this file except in compliance with the License.\n * You may obtain a copy of the License at\n *\n *     http://www.apache.org/licenses/LICENSE-2.0\n *\n * Unless required by applicable law or agreed to in writing, software\n * distributed under the License is distributed on an \"AS IS\" BASIS,\n * WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n * See the License for the specific language governing permissions and\n * limitations under the License.\n */\n\npackage io.circe.literal\n\nimport scala.quoted.*\nimport io.circe.{ Encoder, Json, JsonNumber }\nimport org.typelevel.jawn.{ FContext, Facade, Parser }\nimport scala.util.{ Failure, Success }\nimport io.circe.literal.Replacement\n\nobject JsonLiteralMacros {\n  def jsonImpl(sc: Expr[StringContext], args: Expr[Seq[Any]])(using q: Quotes): Expr[Json] = {\n    import q.reflect.*\n    val stringParts = sc match {\n      case '{ StringContext($parts*) } => parts.valueOrAbort\n    }\n\n    val replacements = args match {\n      case Varargs(argExprs) =>\n        argExprs.map(Replacement(stringParts, _))\n      case other => report.errorAndAbort(\"Invalid arguments for json literal.\")\n    }\n\n    val jsonString = stringParts.zip(replacements.map(_.placeholder)).foldLeft(\"\") {\n      case (acc, (part, placeholder)) =>\n        val qm = \"\\\"\"\n        s\"$acc$part$qm$placeholder$qm\"\n    } + stringParts.last\n\n    inline given Facade[Expr[Json]] with {\n\n      private def toJsonKey(s: String): Expr[String] =\n        replacements.find(_.placeholder == s).fold(Expr(s.toString))(_.asKey)\n      private def toJsonString(s: String): Expr[Json] = replacements\n        .find(_.placeholder == s)\n        .fold { val strExpr = Expr(s.toString); '{ Json.fromString($strExpr) } }(_.asJson)\n      def arrayContext(index: Int): FContext[Expr[Json]] = new FContext.NoIndexFContext[Expr[Json]] {\n        private var values: Expr[List[Json]] = Expr(Nil)\n\n        def isObj: Boolean = false\n\n        def add(s: CharSequence): Unit = {\n          val strExpr = toJsonString(s.toString)\n          values = '{ $strExpr :: $values }\n        }\n        def add(v: Expr[Json]): Unit = values = '{ $v :: ${ values } }\n        def finish(): Expr[Json] = '{ Json.arr($values.reverse*) }\n      }\n      def jfalse(index: Int): Expr[Json] = '{ Json.False }\n      def jnull(index: Int): Expr[Json] = '{ Json.Null }\n      inline def jnum(s: CharSequence, decIndex: Int, expIndex: Int, index: Int): Expr[Json] =\n        val str = Expr(s.toString)\n        '{ JsonNumber.fromString($str).map(Json.fromJsonNumber(_)).getOrElse(throw Exception(\"Invalid json number.\")) }\n      def jstring(s: CharSequence, index: Int): Expr[Json] = toJsonString(s.toString)\n      def jtrue(index: Int): Expr[Json] = '{ Json.True }\n\n      def objectContext(index: Int): FContext[Expr[Json]] = new FContext.NoIndexFContext[Expr[Json]] {\n        private[this] var fields: Expr[List[(String, Json)]] = Expr(Nil)\n        private[this] var key: String = null\n\n        def isObj: Boolean = true\n        def add(s: CharSequence): Unit = {\n          if (key.eq(null)) {\n            key = s.toString\n          } else {\n            val keyExpr = toJsonKey(key)\n            val value = toJsonString(s.toString)\n            fields = '{ ($keyExpr, $value) :: $fields }\n            key = null\n          }\n        }\n        def add(v: Expr[Json]): Unit = {\n          val keyExpr = toJsonKey(key)\n          fields = '{ ($keyExpr, $v) :: $fields }\n          key = null\n        }\n        def finish(): Expr[Json] = '{ Json.obj($fields.reverse*) }\n      }\n      def singleContext(index: Int): FContext[Expr[Json]] = new FContext.NoIndexFContext[Expr[Json]] {\n        private[this] var value: Expr[Json] = null\n\n        def isObj: Boolean = false\n        def add(s: CharSequence): Unit = value = toJsonString(s.toString)\n        def add(v: Expr[Json]): Unit = value = v\n        def finish(): Expr[Json] = value\n      }\n    }\n\n    Parser.parseFromString[Expr[Json]](jsonString) match {\n      case Success(jsonExpr) => jsonExpr\n      case Failure(e)        =>\n        report.errorAndAbort(e.toString)\n    }\n  }\n}\n./META-INF/MANIFEST.MF\n==== ./META-INF/MANIFEST.MF\nManifest-Version: 1.0\r\nSpecification-Vendor: circe\r\nSpecification-Title: Circe literal\r\nSpecification-Version: 0.14.15\r\n\r\n"}], "isError": false, "timestamp": 1782550045998}}
