iteral\")\n    )\n\n    assertThat(document).isEqualTo(expected)\n  }\n\n  @Test\n  def literalPreservesJsonEscapesAndInterpolatedStrings(): Unit = {\n"}]}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 131, "output": 1455, "cacheRead": 17920, "cacheWrite": 0, "totalTokens": 19506, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1781156469727, "responseId": "resp_053b6a31cd83c06b016a2a4a7618e48196ae3f2b3d1d1ec9a7"}}
