[tool-call] delta {"path":"tests/src/io.circe/circe-literal_3/0.14.15/src/test/scala/io_circe/circe_literal_3/Circe_literal_3Test.scala","edits":[{"oldText":"import io.circe.Json\nimport io.circe.KeyEncoder\n","newText":"import io.circe.Json\nimport io.circe.JsonObject\nimport io.circe.KeyEncoder\n"},{"oldText":"  @Test\n  def buildsTopLevelScalarLiteralsAndInterpolatedValues(): Unit = {\n","newText":"  @Test\n  def buildsJsonObjectLiteralsForObjectSpecificOperations(): Unit = {\n    val serviceName: String = \"search\"\n    val enabled: Boolean = true\n    val limits: Json = json\"\"\"{ \"requests\": 100, \"burst\": 10 }\"\"\"\n\n    val fields: JsonObject = jsonObject\"\"\"\n      {\n        \"service\": $serviceName,\n        \"enabled\": $enabled,\n        \"limits\": $limits\n      }\n    \"\"\"\n\n    val updated: JsonObject = fields.add(\"status\", Json.fromString(\"healthy\"))\n    val withoutFlag: JsonObject = updated.remove(\"enabled\")\n\n    assertThat(fields.apply(\"service\").flatMap(_.asString)).isEqualTo(Some(serviceName))\n    assertThat(fields.apply(\"enabled\").flatMap(_.asBoolean)).isEqualTo(Some(enabled))\n    assertThat(fields.toJson.hcursor.downField(\"limits\").get[Int](\"requests\")).isEqualTo(Right(100))\n    assertThat(updated.toJson.hcursor.get[String](\"status\")).isEqualTo(Right(\"healthy\"))\n    assertThat(withoutFlag.contains(\"enabled\")).isFalse\n  }\n\n  @Test\n  def buildsTopLevelScalarLiteralsAndInterpolatedValues(): Unit = {\n"}]}
