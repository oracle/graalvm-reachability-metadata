t: Json = json\"\"\"\n      {\n        ${prefix + \"Count\"}: ${baseCount + 5},\n        \"tagLengths\": ${tags.map(_.length)},\n        \"summary\": ${s\"${tags.head}:${tags.size}\"}\n      }\n    \"\"\"\n\n    assertThat(document.hcursor.get[Int](\"metricCount\")).isEqualTo(Right(15))\n    assertThat(document.hcursor.get[List[Int]](\"tagLengths\")).isEqualTo(Right(List(5, 4, 7)))\n    assertThat(document.hcursor.get[String](\"summary\")).isEqualTo(Right(\"alpha:3\"))\n  }\n\n  @Test\n  def buildsTopLevelScalarLiteralsAndInterpolatedValues(): Unit = {\n"}]}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 2090, "output": 1827, "cacheRead": 31232, "cacheWrite": 0, "totalTokens": 35149, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1782545071072, "responseId": "resp_0fe5149e3f5592bc016a3f7aaf8cec819481b192d5536b5b22"}}
