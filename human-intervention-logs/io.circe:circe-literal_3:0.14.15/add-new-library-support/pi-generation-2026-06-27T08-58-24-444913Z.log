sertj.core.api.Assertions.assertThat\nimport scala.compiletime.testing.typeCheckErrors"}, {"oldText": "  @Test\n  def allowsInterpolatedScalarsAsCompleteJsonDocuments(): Unit = {", "newText": "  @Test\n  def rejectsMalformedJsonLiteralsAtCompileTime(): Unit = {\n    val errors = typeCheckErrors(\"\"\"\n      |import io.circe.literal.*\n      |val invalidDocument = json\"{ \\\"items\\\": [1, 2, }\"\n      |\"\"\".stripMargin)\n\n    assertThat(errors.nonEmpty).isTrue\n    assertThat(errors.map(_.message).mkString(\"\\n\")).contains(\"ParseException\")\n  }\n\n  @Test\n  def allowsInterpolatedScalarsAsCompleteJsonDocuments(): Unit = {"}]}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 690, "output": 1969, "cacheRead": 38912, "cacheWrite": 0, "totalTokens": 41571, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1782550636119, "responseId": "resp_0b54688ebe1c2c87016a3f906c975481938d436f78b693bd41"}}
