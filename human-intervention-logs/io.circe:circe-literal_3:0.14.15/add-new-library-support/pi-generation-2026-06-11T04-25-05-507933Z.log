      22	import scala.util.{ Failure, Success }
      23	import io.circe.literal.Replacement
      24	
      25	object JsonLiteralMacros {
      26	  def jsonImpl(sc: Expr[StringContext], args: Expr[Seq[Any]])(using q: Quotes): Expr[Json] = {
      27	    import q.reflect.*
      28	    val stringParts = sc match {
      29	      case '{ StringContext($parts*) } => parts.valueOrAbort
      30	    }
      31	
      32	    val replacements = args match {
      33	      case Varargs(argExprs) =>
      34	        argExprs.map(Replacement(stringParts, _))
      35	      case other => report.errorAndAbort("Invalid arguments for json literal.")
      36	    }
      37	
      38	    val jsonString = stringParts.zip(replacements.map(_.placeholder)).foldLeft("") {
      39	      case (acc, (part, placeholder)) =>
      40	        val qm = "\""
      41	        s"$acc$part$qm$placeholder$qm"
      42	    } + stringParts.last
      43	
      44	    inline given Facade[Expr[Json]] with {
      45	
      46	      private def toJsonKey(s: String): Expr[String] =
      47	        replacements.find(_.placeholder == s).fold(Expr(s.toString))(_.asKey)
      48	      private def toJsonString(s: String): Expr[Json] = replacements
      49	        .find(_.placeholder == s)
      50	        .fold { val strExpr = Expr(s.toString); '{ Json.fromString($strExpr) } }(_.asJson)
      51	      def arrayContext(index: Int): FContext[Expr[Json]] = new FContext.NoIndexFContext[Expr[Json]] {
      52	        private var values: Expr[List[Json]] = Expr(Nil)
      53	
      54	        def isObj: Boolean = false
      55	
      56	        def add(s: CharSequence): Unit = {
      57	          val strExpr = toJsonString(s.toString)
      58	          values = '{ $strExpr :: $values }
      59	        }
      60	        def add(v: Expr[Json]): Unit = values = '{ $v :: ${ values } }
      61	        def finish(): Expr[Json] = '{ Json.arr($values.reverse*) }
      62	      }
      63	      def jfalse(index: Int): Expr[Json] = '{ Json.False }
      64	      def jnull(index: Int): Expr[Json] = '{ Json.Null }
      65	      inline def jnum(s: CharSequence, decIndex: Int, expIndex: Int, index: Int): Expr[Json] =
      66	        val str = Expr(s.toString)
      67	        '{ JsonNumber.fromString($str).map(Json.fromJsonNumber(_)).getOrElse(throw Exception("Invalid json number.")) }
      68	      def jstring(s: CharSequence, index: Int): Expr[Json] = toJsonString(s.toString)
      69	      def jtrue(index: Int): Expr[Json] = '{ Json.True }
      70	
      71	      def objectContext(index: Int): FContext[Expr[Json]] = new FContext.NoIndexFContext[Expr[Json]] {
      72	        private[this] var fields: Expr[List[(String, Json)]] = Expr(Nil)
      73	        private[this] var key: String = null
      74	
      75	        def isObj: Boolean = true
      76	        def add(s: CharSequence): Unit = {
      77	          if (key.eq(null)) {
      78	            key = s.toString
      79	          } else {
      80	            val keyExpr = toJsonKey(key)
      81	            val value = toJsonString(s.toString)
      82	            fields = '{ ($keyExpr, $value) :: $fields }
      83	            key = null
      84	          }
      85	        }
      86	        def add(v: Expr[Json]): Unit = {
      87	          val keyExpr = toJsonKey(key)
      88	          fields = '{ ($keyExpr, $v) :: $fields }
      89	          key = null
      90	        }
      91	        def finish(): Expr[Json] = '{ Json.obj($fields.reverse*) }
      92	      }
      93	      def singleContext(index: Int): FContext[Expr[Json]] = new FContext.NoIndexFContext[Expr[Json]] {
      94	        private[this] var value: Expr[Json] = null
      95	
      96	        def isObj: Boolean = false
      97	        def add(s: CharSequence): Unit = value = toJsonString(s.toString)
      98	        def add(v: Expr[Json]): Unit = value = v
      99	        def finish(): Expr[Json] = value
     100	      }
     101	    }
     102	
     103	    Parser.parseFromString[Expr[Json]](jsonString) match {
     104	      case Success(jsonExpr) => jsonExpr
     105	      case Failure(e)        =>
     106	        report.errorAndAbort(e.toString)
     107	    }
     108	  }
     109	}
