laceholder$qm\"\n    42\t    } + stringParts.last\n    43\t\n    44\t    inline given Facade[Expr[Json]] with {\n    45\t\n    46\t      private def toJsonKey(s: String): Expr[String] =\n    47\t        replacements.find(_.placeholder == s).fold(Expr(s.toString))(_.asKey)\n    48\t      private def toJsonString(s: String): Expr[Json] = replacements\n    49\t        .find(_.placeholder == s)\n    50\t        .fold { val strExpr = Expr(s.toString); '{ Json.fromString($strExpr) } }(_.asJson)\n    51\t      def arrayContext(index: Int): FContext[Expr[Json]] = new FContext.NoIndexFContext[Expr[Json]] {\n    52\t        private var values: Expr[List[Json]] = Expr(Nil)\n    53\t\n    54\t        def isObj: Boolean = false\n    55\t\n    56\t        def add(s: CharSequence): Unit = {\n    57\t          val strExpr = toJsonString(s.toString)\n    58\t          values = '{ $strExpr :: $values }\n    59\t        }\n    60\t        def add(v: Expr[Json]): Unit = values = '{ $v :: ${ values } }\n    61\t        def finish(): Expr[Json] = '{ Json.arr($values.reverse*) }\n    62\t      }\n    63\t      def jfalse(index: Int): Expr[Json] = '{ Json.False }\n    64\t      def jnull(index: Int): Expr[Json] = '{ Json.Null }\n    65\t      inline def jnum(s: CharSequence, decIndex: Int, expIndex: Int, index: Int): Expr[Json] =\n    66\t        val str = Expr(s.toString)\n    67\t        '{ JsonNumber.fromString($str).map(Json.fromJsonNumber(_)).getOrElse(throw Exception(\"Invalid json number.\")) }\n    68\t      def jstring(s: CharSequence, index: Int): Expr[Json] = toJsonString(s.toString)\n    69\t      def jtrue(index: Int): Expr[Json] = '{ Json.True }\n    70\t\n    71\t      def objectContext(index: Int): FContext[Expr[Json]] = new FContext.NoIndexFContext[Expr[Json]] {\n    72\t        private[this] var fields: Expr[List[(String, Json)]] = Expr(Nil)\n    73\t        private[this] var key: String = null\n    74\t\n    75\t        def isObj: Boolean = true\n    76\t        def add(