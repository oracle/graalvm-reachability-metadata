          def add(s: CharSequence): Unit = {
            val strExpr = toJsonString(s.toString)
            values = '{ $strExpr :: $values }
          }
          def add(v: Expr[Json]): Unit = values = '{ $v :: ${ values } }
          def finish(): Expr[Json] = '{ Json.arr($values.reverse*) }
