            case '[t] =>
              Expr.summon[KeyEncoder[t]] match {
                case Some(encoder) => '{ $encoder.apply($arg.asInstanceOf[t]) }
                case None => report.errorAndAbort(s"could not find implicit for ${Type.show[KeyEncoder[t]]}", arg)
