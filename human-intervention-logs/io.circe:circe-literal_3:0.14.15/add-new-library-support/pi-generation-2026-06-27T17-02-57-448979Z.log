[tool-call] delta {"path":"tests/src/io.circe/circe-literal_3/0.14.15/src/test/scala/io_circe/circe_literal_3/Circe_literal_3Test.scala","edits":[{"oldText":"  @Test\n  def interpolatesValuesInsideArraysAndAtTheRoot(): Unit = {\n","newText":"  @Test\n  def interpolatesMapsAsJsonObjectsUsingAvailableKeyEncoders(): Unit = {\n    val statusCounts: Map[LiteralField, List[Int]] = Map(\n      LiteralField(\"http\", \"success\") -> List(200, 201, 204),\n      LiteralField(\"http\", \"redirect\") -> List(301, 302)\n    )\n\n    val document: Json = json\"\"\"\n      {\n        \"statusCounts\": $statusCounts,\n        \"emptyCounts\": ${Map.empty[LiteralField, Int]}\n      }\n    \"\"\"\n\n    val statusCursor = document.hcursor.downField(\"statusCounts\")\n    assertEquals(Right(List(200, 201, 204)), statusCursor.get[List[Int]](\"http:success\"))\n    assertEquals(Right(List(301, 302)), statusCursor.get[List[Int]](\"http:redirect\"))\n    assertEquals(Set(\"http:success\", \"http:redirect\"), decodeOrFail(statusCursor.as[Json]).asObject.map(_.keys.toSet).getOrElse(Set.empty))\n    assertEquals(Right(Map.empty[String, Int]), document.hcursor.get[Map[String, Int]](\"emptyCounts\"))\n  }\n\n  @Test\n  def interpolatesValuesInsideArraysAndAtTheRoot(): Unit = {\n"}]}
