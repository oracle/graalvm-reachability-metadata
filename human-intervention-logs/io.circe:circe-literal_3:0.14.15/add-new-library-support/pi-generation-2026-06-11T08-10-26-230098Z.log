    }
  
    @Test
    def interpolatesTopLevelScalaValues(): Unit = {
      val text: String = "quotes \" and unicode snowman ☃"
      val numbers: List[Int] = List(1, 2, 3)
      val jsonObject: Json = Json.obj("ok" -> Json.True, "answer" -> Json.fromInt(42))
  
