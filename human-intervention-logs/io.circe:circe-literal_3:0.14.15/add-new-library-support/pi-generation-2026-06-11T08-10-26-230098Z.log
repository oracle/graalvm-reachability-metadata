    def interpolatesInlineExpressionsInJsonValueAndKeyPositions(): Unit = {
      val literal: Json = json"""{ ${40 + 2}: ${List("forty", "two").mkString("-")} }"""
      val expected: Json = Json.obj("42" -> Json.fromString("forty-two"))
  
      assertEquals(expected, literal)
    }
  
