[tool-call] delta {"path":"tests/src/io.circe/circe-literal_3/0.14.15/src/test/scala/io_circe/circe_literal_3/Circe_literal_3Test.scala","edits":[{"oldText":"  @Test\n  def interpolatesInsideJsonStringsAndQuotedKeys(): Unit = {\n    val operator: String = \"release \\\"candidate\\\"\"\n    val target: String = \"prod\\nblue\"\n    val service: ServiceName = ServiceName(\"catalog.primary\")\n    val lane: ServiceName = ServiceName(\"worker/blue\")\n\n    val document: Json = json\"\"\"\n      {\n        \"message\": \"deploy $operator to $target\",\n        \"route-$service\": {\n          \"lane-$lane\": \"active\"\n        }\n      }\n      \"\"\"\n\n    assertThat(document.hcursor.get[String](\"message\"))\n      .isEqualTo(Right(\"deploy release \\\"candidate\\\" to prod\\nblue\"))\n    assertThat(document.hcursor.downField(\"route-catalog.primary\").get[String](\"lane-worker/blue\"))\n      .isEqualTo(Right(\"active\"))\n  }\n","newText":"  @Test\n  def escapesInterpolatedObjectKeysProducedByKeyEncoders(): Unit = {\n    val quoted: ServiceName = ServiceName(\"service \\\"alpha\\\"\")\n    val multiline: ServiceName = ServiceName(\"service\\nbeta\")\n    val unicode: ServiceName = ServiceName(\"service-☃\")\n\n    val document: Json = json\"\"\"\n      {\n        $quoted: \"quoted\",\n        $multiline: \"multiline\",\n        $unicode: \"unicode\"\n      }\n      \"\"\"\n\n    assertThat(document.hcursor.get[String](quoted.value)).isEqualTo(Right(\"quoted\"))\n    assertThat(document.hcursor.get[String](multiline.value)).isEqualTo(Right(\"multiline\"))\n    assertThat(document.hcursor.get[String](unicode.value)).isEqualTo(Right(\"unicode\"))\n  }\n"}]}
