[tool-call] delta {"path":"tests/src/io.circe/circe-literal_3/0.14.15/src/test/scala/io_circe/circe_literal_3/Circe_literal_3Test.scala","edits":[{"oldText":"import io.circe.Json\nimport io.circe.KeyEncoder\n","newText":"import io.circe.Encoder\nimport io.circe.Json\nimport io.circe.KeyEncoder\n"},{"oldText":"  @Test\n  def encodesInterpolatedObjectKeysWithKeyEncoders(): Unit = {\n","newText":"  @Test\n  def encodesInterpolatedCustomValuesWithInScopeEncoders(): Unit = {\n    final case class Coordinate(x: Int, y: Int)\n    given Encoder[Coordinate] = coordinate => Json.arr(Json.fromInt(coordinate.x), Json.fromInt(coordinate.y))\n\n    val origin: Coordinate = Coordinate(0, 0)\n    val destination: Coordinate = Coordinate(5, -3)\n    val route: Json = json\"\"\"\n      {\n        \"origin\": $origin,\n        \"destination\": $destination,\n        \"description\": \"custom encoder output\"\n      }\n    \"\"\"\n\n    val cursor = route.hcursor\n    val originValues: Vector[Json] = cursor.downField(\"origin\").focus.flatMap(_.asArray).getOrElse(Vector.empty)\n    val destinationValues: Vector[Json] = cursor.downField(\"destination\").focus.flatMap(_.asArray).getOrElse(Vector.empty)\n\n    assertThat(originValues.map(_.asNumber.flatMap(_.toInt)).asJava).containsExactly(Some(0), Some(0))\n    assertThat(destinationValues.map(_.asNumber.flatMap(_.toInt)).asJava).containsExactly(Some(5), Some(-3))\n    assertThat(cursor.downField(\"description\").as[String]).isEqualTo(Right(\"custom encoder output\"))\n  }\n\n  @Test\n  def encodesInterpolatedObjectKeysWithKeyEncoders(): Unit = {\n"}]}
[tool-call] end id=call_EtVnyJiTmSYq5yMtan9J4xXP|fc_0078f4e714546659016a3fde2938888190872713d53ee9c5ba name=edit args={"path": "tests/src/io.circe/circe-literal_3/0.14.15/src/test/scala/io_circe/circe_literal_3/Circe_literal_3Test.scala", "edits": [{"oldText": "import io.circe.Json\nimport io.circe.KeyEncoder\n", "newText": "import io.circe.Encoder\nimport io.circe.Json\nimport io.circe.KeyEncoder\n"}, {"oldText": "  @Test\n  def encodesInterpolatedObjectKeysWithKeyEncoders(): Unit = {\n", "newText": "  @Test\n  def encodesInterpolatedCustomValuesWithInScopeEncoders(): Unit = {\n    final case class Coordinate(x: Int, y: Int)\n    given Encoder[Coordinate] = coordinate => Json.arr(Json.fromInt(coordinate.x), Json.fromInt(coordinate.y))\n\n    val origin: Coordinate = Coordinate(0, 0)\n    val destination: Coordinate = Coordinate(5, -3)\n    val route: Json = json\"\"\"\n      {\n        \"origin\": $origin,\n        \"destination\": $destination,\n        \"description\": \"custom encoder output\"\n      }\n    \"\"\"\n\n    val cursor = route.hcursor\n    val originValues: Vector[Json] = cursor.downField(\"origin\").focus.flatMap(_.asArray).getOrElse(Vector.empty)\n    val destinationValues: Vector[Json] = cursor.downField(\"destination\").focus.flatMap(_.asArray).getOrElse(Vector.empty)\n\n    assertThat(originValues.map(_.asNumber.flatMap(_.toInt)).asJava).containsExactly(Some(0), Some(0))\n    assertThat(destinationValues.map(_.asNumber.flatMap(_.toInt)).asJava).containsExactly(Some(5), Some(-3))\n    assertThat(cursor.downField(\"description\").as[String]).isEqualTo(Right(\"custom encoder output\"))\n  }\n\n  @Test\n  def encodesInterpolatedObjectKeysWithKeyEncoders(): Unit = {\n"}]}
