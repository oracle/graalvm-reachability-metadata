    @Test
    def interpolatesInsideQuotedJsonStrings(): Unit = {
      val environment: String = "prod"
      val service: String = "literal \"api\""
      val pathSegment: String = "v1/users"
      val document: Json = json"""
        {
          "message": "Deploy $service to $environment",
          "endpoint": "/api/$pathSegment",
          "nested": {
            "owner": "team-$environment"
          }
        }
      """
  
      assertThat(document.hcursor.downField("message").as[String])
        .isEqualTo(Right("Deploy literal \"api\" to prod"))
      assertThat(document.hcursor.downField("endpoint").as[String])
        .isEqualTo(Right("/api/v1/users"))
      assertThat(document.hcursor.downField("nested").downField("owner").as[String])
        .isEqualTo(Right("team-prod"))
    }
  
    @Test
    def combinesLiteralStructureAndRepeatedInterpolations(): Unit = {
      val user: LiteralUser = LiteralUser("Grace", 41, List("compiler", "navy"))
      val key: LiteralKey = LiteralKey("user", 100)
      val enabled: Boolean = true
      val document: Json = json"""
        {
          "audit": [
            { "actor": $user, "enabled": $enabled },
            { "actor": $user, "enabled": false }
          ],
          "lookup": {
            $key: $user
          }
        }
      """
  
