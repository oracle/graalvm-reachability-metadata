      val stringKey: String = "title"
      val numericKey: Int = 2024
      val customKey: FieldName = FieldName("custom-field")
      given KeyEncoder[FieldName] = KeyEncoder.instance(_.value)
  
      val actual: Json = json"""
        {
          $stringKey: "Circe",
          $numericKey: true,
          $customKey: [1, 2]
        }
