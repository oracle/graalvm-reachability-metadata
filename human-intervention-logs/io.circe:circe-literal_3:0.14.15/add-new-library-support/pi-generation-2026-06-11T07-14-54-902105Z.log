        "person" -> Json.obj(
          "name" -> Json.fromString("Ada"),
          "age" -> Json.fromInt(36)
        ),
        "team" -> Json.arr(
          Json.obj(
            "name" -> Json.fromString("Ada"),
            "age" -> Json.fromInt(36)
          ),
          Json.obj(
            "name" -> Json.fromString("Grace"),
            "age" -> Json.fromInt(85)
          )
        )
      )
  
      assertEquals(expected, actual)
    }
  
    private final case class FieldName(value: String)
  
    private final case class Person(name: String, age: Int)
  }
