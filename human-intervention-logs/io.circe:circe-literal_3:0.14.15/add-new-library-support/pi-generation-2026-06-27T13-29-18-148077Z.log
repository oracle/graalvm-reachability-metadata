  class Circe_literal_3Test {
    @Test
    def parsesObjectArrayAndPrimitiveLiterals(): Unit = {
      val document: Json = json"""
        {
          "name": "circe-literal",
          "enabled": true,
          "missing": null,
          "count": 42,
          "ratio": -12.5e2,
