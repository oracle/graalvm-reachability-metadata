      17	package io.circe.literal
      18	
      19	import java.util.UUID
      20	import scala.quoted.{ Expr, Quotes, Type }
      21	import io.circe.{ Encoder, Json, KeyEncoder }
      22	
      23	case class Replacement(val placeholder: String, argument: Expr[Any]) {
      24	  def asJson(using q: Quotes): Expr[Json] = {
      25	    import q.reflect.*
      26	    argument match {
      27	      case '{
      28	            $arg: t
      29	          } => {
      30	        arg.asTerm.tpe.widen.asType match {
      31	          case '[t] =>
      32	            Expr.summon[Encoder[t]] match {
      33	              case Some(encoder) => '{ $encoder.apply($arg.asInstanceOf[t]) }
      34	              case None          => report.errorAndAbort(s"could not find implicit Encoder for ${Type.show[t]}", arg)
      35	            }
      36	        }
      37	      }
      38	    }
      39	  }
      40	
      41	  def asKey(using q: Quotes): Expr[String] = {
      42	    import q.reflect.*
      43	    argument match {
      44	      case '{ $arg: t } =>
      45	        arg.asTerm.tpe.widen.asType match {
      46	          case '[t] =>
      47	            Expr.summon[KeyEncoder[t]] match {
      48	              case Some(encoder) => '{ $encoder.apply($arg.asInstanceOf[t]) }
      49	              case None => report.errorAndAbort(s"could not find implicit for ${Type.show[KeyEncoder[t]]}", arg)
      50	            }
      51	        }
      52	    }
      53	  }
      54	}
      55	
      56	object Replacement {
      57	  private[this] final def generatePlaceholder(): String = UUID.randomUUID().toString
      58	
      59	  def apply(stringParts: Seq[String], argument: Expr[Any]): Replacement = {
      60	
      61	    val placeholder =
      62	      Stream.continually(generatePlaceholder()).distinct.dropWhile(s => stringParts.exists(_.contains(s))).head
      63	
      64	    new Replacement(placeholder, argument)
      65	  }
      66	}
