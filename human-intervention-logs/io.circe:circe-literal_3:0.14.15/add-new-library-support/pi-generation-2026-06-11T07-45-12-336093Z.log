ce): Unit = {\n    57\t          val strExpr = toJsonString(s.toString)\n    58\t          values = '{ $strExpr :: $values }\n    59\t        }\n    60\t        def add(v: Expr[Json]): Unit = values = '{ $v :: ${ values } }\n    61\t        def finish(): Expr[Json] = '{ Json.arr($values.reverse*) }\n    62\t      }\n    63\t      def jfalse(index: Int): Expr[Json] = '{ Json.False }\n    64\t      def jnull(index: Int): Expr[Json] = '{ Json.Null }\n    65\t      inline def jnum(s: CharSequence, decIndex: Int, expIndex: Int, index: Int): Expr[Json] =\n    66\t        val str = Expr(s.toString)\n    67\t        '{ JsonNumber.fromString($str).map(Json.fromJsonNumber(_)).getOrElse(throw Exception(\"Invalid json number.\")) }\n    68\t      def jstring(s: CharSequence, index: Int): Expr[Json] = toJsonString(s.toString)\n    69\t      def jtrue(index: Int): Expr[Json] = '{ Json.True }\n    70\t\n    71\t      def objectContext(index: Int): FContext[Expr[Json]] = new FContext.NoIndexFContext[Expr[Json]] {\n    72\t        private[this] var fields: Expr[List[(String, Json)]] = Expr(Nil)\n    73\t        private[this] var key: String = null\n    74\t\n    75\t        def isObj: Boolean = true\n    76\t        def add(s: CharSequence): Unit = {\n    77\t          if (key.eq(null)) {\n    78\t            key = s.toString\n    79\t          } else {\n    80\t            val keyExpr = toJsonKey(key)\n    81\t            val value = toJsonString(s.toString)\n    82\t            fields = '{ ($keyExpr, $value) :: $fields }\n    83\t            key = null\n    84\t          }\n    85\t        }\n    86\t        def add(v: Expr[Json]): Unit = {\n    87\t          val keyExpr = toJsonKey(key)\n    88\t          fields = '{ ($keyExpr, $v) :: $fields }\n    89\t          key = null\n    90\t        }\n    91\t        def finish(): Expr[Json] = '{ Json.obj($fields.reverse*) }\n    92\t      }\n    93\t      def singleContext(index: Int): FContext[Expr[Json]] = new FContext.NoIndexFContext