      } + stringParts.last
  
      inline given Facade[Expr[Json]] with {
  
        private def toJsonKey(s: String): Expr[String] =
          replacements.find(_.placeholder == s).fold(Expr(s.toString))(_.asKey)
        private def toJsonString(s: String): Expr[Json] = replacements
