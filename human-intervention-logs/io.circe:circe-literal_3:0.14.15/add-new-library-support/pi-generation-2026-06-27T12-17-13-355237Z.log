rtEquals(Right(List(\"first\", \"object\")), passthroughArray.asArray.map { values =>\n      values.map { value =>\n        value.asString.getOrElse(if value.isObject then \"object\" else fail(\"Expected string or object\"))\n      }.toList\n    }.toRight(DecodingFailure(\"Expected array\", Nil)))\n    assertEquals(Right(true), passthroughArray.hcursor.downArray.right.downField(\"second\").as[Boolean])\n  }\n\n  @Test\n  def interpolatesValuesThroughCirceEncoders(): Unit = {"}]}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 4872, "output": 1484, "cacheRead": 30720, "cacheWrite": 0, "totalTokens": 37076, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1782562593633, "responseId": "resp_006641b8546e913e016a3fbf2220648195b727bb2686e2683f"}}
