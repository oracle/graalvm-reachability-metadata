[tool-call] delta {"path":"tests/src/io.circe/circe-literal_3/0.14.15/src/test/scala/io_circe/circe_literal_3/Circe_literal_3Test.scala","edits":[{"oldText":"  @Test\n  def interpolatesInsideJsonStringLiteralsWithJsonEscaping(): Unit = {\n    val service: String = \"billing\"\n    val owner: String = \"team \\\"core\\\"\"\n    val multilineDetail: String = \"line one\\nline two\"\n\n    val document: Json = json\"\"\"\n      {\n        \"summary\": \"deploy $service for $owner\",\n        \"details\": \"prefix:$multilineDetail:suffix\"\n      }\n      \"\"\"\n\n    assertThat(document.hcursor.get[String](\"summary\"))\n      .isEqualTo(Right(\"deploy billing for team \\\"core\\\"\"))\n    assertThat(document.hcursor.get[String](\"details\"))\n      .isEqualTo(Right(\"prefix:line one\\nline two:suffix\"))\n  }\n\n","newText":"  @Test\n  def interpolatesMapsWithCustomKeyEncodersAsJsonObjects(): Unit = {\n    val replicasByProject: Map[ProjectKey, Int] = Map(\n      ProjectKey(\"prod\", \"api\") -> 6,\n      ProjectKey(\"prod\", \"worker\") -> 2\n    )\n\n    val document: Json = json\"\"\"\n      {\n        \"replicasByProject\": $replicasByProject\n      }\n      \"\"\"\n\n    assertThat(document.hcursor.get[Map[String, Int]](\"replicasByProject\"))\n      .isEqualTo(Right(Map(\"prod/api\" -> 6, \"prod/worker\" -> 2)))\n  }\n\n"}]}
