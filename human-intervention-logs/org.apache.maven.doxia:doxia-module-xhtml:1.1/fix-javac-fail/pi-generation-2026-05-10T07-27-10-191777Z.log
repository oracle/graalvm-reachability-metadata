      {
          setHeadTitleFlag( true );
  
          writeStartTag( Tag.TITLE );
      }
  
      /**
       * {@inheritDoc}
       * @see javax.swing.text.html.HTML.Tag#TITLE
       */
      public void title_()
      {
          content( getTextBuffer().toString() );
  
          writeEndTag( Tag.TITLE );
  
          resetTextBuffer();
  
      }
  
      /**
       * {@inheritDoc}
       * @see javax.swing.text.html.HTML.Tag#META
       */
      public void author_()
      {
          if ( getTextBuffer().length() > 0 )
          {
