.rawText(\"<span class=\\\"raw\\\">raw html</span>\");\n        sink.paragraph_();\n        sink.section1_();\n        sink.body_();\n        sink.flush();\n\n        String html = writer.toString();\n        assertThat(html)\n                .contains(\"<!DOCTYPE html PUBLIC\")\n                .contains(\"<html xmlns=\\\"http://www.w3.org/1999/xhtml\\\" lang=\\\"en\\\" xml:lang=\\\"en\\\">\")\n                .contains(\"<head>\")\n                .contains(\"<title>User Guide</title>\")\n                .contains(\"<meta name=\\\"author\\\" content=\\\"Jane Author\\\" />\")\n                .contains(\"<meta name=\\\"date\\\" content=\\\"2026-05-09\\\" />\")\n                .contains(\"<meta http-equiv=\\\"Content-Type\\\" content=\\\"text/html; charset=UTF-8\\\"/>\")\n                .contains(\"<body>\")\n                .contains(\"<div class=\\\"section\\\">\")\n                .contains(\"<h2>Overview</h2>\")\n                .contains(\"5 &lt; 6 &amp; &quot;quoted&quot;\")\n                .contains(\"<span class=\\\"raw\\\">raw html</span>\")\n                .contains(\"</body>\")\n                .contains(\"</html>\");\n    }\n\n    @Test\n    void sinkWritesLinksAnchorsInlineMarkupImagesListsTablesAndSpecialWhitespace() {\n        StringWriter writer = new StringWriter();\n        TestXhtmlSink sink = new TestXhtmlSink(writer);\n\n        sink.body();\n        sink.anchor(\"1 intro anchor\");\n        sink.anchor_();\n        sink.paragraph();\n        sink.link(\"https://example.com/search?q=one&lang=en\", attributes(SinkEventAttributes.TARGET, \"_blank\"));\n        sink.text(\"external\");\n        sink.link_();\n        sink.text(\" \");\n        sink.link(\"local-section\");\n        sink.bold();\n        sink.italic();\n        sink.monospaced();\n        sink.text(\"local link\");\n        sink.monospaced_();\n        sink.italic_();\n        sink.bold_();\n        sink.link_();\n        sink.lineBreak();\n        sink.nonBreakingSpace();\n        sink.paragraph_();\n        sink.verbatim(SinkEventAttributeSet.BOXED);\n        sink.text(\"<xml>&value</xml>\");\n        sink.verbatim_();\n        sink.figure(new SinkEventAttributeSet());\n        sink.figureGraphics(\"images/logo.png\", new SinkEventAttributeSet());\n        sink.figureCaption(new SinkEventAttributeSet());\n        sink.text(\"Logo\");\n        sink.figureCaption_();\n        sink.figure_();\n        sink.list();\n        sink.listItem();\n        sink.text(\"bullet\");\n        sink.listItem_();\n        sink.list_();\n        sink.numberedList(Sink.NUMBERING_UPPER_ALPHA);\n        sink.numberedListItem();\n        sink.text(\"numbered\");\n        sink.numberedListItem_();\n        sink.numberedList_();\n        sink.definitionList();\n        sink.definedTerm();\n        sink.text(\"term\");\n        sink.definedTerm_();\n        sink.definition();\n        sink.text(\"definition\");\n        sink.definition_();\n        sink.definitionList_();\n        sink.table();\n        sink.tableCaption();\n        sink.text(\"Metrics\");\n        sink.tableCaption_();\n        sink.tableRows(new int[] {Sink.JUSTIFY_LEFT, Sink.JUSTIFY_CENTER, Sink.JUSTIFY_RIGHT}, true);\n        sink.tableRow();\n        sink.tableHeaderCell(attributes(SinkEventAttributes.WIDTH, \"25%\"));\n        sink.text(\"Name\");\n        sink.tableHeaderCell_();\n        sink.tableCell(attributes(SinkEventAttributes.WIDTH, \"50%\"));\n        sink.text(\"Middle\");\n        sink.tableCell_();\n        sink.tableCell();\n        sink.text(\"Value\");\n        sink.tableCell_();\n        sink.tableRow_();\n        sink.tableRows_();\n        sink.table_();\n        sink.horizontalRule();\n        sink.body_();\n        sink.flush();\n\n        String html = writer.toString();\n        assertThat(html)\n                .contains(\"<a name=\\\"a1_intro_anchor\\\"></a>\")\n                .contains(\"target=\\\"_blank\\\"\")\n                .contains(\"class=\\\"externalLink\\\"\")\n                .contains(\"href=\\\"https://example.com/search?q=one&amp;lang=en\\\"\")\n                .contains(\"href=\\\"#local-section\\\"\")\n                .contains(\"<b><i><tt>local link</tt></i></b>\")\n                .contains(\"<br />\")\n                .contains(\"&#160;\")\n                .contains(\"<div class=\\\"source\\\"><pre>&lt;xml&gt;&amp;value&lt;/xml&gt;</pre>\")\n                .contains(\"<img src=\\\"images/logo.png\\\" alt=\\\"Logo\\\" />\")\n                .contains(\"<ul><li>bullet</li>\")\n                .contains(\"<ol type=\\\"A\\\"><li>numbered</li>\")\n                .contains(\"<dl><dt>term</dt>\")\n                .contains(\"<dd>definition</dd>\")\n                .contains(\"<table class=\\\"bodyTable\\\">\")\n                .contains(\"<caption>Metrics</caption>\")\n                .contains(\"<tbody>\")\n                .contains(\"<tr class=\\\"a\\\">\")\n                .contains(\"<th\")\n                .contains(\"width=\\\"25%\\\"\")\n                .contains(\"align=\\\"left\\\"\")\n                .contains(\">Name</th>\")\n                .contains(\"<td\")\n                .contains(\"width=\\\"50%\\\"\")\n                .contains(\"align=\\\"center\\\"\")\n                .contains(\">Middle</td>\")\n                .contains(\"align=\\\"right\\\"\")\n                .contains(\">Value</td>\")\n                .contains(\"<hr />\");\n    }\n\n    @Test\n    void parserConvertsXhtmlDocumentIntoXhtmlSinkOutput() throws Exception {\n        String xhtml = \"\"\"\n                <html>\n                  <head><title>Parsed Title</title></head>\n                  <body>\n                    <h1>Main &amp; Intro</h1>\n                    <p>Before <strong>bold</strong> and <em>italic</em> text.</p>\n                    <h2>Details</h2>\n                    <p><a href=\"https://example.com\">site</a> and <a name=\"inside\">anchor</a>.</p>\n                    <pre>code &amp; symbols</pre>\n                    <ul><li>first</li><li>second</li></ul>\n                    <ol><li>one</li></ol>\n                    <table><tr><th>head</th><td>cell</td></tr></table>\n                    <img src=\"diagram.png\" alt=\"Diagram\" />\n                    <hr />\n                  </body>\n                </html>\n                \"\"\";\n        StringWriter writer = new StringWriter();\n        XhtmlParser parser = new XhtmlParser();\n\n        parser.parse(new StringReader(xhtml), new TestXhtmlSink(writer));\n\n        String html = writer.toString();\n        assertThat(parser.getType()).isEqualTo(Parser.XML_TYPE);\n        assertThat(html)\n                .contains(\"<title>Parsed Title</title>\")\n                .contains(\"<h2>Main &amp; Intro</h2>\")\n                .contains(\"<p>Before <b>bold</b> and <i>italic</i> text.</p>\")\n                .contains(\"<h3>Details</h3>\")\n                .contains(\"class=\\\"externalLink\\\"\")\n                .contains(\"href=\\\"https://example.com\\\"\")\n                .contains(\">site</a>\")\n                .contains(\"<a name=\\\"inside\\\">anchor</a>\")\n                .contains(\"<div class=\\\"source\\\"><pre>code &amp; symbols</pre>\")\n                .contains(\"<ul><li>first</li>\")\n                .contains(\"<li>second</li>\")\n                .contains(\"<ol type=\\\"1\\\"><li>one</li>\")\n                .contains(\"<table class=\\\"bodyTable\\\"><tr class=\\\"a\\\">\")\n                .contains(\"<td>head</td>\")\n                .contains(\"<td>cell</td>\")\n                .contains(\"<img src=\\\"diagram.png\\\" alt=\\\"Diagram\\\" />\")\n                .contains(\"<hr />\")\n                .contains(\"</div>\")\n                .contains(\"</body>\")\n                .contains(\"</html>\");\n    }\n\n    @Test\n    void parserConvertsAddressElementIntoAuthorMetadata() throws Exception {\n        String xhtml = \"\"\"\n                <html>\n                  <head><title>Project Documentation</title><address>Documentation Team</address></head>\n                  <body><p>content</p></body>\n                </html>\n                \"\"\";\n        StringWriter writer = new StringWriter();\n        XhtmlParser parser = new XhtmlParser();\n\n        parser.parse(new StringReader(xhtml), new TestXhtmlSink(writer));\n\n        String html = writer.toString();\n        assertThat(html)\n                .contains(\"<title>Project Documentation</title>\")\n                .contains(\"<meta name=\\\"author\\\" content=\\\"Documentation Team\\\" />\")\n                .contains(\"<p>content</p>\");\n    }\n\n    @Test\n    void parserClosesNestedSectionsWhenHigherLevelHeadingStarts() throws Exception {\n        String xhtml = \"\"\"\n                <html>\n                  <body>\n                    <h1>First</h1>\n                    <p>one</p>\n                    <h2>Child</h2>\n                    <p>two</p>\n                    <h1>Second</h1>\n                    <p>three</p>\n                  </body>\n                </html>\n                \"\"\";\n        StringWriter writer = new StringWriter();\n        XhtmlParser parser = new XhtmlParser();\n\n        parser.parse(new StringReader(xhtml), new TestXhtmlSink(writer));\n\n        String html = writer.toString().replaceAll(\">\\\\s+<\", \"><\");\n        assertThat(html).contains(\n                \"<div class=\\\"section\\\"><h2>First</h2><p>one</p>\"\n                        + \"<div class=\\\"section\\\"><h3>Child</h3><p>two</p></div></div>\"\n                        + \"<div class=\\\"section\\\"><h2>Second</h2><p>three</p></div>\");\n    }\n\n    @Test\n    void parserReportsMalformedXmlAsParseException() {\n        XhtmlParser parser = new XhtmlParser();\n\n        assertThatThrownBy(() -> parser.parse(new StringReader(\"<html><body><p>unfinished</body></html>\"),\n                new TestXhtmlSink(new StringWriter())))\n                .isInstanceOf(ParseException.class)\n                .hasMessageContaining(\"Error parsing the model\");\n    }\n\n    @Test\n    void factorySiteModuleAndEncodingHelpersProduceXhtmlOutput() throws Exception {\n        XhtmlSiteModule siteModule = new XhtmlSiteModule();\n        XhtmlSinkFactory sinkFactory = new XhtmlSinkFactory();\n        ByteArrayOutputStream outputStream = new ByteArrayOutputStream();\n        Sink sink = sinkFactory.createSink(outputStream, \"UTF-8\", \"fr\");\n\n        sink.head();\n        sink.title();\n        sink.text(\"Factory Output\");\n        sink.title_();\n        sink.head_();\n        sink.body();\n        sink.paragraph();\n        sink.text(\"created by factory <with escaping>\");\n        sink.paragraph_();\n        sink.body_();\n        sink.close();\n\n        String html = outputStream.toString(StandardCharsets.UTF_8);\n        assertThat(siteModule.getSourceDirectory()).isEqualTo(\"xhtml\");\n        assertThat(siteModule.getExtension()).isEqualTo(\"xhtml\");\n        assertThat(siteModule.getParserId()).isEqualTo(\"xhtml\");\n        assertThat(html)\n                .contains(\"lang=\\\"fr\\\"\")\n                .contains(\"xml:lang=\\\"fr\\\"\")\n                .contains(\"<title>Factory Output</title>\")\n                .contains(\"<meta http-equiv=\\\"Content-Type\\\" content=\\\"text/html; charset=UTF-8\\\"/>\")\n                .contains(\"created by factory &lt;with escaping&gt;\");\n        assertThat(TestXhtmlSink.escapeHtml(\"<tag attr=\\\"value\\\">&</tag>\"))\n                .isEqualTo(\"&lt;tag attr=&quot;value&quot;&gt;&amp;&lt;/tag&gt;\");\n        assertThat(TestXhtmlSink.encodeUrl(\"folder/My File.xhtml?x=1&y=\\u00e4\"))\n                .isEqualTo(\"folder/My%20File.xhtml?x=1&y=%c3%a4\");\n        assertThat(TestXhtmlSink.encodeUrl(null)).isNull();\n    }\n\n    private static SinkEventAttributeSet attributes(String name, String value) {\n        SinkEventAttributeSet attributes = new SinkEventAttributeSet();\n        attributes.addAttribute(name, value);\n        return attributes;\n    }\n\n    private static final class TestXhtmlSink extends XhtmlSink {\n        private TestXhtmlSink(Writer writer) {\n            super(writer);\n        }\n\n        private TestXhtmlSink(Writer writer, String encoding, String languageId) {\n            super(writer, encoding, languageId);\n        }\n\n        private static String escapeHtml(String text) {\n            return escapeHTML(text);\n        }\n\n        private static String encodeUrl(String text) {\n            return encodeURL(text);\n        }\n    }\n}\n"}
