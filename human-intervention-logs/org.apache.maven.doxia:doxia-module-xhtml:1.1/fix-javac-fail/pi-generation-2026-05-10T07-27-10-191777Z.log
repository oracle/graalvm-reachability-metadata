              att.addAttribute( Attribute.NAME, "author" );
              att.addAttribute( Attribute.CONTENT, getTextBuffer().toString() );
  
              writeSimpleTag( Tag.META, att );
  
              resetTextBuffer();
          }
      }
  
      /**
       * {@inheritDoc}
       * @see javax.swing.text.html.HTML.Tag#META
       */
      public void date_()
      {
          if ( getTextBuffer().length() > 0 )
          {
