A=Y\",\n    42\t                \"-e\", \"MSSQL_SA_PASSWORD=\" + PASSWORD,\n    43\t                \"mcr.microsoft.com/mssql/server:2022-CU14-ubuntu-22.04\")\n    44\t                .redirectOutput(new File(\"mssql-stdout.txt\"))\n    45\t                .redirectError(new File(\"mssql-stderr.txt\"))\n    46\t                .start();\n    47\t\n    48\t        // Wait until connection can be established\n    49\t        Awaitility.await().atMost(Duration.ofMinutes(1)).ignoreExceptions().until(() -> {\n    50\t            getDataSource().getConnection().close();\n    51\t            return true;\n    52\t        });\n    53\t        System.out.println(\"MSSQL started\");\n    54\t    }\n    55\t\n    56\t    @AfterAll\n    57\t    static void tearDown() {\n    58\t        if (process != null && process.isAlive()) {\n    59\t            System.out.println(\"Shutting down MSSQL\");\n    60\t            process.destroy();\n    61\t        }\n    62\t    }\n    63\t\n    64\t    @Test\n    65\t    void migrate() {\n    66\t        DataSource dataSource = getDataSource();\n    67\t\n    68\t        Configuration configuration = new FluentConfiguration()\n    69\t                .dataSource(dataSource)\n    70\t                .encoding(StandardCharsets.UTF_8)\n    71\t                .resourceProvider(new FixedResourceProvider());\n    72\t\n    73\t        Flyway flyway = new Flyway(configuration);\n    74\t        MigrateResult migration = flyway.migrate();\n    75\t\n    76\t        assertThat(migration.success).isTrue();\n    77\t        assertThat(migration.migrationsExecuted).isEqualTo(2);\n    78\t    }\n    79\t\n    80\t    private static DataSource getDataSource() {\n    81\t        SQLServerDataSource dataSource = new SQLServerDataSource();\n    82\t        dataSource.setURL(JDBC_URL);\n    83\t        dataSource.setUser(USERNAME);\n    84\t        dataSource.setPassword(PASSWORD);\n    85\t        return dataSource;\n    86\t    }\n    87\t\n    88\t}\n","e