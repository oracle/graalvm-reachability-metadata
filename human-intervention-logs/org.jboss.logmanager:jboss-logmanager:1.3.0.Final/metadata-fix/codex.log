    38\t        String formatted = formatWithTccl(blockingTccl, newFailure(className));\n    39\t\n    40\t        assertThat(formatted).contains(\"\\tat \" + className + \".invoke\");\n    41\t    }\n    42\t\n    43\t    @Test\n    44\t    void extendedExceptionFormattingFallsBackThroughClassLookupStrategiesForUnknownFrameClass() {\n    45\t        String className = \"org.jboss.logmanager.coverage.DoesNotExist\";\n    46\t\n    47\t        String formatted = formatWithTccl(null, newFailure(className));\n    48\t\n    49\t        assertThat(formatted).contains(\"\\tat \" + className + \".invoke\");\n    50\t    }\n    51\t\n    52\t    private static String formatWithTccl(final ClassLoader contextClassLoader, final Throwable thrown) {\n    53\t        ClassLoader originalTccl = Thread.currentThread().getContextClassLoader();\n    54\t        try {\n    55\t            Thread.currentThread().setContextClassLoader(contextClassLoader);\n    56\t            PatternFormatter formatter = new PatternFormatter(\"%E\");\n    57\t            ExtLogRecord record = new ExtLogRecord(\n    58\t                    Level.SEVERE,\n    59\t                    \"coverage\",\n    60\t                    FormattersAnonymous12Test.class.getName()\n    61\t            );\n    62\t            record.setThrown(thrown);\n    63\t            return formatter.format(record);\n    64\t        } finally {\n    65\t            Thread.currentThread().setContextClassLoader(originalTccl);\n    66\t        }\n    67\t    }\n    68\t\n    69\t    private static IllegalStateException newFailure(final String className) {\n    70\t        IllegalStateException failure = new IllegalStateException(\"boom\");\n    71\t        failure.setStackTrace(new StackTraceElement[] {\n    72\t                new StackTraceElement(className, \"invoke\", \"GeneratedFrame.java\", 17)\n    73\t        });\n    74\t        return failure;\n    75\t    }\n    76\t\n    77\t    private static boolean isNativeImageRuntime() {\n    78\t        return \"runtime\".equals(System.getProperty(\"org.graalvm.nativeimage.imagecode\"));\n    79\t    }\n    80\t\n    81\t    private static final class BlockingClassLoader extends ClassLoader {\n    82\t        private final String blockedClassName;\n    83\t\n    84\t        private BlockingClassLoader(final String blockedClassName) {\n    85\t            super(FormattersAnonymous12Test.class.getClassLoader());\n    86\t            this.blockedClassName = blockedClassName;\n    87\t        }\n    88\t\n    89\t        @Override\n    90\t        protected Class<?> loadClass(final String name, final boolean resolve) throws ClassNotFoundException {\n    91\t            if (blockedClassName.equals(name)) {\n    92\t                throw new ClassNotFoundException(name);\n    93\t            }\n    94\t            return super.loadClass(name, resolve);\n    95\t        }\n    96\t    }\n    97\t}\n","exit_code":0,"status":"completed"}}
