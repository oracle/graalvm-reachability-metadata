/jsp-api/2.0/src/test/java/javax_servlet/jsp_api/TagSupportTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage javax_servlet.jsp_api;\n\nimport java.util.Enumeration;\n\nimport javax.servlet.jsp.tagext.IterationTag;\nimport javax.servlet.jsp.tagext.Tag;\nimport javax.servlet.jsp.tagext.TagSupport;\n\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class TagSupportTest {\n    @Test\n    void findAncestorWithClassUsesClassicTagHierarchy() {\n        TagSupport child = new TagSupport();\n        TagSupport parent = new TagSupport();\n        TagSupport grandparent = new TagSupport();\n        child.setParent(parent);\n        parent.setParent(grandparent);\n\n        Tag ancestor = TagSupport.findAncestorWithClass(child, TagSupport.class);\n\n        assertThat(ancestor).isSameAs(parent);\n    }\n\n    @Test\n    void findAncestorWithClassAcceptsTagInterface() {\n        TagSupport child = new TagSupport();\n        TagSupport parent = new TagSupport();\n        child.setParent(parent);\n\n        Tag ancestor = TagSupport.findAncestorWithClass(child, IterationTag.class);\n\n        assertThat(ancestor).isSameAs(parent);\n    }\n\n    @Test\n    void releaseClearsManagedState() {\n        TagSupport tag = new TagSupport();\n        tag.setId(\"tag-id\");\n        tag.setParent(new TagSupport());\n        tag.setValue(\"name\", \"value\");\n\n        tag.release();\n\n        assertThat(tag.getId()).isNull();\n        assertThat(tag.getParent()).isNull();\n        assertThat(tag.getValue(\"name\")).isNull();\n        assertThat(tag.getValues()).isNull();\n    }\n\n    @Test\n    void storesAndRemovesNamedValues() {\n        TagSupport tag = new TagSupport();\n        tag.setValue(\"first\", \"one\");\n        tag.setValue(\"second\", \"two\");\n\n        Enumeration keys = tag.getValues();\n\n        assertThat(tag.getValue(\"first\")).isEqualTo(\"one\");\n        assertThat(keys).toIterable().containsExactlyInAnyOrder(\"first\", \"second\");\n\n        tag.removeValue(\"first\");\n\n        assertThat(tag.getValue(\"first\")).isNull();\n        assertThat(tag.getValue(\"second\")).isEqualTo(\"two\");\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1905, "output": 1048, "cacheRead": 14848, "cacheWrite": 0, "totalTokens": 17801, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777979672941, "responseId": "resp_05ffc76838a427720169f9d1194d1081a28d8b1b6b8f1fd615"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_dFDGweXdTLJav9aURUrSTeWI|fc_05ffc76838a427720169f9d1202cd881a28e3cc2f045382faf", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2203 bytes to tests/src/javax.servlet/jsp-api/2.0/src/test/java/javax_servlet/jsp_api/TagSupportTest.java"}], "isError": false, "timestamp": 1777979683989}]}
