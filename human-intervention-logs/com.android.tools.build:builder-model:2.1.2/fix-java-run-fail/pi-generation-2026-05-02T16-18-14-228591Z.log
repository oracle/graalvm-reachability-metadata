          }
  
          private static Map<String, ClassField> singletonClassFieldMap(ClassField classField) {
              Map<String, ClassField> fields = new LinkedHashMap<String, ClassField>();
              fields.put(classField.getName(), classField);
              return fields;
          }
      }
  
