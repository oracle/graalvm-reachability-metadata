       */
      public BasicScheme() {
          super();
          this.complete = false;
      }
  
      /**
       * Constructor for the basic authetication scheme.
       * 
       * @param challenge authentication challenge
       * 
       * @throws MalformedChallengeException is thrown if the authentication challenge
