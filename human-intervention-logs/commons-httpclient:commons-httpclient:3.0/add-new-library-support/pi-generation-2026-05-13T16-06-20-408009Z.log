              Set<String> libraryClasses,
              Map<String, Set<Integer>> coveredLinesBySource,
              Map<String, ParsedDynamicAccessCallSite> callSitesByKey
      ) {
          Matcher matcher = DYNAMIC_ACCESS_REPORT.matcher(path.getFileName().toString());
          if (!matcher.matches()) {
              return;
          }
  
