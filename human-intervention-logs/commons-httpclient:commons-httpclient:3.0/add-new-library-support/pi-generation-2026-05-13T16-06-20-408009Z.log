              headers.append((char) current);
              if ((matched == 0 && current == '\r')
                      || (matched == 1 && current == '\n')
                      || (matched == 2 && previous == '\n' && current == '\r')
                      || (matched == 3 && current == '\n')) {
                  matched++;
              } else {
                  matched = current == '\r' ? 1 : 0;
              }
          }
          return headers.toString();
      }
  
