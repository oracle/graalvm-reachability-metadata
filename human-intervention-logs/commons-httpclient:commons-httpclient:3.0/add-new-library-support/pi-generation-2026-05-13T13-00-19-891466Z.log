terByName(null))\n                .withMessage(\"Name may not be null\");\n    }\n\n    private static HeaderElementClassLoader newHeaderElementClassLoader() {\n        URL location = HeaderElement.class.getProtectionDomain().getCodeSource().getLocation();\n        return new HeaderElementClassLoader(new URL[] {location}, HeaderElementTest.class.getClassLoader());\n    }\n\n    private static final class HeaderElementClassLoader extends URLClassLoader {\n        private HeaderElementClassLoader(URL[] urls, ClassLoader parent) {\n            super(urls, parent);\n        }\n\n        @Override\n        protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {\n            synchronized (getClassLoadingLock(name)) {\n                if (HEADER_ELEMENT_CLASS_NAME.equals(name)) {\n                    Class<?> loadedClass = findLoadedClass(name);\n                    if (loadedClass == null) {\n                        loadedClass = findClass(name);\n                    }\n                    if (resolve) {\n                        resolveClass(loadedClass);\n                    }\n                    return loadedClass;\n                }\n                return super.loadClass(name, resolve);\n            }\n        }\n    }\n}\n", "newText": "    void nullInputsReturnEmptyElementsAndRejectNullParameterLookup() {\n        HeaderElement element = new HeaderElement();\n\n        assertThat(HeaderElement.parseElements((String) null)).isEmpty();\n        assertThat(HeaderElement.parseElements((char[]) null)).isEmpty();\n        assertThatIllegalArgumentException()\n                .isThrownBy(() -> element.getParameterByName(null))\n                .withMessage(\"Name may not be null\");\n    }\n}\n"}]}
