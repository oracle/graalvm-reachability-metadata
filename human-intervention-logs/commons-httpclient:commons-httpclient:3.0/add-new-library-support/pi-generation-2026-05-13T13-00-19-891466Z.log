HeaderElement();\n\n        assertThat(HeaderElement.parseElements((String) null)).isEmpty();\n        assertThat(HeaderElement.parseElements((char[]) null)).isEmpty();\n        assertThatIllegalArgumentException()\n                .isThrownBy(() -> element.getParameterByName(null))\n                .withMessage(\"Name may not be null\");\n    }\n}\n"}]}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 936, "output": 1223, "cacheRead": 26112, "cacheWrite": 0, "totalTokens": 28271, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778677497693, "responseId": "resp_0ab5db23f215fbae016a0476facd308192ab364f40a6c9aa95"}}
