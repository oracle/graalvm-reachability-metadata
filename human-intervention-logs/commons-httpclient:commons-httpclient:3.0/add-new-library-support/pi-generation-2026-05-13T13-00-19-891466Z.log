[tool-call] delta {"path":"tests/src/commons-httpclient/commons-httpclient/3.0/src/test/java/commons_httpclient/commons_httpclient/HeaderElementTest.java","edits":[{"oldText":"import java.net.URL;\nimport java.net.URLClassLoader;\n\nimport org.apache.commons.httpclient.HeaderElement;\nimport org.apache.commons.httpclient.NameValuePair;\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\n","newText":"import org.apache.commons.httpclient.HeaderElement;\nimport org.apache.commons.httpclient.NameValuePair;\nimport org.junit.jupiter.api.Test;\n"},{"oldText":"public class HeaderElementTest {\n    private static final String HEADER_ELEMENT_CLASS_NAME = \"org.apache.commons.httpclient.HeaderElement\";\n\n    @Test\n    void freshClassLoaderInitializationRunsLegacyClassHelper() throws Exception {\n        try (HeaderElementClassLoader classLoader = newHeaderElementClassLoader()) {\n            Class<?> headerElementClass = Class.forName(HEADER_ELEMENT_CLASS_NAME, true, classLoader);\n\n            assertThat(headerElementClass.getName()).isEqualTo(HEADER_ELEMENT_CLASS_NAME);\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    @Test\n    void parseElementsSplitsHeaderValueAndPreservesQuotedComma() {\n","newText":"public class HeaderElementTest {\n    @Test\n    void parseElementsSplitsHeaderValueAndPreservesQuotedComma() {\n"},{"oldText":"    void nullInputsReturnEmptyElementsAndRejectNullParameterLookup() {\n        HeaderElement element = new HeaderElement();\n\n        assertThat(HeaderElement.parseElements((String) null)).isEmpty();\n        assertThat(HeaderElement.parseElements((char[]) null)).isEmpty();\n        assertThatIllegalArgumentException()\n                .isThrownBy(() -> element.getParameterByName(null))\n                .withMessage(\"Name may not be null\");\n    }\n\n    private static HeaderElementClassLoader newHeaderElementClassLoader() {\n        URL location = HeaderElement.class.getProtectionDomain().getCodeSource().getLocation();\n        return new HeaderElementClassLoader(new URL[] {location}, HeaderElementTest.class.getClassLoader());\n    }\n\n    private static final class HeaderElementClassLoader extends URLClassLoader {\n        private HeaderElementClassLoader(URL[] urls, ClassLoader parent) {\n            super(urls, parent);\n        }\n\n        @Override\n        protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {\n            synchronized (getClassLoadingLock(name)) {\n                if (HEADER_ELEMENT_CLASS_NAME.equals(name)) {\n                    Class<?> loadedClass = findLoadedClass(name);\n                    if (loadedClass == null) {\n                        loadedClass = findClass(name);\n                    }\n                    if (resolve) {\n                        resolveClass(loadedClass);\n                    }\n                    return loadedClass;\n                }\n                return super.loadClass(name, resolve);\n            }\n        }\n    }\n}\n","newText":"    void nullInputsReturnEmptyElementsAndRejectNullParameterLookup() {\n        HeaderElement element = new HeaderElement();\n\n        assertThat(HeaderElement.parseElements((String) null)).isEmpty();\n        assertThat(HeaderElement.parseElements((char[]) null)).isEmpty();\n        assertThatIllegalArgumentException()\n                .isThrownBy(() -> element.getParameterByName(null))\n                .withMessage(\"Name may not be null\");\n    }\n}\n"}]}
