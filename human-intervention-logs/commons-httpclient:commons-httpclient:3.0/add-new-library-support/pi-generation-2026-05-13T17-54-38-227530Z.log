nectionTest.class.getClassLoader());\n    }\n\n    private static String serveSingleResponse(\n"}, {"oldText": "    private static String readFully(InputStream input) throws Exception {\n        return new String(input.readAllBytes(), StandardCharsets.ISO_8859_1);\n    }\n}\n", "newText": "    private static String readFully(InputStream input) throws Exception {\n        return new String(input.readAllBytes(), StandardCharsets.ISO_8859_1);\n    }\n\n    private static final class HttpURLConnectionClassLoader extends URLClassLoader {\n        private HttpURLConnectionClassLoader(URL[] urls, ClassLoader parent) {\n            super(urls, parent);\n        }\n\n        @Override\n        protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {\n            synchronized (getClassLoadingLock(name)) {\n                if (HTTP_URL_CONNECTION_CLASS_NAME.equals(name)) {\n                    Class<?> loadedClass = findLoadedClass(name);\n                    if (loadedClass == null) {\n                        loadedClass = findClass(name);\n                    }\n                    if (resolve) {\n                        resolveClass(loadedClass);\n                    }\n                    return loadedClass;\n                }\n                return super.loadClass(name, resolve);\n            }\n        }\n    }\n}\n"}]}
