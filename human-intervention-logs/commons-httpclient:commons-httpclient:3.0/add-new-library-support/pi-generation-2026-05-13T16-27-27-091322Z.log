      /** Content type header */
      protected static final String CONTENT_TRANSFER_ENCODING = "Content-Transfer-Encoding: ";
  
      /** Content type header as a byte array */
      protected static final byte[] CONTENT_TRANSFER_ENCODING_BYTES = 
