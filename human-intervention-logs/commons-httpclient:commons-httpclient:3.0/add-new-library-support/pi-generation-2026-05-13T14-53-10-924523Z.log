-> cookieSpec.parseAttribute(new NameValuePair(\"max-age\", \"later\"), cookie))\n                .isInstanceOf(MalformedCookieException.class)\n                .hasMessageContaining(\"Invalid max-age attribute\");\n    }\n}\n"}
