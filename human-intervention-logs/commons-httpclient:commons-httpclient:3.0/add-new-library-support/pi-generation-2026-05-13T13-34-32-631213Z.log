inal String HTTP_PARSER_RESOURCE_NAME = \"org/apache/commons/httpclient/HttpParser.class\";\n\n"}, {"oldText": "    @Test\n    void parseHeadersRejectsLineWithoutColon() {\n        ByteArrayInputStream input = new ByteArrayInputStream(\"Invalid header\\r\\n\\r\\n\"\n                .getBytes(StandardCharsets.US_ASCII));\n\n        assertThatExceptionOfType(ProtocolException.class)\n                .isThrownBy(() -> HttpParser.parseHeaders(input, StandardCharsets.US_ASCII.name()))\n                .withMessage(\"Unable to parse header: Invalid header\");\n    }\n}\n", "newText": "    @Test\n    void parseHeadersRejectsLineWithoutColon() {\n        ByteArrayInputStream input = new ByteArrayInputStream(\"Invalid header\\r\\n\\r\\n\"\n                .getBytes(StandardCharsets.US_ASCII));\n\n        assertThatExceptionOfType(ProtocolException.class)\n                .isThrownBy(() -> HttpParser.parseHeaders(input, StandardCharsets.US_ASCII.name()))\n                .withMessage(\"Unable to parse header: Invalid header\");\n    }\n\n    @Test\n    void isolatedClassInitializationCreatesLoggerForHttpParserClass() throws Exception {\n        ClassLoader parentLoader = HttpParser.class.getClassLoader();\n        ClassLoader isolatedHttpParserLoader = new IsolatedHttpParserLoader(parentLoader);\n\n        try {\n            Class<?> isolatedHttpParser = Class.forName(\n                    HTTP_PARSER_CLASS_NAME,\n                    true,\n                    isolatedHttpParserLoader);\n\n            assertThat(isolatedHttpParser.getName()).isEqualTo(HTTP_PARSER_CLASS_NAME);\n            assertThat(isolatedHttpParser.getClassLoader()).isSameAs(isolatedHttpParserLoader);\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    private static final class IsolatedHttpParserLoader extends ClassLoader {\n        private IsolatedHttpParserLoader(ClassLoader parent) {\n            super(parent);\n        }\n\n        @Override\n        protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {\n            synchronized (getClassLoadingLock(name)) {\n                Class<?> loadedClass = findLoadedClass(name);\n                if (loadedClass == null) {\n                    if (HTTP_PARSER_CLASS_NAME.equals(name)) {\n                        loadedClass = findClass(name);\n                    } else {\n                        loadedClass = super.loadClass(name, false);\n                    }\n                }\n                if (resolve) {\n                    resolveClass(loadedClass);\n                }\n                return loadedClass;\n            }\n        }\n\n        @Override\n        protected Class<?> findClass(String name) throws ClassNotFoundException {\n            if (!HTTP_PARSER_CLASS_NAME.equals(name)) {\n                throw new ClassNotFoundException(name);\n            }\n\n            byte[] classBytes = readHttpParserClassBytes();\n            return defineClass(name, classBytes, 0, classBytes.length);\n        }\n\n        private byte[] readHttpParserClassBytes() throws ClassNotFoundException {\n            ClassLoader parentLoader = getParent();\n            try (InputStream input = parentLoader.getResourceAsStream(HTTP_PARSER_RESOURCE_NAME)) {\n                if (input == null) {\n                    throw new ClassNotFoundException(HTTP_PARSER_CLASS_NAME);\n                }\n                return input.readAllBytes();\n            } catch (IOException exception) {\n                ClassNotFoundException classNotFound = new ClassNotFoundException(\n                        HTTP_PARSER_CLASS_NAME);\n                classNotFound.initCause(exception);\n                throw classNotFound;\n            }\n        }\n    }\n}\n"}]}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1170, "output": 1656, "cacheRead": 33792, "cach