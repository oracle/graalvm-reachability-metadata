  package commons_httpclient.commons_httpclient;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.net.URL;
  import java.net.URLClassLoader;
  
  import org.apache.commons.httpclient.HttpClient;
  import org.apache.commons.httpclient.SimpleHttpConnectionManager;
  import org.apache.commons.httpclient.params.HttpClientParams;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  
  public class HttpClientTest {
      private static final String HTTP_CLIENT_CLASS_NAME = "org.apache.commons.httpclient.HttpClient";
  
      @Test
      void freshClassLoaderInitializationRunsLegacyClassHelper() throws Exception {
          try (HttpClientClassLoader classLoader = newHttpClientClassLoader()) {
              Class<?> clientClass = Class.forName(HTTP_CLIENT_CLASS_NAME, true, classLoader);
  
              assertThat(clientClass.getName()).isEqualTo(HTTP_CLIENT_CLASS_NAME);
              assertThat(clientClass.getClassLoader()).isSameAs(classLoader);
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
      }
  
      @Test
      void constructorInstantiatesConfiguredConnectionManagerClass() {
          HttpClientParams params = new HttpClientParams();
          params.setConnectionManagerClass(SimpleHttpConnectionManager.class);
  
          HttpClient client = new HttpClient(params);
  
          assertThat(client.getParams()).isSameAs(params);
          assertThat(client.getHttpConnectionManager()).isInstanceOf(SimpleHttpConnectionManager.class);
      }
  
      private static HttpClientClassLoader newHttpClientClassLoader() {
          URL location = HttpClient.class.getProtectionDomain().getCodeSource().getLocation();
          return new HttpClientClassLoader(new URL[] {location}, HttpClientTest.class.getClassLoader());
      }
  
      private static final class HttpClientClassLoader extends URLClassLoader {
          private HttpClientClassLoader(URL[] urls, ClassLoader parent) {
              super(urls, parent);
          }
  
          @Override
          protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {
              synchronized (getClassLoadingLock(name)) {
                  if (HTTP_CLIENT_CLASS_NAME.equals(name)) {
                      Class<?> loadedClass = findLoadedClass(name);
                      if (loadedClass == null) {
                          loadedClass = findClass(name);
                      }
                      if (resolve) {
                          resolveClass(loadedClass);
                      }
                      return loadedClass;
                  }
                  return super.loadClass(name, resolve);
              }
          }
      }
  }
