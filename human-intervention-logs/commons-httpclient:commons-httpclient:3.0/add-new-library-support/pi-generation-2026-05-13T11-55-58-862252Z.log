ructorInstantiatesConfiguredConnectionManagerClass() {"}, {"oldText": "        assertThat(client.getParams()).isSameAs(params);\n        assertThat(client.getHttpConnectionManager()).isInstanceOf(SimpleHttpConnectionManager.class);\n    }\n\n    private static HttpClientClassLoader newHttpClientClassLoader() {\n        URL location = HttpClient.class.getProtectionDomain().getCodeSource().getLocation();\n        return new HttpClientClassLoader(new URL[] {location}, HttpClientTest.class.getClassLoader());\n    }\n\n    private static final class HttpClientClassLoader extends URLClassLoader {\n        private HttpClientClassLoader(URL[] urls, ClassLoader parent) {\n            super(urls, parent);\n        }\n\n        @Override\n        protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {\n            synchronized (getClassLoadingLock(name)) {\n                if (HTTP_CLIENT_CLASS_NAME.equals(name)) {\n                    Class<?> loadedClass = findLoadedClass(name);\n                    if (loadedClass == null) {\n                        loadedClass = findClass(name);\n                    }\n                    if (resolve) {\n                        resolveClass(loadedClass);\n                    }\n                    return loadedClass;\n                }\n                return super.loadClass(name, resolve);\n            }\n        }\n    }\n}\n", "newText": "        assertThat(client.getParams()).isSameAs(params);\n        assertThat(client.getHttpConnectionManager()).isInstanceOf(SimpleHttpConnectionManager.class);\n    }\n}\n"}]}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 22211, "output": 2072, "cacheRead": 34304, "cacheWrite": 0, "totalTokens": 58587, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778673608325, "responseId": "resp_0397440abcf48d83016a0467c93d3881a1995f7049845f674e"}}
