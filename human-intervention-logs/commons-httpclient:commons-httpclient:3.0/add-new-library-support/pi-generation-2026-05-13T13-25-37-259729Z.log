                  if (isRedirectNeeded(method)) {
                      if (processRedirectResponse(method)) {
                          retry = true;
                          ++redirectCount;
                          if (redirectCount >= maxRedirects) {
                              LOG.error("Narrowly avoided an infinite loop in execute");
                              throw new RedirectException("Maximum redirects ("
