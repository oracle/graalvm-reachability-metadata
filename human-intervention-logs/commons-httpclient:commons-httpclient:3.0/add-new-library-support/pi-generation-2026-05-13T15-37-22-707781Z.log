              buildArgs.add('--initialize-at-run-time=org.apache.commons.httpclient.methods.InputStreamRequestEntity')
              buildArgs.add('--initialize-at-run-time=org.apache.commons.httpclient.HttpState')
              buildArgs.add('--initialize-at-run-time=org.apache.commons.httpclient.cookie.CookieSpecBase')
              buildArgs.add('--initialize-at-run-time=org.apache.commons.httpclient.MultiThreadedHttpConnectionManager')
              buildArgs.add('--initialize-at-run-time=org.apache.commons.httpclient.SimpleHttpConnectionManager')
          }
      }
      agent {
          defaultMode = "conditional"
          modes {
              conditional {
                  userCodeFilterPath = "user-code-filter.json"
              }
          }
      }
  }
