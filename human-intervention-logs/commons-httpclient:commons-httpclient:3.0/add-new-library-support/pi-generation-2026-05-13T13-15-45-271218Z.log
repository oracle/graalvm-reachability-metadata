  plugins {
      id "org.graalvm.internal.tck"
  }
  
  String libraryVersion = tck.testedLibraryVersion.get()
  
  dependencies {
      testImplementation "commons-httpclient:commons-httpclient:$libraryVersion"
      testImplementation 'org.assertj:assertj-core:3.22.0'
  }
  
  graalvmNative {
      binaries {
          all {
              buildArgs.add('--initialize-at-run-time=org.apache.commons.httpclient.HeaderElement')
          }
      }
      agent {
          defaultMode = "conditional"
          modes {
              conditional {
                  userCodeFilterPath = "user-code-filter.json"
              }
          }
      }
  }
