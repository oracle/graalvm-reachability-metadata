        assertThat(method.getName()).isEqualTo(\"SAMPLE\");\n        assertThat(method.getPath()).isEqualTo(\"/a%20path\");\n        assertThat(method.getQueryString()).isEqualTo(\"name=value\");\n        assertThat(method.getURI().toString())\n                .isEqualTo(\"http://example.com:8080/a%20path?name=value\");\n    }\n\n    private static final class SampleHttpMethod extends HttpMethodBase {\n        private SampleHttpMethod(String uri) {\n            super(uri);\n        }\n\n        @Override\n        public String getName() {\n            return \"SAMPLE\";\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1166, "output": 1128, "cacheRead": 19968, "cacheWrite": 0, "totalTokens": 22262, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778678115369, "responseId": "resp_020c5848857c36ed016a04796439dc8196a9fe659b3e184096"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_7937OC8wUM9viAkEwLrE8Awd|fc_020c5848857c36ed016a04796e95cc81968dd310b392ba974e", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2103 bytes to tests/src/commons-httpclient/commons-httpclient/3.0/src/test/java/commons_httpclient/commons_httpclient/HttpMethodBaseTest.java"}], "isError": false, "timestamp": 1778678128730}]}
