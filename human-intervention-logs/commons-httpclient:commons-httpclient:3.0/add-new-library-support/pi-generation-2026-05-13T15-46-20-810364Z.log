          LOG.trace("enter MultipartPostMethod.writeRequestBody(HttpState state, "
              + "HttpConnection conn)");
          OutputStream out = conn.getRequestOutputStream();
          Part.sendParts(out, getParts());
          return true;
      }
  
      /**
