   * You should have received a copy of the CC0 legalcode along with this
   * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.
   */
  plugins {
      id "org.graalvm.internal.tck"
  }
  
  String libraryVersion = tck.testedLibraryVersion.get()
  
  dependencies {
      testImplementation "commons-httpclient:commons-httpclient:$libraryVersion"
      testImplementation 'org.assertj:assertj-core:3.22.0'
  }
  
  graalvmNative {
      binaries {
          all {
              buildArgs.add('--initialize-at-run-time=org.apache.commons.httpclient.auth.BasicScheme')
              buildArgs.add('--initialize-at-run-time=org.apache.commons.httpclient.auth.DigestScheme')
              buildArgs.add('--initialize-at-run-time=org.apache.commons.httpclient.auth.NTLMScheme')
              buildArgs.add('--initialize-at-run-time=org.apache.commons.httpclient.HeaderElement')
              buildArgs.add('--initialize-at-run-time=org.apache.commons.httpclient.HttpMethodBase')
              buildArgs.add('--initialize-at-run-time=org.apache.commons.httpclient.HttpMethodDirector')
              buildArgs.add('--initialize-at-run-time=org.apache.commons.httpclient.methods.ExpectContinueMethod')
              buildArgs.add('--initialize-at-run-time=org.apache.commons.httpclient.methods.multipart.FilePart')
              buildArgs.add('--initialize-at-run-time=org.apache.commons.httpclient.methods.multipart.StringPart')
              buildArgs.add('--initialize-at-run-time=org.apache.commons.httpclient.methods.GetMethod')
              buildArgs.add('--initialize-at-run-time=org.apache.commons.httpclient.methods.HeadMethod')
              buildArgs.add('--initialize-at-run-time=org.apache.commons.httpclient.methods.InputStreamRequestEntity')
              buildArgs.add('--initialize-at-run-time=org.apache.commons.httpclient.methods.MultipartPostMethod')
              buildArgs.add('--initialize-at-run-time=org.apache.commons.httpclient.methods.OptionsMethod')
              buildArgs.add('--initialize-at-run-time=org.apache.commons.httpclient.methods.PostMethod')
              buildArgs.add('--initialize-at-run-time=org.apache.commons.httpclient.util.EncodingUtil')
              buildArgs.add('--initialize-at-run-time=org.apache.commons.httpclient.HttpState')
              buildArgs.add('--initialize-at-run-time=org.apache.commons.httpclient.cookie.CookieSpecBase')
              buildArgs.add('--initialize-at-run-time=org.apache.commons.httpclient.params.DefaultHttpParamsFactory')
              buildArgs.add('--initialize-at-run-time=org.apache.commons.httpclient.MultiThreadedHttpConnectionManager')
              buildArgs.add('--initialize-at-run-time=org.apache.commons.httpclient.SimpleHttpConnectionManager')
              buildArgs.add('--initialize-at-run-time=org.apache.commons.httpclient.protocol.DefaultProtocolSocketFactory')
              buildArgs.add('--initialize-at-run-time=org.apache.commons.httpclient.protocol.SSLProtocolSocketFactory')
          }
      }
      agent {
          defaultMode = "conditional"
          modes {
              conditional {
                  userCodeFilterPath = "user-code-filter.json"
              }
          }
      }
  }
