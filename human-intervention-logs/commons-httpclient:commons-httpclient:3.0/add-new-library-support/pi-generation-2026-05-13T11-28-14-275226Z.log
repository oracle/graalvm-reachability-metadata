/LibraryStatsSupportTests.java:420:                tempDir.resolve(\"dynamic-access-missing\"),\n./tests/src/org.springframework/spring-jcl/5.3.15/src/test/java/org_springframework/spring_jcl/LogAdapterTest.java:16:    private static final String LOGGER_NAME = \"spring-jcl.dynamic-access\";\n./forge/forge_metadata.py:2413:    \"\"\"Load dynamic-access coverage from the stored run metrics stats block.\"\"\"\n./forge/forge_metadata.py:2443:    \"\"\"Resolve the dynamic-access coverage report path for a new-library issue.\"\"\"\n./forge/forge_metadata.py:2449:        \"dynamic-access\",\n./forge/forge_metadata.py:2450:        \"dynamic-access-coverage.json\",\n./forge/forge_metadata.py:2455:    \"\"\"Load dynamic-access coverage directly from the generated report as a fallback.\"\"\"\n./forge/forge_metadata.py:2585:        \"Analyze the generated tests, metadata, stats, and dynamic-access report in this repository. \"\n./forge/forge_metadata.py:2589:        \"- Explain briefly why dynamic-access coverage is missing or still very low.\\n\"\n./forge/forge_metadata.py:2608:        f\"Automation completed for `{claimed_issue.issue_coordinates}`, but dynamic-access coverage remains \"\n./forge/forge_metadata.py:2610:        \"This suggests the generated tests are not exercising the required dynamic-access paths well enough.\\n\\n\"\n./forge/forge_metadata.py:2612:        \"- Inspect the generated tests and compare them with the dynamic-access report to find uncovered call sites.\\n\"\n./forge/forge_metadata.py:3379:            pipeline_argv.append(\"--keep-tests-without-dynamic-access\")\n./forge/forge_metadata.py:5541:        \"--keep-tests-without-dynamic-access\",\n./forge/forge_metadata.py:5544:            \"Forwarded to the new-library pipeline. Keeps generated tests for dynamic-access \"\n./forge/forge_metadata.py:5545:            \"strategies even when no dynamic-access coverage is added.\"\n./forge/utility_scripts/metrics_writer.py:78:    \"\"\"Return True when the 