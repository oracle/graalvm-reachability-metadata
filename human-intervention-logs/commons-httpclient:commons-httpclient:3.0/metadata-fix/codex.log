tatic boolean isUnsupportedAotClassLoadingFailure(Throwable throwable) {\n    38\t        Throwable current = throwable;\n    39\t        while (current != null) {\n    40\t            if (current instanceof ClassNotFoundException\n    41\t                    && containsAotClassLoadingStack(current.getStackTrace())) {\n    42\t                return true;\n    43\t            }\n    44\t            current = current.getCause();\n    45\t        }\n    46\t        return false;\n    47\t    }\n    48\t\n    49\t    private static boolean containsAotClassLoadingStack(StackTraceElement[] stackTrace) {\n    50\t        for (StackTraceElement element : stackTrace) {\n    51\t            String className = element.getClassName();\n    52\t            if (\"com.oracle.svm.core.hub.registry.AOTClassRegistry\".equals(className)\n    53\t                    || \"com.oracle.svm.core.hub.registry.ClassRegistries\".equals(className)\n    54\t                    || \"java.net.URLClassLoader\".equals(className)) {\n    55\t                return true;\n    56\t            }\n    57\t        }\n    58\t        return false;\n    59\t    }\n    60\t}\n","exit_code":0,"status":"completed"}}
