Class<?>) classLookup.invoke(STRING_PART_CLASS_NAME);\n    76\t        Class<?> resolvedStringClass = (Class<?>) classLookup.invoke(\"java.lang.String\");\n    77\t\n    78\t        assertThat(resolvedStringPartClass).isSameAs(StringPart.class);\n    79\t        assertThat(resolvedStringClass).isSameAs(String.class);\n    80\t    }\n    81\t\n    82\t    @Test\n    83\t    @Order(4)\n    84\t    void legacyClassLiteralHelperWrapsMissingClassFailures() throws Throwable {\n    85\t        MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(\n    86\t                StringPart.class,\n    87\t                MethodHandles.lookup());\n    88\t        MethodHandle classLookup = lookup.findStatic(\n    89\t                StringPart.class,\n    90\t                \"class$\",\n    91\t                MethodType.methodType(Class.class, String.class));\n    92\t\n    93\t        assertThatThrownBy(() -> classLookup.invoke(\"example.missing.StringPart\"))\n    94\t                .isInstanceOf(NoClassDefFoundError.class)\n    95\t                .hasMessageContaining(\"example.missing.StringPart\");\n    96\t    }\n    97\t\n    98\t    @Test\n    99\t    @Order(5)\n   100\t    void freshClassLoaderInitializationRunsLegacyClassHelper() throws Exception {\n   101\t        try (StringPartClassLoader classLoader = newStringPartClassLoader()) {\n   102\t            Class<?> partClass = Class.forName(\n   103\t                    STRING_PART_CLASS_NAME,\n   104\t                    true,\n   105\t                    classLoader);\n   106\t\n   107\t            assertThat(partClass.getName()).isEqualTo(STRING_PART_CLASS_NAME);\n   108\t        } catch (Throwable throwable) {\n   109\t            if (!NativeImageSupport.isUnsupportedFeatureError(throwable)) {\n   110\t                throw throwable;\n   111\t            }\n   112\t        }\n   113\t    }\n   114\t\n   115\t    @Test\n   116\t    @Order(6)\n   117\t    void sendsRepeatableTextPartAndReencodesAfterCharsetChange() throws Exception {\n   118\t        String value = \"caf\\u00e9\";\n   119\t        StringPart part = new StringPart(\"message\", value, StandardCharsets.UTF_8.name());\n   120\t\n   121\t        byte[] utf8Multipart = send(part);\n   122\t        String utf8Text = new String(utf8Multipart, StandardCharsets.ISO_8859_1);\n   123\t\n   124\t        assertThat(part.getName()).isEqualTo(\"message\");\n   125\t        assertThat(part.getContentType()).isEqualTo(StringPart.DEFAULT_CONTENT_TYPE);\n   126\t        assertThat(part.getCharSet()).isEqualTo(StandardCharsets.UTF_8.name());\n   127\t        assertThat(part.getTransferEncoding()).isEqualTo(StringPart.DEFAULT_TRANSFER_ENCODING);\n   128\t        assertThat(part.isRepeatable()).isTrue();\n   129\t        assertThat(part.length()).isEqualTo(utf8Multipart.length);\n   130\t        assertThat(part.toString()).isEqualTo(\"message\");\n   131\t        assertThat(utf8Text)\n   132\t                .contains(\"Content-Disposition: form-data; name=\\\"message\\\"\")\n   133\t                .contains(\"Content-Type: text/plain; charset=UTF-8\")\n   134\t                .contains(\"Content-Transfer-Encoding: 8bit\");\n   135\t        assertThat(extractBody(utf8Multipart))\n   136\t                .isEqualTo(value.getBytes(StandardCharsets.UTF_8));\n   137\t\n   138\t        part.setCharSet(StandardCharsets.ISO_8859_1.name());\n   139\t        byte[] isoMultipart = send(part);\n   140\t\n   141\t        assertThat(part.getCharSet()).isEqualTo(StandardCharsets.ISO_8859_1.name());\n   142\t        assertThat(new String(isoMultipart, StandardCharsets.ISO_8859_1))\n   143\t                .contains(\"Content-Type: text/plain; charset=ISO-8859-1\");\n   144\t        assertThat(extractBody(isoMultipart))\n   145\t                .isEqualTo(value.getBytes(StandardCharsets.ISO_8859_1));\n   146\t    }\n   147\t\n   148\t    @Test\n   149\t    @Order(7)\n   150\t    void rejectsNullAndNulContainingValues() {\n   151\t        as