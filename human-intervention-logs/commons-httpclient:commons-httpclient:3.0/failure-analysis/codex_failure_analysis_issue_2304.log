namicAccessUtils {\\n\\n    private static final String TRACK_DYNAMIC_ACCESS_PREFIX = \\\"-H:TrackDynamicAccess=path=\\\";\\n\\n    private static final String PRESERVE_PREFIX = \\\"-H:Preserve=path=\\\";\\n\\n    public static List<String> buildArgsForClasspathEntries(List<File> classpathEntries) {\\n        List<File> sortedEntries = new ArrayList<>(classpathEntries);\\n        sortedEntries.sort(Comparator.comparing(File::getAbsolutePath));\\n\\n        List<String> buildArgs = new ArrayList<>(sortedEntries.size() * 2);\\n        for (File classpathEntry : sortedEntries) {\\n            String path = classpathEntry.getAbsolutePath();\\n            buildArgs.add(TRACK_DYNAMIC_ACCESS_PREFIX + path);\\n            buildArgs.add(PRESERVE_PREFIX + path);\\n        }\\n        return buildArgs;\\n    }\\n}\\n\",\"exit_code\":0,\"status\":\"completed\"}}\n161:{\"type\":\"item.started\",\"item\":{\"id\":\"item_93\",\"type\":\"command_execution\",\"command\":\"/usr/bin/bash -lc \\\"rg -n 'TrackDynamicAccess|Preserve=path|dynamicAccess|preserveDynamic|future-defaults' tests/src -g 'build.gradle' -g 'gradle.properties' -S\\\"\",\"aggregated_output\":\"\",\"exit_code\":null,\"status\":\"in_progress\"}}\n162:{\"type\":\"item.completed\",\"item\":{\"id\":\"item_93\",\"type\":\"command_execution\",\"command\":\"/usr/bin/bash -lc \\\"rg -n 'TrackDynamicAccess|Preserve=path|dynamicAccess|preserveDynamic|future-defaults' tests/src -g 'build.gradle' -g 'gradle.properties' -S\\\"\",\"aggregated_output\":\"\",\"exit_code\":1,\"status\":\"failed\"}}\n167:{\"type\":\"item.completed\",\"item\":{\"id\":\"item_96\",\"type\":\"agent_message\",\"text\":\"The repo’s native test harness only adds `TrackDynamicAccess`/`Preserve` automatically in the dynamic-access-report lane, not for normal `test`. I’m checking whether the commons-httpclient fixture can cheaply reuse that existing helper in its own `build.gradle`, because that’s likely the missing piece for these `URLClassLoader` cases.\"}}\n