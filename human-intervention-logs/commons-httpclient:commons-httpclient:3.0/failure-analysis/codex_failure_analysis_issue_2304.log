AME.equals(name)) {\n    98\t                    Class<?> loadedClass = findLoadedClass(name);\n    99\t                    if (loadedClass == null) {\n   100\t                        loadedClass = findClass(name);\n   101\t                    }\n   102\t                    if (resolve) {\n   103\t                        resolveClass(loadedClass);\n   104\t                    }\n   105\t                    return loadedClass;\n   106\t                }\n   107\t                return super.loadClass(name, resolve);\n   108\t            }\n   109\t        }\n   110\t    }\n   111\t}\n\n====\n     1\t/*\n     2\t * Copyright and related rights waived via CC0\n     3\t *\n     4\t * You should have received a copy of the CC0 legalcode along with this\n     5\t * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n     6\t */\n     7\tpackage commons_httpclient.commons_httpclient;\n     8\t\n     9\timport static org.assertj.core.api.Assertions.assertThat;\n    10\timport static org.assertj.core.api.Assertions.assertThatThrownBy;\n    11\t\n    12\timport java.io.ByteArrayOutputStream;\n    13\timport java.io.IOException;\n    14\timport java.io.InputStream;\n    15\timport java.lang.invoke.MethodHandle;\n    16\timport java.lang.invoke.MethodHandles;\n    17\timport java.lang.invoke.MethodType;\n    18\timport java.net.URL;\n    19\timport java.net.URLClassLoader;\n    20\timport java.nio.charset.StandardCharsets;\n    21\t\n    22\timport org.apache.commons.httpclient.methods.multipart.StringPart;\n    23\timport org.graalvm.internal.tck.NativeImageSupport;\n    24\timport org.junit.jupiter.api.MethodOrderer;\n    25\timport org.junit.jupiter.api.Order;\n    26\timport org.junit.jupiter.api.Test;\n    27\timport org.junit.jupiter.api.TestMethodOrder;\n    28\t\n    29\t@TestMethodOrder(MethodOrderer.OrderAnnotation.class)\n    30\tpublic class StringPartTest {\n    31\t    private static final String STRING_PART_CLASS_NAME =\n    32\t            \"