          public String getUser(DatabaseRequest request) {
              return request.user;
          }
  
          public String getName(DatabaseRequest request) {
              return request.name;
          }
  
          public String getConnectionString(DatabaseRequest request) {
              return request.connectionString;
          }
      }
  
