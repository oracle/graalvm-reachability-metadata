[tool-call] delta {"path":"tests/src/org.jetbrains.kotlinx/atomicfu/0.19.0/src/test/kotlin/org_jetbrains_kotlinx/atomicfu/AtomicfuTest.kt","edits":[{"oldText":"import kotlinx.atomicfu.getAndUpdate\nimport kotlinx.atomicfu.update\n","newText":"import kotlinx.atomicfu.getAndUpdate\nimport kotlinx.atomicfu.loop\nimport kotlinx.atomicfu.update\n"},{"oldText":"    @Test\n    fun traceRecordsManualAndNamedAtomicEventsWithCustomFormatting(): Unit {\n","newText":"    @Test\n    fun loopExtensionRetriesWithFreshValuesUntilCallerReturns(): Unit {\n        val state = atomic(1)\n        val observed = mutableListOf<Int>()\n\n        fun claimEvenValue(): Int {\n            state.loop { value ->\n                observed.add(value)\n                if (value % 2 != 0) {\n                    state.incrementAndGet()\n                    return@loop\n                }\n                if (state.compareAndSet(value, value + 10)) {\n                    return value\n                }\n            }\n        }\n\n        assertThat(claimEvenValue()).isEqualTo(2)\n        assertThat(state.value).isEqualTo(12)\n        assertThat(observed).containsExactly(1, 2)\n    }\n\n    @Test\n    fun traceRecordsManualAndNamedAtomicEventsWithCustomFormatting(): Unit {\n"}]}
