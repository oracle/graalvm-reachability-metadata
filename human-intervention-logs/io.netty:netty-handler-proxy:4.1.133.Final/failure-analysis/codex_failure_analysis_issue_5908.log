y-codec-mqtt/index.json:21:    \"source-code-url\": \"https://repo.maven.apache.org/maven2/io/netty/netty-codec-mqtt/4.1.74.Final/netty-codec-mqtt-4.1.74.Final-sources.jar\",\nmetadata/io.netty/netty-codec-mqtt/index.json:22:    \"repository-url\": \"https://github.com/netty/netty\",\nmetadata/io.netty/netty-codec-mqtt/index.json:23:    \"test-code-url\": \"https://repo.maven.apache.org/maven2/io/netty/netty-codec-mqtt/4.1.74.Final/netty-codec-mqtt-4.1.74.Final-tests.jar\",\nmetadata/io.netty/netty-codec-mqtt/index.json:24:    \"documentation-url\": \"https://repo.maven.apache.org/maven2/io/netty/netty-codec-mqtt/4.1.74.Final/netty-codec-mqtt-4.1.74.Final-javadoc.jar\",\nmetadata/io.netty/netty-codec-mqtt/index.json:25:    \"description\": \"Netty Codec MQTT provides MQTT protocol encoder, decoder, and message model classes for Netty pipelines. It lets Java applications implement MQTT clients or servers on top of Netty by translating MQTT wire frames to and from Netty message objects.\",\nmetadata/io.netty/netty-codec/index.json:5:    \"source-code-url\" : \"https://repo.maven.apache.org/maven2/io/netty/netty-codec/$version$/netty-codec-$version$-sources.jar\",\nmetadata/io.netty/netty-codec/index.json:6:    \"repository-url\" : \"https://github.com/netty/netty\",\nmetadata/io.netty/netty-codec/index.json:7:    \"test-code-url\" : \"https://github.com/netty/netty/tree/netty-$version$/codec/src/test/java\",\nmetadata/io.netty/netty-codec/index.json:8:    \"documentation-url\" : \"https://repo.maven.apache.org/maven2/io/netty/netty-codec/$version$/netty-codec-$version$-javadoc.jar\",\nmetadata/io.netty/netty-codec/index.json:9:    \"description\" : \"Netty Codec provides encoders and decoders for transforming byte streams and messages within Netty channel pipelines. It includes reusable frame decoders, compression handlers, serialization codecs, and protocol-building primitives used by Netty-based network applications.\",\nmetadata/io.netty/netty-transport-native-epoll/index.json:5:    \"source-code-url\" : \"https://repo.maven.apache.org/maven2/io/netty/netty-transport-native-epoll/4.1.42.Final/netty-transport-native-epoll-4.1.42.Final-sources.jar\",\nmetadata/io.netty/netty-transport-native-epoll/index.json:6:    \"repository-url\" : \"https://github.com/netty/netty\",\nmetadata/io.netty/netty-transport-native-epoll/index.json:7:    \"test-code-url\" : \"https://github.com/netty/netty/tree/netty-4.1.42.Final/transport-native-epoll/src/test\",\nmetadata/io.netty/netty-transport-native-epoll/index.json:8:    \"documentation-url\" : \"https://repo.maven.apache.org/maven2/io/netty/netty-transport-native-epoll/4.1.42.Final/netty-transport-native-epoll-4.1.42.Final-javadoc.jar\",\nmetadata/io.netty/netty-transport-native-epoll/index.json:9:    \"description\" : \"Netty Transport Native Epoll provides Linux epoll-based native transport support for Netty. It gives Netty applications high-performance event loops, channels, and JNI-backed native socket features on Linux.\",\nmetadata/io.netty/netty-codec-smtp/index.json:6:    \"source-code-url\" : \"https://repo.maven.apache.org/maven2/io/netty/netty-codec-smtp/$version$/netty-codec-smtp-$version$-sources.jar\",\nmetadata/io.netty/netty-codec-smtp/index.json:7:    \"repository-url\" : \"https://github.com/netty/netty\",\nmetadata/io.netty/netty-codec-smtp/index.json:8:    \"test-code-url\" : \"https://repo.maven.apache.org/maven2/io/netty/netty-codec-smtp/$version$/netty-codec-smtp-$version$-test-sources.jar\",\nmetadata/io.netty/netty-codec-smtp/index.json:9:    \"documentation-url\" : \"https://repo.maven.apache.org/maven2/io/netty/netty-codec-smtp/$version$/netty-codec-smtp-$version$-javadoc.jar\",\nmetadata/io.netty/netty-codec-smtp/index.json:10:    \"description\" : \"Netty Codec SMTP provides SMTP protocol support for Netty by modeling SMTP commands, requests, responses, and message content. It includes an SMTP request encoder and response decoder for implementing asynchronous SMTP clients on Netty's channel pipeline.\",\nmetadata/io.netty/netty-codec-smtp/index.json:20:    \"source-code-url\" : \"https://repo.maven.apache.org/maven2/io/netty/netty-codec-smtp/$version$/netty-codec-smtp-$version$-sources.jar\",\nmetadata/io.netty/netty-codec-smtp/index.json:21:    \"repository-url\" : \"https://github.com/netty/netty\",\nmetadata/io.netty/netty-codec-smtp/index.json:22:    \"test-code-url\" : \"https://repo.maven.apache.org/maven2/io/netty/netty-codec-smtp/$version$/netty-codec-smtp-$version$-test-sources.jar\",\nmetadata/io.netty/netty-codec-smtp/index.json:23:    \"documentation-url\" : \"https://repo.maven.apache.org/maven2/io/netty/netty-codec-smtp/$version$/netty-codec-smtp-$version$-javadoc.jar\",\nmetadata/io.netty/netty-codec-smtp/index.json:24:    \"description\" : \"Netty Codec SMTP provides SMTP protocol support for Netty by modeling SMTP commands, requests, responses, and message content. It includes an SMTP request encoder and response decoder for implementing asynchronous SMTP clients on Netty's channel pipeline.\",\nmetadata/io.netty/netty-transport-classes-kqueue/index.json:5:    \"source-code-url\" : \"https://repo.maven.apache.org/maven2/io/netty/netty-transport-classes-kqueue/$version$/netty-transport-classes-kqueue-$version$-sources.jar\",\nmetadata/io.netty/netty-transport-classes-kqueue/index.json:6:    \"repository-url\" : \"https://github.com/netty/netty\",\nmetadata/io.netty/netty-transport-classes-kqueue/index.json:7:    \"test-code-url\" : \"https://github.com/netty/netty/tree/netty-$version$/transport-native-kqueue/src/test/java/io/netty/channel/kqueue\",\nmetadata/io.netty/netty-transport-classes-kqueue/index.json:8:    \"documentation-url\" : \"https://repo.maven.apache.org/maven2/io/netty/netty-transport-classes-kqueue/$version$/netty-transport-classes-kqueue-$version$-javadoc.jar\",\nmetadata/io.netty/netty-transport-classes-kqueue/index.json:9:    \"description\" : \"Netty Transport Classes KQueue provides the Java classes that implement Netty's kqueue-based transport integration on BSD-derived operating systems such as macOS. It enables Netty applications to use the native kqueue event notification mechanism for high-performance asynchronous network I/O when paired with the matching native transport artifacts.\",\nmetadata/io.netty/netty-transport-classes-epoll/index.json:5:    \"source-code-url\" : \"https://repo.maven.apache.org/maven2/io/netty/netty-transport-classes-epoll/$version$/netty-transport-classes-epoll-$version$-sources.jar\",\n","exit_code":0,"status":"completed"}}
