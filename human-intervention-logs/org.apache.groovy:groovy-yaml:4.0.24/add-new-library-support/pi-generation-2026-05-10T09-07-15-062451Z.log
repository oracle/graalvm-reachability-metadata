      @Test
      void parsesMultipleYamlDocumentsAsAList() {
          String yaml = '''\
  ---
  name: first
  value: 1
  ---
  name: second
  value: 2
  ---
  - alpha
  - beta
  '''
  
          List documents = new YamlSlurper().parseText(yaml) as List
  
          assertThat(documents).hasSize(3)
          assertThat(documents[0]).containsEntry('name', 'first')
          assertThat(documents[1]).containsEntry('value', 2)
          assertThat(documents[2]).containsExactly('alpha', 'beta')
      }
  
      @Test
      void resolvesYamlAnchorsAndAliasesInMapsAndLists() {
          String yaml = '''\
  ---
  sharedTask: &sharedTask
    name: compile
    enabled: true
  jobs:
    - *sharedTask
    - name: test
      dependsOn: *sharedTask
  platforms: &platforms
    - linux
    - macos
  copiedPlatforms: *platforms
  '''
  
          Map parsed = new YamlSlurper().parseText(yaml) as Map
  
          Map sharedTask = parsed['sharedTask'] as Map
          assertThat(sharedTask).containsEntry('name', 'compile')
          assertThat(sharedTask).containsEntry('enabled', true)
          List jobs = parsed['jobs'] as List
          assertThat(jobs[0]).isEqualTo(sharedTask)
          assertThat((jobs[1] as Map)['dependsOn']).isEqualTo(sharedTask)
          assertThat(parsed['copiedPlatforms']).isEqualTo(parsed['platforms'])
          assertThat(parsed['copiedPlatforms']).containsExactly('linux', 'macos')
      }
  
