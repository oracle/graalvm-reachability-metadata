ort/\\\"))\\n                .version(HttpClient.Version.HTTP_2)\\n                .timeout(Duration.ofSeconds(10))\\n                .GET()\\n                .build()\\n\\n            val response: HttpResponse<String> = client.sendAsync(\\n                request,\\n                HttpResponse.BodyHandlers.ofString(),\\n                pushHandler\\n            ).get(10, TimeUnit.SECONDS)\\n            val pushedResponse: HttpResponse<String> = awaitPushedResponse(pushedResponses)\\n\\n            assertThat(response.version()).isEqualTo(HttpClient.Version.HTTP_2)\\n            assertThat(response.body()).isEqualTo(\\\"root\\\")\\n            assertThat(pushedPaths).contains(\\\"/pushed\\\")\\n            assertThat(pushedResponse.body()).isEqualTo(\\\"pushed\\\")\\n        } finally {\\n            server.stop(gracePeriodMillis = 0, timeoutMillis = 5_000)\\n            client.close()\\n        }\\n    }\\n\\n    private fun http2ClientTrusting(keyStore: KeyStore, keyAlias: String): HttpClient {\\n        val trustStore: KeyStore = KeyStore.getInstance(KeyStore.getDefaultType()).apply {\\n            load(null)\\n            setCertificateEntry(\\\"server\\\", keyStore.getCertificate(keyAlias))\\n        }\\n        val trustManagerFactory: TrustManagerFactory = TrustManagerFactory.getInstance(\\n            TrustManagerFactory.getDefaultAlgorithm()\\n        ).apply {\\n            init(trustStore)\\n        }\\n        val sslContext: SSLContext = SSLContext.getInstance(\\\"TLS\\\").apply {\\n            init(null, trustManagerFactory.trustManagers, SecureRandom())\\n        }\\n        val sslParameters: SSLParameters = SSLParameters().apply {\\n            endpointIdentificationAlgorithm = \\\"HTTPS\\\"\\n        }\\n\\n        return HttpClient.newBuilder()\\n            .sslContext(sslContext)\\n            .sslParameters(sslParameters)\\n            .version(HttpClient.Version.HTTP_2)\\n            .connectTimeout(Duration.ofSeconds(10))\\n            .bui