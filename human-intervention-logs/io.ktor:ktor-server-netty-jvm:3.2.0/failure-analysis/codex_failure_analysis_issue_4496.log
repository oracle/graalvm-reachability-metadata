mport java.util.concurrent.TimeUnit\n    40\timport javax.net.ssl.SSLContext\n    41\timport javax.net.ssl.TrustManager\n    42\timport javax.net.ssl.X509TrustManager\n    43\t\n    44\tpublic class NettyHttp2HandlerTest {\n    45\t    @OptIn(UseHttp2Push::class)\n    46\t    @Test\n    47\t    fun `netty http2 push promise sets child stream id and property`() {\n    48\t        val keyStorePassword: String = \"changeit\"\n    49\t        val keyAlias: String = \"netty-test-key\"\n    50\t        val keyStore: KeyStore = generateCertificate(\n    51\t            keyAlias = keyAlias,\n    52\t            keyPassword = keyStorePassword,\n    53\t            jksPassword = keyStorePassword,\n    54\t            algorithm = \"SHA256withRSA\",\n    55\t            keySizeInBits = 2048,\n    56\t        )\n    57\t\n    58\t        withSecureNettyServer(\n    59\t            keyAlias = keyAlias,\n    60\t            keyStorePassword = keyStorePassword,\n    61\t            keyStore = keyStore,\n    62\t            module = {\n    63\t                routing {\n    64\t                    get(\"/\") {\n    65\t                        call.push(\"/pushed-resource\")\n    66\t                        call.respondText(\"root-response\", ContentType.Text.Plain)\n    67\t                    }\n    68\t                    get(\"/pushed-resource\") {\n    69\t                        call.respondText(\"pushed-response\", ContentType.Text.Plain)\n    70\t                    }\n    71\t                }\n    72\t            },\n    73\t        ) { baseUri: URI ->\n    74\t            val executor: ExecutorService = Executors.newSingleThreadExecutor()\n    75\t            val client: HttpClient = newHttp2Client(executor)\n    76\t            try {\n    77\t                val pushedPaths: LinkedBlockingQueue<String> = LinkedBlockingQueue()\n    78\t                val pushHandler: HttpResponse.PushPromiseHandler<String> = HttpResponse.PushPromiseHandler {\n    79\t                    _: HttpRequest,\n    80\t                    pushPromiseRequest: HttpRequest,\n    81\t                    _ ->\n    82\t\n    83\t                    pushedPaths.offer(pushPromiseRequest.uri().path)\n    84\t                }\n    85\t\n    86\t                val mainResponse: HttpResponse<String> = client.sendAsync(\n    87\t                    request(baseUri.resolve(\"/\")).build(),\n    88\t                    HttpResponse.BodyHandlers.ofString(),\n    89\t                    pushHandler,\n    90\t                ).get(REQUEST_TIMEOUT.toSeconds(), TimeUnit.SECONDS)\n    91\t                val pushedPath: String = pushedPaths.poll(\n    92\t                    REQUEST_TIMEOUT.toSeconds(),\n    93\t                    TimeUnit.SECONDS,\n    94\t                ) ?: error(\"HTTP/2 push promise was not received\")\n    95\t\n    96\t                assertThat(mainResponse.version()).isEqualTo(HttpClient.Version.HTTP_2)\n    97\t                assertThat(mainResponse.statusCode()).isEqualTo(HttpStatusCode.OK.value)\n    98\t                assertThat(mainResponse.body()).isEqualTo(\"root-response\")\n    99\t                assertThat(pushedPath).isEqualTo(\"/pushed-resource\")\n   100\t            } finally {\n   101\t                client.shutdownNow()\n   102\t                executor.shutdownNow()\n   103\t                assertThat(executor.awaitTermination(10, TimeUnit.SECONDS)).isTrue()\n   104\t            }\n   105\t        }\n   106\t    }\n   107\t\n   108\t    private fun withSecureNettyServer(\n   109\t        keyAlias: String,\n   110\t        keyStorePassword: String,\n   111\t        keyStore: KeyStore,\n   112\t        module: suspend Application.() -> Unit,\n   113\t        test: (URI) -> Unit,\n   114\t    ) {\n   115\t        val port: Int = findAvailablePort()\n   116\t        val server: EmbeddedServer<NettyApplicationEngine, NettyApplicationEngine.Configuration> = embeddedServer(\n   117\t            Netty,\n   118\t            configure = {\n   119\t                enableHttp2 = true\n   120\t                sslConnector(\n   121\t                    keyStore = keyStore,\n   122\t                    keyAlias = keyAlias,\n   123\t                    keyStorePassword = { keyStorePassword.toCharArray() },\n   124\t                    privateKeyPassword = { keyStorePassword.toCharArray() },\n   125\t                ) {\n   126\t                    host = LOOPBACK_HOST\n   127\t                    this.port = port\n   128\t                }\n   129\t            },\n   130\t            module = module,\n   131\t        )\n   132\t\n   133\t        server.start(wait = false)\n   134\t        try {\n   135\t            test(URI(\"https://$LOOPBACK_HOST:$port\"))\n   136\t        } finally {\n   137\t            server.stop(0L, 5_000L)\n   138\t        }\n   139\t    }\n   140\t\n   141\t    private fun newHttp2Client(executor: ExecutorService): HttpClient = HttpClient.newBuilder()\n   142\t        .connectTimeout(REQUEST_TIMEOUT)\n   143\t        .executor(executor)\n   144\t        .sslContext(trustingSslContext())\n   145\t        .version(HttpClient.Version.HTTP_2)\n   146\t        .build()\n   147\t\n   148\t    private fun request(uri: URI): HttpRequest.Builder = HttpRequest.newBuilder(uri)\n   149\t        .timeout(REQUEST_TIMEOUT)\n   150\t        .version(HttpClient.Version.HTTP_2)\n   151\t        .GET()\n   152\t\n   153\t    private fun trustingSslContext(): SSLContext {\n   154\t        val sslContext: SSLContext = SSLContext.getInstance(\"TLS\")\n   155\t        sslContext.init(null, arrayOf<TrustManager>(TrustAllCertificates), SecureRandom())\n   156\t        return sslContext\n   157\t    }\n   158\t\n   159\t    private fun findAvailablePort(): Int = ServerSocket().use { socket: ServerSocket ->\n   160\t        socket.reuseAddress = true\n   161\t        socket.bind(InetSocketAddress(InetAddress.getByName(LOOPBACK_HOST), 0))\n   162\t        socket.localPort\n   163\t    }\n   164\t\n   165\t    private object TrustAllCertificates : X509TrustManager {\n   166\t        override fun checkClientTrusted(chain: Array<X509Certificate>, authType: String): Unit = Unit\n   167\t\n   168\t        override fun checkServerTrusted(chain: Array<X509Certificate>, authType: String): Unit = Unit\n   169\t\n   170\t        override fun getAcceptedIssuers(): Array<X509Certificate> = emptyArray()\n   171\t    }\n   172\t\n   173\t    private companion object {\n   174\t        private const val LOOPBACK_HOST: String = \"127.0.0.1\"\n   175\t        private val REQUEST_TIMEOUT: Duration = Duration.ofSeconds(10)\n   176\t    }\n   177\t}\n","exit_code":0,"status":"completed"}}
