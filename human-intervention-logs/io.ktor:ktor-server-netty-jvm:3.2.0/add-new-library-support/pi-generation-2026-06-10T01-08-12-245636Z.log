[tool-call] delta {"path":"tests/src/io.ktor/ktor-server-netty-jvm/3.2.0/src/test/kotlin/io_ktor/ktor_server_netty_jvm/NettyHttp2HandlerTest.kt","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_ktor.ktor_server_netty_jvm\n\nimport io.ktor.network.tls.certificates.generateCertificate\nimport io.ktor.server.engine.embeddedServer\nimport io.ktor.server.engine.sslConnector\nimport io.ktor.server.http.push\nimport io.ktor.server.netty.Netty\nimport io.ktor.server.response.UseHttp2Push\nimport io.ktor.server.response.respondText\nimport io.ktor.server.routing.get\nimport io.ktor.server.routing.routing\nimport kotlinx.coroutines.runBlocking\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\nimport java.net.URI\nimport java.net.http.HttpClient\nimport java.net.http.HttpRequest\nimport java.net.http.HttpResponse\nimport java.security.KeyStore\nimport java.security.SecureRandom\nimport java.time.Duration\nimport java.util.concurrent.ConcurrentLinkedQueue\nimport java.util.concurrent.TimeUnit\nimport javax.net.ssl.SSLContext\nimport javax.net.ssl.SSLParameters\nimport javax.net.ssl.TrustManagerFactory\n\npublic class NettyHttp2HandlerTest {\n    @OptIn(UseHttp2Push::class)\n    @Test\n    fun http2PushPromiseCreatesPromisedStream() {\n        val keyAlias: String = \"test-key\"\n        val keyPassword: String = \"changeit\"\n        val keyStore: KeyStore = generateCertificate(\n            keyAlias = keyAlias,\n            keyPassword = keyPassword,\n            algorithm = \"SHA256withRSA\",\n            keySizeInBits = 2048\n        )\n        val client: HttpClient = http2ClientTrusting(keyStore, keyAlias)\n        val server = embeddedServer(\n            Netty,\n            configure = {\n                sslConnector(\n                    keyStore = keyStore,\n                    keyAlias = keyAlias,\n                    keyStorePassword = { keyPassword.toCharArray() },\n                    privateKeyPassword = { keyPassword.toCharArray() }\n                ) {\n                    host = \"127.0.0.1\"\n                    port = 0\n                }\n            }\n        ) {\n            routing {\n                get(\"/\") {\n                    call.push(\"/pushed\")\n                    call.respondText(\"root\")\n                }\n                get(\"/pushed\") {\n                    call.respondText(\"pushed\")\n                }\n            }\n        }\n\n        try {\n            server.start(wait = false)\n            val port: Int = runBlocking { server.engine.resolvedConnectors().single().port }\n            val pushedPaths: ConcurrentLinkedQueue<String> = ConcurrentLinkedQueue()\n            val pushedResponses: ConcurrentLinkedQueue<CompletableFutureResponse> = ConcurrentLinkedQueue()\n            val pushHandler: HttpResponse.PushPromiseHandler<String> = HttpResponse.PushPromiseHandler {\n                    _, pushRequest, acceptor ->\n                pushedPaths.add(pushRequest.uri().path)\n                pushedResponses.add(acceptor.apply(HttpResponse.BodyHandlers.ofString()))\n            }\n            val request: HttpRequest = HttpRequest.newBuilder(URI(\"https://127.0.0.1:$port/\"))\n                .version(HttpClient.Version.HTTP_2)\n                .timeout(Duration.ofSeconds(10))\n                .GET()\n                .build()\n\n            val response: HttpResponse<String> = client.sendAsync(\n                request,\n                HttpResponse.BodyHandlers.ofString(),\n                pushHandler\n            ).get(10, TimeUnit.SECONDS)\n            val pushedResponse: HttpResponse<String> = awaitPushedResponse(pushedResponses)\n\n            assertThat(response.version()).isEqualTo(HttpClient.Version.HTTP_2)\n            assertThat(response.body()).isEqualTo(\"root\")\n            assertThat(pushedPaths).contains(\"/pushed\")\n            assertThat(pushedResponse.body()).isEqualTo(\"pushed\")\n        } finally {\n            server.stop(gracePeriodMillis = 0, timeoutMillis = 5_000)\n            client.close()\n        }\n    }\n\n    private fun http2ClientTrusting(keyStore: KeyStore, keyAlias: String): HttpClient {\n        val trustStore: KeyStore = KeyStore.getInstance(KeyStore.getDefaultType()).apply {\n            load(null)\n            setCertificateEntry(\"server\", keyStore.getCertificate(keyAlias))\n        }\n        val trustManagerFactory: TrustManagerFactory = TrustManagerFactory.getInstance(\n            TrustManagerFactory.getDefaultAlgorithm()\n        ).apply {\n            init(trustStore)\n        }\n        val sslContext: SSLContext = SSLContext.getInstance(\"TLS\").apply {\n            init(null, trustManagerFactory.trustManagers, SecureRandom())\n        }\n        val sslParameters: SSLParameters = SSLParameters().apply {\n            endpointIdentificationAlgorithm = \"HTTPS\"\n        }\n\n        return HttpClient.newBuilder()\n            .sslContext(sslContext)\n            .sslParameters(sslParameters)\n            .version(HttpClient.Version.HTTP_2)\n            .connectTimeout(Duration.ofSeconds(10))\n            .build()\n    }\n\n    private fun awaitPushedResponse(\n        pushedResponses: ConcurrentLinkedQueue<CompletableFutureResponse>\n    ): HttpResponse<String> {\n        val deadline: Long = System.nanoTime() + TimeUnit.SECONDS.toNanos(10)\n        while (pushedResponses.isEmpty() && System.nanoTime() < deadline) {\n            Thread.sleep(25)\n        }\n\n        assertThat(pushedResponses).isNotEmpty\n        return pushedResponses.first().get(10, TimeUnit.SECONDS)\n    }\n}\n\nprivate typealias CompletableFutureResponse = java.util.concurrent.CompletableFuture<HttpResponse<String>>\n"}
