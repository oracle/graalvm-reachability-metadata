n()).isEqualTo(HttpClient.Version.HTTP_2)\n            assertThat(response.body()).isEqualTo(\"root\")\n            assertThat(pushedPaths).contains(\"/pushed\")\n            assertThat(pushedResponse.body()).isEqualTo(\"pushed\")\n        } finally {\n            server.stop(gracePeriodMillis = 0, timeoutMillis = 5_000)\n            client.close()\n        }\n    }\n\n    private fun http2ClientTrusting(keyStore: KeyStore, keyAlias: String): HttpClient {\n        val trustStore: KeyStore = KeyStore.getInstance(KeyStore.getDefaultType()).apply {\n            load(null)\n            setCertificateEntry(\"server\", keyStore.getCertificate(keyAlias))\n        }\n        val trustManagerFactory: TrustManagerFactory = TrustManagerFactory.getInstance(\n            TrustManagerFactory.getDefaultAlgorithm()\n        ).apply {\n            init(trustStore)\n        }\n        val sslContext: SSLContext = SSLContext.getInstance(\"TLS\").apply {\n            init(null, trustManagerFactory.trustManagers, SecureRandom())\n        }\n        val sslParameters: SSLParameters = SSLParameters().apply {\n            endpointIdentificationAlgorithm = \"HTTPS\"\n        }\n\n        return HttpClient.newBuilder()\n            .sslContext(sslContext)\n            .sslParameters(sslParameters)\n            .version(HttpClient.Version.HTTP_2)\n            .connectTimeout(Duration.ofSeconds(10))\n            .build()\n    }\n\n    private fun awaitPushedResponse(\n        pushedResponses: ConcurrentLinkedQueue<CompletableFutureResponse>\n    ): HttpResponse<String> {\n        val deadline: Long = System.nanoTime() + TimeUnit.SECONDS.toNanos(10)\n        while (pushedResponses.isEmpty() && System.nanoTime() < deadline) {\n            Thread.sleep(25)\n        }\n\n        assertThat(pushedResponses).isNotEmpty\n        return pushedResponses.first().get(10, TimeUnit.SECONDS)\n    }\n}\n\nprivate typealias CompletableFutureResponse = java.util.concurrent.CompletableFuture<HttpResponse<String>>\n"}
