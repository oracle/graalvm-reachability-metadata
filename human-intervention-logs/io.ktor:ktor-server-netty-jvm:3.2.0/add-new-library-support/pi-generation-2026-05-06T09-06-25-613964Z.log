[tool-call] delta {"path":"tests/src/io.ktor/ktor-server-netty-jvm/3.2.0/src/test/kotlin/io_ktor/ktor_server_netty_jvm/NettyHttp2HandlerTest.kt","edits":[{"oldText":"import java.util.concurrent.CompletableFuture\nimport java.util.concurrent.ExecutorService\nimport java.util.concurrent.Executors\nimport java.util.concurrent.LinkedBlockingQueue\nimport java.util.concurrent.TimeUnit\nimport java.util.function.Function\n","newText":"import java.util.concurrent.ExecutorService\nimport java.util.concurrent.Executors\nimport java.util.concurrent.LinkedBlockingQueue\nimport java.util.concurrent.TimeUnit\n"},{"oldText":"                val pushedResponses: LinkedBlockingQueue<CompletableFuture<HttpResponse<String>>> =\n                    LinkedBlockingQueue()\n                val pushHandler: HttpResponse.PushPromiseHandler<String> = HttpResponse.PushPromiseHandler {\n                    _: HttpRequest,\n                    pushPromiseRequest: HttpRequest,\n                    acceptor: Function<HttpResponse.BodyHandler<String>, CompletableFuture<HttpResponse<String>>> ->\n\n                    assertThat(pushPromiseRequest.uri().path).isEqualTo(\"/pushed-resource\")\n                    pushedResponses.offer(acceptor.apply(HttpResponse.BodyHandlers.ofString()))\n                }\n","newText":"                val pushedPaths: LinkedBlockingQueue<String> = LinkedBlockingQueue()\n                val pushHandler: HttpResponse.PushPromiseHandler<String> = HttpResponse.PushPromiseHandler {\n                    _: HttpRequest,\n                    pushPromiseRequest: HttpRequest,\n                    _ ->\n\n                    pushedPaths.offer(pushPromiseRequest.uri().path)\n                }\n"},{"oldText":"                val pushedResponseFuture: CompletableFuture<HttpResponse<String>> = pushedResponses.poll(\n                    REQUEST_TIMEOUT.toSeconds(),\n                    TimeUnit.SECONDS,\n                ) ?: error(\"HTTP/2 push promise was not received\")\n                val pushedResponse: HttpResponse<String> = pushedResponseFuture.get(\n                    REQUEST_TIMEOUT.toSeconds(),\n                    TimeUnit.SECONDS,\n                )\n\n                assertThat(mainResponse.version()).isEqualTo(HttpClient.Version.HTTP_2)\n                assertThat(mainResponse.statusCode()).isEqualTo(HttpStatusCode.OK.value)\n                assertThat(mainResponse.body()).isEqualTo(\"root-response\")\n                assertThat(pushedResponse.statusCode()).isEqualTo(HttpStatusCode.OK.value)\n                assertThat(pushedResponse.body()).isEqualTo(\"pushed-response\")\n","newText":"                val pushedPath: String = pushedPaths.poll(\n                    REQUEST_TIMEOUT.toSeconds(),\n                    TimeUnit.SECONDS,\n                ) ?: error(\"HTTP/2 push promise was not received\")\n\n                assertThat(mainResponse.version()).isEqualTo(HttpClient.Version.HTTP_2)\n                assertThat(mainResponse.statusCode()).isEqualTo(HttpStatusCode.OK.value)\n                assertThat(mainResponse.body()).isEqualTo(\"root-response\")\n                assertThat(pushedPath).isEqualTo(\"/pushed-resource\")\n"}]}
