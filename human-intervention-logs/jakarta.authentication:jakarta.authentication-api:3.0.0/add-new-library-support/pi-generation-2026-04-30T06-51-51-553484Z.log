toryProperty = Security.getProperty(DEFAULT_FACTORY_SECURITY_PROPERTY);\n        AuthConfigFactory factory = null;\n        AuthConfigFactory.setFactory(null);\n        Security.setProperty(DEFAULT_FACTORY_SECURITY_PROPERTY, FACTORY_CLASS_NAME);\n        Thread.currentThread().setContextClassLoader(AuthConfigFactoryAnonymous1Test.class.getClassLoader());\n\n        try {\n            factory = AuthConfigFactory.getFactory();\n\n            assertInstanceOf(AuthConfigFactoryAnonymous1Test.class, factory);\n            assertSame(factory, AuthConfigFactory.getFactory());\n        } finally {\n            Thread.currentThread().setContextClassLoader(previousContextClassLoader);\n            if (previousFactoryProperty != null) {\n                Security.setProperty(DEFAULT_FACTORY_SECURITY_PROPERTY, previousFactoryProperty);\n                AuthConfigFactory.setFactory(null);\n            } else if (factory != null) {\n                AuthConfigFactory.setFactory(factory);\n            }\n        }\n    }\n"}]}, "partialJson": "{\"path\":\"tests/src/jakarta.authentication/jakarta.authentication-api/3.0.0/src/test/java/jakarta_authentication/jakarta_authentication_api/AuthConfigFactoryAnonymous1Test.java\",\"edits\":[{\"oldText\":\"import org.junit.jupiter.api.BeforeEach;\\nimport org.junit.jupiter.api.Test;\",\"newText\":\"import org.junit.jupiter.api.Test;\"},{\"oldText\":\"    @BeforeEach\\n    void configureDefaultFactoryClass() {\\n        AuthConfigFactory.setFactory(null);\\n        Security.setProperty(DEFAULT_FACTORY_SECURITY_PROPERTY, FACTORY_CLASS_NAME);\\n    }\\n\\n    @Test\\n    void getFactoryLoadsDefaultFactoryFromSecurityProperty() {\\n        AuthConfigFactory factory = AuthConfigFactory.getFactory();\\n\\n        assertInstanceOf(AuthConfigFactoryAnonymous1Test.class, factory);\\n        assertSame(factory, AuthConfigFactory.getFactory());\\n    }\\n\",\"newText\":\"    @Test\\n    void getFactoryLoadsDefaultFactoryFromSecurityProperty() {\\n        ClassLoader previousContextClassLoader = Thread.currentThread().getContextClassLoader();\\n        String previousFactoryProperty = Security.getProperty(DEFAULT_FACTORY_SECURITY_PROPERTY);\\n        AuthConfigFactory factory = null;\\n        AuthConfigFactory.setFactory(null);\\n        Security.setProperty(DEFAULT_FACTORY_SECURITY_PROPERTY, FACTORY_CLASS_NAME);\\n        Thread.currentThread().setContextClassLoader(AuthConfigFactoryAnonymous1Test.class.getClassLoader());\\n\\n        try {\\n            factory = AuthConfigFactory.getFactory();\\n\\n            assertInstanceOf(AuthConfigFactoryAnonymous1Test.class, factory);\\n            assertSame(factory, AuthConfigFactory.getFactory());\\n        } finally {\\n            Thread.currentThread().setContextClassLoader(previousContextClassLoader);\\n            if (previousFactoryProperty != null) {\\n                Security.setProperty(DEFAULT_FACTORY_SECURITY_PROPERTY, previousFactoryProperty);\\n                AuthConfigFactory.setFactory(null);\\n            } else if (factory != null) {\\n                AuthConfigFactory.setFactory(factory);\\n            }\\n        }\\n    }\\n\"}]}"}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1229, "output": 1369, "cacheRead": 25088, "cacheWrite": 0, "totalTokens": 27686, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777531841278, "responseId": "resp_016b2fa145af3bdb0169f2fbc2049481939216bb305785a1e4"}}
