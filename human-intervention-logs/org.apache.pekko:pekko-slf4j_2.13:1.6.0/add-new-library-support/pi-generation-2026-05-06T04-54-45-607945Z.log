it = {"}]}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 523, "output": 1567, "cacheRead": 30720, "cacheWrite": 0, "totalTokens": 32810, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778043256040, "responseId": "resp_0325dc5cad875b420169fac97958a081959bc5f1d45f3ba186"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_eYZuqQsaXNfOoJCONvBxz6Q7|fc_0325dc5cad875b420169fac98669b88195859fc1a4048e9433", "toolName": "edit", "content": [{"type": "text", "text": "Successfully replaced 2 block(s) in tests/src/org.apache.pekko/pekko-slf4j_2.13/1.6.0/src/test/scala/org_apache_pekko/pekko_slf4j_2_13/Pekko_slf4j_2_13Test.scala."}], "details": {"diff": "     ...\n  18 import org.apache.pekko.event.DummyClassForStringSources\n  19 import org.apache.pekko.event.LogMarker\n  20 import org.apache.pekko.event.Logging\n  21 import org.apache.pekko.event.Logging.Debug\n+ 22 import org.apache.pekko.event.LoggingAdapter\n  22 import org.apache.pekko.event.Logging.Error\n  23 import org.apache.pekko.event.Logging.Info\n  24 import org.apache.pekko.event.Logging.InitializeLogger\n  25 import org.apache.pekko.event.Logging.LoggerInitialized\n     ...\n 115     }\n 116   }\n 117 \n 118   @Test\n+120   def actorSystemUsesConfiguredSlf4jLoggingFilterForLoggingAdapters(): Unit = {\n+121     val config = ConfigFactory.parseString(\"\"\"\n+122         pekko.loggers = []\n+123         pekko.logging-filter = \"org.apache.pekko.event.slf4j.Slf4jLoggingFilter\"\n+124         pekko.stdout-loglevel = \"OFF\"\n+125         pekko.loglevel = \"DEBUG\"\n+126         pekko.actor.allow-java-serialization = off\n+127         pekko.actor.warn-about-java-serializer-usage = off\n+128       \"\"\")\n+129     val system: ActorSystem = ActorSystem(\"pekko-slf4j-configured-filter-test\", config)\n+130     try {\n+131       val sourceCategory: String = \"configured.filter.source\"\n+132       va