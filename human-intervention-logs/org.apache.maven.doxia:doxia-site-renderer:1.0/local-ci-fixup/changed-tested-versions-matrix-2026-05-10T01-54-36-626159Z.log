{"type":"item.completed","item":{"id":"item_13","type":"command_execution","command":"/usr/bin/bash -lc \"sed -n '360,460p' tests/tck-build-logic/src/main/groovy/org.graalvm.internal.tck-harness.gradle\"","aggregated_output":"}\n\nList<String> diffCoordinates = new ArrayList<>()\nif (project.hasProperty(\"baseCommit\")) {\n    String baseCommit = project.findProperty(\"baseCommit\")\n    String newCommit = Objects.requireNonNullElse(project.findProperty(\"newCommit\"), \"HEAD\")\n    diffCoordinates.addAll(tck.diffCoordinates(baseCommit, newCommit))\n    tasks.register(\"testDiff\", TestInvocationTask.class) { t ->\n        t.setCoordinatesOverride(diffCoordinates)\n    }\n    diff.configure {\n        dependsOn(\"testDiff\")\n    }\n}\n\nMap<String, Object> loadCi() {\n    File f = project.file(\"ci.json\")\n    if (!f.exists()) {\n        throw new GradleException(\"Missing ci.json in repo root\")\n    }\n    new JsonSlurper().parse(f) as Map<String, Object>\n}\n\nMap<String, Object> matrixSectionFor(String section) {\n    def ci = loadCi()\n    def sec = ci[section]\n    if (sec == null) throw new GradleException(\"Missing '${section}' in ci.json\")\n    sec as Map<String, Object>\n}\n\nMap<String, List<String>> matrixDefaultsFor(String section) {\n    def sec = matrixSectionFor(section)\n    [\n            \"version\": (sec[\"java\"] as List<String>),\n            \"os\": (sec[\"os\"] as List<String>)\n    ]\n}\n\nList<String> nativeImageModesForMatrix() {\n    NativeImageConfigUtils.modeNames(loadCi())\n}\n\nint versionsPerJobFor(String section) {\n    def sec = matrixSectionFor(section)\n    Object versionsPerJob = sec[\"versions-per-job\"]\n    if (versionsPerJob == null) {\n        return 30\n    }\n    int value = Integer.parseInt(versionsPerJob.toString())\n    if (value <= 0) {\n        throw new GradleException(\"'${section}.versions-per-job' must be greater than zero\")\n    }\n    value\n}\n\nint maxLibrariesFor(String section) {\n    def sec = matrixSectionFor(section)\n    Object maxLibraries = sec[\"max-libraries\"]\n    if (maxLibraries == null) {\n        return Integer.MAX_VALUE\n    }\n    int value = Integer.parseInt(maxLibraries.toString())\n    if (value <= 0) {\n        throw new GradleException(\"'${section}.max-libraries' must be greater than zero\")\n    }\n    value\n}\n\nList<Map<String, Object>> expandMatrixEntries(List<Map<String, Object>> entries, String section) {\n    def defaults = matrixDefaultsFor(section)\n    List<String> nativeImageModes = nativeImageModesForMatrix()\n    NativeImageConfigUtils.expandMatrixEntries(\n            entries,\n            defaults[\"version\"],\n            defaults[\"os\"],\n            nativeImageModes,\n            NativeImageConfigUtils.javaVersionsByMode(loadCi(), defaults[\"version\"], nativeImageModes)\n    )\n}\n\nMap<String, Object> springAotMatrixConfig() {\n    def ci = loadCi()\n    def sec = ci[\"generateAffectedSpringTestMatrix\"]\n    if (sec == null) throw new GradleException(\"Missing 'generateAffectedSpringTestMatrix' in ci.json\")\n    [\n            \"java-branch-mapping\": (sec[\"java-branch-mapping\"] as Map<String, String>),\n            \"os\": sec[\"os\"]\n    ]\n}\n\nList<Map<String, Object>> expandNewLibraryVersionCompatibilityMatrix(List<Map<String, Object>> libraries) {\n    int versionsPerJob = versionsPerJobFor(\"generateNewLibraryVersionCompatibilityMatrix\")\n    int maxLibraries = maxLibrariesFor(\"generateNewLibraryVersionCompatibilityMatrix\")\n    expandMatrixEntries(libraries.take(maxLibraries).collect { Map<String, Object> library ->\n        [\n                \"name\"    : library[\"name\"],\n                \"versions\": (library[\"versions\"] as List<?>)\n                        .collect { it.toString() }\n                        .take(versionsPerJob)\n        ]\n    }, \"generateNewLibraryVersionCompatibilityMatrix\")\n","exit_code":0,"status":"completed"}}
