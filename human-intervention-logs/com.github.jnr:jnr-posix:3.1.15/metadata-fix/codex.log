       try {\n            FileDescriptor descriptor = JavaLibCHelper.toFileDescriptor(HANDLE.valueOf(HANDLE_VALUE));\n\n            assertThat(JavaLibCHelper.gethandle(descriptor).toPointer().address()).isEqualTo(HANDLE_VALUE);\n        } catch (NullPointerException unsupported) {\n            assertThat(unsupported).isInstanceOf(NullPointerException.class);\n            assertThat(JavaLibCHelper.gethandle((FileDescriptor) null).toPointer().address()).isEqualTo(-1L);\n        }\n    }\n\n    @Test\n    void getsDescriptorFromFileChannel() throws Exception {\n        Path tempFile = Files.createTempFile(\"jnr-posix-file-channel\", \".tmp\");\n        Files.writeString(tempFile, \"content\");\n\n        try (FileInputStream stream = new FileInputStream(tempFile.toFile())) {\n            FileDescriptor descriptor = JavaLibCHelper.getDescriptorFromChannel(stream.getChannel());\n\n            assertThat(JavaLibCHelper.getfdFromDescriptor(descriptor)).isGreaterThanOrEqualTo(0);\n        } finally {\n            Files.deleteIfExists(tempFile);\n        }\n    }\n\n    @Test\n    void getsDescriptorFromSelectableChannel() throws Exception {\n        Pipe pipe = Pipe.open();\n        try (Pipe.SourceChannel source = pipe.source(); Pipe.SinkChannel sink = pipe.sink()) {\n            FileDescriptor descriptor = JavaLibCHelper.getDescriptorFromChannel(source);\n\n            assertThat(descriptor).isNotNull();\n            assertThat(sink.isOpen()).isTrue();\n        }\n    }\n\n    @Test\n    void getsDescriptorFromChannelWithPublicGetFdMethod() throws Exception {\n        DescriptorBackedChannel channel = new DescriptorBackedChannel(JavaLibCHelper.STDERR);\n\n        FileDescriptor descriptor = JavaLibCHelper.getDescriptorFromChannel(channel);\n\n        assertThat(JavaLibCHelper.getfdFromDescriptor(descriptor)).isEqualTo(JavaLibCHelper.STDERR);\n        channel.close();\n        assertThat(channel.isOpen()).isFalse();\n    }\n\n    @Test\n    void fallsBackToProcessHandleForPid() {\n        JavaLibCHelper helper = new JavaLibCHelper(new ThrowingPidHandler());\n\n        assertThat(helper.getpid()).isEqualTo((int) ProcessHandle.current().pid());\n    }\n\n    public static final class DescriptorBackedChannel implements Channel {\n        private final int fd;\n        private boolean open = true;\n\n        DescriptorBackedChannel(int fd) {\n            this.fd = fd;\n        }\n\n        public int getFD() {\n            return fd;\n        }\n\n        @Override\n        public boolean isOpen() {\n            return open;\n        }\n\n        @Override\n        public void close() {\n            open = false;\n        }\n    }\n\n    private static final class ThrowingPidHandler implements POSIXHandler {\n        @Override\n        public void error(Errno error, String extraData) {\n            throw new UnsupportedOperationException(error + \": \" + extraData);\n        }\n\n        @Override\n        public void error(Errno error, String methodName, String extraData) {\n            throw new UnsupportedOperationException(methodName + \": \" + error + \": \" + extraData);\n        }\n\n        @Override\n        public void unimplementedError(String methodName) {\n            throw new UnsupportedOperationException(methodName);\n        }\n\n        @Override\n        public void warn(WARNING_ID id, String message, Object... data) {\n            if (isVerbose()) {\n                getErrorStream().printf(message, data);\n            }\n        }\n\n        @Override\n        public boolean isVerbose() {\n            return false;\n        }\n\n        @Override\n        public File getCurrentWorkingDirectory() {\n            return new File(\".\");\n        }\n\n        @Override\n        public String[] getEnv() {\n            return new String[0];\n        }\n\n        @Override\n        public ByteArrayInputStream getInputStream() {\n            return new ByteArrayInputStream(new byte[0]);\n        }\n\n        @Override\n        public PrintStream getOutputStream() {\n            return System.out;\n        }\n\n        @Override\n        public int getPID() {\n            throw new UnsupportedOperationException(\"pid\");\n        }\n\n        @Override\n        public PrintStream getErrorStream() {\n            return System.err;\n        }\n    }\n}\n","exit_code":0,"status":"completed"}}
