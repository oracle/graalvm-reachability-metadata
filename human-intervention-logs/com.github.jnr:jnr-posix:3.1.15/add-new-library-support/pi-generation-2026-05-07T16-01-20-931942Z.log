[tool-call] delta {"path":"tests/src/com.github.jnr/jnr-posix/3.1.15/src/test/java/com_github_jnr/jnr_posix/ChmodTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_github_jnr.jnr_posix;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.nio.file.Files;\nimport java.nio.file.Path;\n\nimport jnr.posix.util.Chmod;\nimport org.junit.jupiter.api.Test;\n\npublic class ChmodTest {\n    @Test\n    void appliesOwnerOnlyPermissions() throws Exception {\n        Path tempFile = Files.createTempFile(\"jnr-posix-chmod\", \".tmp\");\n        try {\n            Files.writeString(tempFile, \"content\");\n\n            int result = Chmod.chmod(tempFile.toFile(), \"700\");\n\n            assertThat(result).isZero();\n        } finally {\n            tempFile.toFile().setReadable(true, false);\n            tempFile.toFile().setWritable(true, false);\n            Files.deleteIfExists(tempFile);\n        }\n    }\n}\n"}
