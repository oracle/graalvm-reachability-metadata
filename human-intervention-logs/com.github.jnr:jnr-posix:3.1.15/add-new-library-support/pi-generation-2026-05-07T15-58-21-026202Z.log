  package com_github_jnr.jnr_posix;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.File;
  import java.io.FileDescriptor;
  import java.io.FileInputStream;
  import java.io.PrintStream;
  import java.nio.channels.Channel;
  import java.nio.channels.Pipe;
  import java.nio.file.Files;
  import java.nio.file.Path;
  
  import jnr.constants.platform.Errno;
  import jnr.posix.HANDLE;
  import jnr.posix.JavaLibCHelper;
  import jnr.posix.POSIXHandler;
  import org.junit.jupiter.api.BeforeAll;
  import org.junit.jupiter.api.Test;
  
  public class JavaLibCHelperTest {
      private static final long HANDLE_VALUE = 44L;
  
      @BeforeAll
      static void initializeWindowsHandleAccess() {
          String originalOsName = System.getProperty("os.name");
          System.setProperty("os.name", "Windows 10");
          try {
              JavaLibCHelper.gethandle((FileDescriptor) null);
          } finally {
              if (originalOsName == null) {
                  System.clearProperty("os.name");
              } else {
                  System.setProperty("os.name", originalOsName);
              }
          }
      }
  
      @Test
      void createsFileDescriptorFromIntegerDescriptor() {
          FileDescriptor descriptor = JavaLibCHelper.toFileDescriptor(JavaLibCHelper.STDOUT);
  
          assertThat(JavaLibCHelper.getfdFromDescriptor(descriptor)).isEqualTo(JavaLibCHelper.STDOUT);
      }
  
      @Test
      void createsFileDescriptorFromWindowsHandleWhenAvailable() {
          try {
              FileDescriptor descriptor = JavaLibCHelper.toFileDescriptor(HANDLE.valueOf(HANDLE_VALUE));
  
              assertThat(JavaLibCHelper.gethandle(descriptor).toPointer().address()).isEqualTo(HANDLE_VALUE);
          } catch (NullPointerException ignored) {
              assertThat(JavaLibCHelper.gethandle((FileDescriptor) null).toPointer().address()).isEqualTo(-1L);
          }
      }
  
      @Test
      void getsDescriptorFromFileChannel() throws Exception {
          Path tempFile = Files.createTempFile("jnr-posix-file-channel", ".tmp");
          Files.writeString(tempFile, "content");
  
          try (FileInputStream stream = new FileInputStream(tempFile.toFile())) {
              FileDescriptor descriptor = JavaLibCHelper.getDescriptorFromChannel(stream.getChannel());
  
              assertThat(JavaLibCHelper.getfdFromDescriptor(descriptor)).isGreaterThanOrEqualTo(0);
          } finally {
              Files.deleteIfExists(tempFile);
          }
      }
  
      @Test
      void getsDescriptorFromSelectableChannel() throws Exception {
          try (Pipe.SourceChannel source = Pipe.open().source()) {
              FileDescriptor descriptor = JavaLibCHelper.getDescriptorFromChannel(source);
  
              assertThat(descriptor).isNotNull();
          }
      }
  
      @Test
      void getsDescriptorFromChannelWithPublicGetFdMethod() throws Exception {
          DescriptorBackedChannel channel = new DescriptorBackedChannel(JavaLibCHelper.STDERR);
  
          FileDescriptor descriptor = JavaLibCHelper.getDescriptorFromChannel(channel);
  
          assertThat(JavaLibCHelper.getfdFromDescriptor(descriptor)).isEqualTo(JavaLibCHelper.STDERR);
          channel.close();
          assertThat(channel.isOpen()).isFalse();
      }
  
      @Test
      void fallsBackToProcessHandleForPid() {
          JavaLibCHelper helper = new JavaLibCHelper(new ThrowingPidHandler());
  
          assertThat(helper.getpid()).isEqualTo((int) ProcessHandle.current().pid());
      }
  
      public static final class DescriptorBackedChannel implements Channel {
          private final int fd;
          private boolean open = true;
  
          DescriptorBackedChannel(int fd) {
              this.fd = fd;
          }
  
          public int getFD() {
              return fd;
          }
  
          @Override
          public boolean isOpen() {
              return open;
          }
  
          @Override
          public void close() {
              open = false;
          }
      }
  
      private static final class ThrowingPidHandler implements POSIXHandler {
          @Override
          public void error(Errno error, String extraData) {
              throw new UnsupportedOperationException(error + ": " + extraData);
          }
  
          @Override
          public void error(Errno error, String methodName, String extraData) {
              throw new UnsupportedOperationException(methodName + ": " + error + ": " + extraData);
          }
  
          @Override
          public void unimplementedError(String methodName) {
              throw new UnsupportedOperationException(methodName);
          }
  
          @Override
          public void warn(WARNING_ID id, String message, Object... data) {
          }
  
          @Override
          public boolean isVerbose() {
              return false;
          }
  
          @Override
          public File getCurrentWorkingDirectory() {
              return new File(".");
          }
  
          @Override
          public String[] getEnv() {
              return new String[0];
          }
  
          @Override
          public ByteArrayInputStream getInputStream() {
              return new ByteArrayInputStream(new byte[0]);
          }
  
          @Override
          public PrintStream getOutputStream() {
              return new PrintStream(new ByteArrayOutputStream());
          }
  
          @Override
          public int getPID() {
              throw new UnsupportedOperationException("pid");
          }
  
          @Override
          public PrintStream getErrorStream() {
              return new PrintStream(new ByteArrayOutputStream());
          }
      }
  }
