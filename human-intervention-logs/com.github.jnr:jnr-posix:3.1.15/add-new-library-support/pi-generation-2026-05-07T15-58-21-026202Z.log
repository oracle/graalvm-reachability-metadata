blic static final class DescriptorBackedChannel implements Channel {\n        private final int fd;\n        private boolean open = true;\n\n        DescriptorBackedChannel(int fd) {\n            this.fd = fd;\n        }\n\n        public int getFD() {\n            return fd;\n        }\n\n        @Override\n        public boolean isOpen() {\n            return open;\n        }\n\n        @Override\n        public void close() {\n            open = false;\n        }\n    }\n\n    private static final class ThrowingPidHandler implements POSIXHandler {\n        @Override\n        public void error(Errno error, String extraData) {\n            throw new UnsupportedOperationException(error + \": \" + extraData);\n        }\n\n        @Override\n        public void error(Errno error, String methodName, String extraData) {\n            throw new UnsupportedOperationException(methodName + \": \" + error + \": \" + extraData);\n        }\n\n        @Override\n        public void unimplementedError(String methodName) {\n            throw new UnsupportedOperationException(methodName);\n        }\n\n        @Override\n        public void warn(WARNING_ID id, String message, Object... data) {\n        }\n\n        @Override\n        public boolean isVerbose() {\n            return false;\n        }\n\n        @Override\n        public File getCurrentWorkingDirectory() {\n            return new File(\".\");\n        }\n\n        @Override\n        public String[] getEnv() {\n            return new String[0];\n        }\n\n        @Override\n        public ByteArrayInputStream getInputStream() {\n            return new ByteArrayInputStream(new byte[0]);\n        }\n\n        @Override\n        public PrintStream getOutputStream() {\n            return new PrintStream(new ByteArrayOutputStream());\n        }\n\n        @Override\n        public int getPID() {\n            throw new UnsupportedOperationException(\"pid\");\n        }\n\n        @Override\n        public PrintStream getErrorStream() {\n            return new PrintStream(new ByteArrayOutputStream());\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778169366770}}
