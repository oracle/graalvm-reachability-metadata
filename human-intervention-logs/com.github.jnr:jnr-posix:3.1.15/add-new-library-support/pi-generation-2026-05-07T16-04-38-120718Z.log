  package com_github_jnr.jnr_posix;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.nio.file.Files;
  import java.nio.file.Path;
  
  import jnr.posix.util.Chmod;
  import org.junit.jupiter.api.Test;
  
  public class ChmodTest {
      @Test
      void appliesOwnerOnlyPermissions() throws Exception {
          Path tempFile = Files.createTempFile("jnr-posix-chmod", ".tmp");
          try {
              Files.writeString(tempFile, "content");
  
              int result = Chmod.chmod(tempFile.toFile(), "700");
  
              assertThat(result).isZero();
          } finally {
              tempFile.toFile().setReadable(true, false);
              tempFile.toFile().setWritable(true, false);
              Files.deleteIfExists(tempFile);
          }
      }
  }
