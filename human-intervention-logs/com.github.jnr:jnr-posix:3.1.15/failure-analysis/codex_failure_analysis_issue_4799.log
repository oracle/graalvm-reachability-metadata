  private static final long HANDLE_VALUE = 44L;\\n\\n    @BeforeAll\\n    static void initializeWindowsHandleAccess() {\\n        String originalOsName = System.getProperty(\\\"os.name\\\");\\n        System.setProperty(\\\"os.name\\\", \\\"Windows 10\\\");\\n        try {\\n            JavaLibCHelper.toFileDescriptor(JavaLibCHelper.STDOUT);\\n        } finally {\\n            if (originalOsName == null) {\\n                System.clearProperty(\\\"os.name\\\");\\n            } else {\\n                System.setProperty(\\\"os.name\\\", originalOsName);\\n            }\\n        }\\n    }\\n\\n    @Test\\n    void createsFileDescriptorFromIntegerDescriptor() {\\n        FileDescriptor descriptor = JavaLibCHelper.toFileDescriptor(JavaLibCHelper.STDOUT);\\n\\n        assertThat(JavaLibCHelper.getfdFromDescriptor(descriptor)).isEqualTo(JavaLibCHelper.STDOUT);\\n    }\\n\\n    @Test\\n    void createsFileDescriptorFromWindowsHandleWhenAvailable() {\\n        try {\\n            FileDescriptor descriptor = JavaLibCHelper.toFileDescriptor(HANDLE.valueOf(HANDLE_VALUE));\\n\\n            assertThat(JavaLibCHelper.gethandle(descriptor).toPointer().address()).isEqualTo(HANDLE_VALUE);\\n        } catch (NullPointerException unsupported) {\\n            assertThat(unsupported).isInstanceOf(NullPointerException.class);\\n            assertThat(JavaLibCHelper.gethandle((FileDescriptor) null).toPointer().address()).isEqualTo(-1L);\\n        }\\n    }\\n\\n    @Test\\n    void getsDescriptorFromFileChannel() throws Exception {\\n        Path tempFile = Files.createTempFile(\\\"jnr-posix-file-channel\\\", \\\".tmp\\\");\\n        Files.writeString(tempFile, \\\"content\\\");\\n\\n        try (FileInputStream stream = new FileInputStream(tempFile.toFile())) {\\n            FileDescriptor descriptor = JavaLibCHelper.getDescriptorFromChannel(stream.getChannel());\\n\\n            assertThat(JavaLibCHelper.getfdFromDescriptor(descriptor)).isGreaterThanOrEqualTo(0);\\n        } finally 