          }
      }
  
      @Override
      public void close() throws SQLException {
          closed = true;
          closeCurrentResultSet();
          for (ResultSetImpl resultSet : resultSets) {
              if (resultSet != null &&  !resultSet.isClosed()) {
                  try {
                      resultSet.close();
                  } catch (Exception e) {
                      LOG.error("Failed to close result set", e);
                  }
              }
          }
      }
  
      @Override
