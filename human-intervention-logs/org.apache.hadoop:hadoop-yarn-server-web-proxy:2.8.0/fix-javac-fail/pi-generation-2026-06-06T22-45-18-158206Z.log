              this.filterName = name;
              this.filterClass = classname;
              this.parameters = new HashMap<>(parameters);
          }
  
          @Override
          public void addGlobalFilter(String name, String classname, Map<String, String> parameters) {
              this.globalFilterAdded = true;
          }
      }
  
