ories/forge_worktrees/6697-9d0074ae/tests/src/org.apache.hadoop/hadoop-yarn-server-web-proxy/2.8.0/build/classes/java/test/org_apache_hadoop/hadoop_yarn_server_web_proxy/Hadoop_yarn_server_web_proxyTest$EmptyServletInputStream.class\n/home/vjovanov/c/forge/forge1/graalvm-reachability-metadata/forge/local_repositories/forge_worktrees/6697-9d0074ae/tests/src/org.apache.hadoop/hadoop-yarn-server-web-proxy/2.8.0/build/classes/java/test/org_apache_hadoop/hadoop_yarn_server_web_proxy/Hadoop_yarn_server_web_proxyTest$TestAmFilterInitializer.class\n/home/vjovanov/c/forge/forge1/graalvm-reachability-metadata/forge/local_repositories/forge_worktrees/6697-9d0074ae/tests/src/org.apache.hadoop/hadoop-yarn-server-web-proxy/2.8.0/build/classes/java/test/org_apache_hadoop/hadoop_yarn_server_web_proxy/Hadoop_yarn_server_web_proxyTest$FixedApplicationReportResponse.class\n/home/vjovanov/c/forge/forge1/graalvm-reachability-metadata/forge/local_repositories/forge_worktrees/6697-9d0074ae/tests/src/org.apache.hadoop/hadoop-yarn-server-web-proxy/2.8.0/build/classes/java/test/org_apache_hadoop/hadoop_yarn_server_web_proxy/Hadoop_yarn_server_web_proxyTest$RecordingFilterChain.class\n/home/vjovanov/c/forge/forge1/graalvm-reachability-metadata/forge/local_repositories/forge_worktrees/6697-9d0074ae/tests/src/org.apache.hadoop/hadoop-yarn-server-web-proxy/2.8.0/build/classes/java/test/org_apache_hadoop/hadoop_yarn_server_web_proxy/Hadoop_yarn_server_web_proxyTest$BasicServletRequest.class\n/home/vjovanov/c/forge/forge1/graalvm-reachability-metadata/forge/local_repositories/forge_worktrees/6697-9d0074ae/tests/src/org.apache.hadoop/hadoop-yarn-server-web-proxy/2.8.0/build/tmp\n/home/vjovanov/c/forge/forge1/graalvm-reachability-metadata/forge/local_repositories/forge_worktrees/6697-9d0074ae/tests/src/org.apache.hadoop/hadoop-yarn-server-web-proxy/2.8.0/build/tmp/test\n/home/vjovanov/c/forge/forge1/graalvm-reachability-metadata/forge/local_repositories/forge_worktrees/6697-9d0074ae/tests/src/org.ap