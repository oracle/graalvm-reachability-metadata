ing callerFQCN, int level, String msg,\n--\nhuman-intervention-logs/org.slf4j:slf4j-log4j12:1.6.1/add-new-library-support/pi-generation-2026-05-05T09-03-52-825008Z.log-788-      case LocationAwareLogger.WARN_INT:\nhuman-intervention-logs/org.slf4j:slf4j-log4j12:1.6.1/add-new-library-support/pi-generation-2026-05-05T09-03-52-825008Z.log-789-        log4jLevel = Level.WARN;\nhuman-intervention-logs/org.slf4j:slf4j-log4j12:1.6.1/add-new-library-support/pi-generation-2026-05-05T09-03-52-825008Z.log-790-        break;\nhuman-intervention-logs/org.slf4j:slf4j-log4j12:1.6.1/add-new-library-support/pi-generation-2026-05-05T09-03-52-825008Z.log:791:      case LocationAwareLogger.ERROR_INT:\nhuman-intervention-logs/org.slf4j:slf4j-log4j12:1.6.1/add-new-library-support/pi-generation-2026-05-05T09-03-52-825008Z.log:792:        log4jLevel = Level.ERROR;\nhuman-intervention-logs/org.slf4j:slf4j-log4j12:1.6.1/add-new-library-support/pi-generation-2026-05-05T09-03-52-825008Z.log-793-        break;\nhuman-intervention-logs/org.slf4j:slf4j-log4j12:1.6.1/add-new-library-support/pi-generation-2026-05-05T09-03-52-825008Z.log-794-      default:\nhuman-intervention-logs/org.slf4j:slf4j-log4j12:1.6.1/add-new-library-support/pi-generation-2026-05-05T09-03-52-825008Z.log:795:        throw new IllegalStateException(\"Level number \" + level\nhuman-intervention-logs/org.slf4j:slf4j-log4j12:1.6.1/add-new-library-support/pi-generation-2026-05-05T09-03-52-825008Z.log-796-            + \" is not recognized.\");\nhuman-intervention-logs/org.slf4j:slf4j-log4j12:1.6.1/add-new-library-support/pi-generation-2026-05-05T09-03-52-825008Z.log-797-      }\nhuman-intervention-logs/org.slf4j:slf4j-log4j12:1.6.1/add-new-library-support/pi-generation-2026-05-05T09-03-52-825008Z.log-798-      logger.log(callerFQCN, log4jLevel, msg, t);\nhuman-intervention-logs/org.slf4j:slf4j-log4j12:1.6.1/add-new-library-support/pi-generation-2026-05-05T09-03-52-825008Z.log-799-    }\nhuman-intervention-logs/org.slf4j:slf4j-log