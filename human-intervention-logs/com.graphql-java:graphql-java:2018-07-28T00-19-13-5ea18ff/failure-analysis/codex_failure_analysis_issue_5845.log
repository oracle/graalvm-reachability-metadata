her/aether-util/index.json:5:    \\\"source-code-url\\\" : \\\"https://repo1.maven.org/maven2/org/eclipse/aether/aether-util/$version$/aether-util-$version$-sources.jar\\\",\\nmetadata/org.eclipse.aether/aether-util/index.json:6:    \\\"repository-url\\\" : \\\"https://git.eclipse.org/c/aether/aether-core.git\\\",\\nmetadata/org.eclipse.aether/aether-util/index.json:7:    \\\"test-code-url\\\" : \\\"https://repo1.maven.org/maven2/org/eclipse/aether/aether/$version$/aether-$version$-source-release.zip\\\",\\nmetadata/org.eclipse.aether/aether-util/index.json:8:    \\\"documentation-url\\\" : \\\"https://repo1.maven.org/maven2/org/eclipse/aether/aether-util/$version$/aether-util-$version$-javadoc.jar\\\",\\nmetadata/org.eclipse.aether/aether-util/index.json:9:    \\\"description\\\" : \\\"Aether Util provides utility classes that make it easier to work with the Eclipse Aether repository system. It includes helpers for artifacts, dependency graph filtering and transformation, listeners, repository authentication, proxy selection, and version handling.\\\",\\nmetadata/org.junit.platform/junit-platform-suite-api/index.json:5:    \\\"source-code-url\\\" : \\\"https://repo.maven.apache.org/maven2/org/junit/platform/junit-platform-suite-api/$version$/junit-platform-suite-api-$version$-sources.jar\\\",\\nmetadata/org.junit.platform/junit-platform-suite-api/index.json:6:    \\\"repository-url\\\" : \\\"https://github.com/junit-team/junit-framework\\\",\\nmetadata/org.junit.platform/junit-platform-suite-api/index.json:7:    \\\"test-code-url\\\" : \\\"https://github.com/junit-team/junit-framework/tree/r5.13.4/platform-tests/src/test/java/org/junit/platform/suite\\\",\\nmetadata/org.junit.platform/junit-platform-suite-api/index.json:8:    \\\"documentation-url\\\" : \\\"https://repo.maven.apache.org/maven2/org/junit/platform/junit-platform-suite-api/$version$/junit-platform-suite-api-$version$-javadoc.jar\\\",\\nmetadata/org.junit.platform/junit-platform-suite-api/index.json:9: