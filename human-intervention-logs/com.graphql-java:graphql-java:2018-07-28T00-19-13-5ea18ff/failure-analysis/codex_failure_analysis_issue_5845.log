:    \\\"repository-url\\\" : \\\"https://github.com/FasterXML/jackson-modules-java8\\\",\\nmetadata/com.fasterxml.jackson.datatype/jackson-datatype-jsr310/index.json:7:    \\\"test-code-url\\\" : \\\"https://github.com/FasterXML/jackson-modules-java8/tree/jackson-modules-java8-$version$/datetime/src/test\\\",\\nmetadata/com.fasterxml.jackson.datatype/jackson-datatype-jsr310/index.json:8:    \\\"documentation-url\\\" : \\\"https://repo.maven.apache.org/maven2/com/fasterxml/jackson/datatype/jackson-datatype-jsr310/$version$/jackson-datatype-jsr310-$version$-javadoc.jar\\\",\\nmetadata/com.fasterxml.jackson.datatype/jackson-datatype-jsr310/index.json:9:    \\\"description\\\" : \\\"Jackson Datatype JSR310 is an add-on module for Jackson that adds serialization and deserialization support for Java 8 Date and Time API types. It lets ObjectMapper handle java.time classes such as LocalDate, LocalDateTime, OffsetDateTime, and Instant using Jackson's standard module registration mechanism.\\\",\\nmetadata/org.sangria-graphql/sangria-marshalling-api_3/index.json:5:    \\\"source-code-url\\\" : \\\"https://repo1.maven.org/maven2/org/sangria-graphql/sangria-marshalling-api_3/$version$/sangria-marshalling-api_3-$version$-sources.jar\\\",\\nmetadata/org.sangria-graphql/sangria-marshalling-api_3/index.json:6:    \\\"repository-url\\\" : \\\"https://github.com/sangria-graphql/sangria-marshalling-api\\\",\\nmetadata/org.sangria-graphql/sangria-marshalling-api_3/index.json:7:    \\\"test-code-url\\\" : \\\"https://github.com/sangria-graphql/sangria-marshalling-api/tree/v$version$/src/test\\\",\\nmetadata/org.sangria-graphql/sangria-marshalling-api_3/index.json:8:    \\\"documentation-url\\\" : \\\"https://repo1.maven.org/maven2/org/sangria-graphql/sangria-marshalling-api_3/$version$/sangria-marshalling-api_3-$version$-javadoc.jar\\\",\\nmetadata/org.sangria-graphql/sangria-marshalling-api_3/index.json:9:    \\\"description\\\" : \\\"Sangria Marshalling API defines the common marshalling and unmarshalling abstractions used by Sangria GraphQL integrations. It lets JSON or other data-format modules plug into Sangria by converting GraphQL inputs and results to and from Scala values.\\\",\\nmetadata/org.sangria-graphql/sangria-marshalling-api_3/index.json:10:    \\\"language\\\" : {\\nmetadata/org.sangria-graphql/macro-visit_3/index.json:5:    \\\"source-code-url\\\" : \\\"https://repo1.maven.org/maven2/org/sangria-graphql/macro-visit_3/$version$/macro-visit_3-$version$-sources.jar\\\",\\nmetadata/org.sangria-graphql/macro-visit_3/index.json:6:    \\\"repository-url\\\" : \\\"https://github.com/sangria-graphql/macro-visit\\\",\\nmetadata/org.sangria-graphql/macro-visit_3/index.json:7:    \\\"test-code-url\\\" : \\\"https://github.com/sangria-graphql/macro-visit/tree/v$version$/src/test\\\",\\nmetadata/org.sangria-graphql/macro-visit_3/index.json:8:    \\\"documentation-url\\\" : \\\"https://repo1.maven.org/maven2/org/sangria-graphql/macro-visit_3/$version$/macro-visit_3-$version$-javadoc.jar\\\",\\nmetadata/org.sangria-graphql/macro-visit_3/index.json:9:    \\\"description\\\" : \\\"macro-visit is a Scala macro library that generates type-safe visitor code for sealed case-class hierarchies. It supports non-recursive traversal, immutable transformations, skipping or breaking traversal, and visiting supported collection and option fields, making it useful for AST processing.\\\",\\nmetadata/org.sangria-graphql/macro-visit_3/index.json:10:    \\\"language\\\" : {\\nmetadata/org.sangria-graphql/sangria-core_3/index.json:5:    \\\"source-code-url\\\" : \\\"https://repo1.maven.org/maven2/org/sangria-graphql/sangria-core_3/$version$/sangria-core_3-$version$-sources.jar\\\",\\nmetadata/org.sangria-graphql/sangria-core_3/index.json:6:    \\\"repository-url\\\" : \\\"https://github.com/sangria-graphql/sangria\\\",\\nmetadata/org.sangria-graphql/sangria-core_3/index.json:7:    \\\"test-code-url\\\" : \\\"https://github.com/sangria-graphql/sangria/tree/v$versi