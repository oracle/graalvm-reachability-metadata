ex.json:7:    \\\"test-code-url\\\" : \\\"https://github.com/reactor/reactor-netty/tree/v$version$/reactor-netty-core/src/test/java\\\",\\nmetadata/io.projectreactor.netty/reactor-netty-core/index.json:8:    \\\"documentation-url\\\" : \\\"https://repo.maven.apache.org/maven2/io/projectreactor/netty/reactor-netty-core/$version$/reactor-netty-core-$version$-javadoc.jar\\\",\\nmetadata/io.projectreactor.netty/reactor-netty-core/index.json:9:    \\\"description\\\" : \\\"Reactor Netty Core provides the shared reactive networking foundation used by Reactor Netty clients and servers. It builds on Netty and Reactor Core to offer non-blocking connection management, transport support, DNS/proxy handling, and common infrastructure for higher-level HTTP, TCP, and UDP components.\\\",\\nmetadata/org.eclipse.microprofile.openapi/microprofile-openapi-api/index.json:5:    \\\"source-code-url\\\" : \\\"https://repo.maven.apache.org/maven2/org/eclipse/microprofile/openapi/microprofile-openapi-api/$version$/microprofile-openapi-api-$version$-sources.jar\\\",\\nmetadata/org.eclipse.microprofile.openapi/microprofile-openapi-api/index.json:6:    \\\"repository-url\\\" : \\\"https://github.com/microprofile/microprofile-open-api\\\",\\nmetadata/org.eclipse.microprofile.openapi/microprofile-openapi-api/index.json:7:    \\\"test-code-url\\\" : \\\"https://repo.maven.apache.org/maven2/org/eclipse/microprofile/openapi/microprofile-openapi-tck/$version$/microprofile-openapi-tck-$version$-sources.jar\\\",\\nmetadata/org.eclipse.microprofile.openapi/microprofile-openapi-api/index.json:8:    \\\"documentation-url\\\" : \\\"https://repo.maven.apache.org/maven2/org/eclipse/microprofile/openapi/microprofile-openapi-api/$version$/microprofile-openapi-api-$version$-javadoc.jar\\\",\\nmetadata/org.eclipse.microprofile.openapi/microprofile-openapi-api/index.json:9:    \\\"description\\\" : \\\"MicroProfile OpenAPI API defines annotations, models, and SPI contracts that Java applications use to describe