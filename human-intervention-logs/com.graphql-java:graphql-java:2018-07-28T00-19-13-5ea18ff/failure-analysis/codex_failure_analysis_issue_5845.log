\\\" : \\\"https://repo1.maven.org/maven2/org/eclipse/aether/aether-impl/$version$/aether-impl-$version$-javadoc.jar\\\",\\nmetadata/org.eclipse.aether/aether-impl/index.json:9:    \\\"description\\\" : \\\"Aether Implementation provides the default services that implement Eclipse Aether's repository system. It handles dependency collection and resolution, artifact and metadata installation and deployment, repository layout selection, and integration points for service locators and dependency injection.\\\",\\nmetadata/com.tunnelvisionlabs/antlr4-annotations/index.json:5:    \\\"source-code-url\\\" : \\\"https://repo.maven.apache.org/maven2/com/tunnelvisionlabs/antlr4-annotations/$version$/antlr4-annotations-$version$-sources.jar\\\",\\nmetadata/com.tunnelvisionlabs/antlr4-annotations/index.json:6:    \\\"repository-url\\\" : \\\"https://github.com/antlr/antlr4\\\",\\nmetadata/com.tunnelvisionlabs/antlr4-annotations/index.json:7:    \\\"test-code-url\\\" : \\\"N/A\\\",\\nmetadata/com.tunnelvisionlabs/antlr4-annotations/index.json:8:    \\\"documentation-url\\\" : \\\"https://repo.maven.apache.org/maven2/com/tunnelvisionlabs/antlr4-annotations/$version$/antlr4-annotations-$version$-javadoc.jar\\\",\\nmetadata/com.tunnelvisionlabs/antlr4-annotations/index.json:9:    \\\"description\\\" : \\\"ANTLR 4 Runtime Annotations provides the NotNull and Nullable annotations used by the ANTLR 4 Java runtime to describe nullability contracts. It also includes an annotation processor for checking nullability usage during Java compilation.\\\",\\nmetadata/io.projectreactor.netty/reactor-netty-core/index.json:5:    \\\"source-code-url\\\" : \\\"https://repo.maven.apache.org/maven2/io/projectreactor/netty/reactor-netty-core/$version$/reactor-netty-core-$version$-sources.jar\\\",\\nmetadata/io.projectreactor.netty/reactor-netty-core/index.json:6:    \\\"repository-url\\\" : \\\"https://github.com/reactor/reactor-netty\\\",\\nmetadata/io.projectreactor.netty/reactor-netty-core/index.js