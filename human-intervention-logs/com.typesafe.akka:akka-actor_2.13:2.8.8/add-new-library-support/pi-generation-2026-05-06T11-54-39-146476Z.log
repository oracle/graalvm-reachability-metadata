[tool-call] delta {"path":"tests/src/com.typesafe.akka/akka-actor_2.13/2.8.8/src/test/scala/com_typesafe_akka/akka_actor_2_13/ManifestInfoTest.scala","edits":[{"oldText":"package com_typesafe_akka.akka_actor_2_13\n\nimport akka.Version\nimport akka.actor.ActorSystem\nimport akka.util.ManifestInfo\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\n\nimport scala.concurrent.Await\nimport scala.concurrent.duration.DurationInt\n\nclass ManifestInfoTest {\n  @Test\n  def discoversAkkaArtifactVersionsFromClasspathManifests(): Unit = {\n    withActorSystem(\"manifest-info\") { system: ActorSystem =>\n      val manifestInfo: ManifestInfo = ManifestInfo.get(system)\n\n      assertThat(manifestInfo.versions.contains(\"akka-actor\")).isTrue()\n      assertThat(manifestInfo.versions(\"akka-actor\").toString).isEqualTo(Version.current)\n      assertThat(manifestInfo.checkSameVersion(\"Akka\", Seq(\"akka-actor\"), logWarning = false)).isTrue()\n    }\n  }\n\n  private def withActorSystem(name: String)(body: ActorSystem => Unit): Unit = {\n    val system: ActorSystem = ActorSystem(name)\n    try {\n      body(system)\n    } finally {\n      Await.result(system.terminate(), 10.seconds)\n    }\n  }\n}\n","newText":"package com_typesafe_akka.akka_actor_2_13\n\nimport java.net.URL\nimport java.nio.charset.StandardCharsets\nimport java.nio.file.Files\nimport java.nio.file.Path\nimport java.util.Collections\nimport java.util.Enumeration\n\nimport akka.Version\nimport akka.actor.ActorSystem\nimport akka.actor.ExtendedActorSystem\nimport akka.util.ManifestInfo\nimport com.typesafe.config.ConfigFactory\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\n\nimport scala.concurrent.Await\nimport scala.concurrent.duration.DurationInt\n\nclass ManifestInfoTest {\n  @Test\n  def discoversAkkaArtifactVersionsFromConfiguredClassLoaderManifests(): Unit = {\n    val manifestPath: Path = Files.createTempFile(\"akka-manifest-info\", \".MF\")\n    Files.write(manifestPath, akkaManifestContent.getBytes(StandardCharsets.UTF_8))\n\n    try {\n      val classLoader: ClassLoader = new ManifestOnlyClassLoader(getClass.getClassLoader, manifestPath.toUri.toURL)\n\n      withActorSystem(\"manifest-info\", classLoader) { system: ActorSystem =>\n        val manifestInfo: ManifestInfo = new ManifestInfo(system.asInstanceOf[ExtendedActorSystem])\n\n        assertThat(manifestInfo.versions.contains(\"akka-actor\")).isTrue()\n        assertThat(manifestInfo.versions(\"akka-actor\").toString).isEqualTo(Version.current)\n        assertThat(manifestInfo.checkSameVersion(\"Akka\", Seq(\"akka-actor\"), logWarning = false)).isTrue()\n      }\n    } finally {\n      Files.deleteIfExists(manifestPath)\n    }\n  }\n\n  private def akkaManifestContent: String = {\n    s\"\"\"Manifest-Version: 1.0\n       |Implementation-Title: akka-actor\n       |Implementation-Vendor-Id: com.typesafe.akka\n       |Implementation-Version: ${Version.current}\n       |\n       |\"\"\".stripMargin\n  }\n\n  private def withActorSystem(name: String, classLoader: ClassLoader)(body: ActorSystem => Unit): Unit = {\n    val system: ActorSystem = ActorSystem(name, ConfigFactory.empty(), classLoader)\n    try {\n      body(system)\n    } finally {\n      Await.result(system.terminate(), 10.seconds)\n    }\n  }\n}\n\nclass ManifestOnlyClassLoader(parent: ClassLoader, manifestUrl: URL) extends ClassLoader(parent) {\n  override def getResources(name: String): Enumeration[URL] = {\n    if (name == \"META-INF/MANIFEST.MF\") {\n      Collections.enumeration(Collections.singletonList(manifestUrl))\n    } else {\n      super.getResources(name)\n    }\n  }\n}\n"}]}
