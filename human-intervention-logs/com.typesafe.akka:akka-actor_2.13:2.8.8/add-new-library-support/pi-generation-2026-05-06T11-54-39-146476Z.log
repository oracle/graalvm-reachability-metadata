onsFromClasspathManifests(): Unit = {\\n    withActorSystem(\\\"manifest-info\\\") { system: ActorSystem =>\\n      val manifestInfo: ManifestInfo = ManifestInfo.get(system)\\n\\n      assertThat(manifestInfo.versions.contains(\\\"akka-actor\\\")).isTrue()\\n      assertThat(manifestInfo.versions(\\\"akka-actor\\\").toString).isEqualTo(Version.current)\\n      assertThat(manifestInfo.checkSameVersion(\\\"Akka\\\", Seq(\\\"akka-actor\\\"), logWarning = false)).isTrue()\\n    }\\n  }\\n\\n  private def withActorSystem(name: String)(body: ActorSystem => Unit): Unit = {\\n    val system: ActorSystem = ActorSystem(name)\\n    try {\\n      body(system)\\n    } finally {\\n      Await.result(system.terminate(), 10.seconds)\\n    }\\n  }\\n}\\n\"}"}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 642, "output": 792, "cacheRead": 26624, "cacheWrite": 0, "totalTokens": 28058, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778068458073, "responseId": "resp_0c2f72ae2b6870480169fb2bea85388196a70c6d8cea8ea7eb"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_iov8S5pUJ487Sj90jEoQeQNa|fc_0c2f72ae2b6870480169fb2befcd0881968d669a660b72af62", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1231 bytes to tests/src/com.typesafe.akka/akka-actor_2.13/2.8.8/src/test/scala/com_typesafe_akka/akka_actor_2_13/ManifestInfoTest.scala"}], "isError": false, "timestamp": 1778068468168}]}
