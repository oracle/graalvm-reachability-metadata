  1073:    dns {
  1074:      # Fully qualified config path which holds the dispatcher configuration
  1075:      # for the manager and resolver router actors.
  1076:      # For actual router configuration see akka.actor.deployment./IO-DNS/*
  1077:      dispatcher = "akka.actor.internal-dispatcher"
  1078:
  1079:      # Name of the subconfig at path akka.io.dns, see inet-address below
  1080:      #
  1081:      # Change to `async-dns` to use the new "native" DNS resolver,
  1082:      # which is also capable of resolving SRV records.
  1083:      resolver = "inet-address"
  1084:
  1085:      # To-be-deprecated DNS resolver implementation which uses the Java InetAddress to resolve DNS records.
  1086:      # To be replaced by `akka.io.dns.async` which implements the DNS protocol natively and without blocking (which InetAddress does)
  1087:      inet-address {
  1088:        # Must implement akka.io.DnsProvider
  1089:        provider-object = "akka.io.InetAddressDnsProvider"
  1090:
  1091:        # To set the time to cache name resolutions
  1092:        # Possible values:
  1093:        # default: sun.net.InetAddressCachePolicy.get() and getNegative()
  1094:        # forever: cache forever
  1095:        # never: no caching
  1096:        # n [time unit]: positive timeout with unit, for example 30s
  1097:        positive-ttl = default
  1098:        negative-ttl = default
  1099:
  1100:        # How often to sweep out expired cache entries.
  1101:        # Note that this interval has nothing to do with TTLs
  1102:        cache-cleanup-interval = 120s
  1103:      }
  1104:
  1105:      async-dns {
  1106:        provider-object = "akka.io.dns.internal.AsyncDnsProvider"
  1107:
  1108:        # Set upper bound for caching successfully resolved dns entries
  1109:        # if the DNS record has a smaller TTL value than the setting that
  1110:        # will be used. Default is to use the record TTL with no cap.
  1111:        # Possible values:
  1112:        # forever: always use the minimum TTL from the found records
  1113:        # never: never cache
  1114:        # n [time unit] = cap the caching to this value
  1115:        positive-ttl = forever
  1116:
  1117:        # Set how long the fact that a DNS record could not be found is
  1118:        # cached. If a new resolution is done while the fact is cached it will
  1119:        # be failed and not result in an actual DNS resolution. Default is
  1120:        # to never cache.
  1121:        # Possible values:
  1122:        # never: never cache
  1123:        # forever: cache a missing DNS record forever (you probably will not want to do this)
  1124:        # n [time unit] = cache for this long
  1125:        negative-ttl = never
  1126:
  1127:        # Configures nameservers to query during DNS resolution.
  1128:        # Defaults to the nameservers that would be used by the JVM by default.
  1129:        # Set to a list of IPs to override the servers, e.g. [ "8.8.8.8", "8.8.4.4" ] for Google's servers
  1130:        # If multiple are defined then they are tried in order until one responds
  1131:        nameservers = default
  1132:
  1133:        # The time that a request is allowed to live before being discarded
  1134:        # given no reply. The lower bound of this should always be the amount
  1135:        # of time to reasonably expect a DNS server to reply within.
  1136:        # If multiple name servers are provided then each gets this long to response before trying
  1137:        # the next one
  1138:        resolve-timeout = 5s
  1139:
  1140:        # How often to sweep out expired cache entries.
  1141:        # Note that this interval has nothing to do with TTLs
  1142:        cache-cleanup-interval = 120s
  1143:
  1144:        # Configures the list of search domains.
  1145:        # Defaults to a system dependent lookup (on Unix like OSes, will attempt to parse /etc/resolv.conf, on
  1146:        # other platforms, will not make any attempt to lookup the search domains). Set to a single domain, or
  1147:        # a list of domains, eg, [ "example.com", "example.net" ].
  1148:        search-domains = default
  1149:
  1150:        # Any hosts that have a number of dots less than this will not be looked up directly, instead, a search on
  1151:        # the search domains will be tried first. This corresponds to the ndots option in /etc/resolv.conf, see
  1152:        # https://linux.die.net/man/5/resolver for more info.
  1153:        # Defaults to a system dependent lookup (on Unix like OSes, will attempt to parse /etc/resolv.conf, on
  1154:        # other platforms, will default to 1).
  1155:        ndots = default
