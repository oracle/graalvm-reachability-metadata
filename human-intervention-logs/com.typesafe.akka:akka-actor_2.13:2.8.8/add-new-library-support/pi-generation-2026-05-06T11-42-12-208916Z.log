blicdomain/zero/1.0/>.\n */\npackage com_typesafe_akka.akka_actor_2_13\n\nimport java.io.ByteArrayInputStream\nimport java.io.ByteArrayOutputStream\nimport java.io.ClassNotFoundException\nimport java.io.ObjectOutputStream\nimport java.util.ArrayList\n\nimport akka.util.ClassLoaderObjectInputStream\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\n\nclass ClassLoaderObjectInputStreamTest {\n  @Test\n  def deserializesUsingProvidedClassLoader(): Unit = {\n    val expected: ArrayList[String] = serializableList()\n    val bytes: Array[Byte] = serialize(expected)\n\n    val actual: AnyRef = deserialize(bytes, Thread.currentThread().getContextClassLoader)\n\n    assertThat(actual).isEqualTo(expected)\n  }\n\n  @Test\n  def fallsBackToObjectInputStreamClassResolutionWhenProvidedClassLoaderCannotLoadClass(): Unit = {\n    val expected: ArrayList[String] = serializableList()\n    val bytes: Array[Byte] = serialize(expected)\n    val rejectingClassLoader: ClassLoader = new ClassLoader(null) {\n      @throws[ClassNotFoundException]\n      override protected def loadClass(name: String, resolve: Boolean): Class[_] = {\n        throw new ClassNotFoundException(name)\n      }\n    }\n\n    val actual: AnyRef = deserialize(bytes, rejectingClassLoader)\n\n    assertThat(actual).isEqualTo(expected)\n  }\n\n  private def serializableList(): ArrayList[String] = {\n    val list: ArrayList[String] = new ArrayList[String]()\n    list.add(\"akka\")\n    list.add(\"serialization\")\n    list\n  }\n\n  private def serialize(value: AnyRef): Array[Byte] = {\n    val bytes: ByteArrayOutputStream = new ByteArrayOutputStream()\n    val output: ObjectOutputStream = new ObjectOutputStream(bytes)\n    try {\n      output.writeObject(value)\n    } finally {\n      output.close()\n    }\n    bytes.toByteArray\n  }\n\n  private def deserialize(bytes: Array[Byte], classLoader: ClassLoader): AnyRef = {\n    val input: ClassLoaderObjectInputStream = new ClassLoaderObje