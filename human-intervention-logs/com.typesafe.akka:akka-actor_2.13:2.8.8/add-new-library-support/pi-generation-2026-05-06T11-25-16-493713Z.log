rseString(\"\"\"\n      akka.io.tcp.direct-buffer-size = 16 B\n      akka.io.tcp.direct-buffer-pool-limit = 0\n      \"\"\")\n\n    withActorSystem(\"direct-byte-buffer-pool\", config) { system: ActorSystem =>\n      val bufferPool: BufferPool = Tcp(system).bufferPool\n      val buffer = bufferPool.acquire()\n\n      assertThat(buffer.isDirect).isTrue()\n      assertThat(buffer.capacity()).isEqualTo(16)\n\n      bufferPool.release(buffer)\n    }\n  }\n\n  private def withActorSystem(name: String, config: Config)(body: ActorSystem => Unit): Unit = {\n    val system: ActorSystem = ActorSystem(name, config)\n    try {\n      body(system)\n    } finally {\n      Await.result(system.terminate(), 10.seconds)\n    }\n  }\n}\n}\n\npackage sun.misc {\nclass Cleaner {\n  def clean(): Unit = ()\n}\n}\n"}, "partialJson": "{\"path\":\"tests/src/com.typesafe.akka/akka-actor_2.13/2.8.8/src/test/scala/com_typesafe_akka/akka_actor_2_13/DirectByteBufferPoolTest.scala\",\"content\":\"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage com_typesafe_akka.akka_actor_2_13 {\\n\\nimport akka.actor.ActorSystem\\nimport akka.io.BufferPool\\nimport akka.io.Tcp\\nimport com.typesafe.config.Config\\nimport com.typesafe.config.ConfigFactory\\nimport org.assertj.core.api.Assertions.assertThat\\nimport org.junit.jupiter.api.Test\\n\\nimport scala.concurrent.Await\\nimport scala.concurrent.duration.DurationInt\\n\\nclass DirectByteBufferPoolTest {\\n  @Test\\n  def releasesDirectTcpBufferWhenPoolIsFull(): Unit = {\\n    val config: Config = ConfigFactory.parseString(\\\"\\\"\\\"\\n      akka.io.tcp.direct-buffer-size = 16 B\\n      akka.io.tcp.direct-buffer-pool-limit = 0\\n      \\\"\\\"\\\")\\n\\n    withActorSystem(\\\"direct-byte-buffer-pool\\\", config) { system: ActorSystem =>\\n      val bufferPool: BufferPool = Tcp(system)