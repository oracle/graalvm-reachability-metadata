   *
   * You should have received a copy of the CC0 legalcode along with this
   * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.
   */
  plugins {
      id "org.graalvm.internal.tck"
      id "scala"
  }
  
  String libraryVersion = tck.testedLibraryVersion.get()
  
  dependencies {
      testImplementation "com.typesafe.akka:akka-actor_2.13:$libraryVersion"
      testImplementation 'org.assertj:assertj-core:3.22.0'
      testImplementation 'org.scala-lang:scala-library:2.13.16'
      testImplementation 'org.scala-lang:scala-compiler:2.13.16'
  }
  
  java {
      toolchain {
          languageVersion = JavaLanguageVersion.of(21)
      }
  }
  
  def jdkUnsupportedPatchDir = layout.buildDirectory.dir('jdkUnsupportedPatch')
  
  def prepareJdkUnsupportedPatch = tasks.register('prepareJdkUnsupportedPatch', Sync) {
      dependsOn tasks.named('compileTestScala')
      from(sourceSets.test.output.classesDirs) {
          include 'sun/misc/**'
      }
      into jdkUnsupportedPatchDir
  }
  
  tasks.withType(Test).configureEach {
      dependsOn prepareJdkUnsupportedPatch
      exclude 'sun/misc/**'
      jvmArgs '--add-exports=java.base/sun.net.dns=ALL-UNNAMED'
      jvmArgs '--add-opens=java.base/java.nio=ALL-UNNAMED'
      doFirst {
          jvmArgs "--patch-module=jdk.unsupported=${jdkUnsupportedPatchDir.get().asFile.absolutePath}"
      }
  }
  
  tasks.matching { it.name == 'nativeTestCompile' }.configureEach {
      dependsOn prepareJdkUnsupportedPatch
  }
  
  graalvmNative {
      binaries.configureEach {
          buildArgs.add('--add-exports=java.base/sun.net.dns=ALL-UNNAMED')
          buildArgs.add('--add-opens=java.base/java.nio=ALL-UNNAMED')
          buildArgs.add("--patch-module=jdk.unsupported=${jdkUnsupportedPatchDir.get().asFile.absolutePath}")
      }
  
      agent {
          defaultMode = "conditional"
          modes {
              conditional {
                  userCodeFilterPath = "user-code-filter.json"
              }
          }
      }
  }
