  import nl.adaptivity.xmlutil.dom2.ownerElement
  import nl.adaptivity.xmlutil.dom2.parentNode
  import nl.adaptivity.xmlutil.dom2.prefix
  import nl.adaptivity.xmlutil.dom2.previousSibling
