:274:                JsonNode coveredCallsNode = node.get(\"coveredCalls\");\n../4649-a9dbf980/tests/tck-build-logic/src/main/java/org/graalvm/internal/tck/stats/LibraryStatsModels.java:275:                JsonNode coverageRatioNode = node.get(\"coverageRatio\");\n../4649-a9dbf980/tests/tck-build-logic/src/main/java/org/graalvm/internal/tck/stats/LibraryStatsModels.java:278:                if (coveredCallsNode != null && coverageRatioNode != null && totalCallsNode != null && breakdownNode != null) {\n../4649-a9dbf980/COVERAGE.md:3:![Coverage over time](https://raw.githubusercontent.com/oracle/graalvm-reachability-metadata/stats/coverage/latest/metrics-over-time.svg)\n../4649-a9dbf980/tests/tck-build-logic/src/main/groovy/org.graalvm.internal.tck-harness.gradle:219:    task.setDescription(\"Generates JaCoCo coverage reports for all subprojects (runs tests first)\")\n../4649-a9dbf980/tests/tck-build-logic/src/main/groovy/org.graalvm.internal.tck-harness.gradle:311:    task.setDescription(\"Builds native tests and prints generated dynamic-access JSON report files for matching coordinates\")\n../4649-a9dbf980/tests/tck-build-logic/src/main/groovy/org.graalvm.internal.tck-harness.gradle:316:    task.setDescription(\"Generates a per-class dynamic-access coverage report for matching coordinates\")\n../4649-a9dbf980/tests/tck-build-logic/src/main/groovy/org.graalvm.internal.tck-harness.gradle:326:    task.setDescription(\"Generates current README metrics data, coverage Markdown, and updates README metrics history\")\n../4649-a9dbf980/tests/tck-build-logic/src/main/groovy/org.graalvm.internal.tck-harness.gradle:342:    task.setDescription(\"Resolves an external Maven coordinate and reports preserve/track dynamic-access totals\")\n../4649-a9dbf980/tests/tck-build-logic/src/main/java/org/graalvm/internal/tck/stats/LibraryStatsSchemaValidator.java:472:                    locationPrefix + \":dynamicAccess.coverageRatio\",\n../4649-a9dbf980/tests/tck-build-logic/src/main/java/org/graalvm/internal/tck/stats/LibraryStatsSchemaValidator.java:473:                    dynamicAccess.coverageRatio(),\n../4649-a9dbf980/tests/tck-build-logic/src/main/java/org/graalvm/internal/tck/stats/LibraryStatsSchemaValidator.java:474:                    dynamicAccess.coveredCalls(),\n../4649-a9dbf980/tests/tck-build-logic/src/main/java/org/graalvm/internal/tck/stats/LibraryStatsSchemaValidator.java:480:                    locationPrefix + \":dynamicAccess.breakdown.\" + reportType + \".coverageRatio\",\n../4649-a9dbf980/tests/tck-build-logic/src/main/java/org/graalvm/internal/tck/stats/LibraryStatsSchemaValidator.java:481:                    breakdown.coverageRatio(),\n../4649-a9dbf980/tests/tck-build-logic/src/main/java/org/graalvm/internal/tck/stats/LibraryStatsSchemaValidator.java:482:                    breakdown.coveredCalls(),\n../4649-a9dbf980/tests/tck-build-logic/src/main/java/org/graalvm/internal/tck/stats/LibraryStatsSchemaValidator.java:503:        long expectedTotal = metric.covered() + metric.missed();\n../4649-a9dbf980/tests/tck-build-logic/src/main/java/org/graalvm/internal/tck/stats/LibraryStatsSchemaValidator.java:506:                    + \".total: expected \" + expectedTotal + \" from covered+missed but found \" + metric.total());\n../4649-a9dbf980/tests/tck-build-logic/src/main/java/org/graalvm/internal/tck/stats/LibraryStatsSchemaValidator.java:512:                metric.covered(),\n../4649-a9dbf980/tests/tck-build-logic/src/main/java/org/graalvm/internal/tck/stats/LibraryStatsSchemaValidator.java:522:            long covered,\n../4649-a9dbf980/tests/tck-build-logic/src/main/java/org/graalvm/internal/tck/stats/LibraryStatsSchemaValidator.java:527:        BigDecimal expectedRatio = expectedRatio(covered, total, treatZeroTotalAsFullCoverage);\n../4649-a9dbf980/tests/tck-build-logic/src/main/java/org/graalvm/internal/tck/stats/LibraryStatsSchemaValidator.java:531:                    + \" from covered=\" + covered + \", total=\" + total\n../4649-a9dbf980/tests/tck-build-logic/src/main/java/org/graalvm/internal/tck/stats/LibraryStatsSchemaValidator.java:536:    private static BigDecimal expectedRatio(long covered, long total, boolean treatZeroTotalAsFullCoverage) {\n../4649-a9dbf980/tests/tck-build-logic/src/main/java/org/graalvm/internal/tck/stats/LibraryStatsSchemaValidator.java:543:        return BigDecimal.valueOf(covered)\n../4649-a9dbf980/skills/review-fixes-java-run-fail/SKILL.md:3:description: Review pull requests with the `fixes-java-run-fail` label in graalvm-reachability-metadata. Use when asked to review or triage a PR described as `fixes-java-run-fail` or one that fixes Java/JVM runtime test failures for an existing library version update. Focus on validating the Java runtime fix, keeping the diff scoped, and ensuring dynamic-access coverage does not drop between the previously tested version and the new version.\n../4649-a9dbf980/skills/review-fixes-java-run-fail/SKILL.md:9:These PRs repair tests, dependencies, or narrow runtime setup after an existing library version compiles, but the JVM-based test fails when it runs. Review them more lightly than `library-new-request` PRs: the library already exists, so the goal is to restore Java runtime behavior for the new version while preserving meaningful test and dynamic-access coverage.\n../4649-a9dbf980/skills/review-fixes-java-run-fail/SKILL.md:17:- Be more relaxed than `library-new-request`: do not reject only because a test resembles older coverage, stays in an existing package layout, or contains compatibility branches for multiple supported versions.\n../4649-a9dbf980/skills/review-fixes-java-run-fail/SKILL.md:18:- Do not accept changes that remove meaningful test coverage just to make `java` pass.\n../4649-a9dbf980/skills/review-fixes-java-run-fail/SKILL.md:19:- Native-image execution should remain enabled by default when the repaired test reaches the native lane. Do not accept changes that skip or short-circuit native-image behavior. When a test exercises behavior that fundamentally relies on open-ended dynamic class loading that native image cannot support, such as loading classes, JARs, generated bytecode, plugin implementations, or other class definitions that are only discovered after the native executable is built, accept the `NativeImageSupport.isUnsupportedFeatureError(e)` catch pattern from `org.graalvm.internal.tck`. Reject raw native-only skips, bare `catch (Error)` blocks, and use of this pattern for ordinary reflection, resources, serialization, dynamic proxies, JNI, or missing reachability metadata.\n../4649-a9dbf980/skills/review-fixes-java-run-fail/SKILL.md:20:- Treat dynamic-access coverage preservation as the main quality gate. The new version should not report lower dynamic-access coverage than the previously tested version unless the PR gives a concrete, credible reason.\n../4649-a9dbf980/skills/review-fixes-java-run-fail/SKILL.md:21:- For numeric gates, compare the reported evidence as-is. Do not inspect generation filters, agent configuration, or metadata contents to second-guess why dynamic-access or metadata-count numbers are what they are.\n../4649-a9dbf980/skills/review-fixes-java-run-fail/SKILL.md:51:   - Compatibility branches are acceptable when they keep older and newer tested versions covered by the same test.\n../4649-a9dbf980/skills/review-fixes-java-run-fail/SKILL.md:56:4. Check dynamic-access coverage across versions.\n../4649-a9dbf980/skills/review-fixes-java-run-fail/SKILL.md:58:   - Compare `dynamicAccess.coverageRatio`, `coveredCalls`, `totalCalls`, and the `dynamicAccess.breakdown` entries for reflection, resources, proxies, serialization, JNI, or any other present report type.\n../4649-a9dbf980/skills/review-fixes-java-run-fail/SKILL.md:59:   - Do not use `user-code-filter.json`, agent configuration, or metadata file contents to argue that the reported dynamic-access values are not comparable. Use the stats values as reported unless the stats are missing or stale.\n../4649-a9dbf980/skills/review-fixes-java-run-fail/SKILL.md:60:   - A lower `coverageRatio` or lower `coveredCalls` for the new version is blocking unless the total dynamic-access surface changed and the PR explains why the reduction is expected.\n../4649-a9dbf980/skills/review-fixes-java-run-fail/SKILL.md:61:   - If `totalCalls` increases while `coveredCalls` stays flat or the ratio drops, ask for additional test coverage or metadata unless the uncovered calls are clearly outside the library behavior under test.\n../4649-a9dbf980/skills/review-fixes-java-run-fail/SKILL.md:69:   - Do not require an exact match. Differences are normal when upstream APIs move, generated metadata is cleaned up, or dynamic-access totals change.\n../4649-a9dbf980/skills/review-fixes-java-run-fail/SKILL.md:71:   - When the new total is below 25% of the original and the tests and dynamic-access stats still claim comparable coverage, ask for restored metadata or a concrete explanation of the API/runtime-surface change.\n../4649-a9dbf980/skills/review-fixes-java-run-fail/SKILL.md:77:   - Prefer seeing the full target `test` lane green because a Java runtime fix can still reduce native-image coverage.\n../4649-a9dbf980/skills/review-fixes-java-run-fail/SKILL.md:79:   - If CI is flaky but the diff and coverage comparison are sound, ask for a rerun instead of blocking on speculation.\n../4649-a9dbf980/skills/review-fixes-java-run-fail/SKILL.md:87:- Dynamic-access coverage does not drop between the previous and new tested versions, or any apparent drop is convincingly explained by a changed upstream API/runtime surface.\n../4649-a9dbf980/skills/review-fixes-java-run-fail/SKILL.md:95:- Dynamic-access coverage drops without a credible explanation and replacement coverage.\n../4649-a9dbf980/skills/review-fixes-java-run-fail/SKILL.md:103:- The API or runtime behavior change is plausible but the PR does not explain why a coverage drop is expected.\n../4649-a9dbf980/skills/review-fixes-java-run-fail/SKILL.md:110:- For coverage drops: say that dynamic-access coverage must not regress between tested versions, cite the old and new values, and ask for either restored coverage or a concrete explanation.\n../4649-a9dbf980/skills/review-fixes-java-run-fail/SKILL.md:112:- For deleted or bypassed coverage: say that the PR fixes Java runtime execution by removing coverage and should instead adapt the test to the new runtime behavior.\n../4649-a9dbf980/skills/review-fixes-java-run-fail/SKILL.md:114:- For native skips that does not depend on the open-ended dynamic class loading: say that the PR avoids the failing native path instead of fixing it, so it does not demonstrate native-image runtime coverage.\n../4649-a9dbf980/skills/review-fixes-java-run-fail/SKILL.md:163:        // Expected: Native Image cannot load plugin JARs discovered after build.\n../4649-a9dbf980/tests/tck-build-logic/src/main/java/org/graalvm/internal/tck/stats/ReadmeBadgeSummarySupport.java:167:            Path coverageFile,\n../4649-a9dbf980/tests/tck-build-logic/src/main/java/org/graalvm/internal/tck/stats/ReadmeBadgeSummarySupport.java:173:                coverageFile,\n../4649-a9dbf980/tests/tck-build-logic/src/main/java/org/graalvm/internal/tck/stats/ReadmeBadgeSummarySupport.java:175:                \"Failed to write coverage Markdown to \"\n../4649-a9dbf980/tests/tck-build-logic/src/main/java/org/graalvm/internal/tck/stats/ReadmeBadgeSummarySupport.java:192:        markdown.append(\"| Library | Description | Dynamic access coverage |\\n\");\n../4649-a9dbf980/tests/tck-build-logic/src/main/java/org/graalvm/internal/tck/stats/ReadmeBadgeSummarySupport.java:207:        int coverageStatsArtifacts = libraryStats.entries() == null ? 0 : libraryStats.entries().size();\n../4649-a9dbf980/tests/tck-build-logic/src/main/java/org/graalvm/internal/tck/stats/ReadmeBadgeSummarySupport.java:228:                                dynamicAccessCoveredCalls += versionStats.dynamicAccess().coveredCalls();\n../4649-a9dbf980/tests/tck-build-logic/src/main/java/org/graalvm/internal/tck/stats/ReadmeBadgeSummarySupport.java:235:                            testedLinesOfCode += Math.toIntExact(versionStats.libraryCoverage().line().covered());\n../4649-a9dbf980/tests/tck-build-logic/src/main/java/org/graalvm/internal/tck/stats/ReadmeBadgeSummarySupport.java:250:        return new StatsMetrics(dynamicAccessCallCoveragePercent, coverageStatsArtifacts, testedLinesOfCode);\n../4649-a9dbf980/tests/tck-build-logic/src/main/java/org/graalvm/internal/tck/stats/ReadmeBadgeSummarySupport.java:366:        long coveredCalls = 0;\n../4649-a9dbf980/tests/tck-build-logic/src/main/java/org/graalvm/internal/tck/stats/ReadmeBadgeSummarySupport.java:376:                ratioSum = ratioSum.add(versionStats.dynamicAccess().coverageRatio());\n../4649-a9dbf980/tests/tck-build-logic/src/main/java/org/graalvm/internal/tck/stats/ReadmeBadgeSummarySupport.java:378:                coveredCalls += versionStats.dynamicAccess().coveredCalls();\n../4649-a9dbf980/tests/tck-build-logic/src/main/java/org/graalvm/internal/tck/stats/ReadmeBadgeSummarySupport.java:387:        BigDecimal coveragePercent;\n../4649-a9dbf980/tests/tck-build-logic/src/main/java/org/graalvm/internal/tck/stats/ReadmeBadgeSummarySupport.java:389:            coveragePercent = BigDecimal.valueOf(coveredCalls)\n../4649-a9dbf980/tests/tck-build-logic/src/main/java/org/graalvm/internal/tck/stats/ReadmeBadgeSummarySupport.java:394:            coveragePercent = ratioSum\n../4649-a9dbf980/tests/tck-build-logic/src/main/java/org/graalvm/internal/tck/stats/ReadmeBadgeSummarySupport.java:399:        return new DynamicAccessCoverage(coveragePercent, coveredCalls, totalCalls, true);\n../4649-a9dbf980/tests/tck-build-logic/src/main/java/org/graalvm/internal/tck/stats/ReadmeBadgeSummarySupport.java:444:                        \"dynamic-access\",\n../4649-a9dbf980/tests/tck-build-logic/src/main/java/org/graalvm/internal/tck/stats/ReadmeBadgeSummarySupport.java:445:                        \"Dynamic access coverage\",\n../4649-a9dbf980/tests/tck-build-logic/src/main/java/org/graalvm/internal/tck/stats/ReadmeBadgeSummarySupport.java:446:                        \"Dynamic-access call coverage across repository metadata\",\n../4649-a9dbf980/tests/tck-build-logic/src/main/java/org/graalvm/internal/tck/stats/ReadmeBadgeSummarySupport.java:456:                        \"Covered lines reported across library coverage stats\",\n../4649-a9dbf980/tests/tck-build-logic/src/main/java/org/graalvm/internal/tck/stats/ReadmeBadgeSummarySupport.java:479:        svg.append(\"  <desc id=\\\"graph-desc\\\">A four-panel coverage dashboard showing libraries supported, tested library versions, dynamic access coverage, and tested lines of code over time.</desc>\\n\");\n../4649-a9dbf980/tests/tck-build-logic/src/main/java/org/graalvm/internal/tck/stats/ReadmeBadgeSummarySupport.java:890:    private static String formatDynamicAccessCoverage(DynamicAccessCoverage coverage) {\n../4649-a9dbf980/tests/tck-build-logic/src/main/java/org/graalvm/internal/tck/stats/ReadmeBadgeSummarySupport.java:891:        if (!coverage.available()) {\n../4649-a9dbf980/tests/tck-build-logic/src/main/java/org/graalvm/internal/tck/stats/ReadmeBadgeSummarySupport.java:894:        return formatPercent(coverage.coveragePercent())\n../4649-a9dbf980/tests/tck-build-logic/src/main/java/org/graalvm/internal/tck/stats/ReadmeBadgeSummarySupport.java:896:                + formatInteger(coverage.coveredCalls())\n../4649-a9dbf980/tests/tck-build-logic/src/main/java/org/graalvm/internal/tck/stats/ReadmeBadgeSummarySupport.java:898:                + formatInteger(coverage.totalCalls())\n../4649-a9dbf980/tests/tck-build-logic/src/main/java/org/graalvm/internal/tck/stats/ReadmeBadgeSummarySupport.java:1028:            int coverageStatsArtifacts,\n../4649-a9dbf980/tests/tck-build-logic/src/main/java/org/graalvm/internal/tck/stats/ReadmeBadgeSummarySupport.java:1065:            BigDecimal coveragePercent,\n../4649-a9dbf980/tests/tck-build-logic/src/main/java/org/graalvm/internal/tck/stats/ReadmeBadgeSummarySupport.java:1066:            long coveredCalls,\n../4649-a9dbf980/skills/review-library-new-request/SKILL.md:19:- Tests should execute under native image by default. Do not accept tests that disable themselves under native image. When a test exercises behavior that fundamentally relies on open-ended dynamic class loading that native image cannot support, such as loading classes, JARs, generated bytecode, plugin implementations, or other class definitions that are only discovered after the native executable is built, accept the `NativeImageSupport.isUnsupportedFeatureError(e)` catch pattern from `org.graalvm.internal.tck`. Reject raw native-only skips, bare `catch (Error)` blocks, and use of this pattern for ordinary reflection, resources, serialization, dynamic proxies, JNI, or missing reachability metadata.\n../4649-a9dbf980/skills/review-library-new-request/SKILL.md:21:- Require at least 50% reported dynamic-access coverage when there are dynamic-access calls to cover. Use the exploded stats files under `stats/<group>/<artifact>/<metadata-version>/stats.json` when available, and block the PR when dynamic-access coverage is below 50% or the PR provides no credible dynamic-access coverage evidence for non-zero dynamic-access calls.\n../4649-a9dbf980/skills/review-library-new-request/SKILL.md:22:- Treat dynamic-access coverage counts as a minimum gate, not complete metadata evidence. They can miss metadata required through downstream libraries, so do not use high coverage alone to prove that the submitted metadata is complete or necessary.\n../4649-a9dbf980/skills/review-library-new-request/SKILL.md:23:- Treat `0/0` dynamic-access coverage as a valid no-calls case, not as failed coverage. Do not reject a PR only because the exploded stats report `0/0` dynamic-access calls while the PR adds metadata; those stats can miss metadata required through downstream libraries.\n../4649-a9dbf980/skills/review-library-new-request/SKILL.md:24:- Do not explicitly read or review individual metadata entries. Use the metadata entry count reported in the PR description for the metadata/dynamic-access mismatch check; do not manually count entries from metadata files. When the PR reports both library metadata entries and test-only metadata entries, use their sum as the PR-reported metadata entry count. Only request investigation when the covered dynamic-access call count is at least 75% higher than that PR-reported total.\n../4649-a9dbf980/skills/review-library-new-request/SKILL.md:57:   - For metadata/dynamic-access mismatch checks, use only the metadata entry count reported in the PR description, such as `Metadata entries`, or legacy fields such as `Entries` and `Entries found` in older PRs; add `Test-only metadata entries` when the PR reports it; do not manually count metadata entries from files.\n../4649-a9dbf980/skills/review-library-new-request/SKILL.md:61:5. Compare the PR claims, test, and reported coverage as one unit.\n../4649-a9dbf980/skills/review-library-new-request/SKILL.md:62:   - If the PR claims specific coverage numbers that do not line up with the diff, ask for investigation.\n../4649-a9dbf980/skills/review-library-new-request/SKILL.md:63:   - Confirm reported dynamic-access coverage is at least 50% when the stats include dynamic-access calls.\n../4649-a9dbf980/skills/review-library-new-request/SKILL.md:64:   - If the PR reports zero dynamic-access calls and `reachability-metadata.json` is `{}`, that is acceptable as long as the test is library-specific and the scope is otherwise correct.\n../4649-a9dbf980/skills/review-library-new-request/SKILL.md:65:   - If the PR reports zero dynamic-access calls while adding metadata, do not reject it on that basis alone; dynamic-access stats can miss metadata required through downstream libraries.\n../4649-a9dbf980/skills/review-library-new-request/SKILL.md:66:   - If the stats report less than 50% coverage for non-zero dynamic-access calls, or no usable coverage signal for claimed dynamic-access behavior, ask for stronger tests or refreshed coverage evidence.\n../4649-a9dbf980/skills/review-library-new-request/SKILL.md:67:   - Ask for metadata/coverage mismatch investigation only when the covered dynamic-access call count is at least 75% higher than the PR-reported metadata entry count, where the reported count is `Metadata entries` plus `Test-only metadata entries` when both are present. For older PRs, use legacy `Entries` or `Entries found` as the metadata entry count.\n../4649-a9dbf980/skills/review-library-new-request/SKILL.md:90:  - Reported dynamic-access coverage is below 50% for non-zero dynamic-access calls, absent for claimed dynamic-access behavior, or not credible from the diff.\n../4649-a9dbf980/skills/review-library-new-request/SKILL.md:97:- For native skips that does not depend on the open-ended dynamic class loading: say that the PR avoids the failing native path instead of fixing it, so it does not demonstrate native-image runtime coverage.\n../4649-a9dbf980/skills/review-library-new-request/SKILL.md:101:- For insufficient dynamic-access coverage: say that new-library PRs need at least 50% dynamic-access coverage when there are dynamic-access calls to cover, and ask for stronger tests or refreshed coverage evidence.\n../4649-a9dbf980/skills/review-library-new-request/SKILL.md:102:- For unsupported coverage claims: ask for refreshed coverage evidence when the PR makes concrete coverage claims that are not supported by the diff.\n../4649-a9dbf980/skills/review-library-new-request/SKILL.md:103:- For metadata/dynamic-access entry mismatch: ask for investigation only when covered dynamic-access calls are at least 75% higher than the PR-reported metadata entry count, summing library and test-only metadata entries when both are reported. Do not manually count or argue from metadata contents.\n../4649-a9dbf980/skills/review-library-new-request/SKILL.md:163:        // Expected: Native Image cannot load classes from JARs discovered after build.\n../4649-a9dbf980/tests/tck-build-logic/src/main/java/org/graalvm/internal/tck/stats/LibraryStatsSupport.java:248:        ParsedDynamicAccess parsedDynamicAccess = parseDynamicAccessReports(dynamicAccessDir, libraryClasses, parsedJacocoReport.coveredLinesBySource());\n../4649-a9dbf980/tests/tck-build-logic/src/main/java/org/graalvm/internal/tck/stats/LibraryStatsSupport.java:296:        ParsedDynamicAccess parsedDynamicAccess = parseDynamicAccessReports(dynamicAccessDir, libraryClasses, parsedJacocoReport.coveredLinesBySource());\n../4649-a9dbf980/tests/tck-build-logic/src/main/java/org/graalvm/internal/tck/stats/LibraryStatsSupport.java:302:                        parsedDynamicAccess.dynamicAccessStats().coveredCalls()\n../4649-a9dbf980/tests/tck-build-logic/src/main/java/org/graalvm/internal/tck/stats/LibraryStatsSupport.java:463:                dynamicAccess.coveredCalls(),\n../4649-a9dbf980/tests/tck-build-logic/src/main/java/org/graalvm/internal/tck/stats/LibraryStatsSupport.java:464:                normalizeRatio(dynamicAccess.coverageRatio()),\n../4649-a9dbf980/tests/tck-build-logic/src/main/java/org/graalvm/internal/tck/stats/LibraryStatsSupport.java:478:                breakdown.coveredCalls(),\n../4649-a9dbf980/tests/tck-build-logic/src/main/java/org/graalvm/internal/tck/stats/LibraryStatsSupport.java:479:                normalizeRatio(breakdown.coverageRatio())\n../4649-a9dbf980/tests/tck-build-logic/src/main/java/org/graalvm/internal/tck/stats/LibraryStatsSupport.java:496:            LibraryStatsModels.CoverageMetricValue coverageMetricValue\n../4649-a9dbf980/tests/tck-build-logic/src/main/java/org/graalvm/internal/tck/stats/LibraryStatsSupport.java:498:        if (coverageMetricValue == null || !coverageMetricValue.isAvailable()) {\n../4649-a9dbf980/tests/tck-build-logic/src/main/java/org/graalvm/internal/tck/stats/LibraryStatsSupport.ja