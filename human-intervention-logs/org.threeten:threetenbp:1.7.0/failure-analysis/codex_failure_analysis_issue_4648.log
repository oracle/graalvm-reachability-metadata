/graalvm/internal/tck/stats/LibraryStatsModels.java:165:            long covered,\\n../4649-a9dbf980/tests/tck-build-logic/src/main/java/org/graalvm/internal/tck/stats/LibraryStatsModels.java:191:        public long covered() {\\n../4649-a9dbf980/tests/tck-build-logic/src/main/java/org/graalvm/internal/tck/stats/LibraryStatsModels.java:192:            return requireMetric().covered();\\n../4649-a9dbf980/tests/tck-build-logic/src/main/java/org/graalvm/internal/tck/stats/LibraryStatsModels.java:236:                JsonNode coveredNode = node.get(\\\"covered\\\");\\n../4649-a9dbf980/tests/tck-build-logic/src/main/java/org/graalvm/internal/tck/stats/LibraryStatsModels.java:240:                if (coveredNode != null && missedNode != null && totalNode != null && ratioNode != null) {\\n../4649-a9dbf980/tests/tck-build-logic/src/main/java/org/graalvm/internal/tck/stats/LibraryStatsModels.java:242:                            coveredNode.longValue(),\\n../4649-a9dbf980/tests/tck-build-logic/src/main/java/org/graalvm/internal/tck/stats/LibraryStatsModels.java:274:                JsonNode coveredCallsNode = node.get(\\\"coveredCalls\\\");\\n../4649-a9dbf980/tests/tck-build-logic/src/main/java/org/graalvm/internal/tck/stats/LibraryStatsModels.java:275:                JsonNode coverageRatioNode = node.get(\\\"coverageRatio\\\");\\n../4649-a9dbf980/tests/tck-build-logic/src/main/java/org/graalvm/internal/tck/stats/LibraryStatsModels.java:278:                if (coveredCallsNode != null && coverageRatioNode != null && totalCallsNode != null && breakdownNode != null) {\\n../4649-a9dbf980/COVERAGE.md:3:![Coverage over time](https://raw.githubusercontent.com/oracle/graalvm-reachability-metadata/stats/coverage/latest/metrics-over-time.svg)\\n../4649-a9dbf980/tests/tck-build-logic/src/main/groovy/org.graalvm.internal.tck-harness.gradle:219:    task.setDescription(\\\"Generates JaCoCo coverage reports for all subprojects (runs tests first)\\\")\\n../4649-a9dbf980/tests/tck-build-logic/s