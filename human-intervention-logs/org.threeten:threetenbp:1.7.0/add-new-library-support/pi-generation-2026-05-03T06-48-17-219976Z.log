[tool-call] delta {"path":"tests/src/org.threeten/threetenbp/1.7.0/src/test/java/org_threeten/threetenbp/ChronologyTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_threeten.threetenbp;\n\nimport static org.junit.jupiter.api.Assertions.assertSame;\n\nimport java.util.Locale;\n\nimport org.junit.jupiter.api.Test;\nimport org.threeten.bp.chrono.Chronology;\nimport org.threeten.bp.chrono.IsoChronology;\nimport org.threeten.bp.chrono.ThaiBuddhistChronology;\n\npublic class ChronologyTest {\n    @Test\n    void resolvesChronologyFromUnicodeLocaleCalendarExtension() {\n        Locale buddhistLocale = Locale.forLanguageTag(\"th-TH-u-ca-buddhist\");\n\n        Chronology chronology = Chronology.ofLocale(buddhistLocale);\n\n        assertSame(ThaiBuddhistChronology.INSTANCE, chronology);\n    }\n\n    @Test\n    void resolvesIsoChronologyWhenLocaleHasNoCalendarExtension() {\n        Chronology chronology = Chronology.ofLocale(Locale.US);\n\n        assertSame(IsoChronology.INSTANCE, chronology);\n    }\n}\n"}
