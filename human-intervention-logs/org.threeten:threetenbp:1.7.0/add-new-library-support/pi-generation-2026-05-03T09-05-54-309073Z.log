  package org_threeten.threetenbp;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.util.Locale;
  
  import org.junit.jupiter.api.Test;
  import org.threeten.bp.chrono.Chronology;
  import org.threeten.bp.chrono.IsoChronology;
  import org.threeten.bp.chrono.JapaneseChronology;
  import org.threeten.bp.chrono.MinguoChronology;
  import org.threeten.bp.chrono.ThaiBuddhistChronology;
  
  public class ChronologyTest {
      @Test
      void ofLocaleResolvesUnicodeCalendarExtension() {
          assertThat(Chronology.ofLocale(Locale.forLanguageTag("en-US-u-ca-japanese")))
                  .isSameAs(JapaneseChronology.INSTANCE);
          assertThat(Chronology.ofLocale(Locale.forLanguageTag("zh-TW-u-ca-roc")))
                  .isSameAs(MinguoChronology.INSTANCE);
          assertThat(Chronology.ofLocale(Locale.forLanguageTag("th-TH-u-ca-buddhist")))
                  .isSameAs(ThaiBuddhistChronology.INSTANCE);
      }
  
      @Test
      void ofLocaleDefaultsToIsoChronologyWithoutCalendarExtension() {
          assertThat(Chronology.ofLocale(Locale.US))
                  .isSameAs(IsoChronology.INSTANCE);
      }
  }
