[tool-call] delta {"path":"tests/src/org.threeten/threetenbp/1.7.0/src/test/java/org_threeten/threetenbp/ChronologyTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_threeten.threetenbp;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.util.Locale;\n\nimport org.junit.jupiter.api.Test;\nimport org.threeten.bp.chrono.Chronology;\nimport org.threeten.bp.chrono.IsoChronology;\nimport org.threeten.bp.chrono.MinguoChronology;\nimport org.threeten.bp.chrono.ThaiBuddhistChronology;\n\npublic class ChronologyTest {\n    @Test\n    void resolvesChronologyFromLocaleCalendarExtension() {\n        Locale buddhistLocale = Locale.forLanguageTag(\"th-TH-u-ca-buddhist\");\n        Locale minguoLocale = Locale.forLanguageTag(\"zh-TW-u-ca-roc\");\n        Locale isoLocale = Locale.forLanguageTag(\"en-US-u-ca-iso8601\");\n\n        assertThat(Chronology.ofLocale(buddhistLocale)).isSameAs(ThaiBuddhistChronology.INSTANCE);\n        assertThat(Chronology.ofLocale(minguoLocale)).isSameAs(MinguoChronology.INSTANCE);\n        assertThat(Chronology.ofLocale(isoLocale)).isSameAs(IsoChronology.INSTANCE);\n    }\n}\n"}
