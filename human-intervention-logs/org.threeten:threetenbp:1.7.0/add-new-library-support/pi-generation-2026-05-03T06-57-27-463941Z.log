  package org_threeten.threetenbp;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.util.Locale;
  
  import org.junit.jupiter.api.Test;
  import org.threeten.bp.LocalDate;
  import org.threeten.bp.chrono.ChronoLocalDate;
  import org.threeten.bp.chrono.Chronology;
  import org.threeten.bp.chrono.ThaiBuddhistChronology;
  import org.threeten.bp.temporal.ChronoField;
  
  public class ChronologyTest {
      @Test
      void resolvesCalendarSystemFromLocaleUnicodeExtension() {
          Locale thaiBuddhistLocale = Locale.forLanguageTag("th-TH-u-ca-buddhist");
  
          Chronology chronology = Chronology.ofLocale(thaiBuddhistLocale);
  
          ChronoLocalDate buddhistDate = chronology.date(LocalDate.of(2024, 1, 1));
          assertThat(chronology).isSameAs(ThaiBuddhistChronology.INSTANCE);
          assertThat(buddhistDate.getChronology()).isSameAs(ThaiBuddhistChronology.INSTANCE);
          assertThat(buddhistDate.get(ChronoField.YEAR)).isEqualTo(2567);
      }
  }
