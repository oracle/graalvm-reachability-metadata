{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Artifact-indexed library stats",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "entries"
  ],
  "properties": {
    "entries": {
      "type": "object",
      "propertyNames": {
        "pattern": "^[^:\\s]+:[^:\\s]+$"
      },
      "additionalProperties": {
        "$ref": "#/definitions/artifactStats"
      }
    }
  },
  "examples": [
    {
      "entries": {
        "org.example:demo-lib": {
          "metadataVersions": {
            "1.0.0": {
              "versions": [
                {
                  "dynamicAccess": {
                    "breakdown": {
                      "foreign": {
                        "coveredCalls": 2,
                        "coverageRatio": 1.0,
                        "totalCalls": 2
                      },
                      "reflection": {
                        "coveredCalls": 5,
                        "coverageRatio": 0.625,
                        "totalCalls": 8
                      }
                    },
                    "coveredCalls": 7,
                    "coverageRatio": 0.7,
                    "totalCalls": 10
                  },
                  "libraryCoverage": {
                    "instruction": {
                      "covered": 140,
                      "missed": 35,
                      "ratio": 0.8,
                      "total": 175
                    },
                    "line": {
                      "covered": 60,
                      "missed": 20,
                      "ratio": 0.75,
                      "total": 80
                    },
                    "method": {
                      "covered": 32,
                      "missed": 8,
                      "ratio": 0.8,
                      "total": 40
                    }
                  },
                  "version": "1.2.3"
                },
                {
                  "dynamicAccess": {
                    "breakdown": {
                      "foreign": {
                        "coveredCalls": 3,
                        "coverageRatio": 1.0,
                        "totalCalls": 3
                      },
                      "resources": {
                        "coveredCalls": 4,
                        "coverageRatio": 0.666667,
                        "totalCalls": 6
                      },
                      "reflection": {
                        "coveredCalls": 6,
                        "coverageRatio": 0.75,
                        "totalCalls": 8
                      }
                    },
                    "coveredCalls": 13,
                    "coverageRatio": 0.764706,
                    "totalCalls": 17
                  },
                  "libraryCoverage": {
                    "instruction": {
                      "covered": 155,
                      "missed": 20,
                      "ratio": 0.885714,
                      "total": 175
                    },
                    "line": {
                      "covered": 67,
                      "missed": 13,
                      "ratio": 0.8375,
                      "total": 80
                    },
                    "method": {
                      "covered": 34,
                      "missed": 6,
                      "ratio": 0.85,
                      "total": 40
                    }
                  },
                  "version": "1.2.4"
                }
              ]
            },
            "2.0.0": {
              "versions": [
                {
                  "dynamicAccess": {
                    "breakdown": {
                      "foreign": {
                        "coveredCalls": 4,
                        "coverageRatio": 0.8,
                        "totalCalls": 5
                      },
                      "resources": {
                        "coveredCalls": 2,
                        "coverageRatio": 0.4,
                        "totalCalls": 5
                      },
                      "reflection": {
                        "coveredCalls": 10,
                        "coverageRatio": 0.909091,
                        "totalCalls": 11
                      }
                    },
                    "coveredCalls": 16,
                    "coverageRatio": 0.761905,
                    "totalCalls": 21
                  },
                  "libraryCoverage": {
                    "instruction": {
                      "covered": 210,
                      "missed": 30,
                      "ratio": 0.875,
                      "total": 240
                    },
                    "line": {
                      "covered": 95,
                      "missed": 15,
                      "ratio": 0.863636,
                      "total": 110
                    },
                    "method": {
                      "covered": 50,
                      "missed": 10,
                      "ratio": 0.833333,
                      "total": 60
                    }
                  },
                  "version": "2.0.1"
                }
              ]
            }
          }
        }
      }
    }
  ],
  "definitions": {
    "ratio": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "coverageMetric": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "covered",
        "missed",
        "ratio",
        "total"
      ],
      "properties": {
        "covered": {
          "type": "integer",
          "minimum": 0
        },
        "missed": {
          "type": "integer",
          "minimum": 0
        },
        "ratio": {
          "$ref": "#/definitions/ratio"
        },
        "total": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "coverageMetricOrNa": {
      "oneOf": [
        {
          "$ref": "#/definitions/coverageMetric"
        },
        {
          "type": "string",
          "enum": [
            "N/A"
          ]
        }
      ]
    },
    "dynamicAccessBreakdown": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "coveredCalls",
        "coverageRatio",
        "totalCalls"
      ],
      "properties": {
        "coveredCalls": {
          "type": "integer",
          "minimum": 0
        },
        "coverageRatio": {
          "$ref": "#/definitions/ratio"
        },
        "totalCalls": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "dynamicAccessStats": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "breakdown",
        "coveredCalls",
        "coverageRatio",
        "totalCalls"
      ],
      "properties": {
        "breakdown": {
          "type": "object",
          "propertyNames": {
            "enum": [
              "foreign",
              "reflection",
              "resources"
            ]
          },
          "additionalProperties": {
            "$ref": "#/definitions/dynamicAccessBreakdown"
          }
        },
        "coveredCalls": {
          "type": "integer",
          "minimum": 0
        },
        "coverageRatio": {
          "$ref": "#/definitions/ratio"
        },
        "totalCalls": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "dynamicAccessStatsOrNa": {
      "oneOf": [
        {
          "$ref": "#/definitions/dynamicAccessStats"
        },
        {
          "type": "string",
          "enum": [
            "N/A"
          ]
        }
      ]
    },
    "libraryCoverage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "instruction",
        "line",
        "method"
      ],
      "properties": {
        "instruction": {
          "$ref": "#/definitions/coverageMetricOrNa"
        },
        "line": {
          "$ref": "#/definitions/coverageMetricOrNa"
        },
        "method": {
          "$ref": "#/definitions/coverageMetricOrNa"
        }
      }
    },
    "versionStats": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dynamicAccess",
        "libraryCoverage",
        "version"
      ],
      "properties": {
        "dynamicAccess": {
          "$ref": "#/definitions/dynamicAccessStatsOrNa"
        },
        "libraryCoverage": {
          "$ref": "#/definitions/libraryCoverage"
        },
        "version": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "metadataVersionStats": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "versions"
      ],
      "properties": {
        "versions": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/versionStats"
          }
        }
      }
    },
    "artifactStats": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "metadataVersions"
      ],
      "properties": {
        "metadataVersions": {
          "type": "object",
          "propertyNames": {
            "type": "string",
            "minLength": 1
          },
          "additionalProperties": {
            "$ref": "#/definitions/metadataVersionStats"
          }
        }
      }
    }
  }
}
